;;; std/order — back-compat shim.
;;;
;;; `order` is now a MODULE: its directory `std/order/` holds the interface
;;; `mod.req.shard` (the public surface) and, in time, private impl files.
;;; This file preserves the old import path `std/order.shard` by forwarding
;;; to the module directory; existing importers keep working unchanged while
;;; the stdlib migrates to the directory-per-module layout.
(import "order")
