         (steps ((rewrite (premise lt0) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w0) lr rhs true ())))
    refl))

(claim lowered_rng_val
  (goal
    ((x0 Int)
     (x1 Int)
     (f0 Func)
     (f1 Func)
     (f2 Func)
     (c Nat)
     (restfs (List Func)))
    ((= (le 0 x0) True) (= (lt x0 4294967296) True) (= (le 1 x1) True))
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons
            f0
            (Cons
              f1
              (Cons
                f2
                (Cons
                  (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BRemU)))
                  restfs))))
          0)
        3
        (list x0 x1))
      (Some (rng_val (u32 x0) x1))))
  (chain
    (steps ((compute lhs) (unfold rng_val rhs) (reduce rhs)))
    (steps ((rewrite (premise 2) lr lhs true ()) (compute lhs)))
    (have a0 (= (u32_val (u32 x0)) x0)
      (chain
        (rewrite-with (lemma u32_val_of) lr lhs ((inst nn x0)) ())
        (rewrite-with
          (lemma wrap32_id)
          lr
          lhs
          ((inst x x0))
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl)))
    (steps ((rewrite (premise a0) lr rhs true ())))
    refl))

;; the lib module: every fn of the file at its source-order index
(fn rng_wmod () WModule
  (MkWModule
    (Cons
      (MkFunc
        1
        2
        (list
          (LocalGet 0)
          (I32Const 8192)
          (LocalGet 0)
          (I32Bin BMul)
          (I32Bin BXor)
          (LocalSet 1)
          (LocalGet 1)
          (LocalGet 1)
          (I32Const 131072)
          (I32Bin BDivU)
          (I32Bin BXor)
          (LocalSet 2)
          (LocalGet 2)
          (I32Const 32)
          (LocalGet 2)
          (I32Bin BMul)
          (I32Bin BXor)))
      (Cons
        (MkFunc
          1
          2
          (list
            (LocalGet 0)
            (LocalSet 1)
            (Block
              (list
                (Block
                  (list
                    (LocalGet 1)
                    (I32Const 0)
                    (I32Bin BEq)
                    (BrIf 0)
                    (LocalGet 1)
                    (Call 0)
                    (Call 0)
                    (LocalSet 2)
                    (Br 1)))
                (I32Const 2463534242)
                (Call 0)
                (Call 0)
                (LocalSet 2)))
            (LocalGet 2)))
        (Cons
          (MkFunc 1 0 (list (LocalGet 0) (Call 0)))
          (Cons
            (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BRemU)))
            Nil))))
    0))

;; the export table: the (lib …) declaration's names, by index
(fn rng_exports () (List WExport)
  (list (WX "rng_seed" 1) (WX "rng_step" 2) (WX "rng_val" 3)))

;; the encoded lib binary: the module + named exports through enc_lib
(fn rng_bytes () (List Int) (enc_lib (rng_wmod) (rng_exports)))
