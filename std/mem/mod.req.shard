;;; std/mem/mod.req.shard — the PUBLIC INTERFACE of the `mem` module (its ".h").
;;;
;;; The generic byte-addressed memory substrate (the Mem arc, docs/ISA.md §10):
;;; ONE flat memory type intended to back every byte-addressed little-endian
;;; ISA model (wasm32, x86-64, …). The substrate is deliberately the pure
;;; mathematical object — an UNBOUNDED, default-zero map from Int addresses
;;; to byte values. Everything ISAs disagree on (bounds/trap semantics, page
;;; growth, alignment) is layered in each ISA model, NOT here.
;;;
;;; Totality is wasm-style: a read of an unwritten cell returns 0; every read
;;; is a byte (0 <= mem_get < 256 UNCONDITIONALLY — reads re-canonicalize);
;;; a store TRUNCATES (reading back a store of v gives v mod 256). No Option,
;;; no bounds, no traps.
;;;
;;; DISCIPLINE (why there is no mem_eq): theorems compare OBSERVATIONS
;;; (mem_get probes), never Mem values — two observationally equal memories
;;; need not be structurally equal, so value equality stays off the surface.
;;; Same rule as std/map. The sanctioned spelling for "the memory holds these
;;; cells" is reading them back out (see examples/mem_reverse.shard).

(import "../../kernel/stdlib.shard")  ; Int / Bool / True / Nat
(import "../nat")  ; int_of_nat — the width bound in the framing laws
(use (:: std nat int_of_nat))

;; an opaque flat byte memory.
(sig type Mem)

(sig fn mem_empty () Mem)  ; all cells read 0
(sig fn mem_get ((m Mem) (a Int)) Int)  ; the byte at address a
(sig fn mem_set ((m Mem) (a Int) (v Int)) Mem)  ; store v (truncated) at a

;; --- the framing algebra (consumers reason against THIS) -------------------

;; the empty memory reads 0 everywhere.
(requirement get_empty (goal ((a Int)) () (= (mem_get (mem_empty) a) 0)))

;; every read is a byte: non-negative…
(requirement get_lo (goal ((m Mem) (a Int)) () (= (le 0 (mem_get m a)) True)))

;; …and below 256. (Unconditional — no premise about how m was built.)
(requirement get_hi (goal ((m Mem) (a Int)) () (= (lt (mem_get m a) 256) True)))

;; read back the cell you just wrote: stores truncate mod 256.
(requirement get_set
  (goal ((m Mem) (a Int) (v Int)) ()
    (= (mem_get (mem_set m a v) a) (mod v 256))))

;; the in-range corollary: a byte value reads back exactly.
(requirement get_set_byte
  (goal ((m Mem) (a Int) (v Int)) ((= (le 0 v) True) (= (lt v 256) True))
    (= (mem_get (mem_set m a v) a) v)))

;; writing a READ back reads back exactly (reads are bytes by get_lo/get_hi) —
;; the form in-place algorithms lean on (a swap is two of these).
(requirement get_set_get
  (goal ((m Mem) (a Int) (m2 Mem) (b Int)) ()
    (= (mem_get (mem_set m a (mem_get m2 b)) a) (mem_get m2 b))))

;; a store at a different address is invisible to a read: THE framing law.
(requirement get_set_other
  (goal ((m Mem) (a Int) (b Int) (v Int)) ((= (int_eq b a) False))
    (= (mem_get (mem_set m a v) b) (mem_get m b))))

;; --- little-endian words (the multi-byte view every LE ISA shares) ----------
;;
;; load_le/store_le read/write a w-byte little-endian word (byte at the lowest
;; address = least significant). Width is a STRUCTURAL Nat so consumers unfold
;; one byte per ι-step and the law proofs are ordinary inductions; the widths
;; that matter are tiny ((S Z) / two / four). store_le stores the raw
;; quotient chain — mem_get's masking makes each byte a byte, so the store
;; needs no masking of its own. The defining equations are exported (the
;; weaning technique): a consumer can always unfold a concrete-width access
;; by rewriting; the framing and round-trip laws below are the closed forms.

(sig fn load_le ((w Nat) (m Mem) (a Int)) Int)
(sig fn store_le ((w Nat) (m Mem) (a Int) (v Int)) Mem)

;; defining equations.
(requirement load_le_z (goal ((m Mem) (a Int)) () (= (load_le Z m a) 0)))

(requirement load_le_s
  (goal ((w Nat) (m Mem) (a Int)) ()
    (= (load_le (S w) m a) (+ (mem_get m a) (* 256 (load_le w m (+ a 1)))))))

(requirement store_le_z
  (goal ((m Mem) (a Int) (v Int)) () (= (store_le Z m a v) m)))

(requirement store_le_s
  (goal ((w Nat) (m Mem) (a Int) (v Int)) ()
    (= (store_le (S w) m a v) (store_le w (mem_set m a v) (+ a 1) (ediv v 256)))))

;; --- word-level framing: a store is invisible outside [a, a+w) --------------

;; a byte read strictly below the stored range is untouched.
(requirement store_le_get_below
  (goal ((w Nat) (m Mem) (a Int) (v Int) (b Int)) ((= (lt b a) True))
    (= (mem_get (store_le w m a v) b) (mem_get m b))))

;; a byte read at or above the stored range's end is untouched.
(requirement store_le_get_above
  (goal ((w Nat) (m Mem) (a Int) (v Int) (b Int))
    ((= (le (+ a (int_of_nat w)) b) True))
    (= (mem_get (store_le w m a v) b) (mem_get m b))))

;; --- word round trips at the widths wasm speaks (1, 2, 4 bytes) -------------
;;
;; Reading back a just-stored in-range word is the identity. Stated at
;; LITERAL widths: the in-range bound is then a literal too (no pow on the
;; surface), and these are the only widths a wasm32 model needs. Out-of-range
;; stores still truncate per byte (get_set) — unfold by the defining
;; equations if you need the masked general form.

(requirement ls1_id
  (goal ((m Mem) (a Int) (v Int)) ((= (le 0 v) True) (= (lt v 256) True))
    (= (load_le (S Z) (store_le (S Z) m a v) a) v)))

(requirement ls2_id
  (goal ((m Mem) (a Int) (v Int)) ((= (le 0 v) True) (= (lt v 65536) True))
    (= (load_le (S (S Z)) (store_le (S (S Z)) m a v) a) v)))

(requirement ls4_id
  (goal ((m Mem) (a Int) (v Int)) ((= (le 0 v) True) (= (lt v 4294967296) True))
    (= (load_le (S (S (S (S Z)))) (store_le (S (S (S (S Z)))) m a v) a) v)))

;; --- the aggregate readback view: w bytes at [a, a+w) as a list -------------
;;
;; mem_read is the ABSTRACTION FUNCTION aggregate rep relations are stated
;; with (docs/LOWERING.md §6p-§6r): "(mem_read w m a) = bs" says the memory
;; holds the list bs at a — an EQUATION, never a Bool predicate, so consumers
;; never invert an invariant. Width is a STRUCTURAL Nat like load_le's and
;; the defining equations are exported (the weaning technique). The framing
;; laws are the window-level get_set_other: a store OUTSIDE [a, a+w) is
;; invisible to the readback — below takes the strict bound, above takes the
;; window-end bound; a store INSIDE the window has no closed form here
;; (unfold to the byte level).

(sig fn mem_read ((w Nat) (m Mem) (a Int)) (List Int))

;; defining equations.
(requirement mem_read_z (goal ((m Mem) (a Int)) () (= (mem_read Z m a) Nil)))

(requirement mem_read_s
  (goal ((w Nat) (m Mem) (a Int)) ()
    (= (mem_read (S w) m a) (Cons (mem_get m a) (mem_read w m (+ a 1))))))

;; a store strictly below the window is invisible to the readback.
(requirement mem_read_set_below
  (goal ((w Nat) (m Mem) (a Int) (b Int) (v Int)) ((= (lt b a) True))
    (= (mem_read w (mem_set m b v) a) (mem_read w m a))))

;; a store at or above the window's end is invisible to the readback.
(requirement mem_read_set_above
  (goal ((w Nat) (m Mem) (a Int) (b Int) (v Int))
    ((= (le (+ a (int_of_nat w)) b) True))
    (= (mem_read w (mem_set m b v) a) (mem_read w m a))))
