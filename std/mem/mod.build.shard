;;; std/mem/mod.build.shard — std/mem's BUILD ENTRY (docs/LOWERING.md §6):
;;; assembles the module's wasm artifact set as a native Plan value.
;;;
;;;     (fn build ((t Target)) Plan)     — PURE; the whole interface
;;;
;;; The driver (tools/lowbuild/lowbuild.shard) loads this file's closure at
;;; runtime, constructs the Target compile-context, calls build across the
;;; meta-level boundary, and renders wire formats at the boundary. No main,
;;; no World, no text rendering here — that whole layer was the retired
;;; v1 plan-on-stdout form. std/mem is still not special to any compiler
;;; machinery: this file is ordinary shard, and an override would return
;;; the same statements (variant selection stays explicit build-entry data).
;;;
;;; The plan: one module "stdmem" — the certs' module at restfs := Nil
;;; ([mget, mset], linear memory from the Target), two manifest entries
;;; (lowered_mem_get covers f0, lowered_mem_set covers f1), five engine
;;; vectors with expected value AND memory readback computed from the
;;; SOURCE surface (mem_get/mem_set applied directly — spec-side semantics,
;;; not the model; the artifact-level differential).
;;;
;;; RUN IT:  bin/shard_eval run tools/lowbuild/lowbuild.shard std/mem/mod.build.shard | node examples/wasm_diff.mjs /dev/stdin

(import "../../kernel/stdlib.shard")
(import "../../std/mem")  ; interface in check; IMPL in run — spec-side expected values
(import "mem.wasm.shard")  ; the artifact fns + certs
(import "../../models/wasm/wasm.shard")
(import "../../models/wasm/encode.shard")
(import "../../tools/low/plan.shard")
(use (:: std mem *))
(use (:: std mem mem.wasm *))
(use (:: models wasm wasm *))
(use (:: models wasm encode *))
(use (:: tools low plan *))

;; the shipped binary: both certs' module literal at restfs := Nil.
(fn stdmem_mod ((limit Int)) WModule (MkWModule (list (mget_f) (mset_f)) limit))

;; --- spec-side memory helpers ---------------------------------------------------

;; preload bytes at address 0 (the vector's initial memory image)
(fn mload ((bs (List Int)) (a Int) (m Mem)) Mem
  (measure (struct bs))
  (match bs
    (Nil m)
    ((Cons b t) (mload t (+ a 1) (mem_set m a b)))))

;; read n bytes from address 0 (the vector's final-memory readback)
(fn mdump ((a Int) (n Nat) (m Mem)) (List Int)
  (measure (struct n))
  (match n
    (Z Nil)
    ((S k) (Cons (mem_get m a) (mdump (+ a 1) k m)))))

(fn len_nat ((xs (List Int))) Nat
  (measure (struct xs))
  (match xs
    (Nil Z)
    ((Cons _ t) (S (len_nat t)))))

;; --- the vectors: spec-side denotations of the two exports ----------------------

(fn vec_get ((membytes (List Int)) (a Int)) PVec
  (match (mload membytes 0 (mem_empty))
    (m (PV 0 (list a) membytes (mem_get m a) (mdump 0 (len_nat membytes) m)))))

(fn vec_set ((membytes (List Int)) (a Int) (v Int)) PVec
  (match (mload membytes 0 (mem_empty))
    (m
      (PV 1 (list a v) membytes v (mdump 0 (len_nat membytes) (mem_set m a v))))))

;; --- the build entry -------------------------------------------------------------

(fn art ((nm (List Int)) (cert (List Int)) (k Int)) PArt
  (PA nm cert "std/mem/mem.wasm.shard" "models/wasm/wasm.shard" k "" "none"))

(fn build ((t Target)) Plan
  (MkPlan
    (list
      (PM
        "stdmem"
        (enc_module (stdmem_mod (mem_limit_of t)))
        (list
          (art "mem_get" "lowered_mem_get" 0)
          (art "mem_set" "lowered_mem_set" 1))
        (list
          (vec_get (list 5 7 11 13) 2)
          (vec_get (list 200 1) 0)
          (vec_set (list 5 7 11 13 17 19) 3 200)
          (vec_set (list 5 7 11 13) 1 999)
          (vec_set (list 9) 0 0))))))
