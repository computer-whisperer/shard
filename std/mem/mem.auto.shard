(proof-for
  get_set_byte
  (steps
    ((rewrite (lemma gs_i) lr lhs true ()))
    (rewrite-with
      (lemma mod_byte_id)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl))
      refl)))
(proof-for
  get_set_get
  (steps
    ((rewrite (lemma gs_i) lr lhs true ()) (unfold mem_get both))
    (rewrite-with
      (lemma mod_byte_id)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma mod_lo)
         lr
         lhs
         ()
         ((steps ((compute both)) refl))
         refl)
       (rewrite-with
         (lemma mod_hi)
         lr
         lhs
         ()
         ((steps ((compute both)) refl))
         refl))
      refl)))
