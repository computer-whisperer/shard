;;; std/nat/nat.shard — the `nat` module IMPLEMENTATION (private).
;;;
;;; Supplies the bodies behind the interface's `sig fn`s, the private helper
;;; `half_step`, and the `fulfills` proofs that discharge the interface's
;;; requirements. It imports its own interface as an ordinary `.shard` FILE
;;; (ungranted), so the requirements load FIRST as obligations and the bodies
;;; shadow the sigs — the proofs here MAY unfold/simp them, which is sound
;;; because the module is reasoning about its OWN implementation. Consumers
;;; never load this file (they get only mod.req.shard).

(import "../../kernel/stdlib.shard")
(import "../order")  ; le0_succ (cited by int_of_nat_nonneg's proof)
(import "mod.req.shard")  ; our interface — requirements + Nat + the sigs

;; ---- bodies (behind the interface's opaque sig fns) ----

(fn add_nat ((a Nat) (b Nat)) Nat
  (match a
    (Z b)
    ((S k) (S (add_nat k b)))))

;; Nat → Int (structural on the Nat).
(fn int_of_nat ((n Nat)) Int
  (match n
    (Z 0)
    ((S k) (+ 1 (int_of_nat k)))))

;; floor(n/2) as a Nat (structural, two S's at a time).
(fn half_nat ((n Nat)) Nat
  (match n
    (Z Z)
    ((S k)
     (match k
       (Z Z)
       ((S k2) (S (half_nat k2)))))))

;; ---- private helper ----

;; half_step: the two-step inductive step for half_bound, with the IH's
;; inequality supplied as a premise (farkas can't read the Induct2 hyp
;; directly). X = int_of_nat k, Y = int_of_nat (half_nat k); the goal is the
;; simp-normalized half_bound at S (S k). Pure linear arithmetic. PRIVATE — the
;; gate rejects any citation of `half_step` from OUTSIDE this module.
(claim half_step
  (goal ((X Int) (Y Int)) ((= (le (- X 1) (* 2 Y)) True))
    (= (le (- (+ 1 (+ 1 X)) 1) (* 2 (+ 1 Y))) True))
  (by arith (list 1 1)))

;; ---- discharge the interface's requirements (proofs may use the bodies) ----

;; int_of_nat over a successor — the module may unfold its OWN body (a consumer
;; may not); one unfold + reduce fires the S arm to (+ 1 (int_of_nat k)).
(fulfills int_of_nat_succ (steps ((unfold int_of_nat lhs) (reduce lhs)) refl))

;; int_of_nat at zero — unfold the body to fire the Z arm to 0.
(fulfills int_of_nat_zero (steps ((unfold int_of_nat lhs) (reduce lhs)) refl))

;; int_of_nat is nonnegative. Induction on n; the S case threads the IH through
;; le0_succ's premise (farkas can't see the hyp directly).
(fulfills int_of_nat_nonneg
  (induct n
    ((case Z (steps ((simp lhs)) refl))
     (case S
       (steps
         ((simp lhs))  ; (le 0 (+ 1 (int_of_nat k)))
         (rewrite-with
           (lemma le0_succ)
           lr
           lhs
           ()
           ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
           refl))))))

;; half_bound by two-step induction: the Z and (S Z) arms close by simp; the
;; (S (S k)) arm simp-normalizes and hands the IH (at k) to the private half_step.
(fulfills half_bound
  (induct2
    m
    ((case Z (steps ((simp lhs)) refl))
     (case SZ (steps ((simp lhs)) refl))
     (case SS
       (steps
         ((simp lhs))
         (rewrite-with
           (lemma half_step)
           lr
           lhs
           ()
           ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
           refl))))))
