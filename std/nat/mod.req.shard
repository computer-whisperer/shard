;;; std/nat/mod.req.shard — the PUBLIC INTERFACE of the `nat` module (its ".h").
;;;
;;; BODYLESS by design. The public surface is: the `Nat` type, OPAQUE function
;;; signatures (`sig fn` — consumers reason about these ONLY through the lemmas
;;; below, never by unfolding a body), and the promised lemmas as
;;; `requirement`s. The dir-mate `nat.shard` supplies the bodies, the private
;;; `half_step`, and the `fulfills` proofs. A consumer that imports `nat` sees
;;; exactly this file; it cannot cite a private nor unfold an implementation.

(import "../../kernel/stdlib.shard")   ; Int/Bool/True for the lemma goals

(type Nat
  (Z)
  (S Nat))

;; Opaque signatures — bodies live in nat.shard, hidden from consumers. A
;; consumer reasons about `add_nat`/`int_of_nat`/`half_nat` only via the lemmas.
(sig fn add_nat    ((a Nat) (b Nat)) Nat)
(sig fn int_of_nat ((n Nat))         Int)
(sig fn half_nat   ((n Nat))         Nat)

;; ---- promised lemmas (the SPEC consumers reason against; proven in nat.shard) ----

;; int_of_nat is nonnegative.
(requirement int_of_nat_nonneg
  (goal ((n Nat)) ()
    (= (le 0 (int_of_nat n)) True)))

;; int_of_nat advances over a successor — the definitional step, exported so a
;; consumer can rewrite `int_of_nat (S k)` → `1 + int_of_nat k` WITHOUT unfolding
;; the opaque body (wanted by std/mem's dump/rdump index arithmetic).
(requirement int_of_nat_succ
  (goal ((k Nat)) ()
    (= (int_of_nat (S k)) (+ 1 (int_of_nat k)))))

;; int_of_nat m - 1 <= 2 * int_of_nat (half_nat m), for all m (tight at both
;; parities) — the loop's floor(m/2) swaps cover a segment of length m.
(requirement half_bound
  (goal ((m Nat)) ()
    (= (le (- (int_of_nat m) 1) (* 2 (int_of_nat (half_nat m)))) True)))
