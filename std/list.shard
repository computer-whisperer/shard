;;; std/list — back-compat shim.
;;;
;;; `list` is now a directory-module: `std/list/` holds the interface
;;; `mod.req.shard` (public: opaque append/len/rev sig fns + the append/len/rev
;;; algebra lemmas) and `list.shard` (the bodies + `fulfills` proofs). This file
;;; preserves the old import path `std/list.shard` by forwarding to the module;
;;; per mode-aware resolution, importers reasoning in PROOFS get the opaque
;;; interface, importers that RUN get the real bodies.
(import "list")
