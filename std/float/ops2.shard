;; The main theorem: fadd2 = fadd on well-formed views. The NaN/Inf table
;; arms mirror verbatim (unfold + reduce meet by refl); the both-zero arm is
;; the shared sign-keep spelling; the generic arms select the zero guards,
;; open the aligned-sum let, collapse the gap alternation with selector
;; equations, and close by the direction core. (The fwf premises are carried
;; for interface uniformity with fmul2_fmul/fdiv2_fdiv; the add equality
;; needs no shape facts — sv's own dispatch supplies the magnitude bounds.)
(claim fadd2_fadd
  (goal ((f Fmt) (x FVal) (y FVal)) ((= (fwf f x) True) (= (fwf f y) True))
    (= (fadd2 f x y) (fadd f x y)))
  (case-on x FVal
    ((case Fin
       (s1 m1 e1)
       (case-on y FVal
         ((case Fin
            (s2 m2 e2)
            (chain
              (have hxe (= x (Fin s1 m1 e1))
                (steps ((rewrite (hyp 1) lr lhs true ())) refl))
              (have hye (= y (Fin s2 m2 e2))
                (steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (case-on (int_eq m1 0) Bool
                ((case True
                   (chain
                     (have hz1 (= (int_eq m1 0) True)
                       (steps ((rewrite (hyp True) lr lhs true ())) refl))
                     (case-on (int_eq m2 0) Bool
                       ((case True
                          (chain
                            (have hz2 (= (int_eq m2 0) True)
                              (steps ((rewrite (hyp True) lr lhs true ())) refl))
                            (steps
                              ((rewrite (premise hxe) lr lhs true ())
                               (rewrite (premise hxe) lr rhs true ())
                               (rewrite (premise hye) lr lhs true ())
                               (rewrite (premise hye) lr rhs true ())
                               (unfold fadd2 lhs)
                               (reduce lhs)
                               (unfold fadd rhs)
                               (reduce rhs)
                               (rewrite (premise hz1) lr lhs true ())
                               (rewrite (premise hz1) lr rhs true ())
                               (rewrite (premise hz2) lr lhs true ())
                               (rewrite (premise hz2) lr rhs true ())
                               (simp lhs)
                               (simp rhs))
                              refl)))
                        (case False
                          (chain
                            (have hz2 (= (int_eq m2 0) False)
                              (steps
                                ((rewrite (hyp False) lr lhs true ()))
                                refl))
                            (case-on (le e1 e2) Bool
                              ((case True
                                 (chain
                                   (have hgap (= (le e1 e2) True)
                                     (steps
                                       ((rewrite (hyp True) lr lhs true ()))
                                       refl))
                                   (have hsv
                                     (=
                                       (if (le e1 e2)
                                         (+
                                           (if s1 (- 0 m1) m1)
                                           (if s2 (- 0 (* m2 (fpow2 (- e2 e1))))
                                           (* m2 (fpow2 (- e2 e1)))))
                                         (+
                                           (if s1 (- 0 (* m1 (fpow2 (- e1 e2))))
                                           (* m1 (fpow2 (- e1 e2))))
                                           (if s2 (- 0 m2) m2)))
                                       (+
                                         (if s1 (- 0 m1) m1)
                                         (if s2 (- 0 (* m2 (fpow2 (- e2 e1))))
                                         (* m2 (fpow2 (- e2 e1))))))
                                     (steps
                                       ((rewrite (premise hgap) lr lhs true ())
                                        (simp lhs))
                                       refl))
                                   (have hbase
                                     (=
                                       (if (le e1 e2) (- e1 (mw_of f))
                                       (- e2 (mw_of f)))
                                       (- e1 (mw_of f)))
                                     (steps
                                       ((rewrite (premise hgap) lr lhs true ())
                                        (simp lhs))
                                       refl))
                                   (have hcore
                                     (=
                                       (if
                                         (int_eq
                                           (+
                                             (if s1 (- 0 m1) m1)
                                             (if s2
                                               (- 0 (* m2 (fpow2 (- e2 e1))))
                                               (* m2 (fpow2 (- e2 e1)))))
