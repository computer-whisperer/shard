                     (rewrite (premise hJarg) lr rhs true ())
                     (rewrite (premise hEj) lr lhs true ())
                     (rewrite (premise hbrr) lr lhs true ()))
                    refl)))))))))))

;; THE R2.4c THEOREM: the L2 mul equals the L1 mul on every pair of
;; well-formed views, parametrically in the format. The non-finite arms
;; mirror verbatim (unfold both + select = refl); the Fin x Fin arm keeps
;; the zero guards FOLDED (identical if-trees both sides) and bridges the
;; else branch: sign-normalize the fval pair to the positive view
;; (fval_num_sign), fold the product sign out (mul_neg_l), select frnd's
;; dispatch (frnd_of_pos/neg), and land on the positive-magnitude core.
(claim fmul2_fmul
  (goal ((f Fmt) (x FVal) (y FVal)) ((= (fwf f x) True) (= (fwf f y) True))
    (= (fmul2 f x y) (fmul f x y)))
  (case-on x FVal
    ((case Fin
       (s1 m1 e1)
       (case-on y FVal
         ((case Fin
            (s2 m2 e2)
            (chain
              (have hxe (= x (Fin s1 m1 e1))
                (steps ((rewrite (hyp 1) lr lhs true ())) refl))
              (have hye (= y (Fin s2 m2 e2))
                (steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (have hw1 (= (fwf_fin f m1 e1) True)
                (steps
                  ((rewrite (premise 0) rl rhs true ())
                   (rewrite (premise hxe) lr rhs true ())
                   (unfold fwf rhs)
                   (simp rhs))
                  refl))
              (have hw2 (= (fwf_fin f m2 e2) True)
                (steps
                  ((rewrite (premise 1) rl rhs true ())
                   (rewrite (premise hye) lr rhs true ())
                   (unfold fwf rhs)
                   (simp rhs))
                  refl))
              (case-on (int_eq m1 0) Bool
                ((case True
                   (chain
                     (have hz1t (= (int_eq m1 0) True)
                       (steps ((rewrite (hyp True) lr lhs true ())) refl))
                     (steps
                       ((rewrite (premise hxe) lr lhs true ())
                        (rewrite (premise hxe) lr rhs true ())
                        (rewrite (premise hye) lr lhs true ())
                        (rewrite (premise hye) lr rhs true ())
                        (unfold fmul2 lhs)
                        (simp lhs)
                        (rewrite (premise hz1t) lr lhs true ())
                        (simp lhs)
                        (unfold fmul rhs)
                        (simp rhs)
                        (rewrite (premise hz1t) lr rhs true ())
                        (simp rhs))
                       refl)))
                 (case False
                   (chain
                     (have hz1f (= (int_eq m1 0) False)
                       (steps ((rewrite (hyp False) lr lhs true ())) refl))
                     (case-on (int_eq m2 0) Bool
                       ((case True
                          (chain
                            (have hz2t (= (int_eq m2 0) True)
                              (steps ((rewrite (hyp True) lr lhs true ())) refl))
                            (steps
                              ((rewrite (premise hxe) lr lhs true ())
                               (rewrite (premise hxe) lr rhs true ())
                               (rewrite (premise hye) lr lhs true ())
                               (rewrite (premise hye) lr rhs true ())
                               (unfold fmul2 lhs)
                               (simp lhs)
                               (rewrite (premise hz1f) lr lhs true ())
                               (simp lhs)
                               (rewrite (premise hz2t) lr lhs true ())
                               (simp lhs)
                               (unfold fmul rhs)
                               (simp rhs)
                               (rewrite (premise hz1f) lr rhs true ())
                               (simp rhs)
                               (rewrite (premise hz2t) lr rhs true ())
                               (simp rhs))
                              refl)))
                        (case False
                          (chain
                            (have hz2f (= (int_eq m2 0) False)
                              (steps
                                ((rewrite (hyp False) lr lhs true ()))
                                refl))
                            (case-on (le 0 m1) Bool
                              ((case True
                                 (chain
                                   (have hm0a (= (le 0 m1) True)
                                     (steps
                                       ((rewrite (hyp True) lr lhs true ()))
                                       refl))
