;; Subtraction rides addition exactly as its definition does: both sides
;; unfold to the add at (fneg y), fneg preserves well-formedness, and the
;; add equality closes.
(claim fsub2_fsub
  (goal ((f Fmt) (x FVal) (y FVal)) ((= (fwf f x) True) (= (fwf f y) True))
    (= (fsub2 f x y) (fsub f x y)))
  (chain
    (have hwn (= (fwf f (fneg y)) True)
      (rewrite-with
        (lemma fneg_wf)
        lr
        lhs
        ((inst f f) (inst x y))
        ((steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (have hadd (= (fadd2 f x (fneg y)) (fadd f x (fneg y)))
      (rewrite-with
        (lemma fadd2_fadd)
        lr
        lhs
        ((inst f f) (inst x x) (inst y (fneg y)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise hwn) lr lhs true ())) refl))
        refl))
    (steps
      ((unfold fsub2 lhs)
       (unfold fsub rhs)
       (rewrite (premise hadd) lr lhs true ()))
      refl)))
