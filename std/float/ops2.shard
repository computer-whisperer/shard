;; High-row direction (e2 < e1): the mirror core — sv is aligned at base row
;; e2, the s1 operand carries the gap power, and the positive factor P is
;; 2^(e2-MW) / 1 / 2^(MW-e1) across the TT/TF/FF arms. Same skeleton as
;; fadd_core_le with the operand roles swapped (and one mul_comm den respell
;; on the both-low arm, where the common factor sits on the left of DEN).
(claim fadd_core_gt
  (goal ((f Fmt) (s1 Bool) (m1 Int) (e1 Int) (s2 Bool) (m2 Int) (e2 Int))
    ((= (le e1 e2) False))
    (=
      (if
        (int_eq
          (+
            (if s1 (- 0 (* m1 (fpow2 (- e1 e2)))) (* m1 (fpow2 (- e1 e2))))
            (if s2 (- 0 m2) m2))
          0)
        (Fin False 0 (fmt_emin f))
        (if
          (lt
            (+
              (if s1 (- 0 (* m1 (fpow2 (- e1 e2)))) (* m1 (fpow2 (- e1 e2))))
              (if s2 (- 0 m2) m2))
            0)
          (fgrs
            f
            True
            (-
              0
              (+
                (if s1 (- 0 (* m1 (fpow2 (- e1 e2)))) (* m1 (fpow2 (- e1 e2))))
                (if s2 (- 0 m2) m2)))
            (- e2 (mw_of f)))
          (fgrs
            f
            False
            (+
              (if s1 (- 0 (* m1 (fpow2 (- e1 e2)))) (* m1 (fpow2 (- e1 e2))))
              (if s2 (- 0 m2) m2))
            (- e2 (mw_of f)))))
      (frnd
        f
        (+
          (* (fval_num f (Fin s1 m1 e1)) (fval_den f (Fin s2 m2 e2)))
          (* (fval_num f (Fin s2 m2 e2)) (fval_den f (Fin s1 m1 e1))))
        (* (fval_den f (Fin s1 m1 e1)) (fval_den f (Fin s2 m2 e2))))))
  (chain
    (rewrite-with
      (lemma if_neg_mul)
      lr
      lhs
      ((inst s s1) (inst m m1) (inst p (fpow2 (- e1 e2))))
      ())
    (rewrite-with
      (lemma if_neg_mul)
      lr
      lhs
      ((inst s s1) (inst m m1) (inst p (fpow2 (- e1 e2))))
      ())
    (rewrite-with
      (lemma if_neg_mul)
      lr
      lhs
      ((inst s s1) (inst m m1) (inst p (fpow2 (- e1 e2))))
      ())
    (rewrite-with
      (lemma if_neg_mul)
      lr
      lhs
      ((inst s s1) (inst m m1) (inst p (fpow2 (- e1 e2))))
      ())
    (case-on (le (mw_of f) e2) Bool
      ((case True
         (chain
           (have hmle2 (= (le (mw_of f) e2) True)
             (steps ((rewrite (hyp True) lr lhs true ())) refl))
           (have hmle1 (= (le (mw_of f) e1) True)
             (steps () (by arith (list 1 1 1))))
           (have hga (= (le 0 (- e1 e2)) True)
             (steps () (by arith (list 1 1 0 0))))
           (have hgb (= (le 0 (- e2 (mw_of f))) True)
             (steps () (by arith (list 1 0 1 0 0))))
           (have hn1
             (=
               (fval_num f (Fin s1 m1 e1))
               (* (if s1 (- 0 m1) m1) (fpow2 (- e1 (mw_of f)))))
             (steps
               ((unfold fval_num lhs)
                (simp lhs)
                (rewrite (premise hmle1) lr lhs true ())
                (simp lhs))
               refl))
           (have hd1 (= (fval_den f (Fin s1 m1 e1)) 1)
