                                         True)
                                       (rewrite-with
                                         (lemma frnd_wf)
                                         lr
                                         lhs
                                         ((inst f f)
                                          (inst
                                            n
                                            (*
                                              (fval_num f (Fin s1 m1 e1))
                                              (fval_den f (Fin s2 m2 e2))))
                                          (inst
                                            d
                                            (*
                                              (fval_den f (Fin s1 m1 e1))
                                              (fval_num f (Fin s2 m2 e2)))))
                                         ((steps
                                            ((rewrite
                                               (premise 0)
                                               lr
                                               lhs
                                               true
                                               ()))
                                            refl)
                                          (steps
                                            ((rewrite
                                               (premise hdp)
                                               lr
                                               lhs
                                               true
                                               ()))
                                            refl))
                                         refl))
                                     (steps
                                       ((rewrite (premise hxe) lr lhs true ())
                                        (rewrite (premise hye) lr lhs true ())
                                        (rewrite (premise hb) lr lhs true ())
                                        (rewrite (premise hwr) lr lhs true ()))
                                       refl)))))))))))))))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hb
                  (=
                    (fdiv f (Fin s1 m1 e1) (FInf s2))
                    (Fin (bxorb s1 s2) 0 (fmt_emin f)))
                  (steps ((unfold fdiv lhs) (reduce lhs)) refl))
                (have hwr (= (fwf f (Fin (bxorb s1 s2) 0 (fmt_emin f))) True)
                  (rewrite-with
                    (lemma fwf_zero)
                    lr
                    lhs
                    ((inst f f) (inst s (bxorb s1 s2)))
                    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                    refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (rewrite (premise hb) lr lhs true ())
                   (rewrite (premise hwr) lr lhs true ()))
                  refl)))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fdiv lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FInf
       (s1)
       (chain
         (have hxe (= x (FInf s1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwi (= (hinf_of f) True)
           (steps
             ((rewrite (premise 2) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hwi) rl rhs true ())
                   (rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fdiv lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs))
                  refl)))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fdiv lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fdiv lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (unfold fdiv lhs)
            (reduce lhs)
            (unfold fwf lhs)
            (reduce lhs)
            (rewrite (premise 1) lr lhs true ()))
           refl))))))

;; fsub = fadd of the negation; wf composes.
(claim fsub_wf
  (goal ((f Fmt) (x FVal) (y FVal))
    ((= (fmt_wf f) True)
     (= (hnan_of f) True)
     (= (fwf f x) True)
     (= (fwf f y) True))
    (= (fwf f (fsub f x y)) True))
  (chain
    (have hwn (= (fwf f (fneg y)) True)
      (rewrite-with
        (lemma fneg_wf)
        lr
        lhs
        ((inst f f) (inst x y))
        ((steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (have hwa (= (fwf f (fadd f x (fneg y))) True)
      (rewrite-with
        (lemma fadd_wf)
        lr
        lhs
        ((inst f f) (inst x x) (inst y (fneg y)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl)
         (steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 4) lr lhs true ())) refl))
        refl))
    (steps ((unfold fsub lhs) (rewrite (premise 5) lr lhs true ())) refl)))

;; --- decode is well-formed on ANY Int (fmt-ground, §3a tier 2) ------------------
;; funpack's fields are mod-masked, so every branch lands wf with NO premise
;; on b — the from_bits surface door's whole obligation. Choreography: literal
;; pins as farkas EQUALITY ROWS (never rewritten into the goal — the guard
;; tree stays at the folded spelling), mod_lo/mod_hi field bounds, guard
;; case-ons with hv equation-haves, fwf_fin walk with per-guard farkas haves.

(claim funpack_wf_f32
  (goal ((b Int)) () (= (fwf (fmt_f32) (funpack (fmt_f32) b)) True))
  (chain
    (have hPM (= (fpow2 (mw_of (fmt_f32))) 8388608)
      (steps ((compute lhs)) refl))
    (have hPM1 (= (fpow2 (+ (mw_of (fmt_f32)) 1)) 16777216)
      (steps ((compute lhs)) refl))
    (have hPE (= (fpow2 (ew_of (fmt_f32))) 256) (steps ((compute lhs)) refl))
    (have hBIAS (= (fmt_bias (fmt_f32)) 127) (steps ((compute lhs)) refl))
    (have hEMIN (= (fmt_emin (fmt_f32)) -126) (steps ((compute lhs)) refl))
    (have hEMAX (= (fmt_emax (fmt_f32)) 127) (steps ((compute lhs)) refl))
    (have hHI (= (hinf_of (fmt_f32)) True) (steps ((compute lhs)) refl))
    (have hHN (= (hnan_of (fmt_f32)) True) (steps ((compute lhs)) refl))
    (have hpepos (= (lt 0 (fpow2 (ew_of (fmt_f32)))) True)
      (rewrite-with
        (lemma fpow2_pos)
        lr
        lhs
        ((inst k (ew_of (fmt_f32))))
        ()
        refl))
    (have hpmpos (= (lt 0 (fpow2 (mw_of (fmt_f32)))) True)
      (rewrite-with
        (lemma fpow2_pos)
        lr
        lhs
        ((inst k (mw_of (fmt_f32))))
        ()
        refl))
    (have heb_lo
      (=
        (le
          0
          (mod (ediv b (fpow2 (mw_of (fmt_f32)))) (fpow2 (ew_of (fmt_f32)))))
        True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ((inst n (ediv b (fpow2 (mw_of (fmt_f32)))))
         (inst d (fpow2 (ew_of (fmt_f32)))))
        ((steps ((rewrite (premise hpepos) lr lhs true ())) refl))
        refl))
    (have heb_hi
      (=
        (lt
          (mod (ediv b (fpow2 (mw_of (fmt_f32)))) (fpow2 (ew_of (fmt_f32))))
          (fpow2 (ew_of (fmt_f32))))
        True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ((inst n (ediv b (fpow2 (mw_of (fmt_f32)))))
         (inst d (fpow2 (ew_of (fmt_f32)))))
        ((steps ((rewrite (premise hpepos) lr lhs true ())) refl))
        refl))
    (have hmb_lo (= (le 0 (mod b (fpow2 (mw_of (fmt_f32))))) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ((inst n b) (inst d (fpow2 (mw_of (fmt_f32)))))
        ((steps ((rewrite (premise hpmpos) lr lhs true ())) refl))
        refl))
    (have hmb_hi
      (= (lt (mod b (fpow2 (mw_of (fmt_f32)))) (fpow2 (mw_of (fmt_f32)))) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ((inst n b) (inst d (fpow2 (mw_of (fmt_f32)))))
        ((steps ((rewrite (premise hpmpos) lr lhs true ())) refl))
        refl))
    (case-on
      (int_eq
        (mod (ediv b (fpow2 (mw_of (fmt_f32)))) (fpow2 (ew_of (fmt_f32))))
        0)
      Bool
      ((case True
         (chain
           (have hg1
             (=
               (int_eq
                 (mod
                   (ediv b (fpow2 (mw_of (fmt_f32))))
                   (fpow2 (ew_of (fmt_f32))))
                 0)
               True)
             (steps ((rewrite (hyp True) lr lhs true ())) refl))
           (have hv
             (=
               (funpack (fmt_f32) b)
               (Fin
                 (int_eq
                   (mod
                     (ediv b (fpow2 (+ (ew_of (fmt_f32)) (mw_of (fmt_f32)))))
                     2)
                   1)
                 (mod b (fpow2 (mw_of (fmt_f32))))
                 (fmt_emin (fmt_f32))))
             (steps
               ((unfold funpack lhs)
                (reduce lhs)
                (rewrite (premise hg1) lr lhs true ())
                (reduce lhs))
               refl))
           (have hw2
             (=
               (lt
                 (mod b (fpow2 (mw_of (fmt_f32))))
                 (fpow2 (+ (mw_of (fmt_f32)) 1)))
               True)
             (steps () (by arith (rows (goal 1) (hmb_hi 1) (hPM -1) (hPM1 1)))))
           (have hemm (= (le (fmt_emin (fmt_f32)) (fmt_emin (fmt_f32))) True)
             (steps ((compute lhs)) refl))
           (have hemx (= (le (fmt_emin (fmt_f32)) (fmt_emax (fmt_f32))) True)
             (steps ((compute lhs)) refl))
           (have hiee
             (= (int_eq (fmt_emin (fmt_f32)) (fmt_emin (fmt_f32))) True)
             (steps ((compute lhs)) refl))
           (steps
             ((rewrite (premise hv) lr lhs true ())
              (unfold fwf lhs)
              (reduce lhs)
              (unfold fwf_fin lhs)
              (reduce lhs)
              (rewrite (premise hmb_lo) lr lhs true ())
              (reduce lhs)
              (rewrite (premise hw2) lr lhs true ())
              (reduce lhs)
              (rewrite (premise hemm) lr lhs true ())
              (reduce lhs)
              (rewrite (premise hemx) lr lhs true ())
              (reduce lhs)
              (rewrite (premise hmb_hi) lr lhs true ())
              (reduce lhs)
              (rewrite (premise hiee) lr lhs true ())
              (reduce lhs))
             refl)))
       (case False
         (chain
           (have hg1
             (=
               (int_eq
                 (mod
                   (ediv b (fpow2 (mw_of (fmt_f32))))
                   (fpow2 (ew_of (fmt_f32))))
                 0)
               False)
             (steps ((rewrite (hyp False) lr lhs true ())) refl))
           (case-on
             (int_eq
               (mod
                 (ediv b (fpow2 (mw_of (fmt_f32))))
                 (fpow2 (ew_of (fmt_f32))))
               (- (fpow2 (ew_of (fmt_f32))) 1))
             Bool
             ((case True
                (chain
                  (have hg2
                    (=
                      (int_eq
                        (mod
                          (ediv b (fpow2 (mw_of (fmt_f32))))
                          (fpow2 (ew_of (fmt_f32))))
                        (- (fpow2 (ew_of (fmt_f32))) 1))
                      True)
                    (steps ((rewrite (hyp True) lr lhs true ())) refl))
                  (case-on (int_eq (mod b (fpow2 (mw_of (fmt_f32)))) 0) Bool
                    ((case True
                       (chain
                         (have hgm
                           (= (int_eq (mod b (fpow2 (mw_of (fmt_f32)))) 0) True)
                           (steps ((rewrite (hyp True) lr lhs true ())) refl))
                         (have hv
                           (=
                             (funpack (fmt_f32) b)
                             (FInf
                               (int_eq
                                 (mod
                                   (ediv
                                     b
                                     (fpow2
                                       (+ (ew_of (fmt_f32)) (mw_of (fmt_f32)))))
                                   2)
                                 1)))
                           (steps
                             ((unfold funpack lhs)
                              (reduce lhs)
                              (rewrite (premise hg1) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hg2) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hHI) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hgm) lr lhs true ())
                              (reduce lhs))
                             refl))
                         (steps
                           ((rewrite (premise hv) lr lhs true ())
                            (unfold fwf lhs)
                            (reduce lhs)
                            (rewrite (premise hHI) lr lhs true ()))
                           refl)))
                     (case False
                       (chain
                         (have hgm
                           (=
                             (int_eq (mod b (fpow2 (mw_of (fmt_f32)))) 0)
                             False)
                           (steps ((rewrite (hyp False) lr lhs true ())) refl))
                         (have hv (= (funpack (fmt_f32) b) FNaN)
                           (steps
                             ((unfold funpack lhs)
                              (reduce lhs)
                              (rewrite (premise hg1) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hg2) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hHI) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hgm) lr lhs true ())
                              (reduce lhs)
                              (rewrite (premise hHN) lr lhs true ())
                              (reduce lhs))
                             refl))
                         (steps
                           ((rewrite (premise hv) lr lhs true ())
                            (unfold fwf lhs)
                            (reduce lhs)
                            (rewrite (premise hHN) lr lhs true ()))
                           refl)))))))
              (case False
                (chain
                  (have hg2
                    (=
                      (int_eq
                        (mod
                          (ediv b (fpow2 (mw_of (fmt_f32))))
                          (fpow2 (ew_of (fmt_f32))))
                        (- (fpow2 (ew_of (fmt_f32))) 1))
                      False)
                    (steps ((rewrite (hyp False) lr lhs true ())) refl))
                  (case-on
                    (le
                      (mod
                        (ediv b (fpow2 (mw_of (fmt_f32))))
                        (fpow2 (ew_of (fmt_f32))))
                      0)
                    Bool
                    ((case True
                       (chain
                         (have hle0
                           (=
                             (le
                               (mod
                                 (ediv b (fpow2 (mw_of (fmt_f32))))
                                 (fpow2 (ew_of (fmt_f32))))
                               0)
                             True)
                           (steps ((rewrite (hyp True) lr lhs true ())) refl))
                         (have heq0
                           (=
                             (mod
                               (ediv b (fpow2 (mw_of (fmt_f32))))
                               (fpow2 (ew_of (fmt_f32))))
                             0)
                           (steps
                             ()
                             (by
                               arith
                               (list
                                 (rows (goal 1) (hle0 1))
                                 (rows (goal 1) (heb_lo 1))))))
                         (have hff (= False True)
                           (steps
                             ((rewrite (premise hg1) rl lhs true ())
                              (rewrite (premise heq0) lr lhs true ())
                              (simp lhs))
                             refl))
                         (absurd (premise hff))))
                     (case False
                       (chain
                         (have hEB1
                           (=
                             (le
                               (mod
                                 (ediv b (fpow2 (mw_of (fmt_f32))))
                                 (fpow2 (ew_of (fmt_f32))))
                               0)
                             False)
                           (steps ((rewrite (hyp False) lr lhs true ())) refl))
                         (case-on
                           (le
                             255
                             (mod
                               (ediv b (fpow2 (mw_of (fmt_f32))))
                               (fpow2 (ew_of (fmt_f32)))))
                           Bool
                           ((case True
                              (chain
                                (have h255
                                  (=
                                    (le
                                      255
                                      (mod
                                        (ediv b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (ew_of (fmt_f32)))))
                                    True)
                                  (steps
                                    ((rewrite (hyp True) lr lhs true ()))
                                    refl))
                                (have heq255
                                  (=
                                    (mod
                                      (ediv b (fpow2 (mw_of (fmt_f32))))
                                      (fpow2 (ew_of (fmt_f32))))
                                    255)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (list
                                        (rows (goal 1) (heb_hi 1) (hPE -1))
                                        (rows (goal 1) (h255 1))))))
                                (have hff (= False True)
                                  (steps
                                    ((rewrite (premise hg2) rl lhs true ())
                                     (rewrite (premise heq255) lr lhs true ())
                                     (rewrite (premise hPE) lr lhs true ())
                                     (simp lhs))
                                    refl))
                                (absurd (premise hff))))
                            (case False
                              (chain
                                (have hEB254
                                  (=
                                    (le
                                      255
                                      (mod
                                        (ediv b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (ew_of (fmt_f32)))))
                                    False)
                                  (steps
                                    ((rewrite (hyp False) lr lhs true ()))
                                    refl))
                                (have hv
                                  (=
                                    (funpack (fmt_f32) b)
                                    (Fin
                                      (int_eq
                                        (mod
                                          (ediv
                                            b
                                            (fpow2
                                              (+
                                                (ew_of (fmt_f32))
                                                (mw_of (fmt_f32)))))
                                          2)
                                        1)
                                      (+
                                        (mod b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (mw_of (fmt_f32))))
                                      (-
                                        (mod
                                          (ediv b (fpow2 (mw_of (fmt_f32))))
                                          (fpow2 (ew_of (fmt_f32))))
                                        (fmt_bias (fmt_f32)))))
                                  (steps
                                    ((unfold funpack lhs)
                                     (reduce lhs)
                                     (rewrite (premise hg1) lr lhs true ())
                                     (reduce lhs)
                                     (rewrite (premise hg2) lr lhs true ())
                                     (reduce lhs))
                                    refl))
                                (have hw1
                                  (=
                                    (le
                                      0
                                      (+
                                        (mod b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (mw_of (fmt_f32)))))
                                    True)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (rows (goal 1) (hmb_lo 1) (hpmpos 1)))))
                                (have hw2
                                  (=
                                    (lt
                                      (+
                                        (mod b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (mw_of (fmt_f32))))
                                      (fpow2 (+ (mw_of (fmt_f32)) 1)))
                                    True)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (rows
                                        (goal 1)
                                        (hmb_hi 1)
                                        (hPM -2)
                                        (hPM1 1)))))
                                (have hw3
                                  (=
                                    (le
                                      (fmt_emin (fmt_f32))
                                      (-
                                        (mod
                                          (ediv b (fpow2 (mw_of (fmt_f32))))
                                          (fpow2 (ew_of (fmt_f32))))
                                        (fmt_bias (fmt_f32))))
                                    True)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (rows
                                        (goal 1)
                                        (hEB1 1)
                                        (hEMIN -1)
                                        (hBIAS -1)))))
                                (have hw4
                                  (=
                                    (le
                                      (-
                                        (mod
                                          (ediv b (fpow2 (mw_of (fmt_f32))))
                                          (fpow2 (ew_of (fmt_f32))))
                                        (fmt_bias (fmt_f32)))
                                      (fmt_emax (fmt_f32)))
                                    True)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (rows
                                        (goal 1)
                                        (hEB254 1)
                                        (hBIAS 1)
                                        (hEMAX 1)))))
                                (have hw5
                                  (=
                                    (lt
                                      (+
                                        (mod b (fpow2 (mw_of (fmt_f32))))
                                        (fpow2 (mw_of (fmt_f32))))
                                      (fpow2 (mw_of (fmt_f32))))
                                    False)
                                  (steps
                                    ()
                                    (by arith (rows (goal 1) (hmb_lo 1)))))
                                (have htop
                                  (=
                                    (int_eq
                                      (-
                                        (mod
                                          (ediv b (fpow2 (mw_of (fmt_f32))))
                                          (fpow2 (ew_of (fmt_f32))))
                                        (fmt_bias (fmt_f32)))
                                      (+ (fmt_bias (fmt_f32)) 1))
                                    False)
                                  (steps
                                    ()
                                    (by
                                      arith
                                      (rows (goal 1) (hEB254 1) (hBIAS 2)))))
                                (steps
                                  ((rewrite (premise hv) lr lhs true ())
                                   (unfold fwf lhs)
                                   (reduce lhs)
                                   (unfold fwf_fin lhs)
                                   (reduce lhs)
                                   (rewrite (premise hw1) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hw2) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hw3) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hw4) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hw5) lr lhs true ())
                                   (reduce lhs)
                                   (unfold ftop_ok lhs)
                                   (reduce lhs)
                                   (rewrite (premise htop) lr lhs true ())
                                   (reduce lhs))
                                  refl)))))))))))))))))))

(claim funpack_wf_f64
  (goal ((b Int)) () (= (fwf (fmt_f64) (funpack (fmt_f64) b)) True))
  (chain
    (have hPM (= (fpow2 (mw_of (fmt_f64))) 4503599627370496)
      (steps ((compute lhs)) refl))
    (have hPM1 (= (fpow2 (+ (mw_of (fmt_f64)) 1)) 9007199254740992)
      (steps ((compute lhs)) refl))
    (have hPE (= (fpow2 (ew_of (fmt_f64))) 2048) (steps ((compute lhs)) refl))
    (have hBIAS (= (fmt_bias (fmt_f64)) 1023) (steps ((compute lhs)) refl))
    (have hEMIN (= (fmt_emin (fmt_f64)) -1022) (steps ((compute lhs)) refl))
    (have hEMAX (= (fmt_emax (fmt_f64)) 1023) (steps ((compute lhs)) refl))
    (have hHI (= (hinf_of (fmt_f64)) True) (steps ((compute lhs)) refl))
    (have hHN (= (hnan_of (fmt_f64)) True) (steps ((compute lhs)) refl))
    (have hpepos (= (lt 0 (fpow2 (ew_of (fmt_f64)))) True)
      (rewrite-with
        (lemma fpow2_pos)
        lr
        lhs
        ((inst k (ew_of (fmt_f64))))
        ()
        refl))
    (have hpmpos (= (lt 0 (fpow2 (mw_of (fmt_f64)))) True)
      (rewrite-with
        (lemma fpow2_pos)
        lr
