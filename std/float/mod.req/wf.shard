                       (steps
                         ((rewrite (premise hwi) rl rhs true ())
                          (rewrite (premise hxe) lr lhs true ())
                          (rewrite (premise hye) lr lhs true ())
                          (unfold fmul lhs)
                          (reduce lhs)
                          (rewrite (premise hz2) lr lhs true ())
                          (reduce lhs)
                          (unfold fwf lhs)
                          (reduce lhs))
                         refl)))))))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hwi) rl rhs true ())
                   (rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fmul lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs))
                  refl)))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fmul lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (unfold fmul lhs)
            (reduce lhs)
            (unfold fwf lhs)
            (reduce lhs)
            (rewrite (premise 1) lr lhs true ()))
           refl))))))

(claim fdiv_wf
  (goal ((f Fmt) (x FVal) (y FVal))
    ((= (fmt_wf f) True)
     (= (hnan_of f) True)
     (= (fwf f x) True)
     (= (fwf f y) True))
    (= (fwf f (fdiv f x y)) True))
  (case-on x FVal
    ((case Fin
       (s1 m1 e1)
       (chain
         (have hxe (= x (Fin s1 m1 e1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hd1 (= (lt 0 (fval_den f (Fin s1 m1 e1))) True)
                  (rewrite-with
                    (lemma fval_den_pos_any)
                    lr
                    lhs
                    ((inst f f) (inst s s1) (inst m m1) (inst e e1))
                    ()
                    refl))
                (case-on (int_eq m2 0) Bool
                  ((case True
                     (chain
                       (have hz2 (= (int_eq m2 0) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
                       (case-on (int_eq m1 0) Bool
                         ((case True
                            (chain
                              (have hz1 (= (int_eq m1 0) True)
                                (steps
                                  ((rewrite (hyp True) lr lhs true ()))
                                  refl))
                              (steps
                                ((rewrite (premise hxe) lr lhs true ())
                                 (rewrite (premise hye) lr lhs true ())
                                 (unfold fdiv lhs)
                                 (reduce lhs)
                                 (rewrite (premise hz2) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise hz1) lr lhs true ())
                                 (reduce lhs)
                                 (unfold fwf lhs)
                                 (reduce lhs)
                                 (rewrite (premise 1) lr lhs true ()))
                                refl)))
                          (case False
                            (chain
                              (have hz1 (= (int_eq m1 0) False)
                                (steps
                                  ((rewrite (hyp False) lr lhs true ()))
                                  refl))
                              (have hb
                                (=
                                  (fdiv f (Fin s1 m1 e1) (Fin s2 m2 e2))
                                  (fovf f (bxorb s1 s2)))
                                (steps
                                  ((unfold fdiv lhs)
                                   (reduce lhs)
                                   (rewrite (premise hz2) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hz1) lr lhs true ())
                                   (reduce lhs))
                                  refl))
                              (have hwr (= (fwf f (fovf f (bxorb s1 s2))) True)
