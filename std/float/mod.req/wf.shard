;;; std/float/mod.req/wf.shard — wf-closure of the L1 ops + the decode/roundtrip
;;; theorems the per-format surface modules (std/f32, std/f64 — rung R3a,
;;; docs/FLOATS.md §3a) consume for their refine obligations:
;;;
;;;   fadd_wf/fsub_wf/fmul_wf/fdiv_wf  — ops preserve fwf (parametric; the
;;;     hnan premise covers the NaN-producing table arms: Inf-Inf, Inf*0,
;;;     0/0, Inf/Inf — every named IEEE/FN instance has a NaN)
;;;   fabs_wf                          — sign ops (fneg_wf lives in kit.shard)
;;;   funpack_wf_f32/_f64              — decode is wf on ANY Int (fields are
;;;     mod-masked; §3a tier 2, fmt-ground)
;;;   funpack_fpack_f32/_f64           — the combined wf-premised roundtrip,
;;;     assembling the R2.2 pieces (fin fmt-ground + inf/nan parametric)

(import "../../../kernel/stdlib.shard")
(import "../../../kernel/facts.shard")  ; ediv/mod range facts for the field bounds
(import "float.shard")  ; the L1 model: Fmt, FVal, fwf, the ops, frnd
(import "kit.shard")  ; frnd_wf, fovf_wf, fneg_wf, fpow2_pos, fval pair kit
(import "pack.shard")  ; funpack/fpack + the R2.2 bijection theorems
(import "../../rat")  ; mul_pos (interface theorem kit, L0)
(use (:: kernel facts *))
(use (:: std float float *))  ; type names (Fmt, FVal) for binders
(use (:: std float kit *))
(use (:: std float pack *))
(use (:: std rat gcd mul_pos))

;; --- small extraction helpers ---------------------------------------------------

;; the signed zero on the bottom row is well-formed (both ops' exact-zero
;; dispatch arms produce it; the sign never enters fwf).
(claim fwf_zero
  (goal ((f Fmt) (s Bool)) ((= (fmt_wf f) True))
    (= (fwf f (Fin s 0 (fmt_emin f))) True))
  (chain
    (have hp1 (= (lt 0 (fpow2 (+ (mw_of f) 1))) True)
      (rewrite-with (lemma fpow2_pos) lr lhs ((inst k (+ (mw_of f) 1))) () refl))
    (have hpm (= (lt 0 (fpow2 (mw_of f))) True)
      (rewrite-with (lemma fpow2_pos) lr lhs ((inst k (mw_of f))) () refl))
    (have hee (= (le (fmt_emin f) (fmt_emin f)) True)
      (steps () (by arith (list 1))))
    (have hex (= (le (fmt_emin f) (fmt_emax f)) True)
      (rewrite-with
        (lemma fmt_emin_le_emax)
        lr
        lhs
        ((inst f f))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
        refl))
    (have hie (= (int_eq (fmt_emin f) (fmt_emin f)) True)
      (steps () (by arith (list (list 1) (list 1)))))
    (steps
      ((unfold fwf lhs)
       (simp lhs)
       (unfold fwf_fin lhs)
       (simp lhs)
       (rewrite (premise 1) lr lhs true ())
       (simp lhs)
       (rewrite (premise 3) lr lhs true ())
       (simp lhs)
       (rewrite (premise 4) lr lhs true ())
       (simp lhs)
       (rewrite (premise 2) lr lhs true ())
       (simp lhs)
       (rewrite (premise 5) lr lhs true ()))
      refl)))

;; the exact-value denominator is positive at EITHER sign (fval_den never
;; reads the sign; kit's fval_den_pos is spelled at False only).
(claim fval_den_pos_any
  (goal ((f Fmt) (s Bool) (m Int) (e Int)) ()
    (= (lt 0 (fval_den f (Fin s m e))) True))
  (case-on (le (mw_of f) e) Bool
    ((case True
       (chain
         (have hg (= (le (mw_of f) e) True)
           (steps ((rewrite (hyp True) lr lhs true ())) refl))
         (steps
           ((unfold fval_den lhs)
            (simp lhs)
            (rewrite (premise 0) lr lhs true ())
            (simp lhs))
           refl)))
     (case False
       (chain
         (have hg (= (le (mw_of f) e) False)
           (steps ((rewrite (hyp False) lr lhs true ())) refl))
         (have hp (= (lt 0 (fpow2 (- (mw_of f) e))) True)
           (rewrite-with
             (lemma fpow2_pos)
             lr
             lhs
             ((inst k (- (mw_of f) e)))
             ()
             refl))
         (steps
           ((unfold fval_den lhs)
            (simp lhs)
            (rewrite (premise 0) lr lhs true ())
            (simp lhs)
            (rewrite (premise 1) lr lhs true ()))
           refl))))))

;; a well-formed nonzero mantissa is at least 1 (the m >= 1 extraction, done
;; once: fwf_fin's first guard gives m >= 0, the int_eq disequality kills 0).
(claim fwf_m_lo
  (goal ((f Fmt) (m Int) (e Int))
    ((= (fwf_fin f m e) True) (= (int_eq m 0) False))
    (= (le 1 m) True))
  (case-on (le 0 m) Bool
    ((case True
       (chain
         (have hm0 (= (le 0 m) True)
           (steps ((rewrite (hyp True) lr lhs true ())) refl))
         (case-on (le m 0) Bool
           ((case True
              (chain
                (have hmz (= (le m 0) True)
                  (steps ((rewrite (hyp True) lr lhs true ())) refl))
                (have hmeq (= m 0)
                  (steps () (by arith (list (list 1 0 0 0 1) (list 1 0 0 1 0)))))
                (have hff (= False True)
                  (steps
                    ((rewrite (premise 1) rl lhs true ())
                     (rewrite (premise 4) lr lhs true ())
                     (simp lhs))
                    refl))
                (absurd (premise hff))))
            (case False
              (chain
                (have hmnz (= (le m 0) False)
                  (steps ((rewrite (hyp False) lr lhs true ())) refl))
                (steps () (by arith (list 1 0 0 0 1)))))))))
     (case False
       (chain
         (have hm0f (= (le 0 m) False)
           (steps ((rewrite (hyp False) lr lhs true ())) refl))
         (have hff (= False True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (unfold fwf_fin rhs)
              (rewrite (premise 2) lr rhs true ())
              (simp rhs))
             refl))
         (absurd (premise hff)))))))

;; a nonzero-magnitude numerator that is not negative is strictly positive
;; (fdiv's divisor-sign probe consumer: the sign split lives HERE, once —
;; s = True contradicts the probe via fval_num_sign, s = False rides
;; fval_num_pos).
(claim fval_num_pos_probe
  (goal ((f Fmt) (s Bool) (m Int) (e Int))
    ((= (le 1 m) True) (= (lt (fval_num f (Fin s m e)) 0) False))
    (= (lt 0 (fval_num f (Fin s m e))) True))
  (case-on s Bool
    ((case True
       (chain
         (have hs (= s True) (steps ((rewrite (hyp True) lr lhs true ())) refl))
         (have hspell (= (lt (fval_num f (Fin True m e)) 0) False)
           (steps
             ((rewrite (premise hs) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (have hsign
           (= (fval_num f (Fin True m e)) (- 0 (fval_num f (Fin False m e))))
           (rewrite-with
             (lemma fval_num_sign)
             lr
             lhs
             ((inst f f) (inst m m) (inst e e))
             ()
             refl))
         (have hpos (= (le 1 (fval_num f (Fin False m e))) True)
           (rewrite-with
             (lemma fval_num_pos)
             lr
             lhs
             ((inst f f) (inst m m) (inst e e))
             ((steps ((rewrite (premise 0) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hs) lr lhs true ()))
           (by arith (rows (hspell 1) (hsign -1) (hpos 1))))))
     (case False
       (chain
         (have hs (= s False)
           (steps ((rewrite (hyp False) lr lhs true ())) refl))
         (have hpos (= (le 1 (fval_num f (Fin False m e))) True)
           (rewrite-with
             (lemma fval_num_pos)
             lr
             lhs
             ((inst f f) (inst m m) (inst e e))
             ((steps ((rewrite (premise 0) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hs) lr lhs true ()))
           (by arith (rows (goal 1) (hpos 1)))))))))

;; --- fabs preserves wf (fneg's textual twin — fwf never reads the sign) --------

(claim fabs_wf
  (goal ((f Fmt) (x FVal)) ((= (fwf f x) True)) (= (fwf f (fabs x)) True))
  (case-on x FVal
    ((case Fin
       (s m e)
       (chain
         (have hxe (= x (Fin s m e))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (fwf_fin f m e) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (steps
           ((rewrite (premise hwf) rl rhs true ())
            (rewrite (premise hxe) lr lhs true ())
            (unfold fabs lhs)
            (unfold fwf lhs)
            (simp lhs))
           refl)))
     (case FInf
       (s)
       (chain
         (have hxe (= x (FInf s))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (hinf_of f) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (steps
           ((rewrite (premise hwf) rl rhs true ())
            (rewrite (premise hxe) lr lhs true ())
            (unfold fabs lhs)
            (unfold fwf lhs)
            (simp lhs))
           refl)))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (hnan_of f) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (steps
           ((rewrite (premise hwf) rl rhs true ())
            (rewrite (premise hxe) lr lhs true ())
            (unfold fabs lhs)
            (unfold fwf lhs)
            (simp lhs))
           refl))))))

;; --- the op wf-closures: fadd/fmul/fdiv/fsub preserve fwf -----------------------
;; Parametric (§3a tier 1). The hnan premise covers the table arms that
;; CREATE a NaN from non-NaN inputs (Inf-Inf, Inf*0, 0/0, Inf/Inf); every
;; named instance has a NaN, so per-format discharge is one ground compute.
;; Choreography per live arm: hoisted positivity haves, zero-guard case-ons
;; with unfold+reduce spelling (reduce never unfolds named calls, so frnd and
;; the fval pair stay FOLDED for the frnd_wf cite).

(claim fadd_wf
  (goal ((f Fmt) (x FVal) (y FVal))
    ((= (fmt_wf f) True)
     (= (hnan_of f) True)
     (= (fwf f x) True)
     (= (fwf f y) True))
    (= (fwf f (fadd f x y)) True))
  (case-on x FVal
    ((case Fin
       (s1 m1 e1)
       (chain
         (have hxe (= x (Fin s1 m1 e1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hd1 (= (lt 0 (fval_den f (Fin s1 m1 e1))) True)
                  (rewrite-with
                    (lemma fval_den_pos_any)
                    lr
                    lhs
                    ((inst f f) (inst s s1) (inst m m1) (inst e e1))
                    ()
                    refl))
                (have hd2 (= (lt 0 (fval_den f (Fin s2 m2 e2))) True)
                  (rewrite-with
                    (lemma fval_den_pos_any)
                    lr
                    lhs
                    ((inst f f) (inst s s2) (inst m m2) (inst e e2))
                    ()
                    refl))
                (have hdd
                  (=
                    (lt
                      0
                      (*
                        (fval_den f (Fin s1 m1 e1))
                        (fval_den f (Fin s2 m2 e2))))
                    True)
                  (rewrite-with
                    (lemma mul_pos)
                    lr
                    lhs
                    ((inst a (fval_den f (Fin s1 m1 e1)))
                     (inst b (fval_den f (Fin s2 m2 e2))))
                    ((steps ((rewrite (premise hd1) lr lhs true ())) refl)
                     (steps ((rewrite (premise hd2) lr lhs true ())) refl))
                    refl))
                (case-on (int_eq m1 0) Bool
                  ((case True
                     (chain
                       (have hz1 (= (int_eq m1 0) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
                       (case-on (int_eq m2 0) Bool
                         ((case True
                            (chain
                              (have hz2 (= (int_eq m2 0) True)
                                (steps
                                  ((rewrite (hyp True) lr lhs true ()))
                                  refl))
                              (have hb
                                (=
                                  (fadd f (Fin s1 m1 e1) (Fin s2 m2 e2))
                                  (Fin (if s1 s2 False) 0 (fmt_emin f)))
                                (steps
                                  ((unfold fadd lhs)
                                   (reduce lhs)
                                   (rewrite (premise hz1) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hz2) lr lhs true ())
                                   (reduce lhs))
                                  refl))
                              (have hwr
                                (=
                                  (fwf f (Fin (if s1 s2 False) 0 (fmt_emin f)))
                                  True)
                                (rewrite-with
                                  (lemma fwf_zero)
                                  lr
                                  lhs
                                  ((inst f f) (inst s (if s1 s2 False)))
                                  ((steps
                                     ((rewrite (premise 0) lr lhs true ()))
                                     refl))
                                  refl))
                              (steps
                                ((rewrite (premise hxe) lr lhs true ())
                                 (rewrite (premise hye) lr lhs true ())
                                 (rewrite (premise hb) lr lhs true ())
                                 (rewrite (premise hwr) lr lhs true ()))
                                refl)))
                          (case False
                            (chain
                              (have hz2 (= (int_eq m2 0) False)
                                (steps
                                  ((rewrite (hyp False) lr lhs true ()))
                                  refl))
                              (have hb
                                (=
                                  (fadd f (Fin s1 m1 e1) (Fin s2 m2 e2))
                                  (frnd
                                    f
                                    (+
                                      (*
                                        (fval_num f (Fin s1 m1 e1))
                                        (fval_den f (Fin s2 m2 e2)))
                                      (*
                                        (fval_num f (Fin s2 m2 e2))
                                        (fval_den f (Fin s1 m1 e1))))
                                    (*
                                      (fval_den f (Fin s1 m1 e1))
                                      (fval_den f (Fin s2 m2 e2)))))
                                (steps
                                  ((unfold fadd lhs)
                                   (reduce lhs)
                                   (rewrite (premise hz1) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hz2) lr lhs true ())
                                   (reduce lhs))
                                  refl))
                              (have hwr
                                (=
                                  (fwf
                                    f
                                    (frnd
                                      f
                                      (+
                                        (*
                                          (fval_num f (Fin s1 m1 e1))
                                          (fval_den f (Fin s2 m2 e2)))
                                        (*
                                          (fval_num f (Fin s2 m2 e2))
                                          (fval_den f (Fin s1 m1 e1))))
                                      (*
                                        (fval_den f (Fin s1 m1 e1))
                                        (fval_den f (Fin s2 m2 e2)))))
                                  True)
                                (rewrite-with
                                  (lemma frnd_wf)
                                  lr
                                  lhs
                                  ((inst f f)
                                   (inst
                                     n
                                     (+
                                       (*
                                         (fval_num f (Fin s1 m1 e1))
                                         (fval_den f (Fin s2 m2 e2)))
                                       (*
                                         (fval_num f (Fin s2 m2 e2))
                                         (fval_den f (Fin s1 m1 e1)))))
                                   (inst
                                     d
                                     (*
                                       (fval_den f (Fin s1 m1 e1))
                                       (fval_den f (Fin s2 m2 e2)))))
                                  ((steps
                                     ((rewrite (premise 0) lr lhs true ()))
                                     refl)
                                   (steps
                                     ((rewrite (premise hdd) lr lhs true ()))
                                     refl))
                                  refl))
                              (steps
                                ((rewrite (premise hxe) lr lhs true ())
                                 (rewrite (premise hye) lr lhs true ())
                                 (rewrite (premise hb) lr lhs true ())
                                 (rewrite (premise hwr) lr lhs true ()))
                                refl)))))))
                   (case False
                     (chain
                       (have hz1 (= (int_eq m1 0) False)
                         (steps ((rewrite (hyp False) lr lhs true ())) refl))
                       (have hb
                         (=
                           (fadd f (Fin s1 m1 e1) (Fin s2 m2 e2))
                           (frnd
                             f
                             (+
                               (*
                                 (fval_num f (Fin s1 m1 e1))
                                 (fval_den f (Fin s2 m2 e2)))
                               (*
                                 (fval_num f (Fin s2 m2 e2))
                                 (fval_den f (Fin s1 m1 e1))))
                             (*
                               (fval_den f (Fin s1 m1 e1))
                               (fval_den f (Fin s2 m2 e2)))))
                         (steps
                           ((unfold fadd lhs)
                            (reduce lhs)
                            (rewrite (premise hz1) lr lhs true ())
                            (reduce lhs))
                           refl))
                       (have hwr
                         (=
                           (fwf
                             f
                             (frnd
                               f
                               (+
                                 (*
                                   (fval_num f (Fin s1 m1 e1))
                                   (fval_den f (Fin s2 m2 e2)))
                                 (*
                                   (fval_num f (Fin s2 m2 e2))
                                   (fval_den f (Fin s1 m1 e1))))
                               (*
                                 (fval_den f (Fin s1 m1 e1))
                                 (fval_den f (Fin s2 m2 e2)))))
                           True)
                         (rewrite-with
                           (lemma frnd_wf)
                           lr
                           lhs
                           ((inst f f)
                            (inst
                              n
                              (+
                                (*
                                  (fval_num f (Fin s1 m1 e1))
                                  (fval_den f (Fin s2 m2 e2)))
                                (*
                                  (fval_num f (Fin s2 m2 e2))
                                  (fval_den f (Fin s1 m1 e1)))))
                            (inst
                              d
                              (*
                                (fval_den f (Fin s1 m1 e1))
                                (fval_den f (Fin s2 m2 e2)))))
                           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                            (steps
                              ((rewrite (premise hdd) lr lhs true ()))
                              refl))
                           refl))
                       (steps
                         ((rewrite (premise hxe) lr lhs true ())
                          (rewrite (premise hye) lr lhs true ())
                          (rewrite (premise hb) lr lhs true ())
                          (rewrite (premise hwr) lr lhs true ()))
                         refl)))))))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hwi (= (hinf_of f) True)
                  (steps
                    ((rewrite (premise 3) rl rhs true ())
                     (rewrite (premise hye) lr rhs true ())
                     (unfold fwf rhs)
                     (simp rhs))
                    refl))
                (steps
                  ((rewrite (premise hwi) rl rhs true ())
                   (rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fadd lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs))
                  refl)))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fadd lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FInf
       (s1)
       (chain
         (have hxe (= x (FInf s1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwi (= (hinf_of f) True)
           (steps
             ((rewrite (premise 2) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hwi) rl rhs true ())
                   (rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fadd lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs))
                  refl)))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (case-on (beq s1 s2) Bool
                  ((case True
                     (chain
                       (have hbq (= (beq s1 s2) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
                       (steps
                         ((rewrite (premise hwi) rl rhs true ())
                          (rewrite (premise hxe) lr lhs true ())
                          (rewrite (premise hye) lr lhs true ())
                          (unfold fadd lhs)
                          (reduce lhs)
                          (rewrite (premise hbq) lr lhs true ())
                          (reduce lhs)
                          (unfold fwf lhs)
                          (reduce lhs))
                         refl)))
                   (case False
                     (chain
                       (have hbq (= (beq s1 s2) False)
                         (steps ((rewrite (hyp False) lr lhs true ())) refl))
                       (steps
                         ((rewrite (premise hxe) lr lhs true ())
                          (rewrite (premise hye) lr lhs true ())
                          (unfold fadd lhs)
                          (reduce lhs)
                          (rewrite (premise hbq) lr lhs true ())
                          (reduce lhs)
                          (unfold fwf lhs)
                          (reduce lhs)
                          (rewrite (premise 1) lr lhs true ()))
                         refl)))))))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fadd lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (unfold fadd lhs)
            (reduce lhs)
            (unfold fwf lhs)
            (reduce lhs)
            (rewrite (premise 1) lr lhs true ()))
           refl))))))

(claim fmul_wf
  (goal ((f Fmt) (x FVal) (y FVal))
    ((= (fmt_wf f) True)
     (= (hnan_of f) True)
     (= (fwf f x) True)
     (= (fwf f y) True))
    (= (fwf f (fmul f x y)) True))
  (case-on x FVal
    ((case Fin
       (s1 m1 e1)
       (chain
         (have hxe (= x (Fin s1 m1 e1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hd1 (= (lt 0 (fval_den f (Fin s1 m1 e1))) True)
                  (rewrite-with
                    (lemma fval_den_pos_any)
                    lr
                    lhs
                    ((inst f f) (inst s s1) (inst m m1) (inst e e1))
                    ()
                    refl))
                (have hd2 (= (lt 0 (fval_den f (Fin s2 m2 e2))) True)
                  (rewrite-with
                    (lemma fval_den_pos_any)
                    lr
                    lhs
                    ((inst f f) (inst s s2) (inst m m2) (inst e e2))
                    ()
                    refl))
                (have hdd
                  (=
                    (lt
                      0
                      (*
                        (fval_den f (Fin s1 m1 e1))
                        (fval_den f (Fin s2 m2 e2))))
                    True)
                  (rewrite-with
                    (lemma mul_pos)
                    lr
                    lhs
                    ((inst a (fval_den f (Fin s1 m1 e1)))
                     (inst b (fval_den f (Fin s2 m2 e2))))
                    ((steps ((rewrite (premise hd1) lr lhs true ())) refl)
                     (steps ((rewrite (premise hd2) lr lhs true ())) refl))
                    refl))
                (case-on (int_eq m1 0) Bool
                  ((case True
                     (chain
                       (have hz1 (= (int_eq m1 0) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
                       (have hb
                         (=
                           (fmul f (Fin s1 m1 e1) (Fin s2 m2 e2))
