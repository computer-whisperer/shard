                                              0
                                              (*
                                                (fval_num f (Fin s1 m1 e1))
                                                (fval_den f (Fin s2 m2 e2)))))
                                          (inst
                                            d
                                            (*
                                              (fval_den f (Fin s1 m1 e1))
                                              (- 0 (fval_num f (Fin s2 m2 e2))))))
                                         ((steps
                                            ((rewrite
                                               (premise 0)
                                               lr
                                               lhs
                                               true
                                               ()))
                                            refl)
                                          (steps
                                            ((rewrite
