                                   (reduce lhs)
                                   (rewrite (premise hz1) lr lhs true ())
                                   (reduce lhs))
                                  refl))
                              (have hwr
                                (=
                                  (fwf f (Fin (bxorb s1 s2) 0 (fmt_emin f)))
                                  True)
                                (rewrite-with
                                  (lemma fwf_zero)
                                  lr
                                  lhs
                                  ((inst f f) (inst s (bxorb s1 s2)))
                                  ((steps
                                     ((rewrite (premise 0) lr lhs true ()))
                                     refl))
                                  refl))
                              (steps
                                ((rewrite (premise hxe) lr lhs true ())
