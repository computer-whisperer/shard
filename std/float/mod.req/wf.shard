                          (unfold fmul lhs)
                          (reduce lhs)
                          (rewrite (premise hz1) lr lhs true ())
                          (reduce lhs)
                          (unfold fwf lhs)
                          (reduce lhs))
                         refl)))))))
            (case FNaN
              (chain
                (have hye (= y FNaN)
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hye) lr lhs true ())
                   (unfold fmul lhs)
                   (reduce lhs)
                   (unfold fwf lhs)
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl)))))))
     (case FInf
       (s1)
       (chain
         (have hxe (= x (FInf s1))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwi (= (hinf_of f) True)
           (steps
             ((rewrite (premise 2) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (case-on y FVal
           ((case Fin
              (s2 m2 e2)
              (chain
                (have hye (= y (Fin s2 m2 e2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (case-on (int_eq m2 0) Bool
                  ((case True
                     (chain
                       (have hz2 (= (int_eq m2 0) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
                       (steps
                         ((rewrite (premise hxe) lr lhs true ())
                          (rewrite (premise hye) lr lhs true ())
                          (unfold fmul lhs)
                          (reduce lhs)
                          (rewrite (premise hz2) lr lhs true ())
