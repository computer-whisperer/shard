                                         False)
                                       (steps
                                         ((rewrite (hyp False) lr lhs true ()))
                                         refl))
                                     (have hwfy (= (fwf_fin f m2 e2) True)
                                       (steps
                                         ((rewrite (premise 3) rl rhs true ())
                                          (rewrite (premise hye) lr rhs true ())
                                          (unfold fwf rhs)
                                          (simp rhs))
                                         refl))
                                     (have hm2 (= (le 1 m2) True)
                                       (rewrite-with
                                         (lemma fwf_m_lo)
                                         lr
                                         lhs
                                         ((inst f f) (inst m m2) (inst e e2))
