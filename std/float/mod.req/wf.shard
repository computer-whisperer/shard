                                refl)))
                          (case False
                            (chain
                              (have hz2 (= (int_eq m2 0) False)
                                (steps
                                  ((rewrite (hyp False) lr lhs true ()))
                                  refl))
                              (have hb
                                (=
                                  (fmul f (Fin s1 m1 e1) (Fin s2 m2 e2))
                                  (frnd
                                    f
                                    (*
                                      (fval_num f (Fin s1 m1 e1))
                                      (fval_num f (Fin s2 m2 e2)))
                                    (*
                                      (fval_den f (Fin s1 m1 e1))
                                      (fval_den f (Fin s2 m2 e2)))))
                                (steps
                                  ((unfold fmul lhs)
                                   (reduce lhs)
                                   (rewrite (premise hz1) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise hz2) lr lhs true ())
                                   (reduce lhs))
                                  refl))
                              (have hwr
                                (=
                                  (fwf
                                    f
                                    (frnd
                                      f
                                      (*
                                        (fval_num f (Fin s1 m1 e1))
                                        (fval_num f (Fin s2 m2 e2)))
                                      (*
                                        (fval_den f (Fin s1 m1 e1))
                                        (fval_den f (Fin s2 m2 e2)))))
                                  True)
                                (rewrite-with
                                  (lemma frnd_wf)
                                  lr
                                  lhs
                                  ((inst f f)
                                   (inst
                                     n
                                     (*
                                       (fval_num f (Fin s1 m1 e1))
                                       (fval_num f (Fin s2 m2 e2))))
                                   (inst
                                     d
                                     (*
                                       (fval_den f (Fin s1 m1 e1))
                                       (fval_den f (Fin s2 m2 e2)))))
                                  ((steps
                                     ((rewrite (premise 0) lr lhs true ()))
                                     refl)
                                   (steps
                                     ((rewrite (premise hdd) lr lhs true ()))
                                     refl))
                                  refl))
                              (steps
                                ((rewrite (premise hxe) lr lhs true ())
                                 (rewrite (premise hye) lr lhs true ())
                                 (rewrite (premise hb) lr lhs true ())
                                 (rewrite (premise hwr) lr lhs true ()))
                                refl)))))))))))
            (case FInf
              (s2)
              (chain
                (have hye (= y (FInf s2))
                  (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                (have hwi (= (hinf_of f) True)
                  (steps
                    ((rewrite (premise 3) rl rhs true ())
                     (rewrite (premise hye) lr rhs true ())
                     (unfold fwf rhs)
                     (simp rhs))
                    refl))
                (case-on (int_eq m1 0) Bool
                  ((case True
                     (chain
                       (have hz1 (= (int_eq m1 0) True)
                         (steps ((rewrite (hyp True) lr lhs true ())) refl))
