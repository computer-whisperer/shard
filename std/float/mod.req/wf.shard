                                  ((rewrite (hyp True) lr lhs true ()))
                                  refl))
                              (have hb
                                (=
                                  (fdiv f (Fin s1 m1 e1) (Fin s2 m2 e2))
                                  (Fin (bxorb s1 s2) 0 (fmt_emin f)))
                                (steps
                                  ((unfold fdiv lhs)
                                   (reduce lhs)
