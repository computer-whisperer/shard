;; --- the combined roundtrips + ranges the surfaces cite -------------------------
;; funpack∘fpack = id on EVERY wf view (assembles the R2.2 pieces: fin
;; fmt-ground, inf/nan parametric); fpack lands in [0, 2^width) on every wf
;; view (Fin via fpack_range_fXX, Inf/NaN by ground compute per sign).

(claim funpack_fpack_f32
  (goal ((x FVal)) ((= (fwf (fmt_f32) x) True))
    (= (funpack (fmt_f32) (fpack (fmt_f32) x)) x))
  (case-on x FVal
    ((case Fin
       (s m e)
       (chain
         (have hxe (= x (Fin s m e))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (fwf_fin (fmt_f32) m e) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (have hrt
           (= (funpack (fmt_f32) (fpack (fmt_f32) (Fin s m e))) (Fin s m e))
           (rewrite-with
             (lemma funpack_fpack_fin_f32)
             lr
             lhs
             ((inst s s) (inst m m) (inst e e))
             ((steps ((rewrite (premise hwf) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hxe) lr rhs true ())
            (rewrite (premise hrt) lr lhs true ()))
           refl)))
     (case FInf
       (s)
       (chain
         (have hxe (= x (FInf s))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hfw (= (fmt_wf (fmt_f32)) True) (steps ((compute lhs)) refl))
         (have hhi (= (hinf_of (fmt_f32)) True) (steps ((compute lhs)) refl))
         (have hrt (= (funpack (fmt_f32) (fpack (fmt_f32) (FInf s))) (FInf s))
           (rewrite-with
             (lemma funpack_fpack_inf)
             lr
             lhs
             ((inst f (fmt_f32)) (inst s s))
             ((steps ((rewrite (premise hfw) lr lhs true ())) refl)
              (steps ((rewrite (premise hhi) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hxe) lr rhs true ())
            (rewrite (premise hrt) lr lhs true ()))
           refl)))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hfw (= (fmt_wf (fmt_f32)) True) (steps ((compute lhs)) refl))
         (have hhn (= (hnan_of (fmt_f32)) True) (steps ((compute lhs)) refl))
         (have hrt (= (funpack (fmt_f32) (fpack (fmt_f32) FNaN)) FNaN)
           (rewrite-with
             (lemma funpack_fpack_nan)
             lr
             lhs
             ((inst f (fmt_f32)))
             ((steps ((rewrite (premise hfw) lr lhs true ())) refl)
              (steps ((rewrite (premise hhn) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hxe) lr rhs true ())
            (rewrite (premise hrt) lr lhs true ()))
           refl))))))

(claim fpack_range_all_f32
  (goal ((x FVal)) ((= (fwf (fmt_f32) x) True))
    (=
      (if (le 0 (fpack (fmt_f32) x)) (lt (fpack (fmt_f32) x) 4294967296) False)
      True))
  (case-on x FVal
    ((case Fin
       (s m e)
       (chain
         (have hxe (= x (Fin s m e))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (fwf_fin (fmt_f32) m e) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (have hr
           (=
             (if (le 0 (fpack (fmt_f32) (Fin s m e)))
               (lt (fpack (fmt_f32) (Fin s m e)) 4294967296)
               False)
             True)
           (rewrite-with
             (lemma fpack_range_f32)
             lr
             lhs
             ((inst s s) (inst m m) (inst e e))
             ((steps ((rewrite (premise hwf) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hr) lr lhs true ()))
           refl)))
     (case FInf
       (s)
       (chain
         (have hxe (= x (FInf s))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (case-on s Bool
           ((case True
              (chain
                (have hs (= s True)
                  (steps ((rewrite (hyp True) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hs) lr lhs true ())
                   (compute lhs))
                  refl)))
            (case False
              (chain
                (have hs (= s False)
                  (steps ((rewrite (hyp False) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hs) lr lhs true ())
                   (compute lhs))
                  refl)))))))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps ((rewrite (premise hxe) lr lhs true ()) (compute lhs)) refl))))))

