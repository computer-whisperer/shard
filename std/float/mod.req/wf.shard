             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hxe) lr rhs true ())
            (rewrite (premise hrt) lr lhs true ()))
           refl))))))

(claim fpack_range_all_f64
  (goal ((x FVal)) ((= (fwf (fmt_f64) x) True))
    (=
      (if (le 0 (fpack (fmt_f64) x))
        (lt (fpack (fmt_f64) x) 18446744073709551616)
        False)
      True))
  (case-on x FVal
    ((case Fin
       (s m e)
       (chain
         (have hxe (= x (Fin s m e))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (have hwf (= (fwf_fin (fmt_f64) m e) True)
           (steps
             ((rewrite (premise 0) rl rhs true ())
              (rewrite (premise hxe) lr rhs true ())
              (unfold fwf rhs)
              (simp rhs))
             refl))
         (have hr
           (=
             (if (le 0 (fpack (fmt_f64) (Fin s m e)))
               (lt (fpack (fmt_f64) (Fin s m e)) 18446744073709551616)
               False)
             True)
           (rewrite-with
             (lemma fpack_range_f64)
             lr
             lhs
             ((inst s s) (inst m m) (inst e e))
             ((steps ((rewrite (premise hwf) lr lhs true ())) refl))
             refl))
         (steps
           ((rewrite (premise hxe) lr lhs true ())
            (rewrite (premise hr) lr lhs true ()))
           refl)))
     (case FInf
       (s)
       (chain
         (have hxe (= x (FInf s))
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (case-on s Bool
           ((case True
              (chain
                (have hs (= s True)
                  (steps ((rewrite (hyp True) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hs) lr lhs true ())
                   (compute lhs))
                  refl)))
            (case False
              (chain
                (have hs (= s False)
                  (steps ((rewrite (hyp False) lr lhs true ())) refl))
                (steps
                  ((rewrite (premise hxe) lr lhs true ())
                   (rewrite (premise hs) lr lhs true ())
                   (compute lhs))
                  refl)))))))
     (case FNaN
       (chain
         (have hxe (= x FNaN) (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps ((rewrite (premise hxe) lr lhs true ()) (compute lhs)) refl))))))
