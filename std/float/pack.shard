(claim fpack_funpack_f32
  (goal ((b Int)) ((= (le 0 b) True) (= (lt b 4294967296) True))
    (=
      (fpack (fmt_f32) (funpack (fmt_f32) b))
      (if (fval_eqb (funpack (fmt_f32) b) FNaN) 2143289344 b)))
  (chain
    (have hPM (= (fpow2 (mw_of (fmt_f32))) 8388608)
      (steps ((compute lhs)) refl))
    (have hPE (= (fpow2 (ew_of (fmt_f32))) 256) (steps ((compute lhs)) refl))
    (have hPEM (= (fpow2 (+ (ew_of (fmt_f32)) (mw_of (fmt_f32)))) 2147483648)
      (steps ((compute lhs)) refl))
    (have hBIAS (= (fmt_bias (fmt_f32)) 127) (steps ((compute lhs)) refl))
    (have hHI (= (hinf_of (fmt_f32)) True) (steps ((compute lhs)) refl))
    (have hHN (= (hnan_of (fmt_f32)) True) (steps ((compute lhs)) refl))
    (have hd1a (= (+ (* 8388608 (ediv b 8388608)) (mod b 8388608)) b)
      (chain
        (rewrite-with
          (lemma ediv_mod_id)
          lr
          rhs
          ((inst n b) (inst d 8388608))
          ((steps ((compute lhs)) refl)))
        (steps () refl)))
