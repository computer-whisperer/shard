        (rewrite-with
          (lemma ediv_mod_id)
          lr
          rhs
          ((inst n (ediv b 8388608)) (inst d 256))
          ((steps ((compute lhs)) refl)))
        (steps () refl)))
    (have heb_lo (= (le 0 (mod (ediv b 8388608) 256)) True)
      (rewrite-with
        (lemma mod_lo)
