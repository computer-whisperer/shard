      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ((inst n b) (inst d 8388608))
        ((steps ((compute lhs)) refl))
        refl))
    (have hmb_hi (= (lt (mod b 8388608) 8388608) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ((inst n b) (inst d 8388608))
        ((steps ((compute lhs)) refl))
        refl))
    (have hd1b
