;; --- pack range + the encode side (rung R2 slice 2c), fmt-ground F32/F64 --------------
;; Range: every well-formed finite view packs into [0, 2^(1+EW+MW)) (Inf/NaN
;; are pinned ground above). Encode side: fpack . funpack is the identity on
;; every non-NaN encoding and collapses the whole NaN class to the canonical
;; slot — stated as one equation against the fval_eqb NaN test, so the
;; bijection-up-to-the-NaN-quotient is closed fmt-ground on both directions.

(claim fpack_range_f32
  (goal ((s Bool) (m Int) (e Int)) ((= (fwf_fin (fmt_f32) m e) True))
    (=
      (if (le 0 (fpack (fmt_f32) (Fin s m e)))
        (lt (fpack (fmt_f32) (Fin s m e)) 4294967296)
        False)
      True))
  (chain
    (have hPM (= (fpow2 (mw_of (fmt_f32))) 8388608)
      (steps ((compute lhs)) refl))
    (have hPM1 (= (fpow2 (+ (mw_of (fmt_f32)) 1)) 16777216)
      (steps ((compute lhs)) refl))
    (have hPE (= (fpow2 (ew_of (fmt_f32))) 256) (steps ((compute lhs)) refl))
    (have hPEM (= (fpow2 (+ (ew_of (fmt_f32)) (mw_of (fmt_f32)))) 2147483648)
      (steps ((compute lhs)) refl))
    (have hBIAS (= (fmt_bias (fmt_f32)) 127) (steps ((compute lhs)) refl))
    (have hEMIN (= (fmt_emin (fmt_f32)) -126) (steps ((compute lhs)) refl))
