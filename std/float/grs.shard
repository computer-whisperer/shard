;; --- the R2.3 equality, right-shift side: e = -j <= 0 -----------------------------------
;; fgrs f s m (-j) = frnd_pos f s m 2^j. elog_shr aligns the rows; the
;; L1 branch on erow <= MW splits against the GRS shift sign into three
;; live arms: exact placement (the euclidean split at divisor 2^j), the
;; scaled GRS (common factor 2^(MW-erow) cancelled by rne_div_scale), and
;; the deep arm where the L1 divisor product folds to 2^k directly.
(claim fgrs_frnd_pos_shr
  (goal ((f Fmt) (s Bool) (m Int) (j Int)) ((= (le 1 m) True) (= (le 0 j) True))
    (= (fgrs f s m (- 0 j)) (frnd_pos f s m (fpow2 j))))
  (chain
    (have helog (= (elog m (fpow2 j)) (- (- (ibits m) 1) j))
      (rewrite-with
        (lemma elog_shr)
        lr
        lhs
        ((inst m m) (inst j j))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (have hexp (= (- (- (ibits m) 1) j) (+ (- 0 j) (- (ibits m) 1)))
      (steps () (by arith (list (list 1 0 0 0) (list 1 0 0 0)))))
    (case-on (le (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f)) (mw_of f)) Bool
      ((case True
         (chain
           (have hgrow
             (=
               (le (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f)) (mw_of f))
               True)
             (steps ((rewrite (hyp True) lr lhs true ())) refl))
           (case-on
             (le
               (-
                 (- (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f)) (mw_of f))
                 (- 0 j))
               0)
             Bool
             ((case True
                (chain
                  (have hgk
                    (=
                      (le
                        (-
                          (-
                            (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f))
                            (mw_of f))
                          (- 0 j))
                        0)
                      True)
                    (steps ((rewrite (hyp True) lr lhs true ())) refl))
                  (have hmr
                    (=
                      (fshr_rne
                        m
                        (-
                          (-
                            (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f))
                            (mw_of f))
                          (- 0 j)))
                      (*
                        m
                        (fpow2
                          (-
                            0
                            (-
                              (-
                                (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f))
                                (mw_of f))
                              (- 0 j))))))
                    (steps
                      ((unfold fshr_rne lhs)
                       (rewrite (premise hgk) lr lhs true ())
                       (simp lhs))
                      refl))
                  (have hsp5
                    (=
                      (fpow2
                        (-
                          (mw_of f)
                          (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f))))
                      (*
                        (fpow2
                          (-
                            0
                            (-
                              (-
                                (imax (+ (- 0 j) (- (ibits m) 1)) (fmt_emin f))
                                (mw_of f))
                              (- 0 j))))
                        (fpow2 j)))
                    (chain
                      (have hE4sum
                        (=
                          (+
                            (-
                              0
                              (-
