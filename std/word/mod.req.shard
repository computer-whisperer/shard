;;; std/word/mod.req.shard — the PUBLIC INTERFACE of the `word` module (its ".h").
;;;
;;; Fixed-width modular integers as OPAQUE std constructions (replacing the
;;; revoked kernel `(Word W S)` former — trusted-core contraction, issue #15).
;;; The representation (a raw Int normalized into [0, 2^W)) is hidden behind a
;;; `sig type`; consumers build words only through the makers and observe only
;;; through `*_val`, reasoning via the law family below.
;;;
;;; SLICE 1: u8 only — the arithmetic pattern. u16/u32/u64 (and the signed
;;; siblings) follow this exact template; the `u8…i64` type-alias sugar
;;; (kernel/reader.shard) will repoint here once the family is complete.
;;;
;;; NOTE on range laws: because the type is opaque, the value-range facts are
;;; stated over CONSTRUCTED values (u8_made_lo/hi: `u8 n` is in [0,256)). Every
;;; u8 is `u8`-of-something behind the boundary, so this is the range fact
;;; consumers use. A structural `∀x:U8. 0 <= u8_val x < 256` over an arbitrary
;;; inhabitant is NOT provable from the construction (the rep is wider than the
;;; invariant) — that needs the refinement/subset type (designed follow-up,
;;; issue #15), which would make the bound type-given rather than compositional.

(import "../../kernel/stdlib.shard")  ; Int / Bool / True for the goals

(sig type U8)  ; opaque 8-bit unsigned word; the raw Int is hidden

(sig fn u8 ((n Int)) U8)  ; normalize an Int into a u8 (mod 256)
(sig fn u8_val ((x U8)) Int)  ; the raw value as an Int
(sig fn u8_add ((a U8) (b U8)) U8)
(sig fn u8_sub ((a U8) (b U8)) U8)
(sig fn u8_mul ((a U8) (b U8)) U8)
(sig fn u8_and ((a U8) (b U8)) U8)
(sig fn u8_or ((a U8) (b U8)) U8)
(sig fn u8_xor ((a U8) (b U8)) U8)
(sig fn u8_not ((x U8)) U8)  ; bitwise complement: 255 - raw
(sig fn u8_eq ((a U8) (b U8)) Bool)
(sig fn u8_lt ((a U8) (b U8)) Bool)  ; unsigned <
(sig fn u8_le ((a U8) (b U8)) Bool)  ; unsigned <=
(sig fn u8_shl ((x U8) (k Int)) U8)  ; logical shift left  (k in [0,64))
(sig fn u8_shr ((x U8) (k Int)) U8)  ; logical shift right (k in [0,64))

;; ---- the exported algebra (consumers reason against THIS) ------------------

;; constructor-projection: the raw value of a freshly made u8.
(requirement u8_val_of (goal ((n Int)) () (= (u8_val (u8 n)) (mod n 256))))

;; range of any constructed u8.
(requirement u8_made_lo (goal ((n Int)) () (= (le 0 (u8_val (u8 n))) True)))

(requirement u8_made_hi (goal ((n Int)) () (= (lt (u8_val (u8 n)) 256) True)))

;; arithmetic images: each op is the wrapped Int op on the raw values.
(requirement u8_add_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_add a b)) (mod (+ (u8_val a) (u8_val b)) 256))))

(requirement u8_sub_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_sub a b)) (mod (- (u8_val a) (u8_val b)) 256))))

(requirement u8_mul_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_mul a b)) (mod (* (u8_val a) (u8_val b)) 256))))

;; bitwise images (WRAPPED form: band/bor/bxor are opaque Int atoms to the
;; backends; the unwrapped "result already in range" simplification needs a
;; bit theory and the arbitrary-inhabitant range — deferred, issue #15).
(requirement u8_and_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_and a b)) (mod (band (u8_val a) (u8_val b)) 256))))

(requirement u8_or_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_or a b)) (mod (bor (u8_val a) (u8_val b)) 256))))

(requirement u8_xor_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_xor a b)) (mod (bxor (u8_val a) (u8_val b)) 256))))

(requirement u8_not_val
  (goal ((x U8)) () (= (u8_val (u8_not x)) (mod (- 255 (u8_val x)) 256))))

;; comparison images: unsigned compare IS Int compare on the raw values.
(requirement u8_eq_val
  (goal ((a U8) (b U8)) () (= (u8_eq a b) (int_eq (u8_val a) (u8_val b)))))

(requirement u8_lt_val
  (goal ((a U8) (b U8)) () (= (u8_lt a b) (lt (u8_val a) (u8_val b)))))

(requirement u8_le_val
  (goal ((a U8) (b U8)) () (= (u8_le a b) (le (u8_val a) (u8_val b)))))

;; shift images (WRAPPED): bshl/bshr are the raw-Int bit-shift prims (= * /
;; by 2^k for k in [0,64), opaque atoms to the backends). For a u8 raw and
;; k>=8 the wrap already yields 0, matching the kernel's wshl/ushr.
(requirement u8_shl_val
  (goal ((x U8) (k Int)) ()
    (= (u8_val (u8_shl x k)) (mod (bshl (u8_val x) k) 256))))

(requirement u8_shr_val
  (goal ((x U8) (k Int)) ()
    (= (u8_val (u8_shr x k)) (mod (bshr (u8_val x) k) 256))))

;; ===========================================================================
;; i8 — signed 8-bit. Approach B: the underlying Int stores the SIGNED value
;; in [-128, 128) (two's-complement value, not the raw bit pattern). i8_val is
;; therefore an identity projection; the work moves into i8_wrap, the signed
;; normalization (mod into [0,256), then fold [128,256) down by 256).
;; ===========================================================================

(sig type I8)  ; opaque 8-bit signed word; the signed Int value is hidden

(sig fn i8 ((n Int)) I8)  ; normalize a signed Int into [-128,128)
(sig fn i8_val ((x I8)) Int)  ; the signed value
(sig fn i8_wrap ((n Int)) Int)  ; the signed normalization (shared by the laws)
(sig fn i8_add ((a I8) (b I8)) I8)
(sig fn i8_sub ((a I8) (b I8)) I8)
(sig fn i8_mul ((a I8) (b I8)) I8)
(sig fn i8_eq ((a I8) (b I8)) Bool)
(sig fn i8_slt ((a I8) (b I8)) Bool)  ; signed <
(sig fn i8_sle ((a I8) (b I8)) Bool)  ; signed <=
(sig fn i8_shl ((x I8) (k Int)) I8)  ; shift left  (k in [0,64))
(sig fn i8_sshr ((x I8) (k Int)) I8)  ; arithmetic shift right (floor div)

;; constructor-projection: the value of a freshly made i8 is its signed wrap.
(requirement i8_val_of (goal ((n Int)) () (= (i8_val (i8 n)) (i8_wrap n))))

;; the signed wrap lands in [-128, 128).
(requirement i8_wrap_lo (goal ((n Int)) () (= (le -128 (i8_wrap n)) True)))

(requirement i8_wrap_hi (goal ((n Int)) () (= (lt (i8_wrap n) 128) True)))

;; arithmetic images: each op is the signed-wrapped Int op on the values.
(requirement i8_add_val
  (goal ((a I8) (b I8)) ()
    (= (i8_val (i8_add a b)) (i8_wrap (+ (i8_val a) (i8_val b))))))

(requirement i8_sub_val
  (goal ((a I8) (b I8)) ()
    (= (i8_val (i8_sub a b)) (i8_wrap (- (i8_val a) (i8_val b))))))

(requirement i8_mul_val
  (goal ((a I8) (b I8)) ()
    (= (i8_val (i8_mul a b)) (i8_wrap (* (i8_val a) (i8_val b))))))

;; comparison images: signed compare IS Int compare on the stored signed
;; values (the win of approach B — no sval reinterpretation needed).
(requirement i8_eq_val
  (goal ((a I8) (b I8)) () (= (i8_eq a b) (int_eq (i8_val a) (i8_val b)))))

(requirement i8_slt_val
  (goal ((a I8) (b I8)) () (= (i8_slt a b) (lt (i8_val a) (i8_val b)))))

(requirement i8_sle_val
  (goal ((a I8) (b I8)) () (= (i8_sle a b) (le (i8_val a) (i8_val b)))))

;; shift images: left = wrap of bshl; arithmetic right = wrap of euclidean
;; ediv by 2^k (= floor division = the arithmetic shift on a signed value).
(requirement i8_shl_val
  (goal ((x I8) (k Int)) ()
    (= (i8_val (i8_shl x k)) (i8_wrap (bshl (i8_val x) k)))))

(requirement i8_sshr_val
  (goal ((x I8) (k Int)) ()
    (= (i8_val (i8_sshr x k)) (i8_wrap (ediv (i8_val x) (bshl 1 k))))))
