;;; std/word/mod.req.shard — the PUBLIC INTERFACE of the `word` module (its ".h").
;;;
;;; Fixed-width modular integers as OPAQUE std constructions (replacing the
;;; revoked kernel `(Word W S)` former — trusted-core contraction, issue #15).
;;; The representation (a raw Int normalized into [0, 2^W)) is hidden behind a
;;; `sig type`; consumers build words only through the makers and observe only
;;; through `*_val`, reasoning via the law family below.
;;;
;;; SLICE 1: u8 only — the arithmetic pattern. u16/u32/u64 (and the signed
;;; siblings) follow this exact template; the `u8…i64` type-alias sugar
;;; (kernel/reader.shard) will repoint here once the family is complete.
;;;
;;; NOTE on range laws: because the type is opaque, the value-range facts are
;;; stated over CONSTRUCTED values (u8_made_lo/hi: `u8 n` is in [0,256)). Every
;;; u8 is `u8`-of-something behind the boundary, so this is the range fact
;;; consumers use. A structural `∀x:U8. 0 <= u8_val x < 256` over an arbitrary
;;; inhabitant is NOT provable from the construction (the rep is wider than the
;;; invariant) — that needs the refinement/subset type (designed follow-up,
;;; issue #15), which would make the bound type-given rather than compositional.

(import "../../kernel/stdlib.shard")  ; Int / Bool / True for the goals

(sig type U8)  ; opaque 8-bit unsigned word; the raw Int is hidden

(sig fn u8 ((n Int)) U8)  ; normalize an Int into a u8 (mod 256)
(sig fn u8_val ((x U8)) Int)  ; the raw value as an Int
(sig fn u8_add ((a U8) (b U8)) U8)
(sig fn u8_sub ((a U8) (b U8)) U8)
(sig fn u8_mul ((a U8) (b U8)) U8)

;; ---- the exported algebra (consumers reason against THIS) ------------------

;; constructor-projection: the raw value of a freshly made u8.
(requirement u8_val_of (goal ((n Int)) () (= (u8_val (u8 n)) (mod n 256))))

;; range of any constructed u8.
(requirement u8_made_lo (goal ((n Int)) () (= (le 0 (u8_val (u8 n))) True)))

(requirement u8_made_hi (goal ((n Int)) () (= (lt (u8_val (u8 n)) 256) True)))

;; arithmetic images: each op is the wrapped Int op on the raw values.
(requirement u8_add_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_add a b)) (mod (+ (u8_val a) (u8_val b)) 256))))

(requirement u8_sub_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_sub a b)) (mod (- (u8_val a) (u8_val b)) 256))))

(requirement u8_mul_val
  (goal ((a U8) (b U8)) ()
    (= (u8_val (u8_mul a b)) (mod (* (u8_val a) (u8_val b)) 256))))
