;;; std/word/word.shard — the `word` module IMPLEMENTATION (private).
;;;
;;; Full types (private ctors mk_uN/mk_iN), the bodies behind the opaque sig
;;; fns, and the fulfills (all `auto` — proofs machine-solved into the
;;; word.auto.shard sidecar by tools/prove; the wrap hints name the case
;;; split). Every op projects to Int, applies the Int op, re-wraps — so the range invariant holds BY CONSTRUCTION and each law reduces
;;; to a fact about euclidean `mod` (std/div). GENERATED — see tools/wordgen/wordgen.py.

(import "../../kernel/stdlib.shard")
(import "../../kernel/facts.shard")  ; mod_lo / mod_hi — euclidean remainder range
(import "mod.req.shard")  ; our interface — the opaque types + sig fns + reqs
(use (:: kernel facts *))  ; the mod range axioms for citation
(use (:: std word *))  ; impl-proof: rebind bodies + bring lemma names into scope

;; ---- u8: unsigned 8-bit -------------------------------------------------
(type U8 (mk_u8 Int))
(fn u8 ((nn Int)) U8 (mk_u8 (mod nn 256)))
(fn u8_val ((x U8)) Int
  (match x
    ((mk_u8 r) r)))
(fn u8_add ((a U8) (b U8)) U8 (u8 (+ (u8_val a) (u8_val b))))
(fn u8_sub ((a U8) (b U8)) U8 (u8 (- (u8_val a) (u8_val b))))
(fn u8_mul ((a U8) (b U8)) U8 (u8 (* (u8_val a) (u8_val b))))
(fn u8_and ((a U8) (b U8)) U8 (u8 (band (u8_val a) (u8_val b))))
(fn u8_or ((a U8) (b U8)) U8 (u8 (bor (u8_val a) (u8_val b))))
(fn u8_xor ((a U8) (b U8)) U8 (u8 (bxor (u8_val a) (u8_val b))))
(fn u8_not ((x U8)) U8 (u8 (- 255 (u8_val x))))
(fn u8_eq ((a U8) (b U8)) Bool (int_eq (u8_val a) (u8_val b)))
(fn u8_lt ((a U8) (b U8)) Bool (lt (u8_val a) (u8_val b)))
(fn u8_le ((a U8) (b U8)) Bool (le (u8_val a) (u8_val b)))
(fn u8_shl ((x U8) (k Int)) U8 (u8 (bshl (u8_val x) k)))
(fn u8_shr ((x U8) (k Int)) U8 (u8 (bshr (u8_val x) k)))

(fulfills u8_val_of auto)
(fulfills u8_made_lo auto)
(fulfills u8_made_hi auto)
(fulfills u8_add_val auto)
(fulfills u8_sub_val auto)
(fulfills u8_mul_val auto)
(fulfills u8_and_val auto)
(fulfills u8_or_val auto)
(fulfills u8_xor_val auto)
(fulfills u8_not_val auto)
(fulfills u8_eq_val auto)
(fulfills u8_lt_val auto)
(fulfills u8_le_val auto)
(fulfills u8_shl_val auto)
(fulfills u8_shr_val auto)

