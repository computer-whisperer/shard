(proof-for brep_mk (steps ((compute both)) refl))
(proof-for mapu8_nil (steps ((compute both)) refl))
(proof-for mapu8_cons (steps ((compute both)) refl))
(proof-for mapval_nil (steps ((compute both)) refl))
(proof-for mapval_cons (steps ((compute both)) refl))
