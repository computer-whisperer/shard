(proof-for
  blen_nonneg
  (steps
    ((unfold blen lhs) (simp lhs))
    (have (= (le 0 (len (brep b))) True)
      (rewrite-with (lemma len_nonneg) lr lhs () () refl)
      (by arith (list 1 1)))))
(proof-for
  idx_lo
  (steps
    ((unfold bidx lhs) (simp lhs))
    (have (= (lt (u8_val (u8 (raw_at (brep b) i))) 256) True)
      (rewrite-with (lemma u8_made_hi) lr lhs () () refl)
      (have (= (le 0 (u8_val (u8 (raw_at (brep b) i)))) True)
        (rewrite-with (lemma u8_made_lo) lr lhs () () refl)
        (by arith (list 1 0 1))))))
(proof-for
  idx_hi
  (steps
    ((unfold bidx lhs) (simp lhs))
    (have (= (lt (u8_val (u8 (raw_at (brep b) i))) 256) True)
      (rewrite-with (lemma u8_made_hi) lr lhs () () refl)
      (by arith (list 1 1)))))
(proof-for
  of_list_id
  (steps
    ((unfold bytes_of_list lhs) (simp lhs))
    (rewrite-with
      (lemma roundtrip)
      rl
      rhs
      ()
      ((by arith (list (list 1 -1) (list 1 1))))
      (steps ((compute both)) refl))))
(proof-for
  blen_is_len
  (steps
    ((unfold blen lhs)
     (unfold list_of_bytes rhs)
     (rewrite (lemma mapval_len) lr rhs true ()))
    refl))
(proof-for
  list_of_cat
  (steps
    ((unfold list_of_bytes lhs)
     (unfold bcat lhs)
     (rewrite (lemma brep_mk) lr lhs true ())
     (rewrite (lemma mapval_append) lr lhs true ())
     (unfold list_of_bytes rhs)
     (unfold list_of_bytes rhs))
    refl))
(proof-for
  cat_len
  (steps
    ((unfold blen lhs)
     (unfold bcat lhs)
     (rewrite (lemma brep_mk) lr lhs true ())
     (rewrite (lemma len_append) lr lhs true ())
     (unfold blen rhs)
     (unfold blen rhs))
    refl))
(proof-for
  slice_len_exact
  (steps
    ((unfold blen lhs)
     (unfold bslice lhs)
     (rewrite (lemma brep_mk) lr lhs true ()))
    (have (= (blen b) (len (brep b))) (steps ((unfold blen lhs)) refl)
      (rewrite-with
        (lemma take_len)
        lr
        lhs
        ()
        ((by arith (list 1 0 1 0 0))
         (rewrite-with
           (lemma drop_len)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
            (by arith (list 1 0 1 1 -1)))
           (by arith (list 1 0 0 1 -1))))
        refl))))
(proof-for bytes_eq_nil (steps ((compute both)) refl))
(proof-for bytes_eq_nil_cons (steps ((compute both)) refl))
(proof-for bytes_eq_cons_nil (steps ((compute both)) refl))
