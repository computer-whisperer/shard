;;; std/bytes/bytes.shard — the `bytes` module IMPLEMENTATION (private).
;;;
;;; Supplies bytes_ok's body and discharges the interface's derived
;;; requirements from the kernel's own (bytes-fact …) premise step —
;;; no axiom is touched here; the 5 bridge axioms in mod.req.shard are
;;; admitted at load and stand as the audit boundary. Consumers never
;;; load this file; they get mod.req.shard.

(import "../../kernel/stdlib.shard")
(import "mod.req.shard")  ; own interface: axioms + obligations
(use (:: std bytes bytes_ok))  ; sig→def rebind: our def supplies the sig

;; element-wise byte-range check, structurally recursive.
(fn bytes_ok ((xs (List Int))) Bool
  (match xs
    (Nil True)
    ((Cons h t) (if (le 0 h) (if (lt h 256) (bytes_ok t) False) False))))

;; --- defining equations -----------------------------------------------------

(fulfills bytes_ok_nil (steps ((unfold bytes_ok lhs) (reduce lhs)) refl))

(fulfills bytes_ok_cons (steps ((unfold bytes_ok lhs) (reduce lhs)) refl))

;; --- derived requirements: the kernel's bytes-fact, re-exported -------------

;; (bytes-fact (bcat a b)) injects p0: blen (bcat a b) = blen a + blen b.
(fulfills cat_len
  (bytes-fact (bcat a b) (steps ((rewrite (premise 0) lr lhs true ())) refl)))

;; (bytes-fact b) injects p0: (le 0 (blen b)) = True.
(fulfills blen_nonneg
  (bytes-fact b (steps ((rewrite (premise 0) lr lhs true ())) refl)))
