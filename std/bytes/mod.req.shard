;;; std/bytes/mod.req.shard — the PUBLIC INTERFACE of the `bytes` module.
;;;
;;; The LIST-MODEL BRIDGE for the built-in Bytes former: the laws
;;; connecting the packed prims (blen/bidx/bcat/bslice/bytes_of_list/
;;; list_of_bytes) to the (List Int) vocabulary (std/list len/append).
;;; The kernel cannot emit these — it has no list functions — so the
;;; bridge is THE AUDIT BOUNDARY for bytes, exactly as std/div's axioms
;;; are for `/`/`mod`:
;;;   - 5 TRUSTED AXIOMS, each mirroring the corresponding bp_* body in
;;;     kernel/reduce.shard, REVIEWED IN LOCKSTEP. Their ground
;;;     instances are runtime-pinned by examples/bytes_basics.shard.
;;;   - 2 DERIVED requirements (cat_len, blen_nonneg), proven in
;;;     bytes.shard from the kernel's own (bytes-fact …) step — the
;;;     consumer-facing forms of what the kernel already justifies.
;;;   - bytes_ok: the byte-range predicate (opaque sig + defining
;;;     equations) that guards the round-trip law.

(import "../../kernel/stdlib.shard")  ; Int / Bool / List / True
(import "../list")  ; len / append — the model vocabulary
(use (:: std list len))
(use (:: std list append))

;; all elements in byte range [0, 256)? The round-trip law's guard.
(sig fn bytes_ok ((xs (List Int))) Bool)

;; defining equations (the computational surface — bytes_ok is opaque).
(requirement bytes_ok_nil (goal () () (= (bytes_ok Nil) True)))

(requirement bytes_ok_cons
  (goal ((h Int) (t (List Int))) ()
    (=
      (bytes_ok (Cons h t))
      (if (le 0 h) (if (lt h 256) (bytes_ok t) False) False))))

;; --- trusted axioms: the packed/list bridge (the audit boundary) -----------

;; blen IS the model's length.
(axiom blen_is_len (goal ((b Bytes)) () (= (blen b) (len (list_of_bytes b)))))

;; concatenation is append on the model.
(axiom list_of_cat
  (goal ((a Bytes) (b Bytes)) ()
    (= (list_of_bytes (bcat a b)) (append (list_of_bytes a) (list_of_bytes b)))))

;; construction preserves length (masking is element-wise).
(axiom of_list_len
  (goal ((xs (List Int))) () (= (blen (bytes_of_list xs)) (len xs))))

;; the round trip is the identity ON BYTE-RANGE lists (out-of-range
;; elements are masked mod 256 — see examples/bytes_basics.shard's
;; bytes_mask_wraps for the unguarded behavior).
(axiom of_list_id
  (goal ((xs (List Int))) ((= (bytes_ok xs) True))
    (= (list_of_bytes (bytes_of_list xs)) xs)))

;; the exact slice length on a VALID window (the kernel's bytes-fact
;; emits only the clamped bounds — the exact law needs these premises).
(axiom slice_len_exact
  (goal ((b Bytes) (i Int) (j Int))
    ((= (le 0 i) True) (= (le i j) True) (= (le j (blen b)) True))
    (= (blen (bslice b i j)) (- j i))))

;; --- derived requirements (proven in bytes.shard via bytes-fact) -----------

;; the length of a concatenation, as a citable equation.
(requirement cat_len
  (goal ((a Bytes) (b Bytes)) () (= (blen (bcat a b)) (+ (blen a) (blen b)))))

;; lengths are non-negative.
(requirement blen_nonneg (goal ((b Bytes)) () (= (le 0 (blen b)) True)))
