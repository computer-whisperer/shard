;;; std/nat — back-compat shim.
;;;
;;; `nat` is now a directory-module: `std/nat/` holds the interface
;;; `mod.req.shard` (public: Nat, add_nat, int_of_nat, half_nat, and the
;;; exported lemmas) and `nat.shard` (private: half_step). This file
;;; preserves the old import path `std/nat.shard` by forwarding to the
;;; module directory, so existing importers keep working unchanged.
(import "nat")
