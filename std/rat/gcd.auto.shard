;;; proof sidecar — hand-written (tools/prove search exhausted on the
;;; premised mod_lo/mod_hi citations). check REPLAYS these entries.

(proof-for
  gcd_nn#0#decrease
  (rewrite-with
    (lemma mod_hi)
    lr
    lhs
    ()
    ((steps () (by arith (list 1 1))))
    refl))
(proof-for
  gcd_nn#0#nonneg
  (rewrite-with
    (lemma mod_lo)
    lr
    lhs
    ()
    ((steps () (by arith (list 1 1))))
    refl))
