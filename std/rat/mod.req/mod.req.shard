;;; std/rat/mod.req.shard — the PUBLIC INTERFACE of the `rat` module.
;;;
;;; Rat as an OPAQUE canonical rational: internally (refine RatRep rat_ok) — a
;;; (num, den) record refined to den > 0 and gcd(|num|, den) = 1 (the impl,
;;; rat.shard); here an abstract type whose every inhabitant is GUARANTEED
;;; canonical. The std/str shape (docs/REFINEMENT.md §6.5): the invariants are
;;; FULFILLED requirements (refine-fact through the doors), never assumptions.
;;;
;;;   rat_make = the one total constructor (normalizes; d = 0 -> 0/1)
;;;   rat_num / rat_den = the projections
;;;
;;; The canonical-form vocabulary (gcd_nn, iabs) comes from the proven sibling
;;; theorem module gcd.shard, so the invariants are STATABLE on the interface.

(import "../../../kernel/stdlib.shard")  ; Int / Bool / lt / le
(import "gcd.shard")  ; req-scope sibling — the canonical-form vocabulary
(use (:: std rat gcd gcd_nn))
(use (:: std rat gcd iabs))

;; an opaque canonical rational: den > 0, gcd-reduced (rat_den_pos/rat_reduced).
(sig type Rat)

;; the ONE constructor: n/d normalized to canonical form. Total: d = 0 maps to
;; the canonical zero 0/1 (the kernel euclidean d = 0 posture; a checked Option
;; wrapper can ride refine_try on consumer demand).
(sig fn rat_make ((n Int) (d Int)) Rat)

;; the projections.
(sig fn rat_num ((x Rat)) Int)
(sig fn rat_den ((x Rat)) Int)

;; --- the structural invariants: every Rat is a canonical fraction ------------

;; the denominator is positive, for EVERY inhabitant.
(requirement rat_den_pos (goal ((x Rat)) () (= (lt 0 (rat_den x)) True)))

;; the pair is reduced: gcd(|num|, den) = 1, for EVERY inhabitant.
(requirement rat_reduced
  (goal ((x Rat)) () (= (gcd_nn (iabs (rat_num x)) (rat_den x)) 1)))
