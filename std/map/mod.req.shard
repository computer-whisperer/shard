;;; std/map/mod.req.shard — the PUBLIC INTERFACE of the `map` module (its ".h").
;;;
;;; Finite (Map V) over Int keys. The TYPE IS OPAQUE — `(sig type (Map V))`
;;; declares the name but hides the constructors, so the assoc-list
;;; representation (with its shadowed entries) is invisible to consumers. They
;;; build maps only through `empty`/`insert` and observe only through `lookup`,
;;; reasoning via the EXTENSIONAL lemmas below — never by matching the
;;; representation. This is what makes the "two observationally-equal maps need
;;; not be structurally equal" discipline enforceable rather than aspirational.

(import "../../kernel/stdlib.shard")   ; Option / Bool / Int

(sig type (Map V))                                  ; abstract — ctors private to the impl
(sig fn (empty  V) ()                      (Map V)) ; the empty map
(sig fn (lookup V) ((k Int) (m (Map V)))   (Option V))
(sig fn (insert V) ((k Int) (v V) (m (Map V))) (Map V))

;; ---- the exported algebra (consumers reason against THIS) ------------------

;; reflexivity of int_eq (a general arithmetic fact; the enabling lemma for
;; lookup_insert_eq, so it ships here).
(requirement int_eq_refl
  (goal ((k Int)) ()
    (= (int_eq k k) True)))

;; the empty map has no bindings.
(requirement lookup_empty
  (goal ((k Int)) ()
    (= (lookup k (empty)) None)))

;; read back the value you just wrote.
(requirement lookup_insert_eq
  (goal ((k Int) (v V) (m (Map V))) ()
    (= (lookup k (insert k v m)) (Some v))))

;; a different key is unaffected by the insert.
(requirement lookup_insert_neq
  (goal ((j Int) (k Int) (v V) (m (Map V)))
        ((= (int_eq j k) False))
    (= (lookup j (insert k v m)) (lookup j m))))

;; a re-insert at the same key shadows the first — observed via lookup.
(requirement insert_shadow
  (goal ((j Int) (k Int) (v1 V) (v2 V) (m (Map V))) ()
    (= (lookup j (insert k v2 (insert k v1 m)))
       (lookup j (insert k v2 m)))))
