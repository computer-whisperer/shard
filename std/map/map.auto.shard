;;; proof sidecar — MACHINE-OWNED, written by tools/prove (comments are
;;; not preserved). check REPLAYS these entries; it never searches.

(proof-for int_eq_refl (by arith (list)))
(proof-for
  lookup_insert_eq
  (steps
    ((unfold insert lhs)
     (simp lhs)
     (rewrite (lemma int_eq_refl) lr lhs true ())
     (simp lhs))
    refl))
(proof-for
  insert_shadow
  (case-on (int_eq j k) Bool
    ((case False
       (steps
         ((unfold insert lhs)
          (unfold insert lhs)
          (unfold insert rhs)
          (simp lhs)
          (simp rhs)
          (rewrite (hyp 0) lr lhs true ())
          (rewrite (hyp 0) lr rhs true ())
          (simp lhs)
          (simp rhs)
          (rewrite (hyp 0) lr lhs true ())
          (simp lhs))
         refl))
     (case True
       (steps
         ((unfold insert lhs)
          (unfold insert lhs)
          (unfold insert rhs)
          (simp lhs)
          (simp rhs)
          (rewrite (hyp 0) lr lhs true ())
          (rewrite (hyp 0) lr rhs true ())
          (simp lhs)
          (simp rhs))
         refl)))))
(proof-for lookup_empty (steps ((compute both)) refl))
(proof-for
  lookup_insert_neq
  (steps
    ((unfold insert lhs)
     (simp lhs)
     (rewrite (premise 0) lr lhs true ())
     (simp lhs))
    refl))
