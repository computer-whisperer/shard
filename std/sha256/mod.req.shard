;;; std/sha256/mod.req.shard — the PUBLIC INTERFACE of the `sha256` module.
;;;
;;; FIPS 180-4 SHA-256 over byte lists. A message is a (List Int) of bytes
;;; (each in 0..255); the digest is the 32 hash bytes, or 64 lowercase-hex
;;; ASCII bytes through sha256_hex. Both fns are opaque — consumers get the
;;; ground NIST vector pins in sha256.shard (compute-proven against the
;;; implementation) as the behavioural anchor; the interface itself stays
;;; minimal.

(import "../../kernel/stdlib.shard")  ; Int / List
(import "../list")  ; len — the digest-length vocabulary
(use (:: std list len))

;; sha256: the 32-byte digest of a byte-list message.
(sig fn sha256 ((msg (List Int))) (List Int))

;; sha256_hex: the digest rendered as 64 lowercase-hex ASCII bytes.
(sig fn sha256_hex ((msg (List Int))) (List Int))

;; THE DIGEST-LENGTH CONTRACT: every digest is exactly 32 bytes, whatever the
;; message — the fact a consumer needs to lay a digest into a fixed-width slot.
(requirement sha256_len (goal ((msg (List Int))) () (= (len (sha256 msg)) 32)))

;; …and its hex rendering is exactly 64 bytes.
(requirement sha256_hex_len
  (goal ((msg (List Int))) () (= (len (sha256_hex msg)) 64)))
