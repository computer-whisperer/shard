;;; std/sha256/mod.build.shard — std/sha256's BUILD ENTRY (docs/BUILD.md
;;; §3: module-owned products live in the module's entry; the repo
;;; aggregator includes this file via build_entries and appends its
;;; build_products). The imp dialect sibling's proof gate (docs/IMP.md
;;; rung I2b — 'check imp, per the DI2 resolution) plus the generated
;;; statement-tier ISA legs (V2-5e sha legs: 'impgen regen pairs — the
;;; standard derive-and-verify ladder). The bin/artifact products
;;; arrive with I2e.

(import "../../kernel/stdlib.shard")
(import "../../meta/build")
(use (:: meta build *))

(fn build_products () (List BuildProfile)
  (list
    (MkBuildProfile
      (quote check)
      (quote imp)
      "std/sha256/sha256.imp.shard"
      "std/sha256/sha256.imp.shard"
      "")
    (MkBuildProfile
      (quote impgen)
      (quote wasm)
      "std/sha256/sha256.imp.shard"
      "std/sha256/impgen_wasm_out.shard"
      "")
    (MkBuildProfile
      (quote check)
      (quote imp)
      "std/sha256/impgen_wasm_out.shard"
      "std/sha256/impgen_wasm_out.shard"
      "")
    (MkBuildProfile
      (quote impgen)
      (quote x86)
      "std/sha256/sha256.imp.shard"
      "std/sha256/impgen_x86_out.shard"
      "")
    (MkBuildProfile
      (quote check)
      (quote imp)
      "std/sha256/impgen_x86_out.shard"
      "std/sha256/impgen_x86_out.shard"
      "")))
