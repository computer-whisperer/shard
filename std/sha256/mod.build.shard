;;; std/sha256/mod.build.shard — std/sha256's BUILD ENTRY (docs/BUILD.md
;;; §3: module-owned products live in the module's entry; the repo
;;; aggregator includes this file via build_entries and appends its
;;; build_products). Products-only for now: the imp dialect sibling's
;;; proof gate (docs/IMP.md rung I2b — 'check imp, per the DI2
;;; resolution). The pinlib/artifact products arrive with the flagship's
;;; ISA legs (rungs I2d/I2e).

(import "../../kernel/stdlib.shard")
(import "../../meta/build")
(use (:: meta build *))

(fn build_products () (List BuildProfile)
  (list
    (MkBuildProfile
      (quote check)
      (quote imp)
      "std/sha256/sha256.imp.shard"
      "std/sha256/sha256.imp.shard"
      "")))
