(claim xhg_h8gf_b
  (goal ((m Mem) (a Int) (vs (List Int)) (c Int)) ((= (lt c a) True))
    (= (xp_tb (h8p_go m a vs) c) False))
  (induct vs
    ((case Nil
       (steps
         ((unfold h8p_go lhs) (reduce lhs) (unfold xp_tb lhs) (reduce lhs))
         refl))
     (case Cons
       (x vt)
       (chain
         (have h1
           (=
             (xp_tb
               (h8p_go (wput m a (mod (+ (wget m a) x) 4294967296)) (+ a 4) vt)
               c)
             False)
           (rewrite-with
             (hyp ih)
             lr
             lhs
             ((inst m (wput m a (mod (+ (wget m a) x) 4294967296)))
              (inst a (+ a 4))
              (inst c c))
             ((by arith (list 1 1)))
             refl))
         (have h2
           (=
             (xp_tb (list (PWord a (mod (+ (wget m a) x) 4294967296))) c)
             False)
           (rewrite-with
             (lemma xhg_pw1b)
             lr
             lhs
             ((inst d a) (inst v (mod (+ (wget m a) x) 4294967296)) (inst c c))
             ((steps ((rewrite (premise 0) lr lhs true ())) refl))
             refl))
         (steps ((unfold h8p_go lhs) (reduce lhs)))
         (rewrite-with
           (lemma xhg_tbapp)
           lr
           lhs
           ((inst
              a
              (h8p_go (wput m a (mod (+ (wget m a) x) 4294967296)) (+ a 4) vt))
            (inst b (list (PWord a (mod (+ (wget m a) x) 4294967296))))
            (inst c c))
           ((steps ((rewrite (premise h1) lr lhs true ())) refl)
            (steps ((rewrite (premise h2) lr lhs true ())) refl)))
         refl)))))

(claim xhg_h8gf_a
  (goal ((m Mem) (a Int) (vs (List Int)) (c Int))
    ((= (le (+ a (* 4 (ilen vs))) c) True))
    (= (xp_tb (h8p_go m a vs) c) False))
  (induct vs
    ((case Nil
       (steps
         ((unfold h8p_go lhs) (reduce lhs) (unfold xp_tb lhs) (reduce lhs))
         refl))
     (case Cons
       (x vt)
       (chain
         (have hlen (= (ilen (Cons x vt)) (+ 1 (ilen vt)))
           (steps ((unfold ilen lhs) (reduce lhs)) refl))
         (have hp0b (= (le (+ a (* 4 (+ 1 (ilen vt)))) c) True)
           (steps
             ((rewrite (premise hlen) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (have hnn (= (le 0 (ilen vt)) True)
           (steps ((rewrite (lemma ilen_nonneg) lr lhs true ())) refl))
         (have h1
           (=
             (xp_tb
               (h8p_go (wput m a (mod (+ (wget m a) x) 4294967296)) (+ a 4) vt)
               c)
             False)
           (rewrite-with
             (hyp ih)
             lr
             lhs
             ((inst m (wput m a (mod (+ (wget m a) x) 4294967296)))
              (inst a (+ a 4))
              (inst c c))
             ((by arith (list 1 0 0 1 0)))
             refl))
         (have h2
           (=
             (xp_tb (list (PWord a (mod (+ (wget m a) x) 4294967296))) c)
             False)
           (rewrite-with
             (lemma xhg_pw1a)
             lr
             lhs
             ((inst d a) (inst v (mod (+ (wget m a) x) 4294967296)) (inst c c))
             ((by arith (list 1 0 0 1 4 0)))
             refl))
         (steps ((unfold h8p_go lhs) (reduce lhs)))
         (rewrite-with
           (lemma xhg_tbapp)
           lr
           lhs
           ((inst
              a
              (h8p_go (wput m a (mod (+ (wget m a) x) 4294967296)) (+ a 4) vt))
            (inst b (list (PWord a (mod (+ (wget m a) x) 4294967296))))
            (inst c c))
           ((steps ((rewrite (premise h1) lr lhs true ())) refl)
            (steps ((rewrite (premise h2) lr lhs true ())) refl)))
         refl)))))

(claim xhg_h8f_b
  (goal ((m Mem) (hb Int) (st H8) (c Int)) ((= (lt c hb) True))
    (= (xp_tb (h8p m hb st) c) False))
  (chain
    (steps ((unfold h8p lhs)))
    (rewrite-with
      (lemma xhg_h8gf_b)
      lr
      lhs
      ((inst m m)
       (inst a hb)
       (inst
         vs
         (list
           (h8a st)
           (h8b st)
           (h8c st)
           (h8d st)
           (h8e st)
           (h8f st)
           (h8g st)
           (h8h st)))
       (inst c c))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

(claim xhg_h8f_a
  (goal ((m Mem) (hb Int) (st H8) (c Int)) ((= (le (+ hb 32) c) True))
    (= (xp_tb (h8p m hb st) c) False))
  (chain
    (have hil
      (=
        (ilen
          (list
            (h8a st)
            (h8b st)
            (h8c st)
            (h8d st)
            (h8e st)
            (h8f st)
            (h8g st)
            (h8h st)))
        8)
      (steps ((compute lhs)) refl))
    (steps ((unfold h8p lhs)))
    (rewrite-with
      (lemma xhg_h8gf_a)
      lr
      lhs
      ((inst m m)
       (inst a hb)
       (inst
         vs
         (list
           (h8a st)
           (h8b st)
           (h8c st)
           (h8d st)
           (h8e st)
           (h8f st)
           (h8g st)
           (h8h st)))
       (inst c c))
      ((steps
         ((rewrite (premise hil) lr lhs true ())
          (compute lhs)
          (rewrite (premise 0) lr lhs true ()))
         refl)))
    refl))

;; --- the generic word-observation frame law ----------------------------------------

;; a wget past a patch list touching none of its four bytes is the base
;; read — EVERY (writer × wget) pair below is this law + that writer's
;; footprint lemma, nothing else
(claim xhg_wgetf
  (goal ((m Mem) (ps (List IPatch)) (p Int))
    ((= (xp_tb ps p) False)
     (= (xp_tb ps (+ p 1)) False)
     (= (xp_tb ps (+ p 2)) False)
     (= (xp_tb ps (+ p 3)) False))
    (= (wget (xp_mem m ps) p) (wget m p)))
  (chain
    (steps
      ((unfold wget both)
       (reduce both)
       (rewrite (lemma xpg_mgetfid) lr lhs true ())))
    (rewrite-with
      (lemma xpg_tbf)
      lr
      lhs
      ((inst m m) (inst ps ps) (inst b p))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (rewrite-with
      (lemma xpg_tbf)
      lr
      lhs
      ((inst m m) (inst ps ps) (inst b (+ p 1)))
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with
      (lemma xpg_tbf)
      lr
      lhs
      ((inst m m) (inst ps ps) (inst b (+ p 2)))
      ((steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (rewrite-with
      (lemma xpg_tbf)
      lr
      lhs
      ((inst m m) (inst ps ps) (inst b (+ p 3)))
      ((steps ((rewrite (premise 3) lr lhs true ())) refl)))
    refl))

;; --- THE DEMONSTRATIONS: the ish_* pair-lemma statements, re-derived ---------------
;; Each is collapse + frame + footprint — a few-line citation chain where
;; the hand family spends a bespoke induction per (observation × writer).

;; ish_wget_copy_below's statement
(claim xhd_wget_copy_below
  (goal ((m Mem) (s Int) (d Int) (c Int) (k Nat)) ((= (lt (+ c 3) d) True))
    (= (wget (copy_wmem m s d k) c) (wget m c)))
  (chain
    (steps ((rewrite (lemma xhg_cwc) lr lhs true ())))
    (rewrite-with
      (lemma xhg_wgetf)
      lr
      lhs
      ((inst m m) (inst ps (cwp m s d k)) (inst p c))
      ((rewrite-with
         (lemma xhg_cwf_b)
         lr
         lhs
         ((inst m m) (inst s s) (inst d d) (inst k k) (inst c c))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_cwf_b)
         lr
         lhs
         ((inst m m) (inst s s) (inst d d) (inst k k) (inst c (+ c 1)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_cwf_b)
         lr
         lhs
         ((inst m m) (inst s s) (inst d d) (inst k k) (inst c (+ c 2)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_cwf_b)
         lr
         lhs
         ((inst m m) (inst s s) (inst d d) (inst k k) (inst c (+ c 3)))
         ((by arith (list 1 1)))
         refl)))
    refl))

;; ish_wget_sched_below's statement
(claim xhd_wget_sched_below
  (goal ((m Mem) (p Int) (c Int) (k Nat)) ((= (lt (+ c 3) p) True))
    (= (wget (sched_mem m p k) c) (wget m c)))
  (chain
    (steps ((rewrite (lemma xhg_sdc) lr lhs true ())))
    (rewrite-with
      (lemma xhg_wgetf)
      lr
      lhs
      ((inst m m) (inst ps (sdp m p k)) (inst p c))
      ((rewrite-with
         (lemma xhg_sdf_b)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c c))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_b)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 1)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_b)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 2)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_b)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 3)))
         ((by arith (list 1 1)))
         refl)))
    refl))

;; the K-table shape: reads ABOVE the whole schedule window
(claim xhd_wget_sched_above
  (goal ((m Mem) (p Int) (c Int) (k Nat))
    ((= (le (+ p (* 4 (int_of_nat k))) c) True))
    (= (wget (sched_mem m p k) c) (wget m c)))
  (chain
    (steps ((rewrite (lemma xhg_sdc) lr lhs true ())))
    (rewrite-with
      (lemma xhg_wgetf)
      lr
      lhs
      ((inst m m) (inst ps (sdp m p k)) (inst p c))
      ((rewrite-with
         (lemma xhg_sdf_a)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c c))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_a)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 1)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_a)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 2)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_sdf_a)
         lr
         lhs
         ((inst m m) (inst p p) (inst k k) (inst c (+ c 3)))
         ((by arith (list 1 1)))
         refl)))
    refl))

;; ish_wget_h8add_below's statement
(claim xhd_wget_h8add_below
  (goal ((m Mem) (hb Int) (st H8) (c Int)) ((= (lt (+ c 3) hb) True))
    (= (wget (h8add_mem m hb st) c) (wget m c)))
  (chain
    (steps ((rewrite (lemma xhg_h8c) lr lhs true ())))
    (rewrite-with
      (lemma xhg_wgetf)
      lr
      lhs
      ((inst m m) (inst ps (h8p m hb st)) (inst p c))
      ((rewrite-with
         (lemma xhg_h8f_b)
         lr
         lhs
         ((inst m m) (inst hb hb) (inst st st) (inst c c))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_h8f_b)
         lr
         lhs
         ((inst m m) (inst hb hb) (inst st st) (inst c (+ c 1)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_h8f_b)
         lr
         lhs
         ((inst m m) (inst hb hb) (inst st st) (inst c (+ c 2)))
         ((by arith (list 1 1)))
         refl)
       (rewrite-with
         (lemma xhg_h8f_b)
         lr
         lhs
         ((inst m m) (inst hb hb) (inst st st) (inst c (+ c 3)))
         ((by arith (list 1 1)))
         refl)))
    refl))
