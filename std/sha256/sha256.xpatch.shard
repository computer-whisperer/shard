;; sha256.xpatch.shard — Arc A2 rung (d): the x86 segment-chain leg.
;;
;; CERT.md par.8/par.9: does base+patch avoid materializing full state at the
;; GENERATED chain's composition seams?  The landed cmp_x_shblock_bN family
;; re-generalizes the intermediate state at every seam: a 12-deep Cons
;; exposure with a ~40-line length-absurd per level (~2200 lines per seam,
;; 12 seams).  Here the same seam is derived by CITATION AT VIEW READS:
;; the segment-step cert (sqs_x_shblock_c12) instantiates at the patch
;; view's canonical reads (xp_loc lc ps i), the segment's effect enters as
;; a collapse fact in view form, xm_scont's register rebuild COMPUTES on
;; the literal-of-reads state, and the suffix cert (cmp_x_shblock_b13)
;; cites at the post-segment reads.  No case-on, no exposure, no fresh
;; symbols: the seam is a citation with view-read instantiations.

(import "../../kernel/stdlib.shard")
(import "sha256.imp.shard")
(import "../../models/imp/imp.shard")
(import "../../models/x86/x86.shard")
(import "../../models/imp/to_x86.shard")
(import "../../std/nat.shard")
(import "../../std/mem")
(import "../../models/wasm/loopkit.shard")
(import "../../models/x86/loopkit.shard")
(import "../../kernel/facts.shard")
(import "../../models/imp/probes/ipatch_probe.shard")
(import "impgen_x86_out.shard")
(use (:: std sha256 sha256.imp *))
(use (:: models imp imp *))
(use (:: models x86 x86 *))
(use (:: models imp to_x86 *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: models wasm loopkit *))
(use (:: models x86 loopkit *))
(use (:: kernel facts *))
(use (:: models imp probes ipatch_probe *))
(use (:: std sha256 impgen_x86_out *))

;; local verbatim copy of gb_shblock_c12_i: (inline ...) resolves against the
;; SAME-FILE fn table, and the spliced literal is what the generated seam terms
;; carry -- an identical literal splices from an identical body
(fn xc12_i () (List IStmt)
  (list
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (ILoc 6)))
    (ISet 9 (IBin U32 ISub (ILoc 8) (IConst 1)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))))

;; --- THE SEAM, patch-dialect: cmp_x_shblock_b12's statement at view reads,
;; derived from sqs_c12 + the segment collapse fact + cmp_b13 with ZERO
;; state exposure.  ps2 = the post-segment patch list; the collapse fact
;; (premise 0) is the per-segment product wave 2 prices below.
(claim xxd_b12v
  (goal
    ((lc (List Int))
     (ps (List IPatch))
     (ps2 (List IPatch))
     (m Mem)
     (za Int)
     (zb Int)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ((=
       (istmts
         (S^ 24 (S c2))
         65536
         (inline xc12_i)
         (list
           (xp_loc lc ps 0)
           (xp_loc lc ps 1)
           (xp_loc lc ps 2)
           (xp_loc lc ps 3)
           (xp_loc lc ps 4)
           (xp_loc lc ps 5)
           (xp_loc lc ps 6)
           (xp_loc lc ps 7)
           (xp_loc lc ps 8)
           (xp_loc lc ps 9)
           (xp_loc lc ps 10)
           (xp_loc lc ps 11))
         (xp_mem m ps))
       (Some
         (INorm
           (list
             (xp_loc lc ps2 0)
             (xp_loc lc ps2 1)
             (xp_loc lc ps2 2)
             (xp_loc lc ps2 3)
             (xp_loc lc ps2 4)
             (xp_loc lc ps2 5)
             (xp_loc lc ps2 6)
             (xp_loc lc ps2 7)
             (xp_loc lc ps2 8)
             (xp_loc lc ps2 9)
             (xp_loc lc ps2 10)
             (xp_loc lc ps2 11))
           (xp_mem m ps2)))))
    (=
      (xeval_seq
        (S^ 76 c)
        (MkXModule restfs 0 65536)
        (gb_shblock_r12_x)
        (MkRegs
          za
          (xp_loc lc ps 3)
          (xp_loc lc ps 2)
          (xp_loc lc ps 6)
          (xp_loc lc ps 7)
          (xp_loc lc ps 1)
          (xp_loc lc ps 0)
          (xp_loc lc ps 4)
          (xp_loc lc ps 5)
          zb
          0
          (xp_loc lc ps 8)
          (xp_loc lc ps 9)
          (xp_loc lc ps 10)
          (xp_loc lc ps 11))
        (xp_mem m ps))
      (ix_sout
        (istmts
          (S^ 52 c2)
          65536
          (gb_shblock_r12_i)
          (list
            (xp_loc lc ps 0)
            (xp_loc lc ps 1)
            (xp_loc lc ps 2)
            (xp_loc lc ps 3)
            (xp_loc lc ps 4)
            (xp_loc lc ps 5)
            (xp_loc lc ps 6)
            (xp_loc lc ps 7)
            (xp_loc lc ps 8)
            (xp_loc lc ps 9)
            (xp_loc lc ps 10)
            (xp_loc lc ps 11))
          (xp_mem m ps)))))
  (chain
    (have hx12
      (=
        (gb_shblock_r12_x)
        (Cons
          (XLoad8 RAX (AReg R12))
          (Cons
            (XBin32 XAdd R15 (SReg RAX))
            (Cons
              (XBin32 XAdd R12 (SImm 1))
              (Cons
                (XBin32 XMul R15 (SImm 256))
                (Cons
                  (XLoad8 RAX (AReg R12))
                  (Cons
                    (XBin32 XAdd R15 (SReg RAX))
                    (Cons
                      (XBin32 XAdd R12 (SImm 1))
                      (Cons
                        (XBin32 XAdd R15 (SReg RBX))
                        (Cons
                          (XMovRR R13 R12)
                          (Cons
                            (XBin32 XSub R13 (SImm 1))
                            (Cons
                              (XMovRR RAX R15)
                              (Cons
                                (XBin XAnd RAX (SImm 255))
                                (Cons
                                  (XStore8 (AReg R13) (SReg RAX))
                                  (Cons
                                    (XBin32 XSub R13 (SImm 1))
                                    (Cons
                                      (XShrI R15 8)
                                      (Cons
                                        (XMovRR RAX R15)
                                        (Cons
                                          (XBin XAnd RAX (SImm 255))
                                          (Cons
                                            (XStore8 (AReg R13) (SReg RAX))
                                            (Cons
                                              (XBin32 XSub R13 (SImm 1))
                                              (Cons
                                                (XShrI R15 8)
                                                (Cons
                                                  (XMovRR RAX R15)
                                                  (Cons
                                                    (XBin XAnd RAX (SImm 255))
                                                    (Cons
                                                      (XStore8
                                                        (AReg R13)
                                                        (SReg RAX))
                                                      (Cons
                                                        (XBin32
                                                          XSub
                                                          R13
                                                          (SImm 1))
                                                        (Cons
                                                          (XShrI R15 8)
                                                          (Cons
                                                            (XMovRR RAX R15)
                                                            (Cons
                                                              (XBin
                                                                XAnd
                                                                RAX
                                                                (SImm 255))
                                                              (Cons
                                                                (XStore8
                                                                  (AReg R13)
                                                                  (SReg RAX))
                                                                (Cons
                                                                  (XLoad8
                                                                    R15
                                                                    (AReg R12))
                                                                  (Cons
                                                                    (XBin32
                                                                      XAdd
                                                                      R12
                                                                      (SImm 1))
                                                                    (Cons
                                                                      (XBin32
                                                                        XMul
                                                                        R15
                                                                        (SImm
                                                                          256))
                                                                      (Cons
                                                                        (XLoad8
                                                                          RAX
                                                                          (AReg
                                                                            R12))
                                                                        (Cons
                                                                          (XBin32
                                                                            XAdd
                                                                            R15
                                                                            (SReg
                                                                              RAX))
                                                                          (Cons
                                                                            (XBin32
                                                                              XAdd
                                                                              R12
                                                                              (SImm
                                                                                1))
                                                                            (Cons
                                                                              (XBin32
                                                                                XMul
                                                                                R15
                                                                                (SImm
                                                                                  256))
                                                                              (Cons
                                                                                (XLoad8
                                                                                  RAX
                                                                                  (AReg
                                                                                    R12))
                                                                                (Cons
                                                                                  (XBin32
                                                                                    XAdd
                                                                                    R15
                                                                                    (SReg
                                                                                      RAX))
                                                                                  (Cons
                                                                                    (XMovRI
                                                                                      RAX
                                                                                      0)
                                                                                    (gb_shblock_r13_x))))))))))))))))))))))))))))))))))))))))
      (steps ((unfold gb_shblock_r12_x lhs)) refl))
    (have hsp (= (gb_shblock_r12_i) (isapp (inline xc12_i) (gb_shblock_r13_i)))
      (steps ((compute both)) refl))
    (have hfg (= (S^ 52 c2) (lg_fuel (istn (inline xc12_i)) (S (S^ 27 c2))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hx12) lr lhs true ())
       (rewrite (premise hsp) lr rhs true ())
       (rewrite (premise hfg) lr rhs true ())))
    (rewrite-with
      (lemma ist_seam)
      lr
      rhs
      ((inst g c2))
      ((steps ((compute lhs)) refl)))
    (have hfb (= (lg_fuel (istn (inline xc12_i)) (S c2)) (S^ 24 (S c2)))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hfb) lr rhs true ())
       (rewrite (premise 0) lr rhs true ())
       (unfold ist_cont rhs)
       (reduce rhs)))
    (rewrite-with (lemma sqs_x_shblock_c12) lr lhs ((inst g c2)) ())
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (unfold xm_scont lhs)
       (reduce lhs)
       (compute
         lhs
         (stop xeval_seq gb_shblock_r13_x istmts gb_shblock_r13_i xp_loc xp_mem))))
    (rewrite-with (lemma cmp_x_shblock_b13) lr lhs ((inst c2 c2)) ())
    (steps () refl)))
;; --- WAVE 2: the segment step itself — first contact of the collapse
;; theorems with GENERATED code.  xs8_i = the first 8 statements of
;; gb_shblock_c12_i verbatim (7 ISets + the first IStore: byte loads, the
;; word accumulate, the descending store pointer).  The named value ladder
;; xv1..xv8 is the load-bearing finding: values TELESCOPE (xv6 references
;; xv4 references xv3 references xv1), so inline spelling grows
;; quadratically — the generator must emit a naming ladder (or A3's
;; hash-consing arrives).  With names, per-statement cost is constant:
;; one xps cite + one iexp have.  On concrete patch lists the view
;; MATERIALIZES by computation (ground indices), so no read-through law
;; is needed here — locfid/mgetfid carry only the symbolic-ps seams.

(fn xs8_i () (List IStmt)
  (list
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (ILoc 6)))
    (ISet 9 (IBin U32 ISub (ILoc 8) (IConst 1)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))))

(fn xv1 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (+ l11 (mem_get m l8)) 4294967296))

(fn xv2 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int (mod (+ l8 1) 4294967296))

(fn xv3 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (* (xv1 l6 l8 l11 m) 256) 4294967296))

(fn xv4 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (+ (xv3 l6 l8 l11 m) (mem_get m (xv2 l6 l8 l11 m))) 4294967296))

(fn xv5 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (+ (xv2 l6 l8 l11 m) 1) 4294967296))

(fn xv6 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (+ (xv4 l6 l8 l11 m) l6) 4294967296))

(fn xv7 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int
  (mod (- (xv5 l6 l8 l11 m) 1) 4294967296))

(fn xv8 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Int (band (xv6 l6 l8 l11 m) 255))

;; the segment's effect, NAMED ONCE (the blk_ps shape on the generated leg)
(fn xq8 ((l6 Int) (l8 Int) (l11 Int) (m Mem)) (List IPatch)
  (Cons
    (PByte (xv7 l6 l8 l11 m) (xv8 l6 l8 l11 m))
    (Cons
      (PLoc 9 (xv7 l6 l8 l11 m))
      (Cons
        (PLoc 11 (xv6 l6 l8 l11 m))
        (Cons
          (PLoc 8 (xv5 l6 l8 l11 m))
          (Cons
            (PLoc 11 (xv4 l6 l8 l11 m))
            (Cons
              (PLoc 11 (xv3 l6 l8 l11 m))
              (Cons
                (PLoc 8 (xv2 l6 l8 l11 m))
                (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil)))))))))

;; band collapse at the U32 modulus (vxg_mc32's template)
(claim xxg_m32
  (goal ((n Int)) ((= (le 0 n) True) (= (lt n 4294967296) True))
    (= (mod n 4294967296) n))
  (chain
    (rewrite-with
      (lemma mod_unique)
      lr
      lhs
      ((inst q 0) (inst r n))
      ((by arith (list (list 1 0 0) (list 1 0 0)))
       (steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    refl))

;; THE SEGMENT COLLAPSE: 8 generated statements step to ONE named patch
;; term over the base state.  Premises = the segment's root address
;; bounds only; every derived bound is arithmetic on the named values.
(claim xxd_seg8
  (goal
    ((l0 Int)
     (l1 Int)
     (l2 Int)
     (l3 Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l10 Int)
     (l11 Int)
     (m Mem)
     (g Nat))
    ((= (le 0 l8) True) (= (lt (+ l8 2) 65536) True))
    (=
      (istmts
        (S^ 8 (S g))
        65536
        (inline xs8_i)
        (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
        m)
      (Some
        (INorm
          (xp_lc (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11) (xq8 l6 l8 l11 m))
          (xp_mem m (xq8 l6 l8 l11 m))))))
  (chain
    (have h0 (= (le 0 l8) True)
      (steps ((rewrite (premise 0) lr lhs true ())) refl))
    (have h1 (= (lt (+ l8 2) 65536) True)
      (steps ((rewrite (premise 1) lr lhs true ())) refl))
    (have hlt8 (= (lt l8 65536) True)
      (steps () (by arith (rows (goal 1) (h1 1)))))
    (have hc2 (= (xv2 l6 l8 l11 m) (+ l8 1))
      (chain
        (steps ((unfold xv2 lhs)))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have ha2a (= (le 0 (xv2 l6 l8 l11 m)) True)
      (steps
        ((rewrite (premise hc2) lr lhs true ()))
        (by arith (rows (goal 1) (h0 1)))))
    (have ha2b (= (lt (xv2 l6 l8 l11 m) 65536) True)
      (steps
        ((rewrite (premise hc2) lr lhs true ()))
        (by arith (rows (goal 1) (h1 1)))))
    (have hc5 (= (xv5 l6 l8 l11 m) (+ (+ l8 1) 1))
      (chain
        (steps ((unfold xv5 lhs) (rewrite (premise hc2) lr lhs true ())))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have hc7 (= (xv7 l6 l8 l11 m) (- (+ (+ l8 1) 1) 1))
      (chain
        (steps ((unfold xv7 lhs) (rewrite (premise hc5) lr lhs true ())))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have ha7a (= (le 0 (xv7 l6 l8 l11 m)) True)
      (steps
        ((rewrite (premise hc7) lr lhs true ()))
        (by arith (rows (goal 1) (h0 1)))))
    (have ha7b (= (lt (xv7 l6 l8 l11 m) 65536) True)
      (steps
        ((rewrite (premise hc7) lr lhs true ()))
        (by arith (rows (goal 1) (h1 1)))))
    (have he1
      (=
        (iexp
          (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8))))
          (xp_lc (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11) Nil)
          (xp_mem m Nil)
          65536)
        (Some (xv1 l6 l8 l11 m)))
      (steps
        ((compute lhs)
         (rewrite (premise h0) lr lhs true ())
         (rewrite (premise hlt8) lr lhs true ())
         (compute lhs)
         (unfold xv1 rhs))
        refl))
    (have he2
      (=
        (iexp
          (IBin U32 IAdd (ILoc 8) (IConst 1))
          (xp_lc
            (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
            (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))
          (xp_mem m (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))
          65536)
        (Some (xv2 l6 l8 l11 m)))
      (steps ((compute lhs (stop xv1)) (unfold xv2 rhs)) refl))
    (have he3
      (=
        (iexp
          (IBin U32 IMul (ILoc 11) (IConst 256))
          (xp_lc
            (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
            (Cons
              (PLoc 8 (xv2 l6 l8 l11 m))
              (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil)))
          (xp_mem
            m
            (Cons
              (PLoc 8 (xv2 l6 l8 l11 m))
              (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil)))
          65536)
        (Some (xv3 l6 l8 l11 m)))
      (steps ((compute lhs (stop xv1 xv2)) (unfold xv3 rhs)) refl))
    (have he4
      (=
        (iexp
          (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8))))
          (xp_lc
            (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
            (Cons
              (PLoc 11 (xv3 l6 l8 l11 m))
              (Cons
                (PLoc 8 (xv2 l6 l8 l11 m))
                (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))))
          (xp_mem
            m
            (Cons
              (PLoc 11 (xv3 l6 l8 l11 m))
              (Cons
                (PLoc 8 (xv2 l6 l8 l11 m))
                (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))))
          65536)
        (Some (xv4 l6 l8 l11 m)))
      (steps
        ((compute lhs (stop xv1 xv2 xv3))
         (rewrite (premise ha2a) lr lhs true ())
         (rewrite (premise ha2b) lr lhs true ())
         (compute lhs (stop xv1 xv2 xv3))
         (unfold xv4 rhs))
        refl))
    (have he5
      (=
        (iexp
          (IBin U32 IAdd (ILoc 8) (IConst 1))
          (xp_lc
            (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
            (Cons
              (PLoc 11 (xv4 l6 l8 l11 m))
              (Cons
                (PLoc 11 (xv3 l6 l8 l11 m))
                (Cons
                  (PLoc 8 (xv2 l6 l8 l11 m))
                  (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil)))))
          (xp_mem
            m
            (Cons
              (PLoc 11 (xv4 l6 l8 l11 m))
              (Cons
                (PLoc 11 (xv3 l6 l8 l11 m))
                (Cons
                  (PLoc 8 (xv2 l6 l8 l11 m))
                  (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil)))))
          65536)
        (Some (xv5 l6 l8 l11 m)))
      (steps ((compute lhs (stop xv1 xv2 xv3 xv4)) (unfold xv5 rhs)) refl))
    (have he6
      (=
        (iexp
          (IBin U32 IAdd (ILoc 11) (ILoc 6))
          (xp_lc
            (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
            (Cons
              (PLoc 8 (xv5 l6 l8 l11 m))
              (Cons
                (PLoc 11 (xv4 l6 l8 l11 m))
                (Cons
                  (PLoc 11 (xv3 l6 l8 l11 m))
                  (Cons
                    (PLoc 8 (xv2 l6 l8 l11 m))
                    (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))))))
          (xp_mem
            m
            (Cons
              (PLoc 8 (xv5 l6 l8 l11 m))
              (Cons
                (PLoc 11 (xv4 l6 l8 l11 m))
                (Cons
                  (PLoc 11 (xv3 l6 l8 l11 m))
                  (Cons
                    (PLoc 8 (xv2 l6 l8 l11 m))
                    (Cons (PLoc 11 (xv1 l6 l8 l11 m)) Nil))))))
          65536)
        (Some (xv6 l6 l8 l11 m)))
      (steps ((compute lhs (stop xv1 xv2 xv3 xv4 xv5)) (unfold xv6 rhs)) refl))
    (have he7
