(claim imp_x_shround
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (x8 Int)
     (x9 Int)
     (x10 Int)
     (x11 Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 90 c)
        (MkXModule restfs 0 65536)
        (inline gb_shround_x)
        (MkRegs 0 x3 x2 x6 x7 x1 x0 x4 x5 0 0 x8 x9 x10 x11)
        m)
      (ix_sout
        (istmts
          (S^ 54 c2)
          65536
          (inline gb_shround_i)
          (list x0 x1 x2 x3 x4 x5 x6 x7 x8 x9 x10 x11)
          m))))
  (chain
    (steps ((compute both)))
    (case-on (le 0 x8) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp 0) lr both true ()) (compute both)))
           (case-on (lt x8 65536) Bool
             ((case True
                (chain
                  (have hlt2 (= (lt x8 65536) True)
