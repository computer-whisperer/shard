                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        (IConst
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          7)))
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Nil))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))

(claim shi_bridge
  (goal ((ls (List Int)) (m Mem) (d Nat)) ()
    (=
      (istmts (S^ 600 d) 65536 (inline shi_nf_body) ls m)
      (istmts (S^ 600 d) 65536 (inline shi_src_body) ls m)))
  (steps ((compute both (stop istmts))) refl))

(claim shi_winit
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (x8 Int)
     (x9 Int)
     (x10 Int)
     (x11 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 2024 c)
        (MkWModule restfs 65536)
        (gb_shinit_w)
        (list x0 x1 x2 x3 x4 x5 x6 x7 x8 x9 x10 x11)
        st
        m)
      (Some
        (ONorm st (list 65507 x1 x2 x3 x4 x5 x6 x7 x8 x9 x10 x11) (ikh_mem m)))))
  (chain
    (steps ((unfold gb_shinit_w lhs)))
    (rewrite-with (lemma imp_w_shinit) lr lhs ((inst c2 (S^ 17 d))) ())
    (steps
      ((rewrite (lemma shi_bridge) lr lhs true ())
       (rewrite (lemma isha_init_walk) lr lhs true ())
       (compute lhs (stop ikh_mem))))
    refl))

(claim shi_xinit
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (x8 Int)
     (x9 Int)
     (x10 Int)
     (x11 Int)
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 583 c)
        (MkXModule restfs 0 65536)
        (gb_shinit_x)
        (MkRegs 0 x3 x2 x6 x7 x1 x0 x4 x5 0 0 x8 x9 x10 x11)
        m)
      (Some
        (XNorm
          (MkRegs 0 x3 x2 x6 x7 x1 65507 x4 x5 0 0 x8 x9 x10 x11)
          (ikh_mem m)))))
  (chain
    (steps ((unfold gb_shinit_x lhs)))
    (rewrite-with (lemma imp_x_shinit) lr lhs ((inst c2 (S^ 17 d))) ())
    (steps
      ((rewrite (lemma shi_bridge) lr lhs true ())
       (rewrite (lemma isha_init_walk) lr lhs true ())
       (compute lhs (stop ikh_mem))))
    refl))

;; ---- THE PAD RUNS (I2e-2c) --------------------------------------------------------
;; The machine pad legs land on the sibling's walk: the generated
;; bridges meet isha_pad_walk directly -- the pin body is already its
;; own normal form (no builder calls, every ground literal folded), so
;; no spelling bridge is needed. Fuel: the bridges state istmts at
;; (S^ 87 c2); the walk at (S^ 120 d); c2 := (S^ 33 d) aligns them as
;; one tree. The exit memory is ipd_mem -- ish_pad_read gives the
;; sha_pad readback over it, ish_pad_hi the persistence above the
;; span.

;; the flat body, byte-copied from the sibling (the (inline ...) carrier)
(fn shp_ibody () (List IStmt)
  (list
    (ISet 2 (IBin U32 IAdd (ILoc 0) (ILoc 1)))
    (ISet 3 (IConst 72))
    (IWhile
      (ILoc 3)
      (list
        (IStore (ILoc 2) (IConst 0))
        (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
        (ISet 3 (IBin U32 ISub (ILoc 3) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 0) (ILoc 1)))
    (IStore (ILoc 2) (IConst 128))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (ISet 3 (IBin U32 ISub (IConst 55) (ILoc 1)))
    (ISet 3 (IBin U32 IAnd (ILoc 3) (IConst 63)))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (ILoc 3)))
    (ISet 4 (IBin U64 IMul (IConst 8) (IExt U32 U64 (ILoc 1))))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 56)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 48)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 40)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 32)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 24)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 16)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore
      (ILoc 2)
      (ITrunc U32 U8 (ITrunc U64 U32 (IBin U64 IShr (ILoc 4) (IConst 8)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ITrunc U64 U32 (ILoc 4))))))

;; the x86 out's chained spelling: the flat tail folds behind the
;; rest fn (the V2-8 chain architecture); the bridge normalizes both
;; spellings to the shared form under a stopped istmts
(fn shp_xchain () (List IStmt)
  (Cons
    (ISet 2 (IBin U32 IAdd (ILoc 0) (ILoc 1)))
    (Cons
      (ISet 3 (IConst 72))
      (Cons
        (IWhile
          (ILoc 3)
          (list
            (IStore (ILoc 2) (IConst 0))
            (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 1)))
            (ISet 3 (IBin U32 ISub (ILoc 3) (IConst 1)))))
        (gb_shpad_r1_i)))))

(claim shp_xbridge
  (goal ((ls (List Int)) (m Mem) (d Nat)) ()
    (=
      (istmts (S^ 120 d) 65536 (inline shp_xchain) ls m)
      (istmts (S^ 120 d) 65536 (inline shp_ibody) ls m)))
  (steps ((compute both (stop istmts))) refl))

(claim shp_wpad
  (goal
    ((src Int)
     (n Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List Func)))
    ((= (le 0 src) True) (= (le 0 n) True) (= (le (+ (+ src n) 72) 65536) True))
    (=
      (eval_seq
        (S^ 133 c)
        (MkWModule restfs 65536)
        (gb_shpad_w)
        (list src n x2 x3 x4)
        st
        m)
      (Some
        (ONorm
          st
          (list
            src
            n
            (+ (+ (+ (+ (+ (+ (+ (ipd_ql src n) 1) 1) 1) 1) 1) 1) 1)
            (ipd_zf n)
            (ipd_l n))
          (ipd_mem m src n)))))
  (chain
    (steps ((unfold gb_shpad_w lhs)))
    (rewrite-with (lemma imp_w_shpad) lr lhs ((inst c2 (S^ 33 d))) ())
    (rewrite-with
      (lemma isha_pad_walk)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs (stop ipd_mem ipd_zf ipd_ql ipd_l))))
    refl))

(claim shp_xpad
  (goal
    ((src Int)
     (n Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List XFunc)))
    ((= (le 0 src) True) (= (le 0 n) True) (= (le (+ (+ src n) 72) 65536) True))
    (=
      (xeval_seq
        (S^ 89 c)
        (MkXModule restfs 0 65536)
        (gb_shpad_x)
        (MkRegs 0 x3 x2 0 0 n src x4 0 0 0 0 0 0 0)
        m)
      (Some
        (XNorm
          (MkRegs
            0
            (ipd_zf n)
            (+ (+ (+ (+ (+ (+ (+ (ipd_ql src n) 1) 1) 1) 1) 1) 1) 1)
            0
            0
            n
            src
            (ipd_l n)
            0
            0
            0
            0
            0
            0
            0)
          (ipd_mem m src n)))))
  (chain
    (steps ((unfold gb_shpad_x lhs)))
    (rewrite-with (lemma imp_x_shpad) lr lhs ((inst c2 (S^ 33 d))) ())
    (steps ((rewrite (lemma shp_xbridge) lr lhs true ())))
    (rewrite-with
      (lemma isha_pad_walk)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs (stop ipd_mem ipd_zf ipd_ql ipd_l))))
    refl))
