;; the exit memory's K window is untouched: the constants persist
(claim shw_out_k
  (goal ((m Mem) (src Int) (wb Int)) ((= (wlist m (+ wb 256) 64) (sha_k)))
    (= (wlist (shw_mem m src wb) (+ wb 256) 64) (sha_k)))
  (chain
    (steps ((rewrite (lemma shw_mem_def) lr lhs true ())))
    (rewrite-with
      (lemma ish_wlist_h8add_below)
      lr
      lhs
      ()
      ((steps
         ((compute lhs) (rewrite (lemma ish_i64p) lr lhs true ()) (compute lhs))
         (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wlist_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (steps ((rewrite (premise 0) lr lhs true ())))
    refl))

;; every window below wb is untouched: the message region persists
(claim shw_out_lo
  (goal ((m Mem) (src Int) (wb Int) (p Int) (j Nat))
    ((= (le (+ p (* 4 (int_of_nat j))) wb) True))
    (= (wlist (shw_mem m src wb) p j) (wlist m p j)))
  (chain
    (steps ((rewrite (lemma shw_mem_def) lr lhs true ())))
    (rewrite-with
      (lemma ish_wlist_h8add_below)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (steps ((rewrite (lemma shw_sm_def) lr lhs true ())))
    (rewrite-with
      (lemma ish_wlist_sched_below)
      lr
      lhs
      ()
      ((steps ((compute lhs)) (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wlist_copy_below)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

;; --- I2e-2b: THE INIT WELD — the prologue's machine code lands on ikh_mem ---
;; Both generated legs share ONE flat NF spelling (the init is
;; straight-line, so the x86 tier emits it unchunked); the weld
;; carries the source spelling and the NF as local nullary fns and
;; crosses by the I2e-1 compute-both bridge. Fuel: the bridges state
;; istmts at (S^ 583 c2); the walk at (S^ 600 d); c2 := (S^ 17 d)
;; aligns them as one tree.

(fn shi_src_body () (List IStmt)
  (Cons (ISet 0 (IConst 65219)) (ikh_wstmts (ikh_kh))))

