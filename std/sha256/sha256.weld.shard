;; ---- THE BLOCKS LOOP (I2e-3): the wasm leg ----------------------------------------
;; The compression loop is a PURE artifact at the call boundary (the
;; I2e composition ruling): a counted loop whose per-iteration work is
;; a CALL to the generated block. The callee wrapper pushes its result
;; FIRST -- the block run preserves the stack (shw_wblock quantifies
;; it), so the push surfaces as the return value and the generated
;; body is used verbatim, no append. The layout is the ruled ground
;; frame: wb = 64960 (W@64960 K@65216 H@65472).

(fn shb_wfn () Func (MkFunc 10 2 (Cons (I32Const 0) (gb_shblock_w))))

;; one-instruction peel at a folded tail (the phase-pin idiom at the
;; machine grain: the tail stays a stopped call)
(claim shb_push
  (goal
    ((t (List Instr))
     (mo WModule)
     (lc (List Int))
     (st (List Int))
     (m Mem)
     (f Nat))
    ()
    (=
      (eval_seq (S^ 2 f) mo (Cons (I32Const 0) t) lc st m)
      (eval_seq (S f) mo t lc (Cons 0 st) m)))
  (steps ((compute both)) refl))

;; the callee's run: the block behind the call boundary, from the ten
;; pushed arguments (eight dead zeros, src, the ground frame base)
(claim shb_wcall
  (goal ((src Int) (m Mem) (c Nat) (restfs (List Func)))
    ((= (le 0 src) True) (= (le (+ src 64) 64960) True))
    (=
      (call_fn_mem
        (S^ 1196 c)
        (MkWModule (Cons (shb_wfn) restfs) 65536)
        0
        (list 0 0 0 0 0 0 0 0 src 64960)
        m)
      (Some (Pair 0 (shw_mem m src 64960)))))
  (chain
    (steps
      ((unfold call_fn_mem lhs)
       (compute lhs (stop eval_seq gb_shblock_w shw_mem))))
    (have hf (= (S^ 1196 c) (S^ 2 (S^ 1194 c))) (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hf) lr lhs true ())
       (rewrite (lemma shb_push) lr lhs true ())))
    (have hf2 (= (S (S^ 1194 c)) (S^ 1195 c)) (steps ((compute both)) refl))
    (steps ((rewrite (premise hf2) lr lhs true ())))
    (rewrite-with
      (lemma shw_wblock)
      lr
      lhs
      ((inst d c))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((compute lhs)) refl)))
    (steps ((compute lhs (stop shw_mem shw_locals))))
    refl))

;; the loop body: guard on the count, ten pushes, the call, the two
;; bumps. Locals: 0 = src (advances by 64), 1 = the block count.
(fn shb_wbody () (List Instr)
  (list
    (LocalGet 1)
    (I32Eqz)
    (BrIf 1)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (I32Const 0)
    (LocalGet 0)
    (I32Const 64960)
    (Call 0)
    (Drop)
    (LocalGet 0)
    (I32Const 64)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 1)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 1)
    (Br 0)))

;; the loop fn spelled as a LITERAL MkFunc where it appears in a module
;; (below): func_at/body_of compute directly on the literal, and the
;; exposed loop body is (inline shb_wbody) -- exactly the worker's body
;; arg (the callee shb_wfn stays folded, reconciled inside call_bridge).

;; the loop's memory effect: k blocks folded over the ground frame,
;; the source window advancing 64 per block
(fn shb_mem ((m Mem) (src Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (shb_mem (shw_mem m src 64960) (+ src 64) k2))))

(claim shb_mem_z
  (goal ((m Mem) (src Int)) () (= (shb_mem m src Z) m))
  (steps ((unfold shb_mem lhs) (reduce lhs)) refl))

(claim shb_mem_s
  (goal ((m Mem) (src Int) (k Nat)) ()
    (= (shb_mem m src (S k)) (shb_mem (shw_mem m src 64960) (+ src 64) k)))
  (steps ((unfold shb_mem lhs) (reduce lhs)) refl))

;; the worker: k loop passes from the loop head ARE the k-block fold
(claim shb_wloop
  (goal ((src Int) (st (List Int)) (m Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 src) True) (= (le (+ src (* 64 (int_of_nat k))) 64960) True))
    (=
      (eval_loop
        (S^ 1212 (lg_fuel k c))
        (MkWModule
          (Cons
            (shb_wfn)
            (Cons
              (MkFunc
                2
                0
                (list (Block (list (Loop (inline shb_wbody)))) (I32Const 0)))
              restfs))
          65536)
        (inline shb_wbody)
        (list src (int_of_nat k))
        st
        m)
      (Some (OBr 0 st (list (lg_advk src 64 k) 0) (shb_mem m src k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ())
          (compute both (stop shw_mem gb_shblock_w)))
         refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hqs (= (le (+ src (* 64 (+ 1 (int_of_nat k2)))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold eval_loop lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute
              lhs
              (stop eval_call eval_loop lg_fuel gb_shblock_w shw_mem shb_mem
                lg_advk shb_wfn))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute
              lhs
              (stop eval_call eval_loop lg_fuel gb_shblock_w shw_mem shb_mem
                lg_advk shb_wfn))))
         (rewrite-with
           (lemma call_bridge)
           lr
           lhs
           ((inst f (inline shb_wfn))
            (inst popped (list 64960 src 0 0 0 0 0 0 0 0))
            (inst rest st)
            (inst args (list 0 0 0 0 0 0 0 0 src 64960))
            (inst v 0)
            (inst mem2 (shw_mem m src 64960)))
           ((steps ((compute both)) refl)
            (steps ((compute both (stop shb_wfn))) refl)
            (steps ((compute both)) refl)
            (steps ((compute both (stop shb_wfn))) refl)
            (chain
              (rewrite-with
                (lemma shb_wcall)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                 (steps () (by arith (rows (goal 1) (hqs 1) (hnn 64))))))
              refl)))
         (steps
           ((compute
              lhs
              (stop eval_call eval_loop lg_fuel gb_shblock_w shw_mem shb_mem
                lg_advk shb_wfn))))
         (have hw0 (= (mod (+ src 64) 4294967296) (+ src 64))
           (rewrite-with
             (lemma ish_mid32)
             lr
             lhs
             ()
             ((steps () (by arith (rows (goal 1) (0 1))))
              (steps () (by arith (rows (goal 1) (hqs 1) (hnn 64)))))
             refl))
         (steps ((rewrite (premise hw0) lr lhs true ())))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma ish_mid32)
             lr
             lhs
             ()
             ((steps ((rewrite (premise hnn) lr lhs true ())) refl)
              (steps () (by arith (rows (goal 1) (hnn 63) (hqs 1) (0 1)))))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         (steps
           ((rewrite (lemma lg_advk_s) rl lhs true ())
            (rewrite (lemma shb_mem_s) rl lhs true ())))
         refl)))))

;; the loop's denotation: call the loop fn (index 1) on src and the
;; block count -- the k-block memory fold, the source consumed 64 per
;; block. The result value is the trailing (I32Const 0).
(claim shb_wblocks
  (goal ((src Int) (m Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 src) True) (= (le (+ src (* 64 (int_of_nat k))) 64960) True))
    (=
      (call_fn_mem
        (S^ 1216 (lg_fuel k c))
        (MkWModule
          (Cons
            (shb_wfn)
            (Cons
              (MkFunc
                2
                0
                (list (Block (list (Loop (inline shb_wbody)))) (I32Const 0)))
              restfs))
          65536)
        1
        (list src (int_of_nat k))
        m)
      (Some (Pair 0 (shb_mem m src k)))))
  (chain
    (steps
      ((unfold call_fn_mem lhs)
       (compute lhs (stop eval_loop lg_fuel shb_mem shb_wfn))))
    (rewrite-with
      (lemma shb_wloop)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs (stop shb_mem))))
    refl))

;; ---- THE BLOCKS LOOP (I2e-3): the x86 leg ----------------------------------------
;; The register-as-interface consequence: shw_xblock's output file is
;; h8 words and ZEROS -- the block clobbers src (r12) and wb (r13), so
;; the loop's induction state cannot ride registers across the call.
;; The loop SPILLS src and count to [65504, 65508) -- above the frame
;; end wb + 544 = 65504, the one region the block never touches -- as
;; two-byte little-endian words (both values sit below 2^16), and the
;; post-call reload reads them back THROUGH the block's memory effect
;; (ish_get_shw_above) and recombines by the euclidean round trip
;; (ish_rt2). Dirtied registers are re-zeroed each pass (the walker's
;; zero-in/zero-out idiom at the machine grain), so the loop head is
;; one pinned register file and the worker induction closes.

;; a byte read at or above 65504 sees through the whole block effect
;; (the frame is [64960, 65504): copy [64960,65024), schedule
;; [65024,65216), finish adds [65472,65504))
(claim ish_get_shw_above
  (goal ((m Mem) (src Int) (p Int)) ((= (le 65504 p) True))
    (= (mem_get (shw_mem m src 64960) p) (mem_get m p)))
  (chain
    (steps
      ((unfold shw_mem lhs)
       (unfold shw_sm lhs)
       (compute lhs (stop mem_get copy_wmem sched_mem h8add_mem shw_r))))
    (rewrite-with
      (lemma ish_get_h8add_above)
      lr
      lhs
      ()
      ((chain
         (steps ((compute both)))
         (steps ((rewrite (premise 0) lr lhs true ())) refl))))
    (rewrite-with
      (lemma ish_get_sched_above)
      lr
      lhs
      ()
      ((chain
         (steps ((rewrite (lemma ish_i48p) lr lhs true ()) (compute both)))
         (steps () (by arith (rows (goal 1) (0 1)))))))
    (rewrite-with
      (lemma ish_get_copy_above)
      lr
      lhs
      ()
      ((chain
         (steps ((rewrite (lemma ish_i16p) lr lhs true ()) (compute both)))
         (steps () (by arith (rows (goal 1) (0 1)))))))
    refl))

;; the spill image: src at [65504,65506), count at [65506,65508), raw
;; low byte first (mask-on-read makes them bytes)
(fn shx_spill ((m Mem) (s Int) (n Int)) Mem
  (mem_set
    (mem_set (mem_set (mem_set m 65504 s) 65505 (bshr s 8)) 65506 n)
    65507
    (bshr n 8)))

(claim shx_spill_def
  (goal ((m Mem) (s Int) (n Int)) ()
    (=
      (shx_spill m s n)
      (mem_set
        (mem_set (mem_set (mem_set m 65504 s) 65505 (bshr s 8)) 65506 n)
        65507
        (bshr n 8))))
  (steps ((unfold shx_spill lhs)) refl))

;; the four spill-cell readbacks (get_set chases at ground addresses)
(claim shx_get_04
  (goal ((m Mem) (s Int) (n Int)) ()
    (= (mem_get (shx_spill m s n) 65504) (mod s 256)))
  (chain
    (steps ((unfold shx_spill lhs)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((steps ((compute both)) refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((steps ((compute both)) refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((steps ((compute both)) refl)))
    (steps ((rewrite (lemma get_set) lr lhs true ())))
    refl))

(claim shx_get_05
  (goal ((m Mem) (s Int) (n Int)) ()
    (= (mem_get (shx_spill m s n) 65505) (mod (bshr s 8) 256)))
