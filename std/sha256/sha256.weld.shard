;; the x86 out's CHUNK-CHAIN spelling (= gb_shblock_i's body in
;; impgen_x86_out.shard: the first chunk over the folded rest chain)
(fn shw_xnf_body () (List IStmt)
  (Cons
    (ISet 3 (ILoc 9))
    (Cons
      (ISet 10 (IConst 16))
      (Cons
        (IWhile
          (ILoc 10)
          (list
            (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
            (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
            (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
            (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
            (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
            (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
            (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
            (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
            (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
            (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
            (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
            (ISet 0 (IBin U32 IAdd (ILoc 9) (IConst 3)))
            (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
            (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
            (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
            (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
            (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
            (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
            (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
            (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
            (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
            (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
            (ISet 9 (IBin U32 IAdd (ILoc 9) (IConst 4)))
            (ISet 0 (IConst 0))
            (ISet 1 (IConst 0))
            (ISet 11 (IConst 0))
            (ISet 10 (IBin U32 ISub (ILoc 10) (IConst 1)))))
        (gb_shblock_r1_i)))))

;; --- the named output value (the walk's RHS trees, verbatim) ---------------

;; the schedule memory: copy 16 message words to the W window, extend 48
(fn shw_sm ((m Mem) (src Int) (wb Int)) Mem
  (sched_mem (copy_wmem m src wb 16) (lg_advk wb 4 16) 48))

;; the rounds output: H state read from the H window, K from the K
;; window, W from the W window -- all over the schedule memory
(fn shw_r ((m Mem) (src Int) (wb Int)) H8
  (sha_rounds
    (mk_h8
      (wget (shw_sm m src wb) (+ wb 512))
      (wget (shw_sm m src wb) (+ (+ wb 512) 4))
      (wget (shw_sm m src wb) (+ (+ (+ wb 512) 4) 4))
      (wget (shw_sm m src wb) (+ (+ (+ (+ wb 512) 4) 4) 4))
      (wget (shw_sm m src wb) (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4))
      (wget (shw_sm m src wb) (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4))
      (wget (shw_sm m src wb) (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4))
      (wget
        (shw_sm m src wb)
        (+ (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4) 4)))
    (wlist (shw_sm m src wb) (+ wb 256) 64)
    (wlist (shw_sm m src wb) wb 64)))

;; the block body's exit locals: the eight projections, pointers and
;; scratch re-zeroed
(fn shw_locals ((m Mem) (src Int) (wb Int)) (List Int)
  (list
    (h8a (shw_r m src wb))
    (h8b (shw_r m src wb))
    (h8c (shw_r m src wb))
    (h8d (shw_r m src wb))
    (h8e (shw_r m src wb))
    (h8f (shw_r m src wb))
    (h8g (shw_r m src wb))
    (h8h (shw_r m src wb))
    0
    0
    0
    0))

;; the block body's exit memory: the finish stores = h8add_mem at the
;; H window
(fn shw_mem ((m Mem) (src Int) (wb Int)) Mem
  (h8add_mem (shw_sm m src wb) (+ wb 512) (shw_r m src wb)))

;; --- the defining equations (RL-fold vocabulary for the weld proofs) --------

(claim shw_sm_def
  (goal ((m Mem) (src Int) (wb Int)) ()
    (=
      (shw_sm m src wb)
      (sched_mem (copy_wmem m src wb 16) (lg_advk wb 4 16) 48)))
  (steps ((compute both (stop sched_mem copy_wmem lg_advk))) refl))

(claim shw_r_def
  (goal ((m Mem) (src Int) (wb Int)) ()
    (=
      (shw_r m src wb)
      (sha_rounds
        (mk_h8
          (wget (shw_sm m src wb) (+ wb 512))
          (wget (shw_sm m src wb) (+ (+ wb 512) 4))
          (wget (shw_sm m src wb) (+ (+ (+ wb 512) 4) 4))
          (wget (shw_sm m src wb) (+ (+ (+ (+ wb 512) 4) 4) 4))
          (wget (shw_sm m src wb) (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4))
          (wget (shw_sm m src wb) (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4))
          (wget
            (shw_sm m src wb)
            (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4))
          (wget
            (shw_sm m src wb)
            (+ (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4) 4)))
        (wlist (shw_sm m src wb) (+ wb 256) 64)
        (wlist (shw_sm m src wb) wb 64))))
  (steps ((compute both (stop sha_rounds wget wlist shw_sm))) refl))

(claim shw_locals_def
  (goal ((m Mem) (src Int) (wb Int)) ()
    (=
      (shw_locals m src wb)
      (list
        (h8a (shw_r m src wb))
        (h8b (shw_r m src wb))
        (h8c (shw_r m src wb))
        (h8d (shw_r m src wb))
        (h8e (shw_r m src wb))
        (h8f (shw_r m src wb))
        (h8g (shw_r m src wb))
        (h8h (shw_r m src wb))
        0
        0
        0
        0)))
  (steps ((compute both (stop h8a h8b h8c h8d h8e h8f h8g h8h shw_r))) refl))

(claim shw_mem_def
  (goal ((m Mem) (src Int) (wb Int)) ()
    (=
      (shw_mem m src wb)
      (h8add_mem (shw_sm m src wb) (+ wb 512) (shw_r m src wb))))
  (steps ((compute both (stop h8add_mem shw_sm shw_r))) refl))

;; --- the spelling bridges (closed bodies meet at the normal form) -----------

(claim shw_wbridge
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (src Int)
     (wb Int)
     (m Mem)
     (d Nat))
    ()
    (=
      (istmts
        (S^ 400 d)
        65536
        (inline shw_src_body)
        (list 0 0 x2 x3 x4 x5 x6 x7 src wb 0 0)
        m)
      (istmts
        (S^ 400 d)
        65536
        (inline shw_wnf_body)
        (list 0 0 x2 x3 x4 x5 x6 x7 src wb 0 0)
        m)))
  (steps ((compute both (stop istmts))) refl))

(claim shw_xbridge
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (src Int)
     (wb Int)
     (m Mem)
     (d Nat))
    ()
    (=
      (istmts
        (S^ 400 d)
        65536
        (inline shw_src_body)
        (list 0 0 x2 x3 x4 x5 x6 x7 src wb 0 0)
        m)
      (istmts
        (S^ 400 d)
        65536
        (inline shw_xnf_body)
        (list 0 0 x2 x3 x4 x5 x6 x7 src wb 0 0)
        m)))
  (steps ((compute both (stop istmts))) refl))

;; --- THE WELD: one block's machine code lands on spec shapes ----------------

;; wasm: eval_seq of the generated block code, from any stack/locals
;; frame at the walk's layout, = ONorm carrying the named output value
(claim shw_wblock
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (src Int)
     (wb Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List Func)))
    ((= (le 0 src) True)
     (= (le (+ src 64) wb) True)
     (= (le (+ wb 544) 65536) True))
    (=
      (eval_seq
        (S^ 1195 c)
        (MkWModule restfs 65536)
        (gb_shblock_w)
        (list 0 0 x2 x3 x4 x5 x6 x7 src wb 0 0)
        st
        m)
      (Some (ONorm st (shw_locals m src wb) (shw_mem m src wb)))))
  (chain
    (steps ((unfold gb_shblock_w lhs)))
    (rewrite-with (lemma imp_w_shblock) lr lhs ((inst c2 (S^ 103 d))) ())
    (steps ((rewrite (lemma shw_wbridge) rl lhs true ())))
    (rewrite-with
      (lemma isha_block_walk)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps
      ((rewrite (lemma shw_sm_def) rl lhs true ())
       (rewrite (lemma shw_r_def) rl lhs true ())
       (rewrite (lemma shw_locals_def) rl lhs true ())
       (rewrite (lemma shw_mem_def) rl lhs true ())
       (compute lhs (stop shw_locals shw_mem)))
      refl)))

;; x86: xeval_seq of the generated block code, from the walk's layout
;; realized as the SysV register file, = XNorm carrying the named
;; output value through xargs' home mapping
(claim shw_xblock
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (src Int)
     (wb Int)
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List XFunc)))
    ((= (le 0 src) True)
     (= (le (+ src 64) wb) True)
     (= (le (+ wb 544) 65536) True))
    (=
      (xeval_seq
        (S^ 433 c)
        (MkXModule restfs 0 65536)
        (gb_shblock_x)
        (MkRegs 0 x3 x2 x6 x7 0 0 x4 x5 0 0 src wb 0 0)
        m)
      (Some
        (XNorm
          (MkRegs
            0
            (h8d (shw_r m src wb))
            (h8c (shw_r m src wb))
            (h8g (shw_r m src wb))
            (h8h (shw_r m src wb))
            (h8b (shw_r m src wb))
            (h8a (shw_r m src wb))
            (h8e (shw_r m src wb))
            (h8f (shw_r m src wb))
            0
            0
            0
            0
            0
            0)
          (shw_mem m src wb)))))
  (chain
    (steps ((unfold gb_shblock_x lhs)))
    (rewrite-with (lemma imp_x_shblock) lr lhs ((inst c2 (S^ 103 d))) ())
    (steps ((rewrite (lemma shw_xbridge) rl lhs true ())))
    (rewrite-with
      (lemma isha_block_walk)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps
      ((rewrite (lemma shw_sm_def) rl lhs true ())
       (rewrite (lemma shw_r_def) rl lhs true ())
       (rewrite (lemma shw_mem_def) rl lhs true ())
       (compute lhs (stop shw_r shw_mem h8a h8b h8c h8d h8e h8f h8g h8h)))
      refl)))

;; --- I2e-2: THE COLLAPSE — the weld output lands on sha_block ---------------
;; With the K window holding the round constants and the H window
;; holding the running state's eight words, the weld's named outputs
;; collapse to spec vocabulary: shw_r = sha_rounds of the state over
;; sha_k and the block's schedule, and shw_mem's H window reads back
;; as sha_block's state (the mod/band crossing rides the I2e-2 range
;; kit), with the K window and every window below wb untouched. These
;; are the three memory facts the blocks-loop driver chains.

;; the H-window vocabulary: the eight words of a state, in lane order
(fn shw_hlist ((st H8)) (List Int)
  (list (h8a st) (h8b st) (h8c st) (h8d st) (h8e st) (h8f st) (h8g st) (h8h st)))

;; h8_add opened against a concrete left state, componentwise
(claim shw_hadd_open
  (goal
    ((a0 Int)
     (a1 Int)
     (a2 Int)
     (a3 Int)
     (a4 Int)
     (a5 Int)
     (a6 Int)
     (a7 Int)
     (y H8))
    ()
    (=
      (shw_hlist (h8_add (mk_h8 a0 a1 a2 a3 a4 a5 a6 a7) y))
      (list
        (m32 (+ a0 (h8a y)))
        (m32 (+ a1 (h8b y)))
        (m32 (+ a2 (h8c y)))
        (m32 (+ a3 (h8d y)))
        (m32 (+ a4 (h8e y)))
        (m32 (+ a5 (h8f y)))
        (m32 (+ a6 (h8g y)))
        (m32 (+ a7 (h8h y))))))
  (case-on y H8
    ((case mk_h8
       (ya yb yc yd ye yf yg yh)
       (steps
         ((rewrite (hyp 0) lr both true ()) (compute both (stop m32)))
         refl)))))

;; reads at or above the K window pass through the schedule memory
(claim shw_sm_wget_hi
  (goal ((m Mem) (src Int) (wb Int) (p Int)) ((= (le (+ wb 256) p) True))
    (= (wget (shw_sm m src wb) p) (wget m p)))
  (chain
    (steps ((rewrite (lemma shw_sm_def) lr lhs true ())))
    (rewrite-with
      (lemma ish_wget_sched_hi)
      lr
      lhs
      ()
      ((steps
         ((compute lhs) (rewrite (lemma ish_i48p) lr lhs true ()) (compute lhs))
         (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wget_copy_hi)
      lr
      lhs
      ()
      ((steps
         ((compute lhs) (rewrite (lemma ish_i16p) lr lhs true ()) (compute lhs))
         (by arith (rows (goal 1) (0 1))))))
    refl))

(claim shw_sm_wlist_hi
  (goal ((m Mem) (src Int) (wb Int) (p Int) (j Nat))
    ((= (le (+ wb 256) p) True))
    (= (wlist (shw_sm m src wb) p j) (wlist m p j)))
  (chain
    (steps ((rewrite (lemma shw_sm_def) lr lhs true ())))
    (rewrite-with
      (lemma ish_wlist_sched_hi)
      lr
      lhs
      ()
      ((steps
         ((compute lhs) (rewrite (lemma ish_i48p) lr lhs true ()) (compute lhs))
         (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wlist_copy_hi)
      lr
      lhs
      ()
      ((steps
         ((compute lhs) (rewrite (lemma ish_i16p) lr lhs true ()) (compute lhs))
         (by arith (rows (goal 1) (0 1))))))
    refl))

;; the W window holds the spec schedule of the block's bytes
(claim shw_w_sched
  (goal ((m Mem) (src Int) (wb Int)) ((= (le (+ src 64) wb) True))
    (= (wlist (shw_sm m src wb) wb 64) (sha_sched (mem_read 64 m src))))
  (chain
    (steps ((rewrite (lemma shw_sm_def) lr lhs true ())))
    (have hsp
      (=
        (wlist (sched_mem (copy_wmem m src wb 16) (lg_advk wb 4 16) 48) wb 64)
        (wlist
          (sched_mem
            (copy_wmem m src wb (S^ 16 Z))
            (lg_advk wb 4 (S^ 16 Z))
            (S^ 48 Z))
          wb
          (S^ 64 Z)))
      (steps
        ((compute both (stop wlist sched_mem copy_wmem lg_advk wget)))
        refl))
    (steps ((rewrite (premise hsp) lr lhs true ())))
    (rewrite-with
      (lemma isha_sched_window)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps
      ((rewrite (lemma ish_words16_read) rl lhs true ())
       (rewrite (lemma ish_i16) lr lhs true ())
       (unfold sha_sched rhs)
       (compute
         both
         (stop srev_acc sched_ext words16 mem_read wget wlist mem_get))))
    refl))

;; the rounds output collapses to spec sha_rounds of the state
(claim shw_r_sha
  (goal
    ((y0 Int)
     (y1 Int)
     (y2 Int)
     (y3 Int)
     (y4 Int)
     (y5 Int)
     (y6 Int)
     (y7 Int)
     (m Mem)
     (src Int)
     (wb Int))
    ((= (le (+ src 64) wb) True)
     (= (wlist m (+ wb 256) 64) (sha_k))
     (= (wget m (+ wb 512)) y0)
     (= (wget m (+ (+ wb 512) 4)) y1)
     (= (wget m (+ (+ (+ wb 512) 4) 4)) y2)
     (= (wget m (+ (+ (+ (+ wb 512) 4) 4) 4)) y3)
     (= (wget m (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4)) y4)
     (= (wget m (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4)) y5)
     (= (wget m (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4)) y6)
     (= (wget m (+ (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4) 4)) y7))
    (=
      (shw_r m src wb)
      (sha_rounds
        (mk_h8 y0 y1 y2 y3 y4 y5 y6 y7)
        (sha_k)
        (sha_sched (mem_read 64 m src)))))
  (chain
    (steps ((rewrite (lemma shw_r_def) lr lhs true ())))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (steps
      ((rewrite (premise 2) lr lhs true ())
       (rewrite (premise 3) lr lhs true ())
       (rewrite (premise 4) lr lhs true ())
       (rewrite (premise 5) lr lhs true ())
       (rewrite (premise 6) lr lhs true ())
       (rewrite (premise 7) lr lhs true ())
       (rewrite (premise 8) lr lhs true ())
       (rewrite (premise 9) lr lhs true ())))
    (rewrite-with
      (lemma shw_sm_wlist_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (steps ((rewrite (premise 1) lr lhs true ())))
    (rewrite-with
      (lemma shw_w_sched)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

;; the exit memory's H window reads back as sha_block's state
(claim shw_out_h
  (goal
    ((y0 Int)
     (y1 Int)
     (y2 Int)
     (y3 Int)
     (y4 Int)
     (y5 Int)
     (y6 Int)
     (y7 Int)
     (m Mem)
     (src Int)
     (wb Int))
    ((= (le (+ src 64) wb) True)
     (= (wlist m (+ wb 256) 64) (sha_k))
     (= (wget m (+ wb 512)) y0)
     (= (wget m (+ (+ wb 512) 4)) y1)
     (= (wget m (+ (+ (+ wb 512) 4) 4)) y2)
     (= (wget m (+ (+ (+ (+ wb 512) 4) 4) 4)) y3)
     (= (wget m (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4)) y4)
     (= (wget m (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4)) y5)
     (= (wget m (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4)) y6)
     (= (wget m (+ (+ (+ (+ (+ (+ (+ (+ wb 512) 4) 4) 4) 4) 4) 4) 4)) y7))
    (=
      (wlist (shw_mem m src wb) (+ wb 512) 8)
      (shw_hlist
        (sha_block (mk_h8 y0 y1 y2 y3 y4 y5 y6 y7) (mem_read 64 m src)))))
  (chain
    (steps
      ((rewrite (lemma shw_mem_def) lr lhs true ())
       (rewrite (lemma ish_h8add_read) lr lhs true ())))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (rewrite-with
      (lemma shw_sm_wget_hi)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1))))))
    (steps
      ((rewrite (premise 2) lr lhs true ())
       (rewrite (premise 3) lr lhs true ())
       (rewrite (premise 4) lr lhs true ())
       (rewrite (premise 5) lr lhs true ())
       (rewrite (premise 6) lr lhs true ())
       (rewrite (premise 7) lr lhs true ())
       (rewrite (premise 8) lr lhs true ())
       (rewrite (premise 9) lr lhs true ())))
    (have hr
      (=
        (shw_r m src wb)
        (sha_rounds
          (mk_h8 y0 y1 y2 y3 y4 y5 y6 y7)
          (sha_k)
          (sha_sched (mem_read 64 m src))))
      (rewrite-with
        (lemma shw_r_sha)
        lr
        lhs
        ((inst y0 y0)
         (inst y1 y1)
         (inst y2 y2)
         (inst y3 y3)
         (inst y4 y4)
         (inst y5 y5)
         (inst y6 y6)
         (inst y7 y7))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl)
         (steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl)
         (steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl)
         (steps ((rewrite (premise 6) lr lhs true ())) refl)
         (steps ((rewrite (premise 7) lr lhs true ())) refl)
         (steps ((rewrite (premise 8) lr lhs true ())) refl)
         (steps ((rewrite (premise 9) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hr) lr lhs true ())))
    (have hl0 (= (le 0 y0) True)
      (chain
        (steps ((rewrite (premise 2) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl1 (= (le 0 y1) True)
      (chain
        (steps ((rewrite (premise 3) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl2 (= (le 0 y2) True)
      (chain
        (steps ((rewrite (premise 4) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl3 (= (le 0 y3) True)
      (chain
        (steps ((rewrite (premise 5) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl4 (= (le 0 y4) True)
      (chain
        (steps ((rewrite (premise 6) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl5 (= (le 0 y5) True)
      (chain
        (steps ((rewrite (premise 7) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
        refl))
    (have hl6 (= (le 0 y6) True)
      (chain
        (steps ((rewrite (premise 8) rl lhs true ())))
        (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
