         (steps ((rewrite (premise hwk) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         (steps
           ((rewrite (lemma lg_advk_s) rl lhs true ())
            (rewrite (lemma shx_mem_s) rl lhs true ())))
         refl)))))

;; the loop's denotation: call the loop fn (index 1) on src and the
;; block count -- the k-block fold with spill residue, the source
;; consumed 64 per block. The result value is rax's pinned zero.
(claim shb_xblocks
  (goal ((src Int) (m Mem) (c Nat) (k Nat) (restfs (List XFunc)))
    ((= (le 0 src) True) (= (le (+ src (* 64 (int_of_nat k))) 64960) True))
    (=
      (xcall_fn_mem
        (S^ 458 (lg_fuel k c))
        (MkXModule
          (Cons
            (MkXFunc 0 (gb_shblock_x))
            (Cons
              (MkXFunc
                2
                (list
                  (XMovRR R12 RDI)
                  (XMovRR RDX RSI)
                  (XMovRI RDI 0)
                  (XMovRI RSI 0)
                  (XBlock (list (XLoop (inline shb_xbody))))))
              restfs))
          0
          65536)
        1
        (list src (int_of_nat k))
        m)
      (Some (Pair 0 (shx_mem m src k)))))
  (chain
    (steps
      ((unfold xcall_fn_mem lhs)
       (compute lhs (stop xeval_loop lg_fuel shx_mem gb_shblock_x))))
    (rewrite-with
      (lemma shb_xloop)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both (stop shx_mem gb_shblock_x))))
    refl))

;; ---- I2e-4a: THE BLOCKS FOLD LANDS ON THE SPEC -----------------------------------
;; The chain: source survival (byte reads below wb see through the
;; whole block effect), the wlist-premised block step, then the fold
;; induction landing the loop denotations' H window on the spec fold.

;; a byte read strictly below the frame sees through one block effect
(claim ish_get_shw_below
  (goal ((m Mem) (src Int) (p Int)) ((= (lt p 64960) True))
    (= (mem_get (shw_mem m src 64960) p) (mem_get m p)))
  (chain
    (steps
      ((unfold shw_mem lhs)
       (unfold shw_sm lhs)
       (compute lhs (stop mem_get copy_wmem sched_mem h8add_mem shw_r))))
    (rewrite-with
      (lemma ish_get_h8add_below)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_get_sched_below)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_get_copy_below)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

;; source survival at window grain: a read wholly below the frame
(claim ish_read_shw_below
  (goal ((m Mem) (src Int) (p Int) (w Nat))
    ((= (le (+ p (int_of_nat w)) 64960) True))
    (= (mem_read w (shw_mem m src 64960) p) (mem_read w m p)))
  (induct w
    ((case Z (steps ((rewrite (lemma mem_read_z) lr both true ())) refl))
     (case S
       (w2)
       (chain
         (have hnn (= (le 0 (int_of_nat w2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hs (= (le (+ p (+ 1 (int_of_nat w2))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (steps ((rewrite (lemma mem_read_s) lr both true ())))
         (rewrite-with
           (lemma ish_get_shw_below)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (hs 1) (hnn 1))))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (hs 1))))))
         refl)))))

;; list projections (lane extraction from window equations: apply the
;; projection to both sides of a list equation, then compute)
(fn wl_hd ((l (List Int))) Int
  (match l
    (Nil 0)
    ((Cons h t) h)))

(fn wl_tl ((l (List Int))) (List Int)
  (match l
    (Nil Nil)
    ((Cons h t) t)))

;; the block step at UNIFORM WLIST GRAIN (the fold's invariant shape):
;; K window holds sha_k, H window holds st -- after one block the H
;; window holds sha_block of st and the source chunk. Ground frame.
(claim shw_out_hw
  (goal ((st H8) (m Mem) (src Int))
    ((= (le (+ src 64) 64960) True)
     (= (wlist m 65216 64) (sha_k))
     (= (wlist m 65472 8) (shw_hlist st)))
    (=
      (wlist (shw_mem m src 64960) 65472 8)
      (shw_hlist (sha_block st (mem_read 64 m src)))))
  (case-on st H8
    ((case mk_h8
       (y0 y1 y2 y3 y4 y5 y6 y7)
       (chain
         (steps ((rewrite (hyp 0) lr both true ())))
         (have ha
           (=
             (wlist (shw_mem m src 64960) 65472 8)
             (wlist (shw_mem m src 64960) (+ 64960 512) 8))
           (steps ((compute both (stop wlist shw_mem))) refl))
         (steps ((rewrite (premise ha) lr lhs true ())))
         (rewrite-with
           (lemma shw_out_h)
           lr
           lhs
           ((inst y0 y0)
            (inst y1 y1)
            (inst y2 y2)
            (inst y3 y3)
            (inst y4 y4)
            (inst y5 y5)
            (inst y6 y6)
            (inst y7 y7))
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
            (chain
              (steps ((compute lhs (stop wlist sha_k))))
              (steps ((rewrite (premise 1) lr lhs true ())) refl))
            (chain
              (have h0 (= (wget m (+ 64960 512)) (wl_hd (wlist m 65472 8)))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h0) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h1
                (=
                  (wget m (+ (+ 64960 512) 4))
                  (wl_hd (wl_tl (wlist m 65472 8))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h1) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h2
                (=
                  (wget m (+ (+ (+ 64960 512) 4) 4))
                  (wl_hd (wl_tl (wl_tl (wlist m 65472 8)))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h2) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h3
                (=
                  (wget m (+ (+ (+ (+ 64960 512) 4) 4) 4))
                  (wl_hd (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h3) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h4
                (=
                  (wget m (+ (+ (+ (+ (+ 64960 512) 4) 4) 4) 4))
                  (wl_hd (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8)))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h4) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h5
                (=
                  (wget m (+ (+ (+ (+ (+ (+ 64960 512) 4) 4) 4) 4) 4))
                  (wl_hd
                    (wl_tl (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h5) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h6
                (=
                  (wget m (+ (+ (+ (+ (+ (+ (+ 64960 512) 4) 4) 4) 4) 4) 4))
                  (wl_hd
                    (wl_tl
                      (wl_tl (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8)))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h6) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have h7
                (=
                  (wget
                    m
                    (+ (+ (+ (+ (+ (+ (+ (+ 64960 512) 4) 4) 4) 4) 4) 4) 4))
                  (wl_hd
                    (wl_tl
                      (wl_tl
                        (wl_tl
                          (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise h7) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)))
         refl)))))

;; the memory-chunk spec fold: k sha_block steps, chunks read from ONE
;; memory at src, src+64, ... (source survival keeps every step's read
;; on the original memory)
(fn shb_fold ((st H8) (m Mem) (src Int) (k Nat)) H8
  (measure (struct k))
  (match k
    (Z st)
    ((S k2) (shb_fold (sha_block st (mem_read 64 m src)) m (+ src 64) k2))))

(claim shb_fold_s
  (goal ((st H8) (m Mem) (src Int) (k Nat)) ()
    (=
      (shb_fold st m src (S k))
      (shb_fold (sha_block st (mem_read 64 m src)) m (+ src 64) k)))
  (steps ((unfold shb_fold lhs) (reduce lhs)) refl))

;; the fold ignores one block effect above its chunks
(claim shb_fold_frame
  (goal ((st H8) (m Mem) (src Int) (p Int) (k Nat))
    ((= (le 0 p) True) (= (le (+ p (* 64 (int_of_nat k))) 64960) True))
    (= (shb_fold st (shw_mem m src 64960) p k) (shb_fold st m p k)))
  (induct k
    ((case Z (steps ((compute both (stop shw_mem))) refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hqs (= (le (+ p (* 64 (+ 1 (int_of_nat k2)))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (steps ((rewrite (lemma shb_fold_s) lr both true ())))
         (rewrite-with
           (lemma ish_read_shw_below)
           lr
           lhs
           ()
           ((chain
              (steps ((rewrite (lemma ish_i64p) lr lhs true ())))
              (steps () (by arith (rows (goal 1) (hqs 1) (hnn 64)))))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         refl)))))

;; THE FOLD READBACK (wasm): the loop denotation's H window holds the
;; spec fold of the initial state over the source chunks
(claim shb_hread
  (goal ((st H8) (m Mem) (src Int) (k Nat))
    ((= (le 0 src) True)
     (= (le (+ src (* 64 (int_of_nat k))) 64960) True)
     (= (wlist m 65216 64) (sha_k))
     (= (wlist m 65472 8) (shw_hlist st)))
    (= (wlist (shb_mem m src k) 65472 8) (shw_hlist (shb_fold st m src k))))
  (induct k
    ((case Z
       (steps
         ((compute both (stop wlist shw_hlist))
          (rewrite (premise 3) lr lhs true ()))
         refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hqs (= (le (+ src (* 64 (+ 1 (int_of_nat k2)))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (steps ((rewrite (lemma shb_mem_s) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst st (sha_block st (mem_read 64 m src))))
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))
            (chain
              (have hk
                (=
                  (wlist (shw_mem m src 64960) 65216 64)
                  (wlist (shw_mem m src 64960) (+ 64960 256) 64))
                (steps ((compute both (stop wlist shw_mem))) refl))
              (steps ((rewrite (premise hk) lr lhs true ())))
              (rewrite-with
                (lemma shw_out_k)
                lr
                lhs
                ()
                ((chain
                   (steps ((compute lhs (stop wlist sha_k))))
                   (steps ((rewrite (premise 2) lr lhs true ())) refl))))
              refl)
            (chain
              (rewrite-with
                (lemma shw_out_hw)
                lr
                lhs
                ((inst st st))
                ((steps () (by arith (rows (goal 1) (hqs 1) (hnn 64))))
                 (steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (steps ((rewrite (premise 3) lr lhs true ())) refl)))
              refl)))
         (rewrite-with
           (lemma shb_fold_frame)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         (steps ((rewrite (lemma shb_fold_s) rl lhs true ())))
         refl)))))

;; --- the x86 twin: the same fold through the spill cells --------------------
;; shx_mem interleaves a 4-cell spill at [65504,65508) before each
;; block; every window the fold reasons about (K, H, source) sits
;; BELOW 65504, so the spill is invisible to all three facts.

;; word windows ending at or below 65504 see through the spill
(claim shx_spill_wlist_below
  (goal ((m Mem) (s Int) (n Int) (p Int) (k Nat))
    ((= (le (+ p (* 4 (int_of_nat k))) 65504) True))
    (= (wlist (shx_spill m s n) p k) (wlist m p k)))
  (chain
    (steps ((unfold shx_spill lhs)))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    refl))

;; byte windows ending at or below 65504 see through the spill
(claim shx_spill_read_below
  (goal ((m Mem) (s Int) (n Int) (p Int) (w Nat))
    ((= (le (+ p (int_of_nat w)) 65504) True))
    (= (mem_read w (shx_spill m s n) p) (mem_read w m p)))
  (chain
    (steps ((unfold shx_spill lhs)))
    (rewrite-with
      (lemma mem_read_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma mem_read_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma mem_read_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    (rewrite-with
      (lemma mem_read_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (0 1))))))
    refl))

;; the fold ignores the spill above its chunks
(claim shx_spill_fold_frame
  (goal ((st H8) (m Mem) (s Int) (n Int) (p Int) (k Nat))
    ((= (le 0 p) True) (= (le (+ p (* 64 (int_of_nat k))) 64960) True))
    (= (shb_fold st (shx_spill m s n) p k) (shb_fold st m p k)))
  (induct k
    ((case Z (steps ((compute both (stop shx_spill))) refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hqs (= (le (+ p (* 64 (+ 1 (int_of_nat k2)))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (steps ((rewrite (lemma shb_fold_s) lr both true ())))
         (rewrite-with
           (lemma shx_spill_read_below)
           lr
           lhs
           ()
           ((chain
              (steps ((rewrite (lemma ish_i64p) lr lhs true ())))
              (steps () (by arith (rows (goal 1) (hqs 1) (hnn 64)))))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         refl)))))

;; THE FOLD READBACK (x86): the spill loop's H window holds the SAME
;; spec fold -- the two targets' denotations meet at shb_fold
(claim shx_hread
  (goal ((st H8) (m Mem) (src Int) (k Nat))
    ((= (le 0 src) True)
     (= (le (+ src (* 64 (int_of_nat k))) 64960) True)
     (= (wlist m 65216 64) (sha_k))
     (= (wlist m 65472 8) (shw_hlist st)))
    (= (wlist (shx_mem m src k) 65472 8) (shw_hlist (shb_fold st m src k))))
  (induct k
    ((case Z
       (steps
         ((compute both (stop wlist shw_hlist))
          (rewrite (premise 3) lr lhs true ()))
         refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hqs (= (le (+ src (* 64 (+ 1 (int_of_nat k2)))) 64960) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 1) lr lhs true ()))
             refl))
         (steps ((rewrite (lemma shx_mem_s) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst st (sha_block st (mem_read 64 m src))))
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))
            (chain
              (have hk
                (=
                  (wlist
                    (shw_mem (shx_spill m src (+ 1 (int_of_nat k2))) src 64960)
                    65216
                    64)
                  (wlist
                    (shw_mem (shx_spill m src (+ 1 (int_of_nat k2))) src 64960)
                    (+ 64960 256)
                    64))
                (steps ((compute both (stop wlist shw_mem shx_spill))) refl))
              (steps ((rewrite (premise hk) lr lhs true ())))
              (rewrite-with
                (lemma shw_out_k)
                lr
                lhs
                ()
                ((chain
                   (steps ((compute lhs (stop wlist sha_k shx_spill))))
                   (rewrite-with
                     (lemma shx_spill_wlist_below)
                     lr
                     lhs
                     ()
                     ((chain
                        (steps ((rewrite (lemma ish_i64p) lr lhs true ())))
                        (steps () (by arith (rows (goal 1)))))))
                   (steps ((rewrite (premise 2) lr lhs true ())) refl))))
              refl)
            (chain
              (rewrite-with
                (lemma shw_out_hw)
                lr
                lhs
                ((inst st st))
                ((steps () (by arith (rows (goal 1) (hqs 1) (hnn 64))))
                 (chain
                   (rewrite-with
                     (lemma shx_spill_wlist_below)
                     lr
                     lhs
                     ()
                     ((chain
                        (steps ((rewrite (lemma ish_i64p) lr lhs true ())))
                        (steps () (by arith (rows (goal 1)))))))
                   (steps ((rewrite (premise 2) lr lhs true ())) refl))
                 (chain
                   (rewrite-with
                     (lemma shx_spill_wlist_below)
                     lr
                     lhs
                     ()
                     ((chain
                        (steps ((rewrite (lemma ish_i8p) lr lhs true ())))
                        (steps () (by arith (rows (goal 1)))))))
                   (steps ((rewrite (premise 3) lr lhs true ())) refl))))
              (rewrite-with
                (lemma shx_spill_read_below)
                lr
                lhs
                ()
                ((chain
                   (steps ((rewrite (lemma ish_i64p) lr lhs true ())))
                   (steps () (by arith (rows (goal 1) (hqs 1) (hnn 64)))))))
              refl)))
         (rewrite-with
           (lemma shb_fold_frame)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         (rewrite-with
           (lemma shx_spill_fold_frame)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))
            (steps () (by arith (rows (goal 1) (hqs 1))))))
         (steps ((rewrite (lemma shb_fold_s) rl lhs true ())))
         refl)))))

;; --- stage C: the memory fold IS the spec's list fold -----------------------
;; The k chunks read off memory, appended in source order
(fn shb_bytes ((m Mem) (src Int) (k Nat)) (List Int)
  (measure (struct k))
  (match k
    (Z Nil)
    ((S k2) (sapp (mem_read 64 m src) (shb_bytes m (+ src 64) k2)))))

;; shb_fold = sha_blocks over the chunks, unpremised: the chunk
;; boundaries are exactly stake/sdrop 64 by the measured read length
(claim shb_fold_blocks
  (goal ((st H8) (m Mem) (src Int) (k Nat)) ()
    (= (shb_fold st m src k) (sha_blocks st (shb_bytes m src k) (int_of_nat k))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr rhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (have hnn (= (le 0 (int_of_nat k2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hle (= (le (+ 1 (int_of_nat k2)) 0) False)
           (steps () (by arith (rows (goal 1) (hnn 1)))))
         (steps
           ((rewrite (lemma shb_fold_s) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr rhs true ())
            (unfold shb_bytes rhs)
            (reduce rhs)
            (unfold sha_blocks rhs)
            (reduce rhs)
            (rewrite (premise hle) lr rhs true ())
            (compute
              rhs
              (stop sha_blocks sha_block stake sdrop sapp mem_read shb_bytes))))
         (rewrite-with
           (lemma ish_stake64_app)
           lr
           rhs
           ()
           ((steps
              ((rewrite (lemma ish_read_len) lr lhs true ())
               (rewrite (lemma ish_i64p) lr lhs true ()))
              refl)))
         (rewrite-with
           (lemma ish_sdrop64_app)
           lr
           rhs
           ()
           ((steps
              ((rewrite (lemma ish_read_len) lr lhs true ())
               (rewrite (lemma ish_i64p) lr lhs true ()))
              refl)))
         (steps ((rewrite (lemma lg_sub) lr rhs true ())))
         (steps ((rewrite (hyp 0) lr lhs true ())))
         refl)))))

;; --- I2e-4b: the init crossing — ikh_mem delivers the fold's invariants -----
(claim ikh_k_read
  (goal ((m Mem)) () (= (wlist (ikh_mem m) 65216 64) (sha_k)))
  (chain
    (steps ((unfold ikh_mem lhs)))
    (rewrite-with
      (lemma ikh_setw_below)
      lr
      lhs
      ()
      ((chain
         (steps ((rewrite (lemma ish_i64p) lr lhs true ()) (compute both)))
         refl)))
    (rewrite-with
      (lemma ikh_setw_read)
      lr
      lhs
      ()
      ((steps ((compute both)) refl) (steps ((compute both)) refl)))
    refl))

(claim ikh_h_read
  (goal ((m Mem)) () (= (wlist (ikh_mem m) 65472 8) (shw_hlist (sha_h0))))
  (chain
    (steps ((unfold ikh_mem lhs)))
    (rewrite-with
      (lemma ikh_setw_read)
      lr
      lhs
      ()
      ((steps ((compute both)) refl) (steps ((compute both)) refl)))
    (steps ((compute both)))
    refl))

;; the fold's chunk region as ONE read: 64k bytes at src
(fn shb_w ((k Nat)) Nat
  (measure (struct k))
  (match k
    (Z Z)
    ((S k2) (wn_add 64 (shb_w k2)))))

(claim shb_bytes_read
  (goal ((m Mem) (src Int) (k Nat)) ()
    (= (shb_bytes m src k) (mem_read (shb_w k) m src)))
  (induct k
    ((case Z
       (chain
         (have hw (= (mem_read (shb_w Z) m src) (mem_read Z m src))
           (steps ((compute both (stop mem_read mem_get))) refl))
         (steps
           ((rewrite (premise hw) lr rhs true ())
            (rewrite (lemma mem_read_z) lr rhs true ())
            (compute lhs)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold shb_bytes lhs)
            (reduce lhs)
            (unfold shb_w rhs)
            (reduce rhs)
            (rewrite (lemma ish_read_app) lr rhs true ())
            (rewrite (lemma ish_i64p) lr rhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; the chunk width's int image: 64 per block
(claim shb_w_i
  (goal ((k Nat)) () (= (int_of_nat (shb_w k)) (* 64 (int_of_nat k))))
  (induct k
    ((case Z
       (chain
         (have hz (= (int_of_nat (shb_w Z)) (int_of_nat Z))
           (steps ((compute both)) refl))
         (steps
           ((rewrite (premise hz) lr lhs true ())
            (rewrite (lemma int_of_nat_zero) lr lhs true ())
            (rewrite (lemma int_of_nat_zero) lr rhs true ())
            (compute rhs)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold shb_w lhs)
            (reduce lhs)
            (rewrite (lemma ish_iw_add) lr lhs true ())
            (rewrite (lemma ish_i64p) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr rhs true ())))
         (steps () (by arith (list))))))))

;; ---- THE WIDTH TIE ---------------------------------------------------------
;; The pad tier's window (msg ++ 0x80 ++ zeros ++ len_be) and the fold
;; tier's chunk region (64 bytes per block) are the SAME Nat width:
;; wz's mod-64 spelling forces the padded length onto a 64-boundary,
;; and div_unique names the quotient -- k = ediv (wn+72) 64, the block
;; count the artifact computes. Proved by pushing both widths through
;; the int embedding (ish_nat_inj carries the equation back to Nat).
(claim shb_pad_w
  (goal ((wn Nat) (wz Nat) (k Nat))
    ((= (int_of_nat wz) (mod (- 55 (int_of_nat wn)) 64))
     (= (int_of_nat k) (ediv (+ (int_of_nat wn) 72) 64)))
    (= (wn_add wn (wn_add 1 (wn_add wz 8))) (shb_w k)))
  (chain
    (have hL
      (=
        (int_of_nat (wn_add wn (wn_add 1 (wn_add wz 8))))
        (+ (int_of_nat wn) (+ 1 (+ (int_of_nat wz) 8))))
      (steps
        ((rewrite (lemma ish_iw_add) lr lhs true ())
         (rewrite (lemma ish_iw_add) lr lhs true ())
         (rewrite (lemma ish_iw_add) lr lhs true ())
         (rewrite (lemma ish_i1p) lr lhs true ())
         (rewrite (lemma ish_i8p) lr lhs true ()))
        refl))
    (have he
      (=
        (- 55 (int_of_nat wn))
        (+
          (* 64 (ediv (- 55 (int_of_nat wn)) 64))
          (mod (- 55 (int_of_nat wn)) 64)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 64))
        ((steps ((compute lhs)) refl))
        refl))
    (have hzlo (= (le 0 (int_of_nat wz)) True)
      (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
    (have hzhi (= (lt (mod (- 55 (int_of_nat wn)) 64) 64) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hdu
      (=
        (ediv (+ (int_of_nat wn) 72) 64)
        (- 1 (ediv (- 55 (int_of_nat wn)) 64)))
      (rewrite-with
        (lemma div_unique)
        lr
        lhs
        ((inst q (- 1 (ediv (- 55 (int_of_nat wn)) 64)))
         (inst r (- 63 (int_of_nat wz))))
        ((steps
           ()
           (by arith (list (list 1 -1 0 0 1 0 0) (list 1 1 0 0 -1 0 0))))
         (steps () (by arith (rows (goal 1) (0 -1) (hzhi 1))))
         (steps () (by arith (rows (goal 1) (hzlo 1)))))
        refl))
    (rewrite-with
      (lemma ish_nat_inj)
      lr
      lhs
      ((inst b (shb_w k)))
      ((chain
         (steps
           ((rewrite (premise hL) lr lhs true ())
            (rewrite (lemma shb_w_i) lr rhs true ())))
         (steps
           ()
           (by
             arith
             (list (list 1 -1 64 0 1 0 0 64) (list 1 1 -64 0 -1 0 0 -64)))))))
    refl))

;; ---- THE DIGEST + HEX SEALS ------------------------------------------------
;; The last two stage boundaries. The digest seal turns the fold's
;; wlist-grain H window into the 32-byte digest read (lane projection
;; discharges ish_digest_read's eight wget premises). The hex seal
;; runs the hex effect over that memory -- the output lands on the
;; dead input region at [0,64), far below the digest window, so
;; ish_hex_read's separation premise is ground. The composed
;; per-target forms land the whole back half: fold exit memory ->
;; the 64 hex characters of the folded state.

(claim shw_digest_read
  (goal ((st H8) (m Mem)) ((= (wlist m 65472 8) (shw_hlist st)))
    (= (mem_read 32 m 65472) (h8_bytes st)))
  (case-on st H8
    ((case mk_h8
       (y0 y1 y2 y3 y4 y5 y6 y7)
       (chain
         (steps ((rewrite (hyp 0) lr both true ())))
         (rewrite-with
           (lemma ish_digest_read)
           lr
           lhs
           ((inst y0 y0)
            (inst y1 y1)
            (inst y2 y2)
            (inst y3 y3)
            (inst y4 y4)
            (inst y5 y5)
            (inst y6 y6)
            (inst y7 y7))
           ((chain
              (have hw (= (wget m 65472) (wl_hd (wlist m 65472 8)))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (= (wget m (+ 65472 4)) (wl_hd (wl_tl (wlist m 65472 8))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 8))
                  (wl_hd (wl_tl (wl_tl (wlist m 65472 8)))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 12))
                  (wl_hd (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 16))
                  (wl_hd (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8)))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 20))
                  (wl_hd
                    (wl_tl (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 24))
                  (wl_hd
                    (wl_tl
                      (wl_tl (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8)))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)
            (chain
              (have hw
                (=
                  (wget m (+ 65472 28))
                  (wl_hd
                    (wl_tl
                      (wl_tl
                        (wl_tl
                          (wl_tl (wl_tl (wl_tl (wl_tl (wlist m 65472 8))))))))))
                (steps ((compute both (stop wget mem_get))) refl))
              (steps
                ((rewrite (premise hw) lr lhs true ())
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (hyp 0) lr lhs true ())
                 (compute lhs)))
              refl)))
         refl)))))

;; the hex effect over any memory whose H window holds st: the output
;; window reads back as the spec's hex of the folded digest
(claim shw_hex_read
  (goal ((st H8) (m Mem)) ((= (wlist m 65472 8) (shw_hlist st)))
    (= (mem_read 64 (ihx_mem m 0 65472 32) 0) (bytes_hex (h8_bytes st))))
  (chain
    (have hw
      (=
        (mem_read 64 (ihx_mem m 0 65472 32) 0)
        (mem_read (wn_add 32 32) (ihx_mem m 0 65472 32) 0))
      (steps ((compute both (stop mem_read mem_get ihx_mem))) refl))
    (steps ((rewrite (premise hw) lr lhs true ())))
    (rewrite-with
      (lemma ish_hex_read)
      lr
      lhs
      ()
      ((steps ((compute lhs)) refl)
       (steps ((rewrite (lemma ish_i32p) lr lhs true ()) (compute lhs)) refl)))
    (rewrite-with
      (lemma shw_digest_read)
      lr
      lhs
      ((inst st st))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

;; THE BACK-HALF READBACK (wasm): fold then hex -- the output window
;; over the hex effect on the fold's exit memory is the spec's hex
;; digest of the fold
(claim shb_out_read
  (goal ((st H8) (m Mem) (src Int) (k Nat))
    ((= (le 0 src) True)
     (= (le (+ src (* 64 (int_of_nat k))) 64960) True)
     (= (wlist m 65216 64) (sha_k))
     (= (wlist m 65472 8) (shw_hlist st)))
    (=
      (mem_read 64 (ihx_mem (shb_mem m src k) 0 65472 32) 0)
      (bytes_hex (h8_bytes (shb_fold st m src k)))))
  (chain
    (rewrite-with
      (lemma shw_hex_read)
      lr
      lhs
      ((inst st (shb_fold st m src k)))
      ((rewrite-with
         (lemma shb_hread)
         lr
         lhs
         ((inst st st))
         ((steps ((rewrite (premise 0) lr lhs true ())) refl)
          (steps ((rewrite (premise 1) lr lhs true ())) refl)
          (steps ((rewrite (premise 2) lr lhs true ())) refl)
          (steps ((rewrite (premise 3) lr lhs true ())) refl))
         refl)))
    refl))

;; THE BACK-HALF READBACK (x86): same seal over the spill loop's exit
;; memory -- the residue is invisible at this grain
(claim shx_out_read
  (goal ((st H8) (m Mem) (src Int) (k Nat))
    ((= (le 0 src) True)
     (= (le (+ src (* 64 (int_of_nat k))) 64960) True)
     (= (wlist m 65216 64) (sha_k))
     (= (wlist m 65472 8) (shw_hlist st)))
    (=
      (mem_read 64 (ihx_mem (shx_mem m src k) 0 65472 32) 0)
      (bytes_hex (h8_bytes (shb_fold st m src k)))))
  (chain
    (rewrite-with
      (lemma shw_hex_read)
      lr
      lhs
      ((inst st (shb_fold st m src k)))
      ((rewrite-with
         (lemma shx_hread)
         lr
         lhs
         ((inst st st))
         ((steps ((rewrite (premise 0) lr lhs true ())) refl)
          (steps ((rewrite (premise 1) lr lhs true ())) refl)
          (steps ((rewrite (premise 2) lr lhs true ())) refl)
          (steps ((rewrite (premise 3) lr lhs true ())) refl))
         refl)))
    refl))

;; ---- THE FULL-PIPE COMPOSITION ---------------------------------------------
;; init -> pad -> fold -> hex, end to end: a memory holding the
;; message at [0,wn) flows through the four stage effects and the
;; output window [0,64) reads back as the SPEC's sha256_hex of the
;; message. The premises are the artifact's arithmetic: wz and k are
;; the machine-computed zero-span and block count (their defining
;; equations), and the message fits under the frame (wn+72 <= 64960).
;; The proof is stage seals end to end -- ish_wlist_pad_hi carries
;; the init's K/H invariants across the pad effect, shb_pad_w +
;; ish_pad_read + ish_read_ikh_below deliver the padded window as
;; sha_pad of the message, shb_fold_blocks collapses the fold to
;; sha_blocks, and ish_read_len + shb_w_i + ish_ediv_mul tie the
;; spec's ediv block count to the premised Nat k.
(claim shb_pipe_read
  (goal ((m Mem) (wn Nat) (wz Nat) (k Nat))
    ((= (int_of_nat wz) (mod (- 55 (int_of_nat wn)) 64))
     (= (int_of_nat k) (ediv (+ (int_of_nat wn) 72) 64))
     (= (le (+ (int_of_nat wn) 72) 64960) True))
    (=
      (mem_read
        64
        (ihx_mem
          (shb_mem (ipd_mem (ikh_mem m) 0 (int_of_nat wn)) 0 k)
          0
          65472
          32)
        0)
      (sha256_hex (mem_read wn m 0))))
  (chain
    (have hnn (= (le 0 (int_of_nat wn)) True)
      (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
    (have he
      (=
        (+ (int_of_nat wn) 72)
        (+
          (* 64 (ediv (+ (int_of_nat wn) 72) 64))
          (mod (+ (int_of_nat wn) 72) 64)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 64))
        ((steps ((compute lhs)) refl))
        refl))
    (have hrlo (= (le 0 (mod (+ (int_of_nat wn) 72) 64)) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hpad
      (=
        (mem_read (shb_w k) (ipd_mem (ikh_mem m) 0 (int_of_nat wn)) 0)
        (sha_pad (mem_read wn m 0)))
      (chain
        (rewrite-with
          (lemma shb_pad_w)
          rl
          lhs
          ((inst wn wn) (inst wz wz))
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl)))
        (rewrite-with
          (lemma ish_pad_read)
          lr
          lhs
          ()
          ((steps ((compute lhs)) refl)
           (steps () (by arith (rows (goal 1) (2 1))))
           (steps ((rewrite (premise 0) lr lhs true ())) refl)))
        (rewrite-with
          (lemma ish_read_ikh_below)
          lr
          lhs
          ()
          ((steps () (by arith (rows (goal 1) (2 1))))))
        refl))
    (have hlen (= (ediv (slen (sha_pad (mem_read wn m 0))) 64) (int_of_nat k))
      (chain
        (steps
          ((rewrite (premise hpad) rl lhs true ())
           (rewrite (lemma ish_read_len) lr lhs true ())
           (rewrite (lemma shb_w_i) lr lhs true ())
           (rewrite (lemma ish_ediv_mul) lr lhs true ())))
        refl))
    (rewrite-with
      (lemma shb_out_read)
      lr
      lhs
      ((inst st (sha_h0)))
      ((steps ((compute lhs)) refl)
       (steps () (by arith (rows (goal 1) (1 -64) (he 1) (hrlo 1) (2 1))))
       (chain
         (rewrite-with
           (lemma ish_wlist_pad_hi)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (2 1))))))
         (steps ((rewrite (lemma ikh_k_read) lr lhs true ())))
         refl)
       (chain
         (rewrite-with
           (lemma ish_wlist_pad_hi)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (2 1))))))
         (steps ((rewrite (lemma ikh_h_read) lr lhs true ())))
         refl)))
    (steps
      ((rewrite (lemma shb_fold_blocks) lr lhs true ())
       (rewrite (lemma shb_bytes_read) lr lhs true ())
       (rewrite (premise hpad) lr lhs true ())
       (unfold sha256_hex rhs)
       (reduce rhs)
       (unfold sha256 rhs)
       (reduce rhs)
       (rewrite (premise hlen) lr rhs true ())))
    refl))

;; the x86 pipe: same statement over the spill fold's exit memory
(claim shx_pipe_read
  (goal ((m Mem) (wn Nat) (wz Nat) (k Nat))
    ((= (int_of_nat wz) (mod (- 55 (int_of_nat wn)) 64))
     (= (int_of_nat k) (ediv (+ (int_of_nat wn) 72) 64))
     (= (le (+ (int_of_nat wn) 72) 64960) True))
    (=
      (mem_read
        64
        (ihx_mem
          (shx_mem (ipd_mem (ikh_mem m) 0 (int_of_nat wn)) 0 k)
          0
          65472
          32)
        0)
      (sha256_hex (mem_read wn m 0))))
  (chain
    (have hnn (= (le 0 (int_of_nat wn)) True)
      (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
    (have he
      (=
        (+ (int_of_nat wn) 72)
        (+
          (* 64 (ediv (+ (int_of_nat wn) 72) 64))
          (mod (+ (int_of_nat wn) 72) 64)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 64))
        ((steps ((compute lhs)) refl))
        refl))
    (have hrlo (= (le 0 (mod (+ (int_of_nat wn) 72) 64)) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hpad
      (=
        (mem_read (shb_w k) (ipd_mem (ikh_mem m) 0 (int_of_nat wn)) 0)
        (sha_pad (mem_read wn m 0)))
      (chain
        (rewrite-with
          (lemma shb_pad_w)
          rl
          lhs
          ((inst wn wn) (inst wz wz))
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl)))
        (rewrite-with
          (lemma ish_pad_read)
          lr
          lhs
          ()
          ((steps ((compute lhs)) refl)
           (steps () (by arith (rows (goal 1) (2 1))))
           (steps ((rewrite (premise 0) lr lhs true ())) refl)))
        (rewrite-with
          (lemma ish_read_ikh_below)
          lr
          lhs
          ()
          ((steps () (by arith (rows (goal 1) (2 1))))))
        refl))
    (have hlen (= (ediv (slen (sha_pad (mem_read wn m 0))) 64) (int_of_nat k))
      (chain
        (steps
          ((rewrite (premise hpad) rl lhs true ())
           (rewrite (lemma ish_read_len) lr lhs true ())
           (rewrite (lemma shb_w_i) lr lhs true ())
           (rewrite (lemma ish_ediv_mul) lr lhs true ())))
        refl))
    (rewrite-with
      (lemma shx_out_read)
      lr
      lhs
      ((inst st (sha_h0)))
      ((steps ((compute lhs)) refl)
       (steps () (by arith (rows (goal 1) (1 -64) (he 1) (hrlo 1) (2 1))))
       (chain
         (rewrite-with
           (lemma ish_wlist_pad_hi)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (2 1))))))
         (steps ((rewrite (lemma ikh_k_read) lr lhs true ())))
         refl)
       (chain
         (rewrite-with
           (lemma ish_wlist_pad_hi)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (2 1))))))
         (steps ((rewrite (lemma ikh_h_read) lr lhs true ())))
         refl)))
    (steps
      ((rewrite (lemma shb_fold_blocks) lr lhs true ())
       (rewrite (lemma shb_bytes_read) lr lhs true ())
       (rewrite (premise hpad) lr lhs true ())
       (unfold sha256_hex rhs)
       (reduce rhs)
       (unfold sha256 rhs)
       (reduce rhs)
       (rewrite (premise hlen) lr rhs true ())))
    refl))
