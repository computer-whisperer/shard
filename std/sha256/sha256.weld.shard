    ((q Int)
     (p Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (d Nat)
     (restfs (List Func)))
    ((= (le 0 q) True)
     (= (le (+ q 64) 65536) True)
     (= (le 0 p) True)
     (= (le (+ p 32) 65536) True))
    (=
      (eval_seq
        (S^ 136 c)
        (MkWModule restfs 65536)
        (gb_shhex_w)
        (list q p x2 x3 x4 x5)
        st
        m)
      (Some (ONorm st (list (+ q 64) (+ p 32) 0 0 0 0) (ihx_mem m q p 32)))))
  (chain
    (steps ((unfold gb_shhex_w lhs)))
    (rewrite-with (lemma imp_w_shhex) lr lhs ((inst c2 (S^ 54 d))) ())
    (rewrite-with
      (lemma isha_hex_walk)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute lhs (stop ihx_mem))))
    refl))

