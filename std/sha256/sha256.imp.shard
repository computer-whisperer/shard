;; ---- I2c-3, the block tier: the body ------------------------------------------
;; One compression block over the relative layout: W at wb, K at
;; wb+256, H at wb+512, message block at src (below wb). Initial
;; locals place src at 8 and wb at 9 (the copy loop's frame); wb parks
;; in local 3 — a pass-through local for both loops — to re-derive
;; kp/wp and the H pointer mid-body. After the rounds loop the
;; advanced kp local IS the H base (wb+256 advanced by 4*64), so the
;; finish phase's walking pointer starts there for free. Scratch
;; discipline: the H-load gathers directly into its lane via pointer
;; 10; the finish gathers into 11 via pointer 8 and scatters through
;; 9/10 (never touching state lanes 0-7).

(fn isha_block_body () (List IStmt)
  (list
    (ISet 3 (ILoc 9))
    (ISet 10 (IConst 16))
    (IWhile
      (ILoc 10)
      (list
        (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
        (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
        (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
        (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
        (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
        (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
        (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
        (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
        (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
        (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
        (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
        (ISet 0 (IBin U32 IAdd (ILoc 9) (IConst 3)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
        (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
        (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))
        (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 11)))
        (ISet 9 (IBin U32 IAdd (ILoc 9) (IConst 4)))
        (ISet 0 (IConst 0))
        (ISet 1 (IConst 0))
        (ISet 11 (IConst 0))
        (ISet 10 (IBin U32 ISub (ILoc 10) (IConst 1)))))
    (ISet 2 (IConst 0))
    (ISet 8 (IConst 0))
    (ISet 10 (IConst 48))
    (IWhile
      (ILoc 10)
      (list
        (ISet 8 (IBin U32 ISub (ILoc 9) (IConst 64)))
        (ISet 0 (IExt U8 U32 (ILoad (ILoc 8))))
