      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((rewrite (premise 0) lr lhs true ())))
    refl))

(claim ish_shr1_lo
  (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (bshr x 1)) True))
  (chain
    (have hk (= 1 (+ 0 1)) (by arith (list (list 1 0) (list 1 0))))
    (steps ((rewrite (premise hk) lr lhs true ())))
    (rewrite-with
      (lemma bshr_s)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((compute lhs)) refl)))
    (rewrite-with
      (lemma ish_shr0_lo)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ediv2_lo)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    refl))

