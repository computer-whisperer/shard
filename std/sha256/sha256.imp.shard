;; the body is WELL-KINDED in the 12-slot U32 frame (the 2a membership
;; gate: generated imp -> ISA legs are total over wk programs)
(claim ish_wk_block
  (goal () ()
    (=
      (iwk_stmts
        (list U32 U32 U32 U32 U32 U32 U32 U32 U32 U32 U32 U32)
        (isha_block_body))
      True))
  (steps ((compute lhs)) refl))


;; ---- the H-load lane phases ------------------------------------------------------
;; Eight copies of the ext leg's Horner-load phase, pointer local 10,
;; gathering directly into the lane local: 11 statements burn 11 fuel,
;; the lane holds (wget m hp), the pointer advances by 4.

(claim ish_blk_ld0
  (goal
    ((l0 Int)
     (l1 Int)
     (l2 Int)
     (l3 Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l11 Int)
     (hp Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ((= (le 0 hp) True) (= (le (+ hp 4) 65536) True))
    (=
      (istmts
        (S^ 16 fl)
        65536
        (Cons
          (ISet 0 (IExt U8 U32 (ILoad (ILoc 10))))
          (Cons
            (ISet 10 (IBin U32 IAdd (ILoc 10) (IConst 1)))
            (Cons
              (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
              (Cons
                (ISet
                  0
                  (IBin U32 IAdd (ILoc 0) (IExt U8 U32 (ILoad (ILoc 10)))))
                (Cons
                  (ISet 10 (IBin U32 IAdd (ILoc 10) (IConst 1)))
                  (Cons
                    (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
                    (Cons
                      (ISet
                        0
                        (IBin U32 IAdd (ILoc 0) (IExt U8 U32 (ILoad (ILoc 10)))))
                      (Cons
                        (ISet 10 (IBin U32 IAdd (ILoc 10) (IConst 1)))
                        (Cons
                          (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
                          (Cons
                            (ISet
                              0
                              (IBin
                                U32
                                IAdd
                                (ILoc 0)
                                (IExt U8 U32 (ILoad (ILoc 10)))))
                            (Cons
                              (ISet 10 (IBin U32 IAdd (ILoc 10) (IConst 1)))
                              rest)))))))))))
        (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 hp l11)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list (wget m hp) l1 l2 l3 l4 l5 l6 l7 l8 l9 (+ hp 4) l11)
        m)))
  (chain
    (steps ((compute lhs) (rewrite (premise 0) lr lhs true ()) (compute lhs)))
    (rewrite-with
      (lemma ish_hi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hp1 (= (mod (+ hp 1) 4294967296) (+ hp 1))
      (rewrite-with
        (lemma ish_mp1)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hp1) lr lhs true ())))
    (rewrite-with
      (lemma lg_lo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hp2 (= (mod (+ (+ hp 1) 1) 4294967296) (+ (+ hp 1) 1))
      (rewrite-with
        (lemma ish_mp2)
        lr
