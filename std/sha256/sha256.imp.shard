    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 8))
      ((steps ((compute lhs)) refl)))
    (have h8 (= (pow2 8) (pow2 (+ 7 1))) (steps ((compute both)) refl))
