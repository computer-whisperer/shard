;; one word read at or above the pad span's end is untouched
(claim ish_wget_pad_hi
  (goal ((m Mem) (src Int) (n Int) (p Int)) ((= (le (+ (+ src n) 72) p) True))
    (= (wget (ipd_mem m src n) p) (wget m p)))
