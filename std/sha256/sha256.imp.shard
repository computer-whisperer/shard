         (stop iwhile int_of_nat pad_zmem lg_advk mem_set ipd_zf ipd_ql ipd_l
           ipd_b ipd_b7))
       (rewrite (premise hg7hi) lr lhs true ())
       (compute
         lhs
         (stop iwhile int_of_nat pad_zmem lg_advk mem_set ipd_zf ipd_ql ipd_l
           ipd_b ipd_b7))))
    (steps
      ((rewrite (lemma ipd_b_def) rl lhs true ())
       (rewrite (lemma ipd_b7_def) rl lhs true ())
       (unfold ipd_mem rhs)
       (reduce rhs)))
    refl))

;; ---- pad kit: the byte-value bounds -----------------------------------------------

(claim ipd_l_lo
  (goal ((n Int)) () (= (le 0 (ipd_l n)) True))
  (chain
    (steps ((rewrite (lemma ipd_l_def) lr lhs true ())))
    (rewrite-with (lemma mod_lo) lr lhs () ((steps ((compute lhs)) refl)))
    refl))

(claim ipd_b_lo
  (goal ((n Int) (s Int)) ((= (le 0 s) True)) (= (le 0 (ipd_b n s)) True))
  (chain
    (steps ((rewrite (lemma ipd_b_def) lr lhs true ())))
    (rewrite-with
      (lemma band_lo)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma band_lo)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_shr_lo)
            lr
            lhs
            ()
            ((rewrite-with (lemma ipd_l_lo) lr lhs () () refl)
             (steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl)
          (steps ((compute lhs)) refl))
         refl)
       (steps ((compute lhs)) refl)))
    refl))

(claim ipd_b_hi
  (goal ((n Int) (s Int)) ((= (le 0 s) True)) (= (lt (ipd_b n s) 256) True))
  (chain
    (have hle (= (le (ipd_b n s) 255) True)
      (chain
        (steps ((rewrite (lemma ipd_b_def) lr lhs true ())))
        (rewrite-with
          (lemma band_le_r)
          lr
          lhs
          ()
          ((rewrite-with
             (lemma band_lo)
             lr
             lhs
             ()
             ((rewrite-with
                (lemma ish_shr_lo)
                lr
                lhs
                ()
                ((rewrite-with (lemma ipd_l_lo) lr lhs () () refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (steps ((compute lhs)) refl))
             refl)
           (steps ((compute lhs)) refl)))
        refl))
    (steps () (by arith (rows (goal 1) (hle 1))))))

(claim ipd_b7_lo
  (goal ((n Int)) () (= (le 0 (ipd_b7 n)) True))
  (chain
    (steps ((rewrite (lemma ipd_b7_def) lr lhs true ())))
    (rewrite-with
      (lemma band_lo)
