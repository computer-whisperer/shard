    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 5))
      ((steps ((compute lhs)) refl)))
    (have h5 (= (pow2 5) (pow2 (+ 4 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h5) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 4))
      ((steps ((compute lhs)) refl)))
    (have h4 (= (pow2 4) (pow2 (+ 3 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h4) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
