                   (steps ((rewrite (premise 1) lr lhs true ())) refl)))
                refl))))))))

;; ---- window framing -----------------------------------------------------------------
;; A store at or above a window's end is invisible to the window's
;; words — the wlist face of get_set_other, the second half of the
;; write-direction story (the extension loop writes at the frontier
;; and re-reads only below it).

(claim ish_plt0
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt p b) True))
  (by arith (list 1 1)))

(claim ish_plt1
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt (+ p 1) b) True))
  (by arith (list 1 1)))

(claim ish_plt2
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt (+ p 2) b) True))
  (by arith (list 1 1)))

;; a live window premise puts the head word's last byte below b
(claim ish_hd3
  (goal ((p Int) (b Int) (c2 Nat))
    ((= (le (+ p (* 4 (int_of_nat (S c2)))) b) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2)))
     (= (le 0 (int_of_nat c2)) True))
    (= (lt (+ p 3) b) True))
  (by arith (list 1 1 4 4)))

;; the stride-4 window premise steps to the IH (arbitrary bound)
(claim ish_w4shift_b
  (goal ((p Int) (b Int) (c2 Nat))
    ((= (le (+ p (* 4 (int_of_nat (S c2)))) b) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2))))
    (= (le (+ (+ p 4) (* 4 (int_of_nat c2))) b) True))
  (by arith (list 1 1 4)))

;; one word read below a store is untouched
(claim ish_wget_set_other
  (goal ((m Mem) (p Int) (b Int) (v Int)) ((= (lt (+ p 3) b) True))
    (= (wget (mem_set m b v) p) (wget m p)))
  (chain
    (steps ((compute both)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt0)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt1)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt2)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    refl))

;; a whole window below a store is untouched
(claim ish_wlist_set_above
  (goal ((m Mem) (p Int) (b Int) (v Int) (k Nat))
    ((= (le (+ p (* 4 (int_of_nat k))) b) True))
    (= (wlist (mem_set m b v) p k) (wlist m p k)))
  (induct k
    ((case Z (steps ((compute both)) refl))
     (case S
       (k2)
       (chain
         (steps ((rewrite (lemma wlist_s) lr both true ())))
         (rewrite-with
           (lemma ish_wget_set_other)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_hd3)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_w4shift_b)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         refl)))))
