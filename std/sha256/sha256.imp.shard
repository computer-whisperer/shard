    (rewrite-with
      (lemma ish_lo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hp4
      (= (mod (+ (+ (+ (+ p2 1) 1) 1) 1) 4294967296) (+ (+ (+ (+ p2 1) 1) 1) 1))
      (rewrite-with
        (lemma ish_mp4)
