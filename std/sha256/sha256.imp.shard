;; ---- I2e-4a: chunk-boundary list laws (the fold meets sha_blocks) ----------

;; list length is nonnegative
(claim ish_slen_lo
  (goal ((xs (List Int))) () (= (le 0 (slen xs)) True))
  (induct xs
    ((case Nil (steps ((compute both)) refl))
     (case Cons
       (h t)
       (chain
         (have hI (= (le 0 (slen t)) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
         (steps ((unfold slen lhs) (reduce lhs)))
         (steps () (by arith (rows (goal 1) (hI 1)))))))))

;; taking a prefix's length off an append returns the prefix
(claim ish_stake_app
  (goal ((c (List Int)) (rest (List Int))) ()
    (= (stake (slen c) (sapp c rest)) c))
  (induct c
    ((case Nil
       (case-on rest List
         ((case Nil
            (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))
          (case Cons
            (h2 t2)
            (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))
     (case Cons
       (h t)
       (chain
         (have hnn (= (le 0 (slen t)) True)
           (rewrite-with (lemma ish_slen_lo) lr lhs () () refl))
         (have hle (= (le (+ 1 (slen t)) 0) False)
           (steps () (by arith (rows (goal 1) (hnn 1)))))
         (steps
           ((compute lhs (stop stake sapp slen))
            (unfold slen lhs)
            (reduce lhs)
            (unfold sapp lhs)
            (reduce lhs)
            (unfold stake lhs)
            (reduce lhs)
            (rewrite (premise hle) lr lhs true ())
            (compute lhs (stop stake sapp slen))
            (rewrite (lemma lg_sub) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ())))
         refl)))))

;; dropping a prefix's length off an append returns the tail
(claim ish_sdrop_app
  (goal ((c (List Int)) (rest (List Int))) ()
    (= (sdrop (slen c) (sapp c rest)) rest))
  (induct c
    ((case Nil
       (case-on rest List
         ((case Nil
            (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))
          (case Cons
            (h2 t2)
            (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))
     (case Cons
       (h t)
       (chain
         (have hnn (= (le 0 (slen t)) True)
           (rewrite-with (lemma ish_slen_lo) lr lhs () () refl))
         (have hle (= (le (+ 1 (slen t)) 0) False)
           (steps () (by arith (rows (goal 1) (hnn 1)))))
         (steps
           ((unfold slen lhs)
            (reduce lhs)
            (unfold sapp lhs)
            (reduce lhs)
            (unfold sdrop lhs)
            (reduce lhs)
            (rewrite (premise hle) lr lhs true ())
            (compute lhs (stop sdrop sapp slen))
            (rewrite (lemma lg_sub) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ())))
         refl)))))

;; the literal-64 forms the block fold cites (the count position is
;; unambiguous here; consumers premise the chunk's measured length)
(claim ish_stake64_app
  (goal ((c (List Int)) (rest (List Int))) ((= (slen c) 64))
    (= (stake 64 (sapp c rest)) c))
  (chain
    (steps ((rewrite (premise 0) rl lhs true ())))
    (rewrite-with (lemma ish_stake_app) lr lhs () ())
    refl))

(claim ish_sdrop64_app
  (goal ((c (List Int)) (rest (List Int))) ((= (slen c) 64))
    (= (sdrop 64 (sapp c rest)) rest))
  (chain
    (steps ((rewrite (premise 0) rl lhs true ())))
    (rewrite-with (lemma ish_sdrop_app) lr lhs () ())
    refl))

;; ---- I2e-4b: the init crossing -- reads below the K window survive init ----

;; a byte read strictly below the window fold sees through it
(claim ish_get_setw_below
  (goal ((m Mem) (a Int) (vs (List Int)) (p Int)) ((= (lt p a) True))
    (= (mem_get (ikh_setw m a vs) p) (mem_get m p)))
  (induct vs
    ((case Nil (steps ((compute both)) refl))
     (case Cons
       (v t)
       (chain
         (steps ((rewrite (lemma ikh_setw_s) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))))
         (rewrite-with
           (lemma ish_get_wput_below)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
         refl)))))

;; byte windows ending at or below the K window survive the whole init
(claim ish_read_ikh_below
  (goal ((m Mem) (p Int) (w Nat)) ((= (le (+ p (int_of_nat w)) 65216) True))
    (= (mem_read w (ikh_mem m) p) (mem_read w m p)))
  (induct w
    ((case Z (steps ((rewrite (lemma mem_read_z) lr both true ())) refl))
     (case S
       (w2)
       (chain
         (have hnn (= (le 0 (int_of_nat w2)) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hs (= (le (+ p (+ 1 (int_of_nat w2))) 65216) True)
           (steps
             ((rewrite (lemma int_of_nat_succ) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (steps
           ((rewrite (lemma mem_read_s) lr both true ()) (unfold ikh_mem lhs)))
         (rewrite-with
           (lemma ish_get_setw_below)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (hs 1) (hnn 1))))))
         (rewrite-with
           (lemma ish_get_setw_below)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (hs 1) (hnn 1))))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (hs 1))))))
         refl)))))

;; ---- I2e-4b: the Nat/Int transfer kit --------------------------------------
;; The pad tier spells widths as wn_add trees over premised Nats; the
;; fold tier spells its chunk region as shb_w k. Equating the two Nats
;; from their Int premises needs injectivity of the (opaque) embedding
;; plus the additive hom -- proved here once, from the surface lemmas
;; alone (nonneg pins the successor case; absurd closes the clashes).

(claim ish_i1p
  (goal () () (= (int_of_nat 1) 1))
  (chain
    (have ha (= (int_of_nat 1) (int_of_nat (S Z)))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise ha) lr lhs true ())
       (rewrite (lemma int_of_nat_succ) lr lhs true ())
       (rewrite (lemma int_of_nat_zero) lr lhs true ())
       (compute lhs)))
    refl))

;; the embedding is injective: equal images force equal Nats
(claim ish_nat_inj
  (goal ((a Nat) (b Nat)) ((= (int_of_nat a) (int_of_nat b))) (= a b))
  (induct a
    ((case Z
       (case-on b Nat
         ((case Z (steps ((rewrite (hyp 0) lr rhs true ())) refl))
          (case S
            (b2)
            (chain
              (have h0 (= (int_of_nat Z) 0)
                (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ())) refl))
              (have hb (= (int_of_nat b) (+ 1 (int_of_nat b2)))
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (rewrite (lemma int_of_nat_succ) lr lhs true ()))
                  refl))
              (have hnn (= (le 0 (int_of_nat b2)) True)
                (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              (have hf (= (le 1 0) True)
                (steps
                  ()
                  (by arith (rows (goal 1) (0 1) (h0 -1) (hb 1) (hnn 1)))))
              (have hcl (= False True)
                (steps
                  ((rewrite (premise hf) rl rhs true ()) (compute rhs))
                  refl))
              (absurd (premise hcl)))))))
     (case S
       (a2)
       (case-on b Nat
         ((case Z
            (chain
              (have h0 (= (int_of_nat b) 0)
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (rewrite (lemma int_of_nat_zero) lr lhs true ()))
                  refl))
              (have ha (= (int_of_nat (S a2)) (+ 1 (int_of_nat a2)))
                (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              (have hnn (= (le 0 (int_of_nat a2)) True)
                (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              (have hf (= (le 1 0) True)
                (steps
                  ()
                  (by arith (rows (goal 1) (0 -1) (h0 -1) (ha 1) (hnn 1)))))
              (have hcl (= False True)
                (steps
                  ((rewrite (premise hf) rl rhs true ()) (compute rhs))
                  refl))
              (absurd (premise hcl))))
          (case S
            (b2)
            (chain
              (have ha (= (int_of_nat (S a2)) (+ 1 (int_of_nat a2)))
                (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              (have hb (= (int_of_nat b) (+ 1 (int_of_nat b2)))
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (rewrite (lemma int_of_nat_succ) lr lhs true ()))
                  refl))
              (have heq (= (int_of_nat a2) (int_of_nat b2))
                (steps () (by arith (list (list 1 -1 1 -1) (list 1 1 -1 1)))))
              (steps ((rewrite (hyp 0) lr rhs true ())))
              (rewrite-with
                (hyp 1)
                lr
                lhs
                ((inst b b2))
                ((steps ((rewrite (premise heq) lr lhs true ())) refl)))
              refl))))))))

;; the additive hom over the transparent adder
(claim ish_iw_add
  (goal ((a Nat) (b Nat)) ()
    (= (int_of_nat (wn_add a b)) (+ (int_of_nat a) (int_of_nat b))))
  (induct a
    ((case Z
       (chain
         (steps
           ((unfold wn_add lhs)
            (reduce lhs)
            (rewrite (lemma int_of_nat_zero) lr rhs true ())))
         (steps () (by arith (list)))))
     (case S
       (a2)
       (chain
         (steps
           ((rewrite (lemma wn_add_s) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr rhs true ())))
         (steps () (by arith (list))))))))

;; dividing out an exhibited multiple (the fuel tie's ediv step)
(claim ish_ediv_mul
  (goal ((x Int)) () (= (ediv (* 64 x) 64) x))
  (chain
    (rewrite-with
      (lemma div_unique)
      lr
      lhs
      ((inst q x) (inst r 0))
      ((steps () (by arith (list)))
       (steps () (by arith (list)))
       (steps () (by arith (list)))))
    refl))
