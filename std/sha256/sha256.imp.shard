;; ---- window framing -----------------------------------------------------------------
;; A store at or above a window's end is invisible to the window's
;; words — the wlist face of get_set_other, the second half of the
;; write-direction story (the extension loop writes at the frontier
;; and re-reads only below it).

(claim ish_plt0
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt p b) True))
  (by arith (list 1 1)))

(claim ish_plt1
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt (+ p 1) b) True))
  (by arith (list 1 1)))

(claim ish_plt2
  (goal ((p Int) (b Int)) ((= (lt (+ p 3) b) True)) (= (lt (+ p 2) b) True))
  (by arith (list 1 1)))

;; a live window premise puts the head word's last byte below b
(claim ish_hd3
  (goal ((p Int) (b Int) (c2 Nat))
    ((= (le (+ p (* 4 (int_of_nat (S c2)))) b) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2)))
     (= (le 0 (int_of_nat c2)) True))
    (= (lt (+ p 3) b) True))
  (by arith (list 1 1 4 4)))

;; the stride-4 window premise steps to the IH (arbitrary bound)
(claim ish_w4shift_b
  (goal ((p Int) (b Int) (c2 Nat))
    ((= (le (+ p (* 4 (int_of_nat (S c2)))) b) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2))))
    (= (le (+ (+ p 4) (* 4 (int_of_nat c2))) b) True))
  (by arith (list 1 1 4)))

;; one word read below a store is untouched
(claim ish_wget_set_other
  (goal ((m Mem) (p Int) (b Int) (v Int)) ((= (lt (+ p 3) b) True))
    (= (wget (mem_set m b v) p) (wget m p)))
  (chain
    (steps ((compute both)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt0)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt1)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_plt2)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    refl))

;; a whole window below a store is untouched
(claim ish_wlist_set_above
  (goal ((m Mem) (p Int) (b Int) (v Int) (k Nat))
    ((= (le (+ p (* 4 (int_of_nat k))) b) True))
    (= (wlist (mem_set m b v) p k) (wlist m p k)))
  (induct k
    ((case Z (steps ((compute both)) refl))
     (case S
       (k2)
       (chain
         (steps ((rewrite (lemma wlist_s) lr both true ())))
         (rewrite-with
           (lemma ish_wget_set_other)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_hd3)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_w4shift_b)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         refl)))))

;; ==== rung I2c-2b: the word-copy loop ===============================================
;;
;; words16's machine half: W[0..15] fills from the message block by a
;; WORD-grain copy — per iteration one Horner load (the round tier's
;; proven shape) and one down-walk store (EXACTLY wput's chain), so
;; the pass lemma's memory effect is literally (wput m wp (wget m p2))
;; and the readback rides the roundtrip + framing kit. The three
;; scratch slots (sp/u/t) re-zero at each iteration's end: the worker
;; states zero-in/zero-out and no iteration-dependent residue
;; selectors exist (the rt_last lesson, resolved by construction).
;; Schedule-phase locals: 0 sp (store pointer), 1 u (byte shuttle),
;; 2-7 untouched, 8 p2 (source), 9 wp (destination), 10 n, 11 t.

;; the word-grain copy denotation (the memory-level spec this loop
;; refines; the list-level crossing happens at the block tier)
(fn copy_wmem ((m Mem) (s Int) (d Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (copy_wmem (wput m d (wget m s)) (+ s 4) (+ d 4) k2))))

(claim copy_wmem_s
  (goal ((m Mem) (s Int) (d Int) (k Nat)) ()
    (=
      (copy_wmem m s d (S k))
      (copy_wmem (wput m d (wget m s)) (+ s 4) (+ d 4) k)))
  (steps ((unfold copy_wmem lhs) (reduce lhs)) refl))

;; fold lemmas: the machine's computed trees back into the kit's
;; folded spellings (cited right-to-left with the all-occurrence form)
(claim wget_be
  (goal ((m Mem) (p Int)) ()
    (=
      (wget m p)
      (+
        (* (mem_get m p) 16777216)
        (+
          (* (mem_get m (+ p 1)) 65536)
          (+ (* (mem_get m (+ p 2)) 256) (mem_get m (+ p 3)))))))
  (steps ((compute lhs)) refl))

(claim wput_sets
  (goal ((m Mem) (p Int) (v Int)) ()
    (=
      (wput m p v)
      (mem_set
        (mem_set
          (mem_set
            (mem_set m (+ p 3) (band v 255))
            (+ p 2)
            (band (bshr v 8) 255))
          (+ p 1)
          (band (bshr (bshr v 8) 8) 255))
        p
        (band (bshr (bshr (bshr v 8) 8) 8) 255))))
  (steps ((unfold wput lhs)) refl))

;; store-pointer guard bounds at the down-walk's literal trees
(claim ish_slo3
  (goal ((p Int)) ((= (le 0 p) True)) (= (le 0 (+ p 3)) True))
  (by arith (list 1 1)))

(claim ish_shi3
  (goal ((p Int)) ((= (le (+ p 4) 65536) True)) (= (lt (+ p 3) 65536) True))
  (by arith (list 1 1)))

(claim ish_slo2
  (goal ((p Int)) ((= (le 0 p) True)) (= (le 0 (- (+ p 3) 1)) True))
  (by arith (list 1 1)))

(claim ish_shi2
  (goal ((p Int)) ((= (le (+ p 4) 65536) True))
    (= (lt (- (+ p 3) 1) 65536) True))
  (by arith (list 1 1)))

(claim ish_slo1
  (goal ((p Int)) ((= (le 0 p) True)) (= (le 0 (- (- (+ p 3) 1) 1)) True))
  (by arith (list 1 1)))

(claim ish_shi1
  (goal ((p Int)) ((= (le (+ p 4) 65536) True))
    (= (lt (- (- (+ p 3) 1) 1) 65536) True))
  (by arith (list 1 1)))

(claim ish_slo0
  (goal ((p Int)) ((= (le 0 p) True)) (= (le 0 (- (- (- (+ p 3) 1) 1) 1)) True))
  (by arith (list 1 1)))

(claim ish_shi0
  (goal ((p Int)) ((= (le (+ p 4) 65536) True))
    (= (lt (- (- (- (+ p 3) 1) 1) 1) 65536) True))
  (by arith (list 1 1)))

;; the copy body: Horner load through p2, down-walk store through sp,
;; scratch re-zeroed (31 statements)
(fn isha_copy_body () (List IStmt)
  (list
    (ISet 11 (ILoad (ILoc 8)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    ;; the down-walk store (wput's chain, LSB first at wp+3)
    (ISet 0 (IBin IAdd (ILoc 9) (IConst 3)))
    (ISet 1 (IBin IAnd (ILoc 11) (IConst 255)))
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin ISub (ILoc 0) (IConst 1)))
    (ISet 11 (IBin IShr (ILoc 11) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 11) (IConst 255)))
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin ISub (ILoc 0) (IConst 1)))
    (ISet 11 (IBin IShr (ILoc 11) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 11) (IConst 255)))
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin ISub (ILoc 0) (IConst 1)))
    (ISet 11 (IBin IShr (ILoc 11) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 11) (IConst 255)))
    (IStore (ILoc 0) (ILoc 1))
    (ISet 9 (IBin IAdd (ILoc 9) (IConst 4)))
    ;; scratch re-zeroes (zero-in/zero-out invariant) and the counter
    (ISet 0 (IConst 0))
    (ISet 1 (IConst 0))
    (ISet 11 (IConst 0))
    (ISet 10 (IBin ISub (ILoc 10) (IConst 1)))))

;; ---- the copy pass lemma ------------------------------------------------------------
;; One body run: the source word lands at the destination (the memory
;; effect IS (wput m wp (wget m p2))), both pointers advance by 4, the
;; counter drops, scratch re-zeroes.

(claim isha_copy_pass
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (sp Int)
     (u Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (m Mem)
     (fl Nat))
    ((= (le 0 p2) True)
     (= (le (+ p2 4) 65536) True)
     (= (le 0 wp) True)
     (= (le (+ wp 4) 65536) True))
    (=
      (istmts
        (S^ 36 fl)
        65536
        (inline isha_copy_body)
        (list sp u x2 x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (Some
        (INorm
          (list 0 0 x2 x3 x4 x5 x6 x7 (+ p2 4) (+ wp 4) (- n 1) 0)
          (wput m wp (wget m p2))))))
  (chain
    ;; the load walk (the round tier's guard ladder, source pointer)
    (steps ((compute lhs) (rewrite (premise 0) lr lhs true ()) (compute lhs)))
    (rewrite-with
      (lemma ish_hi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma lg_lo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_lo2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_lo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    ;; the store walk (destination pointer, down-walk trees)
    (rewrite-with
      (lemma ish_slo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    ;; flatten: source bumps deepest-first, store walk shallow-first
    (have hk4 (= (+ (+ (+ (+ p2 1) 1) 1) 1) (+ p2 4)) (by arith (list)))
    (have hk3 (= (+ (+ (+ p2 1) 1) 1) (+ p2 3)) (by arith (list)))
    (have hk2 (= (+ (+ p2 1) 1) (+ p2 2)) (by arith (list)))
    (have hd1 (= (- (+ wp 3) 1) (+ wp 2)) (by arith (list)))
    (have hd2 (= (- (+ wp 2) 1) (+ wp 1)) (by arith (list)))
    (have hd3 (= (- (+ wp 1) 1) wp) (by arith (list)))
    (steps
      ((rewrite (premise hk4) lr lhs true ())
       (rewrite (premise hk3) lr lhs true ())
       (rewrite (premise hk2) lr lhs true ())
       (rewrite (premise hd1) lr lhs true ())
       (rewrite (premise hd2) lr lhs true ())
       (rewrite (premise hd3) lr lhs true ())))
    ;; Horner -> big-endian at the four stored-value positions
    (rewrite-with
      (lemma ish_be)
      lr
      lhs
      ((inst b0 (mem_get m p2))
       (inst b1 (mem_get m (+ p2 1)))
       (inst b2 (mem_get m (+ p2 2)))
       (inst b3 (mem_get m (+ p2 3))))
      ())
    (rewrite-with
      (lemma ish_be)
      lr
      lhs
      ((inst b0 (mem_get m p2))
       (inst b1 (mem_get m (+ p2 1)))
       (inst b2 (mem_get m (+ p2 2)))
       (inst b3 (mem_get m (+ p2 3))))
      ())
    (rewrite-with
      (lemma ish_be)
      lr
      lhs
      ((inst b0 (mem_get m p2))
       (inst b1 (mem_get m (+ p2 1)))
       (inst b2 (mem_get m (+ p2 2)))
       (inst b3 (mem_get m (+ p2 3))))
      ())
    (rewrite-with
      (lemma ish_be)
      lr
      lhs
      ((inst b0 (mem_get m p2))
       (inst b1 (mem_get m (+ p2 1)))
       (inst b2 (mem_get m (+ p2 2)))
       (inst b3 (mem_get m (+ p2 3))))
      ())
    ;; fold the sums to wget, the chain to wput
    (steps
      ((rewrite (lemma wget_be) rl lhs true ())
       (rewrite (lemma wput_sets) rl lhs true ())))
    refl))

;; ---- the copy worker ----------------------------------------------------------------
;; k words from the source window to the destination window: the loop
;; IS copy_wmem. Scratch rides the zero-in/zero-out invariant.

(claim isha_copy_w
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (m Mem)
     (c Nat)
     (k Nat))
    ((= (le 0 p2) True)
     (= (le (+ p2 (* 4 (int_of_nat k))) 65536) True)
     (= (le 0 wp) True)
     (= (le (+ wp (* 4 (int_of_nat k))) 65536) True))
    (=
      (iwhile
        (S^ 40 (lg_fuel k c))
        65536
        (ILoc 10)
        (inline isha_copy_body)
        (list 0 0 x2 x3 x4 x5 x6 x7 p2 wp (int_of_nat k) 0)
        m)
      (Some
        (INorm
          (list 0 0 x2 x3 x4 x5 x6 x7 (lg_advk p2 4 k) (lg_advk wp 4 k) 0 0)
          (copy_wmem m p2 wp k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ())
          (compute both (stop wget wput)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold iwhile lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput copy_wmem lg_advk))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput copy_wmem lg_advk))))
         (rewrite-with
           (lemma isha_copy_pass)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
            (rewrite-with
              (lemma ish_w4hi)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)
            (steps ((rewrite (premise 2) lr lhs true ())) refl)
            (rewrite-with
              (lemma ish_w4hi)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 3) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput copy_wmem lg_advk))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput copy_wmem lg_advk))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_w4lo)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma ish_w4shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma ish_w4lo)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 2) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma ish_w4shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 3) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps
           ((rewrite (lemma copy_wmem_s) lr rhs true ())
            (rewrite (lemma lg_advk_s) lr rhs true ())))
         refl)))))

;; ---- the copy readback --------------------------------------------------------------
;; Reading the copied window gives the source words: the first
;; word-level content theorem, riding the roundtrip and the framing
;; kit. Premise: the source window sits entirely below the
;; destination (the flagship's static layout).

(claim ish_wget_range_lo
  (goal ((m Mem) (p Int)) () (= (le 0 (wget m p)) True))
  (have g0 (= (le 0 (mem_get m p)) True)
    (rewrite-with (lemma get_lo) lr lhs () () refl)
    (have g1 (= (le 0 (mem_get m (+ p 1))) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl)
      (have g2 (= (le 0 (mem_get m (+ p 2))) True)
        (rewrite-with (lemma get_lo) lr lhs () () refl)
        (have g3 (= (le 0 (mem_get m (+ p 3))) True)
          (rewrite-with (lemma get_lo) lr lhs () () refl)
          (chain
            (steps ((compute lhs)))
            (by arith (list 1 16777216 65536 256 1))))))))

(claim ish_wget_range_hi
  (goal ((m Mem) (p Int)) () (= (lt (wget m p) 4294967296) True))
  (have g0 (= (lt (mem_get m p) 256) True)
    (rewrite-with (lemma get_hi) lr lhs () () refl)
    (have g1 (= (lt (mem_get m (+ p 1)) 256) True)
      (rewrite-with (lemma get_hi) lr lhs () () refl)
      (have g2 (= (lt (mem_get m (+ p 2)) 256) True)
        (rewrite-with (lemma get_hi) lr lhs () () refl)
        (have g3 (= (lt (mem_get m (+ p 3)) 256) True)
          (rewrite-with (lemma get_hi) lr lhs () () refl)
          (chain
            (steps ((compute lhs)))
            (by arith (list 1 16777216 65536 256 1))))))))

;; offset monotonicity (the wput-chain peeling premises)
(claim ish_lt_b1
  (goal ((a Int) (b Int)) ((= (lt a b) True)) (= (lt a (+ b 1)) True))
  (by arith (list 1 1)))

(claim ish_lt_b2
  (goal ((a Int) (b Int)) ((= (lt a b) True)) (= (lt a (+ b 2)) True))
  (by arith (list 1 1)))

(claim ish_lt_b3
  (goal ((a Int) (b Int)) ((= (lt a b) True)) (= (lt a (+ b 3)) True))
  (by arith (list 1 1)))

(claim ish_lt_b4
  (goal ((a Int) (b Int)) ((= (lt a b) True)) (= (lt a (+ b 4)) True))
  (by arith (list 1 1)))

(claim ish_le_b1
  (goal ((a Int) (b Int)) ((= (le a b) True)) (= (le a (+ b 1)) True))
  (by arith (list 1 1)))

(claim ish_le_b2
  (goal ((a Int) (b Int)) ((= (le a b) True)) (= (le a (+ b 2)) True))
  (by arith (list 1 1)))

(claim ish_le_b3
  (goal ((a Int) (b Int)) ((= (le a b) True)) (= (le a (+ b 3)) True))
  (by arith (list 1 1)))

(claim ish_d34
  (goal ((d Int)) () (= (lt (+ d 3) (+ d 4)) True))
  (by arith (list 1)))

;; the copy-premise steps to the IH and to the frame
(claim ish_cshift4
  (goal ((s Int) (d Int) (c2 Nat))
    ((= (le (+ s (* 4 (int_of_nat (S c2)))) d) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2))))
    (= (le (+ (+ s 4) (* 4 (int_of_nat c2))) (+ d 4)) True))
  (by arith (list 1 1 4)))

(claim ish_cshift0
  (goal ((s Int) (d Int) (c2 Nat))
    ((= (le (+ s (* 4 (int_of_nat (S c2)))) d) True)
     (= (int_of_nat (S c2)) (+ 1 (int_of_nat c2))))
    (= (le (+ (+ s 4) (* 4 (int_of_nat c2))) d) True))
  (by arith (list 1 1 4)))

;; one word read below a wput is untouched (peel the four stores)
(claim ish_wget_wput_other
  (goal ((m Mem) (p Int) (b Int) (v Int)) ((= (lt (+ p 3) b) True))
    (= (wget (wput m b v) p) (wget m p)))
  (chain
    (steps ((rewrite (lemma wput_sets) lr lhs true ())))
    (rewrite-with
      (lemma ish_wget_set_other)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (rewrite-with
      (lemma ish_wget_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_lt_b1)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    (rewrite-with
      (lemma ish_wget_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_lt_b2)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    (rewrite-with
      (lemma ish_wget_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_lt_b3)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    refl))

;; a whole window below a wput is untouched
(claim ish_wlist_wput_above
  (goal ((m Mem) (p Int) (b Int) (v Int) (k Nat))
    ((= (le (+ p (* 4 (int_of_nat k))) b) True))
    (= (wlist (wput m b v) p k) (wlist m p k)))
  (chain
    (steps ((rewrite (lemma wput_sets) lr lhs true ())))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_le_b1)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_le_b2)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    (rewrite-with
      (lemma ish_wlist_set_above)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_le_b3)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    refl))

;; one word read below a copy's write window is untouched
(claim ish_wget_copy_below
  (goal ((m Mem) (s Int) (d Int) (p Int) (k Nat)) ((= (lt (+ p 3) d) True))
    (= (wget (copy_wmem m s d k) p) (wget m p)))
  (induct k
    ((case Z (steps ((compute both (stop wget wput))) refl))
     (case S
       (k2)
       (chain
         (steps ((rewrite (lemma copy_wmem_s) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_lt_b4)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)))
         (rewrite-with
           (lemma ish_wget_wput_other)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
         refl)))))

;; THE READBACK: the copied window reads as the source words
(claim ish_copy_read
  (goal ((m Mem) (s Int) (d Int) (k Nat))
    ((= (le (+ s (* 4 (int_of_nat k))) d) True))
    (= (wlist (copy_wmem m s d k) d k) (wlist m s k)))
  (induct k
    ((case Z (steps ((compute both (stop wget wput))) refl))
     (case S
       (k2)
       (chain
         (steps
           ((rewrite (lemma copy_wmem_s) lr lhs true ())
            (rewrite (lemma wlist_s) lr both true ())))
         (rewrite-with
           (lemma ish_wget_copy_below)
           lr
           lhs
           ()
           ((steps ((rewrite (lemma ish_d34) lr lhs true ())) refl)))
         (rewrite-with
           (lemma isha_wput_get)
           lr
           lhs
           ()
           ((steps ((rewrite (lemma ish_wget_range_lo) lr lhs true ())) refl)
            (steps ((rewrite (lemma ish_wget_range_hi) lr lhs true ())) refl)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_cshift4)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (rewrite-with
           (lemma ish_wlist_wput_above)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_cshift0)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         refl)))))

;; ---- the continuation-phase idiom, pinned ------------------------------------------
;; The extension pass (I2c-2c) and the block tier compose long bodies
;; from PHASE LEMMAS: a run over a literal statement spine ending in
;; a quantified tail steps to the same run over the tail — the spine
;; consumed, the fuel down by exactly the spine's length, the locals
;; transformed. istmts sticks at the symbolic tail, so both sides
;; stay folded there. This probe pins the shape (fuel stepping,
;; spine matching, the stick).

(claim ish_phase_pin
  (goal ((xa Int) (xb Int) (xc Int) (rest (List IStmt)) (m Mem) (fl Nat)) ()
    (=
      (istmts
        (S^ 5 fl)
        65536
        (Cons (ISet 0 (IConst 7)) (Cons (ISet 1 (ILoc 0)) rest))
        (list xa xb xc)
        m)
      (istmts (S^ 3 fl) 65536 rest (list 7 7 xc) m)))
  (steps ((compute both)) refl))

;; the composition probe: two phase rewrites chain — the second citation
;; must match the S^ residue fuel the first one leaves behind
(claim ish_phase_comp
  (goal ((xa Int) (xb Int) (xc Int) (m Mem) (fl Nat)) ()
    (=
      (istmts
        (S^ 7 fl)
        65536
        (Cons
          (ISet 0 (IConst 7))
          (Cons
            (ISet 1 (ILoc 0))
            (Cons (ISet 0 (IConst 7)) (Cons (ISet 1 (ILoc 0)) Nil))))
        (list xa xb xc)
        m)
      (Some (INorm (list 7 7 xc) m))))
  (chain
    (steps ((compute lhs (stop istmts))))
    (rewrite-with (lemma ish_phase_pin) lr lhs () ())
    (steps ((compute lhs (stop istmts))))
    (rewrite-with (lemma ish_phase_pin) lr lhs () ())
    (steps ((compute lhs)))
    refl))

;; ---- the extension tier (I2c-2c) ---------------------------------------------------
;; The schedule-extension loop: each iteration computes one new word
;; from the four words below the write frontier (byte offsets -8, -28,
;; -60, -64 = W[t-2], W[t-7], W[t-15], W[t-16]) and stores it AT the
;; frontier. The accumulator builds right-to-left, so the finished tree
;; IS the spec's association — no re-association anywhere. The pass
;; lemma is COMPOSED from phase lemmas (the continuation-phase idiom):
;; each Horner load folds its own word inside its own phase, before the
;; sigma statements wrap it.

;; the word-level extension step: exactly sched_ext's word recurrence,
;; read through the memory window ending at p
(fn sched_w ((m Mem) (p Int)) Int
  (m32
    (+
      (ssig1 (wget m (- p 8)))
      (+ (wget m (- p 28)) (+ (ssig0 (wget m (- p 60))) (wget m (- p 64)))))))

;; the memory-level schedule recursion: k new words at stride 4
(fn sched_mem ((m Mem) (p Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (sched_mem (wput m p (sched_w m p)) (+ p 4) k2))))

(claim sched_mem_s
  (goal ((m Mem) (p Int) (k Nat)) ()
    (= (sched_mem m p (S k)) (sched_mem (wput m p (sched_w m p)) (+ p 4) k)))
  (steps ((unfold sched_mem lhs) (reduce lhs)) refl))

;; the fold lemma: sched_w's unfolded spelling (cited right-to-left,
;; folding the machine's accumulated tree back into the denotation)
(claim sched_w_fold
  (goal ((m Mem) (p Int)) ()
    (=
      (sched_w m p)
      (band
        (+
          (ssig1 (wget m (- p 8)))
          (+ (wget m (- p 28)) (+ (ssig0 (wget m (- p 60))) (wget m (- p 64)))))
        4294967295)))
  (steps ((compute lhs (stop wget ssig0 ssig1))) refl))

;; load-guard bounds at the walk's offset trees (all from the worker's
;; frontier premises: 64 <= wp and wp + 4 <= 65536)
(claim ish_xlo64
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 0 (- w 64)) True))
  (by arith (list 1 1)))

(claim ish_xhi64
  (goal ((w Int)) ((= (le (+ w 4) 65536) True))
    (= (le (+ (- w 64) 4) 65536) True))
  (by arith (list 1 1)))

(claim ish_xlo60
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 0 (- w 60)) True))
  (by arith (list 1 1)))

(claim ish_xhi60
  (goal ((w Int)) ((= (le (+ w 4) 65536) True))
    (= (le (+ (- w 60) 4) 65536) True))
  (by arith (list 1 1)))

(claim ish_xlo28
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 0 (- w 28)) True))
  (by arith (list 1 1)))

(claim ish_xhi28
  (goal ((w Int)) ((= (le (+ w 4) 65536) True))
    (= (le (+ (- w 28) 4) 65536) True))
  (by arith (list 1 1)))

(claim ish_xlo8
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 0 (- w 8)) True))
  (by arith (list 1 1)))

(claim ish_xhi8
  (goal ((w Int)) ((= (le (+ w 4) 65536) True))
    (= (le (+ (- w 8) 4) 65536) True))
  (by arith (list 1 1)))

(claim ish_ext_wlo
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 0 w) True))
  (by arith (list 1 1)))

;; the worker induction's frontier step
(claim ish_ext_wstep
  (goal ((w Int)) ((= (le 64 w) True)) (= (le 64 (+ w 4)) True))
  (by arith (list 1 1)))

;; ---- the phase lemmas ---------------------------------------------------------------
;; Each phase: a literal statement spine over a quantified tail, fuel
;; k+5 -> 5 (one unit per statement, the 5-slack window slides). The
;; load phases carry the two bounds premises and fold their word; the
;; others close by compute alone.

;; phase: the window pointer drops to the lowest read offset
(claim ish_ext_ph_ptr
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 6 fl)
        65536
        (Cons (ISet 8 (IBin ISub (ILoc 9) (IConst 64))) rest)
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list acc u sp x3 x4 x5 x6 x7 (- wp 64) wp n t)
        m)))
  (steps ((compute both)) refl))

;; phase: Horner load into the accumulator (W[t-16])
(claim ish_ext_ph_lda
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ((= (le 0 p2) True) (= (le (+ p2 4) 65536) True))
    (=
      (istmts
        (S^ 16 fl)
        65536
        (Cons
          (ISet 0 (ILoad (ILoc 8)))
          (Cons
            (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
            (Cons
              (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
              (Cons
                (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
                (Cons
                  (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
                  (Cons
                    (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
                    (Cons
                      (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
                      (Cons
                        (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
                        (Cons
                          (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
                          (Cons
                            (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
                            (Cons (ISet 8 (IBin IAdd (ILoc 8) (IConst 1))) rest)))))))))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list (wget m p2) u sp x3 x4 x5 x6 x7 (+ p2 4) wp n t)
        m)))
  (chain
    (steps ((compute lhs) (rewrite (premise 0) lr lhs true ()) (compute lhs)))
    (rewrite-with
      (lemma ish_hi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma lg_lo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_lo2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_lo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_hi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hk4 (= (+ (+ (+ (+ p2 1) 1) 1) 1) (+ p2 4)) (by arith (list)))
    (have hk3 (= (+ (+ (+ p2 1) 1) 1) (+ p2 3)) (by arith (list)))
    (have hk2 (= (+ (+ p2 1) 1) (+ p2 2)) (by arith (list)))
    (steps
      ((rewrite (premise hk4) lr lhs true ())
       (rewrite (premise hk3) lr lhs true ())
       (rewrite (premise hk2) lr lhs true ())))
    (steps
      ((rewrite (lemma ish_be) lr lhs true ())
       (rewrite (lemma wget_be) rl lhs true ())
       (compute rhs (stop wget))))
    refl))

;; phase: Horner load into the shuttle (W[t-15], W[t-7], W[t-2])
(claim ish_ext_ph_ldt
  (goal
    ((acc Int)
     (u Int)
