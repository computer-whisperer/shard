    (have h3 (= (pow2 3) (pow2 (+ 2 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h3) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 2))
      ((steps ((compute lhs)) refl)))
    (have h2 (= (pow2 2) (pow2 (+ 1 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h2) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
