;; phase: sigma0 of the shuttle, summed onto the accumulator, then the
;; pointer jumps to W[t-7]
(claim ish_ext_ph_sg0
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 10 fl)
        65536
        (Cons
          (ISet 1 (IBin U32 IShr (ILoc 11) (IConst 3)))
          (Cons
            (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 18)) (ILoc 1)))
            (Cons
              (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 7)) (ILoc 1)))
              (Cons
                (ISet 0 (IBin U32 IAdd (ILoc 1) (ILoc 0)))
                (Cons (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 28))) rest)))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list
          (mod (+ (ssig0 t) acc) 4294967296)
          (ssig0 t)
          sp
          x3
          x4
          x5
          x6
          x7
          (mod (+ p2 28) 4294967296)
          wp
          n
          t)
        m)))
  (steps ((compute both)) refl))

