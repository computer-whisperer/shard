              (steps ((compute lhs)) refl))
             refl)
           (steps ((compute lhs)) refl)))
        refl))
    (steps () (by arith (rows (goal 1) (hle 1))))))

;; ---- pad kit: window reads --------------------------------------------------------

;; window length ties the Nat count
(claim ish_read_len
  (goal ((w Nat) (m Mem) (a Int)) () (= (slen (mem_read w m a)) (int_of_nat w)))
  (induct w
    ((case Z
       (steps
         ((rewrite (lemma mem_read_z) lr lhs true ())
          (rewrite (lemma int_of_nat_zero) lr rhs true ())
          (compute lhs))
         refl))
     (case S
       (w2)
       (chain
         (steps
           ((rewrite (lemma mem_read_s) lr lhs true ())
            (unfold slen lhs)
            (reduce lhs)))
         (rewrite-with (hyp 0) lr lhs () ())
         (steps ((rewrite (lemma int_of_nat_succ) lr rhs true ())))
         refl)))))

;; a window read splits at any Nat sum
(claim ish_read_app
  (goal ((wa Nat) (wb Nat) (m Mem) (a Int)) ()
    (=
      (mem_read (wn_add wa wb) m a)
      (sapp (mem_read wa m a) (mem_read wb m (+ a (int_of_nat wa))))))
  (induct wa
    ((case Z
       (chain
         (have hz (= (+ a (int_of_nat Z)) a)
           (steps
             ((rewrite (lemma int_of_nat_zero) lr lhs true ()))
             (by arith (list (list 1) (list 1)))))
         (steps
           ((rewrite (lemma wn_add_z) lr lhs true ())
            (rewrite (premise hz) lr rhs true ())
            (rewrite (lemma mem_read_z) lr rhs true ())
            (compute rhs (stop mem_read mem_get))))
         refl))
     (case S
       (wa2)
       (chain
         (have hp (= (+ a (int_of_nat (S wa2))) (+ (+ a 1) (int_of_nat wa2)))
           (steps
             ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
             (by arith (list (list 1) (list 1)))))
         (steps
           ((rewrite (lemma wn_add_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr rhs true ())
            (rewrite (premise hp) lr rhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         (steps ((compute both (stop mem_read mem_get))))
         refl)))))

(claim ish_read1
  (goal ((m Mem) (a Int)) () (= (mem_read 1 m a) (Cons (mem_get m a) Nil)))
  (chain
    (have hb (= (mem_read 1 m a) (mem_read (S Z) m a))
      (steps ((compute both (stop mem_read mem_get))) refl))
    (steps
      ((rewrite (premise hb) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_z) lr lhs true ())))
    refl))

;; the ground-8 unroll (nested pointers -- the pad chain's spellings)
(claim ish_read8
  (goal ((m Mem) (a Int)) ()
    (=
      (mem_read 8 m a)
      (Cons
        (mem_get m a)
        (Cons
          (mem_get m (+ a 1))
          (Cons
            (mem_get m (+ (+ a 1) 1))
            (Cons
              (mem_get m (+ (+ (+ a 1) 1) 1))
              (Cons
                (mem_get m (+ (+ (+ (+ a 1) 1) 1) 1))
                (Cons
                  (mem_get m (+ (+ (+ (+ (+ a 1) 1) 1) 1) 1))
                  (Cons
                    (mem_get m (+ (+ (+ (+ (+ (+ a 1) 1) 1) 1) 1) 1))
                    (Cons
                      (mem_get m (+ (+ (+ (+ (+ (+ (+ a 1) 1) 1) 1) 1) 1) 1))
                      Nil))))))))))
  (chain
    (have hb
      (= (mem_read 8 m a) (mem_read (S (S (S (S (S (S (S (S Z)))))))) m a))
      (steps ((compute both (stop mem_read mem_get))) refl))
    (steps
      ((rewrite (premise hb) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_s) lr lhs true ())
       (rewrite (lemma mem_read_z) lr lhs true ())))
    refl))

;; ---- THE PAD READBACK -------------------------------------------------------------
;; The padded window over the pad effect reads back as the spec's
;; sha_pad of the message window: msg ++ 0x80 ++ zeros ++ len_be(8n).
;; Counts enter as Nats (wn = the message length, wz = the zero span,
;; tied to the spec's mod-64 spelling by the equation premise).
(claim ish_pad_read
  (goal ((m Mem) (src Int) (wn Nat) (wz Nat))
    ((= (le 0 src) True)
     (= (le (+ (+ src (int_of_nat wn)) 72) 65536) True)
     (= (int_of_nat wz) (mod (- 55 (int_of_nat wn)) 64)))
    (=
      (mem_read
        (wn_add wn (wn_add 1 (wn_add wz 8)))
        (ipd_mem m src (int_of_nat wn))
        src)
      (sha_pad (mem_read wn m src))))
  (chain
    (have hnn (= (le 0 (int_of_nat wn)) True)
      (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
    (have hwzlo (= (le 0 (int_of_nat wz)) True)
      (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
    (have hzflo (= (le 0 (ipd_zf (int_of_nat wn))) True)
      (chain
        (steps ((rewrite (lemma ipd_zf_def) lr lhs true ())))
        (rewrite-with
          (lemma band_lo)
          lr
          lhs
          ()
          ((rewrite-with
             (lemma mod_lo)
             lr
             lhs
             ()
             ((steps ((compute lhs)) refl))
             refl)
           (steps ((compute lhs)) refl)))
        refl))
    (have hqld
      (=
        (ipd_ql src (int_of_nat wn))
        (+ (+ (+ src (int_of_nat wn)) 1) (ipd_zf (int_of_nat wn))))
      (steps ((rewrite (lemma ipd_ql_def) lr lhs true ())) refl))
    (have hzn (= (ipd_zf (int_of_nat wn)) (int_of_nat wz))
      (steps
        ((rewrite (lemma ipd_zf_def) lr lhs true ())
         (rewrite (lemma ish_zf) lr lhs true ())
         (rewrite (premise 2) rl lhs true ()))
        refl))
    (have hmh (= (lt (mod (- 55 (int_of_nat wn)) 64) 64) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hwzhi (= (le (int_of_nat wz) 63) True)
      (steps () (by arith (rows (goal 1) (2 -1) (hmh 1)))))
    (steps
      ((unfold ipd_mem lhs)
       (reduce lhs)
       (rewrite (lemma ish_read_app) lr lhs true ())
       (rewrite (lemma ish_read_app) lr lhs true ())
       (rewrite (lemma ish_read_app) lr lhs true ())))
    (have hi1
      (=
        (+ (+ src (int_of_nat wn)) (int_of_nat 1))
        (+ (+ src (int_of_nat wn)) 1))
      (steps ((rewrite (lemma ish_i1) lr lhs true ())) refl))
    (steps ((rewrite (premise hi1) lr lhs true ())))
    (rewrite-with
      (lemma mem_read_set_above)
      lr
      lhs
      ()
      ((steps () (by arith (rows (goal 1) (hqld 1) (hzflo 1))))))
    (rewrite-with
