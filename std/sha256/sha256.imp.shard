    (steps ((compute lhs)))
    (have hk4 (= (+ (+ (+ (+ p2 1) 1) 1) 1) (+ p2 4)) (by arith (list)))
    (have hk3 (= (+ (+ (+ p2 1) 1) 1) (+ p2 3)) (by arith (list)))
    (have hk2 (= (+ (+ p2 1) 1) (+ p2 2)) (by arith (list)))
    (steps
      ((rewrite (premise hk4) lr lhs true ())
       (rewrite (premise hk3) lr lhs true ())
       (rewrite (premise hk2) lr lhs true ())))
    (steps
      ((rewrite (lemma ish_be) lr lhs true ())
       (rewrite (lemma wget_be) rl lhs true ())
       (compute rhs (stop wget))))
    refl))

;; phase: sigma0 of the shuttle, summed onto the accumulator, then the
;; pointer jumps to W[t-7]
(claim ish_ext_ph_sg0
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 10 fl)
        65536
        (Cons
          (ISet 1 (IBin IShr (ILoc 11) (IConst 3)))
          (Cons
            (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 18)) (ILoc 1)))
            (Cons
              (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 7)) (ILoc 1)))
              (Cons
                (ISet 0 (IBin IAdd (ILoc 1) (ILoc 0)))
                (Cons (ISet 8 (IBin IAdd (ILoc 8) (IConst 28))) rest)))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list (+ (ssig0 t) acc) (ssig0 t) sp x3 x4 x5 x6 x7 (+ p2 28) wp n t)
        m)))
  (steps ((compute both)) refl))

;; phase: the shuttle word summed onto the accumulator (W[t-7]), then
;; the pointer jumps to W[t-2]
(claim ish_ext_ph_add
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 7 fl)
        65536
        (Cons
          (ISet 0 (IBin IAdd (ILoc 11) (ILoc 0)))
          (Cons (ISet 8 (IBin IAdd (ILoc 8) (IConst 16))) rest))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list (+ t acc) u sp x3 x4 x5 x6 x7 (+ p2 16) wp n t)
        m)))
  (steps ((compute both)) refl))

;; phase: sigma1 of the shuttle, summed on, and the 32-bit mask — the
;; accumulator finishes as the spec's masked word tree
(claim ish_ext_ph_sg1
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 10 fl)
        65536
        (Cons
          (ISet 1 (IBin IShr (ILoc 11) (IConst 10)))
          (Cons
            (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 19)) (ILoc 1)))
            (Cons
              (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 17)) (ILoc 1)))
              (Cons
                (ISet 0 (IBin IAdd (ILoc 1) (ILoc 0)))
                (Cons (ISet 0 (IBin IAnd (ILoc 0) (IConst 4294967295))) rest)))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list
          (band (+ (ssig1 t) acc) 4294967295)
          (ssig1 t)
          sp
          x3
          x4
          x5
          x6
          x7
          p2
          wp
          n
          t)
        m)))
  (steps ((compute both)) refl))

;; phase: the down-walk store of the accumulator at the frontier — the
;; memory effect folds to wput; the shuttle slots keep their dead
;; shifted residues (the zero phase kills them next)
(claim ish_ext_ph_st
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ((= (le 0 wp) True) (= (le (+ wp 4) 65536) True))
    (=
      (istmts
        (S^ 20 fl)
        65536
        (Cons
          (ISet 2 (IBin IAdd (ILoc 9) (IConst 3)))
          (Cons
            (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
            (Cons
              (IStore (ILoc 2) (ILoc 1))
              (Cons
                (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
                (Cons
                  (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
                  (Cons
                    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
                    (Cons
                      (IStore (ILoc 2) (ILoc 1))
                      (Cons
                        (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
                        (Cons
                          (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
                          (Cons
                            (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
                            (Cons
                              (IStore (ILoc 2) (ILoc 1))
                              (Cons
                                (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
                                (Cons
                                  (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
                                  (Cons
                                    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
                                    (Cons (IStore (ILoc 2) (ILoc 1)) rest)))))))))))))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list
          (bshr (bshr (bshr acc 8) 8) 8)
          (band (bshr (bshr (bshr acc 8) 8) 8) 255)
          wp
          x3
          x4
          x5
          x6
          x7
          p2
          wp
          n
          t)
        (wput m wp acc))))
  (chain
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_slo0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hd1 (= (- (+ wp 3) 1) (+ wp 2)) (by arith (list)))
    (have hd2 (= (- (+ wp 2) 1) (+ wp 1)) (by arith (list)))
    (have hd3 (= (- (+ wp 1) 1) wp) (by arith (list)))
    (steps
      ((rewrite (premise hd1) lr lhs true ())
       (rewrite (premise hd2) lr lhs true ())
       (rewrite (premise hd3) lr lhs true ())))
    (steps
      ((rewrite (lemma wput_sets) rl lhs true ()) (compute rhs (stop wput))))
    refl))

;; phase: the frontier advances, the scratch re-zeroes (zero-in/
;; zero-out), the counter drops
(claim ish_ext_ph_fin
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 12 fl)
        65536
        (Cons
          (ISet 9 (IBin IAdd (ILoc 9) (IConst 4)))
          (Cons
            (ISet 0 (IConst 0))
            (Cons
              (ISet 1 (IConst 0))
              (Cons
                (ISet 2 (IConst 0))
                (Cons
                  (ISet 8 (IConst 0))
                  (Cons
                    (ISet 11 (IConst 0))
                    (Cons (ISet 10 (IBin ISub (ILoc 10) (IConst 1))) rest)))))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list 0 0 0 x3 x4 x5 x6 x7 0 (+ wp 4) (- n 1) 0)
        m)))
  (steps ((compute both)) refl))

;; ---- the extension body -------------------------------------------------------------
;; One schedule-extension iteration, 79 statements: the phase spines in
;; order (pointer drop, W[t-16] into acc, W[t-15] into t, sigma0+sum+
;; jump, W[t-7] into t, sum+jump, W[t-2] into t, sigma1+sum+mask, the
;; down-walk store at the frontier, advance/re-zero/count).

(fn isha_ext_body () (List IStmt)
  (list
    ;; the window pointer drops to W[t-16]
    (ISet 8 (IBin ISub (ILoc 9) (IConst 64)))
    ;; W[t-16]: Horner walk into the accumulator
    (ISet 0 (ILoad (ILoc 8)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin IAdd (ILoc 0) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    ;; W[t-15]: Horner walk into the shuttle (adjacent — no jump)
    (ISet 11 (ILoad (ILoc 8)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    ;; sigma0(t) right-nested in u, summed on, pointer jumps to W[t-7]
    (ISet 1 (IBin IShr (ILoc 11) (IConst 3)))
    (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 18)) (ILoc 1)))
    (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 7)) (ILoc 1)))
    (ISet 0 (IBin IAdd (ILoc 1) (ILoc 0)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 28)))
    ;; W[t-7]: Horner walk into the shuttle
    (ISet 11 (ILoad (ILoc 8)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    ;; summed on, pointer jumps to W[t-2]
    (ISet 0 (IBin IAdd (ILoc 11) (ILoc 0)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 16)))
    ;; W[t-2]: Horner walk into the shuttle
    (ISet 11 (ILoad (ILoc 8)))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin IAdd (ILoc 11) (ILoad (ILoc 8))))
    (ISet 8 (IBin IAdd (ILoc 8) (IConst 1)))
    ;; sigma1(t) right-nested in u, summed on, masked to 32 bits
    (ISet 1 (IBin IShr (ILoc 11) (IConst 10)))
    (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 19)) (ILoc 1)))
    (ISet 1 (IBin IXor (IRotr 32 (ILoc 11) (IConst 17)) (ILoc 1)))
    (ISet 0 (IBin IAdd (ILoc 1) (ILoc 0)))
    (ISet 0 (IBin IAnd (ILoc 0) (IConst 4294967295)))
    ;; the down-walk store at the frontier (wput's chain)
    (ISet 2 (IBin IAdd (ILoc 9) (IConst 3)))
    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
    (IStore (ILoc 2) (ILoc 1))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
    (IStore (ILoc 2) (ILoc 1))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
    (IStore (ILoc 2) (ILoc 1))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin IShr (ILoc 0) (IConst 8)))
    (ISet 1 (IBin IAnd (ILoc 0) (IConst 255)))
    (IStore (ILoc 2) (ILoc 1))
    ;; frontier forward, scratch re-zeroed, counter down
    (ISet 9 (IBin IAdd (ILoc 9) (IConst 4)))
    (ISet 0 (IConst 0))
    (ISet 1 (IConst 0))
    (ISet 2 (IConst 0))
    (ISet 8 (IConst 0))
    (ISet 11 (IConst 0))
    (ISet 10 (IBin ISub (ILoc 10) (IConst 1)))))

;; ---- the extension pass lemma -------------------------------------------------------
;; One body run: the new word (sched_w of the original memory at the
;; frontier) lands at the frontier, the frontier advances by 4, the
;; counter drops, all scratch re-zeroes. The proof is TEN PHASE
;; REWRITES chained on the folded istmts application, with pointer
;; flattens and word folds applied between phases (plain rewrites — the
;; goal stays a folded application, never an open match).

(claim isha_ext_pass
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (m Mem)
     (fl Nat))
    ((= (le 64 wp) True) (= (le (+ wp 4) 65536) True))
    (=
      (istmts
        (S^ 84 fl)
        65536
        (inline isha_ext_body)
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (Some
        (INorm
          (list 0 0 0 x3 x4 x5 x6 x7 0 (+ wp 4) (- n 1) 0)
          (wput m wp (sched_w m wp))))))
  (chain
    (steps ((compute lhs (stop istmts))))
    (steps ((rewrite (lemma ish_ext_ph_ptr) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_lda)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo64)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi64)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (have hf1 (= (+ (- wp 64) 4) (- wp 60)) (by arith (list)))
    (steps ((rewrite (premise hf1) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_ldt)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo60)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi60)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((rewrite (lemma ish_ext_ph_sg0) lr lhs true ())))
    (have hf2 (= (+ (+ (- wp 60) 4) 28) (- wp 28)) (by arith (list)))
    (steps ((rewrite (premise hf2) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_ldt)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo28)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi28)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((rewrite (lemma ish_ext_ph_add) lr lhs true ())))
    (have hf3 (= (+ (+ (- wp 28) 4) 16) (- wp 8)) (by arith (list)))
    (steps ((rewrite (premise hf3) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_ldt)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo8)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi8)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((rewrite (lemma ish_ext_ph_sg1) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_st)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ext_wlo)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((rewrite (lemma ish_ext_ph_fin) lr lhs true ())))
    (steps
      ((compute lhs (stop wget wput ssig0 ssig1))
       (rewrite (lemma sched_w_fold) rl lhs true ())))
    refl))

;; ---- the extension worker -----------------------------------------------------------
;; k new schedule words at the frontier: the loop IS sched_mem. The
;; frontier premise (64 <= wp) keeps the whole read window in bounds;
;; the write premise covers all k stores. Scratch rides zero-in/
;; zero-out.

(claim isha_ext_w
  (goal
    ((x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (wp Int)
     (m Mem)
     (c Nat)
     (k Nat))
    ((= (le 64 wp) True) (= (le (+ wp (* 4 (int_of_nat k))) 65536) True))
    (=
      (iwhile
        (S^ 88 (lg_fuel k c))
        65536
        (ILoc 10)
        (inline isha_ext_body)
        (list 0 0 0 x3 x4 x5 x6 x7 0 wp (int_of_nat k) 0)
        m)
      (Some
        (INorm
          (list 0 0 0 x3 x4 x5 x6 x7 0 (lg_advk wp 4 k) 0 0)
          (sched_mem m wp k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ())
          (compute both (stop wget wput)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold iwhile lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (rewrite-with
           (lemma isha_ext_pass)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
            (rewrite-with
              (lemma ish_w4hi)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_ext_wstep)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma ish_w4shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps
           ((rewrite (lemma sched_mem_s) lr rhs true ())
            (rewrite (lemma lg_advk_s) lr rhs true ())))
         refl)))))

;; ---- the list bridge kit (I2c-2d) ---------------------------------------------------
;; The bridge reads the window DOWNWARD from the frontier: the reversed
;; window's head is the newest word, so one sched_mem step is one Cons
;; -- exactly srev_acc's algebra. Counts ride a transparent in-file
;; adder (std/nat is opaque; add_nat exports no lemmas).

(fn wn_add ((a Nat) (b Nat)) Nat
  (measure (struct a))
  (match a
    (Z b)
    ((S a2) (S (wn_add a2 b)))))

(claim wn_add_s
  (goal ((a Nat) (b Nat)) () (= (wn_add (S a) b) (S (wn_add a b))))
  (steps ((unfold wn_add lhs) (reduce lhs)) refl))

(claim wn_add_sr
  (goal ((a Nat) (b Nat)) () (= (wn_add a (S b)) (S (wn_add a b))))
  (induct a
    ((case Z (steps ((compute both)) refl))
     (case S
       (a2)
       (chain
         (steps
           ((rewrite (lemma wn_add_s) lr lhs true ())
            (rewrite (lemma wn_add_s) lr rhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; the downward window reader: k words below p, newest first
(fn wrev ((m Mem) (p Int) (k Nat)) (List Int)
  (measure (struct k))
  (match k
    (Z Nil)
    ((S k2) (Cons (wget m (- p 4)) (wrev m (- p 4) k2)))))

(claim wrev_s
  (goal ((m Mem) (p Int) (k Nat)) ()
    (= (wrev m p (S k)) (Cons (wget m (- p 4)) (wrev m (- p 4) k))))
  (steps ((unfold wrev lhs) (reduce lhs)) refl))

;; arith helpers for the bridge
(claim ish_le_refl (goal ((x Int)) () (= (le x x) True)) (by arith (list 1)))

(claim ish_wrev_plt
  (goal ((p Int) (d Int)) ((= (le p d) True)) (= (lt (+ (- p 4) 3) d) True))
  (by arith (list 1 1)))

(claim ish_wrev_ple
  (goal ((p Int) (d Int)) ((= (le p d) True)) (= (le (- p 4) d) True))
  (by arith (list 1 1)))

(claim ish_lt32
  (goal ((x Int)) ((= (le x 4294967295) True)) (= (lt x 4294967296) True))
  (by arith (list 1 1)))

(claim ish_le_ne
  (goal ((n Int)) ((= (le 0 n) True)) (= (le (+ 1 n) 0) False))
  (by arith (list 1 1)))

;; ---- stored-value bounds ------------------------------------------------------------
;; The roundtrip needs 0 <= sched_w < 2^32. The mask gives both once
;; the sum under it is nonnegative, which walks down the sigma trees:
;; per-count shift nonnegativity (ground counts keep farkas linear;
;; shr goes through the euclidean characterization at the ground
;; power, shl through the ground multiplier).


(claim ish_ediv2_lo
  (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (ediv x 2)) True))
  (have hid (= x (+ (* 2 (ediv x 2)) (mod x 2)))
    (rewrite-with
      (lemma ediv_mod_id)
      lr
      lhs
      ((inst d 2))
      ((steps ((compute lhs)) refl))
      refl)
    (have hhi (= (lt (mod x 2) 2) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl)
      (by arith (list 2 1 -1 1)))))

(claim ish_shr0_lo
  (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (bshr x 0)) True))
  (chain
    (rewrite-with
      (lemma bshr_z)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((rewrite (premise 0) lr lhs true ())))
    refl))

