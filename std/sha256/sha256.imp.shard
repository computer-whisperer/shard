       (steps ((compute lhs)) refl)))
    refl))

(claim ipd_b7_hi
  (goal ((n Int)) () (= (lt (ipd_b7 n) 256) True))
  (chain
    (have hle (= (le (ipd_b7 n) 255) True)
      (chain
