;; ---- I2c-3, the block tier: walk vocabulary -----------------------------------
;; The remaining six H8 projections (h8a/h8e predate this tier) — the
;; walk theorem's RHS speaks the rounds output through them — and the
;; PACKED rep bridges for the three loop counts (PIN B: ground counts
;; are packed claim-side; the bridge have computes both ways because
;; ceval packs the tower inside the opaque application).

(fn h8b ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xb)))

(fn h8c ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xc)))

(fn h8d ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xd)))

(fn h8f ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xf)))

(fn h8g ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xg)))

(fn h8h ((s H8)) Int
  (match s
    ((mk_h8 xa xb xc xd xe xf xg xh) xh)))

