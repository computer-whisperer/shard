      ((inst k 12))
      ((steps ((compute lhs)) refl)))
    (have h12 (= (pow2 12) (pow2 (+ 11 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h12) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 11))
      ((steps ((compute lhs)) refl)))
    (have h11 (= (pow2 11) (pow2 (+ 10 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h11) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 10))
      ((steps ((compute lhs)) refl)))
    (have h10 (= (pow2 10) (pow2 (+ 9 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h10) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 9))
      ((steps ((compute lhs)) refl)))
    (have h9 (= (pow2 9) (pow2 (+ 8 1))) (steps ((compute both)) refl))
