    (steps ((rewrite (premise hc2) lr lhs true ())))
    (have hf2 (= (+ (+ (- wp 60) 4) 28) (- wp 28)) (by arith (list)))
    (steps ((rewrite (premise hf2) lr lhs true ())))
    (rewrite-with
