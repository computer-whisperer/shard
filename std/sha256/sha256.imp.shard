    (have hk4 (= (+ (+ (+ (+ p2 1) 1) 1) 1) (+ p2 4)) (by arith (list)))
    (have hk3 (= (+ (+ (+ p2 1) 1) 1) (+ p2 3)) (by arith (list)))
