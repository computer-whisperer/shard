                  ((steps ((rewrite (lemma ish_ne32) lr lhs true ())) refl)))
                (rewrite-with
                  (lemma get_set_byte)
                  lr
                  lhs
                  ()
                  ((rewrite-with
                     (lemma ish_byte_lo)
                     lr
                     lhs
                     ()
                     ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                     refl)
                   (rewrite-with
