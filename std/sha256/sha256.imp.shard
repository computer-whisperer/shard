;; the two-byte spill ROUND TRIP, on the machine walk's exact tree: a
;; value below 2^16 spilled as (raw low store, shr-8 store) and reloaded
;; as (hi byte shl 8, add lo byte) under the 64-bit wraps is itself.
;; The masked reads are mod-spelled (std/mem get_set), so the chain is
;; shr8_div + the euclidean characterization -- no bit apparatus.
(claim ish_rt2
  (goal ((v Int)) ((= (le 0 v) True) (= (lt v 65536) True))
    (=
      (mod
        (+ (mod (bshl (mod (bshr v 8) 256) 8) 18446744073709551616) (mod v 256))
        18446744073709551616)
      v))
  (chain
    (have hq (= (bshr v 8) (ediv v 256))
      (rewrite-with
        (lemma shr8_div)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
        refl))
    (have hid (= v (+ (* 256 (ediv v 256)) (mod v 256)))
      (rewrite-with
        (lemma ediv_mod_id)
        rl
        rhs
        ()
        ((steps ((compute both)) refl))
        refl))
    (have hrlo (= (le 0 (mod v 256)) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ()
        ((steps ((compute both)) refl))
        refl))
    (have hrhi (= (lt (mod v 256) 256) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute both)) refl))
        refl))
    (have hqlo (= (le 0 (ediv v 256)) True)
      (steps () (by arith (rows (goal 256) (hid -1) (hrhi 1) (0 1)))))
    (have hqhi (= (lt (ediv v 256) 256) True)
      (steps () (by arith (rows (goal 256) (hid 1) (hrlo 1) (1 1)))))
    (have hmq (= (mod (ediv v 256) 256) (ediv v 256))
      (rewrite-with
        (lemma mod_unique)
        lr
        lhs
        ((inst q 0) (inst r (ediv v 256)))
        ((steps () (by arith (list (list 1) (list 1))))
         (steps ((rewrite (premise hqlo) lr lhs true ())) refl)
         (steps ((rewrite (premise hqhi) lr lhs true ())) refl))
        refl))
    (have hsl (= (bshl (ediv v 256) 8) (* 256 (ediv v 256)))
      (rewrite-with
        (lemma shl8_mul)
        lr
        lhs
        ()
        ((steps ((rewrite (premise hqlo) lr lhs true ())) refl))
        refl))
    (have hw1
      (= (mod (* 256 (ediv v 256)) 18446744073709551616) (* 256 (ediv v 256)))
      (rewrite-with
        (lemma mod_unique)
        lr
        lhs
        ((inst q 0) (inst r (* 256 (ediv v 256))))
        ((steps () (by arith (list (list 1) (list 1))))
         (steps () (by arith (rows (goal 1) (hqlo 256))))
         (steps () (by arith (rows (goal 1) (hqhi 256)))))
        refl))
    (have hw2 (= (mod v 18446744073709551616) v)
      (rewrite-with
        (lemma mod_unique)
        lr
        lhs
        ((inst q 0) (inst r v))
        ((steps () (by arith (list (list 1) (list 1))))
         (steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps () (by arith (rows (goal 1) (1 1)))))
        refl))
    (steps
      ((rewrite (premise hq) lr lhs true ())
       (rewrite (premise hmq) lr lhs true ())
       (rewrite (premise hsl) lr lhs true ())
       (rewrite (premise hw1) lr lhs true ())
       (rewrite (premise hid) rl lhs true ())
       (rewrite (premise hw2) lr lhs true ()))
      refl)))

;; ---- I2e-4a: point-grain BELOW framing (source survival under the fold) ----
;; The blocks fold reads block i+1's source chunk through blocks
;; 1..i's frame writes. The point-grain below family is the mirror of
;; the above family: a byte read strictly below a write's start sees
;; through it; composed at mem_read grain it is the source-survival
;; fact the fold induction rides.

;; a byte read strictly below a word write sees through it
(claim ish_get_wput_below
  (goal ((m Mem) (q Int) (v Int) (p Int)) ((= (lt p q) True))
    (= (mem_get (wput m q v) p) (mem_get m p)))
  (chain
    (steps ((unfold wput lhs)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps () (by arith (rows (goal 1) (0 1)))))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps () (by arith (rows (goal 1) (0 1)))))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps () (by arith (rows (goal 1) (0 1)))))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_lt)
         lr
         lhs
         ()
         ((steps () (by arith (rows (goal 1) (0 1)))))
         refl)))
    refl))

