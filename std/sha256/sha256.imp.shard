;; the big-endian word sum over the memory's bytes is nonnegative
;; (the unfolded ish_wget_range_lo, at the spelling the pass carries)
(claim ish_wbev_lo
  (goal ((m Mem) (p Int)) ()
    (=
      (le
        0
        (+
          (* (mem_get m p) 16777216)
          (+
            (* (mem_get m (+ p 1)) 65536)
            (+ (* (mem_get m (+ p 2)) 256) (mem_get m (+ p 3))))))
      True))
  (chain
    (have g0 (= (le 0 (mem_get m p)) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl))
    (have g1 (= (le 0 (mem_get m (+ p 1))) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl))
    (have g2 (= (le 0 (mem_get m (+ p 2))) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl))
    (have g3 (= (le 0 (mem_get m (+ p 3))) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl))
    (by arith (list 1 16777216 65536 256 1))))

(claim ish_wget_range_lo
  (goal ((m Mem) (p Int)) () (= (le 0 (wget m p)) True))
  (have g0 (= (le 0 (mem_get m p)) True)
    (rewrite-with (lemma get_lo) lr lhs () () refl)
    (have g1 (= (le 0 (mem_get m (+ p 1))) True)
      (rewrite-with (lemma get_lo) lr lhs () () refl)
      (have g2 (= (le 0 (mem_get m (+ p 2))) True)
        (rewrite-with (lemma get_lo) lr lhs () () refl)
        (have g3 (= (le 0 (mem_get m (+ p 3))) True)
          (rewrite-with (lemma get_lo) lr lhs () () refl)
          (chain
            (steps ((compute lhs)))
            (by arith (list 1 16777216 65536 256 1))))))))

(claim ish_wget_range_hi
  (goal ((m Mem) (p Int)) () (= (lt (wget m p) 4294967296) True))
  (have g0 (= (lt (mem_get m p) 256) True)
    (rewrite-with (lemma get_hi) lr lhs () () refl)
    (have g1 (= (lt (mem_get m (+ p 1)) 256) True)
      (rewrite-with (lemma get_hi) lr lhs () () refl)
      (have g2 (= (lt (mem_get m (+ p 2)) 256) True)
        (rewrite-with (lemma get_hi) lr lhs () () refl)
        (have g3 (= (lt (mem_get m (+ p 3)) 256) True)
          (rewrite-with (lemma get_hi) lr lhs () () refl)
          (chain
            (steps ((compute lhs)))
            (by arith (list 1 16777216 65536 256 1))))))))

