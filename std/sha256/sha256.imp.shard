;; the pre-rounds phase: wp back to the parked base, kp and the H
;; pointer derived from it by ground offsets (three guard-free sets)
(claim ish_blk_pre
  (goal
    ((l0 Int)
     (l1 Int)
     (l2 Int)
     (wbv Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l10 Int)
     (l11 Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ((= (le 0 wbv) True) (= (le (+ wbv 544) 65536) True))
    (=
      (istmts
        (S^ 8 fl)
        65536
        (Cons
          (ISet 9 (ILoc 3))
          (Cons
            (ISet 8 (IBin U32 IAdd (ILoc 3) (IConst 256)))
            (Cons (ISet 10 (IBin U32 IAdd (ILoc 3) (IConst 512))) rest)))
        (list l0 l1 l2 wbv l4 l5 l6 l7 l8 l9 l10 l11)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list l0 l1 l2 wbv l4 l5 l6 l7 (+ wbv 256) wbv (+ wbv 512) l11)
        m)))
  (chain
    (steps ((compute lhs)))
    (have h1lo (= (le 0 (+ wbv 256)) True) (by arith (list 1 1 0)))
    (have h1hi (= (lt (+ wbv 256) 4294967296) True) (by arith (list 1 0 1 0)))
    (have h1 (= (mod (+ wbv 256) 4294967296) (+ wbv 256))
      (rewrite-with
        (lemma ish_mid32)
        lr
        lhs
        ((inst x (+ wbv 256)))
        ((steps ((rewrite (premise h1lo) lr lhs true ())) refl)
         (steps ((rewrite (premise h1hi) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise h1) lr lhs true ())))
    (have h2lo (= (le 0 (+ wbv 512)) True) (by arith (list 1 1 0 0 0 0)))
    (have h2hi (= (lt (+ wbv 512) 4294967296) True)
      (by arith (list 1 0 1 0 0 0 0)))
    (have h2 (= (mod (+ wbv 512) 4294967296) (+ wbv 512))
      (rewrite-with
        (lemma ish_mid32)
        lr
        lhs
        ((inst x (+ wbv 512)))
        ((steps ((rewrite (premise h2lo) lr lhs true ())) refl)
         (steps ((rewrite (premise h2hi) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise h2) lr lhs true ()) (compute both)))
    refl))

