;; ---- the extension worker -----------------------------------------------------------
;; k new schedule words at the frontier: the loop IS sched_mem. The
;; frontier premise (64 <= wp) keeps the whole read window in bounds;
;; the write premise covers all k stores. Scratch rides zero-in/
;; zero-out.

(claim isha_ext_w
  (goal
    ((x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (wp Int)
     (m Mem)
     (c Nat)
     (k Nat))
    ((= (le 64 wp) True) (= (le (+ wp (* 4 (int_of_nat k))) 65536) True))
    (=
      (iwhile
        (S^ 88 (lg_fuel k c))
        65536
        (ILoc 10)
        (inline isha_ext_body)
        (list 0 0 0 x3 x4 x5 x6 x7 0 wp (int_of_nat k) 0)
        m)
      (Some
        (INorm
          (list 0 0 0 x3 x4 x5 x6 x7 0 (lg_advk wp 4 k) 0 0)
          (sched_mem m wp k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ())
          (compute both (stop wget wput)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold iwhile lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (have hw0 (= (le 0 wp) True) (by arith (list 1 1 0)))
         (have hn1 (= (le 1 (+ 1 (int_of_nat k2))) True)
           (chain
             (have hz (= (le 0 (int_of_nat k2)) True)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
             (by arith (list 1 0 0 0 1))))
         (have hnM (= (le (+ 1 (int_of_nat k2)) 4294967296) True)
           (rewrite-with
             (lemma ish_kle)
             lr
             lhs
             ((inst p wp))
             ((steps ((rewrite (premise hw0) lr lhs true ())) refl)
              (steps
                ((rewrite (lemma int_of_nat_succ) rl lhs true ())
                 (rewrite (premise 1) lr lhs true ()))
                refl))
             refl))
         (rewrite-with
           (lemma isha_ext_pass)
           lr
           lhs
           ()
           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
            (rewrite-with
              (lemma ish_w4hi)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)
            (steps ((rewrite (premise hn1) lr lhs true ())) refl)
            (steps ((rewrite (premise hnM) lr lhs true ())) refl)))
         (steps
           ((compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr lhs true ())
            (compute
              lhs
              (stop iwhile lg_fuel istmts wget wput sched_w sched_mem lg_advk))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_ext_wstep)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma ish_w4shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps
           ((rewrite (lemma sched_mem_s) lr rhs true ())
            (rewrite (lemma lg_advk_s) lr rhs true ())))
         refl)))))

;; ---- the list bridge kit (I2c-2d) ---------------------------------------------------
;; The bridge reads the window DOWNWARD from the frontier: the reversed
;; window's head is the newest word, so one sched_mem step is one Cons
;; -- exactly srev_acc's algebra. Counts ride a transparent in-file
;; adder (std/nat is opaque; add_nat exports no lemmas).

(fn wn_add ((a Nat) (b Nat)) Nat
  (measure (struct a))
  (match a
    (Z b)
    ((S a2) (S (wn_add a2 b)))))

(claim wn_add_s
  (goal ((a Nat) (b Nat)) () (= (wn_add (S a) b) (S (wn_add a b))))
  (steps ((unfold wn_add lhs) (reduce lhs)) refl))

(claim wn_add_sr
  (goal ((a Nat) (b Nat)) () (= (wn_add a (S b)) (S (wn_add a b))))
  (induct a
    ((case Z (steps ((compute both)) refl))
     (case S
       (a2)
       (chain
         (steps
           ((rewrite (lemma wn_add_s) lr lhs true ())
            (rewrite (lemma wn_add_s) lr rhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; the downward window reader: k words below p, newest first
(fn wrev ((m Mem) (p Int) (k Nat)) (List Int)
  (measure (struct k))
  (match k
    (Z Nil)
    ((S k2) (Cons (wget m (- p 4)) (wrev m (- p 4) k2)))))

(claim wrev_s
  (goal ((m Mem) (p Int) (k Nat)) ()
    (= (wrev m p (S k)) (Cons (wget m (- p 4)) (wrev m (- p 4) k))))
  (steps ((unfold wrev lhs) (reduce lhs)) refl))

;; arith helpers for the bridge
(claim ish_le_refl (goal ((x Int)) () (= (le x x) True)) (by arith (list 1)))

(claim ish_wrev_plt
  (goal ((p Int) (d Int)) ((= (le p d) True)) (= (lt (+ (- p 4) 3) d) True))
  (by arith (list 1 1)))

(claim ish_wrev_ple
  (goal ((p Int) (d Int)) ((= (le p d) True)) (= (le (- p 4) d) True))
  (by arith (list 1 1)))

(claim ish_lt32
  (goal ((x Int)) ((= (le x 4294967295) True)) (= (lt x 4294967296) True))
  (by arith (list 1 1)))

(claim ish_le_ne
  (goal ((n Int)) ((= (le 0 n) True)) (= (le (+ 1 n) 0) False))
  (by arith (list 1 1)))

(claim ish_swsum_lo
  (goal ((m Mem) (p Int)) ()
    (=
      (le
        0
        (+
          (ssig1 (wget m (- p 8)))
          (+ (wget m (- p 28)) (+ (ssig0 (wget m (- p 60))) (wget m (- p 64))))))
      True))
  (have h1 (= (le 0 (ssig1 (wget m (- p 8)))) True)
    (rewrite-with
      (lemma ish_ssig1_lo)
      lr
      lhs
      ()
      ((rewrite-with (lemma ish_wget_range_lo) lr lhs () () refl))
      refl)
    (have h2 (= (le 0 (wget m (- p 28))) True)
      (rewrite-with (lemma ish_wget_range_lo) lr lhs () () refl)
      (have h3 (= (le 0 (ssig0 (wget m (- p 60)))) True)
        (rewrite-with
          (lemma ish_ssig0_lo)
          lr
          lhs
          ()
          ((rewrite-with (lemma ish_wget_range_lo) lr lhs () () refl))
          refl)
        (have h4 (= (le 0 (wget m (- p 64))) True)
          (rewrite-with (lemma ish_wget_range_lo) lr lhs () () refl)
          (by arith (list 1 1 1 1 1)))))))

(claim ish_sw_lo
  (goal ((m Mem) (p Int)) () (= (le 0 (sched_w m p)) True))
  (chain
    (steps ((rewrite (lemma sched_w_fold) lr lhs true ())))
    (rewrite-with
      (lemma band_lo)
      lr
      lhs
      ()
      ((rewrite-with (lemma ish_swsum_lo) lr lhs () () refl)
       (steps ((compute lhs)) refl)))
    refl))

(claim ish_sw_hi
  (goal ((m Mem) (p Int)) () (= (lt (sched_w m p) 4294967296) True))
  (chain
    (steps ((rewrite (lemma sched_w_fold) lr lhs true ())))
    (rewrite-with
      (lemma ish_lt32)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma band_le_r)
         lr
         lhs
         ()
         ((rewrite-with (lemma ish_swsum_lo) lr lhs () () refl)
          (steps ((compute lhs)) refl))
         refl)))
    refl))

;; ---- the downward framing and the cons step ------------------------------------------

;; a store at or above the frontier is invisible to the window below it
(claim ish_wrev_wput_above
  (goal ((m Mem) (p Int) (d Int) (v Int) (k Nat)) ((= (le p d) True))
    (= (wrev (wput m d v) p k) (wrev m p k)))
  (induct k
    ((case Z (steps ((compute both (stop wput))) refl))
     (case S
       (k2)
       (chain
         (steps
           ((rewrite (lemma wrev_s) lr lhs true ())
            (rewrite (lemma wrev_s) lr rhs true ())))
         (rewrite-with
           (lemma ish_wget_wput_other)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_wrev_plt)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_wrev_ple)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)))
         refl)))))

;; one sched_mem step is one Cons on the reversed window: the head is
;; the roundtripped store, the tail is framed below it
(claim ish_wrev_put_s
  (goal ((m Mem) (p Int) (v Int) (k Nat))
    ((= (le 0 v) True) (= (lt v 4294967296) True))
    (= (wrev (wput m p v) (+ p 4) (S k)) (Cons v (wrev m p k))))
  (chain
    (steps ((rewrite (lemma wrev_s) lr lhs true ())))
    (have hp (= (- (+ p 4) 4) p) (by arith (list)))
    (steps ((rewrite (premise hp) lr lhs true ())))
    (rewrite-with
      (lemma isha_wput_get)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with
      (lemma ish_wrev_wput_above)
      lr
      lhs
      ()
      ((rewrite-with (lemma ish_le_refl) lr lhs () () refl)))
    refl))

;; ---- the spec-side step and the sigma/snth alignment ---------------------------------

;; sched_ext's one-step unfolding at live fuel
(claim sched_ext_s
  (goal ((ws (List Int)) (f Int)) ((= (le f 0) False))
    (=
      (sched_ext ws f)
      (sched_ext
        (Cons
          (m32
            (+
              (ssig1 (snth 1 ws))
              (+ (snth 6 ws) (+ (ssig0 (snth 14 ws)) (snth 15 ws)))))
          ws)
        (- f 1))))
  (steps
    ((unfold sched_ext lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs))
    refl))

;; the reversed-index mirror: sched_ext's snth 1/6/14/15 of the
;; downward window ARE sched_w's reads at p-8/-28/-60/-64 (the window
;; count is spelled sixteen literal S deep so the reader provably
;; unfolds; the tail stays abstract)
(claim ish_sw_snth
  (goal ((m Mem) (p Int) (j Nat)) ()
    (=
      (sched_w m p)
      (m32
        (+
          (ssig1
            (snth
              1
              (wrev
                m
                p
                (S
                  (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S j)))))))))))))))))))
          (+
            (snth
              6
              (wrev
                m
                p
                (S
                  (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S j))))))))))))))))))
            (+
              (ssig0
                (snth
                  14
                  (wrev
                    m
                    p
                    (S
                      (S
                        (S
                          (S (S (S (S (S (S (S (S (S (S (S (S (S j)))))))))))))))))))
              (snth
                15
                (wrev
                  m
                  p
                  (S
                    (S
                      (S (S (S (S (S (S (S (S (S (S (S (S (S (S j))))))))))))))))))))))))
  (chain
    (steps ((compute both (stop wget ssig0 ssig1))))
    (have hc1 (= (- (- p 4) 4) (- p 8)) (by arith (list)))
    (have hc2 (= (- (- p 8) 4) (- p 12)) (by arith (list)))
    (have hc3 (= (- (- p 12) 4) (- p 16)) (by arith (list)))
    (have hc4 (= (- (- p 16) 4) (- p 20)) (by arith (list)))
    (have hc5 (= (- (- p 20) 4) (- p 24)) (by arith (list)))
    (have hc6 (= (- (- p 24) 4) (- p 28)) (by arith (list)))
    (have hc7 (= (- (- p 28) 4) (- p 32)) (by arith (list)))
    (have hc8 (= (- (- p 32) 4) (- p 36)) (by arith (list)))
    (have hc9 (= (- (- p 36) 4) (- p 40)) (by arith (list)))
    (have hc10 (= (- (- p 40) 4) (- p 44)) (by arith (list)))
    (have hc11 (= (- (- p 44) 4) (- p 48)) (by arith (list)))
    (have hc12 (= (- (- p 48) 4) (- p 52)) (by arith (list)))
    (have hc13 (= (- (- p 52) 4) (- p 56)) (by arith (list)))
    (have hc14 (= (- (- p 56) 4) (- p 60)) (by arith (list)))
    (have hc15 (= (- (- p 60) 4) (- p 64)) (by arith (list)))
    (steps
      ((rewrite (premise hc1) lr rhs true ())
       (rewrite (premise hc2) lr rhs true ())
       (rewrite (premise hc3) lr rhs true ())
       (rewrite (premise hc4) lr rhs true ())
       (rewrite (premise hc5) lr rhs true ())
       (rewrite (premise hc6) lr rhs true ())
       (rewrite (premise hc7) lr rhs true ())
       (rewrite (premise hc8) lr rhs true ())
       (rewrite (premise hc9) lr rhs true ())
       (rewrite (premise hc10) lr rhs true ())
       (rewrite (premise hc11) lr rhs true ())
       (rewrite (premise hc12) lr rhs true ())
       (rewrite (premise hc13) lr rhs true ())
       (rewrite (premise hc14) lr rhs true ())
       (rewrite (premise hc15) lr rhs true ())))
    refl))

;; ---- the bridge -----------------------------------------------------------------------
;; sched_mem's readback IS sched_ext: k extension steps at the
;; frontier, read back newest-first over the full grown window, equal
;; the spec's reversed-prefix recursion on the initial window. Premise-
;; free: the denotation level has no bounds story (the machine worker
;; carries the guards).
(claim isha_sched_bridge
  (goal ((m Mem) (p Int) (j Nat) (k Nat)) ()
    (=
      (wrev
        (sched_mem m p k)
        (lg_advk p 4 k)
        (wn_add
          k
          (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S j))))))))))))))))))
      (sched_ext
        (wrev
          m
          p
          (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S (S j)))))))))))))))))
        (int_of_nat k))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr rhs true ())
          (compute both (stop wrev wget sched_w)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((rewrite (lemma sched_mem_s) lr lhs true ())
            (rewrite (lemma lg_advk_s) lr lhs true ())
            (rewrite (lemma wn_add_s) lr lhs true ())
            (rewrite (lemma wn_add_sr) rl lhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         (rewrite-with
           (lemma ish_wrev_put_s)
           lr
           lhs
           ()
           ((rewrite-with (lemma ish_sw_lo) lr lhs () () refl)
            (rewrite-with (lemma ish_sw_hi) lr lhs () () refl)))
         (steps ((rewrite (lemma int_of_nat_succ) lr rhs true ())))
         (rewrite-with
           (lemma sched_ext_s)
           lr
           rhs
           ()
           ((rewrite-with
              (lemma ish_le_ne)
              lr
              lhs
              ()
              ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr rhs true ())
            (rewrite (lemma ish_sw_snth) rl rhs true ())))
         refl)))))

;; ---- the window glue (I2c-3 opening) --------------------------------------------------
;; The rounds worker reads the schedule UPWARD (wlist); the bridge
;; speaks DOWNWARD (wrev). The glue: reversing the downward read is the
;; upward read — srev_acc's accumulator walk against a tail-carrying
;; upward reader, with the frontier spelled (lg_advk b 4 k) so the
;; induction binds by matching.

;; the upward reader with an explicit tail
(fn wlist_acc ((m Mem) (p Int) (k Nat) (acc (List Int))) (List Int)
  (measure (struct k))
  (match k
    (Z acc)
    ((S k2) (Cons (wget m p) (wlist_acc m (+ p 4) k2 acc)))))

(claim wlist_acc_s
  (goal ((m Mem) (p Int) (k Nat) (acc (List Int))) ()
    (= (wlist_acc m p (S k) acc) (Cons (wget m p) (wlist_acc m (+ p 4) k acc))))
  (steps ((unfold wlist_acc lhs) (reduce lhs)) refl))

;; the plain reader is the tail-carrying reader at Nil
(claim ish_wlacc_nil
  (goal ((m Mem) (p Int) (k Nat)) () (= (wlist m p k) (wlist_acc m p k Nil)))
  (induct k
    ((case Z (steps ((compute both (stop wget))) refl))
     (case S
       (k2)
       (chain
         (steps ((rewrite (lemma wlist_s) lr lhs true ())))
         (rewrite-with (lemma wlist_acc_s) lr rhs () ())
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; snoc: one more word on the count moves the LAST word into the tail
(claim ish_wlacc_snoc
  (goal ((m Mem) (p Int) (k Nat) (acc (List Int))) ()
    (=
      (wlist_acc m p (S k) acc)
      (wlist_acc m p k (Cons (wget m (lg_advk p 4 k)) acc))))
  (induct k
    ((case Z (steps ((compute both (stop wget))) refl))
     (case S
       (k2)
       (chain
         (rewrite-with (lemma wlist_acc_s) lr lhs () ())
         (rewrite-with (hyp 0) lr lhs () ())
         (rewrite-with (lemma wlist_acc_s) lr rhs () ())
         (steps ((rewrite (lemma lg_advk_s) lr rhs true ())))
         refl)))))

;; stepping the frontier down one word undoes one advance
(claim ish_advk_m4
  (goal ((z Int) (c Nat)) () (= (- (lg_advk (+ z 4) 4 c) 4) (lg_advk z 4 c)))
  (induct c
    ((case Z (steps ((compute both)) (by arith (list (list 1) (list 1)))))
     (case S
       (c2)
       (chain
         (steps ((rewrite (lemma lg_advk_s) lr lhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         (steps ((rewrite (lemma lg_advk_s) lr rhs true ())))
         refl)))))

;; the spec reverser's step, exported as a one-step unfolding
(claim srev_acc_s
  (goal ((h Int) (t (List Int)) (acc (List Int))) ()
    (= (srev_acc (Cons h t) acc) (srev_acc t (Cons h acc))))
  (steps ((unfold srev_acc lhs) (reduce lhs)) refl))

;; THE GLUE: reversing the downward window read IS the upward read
(claim ish_wrev_srev
  (goal ((m Mem) (b Int) (k Nat) (acc (List Int))) ()
    (= (srev_acc (wrev m (lg_advk b 4 k) k) acc) (wlist_acc m b k acc)))
  (induct k
    ((case Z (steps ((compute both (stop wget))) refl))
     (case S
       (k2)
       (chain
         (rewrite-with (lemma wrev_s) lr lhs () ())
         (steps ((rewrite (lemma lg_advk_s) lr lhs true ())))
         (have hz (= (- (lg_advk (+ b 4) 4 k2) 4) (lg_advk b 4 k2))
           (rewrite-with (lemma ish_advk_m4) lr lhs () () refl))
         (steps ((rewrite (premise hz) lr lhs true ())))
         (rewrite-with (lemma srev_acc_s) lr lhs () ())
         (rewrite-with (hyp 0) lr lhs () ())
         (rewrite-with (lemma ish_wlacc_snoc) rl lhs () ())
         refl)))))

;; pointer advance splits over the count sum — the block tier's weld
;; keeps every frontier in lg_advk vocabulary (copy's exit = ext's
;; entry = (lg_advk b 4 16), the 64-window frontier = the split)
(claim wn_add_z
  (goal ((b Nat)) () (= (wn_add Z b) b))
  (steps ((unfold wn_add lhs) (reduce lhs)) refl))

(claim ish_advk_z
  (goal ((x Int) (s Int)) () (= (lg_advk x s Z) x))
  (steps ((unfold lg_advk lhs) (reduce lhs)) refl))

(claim ish_advk_split
  (goal ((z Int) (s Int) (a Nat) (b Nat)) ()
    (= (lg_advk z s (wn_add a b)) (lg_advk (lg_advk z s a) s b)))
  (induct a
    ((case Z
       (steps
         ((rewrite (lemma wn_add_z) lr lhs true ())
          (rewrite (lemma ish_advk_z) lr rhs true ()))
         refl))
     (case S
       (a2)
       (chain
         (steps ((rewrite (lemma wn_add_s) lr lhs true ())))
         (steps
           ((rewrite (lemma lg_advk_s) lr lhs true ())
            (rewrite (lemma lg_advk_s) lr rhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; ---- the schedule-window weld ---------------------------------------------------------
;; The two denotations composed: copy 16 words from the source, extend
;; 48 at the frontier, and the 64-word window reads back as the spec's
;; full schedule shape over the source words. Proof-steps-only from
;; the landed kit: glue + bridge + copy readback, the double-srev
;; computing away at ground counts.

(claim ish_i16
  (goal () () (= (int_of_nat (S^ 16 Z)) 16))
  (steps
    ((rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_zero) lr lhs true ())
     (compute lhs))
    refl))

(claim ish_i48
  (goal () () (= (int_of_nat (S^ 48 Z)) 48))
  (steps
    ((rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_succ) lr lhs true ())
     (rewrite (lemma int_of_nat_zero) lr lhs true ())
     (compute lhs))
    refl))

(claim isha_sched_window
  (goal ((m Mem) (src Int) (b Int)) ((= (le (+ src 64) b) True))
    (=
      (wlist
        (sched_mem
          (copy_wmem m src b (S^ 16 Z))
          (lg_advk b 4 (S^ 16 Z))
          (S^ 48 Z))
        b
        (S^ 64 Z))
      (srev_acc (sched_ext (srev_acc (wlist m src (S^ 16 Z)) Nil) 48) Nil)))
  (chain
    (have hc2 (= (S^ 64 Z) (wn_add (S^ 16 Z) (S^ 48 Z)))
      (steps ((compute both)) refl))
    (have hcnt (= (S^ 64 Z) (wn_add (S^ 48 Z) (S^ 16 Z)))
      (steps ((compute both)) refl))
    (have hfr
      (= (lg_advk b 4 (S^ 64 Z)) (lg_advk (lg_advk b 4 (S^ 16 Z)) 4 (S^ 48 Z)))
      (steps
        ((rewrite (premise hc2) lr lhs true ())
         (rewrite (lemma ish_advk_split) lr lhs true ()))
        refl))
    (steps
      ((rewrite (lemma ish_wlacc_nil) lr lhs true ())
       (rewrite (lemma ish_wrev_srev) rl lhs true ())
       (rewrite (premise hfr) lr lhs true ())
       (rewrite (premise hcnt) lr lhs true ())
       (rewrite (lemma isha_sched_bridge) lr lhs true ())
       (rewrite (lemma ish_i48) lr lhs true ())))
    (have hg
      (=
        (srev_acc
          (wrev (copy_wmem m src b (S^ 16 Z)) (lg_advk b 4 (S^ 16 Z)) (S^ 16 Z))
          Nil)
        (wlist_acc (copy_wmem m src b (S^ 16 Z)) b (S^ 16 Z) Nil))
      (steps ((rewrite (lemma ish_wrev_srev) lr lhs true ())) refl))
    (have hmir
      (=
        (wrev (copy_wmem m src b (S^ 16 Z)) (lg_advk b 4 (S^ 16 Z)) (S^ 16 Z))
        (srev_acc (wlist_acc (copy_wmem m src b (S^ 16 Z)) b (S^ 16 Z) Nil) Nil))
      (steps
        ((rewrite (premise hg) rl rhs true ())
         (compute both (stop wget copy_wmem)))
        refl))
    (steps
      ((rewrite (premise hmir) lr lhs true ())
       (rewrite (lemma ish_wlacc_nil) rl lhs true ())))
    (rewrite-with
      (lemma ish_copy_read)
      lr
      lhs
      ()
      ((steps
         ((rewrite (lemma ish_i16) lr lhs true ())
          (compute lhs)
          (rewrite (premise 0) lr lhs true ()))
         refl)))
    refl))

;; ---- the byte crossing ----------------------------------------------------------------
;; words16 over the memory's byte readback IS the word-window read:
;; the message block enters the schedule story as bytes (mem_read),
;; and the copy loop's Horner words are exactly words16's word_be
;; groups. The byte count rides a transparent quadrupler.

(fn wn_q ((k Nat)) Nat
  (measure (struct k))
  (match k
    (Z 0)
    ((S k2) (S (S (S (S (wn_q k2))))))))

(claim wn_q_s
  (goal ((k Nat)) () (= (wn_q (S k)) (S (S (S (S (wn_q k)))))))
  (steps ((unfold wn_q lhs) (reduce lhs)) refl))

;; words16's one-step unfolding at live fuel
(claim words16_s
  (goal ((bs (List Int)) (f Int)) ((= (le f 0) False))
    (=
      (words16 bs f)
      (Cons
        (word_be (snth 0 bs) (snth 1 bs) (snth 2 bs) (snth 3 bs))
        (words16 (sdrop 4 bs) (- f 1)))))
  (steps
    ((unfold words16 lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs))
    refl))

;; sdrop 4 over a literal four-head spine lands on the tail (ctor
;; cases keep the guard-behind-match spelling from sticking open)
(claim sdrop4_cons
  (goal ((a Int) (b Int) (c Int) (d Int) (t (List Int))) ()
    (= (sdrop 4 (Cons a (Cons b (Cons c (Cons d t))))) t))
  (induct t
    ((case Nil (steps ((compute both)) refl))
     (case Cons (h t2) (steps ((compute both)) refl)))))

;; the crossing: word-grouping the byte readback is the word read
(claim ish_words16_read
  (goal ((m Mem) (p Int) (k Nat)) ()
    (= (words16 (mem_read (wn_q k) m p) (int_of_nat k)) (wlist m p k)))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ())
          (compute both (stop mem_read)))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((rewrite (lemma wn_q_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr lhs true ())))
         (have hk2 (= (+ (+ p 1) 1) (+ p 2)) (by arith (list)))
         (have hk3 (= (+ (+ p 2) 1) (+ p 3)) (by arith (list)))
         (have hk4 (= (+ (+ p 3) 1) (+ p 4)) (by arith (list)))
         (steps
           ((rewrite (premise hk2) lr lhs true ())
            (rewrite (premise hk3) lr lhs true ())
            (rewrite (premise hk4) lr lhs true ())))
         (rewrite-with
           (lemma words16_s)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_le_ne)
              lr
              lhs
              ()
              ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
              refl)))
         (steps
           ((compute lhs (stop words16 sdrop wget mem_get mem_read wn_q))
            (rewrite (lemma sdrop4_cons) lr lhs true ())))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (rewrite-with (hyp 0) lr lhs () ())
         (steps
           ((rewrite (lemma wget_be) rl lhs true ())
            (rewrite (lemma wlist_s) lr rhs true ())))
         refl)))))


;; =========================================================================
;; ---- I2c-3, the block tier: the sequencing pin --------------------------------
;;
;; Two pins validated on a mini-block (two copy loops + straight-line
;; resets in ONE statement spine), before the real three-loop block body:
;;
;;   PIN A (fuel chaining). The block runs on ONE literal tower (S^ N d).
;;   A loop worker consumes NOTHING from the spine's fuel — istmts hands
;;   the same f2 to head and tail — so each loop head just needs its
;;   residual tower RE-SPELLED as the worker's (S^ 40 (lg_fuel k slack))
;;   shape: a have proven by compute both (lg_fuel ground-collapses; the
;;   slack tower absorbs the excess). The FIRST loop's re-spelling is done
;;   UP FRONT on the initial fuel, where it occurs exactly once, so the
;;   loop head lands on the worker's shape by construction; later loops
;;   re-spell mid-proof, their residual spelling known by construction
;;   from the previous have.
;;
;;   PIN B (ground rep): PACKED EVERYWHERE. ceval normalizes the args of
;;   stopped applications, so any ground tower written claim-side packs
;;   the moment a compute touches it — ground counts must be SPELLED
;;   packed (which is also C6's source form), or the worker's k unifies
;;   inconsistently (packed from the fuel, tower from the locals). The
;;   rep bridge (= (int_of_nat N) (int_of_nat (S^ N Z))) holds by compute
;;   both (the arg packs), which feeds the succ-ladder; count alignment
;;   then rewrites the FULL 12-local list — a compound pattern with
;;   exactly one occurrence — never the bare literal (the rewriter
;;   finding: packed Nat and Int ground literals are the same rewrite
;;   atom, so bare-literal rewrites can cross sorts).
;; -------------------------------------------------------------------------

(claim ish_i1
  (goal () () (= (int_of_nat 1) 1))
  (chain
    (have ha (= (int_of_nat 1) (int_of_nat (S Z)))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise ha) lr lhs true ())
       (rewrite (lemma int_of_nat_succ) lr lhs true ())
       (rewrite (lemma int_of_nat_zero) lr lhs true ())
       (compute lhs)))
    refl))

(claim ish_i2
  (goal () () (= (int_of_nat 2) 2))
  (chain
    (have ha (= (int_of_nat 2) (int_of_nat (S (S Z))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise ha) lr lhs true ())
       (rewrite (lemma int_of_nat_succ) lr lhs true ())
       (rewrite (lemma int_of_nat_succ) lr lhs true ())
       (rewrite (lemma int_of_nat_zero) lr lhs true ())
       (compute lhs)))
    refl))

(claim ish_blk_seq
  (goal
    ((x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (m Mem)
     (d Nat))
    ((= (le 0 p2) True)
     (= (le (+ p2 8) 65536) True)
     (= (le 0 wp) True)
     (= (le (+ wp 12) 65536) True))
    (=
      (istmts
        (S^ 100 d)
        65536
        (list
          (ISet 10 (IConst 2))
          (IWhile (ILoc 10) (inline isha_copy_body))
          (ISet 8 (IConst 0))
          (ISet 10 (IConst 1))
          (IWhile (ILoc 10) (inline isha_copy_body)))
        (list 0 0 x2 x3 x4 x5 x6 x7 p2 wp 0 0)
        m)
      (Some
        (INorm
          (list
            0
            0
            x2
            x3
            x4
            x5
            x6
            x7
            (lg_advk 0 4 1)
            (lg_advk (lg_advk wp 4 2) 4 1)
            0
            0)
          (copy_wmem (copy_wmem m p2 wp 2) 0 (lg_advk wp 4 2) 1)))))
  (chain
    (have hfu2 (= (S^ 97 d) (S^ 40 (lg_fuel 2 (S^ 55 d))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hfu2) lr lhs true ())
       (compute
         lhs
         (stop iwhile lg_fuel lg_advk int_of_nat copy_wmem wget wput))))
    (have hlc2
      (=
        (list 0 0 x2 x3 x4 x5 x6 x7 p2 wp 2 0)
        (list 0 0 x2 x3 x4 x5 x6 x7 p2 wp (int_of_nat 2) 0))
      (steps ((rewrite (lemma ish_i2) lr rhs true ())) refl))
    (steps ((rewrite (premise hlc2) lr lhs true ())))
    (rewrite-with
      (lemma isha_copy_w)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps
         ((rewrite (lemma ish_i2) lr lhs true ())
          (compute lhs)
          (rewrite (premise 1) lr lhs true ()))
         refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps
         ((rewrite (lemma ish_i2) lr lhs true ()) (compute lhs))
         (by arith (list 1 0 0 0 1 0 0)))))
    (steps
      ((compute
         lhs
         (stop iwhile lg_fuel lg_advk int_of_nat copy_wmem wget wput))))
    (have hlc1
      (=
        (list 0 0 x2 x3 x4 x5 x6 x7 0 (lg_advk wp 4 2) 1 0)
        (list 0 0 x2 x3 x4 x5 x6 x7 0 (lg_advk wp 4 2) (int_of_nat 1) 0))
      (steps ((rewrite (lemma ish_i1) lr rhs true ())) refl))
    (steps ((rewrite (premise hlc1) lr lhs true ())))
    (have hfu1 (= (S^ 37 (lg_fuel 2 (S^ 55 d))) (S^ 40 (lg_fuel 1 (S^ 53 d))))
      (steps ((compute both)) refl))
    (steps ((rewrite (premise hfu1) lr lhs true ())))
    (rewrite-with
      (lemma isha_copy_w)
      lr
      lhs
      ()
      ((steps ((compute lhs)) refl)
       (steps ((rewrite (lemma ish_i1) lr lhs true ()) (compute lhs)) refl)
       (steps ((compute lhs)) (by arith (list 1 0 0 1 0 0 0 0 0)))
       (steps
         ((rewrite (lemma ish_i1) lr lhs true ()) (compute lhs))
         (by arith (list 1 0 0 0 1 0 0 0 0)))))
    (steps
      ((compute
         lhs
         (stop iwhile lg_fuel lg_advk int_of_nat copy_wmem wget wput))))
    refl))

;; ---- I2c-3, the block tier: the hi-side framing kit ---------------------------
;; The block's K and H windows sit ABOVE the W-region writes (relative
;; layout: W at wb, K at wb+256, H at wb+512); the rounds citation and
;; the H-load phases read them across copy_wmem/sched_mem. Mirrors of
;; the below-side kit with the reader at higher addresses.

;; a strictly-higher value is a different value
(claim ish_ne_gt
  (goal ((a Int) (b Int)) ((= (lt b a) True)) (= (int_eq a b) False))
  (by arith (list -1 1)))

;; the store side of a word write, peeled down from its last byte
(claim ish_qlt0
  (goal ((b Int) (p Int)) ((= (lt (+ b 3) p) True)) (= (lt b p) True))
  (by arith (list 1 1)))

(claim ish_qlt1
  (goal ((b Int) (p Int)) ((= (lt (+ b 3) p) True)) (= (lt (+ b 1) p) True))
  (by arith (list 1 1)))

(claim ish_qlt2
  (goal ((b Int) (p Int)) ((= (lt (+ b 3) p) True)) (= (lt (+ b 2) p) True))
  (by arith (list 1 1)))

;; one word read above a byte store is untouched
(claim ish_wget_set_hi
  (goal ((m Mem) (p Int) (b Int) (v Int)) ((= (lt b p) True))
    (= (wget (mem_set m b v) p) (wget m p)))
  (chain
    (steps ((compute both)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_gt)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_gt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_lt_b1)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_gt)
         lr
         lhs
         ()
         ((rewrite-with
            (lemma ish_lt_b2)
            lr
            lhs
            ()
            ((steps ((rewrite (premise 0) lr lhs true ())) refl))
            refl))
         refl)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_ne_gt)
         lr
         lhs
         ()
