    (have h1 (= (pow2 1) (pow2 (+ 0 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h1) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 0))
      ((steps ((compute lhs)) refl)))
    (steps ((rewrite (lemma pow2_z) lr lhs true ()) (compute lhs)) refl)))

;; the mask/mod bridge at the 32-bit window: band by the all-ones word
;; IS the remainder (mask_pow2 at k = 32, the pow2 atoms grounded)
(claim ish_mm32
  (goal ((a Int)) ((= (le 0 a) True))
    (= (band a 4294967295) (mod a 4294967296)))
  (chain
    (have hp (= (pow2 32) 4294967296)
      (rewrite-with (lemma ish_pow32) lr lhs () () refl))
    (have hm (= 4294967295 (- (pow2 32) 1))
      (steps ((rewrite (premise hp) lr rhs true ())) (by arith (list))))
    (steps
      ((rewrite (premise hm) lr both true ())
       (rewrite (premise hp) rl rhs true ())))
    (rewrite-with
      (lemma mask_pow2)
      lr
      lhs
      ((inst k 32))
      ((steps ((compute lhs)) refl)
       (steps ((rewrite (premise 0) lr lhs true ())) refl)))
    refl))

;; the in-band collapse: a wrap of an already-in-band value is the value
(claim ish_mid32
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (chain
    (rewrite-with
      (lemma mod_unique)
      lr
      lhs
      ((inst q 0) (inst r x))
      ((steps ((compute both)) (by arith (list)))
       (steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    refl))

;; euclidean congruence, left operand: an inner wrap under + dissolves
(claim ish_madd_l
  (goal ((a Int) (b Int)) ()
    (= (mod (+ (mod a 4294967296) b) 4294967296) (mod (+ a b) 4294967296)))
  (chain
    (have hda (= a (+ (* 4294967296 (ediv a 4294967296)) (mod a 4294967296)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 4294967296))
        ((steps ((compute lhs)) refl))
        refl))
    (have hdb
      (=
        (+ (mod a 4294967296) b)
        (+
          (* 4294967296 (ediv (+ (mod a 4294967296) b) 4294967296))
          (mod (+ (mod a 4294967296) b) 4294967296)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 4294967296))
        ((steps ((compute lhs)) refl))
        refl))
    (have hlo (= (le 0 (mod (+ (mod a 4294967296) b) 4294967296)) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hhi (= (lt (mod (+ (mod a 4294967296) b) 4294967296) 4294967296) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have heq
      (=
        (+ a b)
        (+
          (*
            4294967296
            (+ (ediv (+ (mod a 4294967296) b) 4294967296) (ediv a 4294967296)))
          (mod (+ (mod a 4294967296) b) 4294967296)))
      (chain
        (rewrite-with
          (lemma mul_dist)
          lr
          rhs
          ((inst a 4294967296)
           (inst b (ediv (+ (mod a 4294967296) b) 4294967296))
           (inst c (ediv a 4294967296)))
          ())
        (by arith (list (list 1 -1 -1 0 0) (list 1 1 1 0 0)))))
    (rewrite-with
      (lemma mod_unique)
      lr
      rhs
      ((inst
         q
         (+ (ediv (+ (mod a 4294967296) b) 4294967296) (ediv a 4294967296)))
       (inst r (mod (+ (mod a 4294967296) b) 4294967296)))
      ((steps ((rewrite (premise heq) lr lhs true ())) refl)
       (steps ((rewrite (premise hlo) lr lhs true ())) refl)
       (steps ((rewrite (premise hhi) lr lhs true ())) refl)))
    refl))

;; euclidean congruence, right operand
(claim ish_madd_r
  (goal ((a Int) (b Int)) ()
    (= (mod (+ a (mod b 4294967296)) 4294967296) (mod (+ a b) 4294967296)))
  (chain
    (have hda (= b (+ (* 4294967296 (ediv b 4294967296)) (mod b 4294967296)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 4294967296))
        ((steps ((compute lhs)) refl))
        refl))
    (have hdb
      (=
        (+ a (mod b 4294967296))
        (+
          (* 4294967296 (ediv (+ a (mod b 4294967296)) 4294967296))
          (mod (+ a (mod b 4294967296)) 4294967296)))
      (rewrite-with
        (lemma ediv_mod_id)
        lr
        lhs
        ((inst d 4294967296))
        ((steps ((compute lhs)) refl))
        refl))
    (have hlo (= (le 0 (mod (+ a (mod b 4294967296)) 4294967296)) True)
      (rewrite-with
        (lemma mod_lo)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have hhi (= (lt (mod (+ a (mod b 4294967296)) 4294967296) 4294967296) True)
      (rewrite-with
        (lemma mod_hi)
        lr
        lhs
        ()
        ((steps ((compute lhs)) refl))
        refl))
    (have heq
      (=
        (+ a b)
        (+
          (*
            4294967296
            (+ (ediv (+ a (mod b 4294967296)) 4294967296) (ediv b 4294967296)))
          (mod (+ a (mod b 4294967296)) 4294967296)))
      (chain
        (rewrite-with
          (lemma mul_dist)
          lr
          rhs
          ((inst a 4294967296)
           (inst b (ediv (+ a (mod b 4294967296)) 4294967296))
           (inst c (ediv b 4294967296)))
          ())
        (by arith (list (list 1 -1 -1 0 0) (list 1 1 1 0 0)))))
    (rewrite-with
      (lemma mod_unique)
      lr
      rhs
      ((inst
         q
         (+ (ediv (+ a (mod b 4294967296)) 4294967296) (ediv b 4294967296)))
       (inst r (mod (+ a (mod b 4294967296)) 4294967296)))
      ((steps ((rewrite (premise heq) lr lhs true ())) refl)
       (steps ((rewrite (premise hlo) lr lhs true ())) refl)
       (steps ((rewrite (premise hhi) lr lhs true ())) refl)))
    refl))

;; pointer-advance collapses at the Horner walk's literal trees: the
;; window premise keeps every advanced pointer in band, so the machine
;; wrap is the identity (the guard-lemma idiom, one per tree shape)
(claim ish_mp1
  (goal ((p Int)) ((= (le 0 p) True) (= (le (+ p 4) 65536) True))
    (= (mod (+ p 1) 4294967296) (+ p 1)))
  (chain
    (have hlo (= (le 0 (+ p 1)) True) (by arith (list 1 1 0)))
    (have hhi (= (lt (+ p 1) 4294967296) True) (by arith (list 1 0 1 0)))
    (rewrite-with
      (lemma ish_mid32)
      lr
      lhs
      ((inst x (+ p 1)))
      ((steps ((rewrite (premise hlo) lr lhs true ())) refl)
       (steps ((rewrite (premise hhi) lr lhs true ())) refl)))
    refl))

(claim ish_mp2
  (goal ((p Int)) ((= (le 0 p) True) (= (le (+ p 4) 65536) True))
    (= (mod (+ (+ p 1) 1) 4294967296) (+ (+ p 1) 1)))
  (chain
    (have hlo (= (le 0 (+ (+ p 1) 1)) True) (by arith (list 1 1 0)))
    (have hhi (= (lt (+ (+ p 1) 1) 4294967296) True) (by arith (list 1 0 1 0)))
    (rewrite-with
