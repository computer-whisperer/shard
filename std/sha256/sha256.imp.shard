;; the rounds walk preserves componentwise nonnegativity
(claim ish_srounds_los
  (goal
    ((sa Int)
     (sb Int)
     (sc Int)
     (sd Int)
     (se Int)
     (sf Int)
     (sg Int)
     (sh Int)
     (ks (List Int))
     (ws (List Int)))
    ((= (le 0 sa) True)
     (= (le 0 sb) True)
     (= (le 0 sc) True)
     (= (le 0 sd) True)
     (= (le 0 se) True)
     (= (le 0 sf) True)
     (= (le 0 sg) True)
     (= (le 0 sh) True)
     (= (slo ks) True)
     (= (slo ws) True))
    (=
      (h8_los (sha_rounds (mk_h8 sa sb sc sd se sf sg sh) ks ws))
      (list True True True True True True True True)))
  (induct ks
    ((case Nil
       (chain
         (steps ((compute lhs)))
         (steps
           ((rewrite (premise 0) lr lhs true ())
            (rewrite (premise 1) lr lhs true ())
            (rewrite (premise 2) lr lhs true ())
            (rewrite (premise 3) lr lhs true ())
            (rewrite (premise 4) lr lhs true ())
            (rewrite (premise 5) lr lhs true ())
            (rewrite (premise 6) lr lhs true ())
            (rewrite (premise 7) lr lhs true ())))
         refl))
     (case Cons
       (kw kt)
       (case-on ws List
         ((case Nil
            (chain
              (steps ((rewrite (hyp 0) lr lhs true ()) (compute lhs)))
              (steps
                ((rewrite (premise 0) lr lhs true ())
                 (rewrite (premise 1) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ())
                 (rewrite (premise 3) lr lhs true ())
                 (rewrite (premise 4) lr lhs true ())
                 (rewrite (premise 5) lr lhs true ())
                 (rewrite (premise 6) lr lhs true ())
                 (rewrite (premise 7) lr lhs true ())))
              refl))
          (case Cons
            (ww wt)
            (chain
              (have hkw (= (le 0 kw) True)
                (rewrite-with
                  (lemma ish_slo_hd)
                  lr
                  lhs
                  ((inst t kt))
                  ((steps ((rewrite (premise 8) lr lhs true ())) refl))
                  refl))
              (have hkt (= (slo kt) True)
                (rewrite-with
                  (lemma ish_slo_tl)
                  lr
                  lhs
                  ((inst h kw))
                  ((steps ((rewrite (premise 8) lr lhs true ())) refl))
                  refl))
              (have hww (= (le 0 ww) True)
                (rewrite-with
                  (lemma ish_slo_hd)
                  lr
                  lhs
                  ((inst t wt))
                  ((steps
                     ((rewrite (hyp 0) rl lhs true ())
                      (rewrite (premise 9) lr lhs true ()))
                     refl))
                  refl))
              (have hwt (= (slo wt) True)
                (rewrite-with
                  (lemma ish_slo_tl)
                  lr
                  lhs
                  ((inst h ww))
                  ((steps
                     ((rewrite (hyp 0) rl lhs true ())
                      (rewrite (premise 9) lr lhs true ()))
                     refl))
                  refl))
              (steps
                ((rewrite (hyp 0) lr lhs true ())
                 (rewrite (lemma sha_rounds_s) lr lhs true ())
                 (compute lhs (stop sha_rounds h8_los))))
              (rewrite-with
                (hyp 1)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma ish_ra_lo)
                   lr
                   lhs
                   ()
                   ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                    (steps ((rewrite (premise 1) lr lhs true ())) refl)
                    (steps ((rewrite (premise 2) lr lhs true ())) refl)
                    (steps ((rewrite (premise 4) lr lhs true ())) refl)
                    (steps ((rewrite (premise 5) lr lhs true ())) refl)
                    (steps ((rewrite (premise 6) lr lhs true ())) refl)
                    (steps ((rewrite (premise 7) lr lhs true ())) refl)
                    (steps ((rewrite (premise hkw) lr lhs true ())) refl)
                    (steps ((rewrite (premise hww) lr lhs true ())) refl))
                   refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl)
                 (steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (rewrite-with
                   (lemma ish_re_lo)
                   lr
                   lhs
                   ()
                   ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                    (steps ((rewrite (premise 4) lr lhs true ())) refl)
                    (steps ((rewrite (premise 5) lr lhs true ())) refl)
                    (steps ((rewrite (premise 6) lr lhs true ())) refl)
                    (steps ((rewrite (premise 7) lr lhs true ())) refl)
                    (steps ((rewrite (premise hkw) lr lhs true ())) refl)
                    (steps ((rewrite (premise hww) lr lhs true ())) refl))
                   refl)
                 (steps ((rewrite (premise 4) lr lhs true ())) refl)
                 (steps ((rewrite (premise 5) lr lhs true ())) refl)
                 (steps ((rewrite (premise 6) lr lhs true ())) refl)
                 (steps ((rewrite (premise hkt) lr lhs true ())) refl)
                 (steps ((rewrite (premise hwt) lr lhs true ())) refl)))
              refl))))))))

