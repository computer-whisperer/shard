;; phase: the down-walk store of the accumulator at the frontier — the
;; memory effect folds to wput; the shuttle slots keep their dead
;; shifted residues (the zero phase kills them next)
(claim ish_ext_ph_st
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ((= (le 0 wp) True) (= (le (+ wp 4) 65536) True))
    (=
      (istmts
        (S^ 16 fl)
        65536
        (Cons
          (ISet 2 (IBin U32 IAdd (ILoc 9) (IConst 3)))
          (Cons
            (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
            (Cons
              (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
              (Cons
                (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
                (Cons
                  (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
                  (Cons
                    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
                    (Cons
                      (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
                      (Cons
                        (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
                        (Cons
                          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
                          (Cons
                            (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
                            (Cons
                              (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
                              rest)))))))))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list (bshr (bshr (bshr acc 8) 8) 8) u wp x3 x4 x5 x6 x7 p2 wp n t)
        (wput m wp acc))))
  (chain
    (steps ((compute lhs)))
    (have hs3 (= (mod (+ wp 3) 4294967296) (+ wp 3))
      (rewrite-with
        (lemma ish_mq3)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hs3) lr lhs true ())))
    (rewrite-with
      (lemma ish_slo3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi3)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hm1 (= (mod (- (+ wp 3) 1) 4294967296) (- (+ wp 3) 1))
      (rewrite-with
        (lemma ish_ms1)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hm1) lr lhs true ())))
    (rewrite-with
      (lemma ish_slo2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi2)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hm2 (= (mod (- (- (+ wp 3) 1) 1) 4294967296) (- (- (+ wp 3) 1) 1))
      (rewrite-with
        (lemma ish_ms2)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hm2) lr lhs true ())))
    (rewrite-with
      (lemma ish_slo1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi1)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hm3
      (= (mod (- (- (- (+ wp 3) 1) 1) 1) 4294967296) (- (- (- (+ wp 3) 1) 1) 1))
      (rewrite-with
        (lemma ish_ms3)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hm3) lr lhs true ())))
    (rewrite-with
      (lemma ish_slo0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma ish_shi0)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute lhs)))
    (have hd1 (= (- (+ wp 3) 1) (+ wp 2)) (by arith (list)))
    (have hd2 (= (- (+ wp 2) 1) (+ wp 1)) (by arith (list)))
    (have hd3 (= (- (+ wp 1) 1) wp) (by arith (list)))
    (steps
      ((rewrite (premise hd1) lr lhs true ())
       (rewrite (premise hd2) lr lhs true ())
       (rewrite (premise hd3) lr lhs true ())))
    (steps
      ((rewrite (lemma wput_sets) rl lhs true ()) (compute rhs (stop wput))))
    refl))

;; phase: the frontier advances, the scratch re-zeroes (zero-in/
;; zero-out), the counter drops
(claim ish_ext_ph_fin
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (rest (List IStmt))
     (m Mem)
     (fl Nat))
    ()
    (=
      (istmts
        (S^ 12 fl)
        65536
        (Cons
          (ISet 9 (IBin U32 IAdd (ILoc 9) (IConst 4)))
          (Cons
            (ISet 0 (IConst 0))
            (Cons
              (ISet 1 (IConst 0))
              (Cons
                (ISet 2 (IConst 0))
                (Cons
                  (ISet 8 (IConst 0))
                  (Cons
                    (ISet 11 (IConst 0))
                    (Cons (ISet 10 (IBin U32 ISub (ILoc 10) (IConst 1))) rest)))))))
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (istmts
        (S^ 5 fl)
        65536
        rest
        (list
          0
          0
          0
          x3
          x4
          x5
          x6
          x7
          0
          (mod (+ wp 4) 4294967296)
          (mod (- n 1) 4294967296)
          0)
        m)))
  (steps ((compute both)) refl))

;; ---- the extension body -------------------------------------------------------------
;; One schedule-extension iteration, 79 statements: the phase spines in
;; order (pointer drop, W[t-16] into acc, W[t-15] into t, sigma0+sum+
;; jump, W[t-7] into t, sum+jump, W[t-2] into t, sigma1+sum+mask, the
;; down-walk store at the frontier, advance/re-zero/count).

(fn isha_ext_body () (List IStmt)
  (list
    ;; the window pointer drops to W[t-16]
    (ISet 8 (IBin U32 ISub (ILoc 9) (IConst 64)))
    ;; W[t-16]: Horner walk into the accumulator
    (ISet 0 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin U32 IAdd (ILoc 0) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin U32 IAdd (ILoc 0) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 0 (IBin U32 IMul (ILoc 0) (IConst 256)))
    (ISet 0 (IBin U32 IAdd (ILoc 0) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    ;; W[t-15]: Horner walk into the shuttle (adjacent — no jump)
    (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    ;; sigma0(t) right-nested in u, summed on, pointer jumps to W[t-7]
    (ISet 1 (IBin U32 IShr (ILoc 11) (IConst 3)))
    (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 18)) (ILoc 1)))
    (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 7)) (ILoc 1)))
    (ISet 0 (IBin U32 IAdd (ILoc 1) (ILoc 0)))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 28)))
    ;; W[t-7]: Horner walk into the shuttle
    (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    ;; summed on, pointer jumps to W[t-2]
    (ISet 0 (IBin U32 IAdd (ILoc 11) (ILoc 0)))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 16)))
    ;; W[t-2]: Horner walk into the shuttle
    (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    ;; sigma1(t) right-nested in u, summed on, masked to 32 bits
    (ISet 1 (IBin U32 IShr (ILoc 11) (IConst 10)))
    (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 19)) (ILoc 1)))
    (ISet 1 (IBin U32 IXor (IRotr U32 (ILoc 11) (IConst 17)) (ILoc 1)))
    (ISet 0 (IBin U32 IAdd (ILoc 1) (ILoc 0)))
    ;; the down-walk store at the frontier (wput's chain)
    (ISet 2 (IBin U32 IAdd (ILoc 9) (IConst 3)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))
    (ISet 0 (IBin U32 IShr (ILoc 0) (IConst 8)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 0)))
    ;; frontier forward, scratch re-zeroed, counter down
    (ISet 9 (IBin U32 IAdd (ILoc 9) (IConst 4)))
    (ISet 0 (IConst 0))
    (ISet 1 (IConst 0))
    (ISet 2 (IConst 0))
    (ISet 8 (IConst 0))
    (ISet 11 (IConst 0))
    (ISet 10 (IBin U32 ISub (ILoc 10) (IConst 1)))))

;; the body is WELL-KINDED in the 12-slot U32 frame (the 2a membership
;; gate: generated imp -> ISA legs are total over wk programs)
(claim ish_wk_ext
  (goal () ()
    (=
      (iwk_stmts
        (list U32 U32 U32 U32 U32 U32 U32 U32 U32 U32 U32 U32)
        (isha_ext_body))
      True))
  (steps ((compute lhs)) refl))

;; ---- the extension pass lemma -------------------------------------------------------
;; One body run: the new word (sched_w of the original memory at the
;; frontier) lands at the frontier, the frontier advances by 4, the
;; counter drops, all scratch re-zeroes. The proof is TEN PHASE
;; REWRITES chained on the folded istmts application, with pointer
;; flattens and word folds applied between phases (plain rewrites — the
;; goal stays a folded application, never an open match).

(claim isha_ext_pass
  (goal
    ((acc Int)
     (u Int)
     (sp Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (p2 Int)
     (wp Int)
     (n Int)
     (t Int)
     (m Mem)
     (fl Nat))
    ((= (le 64 wp) True)
     (= (le (+ wp 4) 65536) True)
     (= (le 1 n) True)
     (= (le n 4294967296) True))
    (=
      (istmts
        (S^ 84 fl)
        65536
        (inline isha_ext_body)
        (list acc u sp x3 x4 x5 x6 x7 p2 wp n t)
        m)
      (Some
        (INorm
          (list 0 0 0 x3 x4 x5 x6 x7 0 (+ wp 4) (- n 1) 0)
          (wput m wp (sched_w m wp))))))
  (chain
    (steps ((compute lhs (stop istmts))))
    (steps ((rewrite (lemma ish_ext_ph_ptr) lr lhs true ())))
    (have hc1lo (= (le 0 (- wp 64)) True) (by arith (list 1 1 0 0 0)))
    (have hc1hi (= (lt (- wp 64) 4294967296) True)
      (by arith (list 1 0 1 0 0 0)))
    (have hc1 (= (mod (- wp 64) 4294967296) (- wp 64))
      (rewrite-with
        (lemma ish_mid32)
        lr
        lhs
        ((inst x (- wp 64)))
        ((steps ((rewrite (premise hc1lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hc1hi) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hc1) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_lda)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo64)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi64)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (have hf1 (= (+ (- wp 64) 4) (- wp 60)) (by arith (list)))
    (steps ((rewrite (premise hf1) lr lhs true ())))
    (rewrite-with
      (lemma ish_ext_ph_ldt)
      lr
      lhs
      ()
      ((rewrite-with
         (lemma ish_xlo60)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl))
         refl)
       (rewrite-with
         (lemma ish_xhi60)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((rewrite (lemma ish_ext_ph_sg0) lr lhs true ())))
    (have hc2lo (= (le 0 (+ (+ (- wp 60) 4) 28)) True)
      (by arith (list 1 1 0 0 0 0 0 0 0)))
    (have hc2hi (= (lt (+ (+ (- wp 60) 4) 28) 4294967296) True)
      (by arith (list 1 0 1 0 0 0 0 0 0 0)))
    (have hc2 (= (mod (+ (+ (- wp 60) 4) 28) 4294967296) (+ (+ (- wp 60) 4) 28))
      (rewrite-with
        (lemma ish_mid32)
        lr
        lhs
        ((inst x (+ (+ (- wp 60) 4) 28)))
        ((steps ((rewrite (premise hc2lo) lr lhs true ())) refl)
