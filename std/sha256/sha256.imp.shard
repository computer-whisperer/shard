;;; std/sha256/sha256.imp.shard — the module's IMP DIALECT SIBLING
;;; (docs/IMP.md rung I2b): the sha word kit. This file is std/sha256
;;; growing an imp spelling — the manual spelling target the dialect
;;; exists for — and it lives IN the module directory because the
;;; alignment claims speak about the impl's PRIVATE word fns
;;; (rotr32/sha_ch/…), which the public surface deliberately does not
;;; expose (the .wasm.shard/.x86.shard sibling convention).
;;;
;;; The kit: IExp BUILDERS, one per spec word fn, parametric over the
;;; source LOCAL INDEX — the vocabulary the round twin (rung I2c)
;;; composes its statements from — plus per-fn ALIGNMENT PINS proving
;;; each builder's iexp value IS the spec fn's value. The pins are
;;; nearly refl-grade by design: IRotr's band-spelled containment is
;;; the spec's own m32 idiom, so both sides compute to the same
;;; shift-or-shift-under-mask tree. Any spelling drift between the
;;; builders and the spec fails HERE, not deep inside the round
;;; induction.
;;;
;;; V2 (the typed machine, IMP.md 2a): the twin is spelled at
;;; crystallized scalar kinds — every op node carries U32, loads are
;;; explicit (IExt U8 U32 (ILoad …)), stores go through (ITrunc U32 U8
;;; …) (the ITrunc IS the byte mask), and the explicit m32 mask
;;; statements DISSOLVE because every arithmetic op wraps to its kind.
;;; The seam this opens — the machine wraps via mod while the spec
;;; masks via band, at every add instead of only where FIPS masks —
;;; is paid by the v2 conversion kit below: the band/mod bridge
;;; (ish_mm32 through pow2 32), euclidean congruences that flatten
;;; nested wraps (ish_madd_l/r), the in-band collapse (ish_mid32) for
;;; pointers/counters/Horner words, and per-shape sum conversions
;;; (ish_t1c/ish_t2c/ish_e2c/ish_swc) that land the machine's wrapped
;;; sums on the spec's masked trees. Bitwise trees (rotations, sigmas,
;;; Ch/Maj) compute identically to v1 — the band-spelling thesis
;;; survives the re-typing untouched. The continuation-phase machinery
;;; carries over verbatim (fuel/spine structure is width-free); the
;;; four bodies are pinned WELL-KINDED (ish_wk_*) in the 12-slot U32
;;; frame, so the rebuilt impgen's structural walk consumes them
;;; directly.

(import "../../kernel/stdlib.shard")
(import "../../kernel/facts.shard")
(use (:: kernel facts *))
(import "../nat.shard")
(use (:: std nat *))
(import "sha256.shard")
(use (:: std sha256 sha256 *))
(import "../mem")
(use (:: std mem *))
(import "../bits")
(use (:: std bits *))
(import "../../models/imp/imp.shard")
(use (:: models imp imp *))
(import "../../models/wasm/loopkit.shard")
(use (:: models wasm loopkit *))

;; ---- the builders ---------------------------------------------------------------

;; rotate-right of a local within 32 bits
(fn ie_rotr32 ((i Int) (k Int)) IExp (IRotr U32 (ILoc i) (IConst k)))

;; Ch(x,y,z) = (x AND y) XOR (NOT x AND z); NOT is xor with all-ones
(fn ie_ch ((x Int) (y Int) (z Int)) IExp
  (IBin
    U32
    IXor
    (IBin U32 IAnd (ILoc x) (ILoc y))
    (IBin U32 IAnd (IBin U32 IXor (ILoc x) (IConst 4294967295)) (ILoc z))))

;; Maj(x,y,z) = (x AND y) XOR (x AND z) XOR (y AND z)
(fn ie_maj ((x Int) (y Int) (z Int)) IExp
  (IBin
    U32
    IXor
    (IBin U32 IAnd (ILoc x) (ILoc y))
    (IBin
      U32
      IXor
      (IBin U32 IAnd (ILoc x) (ILoc z))
      (IBin U32 IAnd (ILoc y) (ILoc z)))))

;; Σ0(x) = ROTR2 XOR ROTR13 XOR ROTR22
(fn ie_bsig0 ((i Int)) IExp
  (IBin
    U32
    IXor
    (ie_rotr32 i 2)
    (IBin U32 IXor (ie_rotr32 i 13) (ie_rotr32 i 22))))

;; Σ1(x) = ROTR6 XOR ROTR11 XOR ROTR25
(fn ie_bsig1 ((i Int)) IExp
  (IBin
    U32
    IXor
    (ie_rotr32 i 6)
    (IBin U32 IXor (ie_rotr32 i 11) (ie_rotr32 i 25))))

;; σ0(x) = ROTR7 XOR ROTR18 XOR SHR3
(fn ie_ssig0 ((i Int)) IExp
  (IBin
    U32
    IXor
    (ie_rotr32 i 7)
    (IBin U32 IXor (ie_rotr32 i 18) (IBin U32 IShr (ILoc i) (IConst 3)))))

;; σ1(x) = ROTR17 XOR ROTR19 XOR SHR10
(fn ie_ssig1 ((i Int)) IExp
  (IBin
    U32
    IXor
    (ie_rotr32 i 17)
    (IBin U32 IXor (ie_rotr32 i 19) (IBin U32 IShr (ILoc i) (IConst 10)))))

;; ---- the alignment pins ----------------------------------------------------------
;; Each builder's iexp value = the spec fn's value, for locals holding
;; the inputs. Memory is quantified and untouched (pure word ops).

(claim ie_rotr32_ok
  (goal ((x Int) (k Int) (m Mem)) ()
    (= (iexp (ie_rotr32 0 7) (Cons x Nil) m 0) (Some (rotr32 x 7))))
  (steps ((compute both)) refl))

(claim ie_ch_ok
  (goal ((x Int) (y Int) (z Int) (m Mem)) ()
    (=
      (iexp (ie_ch 0 1 2) (Cons x (Cons y (Cons z Nil))) m 0)
      (Some (sha_ch x y z))))
  (steps ((compute both)) refl))

(claim ie_maj_ok
  (goal ((x Int) (y Int) (z Int) (m Mem)) ()
    (=
      (iexp (ie_maj 0 1 2) (Cons x (Cons y (Cons z Nil))) m 0)
      (Some (sha_maj x y z))))
  (steps ((compute both)) refl))

(claim ie_bsig0_ok
  (goal ((x Int) (m Mem)) ()
    (= (iexp (ie_bsig0 0) (Cons x Nil) m 0) (Some (bsig0 x))))
  (steps ((compute both)) refl))

(claim ie_bsig1_ok
  (goal ((x Int) (m Mem)) ()
    (= (iexp (ie_bsig1 0) (Cons x Nil) m 0) (Some (bsig1 x))))
  (steps ((compute both)) refl))

(claim ie_ssig0_ok
  (goal ((x Int) (m Mem)) ()
    (= (iexp (ie_ssig0 0) (Cons x Nil) m 0) (Some (ssig0 x))))
  (steps ((compute both)) refl))

(claim ie_ssig1_ok
  (goal ((x Int) (m Mem)) ()
    (= (iexp (ie_ssig1 0) (Cons x Nil) m 0) (Some (ssig1 x))))
  (steps ((compute both)) refl))

;; ==== the v2 conversion kit =====================================================
;;
;; The typed machine (imp v2, IMP.md 2a) WRAPS every arithmetic op to
;; its kind -- (mod _ 2^32) at U32 -- while the spec masks via band
;; (m32) only where FIPS masks. These lemmas are the seam: the band/mod
;; bridge at the 32-bit mask (through pow2 32 as a literal), the
;; euclidean congruences that FLATTEN the machine's nested wraps, the
;; in-band collapse, and the pointer/counter collapse shapes the pass
;; walks need. Bitwise trees (rotations, sigmas, Ch/Maj) need none of
;; this: band-closed ops compute the very same trees as v1.

;; pow2 32 spelled as the literal (pow2 is opaque outside std/bits --
;; the defining equations unroll it one doubling per rung)
(claim ish_pow32
  (goal () () (= (pow2 32) 4294967296))
  (chain
    (have h32 (= (pow2 32) (pow2 (+ 31 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h32) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 31))
      ((steps ((compute lhs)) refl)))
    (have h31 (= (pow2 31) (pow2 (+ 30 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h31) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 30))
      ((steps ((compute lhs)) refl)))
    (have h30 (= (pow2 30) (pow2 (+ 29 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h30) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 29))
      ((steps ((compute lhs)) refl)))
    (have h29 (= (pow2 29) (pow2 (+ 28 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h29) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 28))
      ((steps ((compute lhs)) refl)))
    (have h28 (= (pow2 28) (pow2 (+ 27 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h28) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 27))
      ((steps ((compute lhs)) refl)))
    (have h27 (= (pow2 27) (pow2 (+ 26 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h27) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 26))
      ((steps ((compute lhs)) refl)))
    (have h26 (= (pow2 26) (pow2 (+ 25 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h26) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 25))
      ((steps ((compute lhs)) refl)))
    (have h25 (= (pow2 25) (pow2 (+ 24 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h25) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 24))
      ((steps ((compute lhs)) refl)))
    (have h24 (= (pow2 24) (pow2 (+ 23 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h24) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 23))
      ((steps ((compute lhs)) refl)))
    (have h23 (= (pow2 23) (pow2 (+ 22 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h23) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 22))
      ((steps ((compute lhs)) refl)))
    (have h22 (= (pow2 22) (pow2 (+ 21 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h22) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 21))
      ((steps ((compute lhs)) refl)))
    (have h21 (= (pow2 21) (pow2 (+ 20 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h21) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 20))
      ((steps ((compute lhs)) refl)))
    (have h20 (= (pow2 20) (pow2 (+ 19 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h20) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 19))
      ((steps ((compute lhs)) refl)))
    (have h19 (= (pow2 19) (pow2 (+ 18 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h19) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
      lhs
      ((inst k 18))
      ((steps ((compute lhs)) refl)))
    (have h18 (= (pow2 18) (pow2 (+ 17 1))) (steps ((compute both)) refl))
    (steps ((rewrite (premise h18) lr lhs true ())))
    (rewrite-with
      (lemma pow2_s)
      lr
