       (chain
         (steps ((rewrite (lemma sched_mem_s) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_w4shift_b)
              lr
              lhs
              ((inst c2 k2))
              ((steps ((rewrite (premise 0) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
