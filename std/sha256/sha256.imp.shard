;; ---- one-step unfolding lemmas ----------------------------------------------------
;; The worker's alignment steps the goal side down by citing these
;; with the all-occurrence rewrite form — the kit fns themselves stay
;; in every stop set (a computed unfold of a stuck match would bury
;; the folded spelling the IH speaks).

(claim wlist_s
  (goal ((m Mem) (p Int) (k Nat)) ()
    (= (wlist m p (S k)) (Cons (wget m p) (wlist m (+ p 4) k))))
  (steps ((unfold wlist lhs) (reduce lhs)) refl))

(claim sha_rounds_s
  (goal ((st H8) (kw Int) (kt (List Int)) (ww Int) (wt (List Int))) ()
    (=
      (sha_rounds st (Cons kw kt) (Cons ww wt))
      (sha_rounds (sha_round st kw ww) kt wt)))
  (steps ((unfold sha_rounds lhs) (reduce lhs)) refl))

(claim lg_advk_s
  (goal ((x Int) (s Int) (k Nat)) ()
    (= (lg_advk x s (S k)) (lg_advk (+ x s) s k)))
  (steps ((unfold lg_advk lhs) (reduce lhs)) refl))

(claim rt_last_s
  (goal ((t0 Int) (r H8) (k Nat)) () (= (rt_last t0 r (S k)) (h8a r)))
  (steps ((unfold rt_last lhs) (reduce lhs)) refl))

;; ---- I2e-2, the rounds range kit ---------------------------------------------------
;; The finish crossing (the machine's mod-spelled feed-forward sums =
;; the spec's band-spelled h8_add) needs the rounds output
;; componentwise nonnegative. slo = elementwise-nonneg over a word
;; list (the K and W windows); h8_los = the eight component
;; nonnegativity flags as a LIST (list equations extract by
;; projection — no Bool-chain inversion). Preservation walks
;; sha_rounds citing ish_ra_lo/ish_re_lo for the two fresh slots; the
;; other six are copies.

(fn slo ((xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil True)
    ((Cons h t) (if (le 0 h) (slo t) False))))

(fn h8_los ((st H8)) (List Bool)
  (match st
    ((mk_h8 a b c d e f g h)
     (list
       (le 0 a)
       (le 0 b)
       (le 0 c)
       (le 0 d)
       (le 0 e)
       (le 0 f)
       (le 0 g)
       (le 0 h)))))

(fn blnth ((n Int) (xs (List Bool))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (le n 0) h (blnth (- n 1) t)))))

;; the slo inversion pair (proven once, cited at every list step)
(claim ish_slo_hd
  (goal ((h Int) (t (List Int))) ((= (slo (Cons h t)) True)) (= (le 0 h) True))
  (case-on (le 0 h) Bool
    ((case True (steps ((rewrite (hyp 0) lr lhs true ())) refl))
     (case False
       (chain
         (have hf (= (slo (Cons h t)) False)
           (steps
             ((unfold slo lhs)
              (reduce lhs)
              (rewrite (hyp 0) lr lhs true ())
              (reduce lhs))
             refl))
         (have hx (= False True)
           (steps
             ((rewrite (premise hf) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (absurd (premise hx)))))))

(claim ish_slo_tl
  (goal ((h Int) (t (List Int))) ((= (slo (Cons h t)) True)) (= (slo t) True))
  (case-on (le 0 h) Bool
    ((case True
       (chain
         (have hc (= (slo (Cons h t)) (slo t))
           (steps
             ((unfold slo lhs)
              (reduce lhs)
              (rewrite (hyp 0) lr lhs true ())
              (reduce lhs))
             refl))
         (steps
           ((rewrite (premise hc) rl lhs true ())
            (rewrite (premise 0) lr lhs true ())))
         refl))
     (case False
       (chain
         (have hf (= (slo (Cons h t)) False)
           (steps
             ((unfold slo lhs)
              (reduce lhs)
              (rewrite (hyp 0) lr lhs true ())
              (reduce lhs))
             refl))
         (have hx (= False True)
           (steps
             ((rewrite (premise hf) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (absurd (premise hx)))))))

;; every word window is elementwise nonnegative (mask-on-read)
(claim ish_slo_wlist
  (goal ((m Mem) (p Int) (k Nat)) () (= (slo (wlist m p k)) True))
  (induct k
    ((case Z (steps ((compute lhs)) refl))
     (case S
       (k2)
       (chain
         (steps
           ((rewrite (lemma wlist_s) lr lhs true ())
            (unfold slo lhs)
            (reduce lhs)))
         (rewrite-with (lemma ish_wget_range_lo) lr lhs () ())
         (steps ((reduce lhs)))
         (rewrite-with (hyp 0) lr lhs () ())
         refl)))))

;; the round constants are elementwise nonnegative (ground walk)
(claim ish_slo_shak
