;; sha256.xconv.shard — Arc A3 rung (d): the conversion-dialect leg of the
;; generated x86 chain, on the SAME objects A2 rung (d) measured
;; (sha256.xpatch.shard).  Two exercises:
;;
;;   xcv_seg8 — the segment step (xs8_i's 8 generated statements) stated at
;;   a NAMED DIRECT-STATE boundary (xcw8_lc / xcw8_m over the xv value
;;   ladder), proven by stepping the evaluator with `change` folding every
;;   produced value to its ladder name as it appears — the goal text stays
;;   folded, no per-statement iexp haves restating a growing state.
;;   The stop set on each fold IS the sharing structure: NF(xvK) under
;;   (stop xv<K) spells the telescoped value at the FOLDED sub-names.
;;
;;   xcv_b12 — cmp_x_shblock_b12's seam statement with the segment result
;;   carried as a premise at twelve ∀-bound slot values (no exposure mints
;;   them, no view reads spell them), closed by ONE `exact-conv` citation
;;   of cmp_x_shblock_b13 — the residual spelling drift (register-rebuild
;;   nest, fuel forms) crosses definitionally instead of via bridge haves.

(import "../../kernel/stdlib.shard")
(import "sha256.imp.shard")
(import "../../models/imp/imp.shard")
(import "../../models/x86/x86.shard")
(import "../../models/imp/to_x86.shard")
(import "../../std/nat.shard")
(import "../../std/mem")
(import "../../models/wasm/loopkit.shard")
(import "../../models/x86/loopkit.shard")
(import "../../kernel/facts.shard")
(import "impgen_x86_out.shard")
(import "sha256.xpatch.shard")
(use (:: std sha256 sha256.imp *))
(use (:: models imp imp *))
(use (:: models x86 x86 *))
(use (:: models imp to_x86 *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: models wasm loopkit *))
(use (:: models x86 loopkit *))
(use (:: kernel facts *))
(use (:: std sha256 impgen_x86_out *))
(use (:: std sha256 sha256.xpatch *))

;; local verbatim copy of xs8_i ((inline F) resolves same-file only)
(fn xcs8_i () (List IStmt)
  (list
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (ILoc 6)))
    (ISet 9 (IBin U32 ISub (ILoc 8) (IConst 1)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))))

;; THE NAMED BOUNDARY: the post-segment state as direct-state fns over the
;; xv ladder (imported from sha256.xpatch — the same names both dialects
;; measure).  Spelled ONCE; every other site says the name.
(fn xcw8_lc
  ((l0 Int)
   (l1 Int)
   (l2 Int)
   (l3 Int)
   (l4 Int)
   (l5 Int)
   (l6 Int)
   (l7 Int)
   (l8 Int)
   (l9 Int)
   (l10 Int)
   (l11 Int)
   (m Mem))
  (List Int)
  (list
    l0
    l1
    l2
    l3
    l4
    l5
    l6
    l7
    (xv5 l6 l8 l11 m)
    (xv7 l6 l8 l11 m)
    l10
    (xv6 l6 l8 l11 m)))

(fn xcw8_m ((l6 Int) (l8 Int) (l11 Int) (m Mem)) Mem
  (mem_set m (xv7 l6 l8 l11 m) (xv8 l6 l8 l11 m)))

;; THE SEGMENT COLLAPSE at the named boundary: same statement family as
;; xxd_seg8 (same stmts, same premises), conclusion in direct state form.
(claim xcv_seg8
  (goal
    ((l0 Int)
     (l1 Int)
     (l2 Int)
     (l3 Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l10 Int)
     (l11 Int)
     (m Mem)
     (g Nat))
    ((= (le 0 l8) True) (= (lt (+ l8 2) 65536) True))
    (=
      (istmts
        (S^ 8 (S g))
        65536
        (inline xcs8_i)
        (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11)
        m)
      (Some
        (INorm
          (xcw8_lc l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11 m)
          (xcw8_m l6 l8 l11 m)))))
  (chain
    ;; the arithmetic block: ground the guard addresses (xv2, xv7) via the
    ;; U32-band collapse (xxg_m32, imported) and derive their bounds from
    ;; the two root premises.  Same facts as xxd_seg8's block.
    (have h0 (= (le 0 l8) True)
      (steps ((rewrite (premise 0) lr lhs true ())) refl))
    (have h1 (= (lt (+ l8 2) 65536) True)
      (steps ((rewrite (premise 1) lr lhs true ())) refl))
    (have hlt8 (= (lt l8 65536) True)
      (steps () (by arith (rows (goal 1) (h1 1)))))
    (have hc2 (= (xv2 l6 l8 l11 m) (+ l8 1))
      (chain
        (steps ((unfold xv2 lhs)))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have ha2a (= (le 0 (xv2 l6 l8 l11 m)) True)
      (steps
        ((rewrite (premise hc2) lr lhs true ()))
        (by arith (rows (goal 1) (h0 1)))))
    (have ha2b (= (lt (xv2 l6 l8 l11 m) 65536) True)
      (steps
        ((rewrite (premise hc2) lr lhs true ()))
        (by arith (rows (goal 1) (h1 1)))))
    (have hc5 (= (xv5 l6 l8 l11 m) (+ (+ l8 1) 1))
      (chain
        (steps ((unfold xv5 lhs) (rewrite (premise hc2) lr lhs true ())))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have hc7 (= (xv7 l6 l8 l11 m) (- (+ (+ l8 1) 1) 1))
      (chain
        (steps ((unfold xv7 lhs) (rewrite (premise hc5) lr lhs true ())))
        (rewrite-with
          (lemma xxg_m32)
          lr
          lhs
          ()
          ((by arith (rows (goal 1) (h0 1))) (by arith (rows (goal 1) (h1 1)))))
        refl))
    (have ha7a (= (le 0 (xv7 l6 l8 l11 m)) True)
      (steps
        ((rewrite (premise hc7) lr lhs true ()))
        (by arith (rows (goal 1) (h0 1)))))
    (have ha7b (= (lt (xv7 l6 l8 l11 m) 65536) True)
      (steps
        ((rewrite (premise hc7) lr lhs true ()))
        (by arith (rows (goal 1) (h1 1)))))
    ;; the walk: compute to each guard, discharge it, fold the address to
    ;; its ladder name — the values themselves stay spelled in intermediate
    ;; sequents and fold ONCE at the end (late folds; NF matches inline).
    (steps
      ((compute lhs (stop xv1 xv2 xv3 xv4 xv5 xv6 xv7 xv8))
       (rewrite (premise h0) lr lhs true ())
       (rewrite (premise hlt8) lr lhs true ())
       (compute lhs (stop xv1 xv2 xv3 xv4 xv5 xv6 xv7 xv8))
       (change lhs true (xv2 l6 l8 l11 m))
       (rewrite (premise ha2a) lr lhs true ())
       (rewrite (premise ha2b) lr lhs true ())
       (compute lhs (stop xv1 xv2 xv3 xv4 xv5 xv6 xv7 xv8))
       (change lhs true (xv7 l6 l8 l11 m) (stop xv2))
       (rewrite (premise ha7a) lr lhs true ())
       (rewrite (premise ha7b) lr lhs true ())
       (compute lhs (stop xv1 xv2 xv3 xv4 xv5 xv6 xv7 xv8))
       (change lhs true (xv8 l6 l8 l11 m) (stop xv2))
       (change lhs true (xv6 l6 l8 l11 m) (stop xv2))
       (change lhs true (xv5 l6 l8 l11 m) (stop xv2))
       (change
         lhs
         true
         (xcw8_lc l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11 m)
         (stop xv5 xv6 xv7))
       (change lhs true (xcw8_m l6 l8 l11 m) (stop xv7 xv8)))
      refl)))

;; local verbatim copy of gb_shblock_c12_i for the seam's (inline …) sites
(fn xcv_c12_i () (List IStmt)
  (list
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (ILoc 6)))
    (ISet 9 (IBin U32 ISub (ILoc 8) (IConst 1)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 9 (IBin U32 ISub (ILoc 9) (IConst 1)))
    (ISet 11 (IBin U32 IShr (ILoc 11) (IConst 8)))
    (IStore (ILoc 9) (ITrunc U32 U8 (ILoc 11)))
    (ISet 11 (IExt U8 U32 (ILoad (ILoc 8))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))
    (ISet 8 (IBin U32 IAdd (ILoc 8) (IConst 1)))
    (ISet 11 (IBin U32 IMul (ILoc 11) (IConst 256)))
    (ISet 11 (IBin U32 IAdd (ILoc 11) (IExt U8 U32 (ILoad (ILoc 8)))))))

;; --- THE SEAM, conversion-dialect: cmp_x_shblock_b12's statement with the
;; segment result carried as a premise at twelve ∀-bound slot values — no
;; 12-deep exposure mints them (replay), no view reads spell them (patch).
;; The suffix citation closes by ONE exact-conv: the register-rebuild nest
;; and fuel forms cross to cmp_b13's spelling definitionally.
(claim xcv_b12
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (x3 Int)
     (x4 Int)
     (x5 Int)
     (x6 Int)
     (x7 Int)
     (x8 Int)
     (x9 Int)
     (x10 Int)
     (x11 Int)
     (za Int)
     (zb Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc))
     (y0 Int)
     (y1 Int)
     (y2 Int)
     (y3 Int)
     (y4 Int)
     (y5 Int)
     (y6 Int)
     (y7 Int)
     (y8 Int)
     (y9 Int)
     (y10 Int)
     (y11 Int)
     (m2 Mem))
    ((=
       (istmts
         (S^ 24 (S c2))
         65536
         (inline xcv_c12_i)
         (list x0 x1 x2 x3 x4 x5 x6 x7 x8 x9 x10 x11)
         m)
       (Some (INorm (list y0 y1 y2 y3 y4 y5 y6 y7 y8 y9 y10 y11) m2))))
    (=
      (xeval_seq
        (S^ 76 c)
        (MkXModule restfs 0 65536)
        (gb_shblock_r12_x)
        (MkRegs za x3 x2 x6 x7 x1 x0 x4 x5 zb 0 x8 x9 x10 x11)
        m)
      (ix_sout
        (istmts
          (S^ 52 c2)
          65536
          (gb_shblock_r12_i)
          (list x0 x1 x2 x3 x4 x5 x6 x7 x8 x9 x10 x11)
          m))))
  (chain
    (have hsp
      (= (gb_shblock_r12_i) (isapp (inline xcv_c12_i) (gb_shblock_r13_i)))
      (steps ((compute both)) refl))
    (have hfg (= (S^ 52 c2) (lg_fuel (istn (inline xcv_c12_i)) (S (S^ 27 c2))))
      (steps ((compute both)) refl))
    (steps
      ((unfold gb_shblock_r12_x lhs)
       (rewrite (premise hsp) lr rhs true ())
       (rewrite (premise hfg) lr rhs true ())))
    (rewrite-with
      (lemma ist_seam)
      lr
      rhs
      ((inst g c2))
      ((steps ((compute lhs)) refl)))
    (have hfb (= (lg_fuel (istn (inline xcv_c12_i)) (S c2)) (S^ 24 (S c2)))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hfb) lr rhs true ())
       (rewrite (premise 0) lr rhs true ())
       (unfold ist_cont rhs)
       (reduce rhs)))
    (rewrite-with (lemma sqs_x_shblock_c12) lr lhs ((inst g c2)) ())
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (compute
         lhs
         (stop xeval_seq gb_shblock_r13_x istmts gb_shblock_r13_i ix_sout))))
    (exact-conv
      (lemma cmp_x_shblock_b13)
      ((inst x0 y0)
       (inst x1 y1)
       (inst x2 y2)
       (inst x3 y3)
       (inst x4 y4)
       (inst x5 y5)
       (inst x6 y6)
       (inst x7 y7)
       (inst x8 y8)
       (inst x9 y9)
       (inst x10 y10)
       (inst x11 y11)
       (inst za 0)
       (inst zb zb)
       (inst m m2)
       (inst c c)
       (inst c2 c2)
       (inst restfs restfs))
      ()
      (stop xeval_seq istmts gb_shblock_r13_x gb_shblock_r13_i ix_sout))))
