;;; std/str/mod.build.shard — std/str's BUILD ENTRY under the
;;; re-founded charter (docs/BUILD.md §4/§5, rung 2): content only —
;;; two pinned modules ("stdstr" = the copy piece, "stdstreq" = the
;;; comparison piece; leaf certs pin their fn at slot 0), each with
;;; its spec-side encoded bytes, its claim binding, and curated
;;; MEMCASE vectors whose expected value AND memory readback are
;;; computed SPEC-SIDE (the source fn applied directly). ARTIFACT
;;; bindings, plan assembly, and wire are DERIVED (tools/lowbuild
;;; pinlib); the manifest gate verifies the derived index bindings
;;; against the cert file read raw. The consumer-facing contracts
;;; over these artifacts are str.rep.shard's lowered_str_copy /
;;; lowered_str_eq (the aggregate rep certs), corpus-gated as their
;;; own 'check product.
;;;
;;;     (fn build_mods ((t Target)) (List PinMod))   — the standard symbol
;;;
;;; RUN IT:
;;;   bin/shard_eval run tools/lowbuild/lowbuild.shard pinlib std/str/mod.build.shard

(import "../../kernel/stdlib.shard")
(import "str.lowsrc.shard")
(use (:: std str str.lowsrc *))
(import "str.wasm.shard")
(use (:: std str str.wasm sc_copy_func))
(use (:: std str str.wasm sc_eq_func))
(import "../../std/mem")
(use (:: std mem *))
(import "../../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../../models/wasm/encode.shard")
(use (:: models wasm encode *))
(import "../../meta/plan")
(use (:: meta plan *))
(import "../../meta/build")
(use (:: meta build *))

;; --- the binary: [self] (leaf piece, no callee prefix) ---------------------------

(fn smod ((self Func) (limit Int)) WModule (MkWModule (list self) limit))

;; --- spec-side memory helpers ---------------------------------------------------

(fn mload ((bs (List Int)) (a Int) (m Mem)) Mem
  (measure (struct bs))
  (match bs
    (Nil m)
    ((Cons b t) (mload t (+ a 1) (mem_set m a b)))))

(fn mdump ((a Int) (n Nat) (m Mem)) (List Int)
  (measure (struct n))
  (match n
    (Z Nil)
    ((S k) (Cons (mem_get m a) (mdump (+ a 1) k m)))))

(fn len_nat ((xs (List Int))) Nat
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ t) (S (len_nat t)))))

;; a memory vector: expected value + final-memory readback, both SPEC-side
(fn vec ((args (List Int)) (membytes (List Int)) (v Int) (mf Mem)) PVec
  (PV 0 args membytes v (mdump 0 (len_nat membytes) mf)))

(fn ld ((bs (List Int))) Mem (mload bs 0 (mem_empty)))

;; --- the build entry: content only ------------------------------------------------

(fn build_mods ((t Target)) (List PinMod)
  (match (mem_limit_of t)
    (lim
      (list
        (MkPinMod
          "stdstr"
          (enc_module (smod (sc_copy_func) lim))
          "std/str/str.wasm.shard"
          (list "lowered_sc_copy")
          (list
            (vec
              (list 0 3 3)
              (list 72 105 33 0 0 0)
              0
              (sc_copy (ld (list 72 105 33 0 0 0)) 0 3 (fnat 3)))
            (vec
              (list 0 1 3)
              (list 8 9 10 11)
              0
              (sc_copy (ld (list 8 9 10 11)) 0 1 (fnat 3)))
            (vec
              (list 5 2 0)
              (list 1 2 3)
              0
              (sc_copy (ld (list 1 2 3)) 5 2 (fnat 0)))))
        (MkPinMod
          "stdstreq"
          (enc_module (smod (sc_eq_func) lim))
          "std/str/str.wasm.shard"
          (list "lowered_sc_eq")
          (list
            (vec
              (list 0 3 3)
              (list 72 105 33 72 105 33)
              (sc_eq (ld (list 72 105 33 72 105 33)) 0 3 (fnat 3))
              (ld (list 72 105 33 72 105 33)))
            (vec
              (list 0 3 3)
              (list 72 105 33 72 106 33)
              (sc_eq (ld (list 72 105 33 72 106 33)) 0 3 (fnat 3))
              (ld (list 72 105 33 72 106 33)))
            (vec
              (list 1 4 0)
              (list 9 9 9 9 9)
              (sc_eq (ld (list 9 9 9 9 9)) 1 4 (fnat 0))
              (ld (list 9 9 9 9 9)))))))))
