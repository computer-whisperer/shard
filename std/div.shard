;;; std/div — back-compat shim.
;;;
;;; `div` is now a directory-module: `std/div/` holds the interface
;;; `mod.req.shard` (public: the 3 trusted /-and-mod axioms + the derived
;;; div_lt/div_nonneg lemmas) and `div.shard` (private: div_lt_aux/
;;; div_nonneg_aux). This file preserves the old import path `std/div.shard`
;;; by forwarding to the module directory, so existing importers
;;; (examples/wf_induct_demo, examples/calc) keep working unchanged.
(import "div")
