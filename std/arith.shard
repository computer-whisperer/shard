;;; std/arith — back-compat shim.
;;;
;;; `arith` is now a directory-module: `std/arith/` holds the interface
;;; `mod.req.shard` (the public lia index-identity lemmas) and `arith.shard`
;;; (the `fulfills` proofs). This file preserves the old import path
;;; `std/arith.shard` by forwarding to the module directory, so existing
;;; importers (std/mem) keep working unchanged.
(import "arith")
