;;; std/f32/f32.shard — the f32 surface module's implementation (rung R3a,
;;; docs/FLOATS.md §3a).
;;;
;;; F32 = (refine FVal f32_ok): the core value view refined by the shape
;;; gate at the ground descriptor. Every op is a ONE-LINE defining equation
;;; over the core model; the refine obligations are one wf-closure cite
;;; each (std/float/mod.req/wf.shard). Definitions and proofs live ONCE in
;;; the core — this file is adapters + instantiated lemmas (the Word-residue
;;; accounting, §3a).

(import "../../kernel/stdlib.shard")
(import "../float/mod.req/float.shard")  ; the L1 model
(import "../float/mod.req/kit.shard")  ; fneg_wf
(import "../float/mod.req/pack.shard")  ; fpack/funpack
(import "../float/mod.req/wf.shard")  ; the wf-closure + roundtrip theorems
(import "../float/mod.req/dec.shard")  ; fdec + fdec_wf — the decimal-literal door
(import "../float/mod.req/hex.shard")  ; fhex — the hex-exact observer
(import "mod.req.shard")  ; our interface — opaque F32 + sig fns + obligations
(use (:: std float float *))
(use (:: std float kit fneg_wf))
(use (:: std float pack *))
(use (:: std float wf *))
(use (:: std float dec *))
(use (:: std float hex *))
(use (:: std f32 *))  ; impl-proof: rebind the opaque type + sig fns to our defs

;; --- the type -------------------------------------------------------------------

;; the refinement predicate: well-formed at the ground binary32 descriptor.
(fn f32_ok ((v FVal)) Bool (fwf (fmt_f32) v))

;; THE type: every inhabitant is a well-formed binary32 view.
(type F32 (refine FVal f32_ok))

;; --- observers ------------------------------------------------------------------

(fn f32_view ((x F32)) FVal (refine_val x))

(fn f32_to_bits ((x F32)) Int (fpack (fmt_f32) (refine_val x)))

(fn f32_le ((x F32) (y F32)) Bool
  (fle_val (fmt_f32) (refine_val x) (refine_val y)))

(fn f32_lt ((x F32) (y F32)) Bool
  (if (f32_le x y) (if (f32_le y x) False True) False))

(fn f32_eq ((x F32) (y F32)) Bool (if (f32_le x y) (f32_le y x) False))

(fn f32_is_nan ((x F32)) Bool (fval_eqb (refine_val x) FNaN))

(fn f32_hex ((x F32)) (List Int) (fhex (fmt_f32) (refine_val x)))

;; --- constructors (each a refined return; obligations below) --------------------

(fn f32_from_bits ((b Int)) F32 (funpack (fmt_f32) b))

(fn f32_from_dec ((m Int) (e Int)) F32 (fdec (fmt_f32) m e))

(fn f32_nan () F32 FNaN)

(fn f32_inf () F32 (FInf False))

(fn f32_neg_inf () F32 (FInf True))

(fn f32_add ((x F32) (y F32)) F32
  (fadd (fmt_f32) (refine_val x) (refine_val y)))

(fn f32_sub ((x F32) (y F32)) F32
  (fsub (fmt_f32) (refine_val x) (refine_val y)))

(fn f32_mul ((x F32) (y F32)) F32
  (fmul (fmt_f32) (refine_val x) (refine_val y)))

(fn f32_div ((x F32) (y F32)) F32
  (fdiv (fmt_f32) (refine_val x) (refine_val y)))

(fn f32_neg ((x F32)) F32 (fneg (refine_val x)))

(fn f32_abs ((x F32)) F32 (fabs (refine_val x)))

;; --- the refined-return obligations ----------------------------------------------
;; (no chain sugar here — the rr path reads bare; continuations hand-nested)

(returns
  f32_from_bits
  (have hw (= (fwf (fmt_f32) (funpack (fmt_f32) b)) True)
    (rewrite-with (lemma funpack_wf_f32) lr lhs ((inst b b)) () refl)
    (steps
      ((unfold f32_from_bits lhs)
       (unfold f32_ok lhs)
       (simp lhs)
       (rewrite (premise 0) lr lhs true ()))
      refl)))

(returns
  f32_from_dec
  (have hw (= (fwf (fmt_f32) (fdec (fmt_f32) m e)) True)
    (rewrite-with
      (lemma fdec_wf)
      lr
      lhs
      ((inst f (fmt_f32)) (inst m m) (inst e e))
      ((steps ((compute lhs)) refl))
      refl)
    (steps
      ((unfold f32_from_dec lhs)
       (unfold f32_ok lhs)
       (simp lhs)
       (rewrite (premise 0) lr lhs true ()))
      refl)))

(returns
  f32_nan
  (steps ((unfold f32_nan lhs) (unfold f32_ok lhs) (compute lhs)) refl))

(returns
  f32_inf
  (steps ((unfold f32_inf lhs) (unfold f32_ok lhs) (compute lhs)) refl))

(returns
  f32_neg_inf
  (steps ((unfold f32_neg_inf lhs) (unfold f32_ok lhs) (compute lhs)) refl))

(returns
  f32_add
  (refine-fact
    F32
    x
    (refine-fact
      F32
      y
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps
          ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
          refl)
        (have hwy (= (fwf (fmt_f32) (refine_val y)) True)
          (steps
            ((rewrite (premise 1) rl rhs true ())
             (unfold f32_ok rhs)
             (simp rhs))
            refl)
          (have hres
            (=
              (fwf (fmt_f32) (fadd (fmt_f32) (refine_val x) (refine_val y)))
              True)
            (rewrite-with
              (lemma fadd_wf)
              lr
              lhs
              ((inst f (fmt_f32))
               (inst x (refine_val x))
               (inst y (refine_val y)))
              ((steps ((compute lhs)) refl)
               (steps ((compute lhs)) refl)
               (steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (premise 3) lr lhs true ())) refl))
              refl)
            (steps
              ((unfold f32_add lhs)
               (unfold f32_ok lhs)
               (simp lhs)
               (rewrite (premise 4) lr lhs true ()))
              refl)))))))

(returns
  f32_sub
  (refine-fact
    F32
    x
    (refine-fact
      F32
      y
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps
          ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
          refl)
        (have hwy (= (fwf (fmt_f32) (refine_val y)) True)
          (steps
            ((rewrite (premise 1) rl rhs true ())
             (unfold f32_ok rhs)
             (simp rhs))
            refl)
          (have hres
            (=
              (fwf (fmt_f32) (fsub (fmt_f32) (refine_val x) (refine_val y)))
              True)
            (rewrite-with
              (lemma fsub_wf)
              lr
              lhs
              ((inst f (fmt_f32))
               (inst x (refine_val x))
               (inst y (refine_val y)))
              ((steps ((compute lhs)) refl)
               (steps ((compute lhs)) refl)
               (steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (premise 3) lr lhs true ())) refl))
              refl)
            (steps
              ((unfold f32_sub lhs)
               (unfold f32_ok lhs)
               (simp lhs)
               (rewrite (premise 4) lr lhs true ()))
              refl)))))))

(returns
  f32_mul
  (refine-fact
    F32
    x
    (refine-fact
      F32
      y
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps
          ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
          refl)
        (have hwy (= (fwf (fmt_f32) (refine_val y)) True)
          (steps
            ((rewrite (premise 1) rl rhs true ())
             (unfold f32_ok rhs)
             (simp rhs))
            refl)
          (have hres
            (=
              (fwf (fmt_f32) (fmul (fmt_f32) (refine_val x) (refine_val y)))
              True)
            (rewrite-with
              (lemma fmul_wf)
              lr
              lhs
              ((inst f (fmt_f32))
               (inst x (refine_val x))
               (inst y (refine_val y)))
              ((steps ((compute lhs)) refl)
               (steps ((compute lhs)) refl)
               (steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (premise 3) lr lhs true ())) refl))
              refl)
            (steps
              ((unfold f32_mul lhs)
               (unfold f32_ok lhs)
               (simp lhs)
               (rewrite (premise 4) lr lhs true ()))
              refl)))))))

(returns
  f32_div
  (refine-fact
    F32
    x
    (refine-fact
      F32
      y
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps
          ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
          refl)
        (have hwy (= (fwf (fmt_f32) (refine_val y)) True)
          (steps
            ((rewrite (premise 1) rl rhs true ())
             (unfold f32_ok rhs)
             (simp rhs))
            refl)
          (have hres
            (=
              (fwf (fmt_f32) (fdiv (fmt_f32) (refine_val x) (refine_val y)))
              True)
            (rewrite-with
              (lemma fdiv_wf)
              lr
              lhs
              ((inst f (fmt_f32))
               (inst x (refine_val x))
               (inst y (refine_val y)))
              ((steps ((compute lhs)) refl)
               (steps ((compute lhs)) refl)
               (steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (premise 3) lr lhs true ())) refl))
              refl)
            (steps
              ((unfold f32_div lhs)
               (unfold f32_ok lhs)
               (simp lhs)
               (rewrite (premise 4) lr lhs true ()))
              refl)))))))

(returns
  f32_neg
  (refine-fact
    F32
    x
    (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
      (steps
        ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
        refl)
      (have hres (= (fwf (fmt_f32) (fneg (refine_val x))) True)
        (rewrite-with
          (lemma fneg_wf)
          lr
          lhs
          ((inst f (fmt_f32)) (inst x (refine_val x)))
          ((steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl)
        (steps
          ((unfold f32_neg lhs)
           (unfold f32_ok lhs)
           (simp lhs)
           (rewrite (premise 2) lr lhs true ()))
          refl)))))

(returns
  f32_abs
  (refine-fact
    F32
    x
    (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
      (steps
        ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs) (simp rhs))
        refl)
      (have hres (= (fwf (fmt_f32) (fabs (refine_val x))) True)
        (rewrite-with
          (lemma fabs_wf)
          lr
          lhs
          ((inst f (fmt_f32)) (inst x (refine_val x)))
          ((steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl)
        (steps
          ((unfold f32_abs lhs)
           (unfold f32_ok lhs)
           (simp lhs)
           (rewrite (premise 2) lr lhs true ()))
          refl)))))

;; --- discharge the interface's requirements --------------------------------------

(fulfills f32_wf
  (refine-fact
    F32
    x
    (steps ((unfold f32_view lhs) (rewrite (premise 0) lr lhs true ())) refl)))

(fulfills f32_ok_def (steps ((unfold f32_ok lhs)) refl))

(fulfills f32_add_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_add lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_sub_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_sub lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_mul_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_mul lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_div_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_div lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_neg_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_neg lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_abs_def
  (steps
    ((unfold f32_view lhs)
     (unfold f32_abs lhs)
     (simp lhs)
     (unfold f32_view rhs)
     (simp rhs))
    refl))

(fulfills f32_le_def
  (steps ((unfold f32_le lhs) (unfold f32_view rhs) (unfold f32_view rhs)) refl))

(fulfills f32_lt_def (steps ((unfold f32_lt lhs)) refl))

(fulfills f32_eq_def (steps ((unfold f32_eq lhs)) refl))

(fulfills f32_is_nan_def
  (steps ((unfold f32_is_nan lhs) (unfold f32_view rhs)) refl))

(fulfills f32_view_from_bits
  (steps
    ((unfold f32_view lhs) (unfold f32_from_bits lhs) (simp lhs) (simp rhs))
    refl))

(fulfills f32_to_bits_def
  (steps ((unfold f32_to_bits lhs) (unfold f32_view rhs)) refl))

(fulfills f32_from_dec_def
  (steps
    ((unfold f32_view lhs) (unfold f32_from_dec lhs) (simp lhs) (simp rhs))
    refl))

(fulfills f32_hex_def (steps ((unfold f32_hex lhs) (unfold f32_view rhs)) refl))

(fulfills f32_nan_def
  (steps ((unfold f32_view lhs) (unfold f32_nan lhs) (simp lhs)) refl))

(fulfills f32_inf_def
  (steps ((unfold f32_view lhs) (unfold f32_inf lhs) (simp lhs)) refl))

(fulfills f32_neg_inf_def
  (steps ((unfold f32_view lhs) (unfold f32_neg_inf lhs) (simp lhs)) refl))

(fulfills f32_bits_roundtrip
  (refine-fact
    F32
    x
    (chain
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs)) refl))
      (have hrt
        (= (funpack (fmt_f32) (fpack (fmt_f32) (refine_val x))) (refine_val x))
        (rewrite-with
          (lemma funpack_fpack_f32)
          lr
          lhs
          ((inst x (refine_val x)))
          ((steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl))
      (have hb1 (= (f32_to_bits x) (fpack (fmt_f32) (refine_val x)))
        (steps ((unfold f32_to_bits lhs)) refl))
      (steps
        ((unfold f32_view lhs)
         (unfold f32_from_bits lhs)
         (rewrite (premise 3) lr lhs true ())
         (rewrite (premise 2) lr lhs true ())
         (unfold f32_view rhs)
         (simp lhs)
         (simp rhs))
        refl))))

(fulfills f32_from_to_bits
  (chain
    (have hb
      (=
        (f32_to_bits (f32_from_bits b))
        (fpack (fmt_f32) (funpack (fmt_f32) b)))
      (steps
        ((unfold f32_to_bits lhs) (simp lhs) (unfold f32_from_bits lhs))
        refl))
    (have hn
      (= (f32_is_nan (f32_from_bits b)) (fval_eqb (funpack (fmt_f32) b) FNaN))
      (steps
        ((unfold f32_is_nan lhs) (simp lhs) (unfold f32_from_bits lhs))
        refl))
    (have hc
      (=
        (fpack (fmt_f32) (funpack (fmt_f32) b))
        (if (fval_eqb (funpack (fmt_f32) b) FNaN) 2143289344 b))
      (rewrite-with
        (lemma fpack_funpack_f32)
        lr
        lhs
        ((inst b b))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps
      ((rewrite (premise 2) lr lhs true ())
       (rewrite (premise 3) lr rhs true ())
       (rewrite (premise 4) lr lhs true ()))
      refl)))

(fulfills f32_to_bits_range
  (refine-fact
    F32
    x
    (chain
      (have hwx (= (fwf (fmt_f32) (refine_val x)) True)
        (steps ((rewrite (premise 0) rl rhs true ()) (unfold f32_ok rhs)) refl))
      (have hr
        (=
          (if (le 0 (fpack (fmt_f32) (refine_val x)))
            (lt (fpack (fmt_f32) (refine_val x)) 4294967296)
            False)
          True)
        (rewrite-with
          (lemma fpack_range_all_f32)
          lr
          lhs
          ((inst x (refine_val x)))
          ((steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl))
      (steps
        ((unfold f32_to_bits lhs)
         (unfold f32_to_bits lhs)
         (rewrite (premise 2) lr lhs true ()))
        refl))))

;; --- ground pins (host-IEEE-verified constants; compute with the impl) ----------

;; bits roundtrip on the classic 1.0f (0x3F800000).
(claim f32_pin_one_bits
  (goal () () (= (f32_to_bits (f32_from_bits 1065353216)) 1065353216))
  (steps ((compute both)) refl))

;; 1.0f + 1.0f = 2.0f (0x40000000).
(claim f32_pin_add_one_one
  (goal () ()
    (=
      (f32_to_bits
        (f32_add (f32_from_bits 1065353216) (f32_from_bits 1065353216)))
      1073741824))
  (steps ((compute both)) refl))

;; the classic: 0.1f + 0.2f = 0x3E99999A (inexact, rounds up).
(claim f32_pin_tenth_fifth
  (goal () ()
    (=
      (f32_to_bits
        (f32_add (f32_from_bits 1036831949) (f32_from_bits 1045220557)))
      1050253722))
  (steps ((compute both)) refl))

;; §5 canonicalization: an sNaN payload (0x7F800001) decodes to the model
;; NaN and re-encodes CANONICAL (0x7FC00000).
(claim f32_pin_nan_canon
  (goal () () (= (f32_to_bits (f32_from_bits 2139095041)) 2143289344))
  (steps ((compute both)) refl))

(claim f32_pin_nan_is_nan
  (goal () () (= (f32_is_nan (f32_from_bits 2139095041)) True))
  (steps ((compute both)) refl))

;; 0/0 is NaN; 1/-0 is -Inf (0xFF800000).
(claim f32_pin_zero_div_zero
  (goal () ()
    (= (f32_is_nan (f32_div (f32_from_bits 0) (f32_from_bits 0))) True))
  (steps ((compute both)) refl))

(claim f32_pin_one_div_negzero
  (goal () ()
    (=
      (f32_to_bits
        (f32_div (f32_from_bits 1065353216) (f32_from_bits 2147483648)))
      4286578688))
  (steps ((compute both)) refl))

;; IEEE comparisons: +0 == -0; -0 < +0 is False; NaN compares False.
(claim f32_pin_zero_eq
  (goal () () (= (f32_eq (f32_from_bits 0) (f32_from_bits 2147483648)) True))
  (steps ((compute both)) refl))

(claim f32_pin_negzero_lt
  (goal () () (= (f32_lt (f32_from_bits 2147483648) (f32_from_bits 0)) False))
  (steps ((compute both)) refl))

(claim f32_pin_nan_le
  (goal () ()
    (= (f32_le (f32_from_bits 2143289344) (f32_from_bits 1065353216)) False))
  (steps ((compute both)) refl))

(claim f32_pin_lt_one_two
  (goal () ()
    (= (f32_lt (f32_from_bits 1065353216) (f32_from_bits 1073741824)) True))
  (steps ((compute both)) refl))

;; neg/abs move only the sign bit.
(claim f32_pin_neg_zero
  (goal () () (= (f32_to_bits (f32_neg (f32_from_bits 0))) 2147483648))
  (steps ((compute both)) refl))

(claim f32_pin_abs_negone
  (goal () () (= (f32_to_bits (f32_abs (f32_from_bits 3212836864))) 1065353216))
  (steps ((compute both)) refl))

;; --- R3b pins: the decimal door (host-IEEE-verified) -----------------------------

;; 1.5f (exact) and 0.1f (inexact, rounds) land on the host bits.
(claim f32_pin_dec_1_5
  (goal () () (= (f32_to_bits (f32_from_dec 15 -1)) 1069547520))
  (steps ((compute both)) refl))

(claim f32_pin_dec_0_1
  (goal () () (= (f32_to_bits (f32_from_dec 1 -1)) 1036831949))
  (steps ((compute both)) refl))

;; the classic, now literal-spelled: 0.1f + 0.2f = 0x3E99999A.
(claim f32_pin_dec_tenth_fifth
  (goal () ()
    (=
      (f32_to_bits (f32_add (f32_from_dec 1 -1) (f32_from_dec 2 -1)))
      1050253722))
  (steps ((compute both)) refl))

;; the sign rides m; overflow rounds to the infinities; tiny decimals hit
;; the subnormal ulp and then underflow to +0.
(claim f32_pin_dec_neg
  (goal () () (= (f32_to_bits (f32_from_dec -25 -2)) 3196059648))
  (steps ((compute both)) refl))

(claim f32_pin_dec_ovf
  (goal () () (= (f32_to_bits (f32_from_dec 1 39)) 2139095040))
  (steps ((compute both)) refl))

(claim f32_pin_dec_sub
  (goal () () (= (f32_to_bits (f32_from_dec 1 -45)) 1))
  (steps ((compute both)) refl))

(claim f32_pin_dec_uflow
  (goal () () (= (f32_to_bits (f32_from_dec 1 -50)) 0))
  (steps ((compute both)) refl))

;; --- R3b pins: the hex observer --------------------------------------------------

;; 1.5f prints "0xc00000p-23"; -0.0f prints "-0x0p-149" (the sign shows).
(claim f32_pin_hex_1_5
  (goal () ()
    (=
      (f32_hex (f32_from_dec 15 -1))
      (list 48 120 99 48 48 48 48 48 112 45 50 51)))
  (steps ((compute both)) refl))

(claim f32_pin_hex_neg_zero
  (goal () ()
    (=
      (f32_hex (f32_neg (f32_from_dec 0 0)))
      (list 45 48 120 48 112 45 49 52 57)))
  (steps ((compute both)) refl))

(claim f32_pin_hex_nan
  (goal () () (= (f32_hex (f32_nan)) (list 110 97 110)))
  (steps ((compute both)) refl))

(claim f32_pin_hex_inf
  (goal () () (= (f32_hex (f32_inf)) (list 43 105 110 102)))
  (steps ((compute both)) refl))

;; --- R3b pins: the special constants ---------------------------------------------

(claim f32_pin_nan_const
  (goal () () (= (f32_is_nan (f32_nan)) True))
  (steps ((compute both)) refl))

(claim f32_pin_inf_const
  (goal () () (= (f32_to_bits (f32_inf)) 2139095040))
  (steps ((compute both)) refl))

(claim f32_pin_neg_inf_const
