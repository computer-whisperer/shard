;;; models/x86/linux.shard — the Linux x86_64 syscall shims (docs/X86.md
;;; §20 born, §32/§44 pedigree): the FIRST increment of a shard PLATFORM
;;; API. The platform is the Linux KERNEL ABI directly — NO libc, ever
;;; (linking it would drag the C toolchain, CRT startup, and the dynamic
;;; loader into the TCB). A freestanding static image reaches the OS
;;; through raw `syscall` instructions and nothing else.
;;;
;;; TRUST STATUS (rewritten at W4c per the §32 ratification, superseding
;;; this file's original axiom-kind header): the shim BODIES below are
;;; ORDINARY PROVABLE CODE. Their behavior is a THEOREM against the
;;; world layer (models/x86/world.shard) composed with the kernel model
;;; (models/linux/kernel.shard) — the §10 clobber-set form, proven by
;;; computation (design articles: examples/xworld_probe.shard
;;; wxp_write_shim / wxp_exit_shim; per-image certs are emitted at the
;;; shim's image index like any callee cert). What REMAINS trusted:
;;; (1) the 2-byte `syscall` encoding (0F 05, objdump-verified, in
;;; encode.shard's table); (2) the kernel model's FIDELITY to Linux —
;;; the ledger's kernel-model trust kind, held by the W4d trace
;;; differential gate, never by an in-language axiom; (3) the _start
;;; entry-state contract (argc/argv stack layout), owned by the glue.
;;;
;;; THE XINSTR BODIES are the shims' source of truth: emitted images
;;; carry them as ordinary image functions (encoded through enc_image
;;; with everything else), and the byte-tie law holds because the bytes
;;; enter the image from THIS pinned reviewed file, never from a
;;; producer. Two instructions each — the first three SysV arg homes
;;; (rdi/rsi/rdx) ARE the first three syscall arg homes, so the
;;; marshalling is the calling convention and only the number needs
;;; loading.
;;;
;;; LEDGER (the per-effect-point register discipline the certs state):
;;;
;;;   syscall            0F 05     rax = syscall number in; rax = result out.
;;;                                CLOBBERS {rcx, r11} (the CPU stores rip in
;;;                                rcx and rflags in r11) — oracle-drawn in
;;;                                the model, so no cert can depend on them.
;;;   sys_write  (nr 1)  rdi=fd  rsi=buf  rdx=count -> rax = bytes written.
;;;                      Clobber set: {rax, rcx, r11}. Trace: LxWrote fd
;;;                      (the bytes OFFERED — the v1 unconditional form).
;;;   sys_exit   (nr 60) rdi=code -> TERMINAL (WExit, wait-status masked).
;;;   entry state        _start receives argc/argv/envp/auxv on the initial
;;;                      stack (no CRT); this is the _start contract, owned
;;;                      by the glue stub that consumes it.

(import "../../kernel/stdlib.shard")
(import "x86.shard")
(use (:: models x86 x86 *))
(import "encode.shard")
(use (:: models x86 encode le4))
(use (:: models x86 encode eapp))

;; the syscall numbers (Linux x86_64)
(fn sc_nr_write () Int 1)

(fn sc_nr_exit () Int 60)

;; --- the shim bodies (model level — the emitter splices these into images) --------

;; sys_write: fd/buf/count already sit in rdi/rsi/rdx (SysV = syscall)
(fn shim_write_body () (List XInstr) (list (XMovRI RAX 1) XSyscall))

;; sys_exit: code already sits in rdi; control never returns (WExit)
(fn shim_exit_body () (List XInstr) (list (XMovRI RAX 60) XSyscall))

;; --- byte-level residue (the GLUE's own effect tail, §20-era, still consumed
;; --- by the exit-variant packagings; dissolves as those variants do) --------------

;; the syscall instruction: 0F 05.
(fn i_syscall () (List Int) (list 15 5))

;; sys_write of the top 8 stack bytes to stdout: assumes the value to emit
;; has just been PUSHed (so it sits at [rsp]); leaves rsp unchanged.
;;   B8 01000000   mov eax, 1     (nr = write)
;;   BF 01000000   mov edi, 1     (fd = stdout)
;;   48 89 E6      mov rsi, rsp   (buf = rsp)
;;   BA 08000000   mov edx, 8     (count = 8)
;;   0F 05         syscall
(fn sys_write_top8 () (List Int)
  (list 184 1 0 0 0 191 1 0 0 0 72 137 230 186 8 0 0 0 15 5))

;; sys_exit with a status code (terminal):
;;   B8 3C000000   mov eax, 60    (nr = exit)
;;   BF <code>     mov edi, code
;;   0F 05         syscall
(fn sys_exit_code ((code Int)) (List Int)
  (eapp (list 184 60 0 0 0) (eapp (Cons 191 (le4 code)) (list 15 5))))
