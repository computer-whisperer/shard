;;; xid_probe.shard — the IDENTITY-ENTRY probe (docs/X86.md §27, the A2
;;; rung's contract slice). The in-place write contract's isolating pilot
;;; is echoarg: an entry that returns its payload Mem UNCHANGED, so the
;;; binary's stdout is exactly the glue's write of the untouched page —
;;; the contract change carries the whole observable behavior. This
;;; probe hand-plays the entry's cert before the emitter learns the
;;; shape.
;;;
;;; The shape: the payload-Mem binder list ((m Mem) (p Int) (k Nat)),
;;; body = the Mem binder itself. Machine code: XMovRI RAX 0 alone (the
;;; Mem pieces' zero-rax epilogue with nothing before it — rax at entry
;;; is undefined, and the (Pair 0 …) conclusion needs the store). ZERO
;;; premises: the entry touches no memory, so there is no address to
;;; guard — the bin surface gate's empty-covered case. Fuel and chain
;;; are arglen's (the 1-instruction straight-line cert, S^ 5).
;;;
;;; On success x86gen's bin image walk learns the identity arm
;;; (fn_is_mem route, body = BVar of the Mem binder) and echoarg rides
;;; the derived bin build.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(import "../../../std/nat.shard")
(import "../x86.shard")
(use (:: std mem *))
(use (:: std nat *))
(use (:: models x86 x86 *))

;; the source article: the identity on the payload
(fn xid_main ((m Mem) (p Int) (k Nat)) Mem m)

;; the lowered conformance theorem, zero premises, at the BIN window
(claim lowered_xid_main
  (goal ((x0 Int) (k Nat) (c Nat) (restfs (List XFunc)) (m0 Mem)) ()
    (=
      (xcall_fn_mem
        (S^ 5 c)
        (MkXModule
          (Cons (MkXFunc 2 (list (XMovRI RAX 0))) restfs)
          6291456
          6295552)
        0
        (list x0 (int_of_nat k))
        m0)
      (Some (Pair 0 (xid_main m0 x0 k)))))
  (chain (steps ((compute lhs) (unfold xid_main rhs) (reduce rhs))) refl))
