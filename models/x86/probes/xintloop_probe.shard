;;; xintloop_probe.shard — the x86 INT-ACCUMULATOR LOOP RETURN probe
;;; (docs/X86.md §14 growth; the wasm twin is examples/intloop_probe.shard,
;;; the pinned design article for the shape). Hand-plays the §14 loop
;;; template extended to loops whose Z arm returns an ACCUMULATOR (Int
;;; return): sum-of-bytes over a range — the read-only loop with a
;;; data-dependent accumulator update (+ acc (mem_get m p)). This is
;;; bytesum, the A1 rung's entry shape (X86.md §22).
;;;
;;; Template deltas over the wasm probe (each line by mechanical rule):
;;;   1. The load target is a REGISTER, not a stack slot: XLoad8 RAX
;;;      leaves a data-dependent rax at loop exit. The closed form is a
;;;      kit fn xig_last (entry value if the loop never ran, else the
;;;      last byte read), and the worker QUANTIFIES the entry rax (ra) so
;;;      the IH can re-enter with rax = the just-read byte. The piece
;;;      instantiates ra = 0 (xargs zeroes non-arg registers) and its
;;;      epilogue XMovRR RAX RSI overwrites the residue with the sum, so
;;;      xig_last never reaches the piece's conclusion.
;;;   2. The wrap modulus is 2^64: xig_sum_64 replaces ig_sum_32 (same
;;;      farkas multipliers — the certificates are bound-literal-blind);
;;;      xig_sum_lo / xig_sum_shift transplant verbatim.
;;;   3. Machine update ORDER as in wasm: the sum reads the address
;;;      accum's OLD value, so load+add come before the advances.
;;;   4. Fuel is depth-shaped (xeval_seq passes the SAME peeled fuel to
;;;      the continuation), so one loop round costs exactly the loop
;;;      node's peel and S^P (xlg_fuel k c) self-restores on the
;;;      backedge for any P >= 1 + the body walk's depth: 10/14 here
;;;      (6-instruction body; fill's 5-instruction body rides 9/13).
;;;
;;; On success xig_last / xig_sum_lo / xig_sum_64 / xig_sum_shift
;;; graduate to models/x86/loopkit.shard as xlg_* and the emitter's loop
;;; route learns the Int-return shape (the LIOk arm of li_recognize).

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(import "../../../std/nat.shard")
(import "../x86.shard")
(import "../loopkit.shard")
(use (:: std mem *))
(use (:: std nat *))
(use (:: models x86 x86 *))
(use (:: models x86 loopkit *))

;; the source article: sum of k bytes starting at p, accumulated onto acc
(fn xip_sum ((m Mem) (p Int) (acc Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z acc)
    ((S k2) (xip_sum m (+ p 1) (+ acc (mem_get m p)) k2))))

;; the load register's residue after k iterations: the entry value if the
;; loop never ran, else the last byte read (delta 1 — the wasm shape has
;; no register residue; this is the x86 template's one new closed form)
(fn xig_last ((m Mem) (p Int) (r Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z r)
    ((S k2) (xig_last m (+ p 1) (mem_get m p) k2))))

;; the machine body: guard / rax = mem[rdi] / rsi += rax / rdi += 1 /
;; rdx -= 1 / loop
(fn xip_sum_body () (List XInstr)
  (list
    (XBrIf (CEqz RDX) 1)
    (XLoad8 RAX (AReg RDI))
    (XBin XAdd RSI (SReg RAX))
    (XBin XAdd RDI (SImm 1))
    (XBin XSub RDX (SImm 1))
    (XBr 0)))

;; --- the sum-invariant helper certs (template constants) --------------------

;; accumulator stays nonneg: 0 <= a, 0 <= b  |-  0 <= a + b.
(claim xig_sum_lo
  (goal ((a Int) (b Int)) ((= (le 0 a) True) (= (le 0 b) True))
    (= (le 0 (+ a b)) True))
  (by arith (list 1 1 1)))

;; the machine XAdd never wraps: a + 256*(S c) <= 2^64, b < 256  |-  a + b < 2^64.
(claim xig_sum_64
  (goal ((a Int) (b Int) (c Nat))
    ((= (le (+ a (* 256 (int_of_nat (S c)))) 18446744073709551616) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (lt b 256) True)
     (= (le 0 (int_of_nat c)) True))
    (= (lt (+ a b) 18446744073709551616) True))
  (by arith (list 1 1 256 1 256)))

;; invariant step to the IH: a + 256*(S c) <= 2^64, b < 256  |-  (a+b) + 256*c <= 2^64.
(claim xig_sum_shift
  (goal ((a Int) (b Int) (c Nat))
    ((= (le (+ a (* 256 (int_of_nat (S c)))) 18446744073709551616) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (lt b 256) True))
    (= (le (+ (+ a b) (* 256 (int_of_nat c))) 18446744073709551616) True))
  (by arith (list 1 1 256 1)))

;; --- the worker induction ----------------------------------------------------

(claim xigw_xip_sum
  (goal
    ((ra Int) (x0 Int) (x1 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc)))
    ((= (le 0 x0) True)
     (= (le 0 x1) True)
     (= (le (+ x0 (int_of_nat k)) 65536) True)
     (= (le (+ x1 (* 256 (int_of_nat k))) 18446744073709551616) True))
    (=
      (xeval_loop
        (S^ 10 (xlg_fuel k c))
        (MkXModule
          (Cons
            (MkXFunc
              3
              (list
                (XBlock (list (XLoop (inline xip_sum_body))))
                (XMovRR RAX RSI)))
            restfs)
          0
          65536)
        (inline xip_sum_body)
        (MkRegs ra 0 (int_of_nat k) 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m0)
      (Some
        (XBrk
          0
          (MkRegs
            (xig_last m0 x0 ra k)
            0
            0
            0
            0
            (xip_sum m0 x0 x1 k)
            (xlg_adv x0 k)
            0
            0
            0
            0
            0
            0
            0
            0)
          m0))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold xlg_fuel lhs)
            (reduce lhs)
            (unfold xeval_loop lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop xeval_loop xlg_fuel))))
         (rewrite-with
           (lemma xlg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop xeval_loop xlg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop xeval_loop xlg_fuel))))
         (rewrite-with
           (lemma xlg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 2) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop xeval_loop xlg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma xlg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (have hwk
           (= (mod (int_of_nat k2) 18446744073709551616) (int_of_nat k2))
           (rewrite-with
             (lemma wrap64_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma xlg_kM)
                lr
                lhs
                ((inst a x0) (inst c k2) (inst w 65536) (inst l 0))
                ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl)
                 (steps ((compute both)) refl)
                 (steps ((compute both)) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hw0 (= (mod (+ x0 1) 18446744073709551616) (+ x0 1))
           (rewrite-with
             (lemma wrap64_id)
             lr
             lhs
             ((inst x (+ x0 1)))
             ((rewrite-with
                (lemma xlg_lo0)
                lr
                lhs
                ((inst l 0))
                ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                 (steps ((compute both)) refl))
                refl)
              (rewrite-with
                (lemma xlg_64)
                lr
                lhs
                ((inst w 65536))
                ((rewrite-with
                   (lemma xlg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl)
                 (steps ((compute both)) refl))
                refl))
             refl))
         (steps ((rewrite (premise hw0) lr lhs true ())))
         (have hwa
           (=
             (mod (+ x1 (mem_get m0 x0)) 18446744073709551616)
             (+ x1 (mem_get m0 x0)))
           (rewrite-with
             (lemma wrap64_id)
             lr
             lhs
             ((inst x (+ x1 (mem_get m0 x0))))
             ((rewrite-with
                (lemma xig_sum_lo)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (rewrite-with (lemma get_lo) lr lhs () () refl))
                refl)
              (rewrite-with
                (lemma xig_sum_64)
                lr
                lhs
                ((inst c k2))
                ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (rewrite-with (lemma get_hi) lr lhs () () refl)
                 (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                refl))
             refl))
         (steps ((rewrite (premise hwa) lr lhs true ())))
         (steps
           ((unfold xip_sum rhs)
            (unfold xlg_adv rhs)
            (unfold xig_last rhs)
            (reduce rhs)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma xlg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma xig_sum_lo)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (rewrite-with (lemma get_lo) lr lhs () () refl))
              refl)
            (rewrite-with
              (lemma xlg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma xig_sum_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 3) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma get_hi) lr lhs () () refl))
              refl)))
         (steps ((compute both)))
         refl)))))

;; --- the lowered theorem ------------------------------------------------------

(claim lowered_xip_sum
  (goal ((x0 Int) (x1 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc)))
    ((= (le 0 x0) True)
     (= (le 0 x1) True)
     (= (le (+ x0 (int_of_nat k)) 65536) True)
     (= (le (+ x1 (* 256 (int_of_nat k))) 18446744073709551616) True))
    (=
      (xcall_fn_mem
        (S^ 14 (xlg_fuel k c))
        (MkXModule
          (Cons
            (MkXFunc
              3
              (list
                (XBlock (list (XLoop (inline xip_sum_body))))
                (XMovRR RAX RSI)))
            restfs)
          0
          65536)
        0
        (list x0 x1 (int_of_nat k))
        m0)
      (Some (Pair (xip_sum m0 x0 x1 k) m0))))
  (chain
    (steps ((compute lhs (stop xeval_loop xlg_fuel))))
    (rewrite-with
      (lemma xigw_xip_sum)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))
