;;; examples/xadequacy_probe.shard — the ADEQUACY FIXTURE (docs/X86.md §32
;;; amendment, the W2 closing obligation): for effect-free code the world
;;; layer IS the base tower — weval = adq-lifted xeval, world unchanged,
;;; trace empty — pinned ARM BY ARM.
;;;
;;; The §32 ratification reserved the per-program fallback ("or emitted
;;; per-program if the generic form fights the kit"); the generic
;;; quantified-over-code theorem needs a mutual-SCC effect predicate and a
;;; thirteen-ctor fuel induction, so this fixture takes the sanctioned
;;; shape instead: every CONTROL ARM of models/x86/world.shard (seq
;;; cons/nil, leaf delegation incl. the trap map, block exit on both WBrk
;;; depths, loop backedge + decrement exit, call on WNorm/WRetO/missing-
;;; callee, in-flight-return percolation) appears in some pin's compute
;;; path AT THE SAME QUANTIFIED FUEL as the base — so any drift in the
;;; twin's mirrored recursion flips a pin. Effectful composition cites
;;; per-callee bridge lemmas (emitted beside the xcert twins), never this
;;; file.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(use (:: std mem *))
(import "../x86.shard")
(use (:: models x86 x86 *))
(import "../../linux/kernel.shard")
(use (:: models linux kernel *))
(import "../world.shard")
(use (:: models x86 world *))

;; the lift: what "the towers agree" MEANS — same outcome, the world
;; threaded through untouched, no events
(fn adq ((w LxWorld) (o (Option XOut))) (Option WOut)
  (match o
    (None None)
    ((Some out)
     (match out
       ((XNorm rs mem) (Some (WNorm rs mem w Nil)))
       ((XBrk d rs mem) (Some (WBrk d rs mem w Nil)))
       ((XRetO rs mem) (Some (WRetO rs mem w Nil)))
       (XTrap (Some WTrap))))))

;; a one-function module around a body (window empty: these pins never
;; touch memory legally — the trap pin relies on it)
(fn adq_m ((body (List XInstr)) (restfs (List XFunc))) XModule
  (MkXModule (Cons (MkXFunc 0 body) restfs) 0 0))

;; two-function module: caller at 0, callee at 1
(fn adq_m2 ((body (List XInstr)) (callee (List XInstr))) XModule
  (MkXModule (Cons (MkXFunc 0 body) (Cons (MkXFunc 0 callee) Nil)) 0 0))

;; --- leaf sequencing (seq cons/nil, leaf delegation, the Nil-trace prepend) -------
(claim adq_leaf
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat)
     (restfs (List XFunc)))
    ()
    (=
      (weval_seq
        (S^ 6 c)
        (adq_m (list (XMovRI RAX 5) (XMovRI RCX 6)) restfs)
        (list (XMovRI RAX 5) (XMovRI RCX 6))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 6 c)
          (adq_m (list (XMovRI RAX 5) (XMovRI RCX 6)) restfs)
          (list (XMovRI RAX 5) (XMovRI RCX 6))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- the trap map (a store outside the empty window: XTrap → WTrap) ----------------
(claim adq_trap
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat)
     (restfs (List XFunc)))
    ()
    (=
      (weval_seq
        (S^ 6 c)
        (adq_m (list (XMovRI RDI 64) (XStore8 (AReg RDI) (SImm 7))) restfs)
        (list (XMovRI RDI 64) (XStore8 (AReg RDI) (SImm 7)))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 6 c)
          (adq_m (list (XMovRI RDI 64) (XStore8 (AReg RDI) (SImm 7))) restfs)
          (list (XMovRI RDI 64) (XStore8 (AReg RDI) (SImm 7)))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- block exit, both WBrk depths (br 0 exits, br 1 unwinds one level) -------------
(claim adq_block
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat)
     (restfs (List XFunc)))
    ()
    (=
      (weval_seq
        (S^ 8 c)
        (adq_m
          (list
            (XBlock (list (XBlock (list (XBr 1))) (XMovRI RAX 3)))
            (XMovRI RCX 4))
          restfs)
        (list
          (XBlock (list (XBlock (list (XBr 1))) (XMovRI RAX 3)))
          (XMovRI RCX 4))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 8 c)
          (adq_m
            (list
              (XBlock (list (XBlock (list (XBr 1))) (XMovRI RAX 3)))
              (XMovRI RCX 4))
            restfs)
          (list
            (XBlock (list (XBlock (list (XBr 1))) (XMovRI RAX 3)))
            (XMovRI RCX 4))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- the loop: three ground backedges, then the depth-1 exit through the block -----
(claim adq_loop
  (goal
    ((c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat)
     (restfs (List XFunc)))
    ()
    (=
      (weval_seq
        (S^ 24 c)
        (adq_m
          (list
            (XMovRI RAX 0)
            (XBlock
              (list
                (XLoop
                  (list
                    (XBin XAdd RAX (SImm 1))
                    (XBrIf (CLtU RAX (SImm 3)) 0)
                    (XBr 1))))))
          restfs)
        (list
          (XMovRI RAX 0)
          (XBlock
            (list
              (XLoop
                (list
                  (XBin XAdd RAX (SImm 1))
                  (XBrIf (CLtU RAX (SImm 3)) 0)
                  (XBr 1))))))
        (MkRegs 0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 24 c)
          (adq_m
            (list
              (XMovRI RAX 0)
              (XBlock
                (list
                  (XLoop
                    (list
                      (XBin XAdd RAX (SImm 1))
                      (XBrIf (CLtU RAX (SImm 3)) 0)
                      (XBr 1))))))
            restfs)
          (list
            (XMovRI RAX 0)
            (XBlock
              (list
                (XLoop
                  (list
                    (XBin XAdd RAX (SImm 1))
                    (XBrIf (CLtU RAX (SImm 3)) 0)
                    (XBr 1))))))
          (MkRegs 0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- the call: WNorm return, then sequencing continues in the caller ---------------
(claim adq_call
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat))
    ()
    (=
      (weval_seq
        (S^ 8 c)
        (adq_m2 (list (XCall 1) (XMovRI RCX 9)) (list (XMovRI RAX 8)))
        (list (XCall 1) (XMovRI RCX 9))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 8 c)
          (adq_m2 (list (XCall 1) (XMovRI RCX 9)) (list (XMovRI RAX 8)))
          (list (XCall 1) (XMovRI RCX 9))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- the call on an in-flight return (XRet inside the callee: WRetO → WNorm) -------
(claim adq_ret
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat))
    ()
    (=
      (weval_seq
        (S^ 8 c)
        (adq_m2 (list (XCall 1)) (list (XMovRI RAX 8) XRet (XMovRI RAX 9)))
        (list (XCall 1))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 8 c)
          (adq_m2 (list (XCall 1)) (list (XMovRI RAX 8) XRet (XMovRI RAX 9)))
          (list (XCall 1))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- the missing callee (both towers trap) ------------------------------------------
(claim adq_badcall
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat))
    ()
    (=
      (weval_seq
        (S^ 5 c)
        (adq_m2 (list (XCall 7)) (list (XMovRI RAX 8)))
        (list (XCall 7))
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (adq
        w
        (xeval_seq
          (S^ 5 c)
          (adq_m2 (list (XCall 7)) (list (XMovRI RAX 8)))
          (list (XCall 7))
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))
