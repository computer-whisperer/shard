;;; Checked straight-line transition reductions for the x86 model.
;;;
;;; These are semantic sequence laws, not equalities of XInstr data.  Fuel is
;;; stated with the exact cost delta: removing one list cell removes one unit
;;; from the structural depth budget.  A search observer may use these under a
;;; length-normalized fuel policy; same-fuel replacement at the exhaustion
;;; boundary would be false.

(import "../../kernel/stdlib.shard")
(import "../../std/bits")
(import "../../std/mem")
(import "x86.shard")
(use (:: std bits *))
(use (:: std mem Mem))
(use (:: models x86 x86 *))

;; The generated record laws make these generic register facts a finite case
;; split rather than a new axiom or a register-specific theorem table.
(claim rget_rset_same
  (goal ((rs Regs) (r Reg) (v Int)) () (= (rget (rset rs r v) r) v))
  (case-on rs Regs
    ((case MkRegs
      (v0 v1 v2 v3 v4 v5 v6 v7 v8 v9 v10 v11 v12 v13 v14)
      (chain
       (steps ((rewrite (hyp MkRegs) lr both true ())))
       (case-on r Reg
    ((case RAX (steps ((rewrite (hyp RAX) lr both true ()) (compute both)) refl))
     (case RCX (steps ((rewrite (hyp RCX) lr both true ()) (compute both)) refl))
     (case RDX (steps ((rewrite (hyp RDX) lr both true ()) (compute both)) refl))
     (case RBX (steps ((rewrite (hyp RBX) lr both true ()) (compute both)) refl))
     (case RBP (steps ((rewrite (hyp RBP) lr both true ()) (compute both)) refl))
     (case RSI (steps ((rewrite (hyp RSI) lr both true ()) (compute both)) refl))
     (case RDI (steps ((rewrite (hyp RDI) lr both true ()) (compute both)) refl))
     (case R8 (steps ((rewrite (hyp R8) lr both true ()) (compute both)) refl))
     (case R9 (steps ((rewrite (hyp R9) lr both true ()) (compute both)) refl))
     (case R10 (steps ((rewrite (hyp R10) lr both true ()) (compute both)) refl))
     (case R11 (steps ((rewrite (hyp R11) lr both true ()) (compute both)) refl))
     (case R12 (steps ((rewrite (hyp R12) lr both true ()) (compute both)) refl))
     (case R13 (steps ((rewrite (hyp R13) lr both true ()) (compute both)) refl))
     (case R14 (steps ((rewrite (hyp R14) lr both true ()) (compute both)) refl))
     (case R15 (steps ((rewrite (hyp R15) lr both true ()) (compute both)) refl)))))))))

;; Updating one register frames every differently coded register.  The code
;; premise is deliberately decidable syntax: reg_code is a complete injective
;; discriminator over Reg, and search can authenticate the same fact directly.
(claim rget_rset_other
  (goal
    ((rs Regs) (written Reg) (read Reg) (v Int))
    ((= (int_eq (reg_code written) (reg_code read)) False))
    (= (rget (rset rs written v) read) (rget rs read)))
  (case-on rs Regs
      ((case MkRegs
        (v0 v1 v2 v3 v4 v5 v6 v7 v8 v9 v10 v11 v12 v13 v14)
        (chain
          (steps ((rewrite (hyp MkRegs) lr both true ())))
          (case-on written Reg
           (      (case RAX
          (case-on read Reg
           (          (case RAX
              (chain
                (have hff (= False True)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (rewrite (hyp 1) lr lhs true ())
                     (rewrite (hyp 0) lr lhs true ())
                     (compute lhs))
                    refl))
                (absurd (premise hff))))
            (case RCX
              (steps
                ((rewrite (hyp 1) lr both true ())
                 (rewrite (hyp 0) lr both true ())
                 (compute both))
                refl))
            (case RDX
