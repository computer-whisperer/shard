;;; models/x86/encode.shard — XFunc value -> real x86_64 machine-code bytes
;;; (docs/X86.md, Probe B: the flattening encoder).
;;;
;;; The reality-check encoder: turns one XFunc into a flat byte string a real
;;; CPU executes, so the silicon differential (examples/x86_diff*) can run what
;;; the model proved. Output is (List Int), every element in [0,256). Nothing
;;; here is in-logic: UNTRUSTED dev-side plumbing; a wrong encoding fails
;;; loudly at the CPU (SIGILL / SIGSEGV / result mismatch), never in a proof.
;;;
;;; THE FLATTENING (what wasm's encoder never had to do): x86 has no
;;; structured control, so XBlock/XLoop/XBr/XBrIf compile to LABELS and
;;; RELATIVE JUMPS. Every branch is FIXED WIDTH (jmp rel32 = 5 bytes,
;;; test+jcc = 9), so the byte length of any sequence is computable WITHOUT
;;; knowing displacements (xsz_* below) — which breaks the assembler's
;;; usual two-pass circularity. Emission then threads a label stack whose
;;; entries carry, for each enclosing block, the bytes remaining to its end,
;;; and for each enclosing loop, the bytes elapsed since its head; a branch
;;; reads its target's entry and computes the signed rel32 directly.
;;;
;;; Encoding commitments (where the model meets the ISA):
;;;   - 64-bit operand size throughout: REX.W on arithmetic/mov/movzx.
;;;   - Register file order skips rsp (num 4): the control stack is the
;;;     encoder's, so rsp is never a model register. reg_num maps the 15
;;;     model registers onto {0,1,2,3,5,6,7,8..15}.
;;;   - A function is a flat body + a trailing `ret` (0xC3). Multi-function
;;;     IMAGES (docs/X86.md §15) lay the ENTRY function first and the rest
;;;     in index order; XCall k -> call rel32 (0xE8) through the per-index
;;;     offset table (fixed 5-byte width). Single-function enc_func has no
;;;     table, so an XCall there is a five-byte int3 fence.
;;;   - SImm arithmetic uses imm32 (sign-extended by the CPU to 64); the
;;;     model wraps the immediate to [0,2^64). They agree for |imm| < 2^31
;;;     (all probe immediates); a wider immediate needs a scratch-register
;;;     materialization (a named growth path), not handled here.
;;;   - Byte store/load only (XStore8/XLoad8): wide ops are X86.md §5 growth.

(import "x86.shard")
(use (:: models x86 x86 *))

;; local list plumbing (transparent; std/list is opaque in check mode)
(fn eapp ((xs (List Int)) (ys (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (eapp t ys)))))

(fn elen ((xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons h t) (+ 1 (elen t)))))

;; --- little-endian byte splitters (no measures — pure ladders) --------------

;; low 4 bytes of (n mod 2^32), little-endian: rel32 / imm32 (two's complement
;; falls out of euclidean mod on a negative displacement).
(fn le4 ((n Int)) (List Int)
  (let ((u (mod n 4294967296)))
    (list
      (mod u 256)
      (mod (ediv u 256) 256)
      (mod (ediv u 65536) 256)
      (mod (ediv u 16777216) 256))))

;; low 8 bytes of (n mod 2^64), little-endian: imm64 for mov r64, imm64.
(fn le8 ((n Int)) (List Int)
  (let ((u (mod n 18446744073709551616)))
    (list
      (mod u 256)
      (mod (ediv u 256) 256)
      (mod (ediv u 65536) 256)
      (mod (ediv u 16777216) 256)
      (mod (ediv u 4294967296) 256)
      (mod (ediv u 1099511627776) 256)
      (mod (ediv u 281474976710656) 256)
      (mod (ediv u 72057594037927936) 256))))

;; --- register numbering -------------------------------------------------------

;; x86_64 encoding number, rsp (4) deliberately absent from the model.
(fn reg_num ((r Reg)) Int
  (match r
    (RAX 0)
    (RCX 1)
    (RDX 2)
    (RBX 3)
    (RBP 5)
    (RSI 6)
    (RDI 7)
    (R8 8)
    (R9 9)
    (R10 10)
    (R11 11)
    (R12 12)
    (R13 13)
    (R14 14)
    (R15 15)))

(fn rhi ((n Int)) Int (ediv n 8))

(fn rlo ((n Int)) Int (mod n 8))

;; ModRM/SIB for a register-indirect memory operand [base], given the ModRM
;; reg field. bl=4 (rsp/r12) needs a SIB byte; bl=5 (rbp/r13) needs mod=01
;; disp8=0 (mod=00 rm=5 means RIP-relative). Everything else is mod=00.
(fn enc_mem ((regf Int) (base Int)) (List Int)
  (let ((bl (mod base 8)))
    (if (int_eq bl 4) (list (+ (* 8 regf) 4) 36)
    (if (int_eq bl 5) (list (+ 64 (+ (* 8 regf) 5)) 0)
    (list (+ (* 8 regf) bl))))))

;; --- non-branch instruction bytes ---------------------------------------------

(fn bin_rr_op ((o XBop)) Int
  (match o
    (XAdd 1)
    (XSub 41)
    (XAnd 33)
    (XOr 9)
    (XXor 49)
    (XMul 0)))

(fn bin_ri_ext ((o XBop)) Int
  (match o
    (XAdd 0)
    (XOr 1)
    (XAnd 4)
    (XSub 5)
    (XXor 6)
    (XMul 0)))

;; dst OP= src (register source). XMul is the odd one: 0F AF, reg field = DST,
;; r/m = source — the opposite direction from the /r arithmetic ops.
(fn enc_bin_rr ((o XBop) (d Reg) (s Reg)) (List Int)
  (let ((nd (reg_num d)))
    (let ((ns (reg_num s)))
      (match o
        (XMul
          (list
            (+ 72 (+ (* 4 (rhi nd)) (rhi ns)))
            15
            175
            (+ 192 (+ (* 8 (rlo nd)) (rlo ns)))))
        (o2
          (list
            (+ 72 (+ (* 4 (rhi ns)) (rhi nd)))
            (bin_rr_op o2)
            (+ 192 (+ (* 8 (rlo ns)) (rlo nd)))))))))

;; dst OP= imm32 (0x81 /ext id; XMul via 0x69 /r id, r/m = dst).
(fn enc_bin_ri ((o XBop) (d Reg) (v Int)) (List Int)
  (let ((nd (reg_num d)))
    (match o
      (XMul
        (eapp
          (list
            (+ 72 (+ (* 4 (rhi nd)) (rhi nd)))
            105
            (+ 192 (+ (* 8 (rlo nd)) (rlo nd))))
          (le4 v)))
      (o2
        (eapp
          (list (+ 72 (rhi nd)) 129 (+ 192 (+ (* 8 (bin_ri_ext o2)) (rlo nd))))
          (le4 v))))))

(fn enc_simple ((i XInstr)) (List Int)
  (match i
    ((XMovRI r v)
     (let ((n (reg_num r)))
       (eapp (list (+ 72 (rhi n)) (+ 184 (rlo n))) (le8 v))))
    ((XMovRR d s)
     (let ((nd (reg_num d)))
       (let ((ns (reg_num s)))
         (list
           (+ 72 (+ (* 4 (rhi ns)) (rhi nd)))
           137
           (+ 192 (+ (* 8 (rlo ns)) (rlo nd)))))))
    ((XBin o d s)
     (match s
       ((SReg sr) (enc_bin_rr o d sr))
       ((SImm v) (enc_bin_ri o d v))))
    ;; shl/shr r/m64, imm8 — REX.W C1 /4 ib (shl) / /5 ib (shr), mod=11 so the
    ;; register is the r/m operand and /4|/5 is the opcode-extension reg field
    ;; (like XDivU's /6: single-operand, only REX.B tracks the high bit). ModRM
    ;; = 0xC0 | (ext<<3) | (r&7): 0xE0|r for /4, 0xE8|r for /5. The count is one
    ;; imm8 folded with (mod k 256) — XStore8's SImm imm8 fencing — and since
    ;; the CPU masks a 64-bit shift count to 6 bits, (mod (mod k 256) 64) =
    ;; (mod k 64) reproduces the model's masked count for EVERY k.
    ((XShlI d k)
     (let ((n (reg_num d)))
       (list (+ 72 (rhi n)) 193 (+ 224 (rlo n)) (mod k 256))))
    ((XShrI d k)
     (let ((n (reg_num d)))
       (list (+ 72 (rhi n)) 193 (+ 232 (rlo n)) (mod k 256))))
    ;; div r64 (REX.W + F7 /6, mod=11): the compound rdx:rax unsigned divide;
    ;; the operand is the r/m field so only REX.B tracks the high register bit
    ;; (like enc_test_r's single-operand REX). ModRM = 0xC0 | (6<<3) | (r&7).
    ((XDivU r)
     (let ((n (reg_num r))) (list (+ 72 (rhi n)) 247 (+ 240 (rlo n)))))
    ((XLoad8 d a)
     (match a
       ((AReg base)
        (let ((nd (reg_num d)))
          (let ((nb (reg_num base)))
            (eapp
              (list (+ 72 (+ (* 4 (rhi nd)) (rhi nb))) 15 182)
              (enc_mem (rlo nd) nb)))))))
    ((XStore8 a s)
     (match a
       ((AReg base)
        (let ((nb (reg_num base)))
          (match s
            ((SReg sr)
             (let ((ns (reg_num sr)))
               (eapp
                 (list (+ 64 (+ (* 4 (rhi ns)) (rhi nb))) 136)
                 (enc_mem (rlo ns) nb))))
            ((SImm v)
             (eapp
               (eapp (list (+ 64 (rhi nb)) 198) (enc_mem 0 nb))
               (list (mod v 256)))))))))
    ;; syscall (0F 05): the two-byte system-call instruction, no operands, no
    ;; REX — nullary, so dispatch and size both flow through enc_simple.
    (XSyscall (list 15 5))
    (other Nil)))

;; --- ELF harness stub byte encoders (docs/X86.md §20) -------------------------
;;
;; The self-checking ELF stub (models/x86/elf.shard) marshals SysV args and
;; `call`s exports; these concentrate its instruction opcodes HERE in the
;; encoder, leaving elf.shard only ELF-structural bytes + encoder/shim calls.
;; Byte-level: push/pop are not model XInstr (the encoder owns the control
;; stack, so rsp is never a model register), but their opcode bytes belong
;; with the rest of the ISA's byte authorship, not in the container.

;; mov r64, imm64 (REX.W + B8+rd io) — the same bytes enc_simple gives XMovRI.
(fn enc_mov_imm64 ((r Reg) (v Int)) (List Int)
  (let ((n (reg_num r))) (eapp (list (+ 72 (rhi n)) (+ 184 (rlo n))) (le8 v))))

;; call rel32 (0xE8 cd) to a caller-computed displacement (target - call end).
;; The image-relative disp is the container's arithmetic; the opcode is ours.
(fn enc_call_rel32 ((disp Int)) (List Int) (Cons 232 (le4 disp)))

;; push r64 / pop r64 (0x50+rd / 0x58+rd, low-8 regs — the stub only spills
;; rax/rcx across the syscall splice).
(fn enc_push_reg ((r Reg)) (List Int) (list (+ 80 (rlo (reg_num r)))))

(fn enc_pop_reg ((r Reg)) (List Int) (list (+ 88 (rlo (reg_num r)))))

;; --- BIN-rung glue byte encoders (docs/X86.md §21) ---------------------------
;;
;; The plainly-executable ELF's `_start` glue reads argc/argv off the entry
;; stack and copies argv[1]'s bytes into the writable data segment. Its three
;; extra opcodes live HERE (like the §20 stub's): a stack-relative load — rsp
;; is NOT a model register, so it can never come through enc_simple — and bare
;; jcc/jmp rel32 (enc_brif bundles cmp+jcc for the MODEL's structured form;
;; the glue's flat argc check and copy-loop back-edge need them standalone).
;; The glue's remaining instructions REUSE the encoders above (enc_mov_imm64,
;; enc_cmp_rs, enc_test_r, enc_bin_ri, enc_call_rel32, and enc_simple for the
;; byte load/store XLoad8/XStore8), so still nothing emits raw opcodes.
;; (push/pop serve the §20 stub, not the glue.)

;; mov r64, [rsp + disp8]  (REX.W 8B /r, mod=01 reg=r rm=100 SIB=0x24 disp8):
;; the only [rsp+k] form (argc at [rsp], argv[1] at [rsp+16]).
(fn enc_mov_reg_rsp8 ((r Reg) (disp Int)) (List Int)
  (let ((n (reg_num r)))
    (list (+ 72 (* 4 (rhi n))) 139 (+ 64 (+ (* 8 (rlo n)) 4)) 36 (mod disp 256))))

;; jcc rel32 (0F 8x cd): `op` is the second opcode byte (cond_jop's vocabulary,
;; e.g. jae 0x83, je/jz 0x84), `disp` = target - (this instruction's end).
(fn enc_jcc_rel32 ((op Int) (disp Int)) (List Int)
  (eapp (list 15 op) (le4 disp)))

;; jmp rel32 (E9 cd): the copy loop's back-edge to its guard.
(fn enc_jmp_rel32 ((disp Int)) (List Int) (Cons 233 (le4 disp)))

;; --- comparison bytes for conditional jumps -----------------------------------

;; test r,r (REX.W 0x85 /r, mod=11) — sets ZF from the register (the zero
;; tests: CEqz / CNz).
(fn enc_test_r ((r Reg)) (List Int)
  (let ((n (reg_num r)))
    (list
      (+ 72 (+ (* 4 (rhi n)) (rhi n)))
      133
      (+ 192 (+ (* 8 (rlo n)) (rlo n))))))

;; cmp r, s — REX.W 0x39 /r (reg source, r/m = dst, reg = src) or
;; REX.W 0x81 /7 id (imm32 source). The dst is the comparison's first
;; operand, the src its second (CLtU r s tests rget r < xsrc s).
(fn enc_cmp_rs ((r Reg) (s Src)) (List Int)
  (let ((nd (reg_num r)))
    (match s
      ((SReg sr)
       (let ((ns (reg_num sr)))
         (list
           (+ 72 (+ (* 4 (rhi ns)) (rhi nd)))
           57
           (+ 192 (+ (* 8 (rlo ns)) (rlo nd))))))
      ((SImm v)
       (eapp (list (+ 72 (rhi nd)) 129 (+ 192 (+ 56 (rlo nd)))) (le4 v))))))

;; the comparison bytes preceding the jcc, per condition. Fixed per
;; (op, operand shape) so branch widths stay computable without
;; displacements — reg-reg cmp / test = 3 bytes, imm32 cmp = 7.
(fn enc_ccmp ((c Cond)) (List Int)
  (match c
    ((CEqz r) (enc_test_r r))
    ((CNz r) (enc_test_r r))
    ((CEq r s) (enc_cmp_rs r s))
    ((CLtU r s) (enc_cmp_rs r s))
    ((CLeU r s) (enc_cmp_rs r s))))

;; --- sizes (fixed for branches; the flattening's foundation) ------------------

;; the whole XBrIf width: the comparison bytes + jcc rel32 (0x0F 0x8x + 4).
(fn xsz_brif ((c Cond)) Int (+ (elen (enc_ccmp c)) 6))

(fn xsz_instr ((i XInstr)) Int
  (measure (struct i))
  (match i
    ((XBlock b) (xsz_seq b))
    ((XLoop b) (xsz_seq b))
    ((XBr d) 5)
    ((XBrIf c d) (xsz_brif c))
    (XRet 1)
    ((XCall k) 5)
    (i2 (elen (enc_simple i2)))))

(fn xsz_seq ((is (List XInstr))) Int
  (measure (struct is))
  (match is
    (Nil 0)
    ((Cons i t) (+ (xsz_instr i) (xsz_seq t)))))

;; --- the label stack and the flattening emit ----------------------------------

;; a live enclosing construct: LB rem = a block whose end is `rem` bytes past
;; the current position's start; LL el = a loop whose head is `el` bytes back.
(type Lbl (LB Int) (LL Int))

(fn lbl_at ((env (List Lbl)) (d Int)) (Option Lbl)
  (measure (struct env))
  (match env
    (Nil None)
    ((Cons h t) (if (int_eq d 0) (Some h) (lbl_at t (- d 1))))))

;; advance every live label by the bytes just emitted: blocks shrink toward
;; their end, loops grow away from their head.
(fn adv1 ((l Lbl) (s Int)) Lbl
  (match l
    ((LB r) (LB (- r s)))
    ((LL e) (LL (+ e s)))))

(fn adv ((env (List Lbl)) (s Int)) (List Lbl)
  (measure (struct env))
  (match env
    (Nil Nil)
    ((Cons h t) (Cons (adv1 h s) (adv t s)))))

;; jmp rel32 (0xE9): forward to a block end (rem - 5 from jmp end) or back to
;; a loop head (-(el + 5)). A malformed depth emits int3 — a loud fence.
(fn enc_br ((d Int) (env (List Lbl))) (List Int)
  (match (lbl_at env d)
    (None (list 204))
    ((Some l)
     (match l
       ((LB rem) (Cons 233 (le4 (- rem 5))))
       ((LL el) (Cons 233 (le4 (- 0 (+ el 5)))))))))

;; jcc opcode (second byte, after 0x0F), TAKEN exactly when xcond is true:
;; jz/je 0x84, jnz 0x85, jb 0x82, jbe 0x86.
(fn cond_jop ((c Cond)) Int
  (match c
    ((CEqz r) 132)
    ((CNz r) 133)
    ((CEq r s) 132)
    ((CLtU r s) 130)
    ((CLeU r s) 134)))

;; the comparison bytes + jcc rel32; the rel32 is off the whole
;; instruction end (xsz_brif c bytes), so imm32-cmp branches (13 bytes)
;; and reg/test branches (9) both resolve correctly.
(fn enc_brif ((c Cond) (d Int) (env (List Lbl))) (List Int)
  (eapp
    (enc_ccmp c)
    (match (lbl_at env d)
      (None (list 204))
      ((Some l)
       (eapp
         (list 15 (cond_jop c))
         (match l
           ((LB rem) (le4 (- rem (xsz_brif c))))
           ((LL el) (le4 (- 0 (+ el (xsz_brif c)))))))))))

;; --- inter-function layout (docs/X86.md §15) -----------------------------------
;;
;; A multi-function IMAGE lays the ENTRY function first (the harness
;; calls the blob's start; the wire carries no entry offset) and every
;; other function after it in index order. Function INDICES are model
;; truth and never move; only the byte layout is entry-first. XCall k
;; encodes as `call rel32` (0xE8) against the per-index offset table —
;; fixed 5-byte width, so the flattening's size arithmetic is
;; unaffected. Emission threads POS (the absolute image offset of the
;; instruction being encoded) alongside the label stack.

;; per-index offset lookup
(fn off_at ((offs (List Int)) (k Int)) (Option Int)
  (measure (struct offs))
  (match offs
    (Nil None)
    ((Cons o t) (if (int_eq k 0) (Some o) (off_at t (- k 1))))))

;; call rel32: target offset minus the call's END. A missing offset
;; (single-function encoding, or an out-of-range index) emits five int3
;; bytes — size-consistent with xsz_instr, loud at the CPU.
(fn enc_call ((k Int) (pos Int) (offs (List Int))) (List Int)
  (match (off_at offs k)
    (None (list 204 204 204 204 204))
    ((Some o) (Cons 232 (le4 (- o (+ pos 5)))))))

;; enc_instr is ALSO models/wasm/encode.shard's name — deliberately: run
;; mode resolves module-internal bare calls QUALIFIED (build_module_r), so
;; co-loaded same-named fns are sound. This shared spelling is the live
;; guard: tools/bytetie loads both encoders, and a regression to flat-core
;; dispatch would cross-resolve it again (the 2026-07-06 bug, then
;; worked around as xenc_instr; examples/runhom_run.shard is the fixture).
(fn enc_instr ((i XInstr) (env (List Lbl)) (pos Int) (offs (List Int)))
  (List Int)
  (measure (struct i))
  (match i
    ((XBlock b) (enc_seq b (Cons (LB (xsz_seq b)) env) pos offs))
    ((XLoop b) (enc_seq b (Cons (LL 0) env) pos offs))
    ((XBr d) (enc_br d env))
    ((XBrIf c d) (enc_brif c d env))
    ((XCall k) (enc_call k pos offs))
    (XRet (list 195))
    (i2 (enc_simple i2))))

(fn enc_seq ((is (List XInstr)) (env (List Lbl)) (pos Int) (offs (List Int)))
  (List Int)
  (measure (struct is))
  (match is
    (Nil Nil)
    ((Cons i t)
     (eapp
       (enc_instr i env pos offs)
       (enc_seq t (adv env (xsz_instr i)) (+ pos (xsz_instr i)) offs)))))

;; the function: flat body + trailing ret. Single-function encoding — no
;; offset table, so an XCall is the int3 fence.
(fn enc_func ((f XFunc)) (List Int)
  (eapp (enc_seq (xbody_of f) Nil 0 Nil) (list 195)))

;; a function placed at image offset POS
(fn enc_fn_at ((f XFunc) (pos Int) (offs (List Int))) (List Int)
  (eapp (enc_seq (xbody_of f) Nil pos offs) (list 195)))

;; function byte size in an image (body + ret)
(fn xsz_func ((f XFunc)) Int (+ (xsz_seq (xbody_of f)) 1))

;; per-index offsets under the entry-first layout: entry at 0, every
;; other function following in index order (acc = the next free offset)
(fn img_offs ((fs (List XFunc)) (i Int) (entry Int) (acc Int)) (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f t)
     (if (int_eq i entry) (Cons 0 (img_offs t (+ i 1) entry acc))
     (Cons acc (img_offs t (+ i 1) entry (+ acc (xsz_func f))))))))

;; the non-entry functions, index order, each at its table offset
(fn img_emit
  ((fs (List XFunc)) (myoffs (List Int)) (i Int) (entry Int) (offs (List Int)))
  (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f t)
     (match myoffs
       (Nil Nil)
       ((Cons o ot)
        (if (int_eq i entry) (img_emit t ot (+ i 1) entry offs)
        (eapp (enc_fn_at f o offs) (img_emit t ot (+ i 1) entry offs))))))))

;; the image: entry function's bytes first, the rest in index order;
;; every XCall resolves through the shared per-index table. An
;; out-of-range entry yields the empty image (loud at the differ).
(fn enc_image ((fs (List XFunc)) (entry Int)) (List Int)
  (match (xfunc_at fs entry)
    (None Nil)
    ((Some ef)
     (let ((offs (img_offs fs 0 entry (xsz_func ef))))
       (eapp (enc_fn_at ef 0 offs) (img_emit fs offs 0 entry offs))))))

;; ---- index-order image (LIB mode / the ELF harness, docs/X86.md §19-§20) ----
;;
;; enc_image lays a chosen ENTRY first; the ELF container's entry is the
;; harness stub, NOT a lib function, so the ELF embeds the image in NATURAL
;; INDEX ORDER (function i at the i-th offset) with internal XCalls resolved
;; RELATIVE to the image start. Placing the whole blob at any later offset
;; (after the stub) keeps those internal rel32s correct — they are relative.

;; per-index offsets under index-order layout: function i at the running
;; byte total of functions 0..i-1
(fn img_offs_ord ((fs (List XFunc)) (acc Int)) (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f t) (Cons acc (img_offs_ord t (+ acc (xsz_func f)))))))

(fn img_emit_ord ((fs (List XFunc)) (myoffs (List Int)) (offs (List Int)))
  (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f t)
     (match myoffs
       (Nil Nil)
       ((Cons o ot) (eapp (enc_fn_at f o offs) (img_emit_ord t ot offs)))))))

;; the whole image, index order, internal calls resolved image-relative
(fn enc_image_ord ((fs (List XFunc))) (List Int)
  (let ((offs (img_offs_ord fs 0))) (img_emit_ord fs offs offs)))

;; ---- named exports (LIB mode, docs/X86.md §19) ------------------------------
;;
;; A lib artifact's export surface: name (as bytes) -> function index.
;; The table is build-plan truth (which entry layouts ship, what the
;; manifest binds); nothing in the raw image bytes carries names — the
;; ELF rung's symbol table is the table's first byte-level consumer.
(type XExport (XX (List Int) Int))
