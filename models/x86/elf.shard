;;; models/x86/elf.shard — the ELF64 container + the self-checking harness
;;; stub (docs/X86.md §20, the lib-build arc's engine-as-a-process rung).
;;;
;;; enc_elf wraps a lib IMAGE (index-order bytes + the per-index offset
;;; table) in a freestanding static ELF64 executable whose entry is a
;;; GENERATED _start stub: for each synthesized vector it marshals the args
;;; into their SysV homes, `call`s the export (rel32 into the image), and
;;; sys_writes the 8-byte result to stdout; after the last, sys_exit(0). The
;;; produced binary RUNS on real Linux with zero C in the loop — the engine
;;; gate becomes the artifact itself, its stdout diffed against the plan's
;;; expected values.
;;;
;;; UNTRUSTED PLUMBING: like examples/x86_diff.c, nothing here is in-logic —
;;; a wrong header or stub byte fails LOUDLY at the loader (the kernel
;;; refuses the image) or at the diff (wrong stdout), never in a proof. The
;;; syscall bytes it splices come from the reviewed models/x86/linux.shard;
;;; the IMAGE bytes are cert-tied upstream (bytetie re-derives enc_image_ord
;;; from the claim literals — the ELF runs bytes tied to the proofs).
;;;
;;; Layout of enc_elf, the §20 stub (one R+X PT_LOAD mapping the whole
;;; file at LOAD_BASE):
;;;   [ELF header : 64][program header : 56][_start stub][image]
;;; e_entry = LOAD_BASE + 120 (the stub, first in the mapped code).
;;; The image's pure Int exports need no writable data segment.
;;; enc_binelf (the §22 bin rung) has its OWN two-segment layout and its
;;; own GLUE CONTRACT — see the contract block above it, not this banner.

(import "../../kernel/stdlib.shard")
(import "x86.shard")
(import "encode.shard")
(import "linux.shard")
(use (:: models x86 x86 RAX))
(use (:: models x86 x86 RCX))
(use (:: models x86 x86 RDX))
(use (:: models x86 x86 RSI))
(use (:: models x86 x86 RDI))
(use (:: models x86 x86 R8))
(use (:: models x86 x86 XMovRR))
(use (:: models x86 x86 XLoad8))
(use (:: models x86 x86 XStore8))
(use (:: models x86 x86 XAdd))
(use (:: models x86 x86 AReg))
(use (:: models x86 x86 SReg))
(use (:: models x86 x86 SImm))
(use (:: models x86 encode le4))
(use (:: models x86 encode le8))
(use (:: models x86 encode eapp))
(use (:: models x86 encode elen))
(use (:: models x86 encode off_at))
(use (:: models x86 encode enc_mov_imm64))
(use (:: models x86 encode enc_call_rel32))
(use (:: models x86 encode enc_push_reg))
(use (:: models x86 encode enc_pop_reg))
(use (:: models x86 encode enc_simple))
(use (:: models x86 encode enc_mov_reg_rsp8))
(use (:: models x86 encode enc_cmp_rs))
(use (:: models x86 encode enc_jcc_rel32))
(use (:: models x86 encode enc_jmp_rel32))
(use (:: models x86 encode enc_test_r))
(use (:: models x86 encode enc_bin_ri))
(use (:: models x86 linux sys_write_top8))
(use (:: models x86 linux sys_exit_code))
(use (:: models x86 linux i_syscall))

;; a harness vector: which export (natural image index) on which args
;; (1-3 values; the stub pads unused arg registers to 0 harmlessly)
(type EVec (EV Int (List Int)))

(fn load_base () Int 4194304)  ; 0x400000 — fixed-address ET_EXEC

;; per-vector stub fragment width and the trailing exit, both fixed so the
;; stub size (hence the image's placement) is computable from vector count:
;;   marshal 3x(mov r64,imm64 = 10) + call rel32 (5) + push (1)
;;     + sys_write_top8 (20) + pop (1) = 57
;;   sys_exit_code (12)
(fn frag_w () Int 57)

(fn stub_size ((nv Int)) Int (+ (* (frag_w) nv) 12))

(fn vlen ((vs (List EVec))) Int
  (measure (struct vs))
  (match vs
    (Nil 0)
    ((Cons _ t) (+ 1 (vlen t)))))

(fn catb ((xs (List (List Int)))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons h t) (eapp h (catb t)))))

(fn arg_at ((args (List Int)) (i Int)) Int
  (measure (struct args))
  (match args
    (Nil 0)
    ((Cons a t) (if (int_eq i 0) a (arg_at t (- i 1))))))

(fn off_or0 ((o (Option Int))) Int
  (match o
    (None 0)
    ((Some x) x)))

;; one vector's 57 bytes at stub offset `fs`; `ss` = stub size (the image
;; sits at region offset ss, so export k is at ss + image_offset[k])
(fn evec_frag ((v EVec) (fs Int) (ss Int) (offs (List Int))) (List Int)
  (match v
    ((EV k args)
     (catb
       (list
         (enc_mov_imm64 RDI (arg_at args 0))  ; mov rdi, a0
         (enc_mov_imm64 RSI (arg_at args 1))  ; mov rsi, a1
         (enc_mov_imm64 RDX (arg_at args 2))  ; mov rdx, a2
         (enc_call_rel32 (- (+ ss (off_or0 (off_at offs k))) (+ (+ fs 30) 5)))
         (enc_push_reg RAX)  ; push rax
         (sys_write_top8)
         (enc_pop_reg RCX))))))  ; pop rcx

(fn gen_stub ((vs (List EVec)) (fs Int) (ss Int) (offs (List Int))) (List Int)
  (measure (struct vs))
  (match vs
    (Nil (sys_exit_code 0))
    ((Cons v rest)
     (eapp (evec_frag v fs ss offs) (gen_stub rest (+ fs (frag_w)) ss offs)))))

;; the 64-byte ELF64 header: ET_EXEC, x86-64, no section headers (a static
;; image needs none to run), e_entry at the stub
(fn elf_hdr ((filesz Int)) (List Int)
  (catb
    (list
      (list 127 69 76 70 2 1 1 0)  ; magic, ELFCLASS64, LE, ver 1, SysV
      (list 0 0 0 0 0 0 0 0)  ; EI_ABIVERSION + pad
      (list 2 0)  ; e_type = ET_EXEC
      (list 62 0)  ; e_machine = x86-64
      (list 1 0 0 0)  ; e_version
      (le8 (+ (load_base) 120))  ; e_entry
      (le8 64)  ; e_phoff
      (le8 0)  ; e_shoff
      (list 0 0 0 0)  ; e_flags
      (list 64 0)  ; e_ehsize
      (list 56 0)  ; e_phentsize
      (list 1 0)  ; e_phnum
      (list 0 0)  ; e_shentsize
      (list 0 0)  ; e_shnum
      (list 0 0))))  ; e_shstrndx

;; the 56-byte program header: one PT_LOAD, R+X, whole file at LOAD_BASE
(fn elf_phdr ((filesz Int)) (List Int)
  (catb
    (list
      (list 1 0 0 0)  ; p_type = PT_LOAD
      (list 5 0 0 0)  ; p_flags = R+X
      (le8 0)  ; p_offset
      (le8 (load_base))  ; p_vaddr
      (le8 (load_base))  ; p_paddr
      (le8 filesz)  ; p_filesz
      (le8 filesz)  ; p_memsz
      (le8 4096))))  ; p_align

;; the whole executable: headers + stub + image
(fn enc_elf ((img (List Int)) (offs (List Int)) (vs (List EVec))) (List Int)
  (let ((ss (stub_size (vlen vs))))
    (let ((code (eapp (gen_stub vs 0 ss offs) img)))
      (let ((filesz (+ 120 (elen code))))
        (eapp (elf_hdr filesz) (eapp (elf_phdr filesz) code))))))

;; ============================================================================
;; THE BIN RUNG — a plainly-executable Linux ELF (docs/X86.md §21/§22)
;; ============================================================================
;;
;; enc_binelf wraps a cert-tied index-order IMAGE in an argv `_start` GLUE and
;; a two-segment ELF64, producing a binary a user runs directly: `./arglen
;; hello` exits with the entry's result. The glue is BYTE-MOVING PLUMBING —
;; untrusted like enc_elf and the shims' USE sites — but its behaviour is a
;; SIGNED TRUST STATEMENT, because a bin's proven entry receives its arguments
;; FROM the glue. That statement is the contract below.
;;
;; ----------------------------------------------------------------------------
;; THE GLUE CONTRACT (user-ratified 2026-07-08, the bin boundary)
;; ----------------------------------------------------------------------------
;; A bin's cert-premise surface must be EXACTLY what this contract supplies —
;; no more (the accepts gate's bin arm enforces it against `glue_fams`). The
;; clauses:
;;
;;   1. ENTRY STATE (trusted like the shims). The process starts under the
;;      Linux x86_64 SysV entry ABI: [rsp] = argc, the argv pointers follow at
;;      [rsp+8], [rsp+16], …, and every argv string is NUL-terminated. This is
;;      the kernel's `_start` contract; the glue is its sole consumer.
;;
;;   2. RW SEGMENT. [0x600000, 0x601000) (4096 bytes) is mapped read-write and
;;      kernel-zero-filled at load (PT_LOAD #2, p_filesz 0, p_memsz 4096).
;;
;;   3. PAYLOAD. On entry the glue writes the first min(|argv[1]|, 255) bytes of
;;      argv[1] to 0x600000; every byte beyond the payload up to the segment top
;;      (0x601000) remains zero (clause 2). An absent argv[1] (argc < 2) is the
;;      empty payload — the glue copies nothing and holds count = 0 (there is NO
;;      exit-1 leg: absent argument is a value, not an error).
;;
;;   4. CALL. The entry is called with rdi = 0x600000 (the payload base) and
;;      rsi = the payload length (0..255). MODEL ADDRESSES ARE PROCESS ADDRESSES:
;;      this is the permanent home of X86.md §15's range dispensation — the A1
;;      rung's address-bounds premises will cite THIS clause together with clause
;;      2 (the payload lives in the mapped, zeroed RW page).
;;
;;   5. TERMINATION — one of two BUILD-SELECTED variants. The driver picks the
;;      variant by the entry's DECLARED RETURN TYPE (which encoder it invokes): an
;;      Int-returning entry gets 5a (enc_binelf), a Mem-returning entry gets 5b
;;      (enc_binelf_w). Exactly one variant is compiled into any given binary.
;;
;;      5a. EXIT variant (Int entry, enc_binelf). The process terminates with
;;          sys_exit(entry's result); the exit code the shell observes is the low
;;          8 bits (kernel truncation of the status). The derived plan refuses any
;;          expected exit outside [0, 256), so the truncation is never load-bearing
;;          in a signed expectation.
;;
;;      5b. WRITE variant (Mem entry, enc_binelf_w). The glue IGNORES the entry's
;;          rax and instead does sys_write(1, 0x600000, len) then sys_exit(0),
;;          where len is the clause-3 payload length (0..255). The glue PRESERVES
;;          len across the call by its OWN stack (push before the `call`, pop
;;          after) — nothing in a register is assumed to survive the entry's
;;          arbitrary clobbers. The write is a SINGLE syscall whose result is
;;          UNCHECKED (SIGNED CAVEAT, v1: len <= 255 <= PIPE_BUF, so the kernel
;;          completes it in one shot; a short write would silently truncate stdout
;;          — acceptable only under this length bound). A no-arg run (clause 3,
;;          len = 0) writes zero bytes then exits 0 — NOT special-cased, keeping
;;          the no-branch spirit.
;;
;;   6. THE LAW. The glue MOVES bytes — it never interprets them. Copy, marshal
;;      into the SysV arg registers, exit, or sys_write the payload page back out
;;      (5b is a byte MOVE from 0x600000 to fd 1, never a computation on the
;;      bytes): nothing else. Any logic beyond that (parsing, branching on payload
;;      content, arithmetic on the bytes) is a contract VIOLATION, to be caught in
;;      review of this one file.
;;
;;   THE TWO-ARGUMENT GLUE (enc_binelf2; X86.md §42, sanctioned by §36(b) —
;;   argv[2] joins the window contract as INPUT growth; the §30 re-cut bars new
;;   OUTPUT variants, not this). Clauses 1, 2, 3, 6 and termination 5a hold
;;   verbatim; the growth is clauses 3-4 said TWICE (two window pairs on the
;;   same RW page), primed so the existing clause numbers keep their citations:
;;
;;   3'. PAYLOAD 2. The glue also writes the first min(|argv[2]|, 255) bytes of
;;       argv[2] (read at [rsp+24], clause 1) to BUF2 = 0x600100 (= 0x600000 +
;;       256, inside the clause-2 segment). Zeros hold beyond EACH payload:
;;       payload 1's length is <= 255 < 256 so it can never reach BUF2, hence
;;       [0x600000+len1, 0x600100) and [0x600100+len2, 0x601000) remain kernel-
;;       zero. An absent argv[2] (argc < 3) is the empty payload, len2 = 0 —
;;       same as clause 3, the glue has NO policy, and there is no exit-1 leg.
;;
;;   4'. CALL. The entry is called with rdi = 0x600000 (payload 1 base), rsi =
;;       len1, rdx = 0x600100 (payload 2 base), rcx = len2 (each len 0..255).
;;       Clause 4's address dispensation covers both windows.
;;
;;   SELECTION is BY THE ENTRY'S MACHINE ARITY, decided by the CALLER
;;   (tools/lowbuild): a 2-register entry (rdi, rsi) gets the one-arg glue, a
;;   4-register entry gets enc_binelf2. The encoders themselves stay arity-
;;   blind — each emits its fixed glue and never inspects the image. There is
;;   no two-arg WRITE variant (no consumer demands one; termination growth is
;;   what the §30 re-cut forecloses).
;; ----------------------------------------------------------------------------

(fn bin_data_base () Int 6291456)  ; 0x600000 — the RW payload segment (clause 2)

(fn bin_data_size () Int 4096)  ; zero-filled bytes reserved at bin_data_base

(fn bin_maxlen () Int 255)  ; copy-loop length cap (clause 3)

(fn bin_buf2 () Int (+ (bin_data_base) 256))  ; 0x600100 — payload 2 base (clause 3')

(fn bin_hdrs_sz () Int 176)  ; 64 (ELF header) + 2*56 (two program headers)

;; The `_start` glue, hand-laid at fixed widths so every displacement is a
;; computable constant (the flattening's foundation — see encode.shard). The
;; byte offset from glue start annotates each instruction; a jump's rel32 is
;; (target offset) - (this instruction's end). Both termination variants (5a/5b)
;; share bin_glue_pre — the entry-state read, the payload copy loop, and the
;; SysV arg marshalling — and diverge only in the tail after the `call`.
;;
;; bin_glue_pre: entry-ABI read + copy loop + arg marshalling, ending with the
;; entry's args in place (rdi = base, rsi = len) at glue offset 111. Landmarks:
;; loop_start = 43, after_loop = 98. It is self-contained (all its jumps target
;; 43 or 98, both inside it) and carries NO `call`, so both tails append cleanly.
(fn bin_glue_pre () (List Int)
  (catb
    (list
      (enc_mov_reg_rsp8 RAX 0)  ; 0    mov rax,[rsp]         argc
      (enc_mov_imm64 RCX 0)  ; 5    mov rcx,0            count = 0
      (enc_cmp_rs RAX (SImm 2))  ; 15   cmp rax,2
      (enc_jcc_rel32 130 70)  ; 22   jb +70 -> 98 (argc<2: empty payload)
      (enc_mov_reg_rsp8 RSI 16)  ; 28   mov rsi,[rsp+16]     src = argv[1]
      (enc_mov_imm64 RDI (bin_data_base))  ; 33   mov rdi,0x600000    dest
      ;; loop_start = 43
      (enc_cmp_rs RCX (SImm (bin_maxlen)))  ; 43   cmp rcx,255
      (enc_jcc_rel32 131 42)  ; 50   jae +42 -> 98 (MAXLEN cap, clause 3)
      (enc_simple (XLoad8 RDX (AReg RSI)))  ; 56   movzx rdx,byte[rsi]
      (enc_test_r RDX)  ; 60   test rdx,rdx
      (enc_jcc_rel32 132 29)  ; 63   jz +29 -> 98 (NUL terminator, clause 1)
      (enc_simple (XStore8 (AReg RDI) (SReg RDX)))  ; 69   mov [rdi],dl
      (enc_bin_ri XAdd RSI 1)  ; 72   add rsi,1
      (enc_bin_ri XAdd RDI 1)  ; 79   add rdi,1
      (enc_bin_ri XAdd RCX 1)  ; 86   add rcx,1
      (enc_jmp_rel32 -55)  ; 93   jmp -55 -> 43 (loop_start)
      ;; after_loop = 98
      (enc_mov_imm64 RDI (bin_data_base))  ; 98   mov rdi,0x600000    arg0 = base
      (enc_simple (XMovRR RSI RCX)))))  ; 108  mov rsi,rcx          arg1 = count

;; 5a EXIT variant. Tail after the prefix: call the entry, then sys_exit(rax).
;; glue length = 131, so the image begins at glue offset 131 and `call` (at 111,
;; ending 116) reaches the entry (at image offset `entry_off`) with rel32 =
;; (131 + entry_off) - 116 = 15 + entry_off.
(fn bin_glue ((entry_off Int)) (List Int)
  (eapp
    (bin_glue_pre)
    (catb
      (list
        (enc_call_rel32 (+ 15 entry_off))  ; 111  call entry (clause 4)
        (enc_simple (XMovRR RDI RAX))  ; 116  mov rdi,rax          exit arg = result
        (enc_mov_imm64 RAX 60)  ; 119  mov rax,60           sys_exit nr
        (i_syscall)))))  ; 129  syscall (clause 5a)  (ends at 131)

;; 5b WRITE variant. Tail after the prefix: PUSH len (rcx) so it survives the
;; entry's arbitrary clobbers, call the entry, POP len into rdx, then a single
;; sys_write(1, 0x600000, len) and sys_exit(0) — the entry's rax is ignored.
;; glue length = 172, so the image begins at glue offset 172 and `call` (at 112,
;; ending 117) reaches the entry with rel32 = (172 + entry_off) - 117 =
;; 55 + entry_off.
(fn bin_glue_w ((entry_off Int)) (List Int)
  (eapp
    (bin_glue_pre)
    (catb
      (list
        (enc_push_reg RCX)  ; 111  push rcx             preserve len (clause 5b)
        (enc_call_rel32 (+ 55 entry_off))  ; 112  call entry (clause 4)
        (enc_pop_reg RDX)  ; 117  pop rdx              len restored across the call
        (enc_mov_imm64 RDI 1)  ; 118  mov rdi,1            fd = stdout
        (enc_mov_imm64 RSI (bin_data_base))  ; 128  mov rsi,0x600000     buf = base
        (enc_mov_imm64 RAX 1)  ; 138  mov rax,1            sys_write nr
        (i_syscall)  ; 148  syscall              write(1,base,len)
        (enc_mov_imm64 RDI 0)  ; 150  mov rdi,0            exit code 0 (clause 5b)
        (enc_mov_imm64 RAX 60)  ; 160  mov rax,60           sys_exit nr
        (i_syscall)))))  ; 170  syscall (clause 5b)  (ends at 172)

;; One parametric argv copy loop for the TWO-ARG glue — the exact instruction
;; shape of bin_glue_pre's loop (bytes 5..98 there), with the three per-payload
;; constants lifted out: `argmin` (the argc bound below which the payload is
;; empty), `rspoff` (the argv pointer's [rsp+k] home, clause 1), `dest` (the
;; payload base). Expects argc in rax (preserved: the loop clobbers only
;; rcx/rsi/rdi/rdx) and leaves rcx = the payload length. Fixed width 93; it is
;; SELF-CONTAINED (every jump targets local 38 or the local end 93), so the
;; branch displacements are position-independent constants — identical at both
;; of bin_glue2's instantiation offsets. Local offsets annotate each line.
(fn bin_copy_loop ((argmin Int) (rspoff Int) (dest Int)) (List Int)
  (catb
    (list
      (enc_mov_imm64 RCX 0)  ; 0    mov rcx,0            count = 0
      (enc_cmp_rs RAX (SImm argmin))  ; 10   cmp rax,argmin
      (enc_jcc_rel32 130 70)  ; 17   jb +70 -> 93 (absent arg: empty payload)
      (enc_mov_reg_rsp8 RSI rspoff)  ; 23   mov rsi,[rsp+rspoff]  src
      (enc_mov_imm64 RDI dest)  ; 28   mov rdi,dest
      ;; loop_start = 38
      (enc_cmp_rs RCX (SImm (bin_maxlen)))  ; 38   cmp rcx,255
      (enc_jcc_rel32 131 42)  ; 45   jae +42 -> 93 (MAXLEN cap, clause 3)
      (enc_simple (XLoad8 RDX (AReg RSI)))  ; 51   movzx rdx,byte[rsi]
      (enc_test_r RDX)  ; 55   test rdx,rdx
      (enc_jcc_rel32 132 29)  ; 58   jz +29 -> 93 (NUL terminator, clause 1)
      (enc_simple (XStore8 (AReg RDI) (SReg RDX)))  ; 64   mov [rdi],dl
      (enc_bin_ri XAdd RSI 1)  ; 67   add rsi,1
      (enc_bin_ri XAdd RDI 1)  ; 74   add rdi,1
      (enc_bin_ri XAdd RCX 1)  ; 81   add rcx,1
      (enc_jmp_rel32 -55))))  ; 88   jmp -55 -> 38 (loop_start)  (ends at 93)

;; TWO-ARG glue (clauses 3'/4', termination 5a verbatim). Copy loop 1 fills
;; BUF1 from argv[1] ([rsp+16]) leaving rcx = len1, stashed to r8 across copy
;; loop 2 (which clobbers rcx/rsi/rdi/rdx but not rax/r8); copy loop 2 fills
;; BUF2 from argv[2] ([rsp+24]) leaving rcx = len2, which then rides UNTOUCHED
;; through the marshalling into the call (clause 4'). It does not reuse
;; bin_glue_pre (whose one-arg marshal tail is baked in) — bin_copy_loop
;; restates the loop both glues share. glue length = 237, so the image begins
;; at glue offset 237 and `call` (at 217, ending 222) reaches the entry with
;; rel32 = (237 + entry_off) - 222 = 15 + entry_off — the SAME +15 as 5a,
;; because the call-to-image gap (the 20-byte 5a exit tail) is unchanged.
(fn bin_glue2 ((entry_off Int)) (List Int)
  (catb
    (list
      (enc_mov_reg_rsp8 RAX 0)  ; 0    mov rax,[rsp]        argc (both guards)
      (bin_copy_loop 2 16 (bin_data_base))  ; 5    argv[1] -> BUF1; rcx = len1
      (enc_simple (XMovRR R8 RCX))  ; 98   mov r8,rcx           stash len1
      (bin_copy_loop 3 24 (bin_buf2))  ; 101  argv[2] -> BUF2; rcx = len2
      (enc_mov_imm64 RDI (bin_data_base))  ; 194  mov rdi,0x600000    arg0 = BUF1
      (enc_simple (XMovRR RSI R8))  ; 204  mov rsi,r8           arg1 = len1
      (enc_mov_imm64 RDX (bin_buf2))  ; 207  mov rdx,0x600100    arg2 = BUF2 (rcx = len2 = arg3)
      (enc_call_rel32 (+ 15 entry_off))  ; 217  call entry (clause 4')
      (enc_simple (XMovRR RDI RAX))  ; 222  mov rdi,rax          exit arg = result
      (enc_mov_imm64 RAX 60)  ; 225  mov rax,60           sys_exit nr
      (i_syscall))))  ; 235  syscall (clause 5a)  (ends at 237)

;; 64-byte ELF header: ET_EXEC, x86-64, TWO program headers, entry at the glue
;; (first code after the headers).
(fn bin_elf_hdr () (List Int)
  (catb
    (list
      (list 127 69 76 70 2 1 1 0)  ; magic, ELFCLASS64, LE, ver 1, SysV
      (list 0 0 0 0 0 0 0 0)  ; EI_ABIVERSION + pad
      (list 2 0)  ; e_type = ET_EXEC
      (list 62 0)  ; e_machine = x86-64
      (list 1 0 0 0)  ; e_version
      (le8 (+ (load_base) (bin_hdrs_sz)))  ; e_entry = glue start
      (le8 64)  ; e_phoff
      (le8 0)  ; e_shoff
      (list 0 0 0 0)  ; e_flags
      (list 64 0)  ; e_ehsize
      (list 56 0)  ; e_phentsize
      (list 2 0)  ; e_phnum = 2
      (list 0 0)  ; e_shentsize
      (list 0 0)  ; e_shnum
      (list 0 0))))  ; e_shstrndx

;; program header 1: PT_LOAD, R+X, the whole file at load_base.
(fn bin_phdr_code ((filesz Int)) (List Int)
  (catb
    (list
      (list 1 0 0 0)  ; p_type = PT_LOAD
      (list 5 0 0 0)  ; p_flags = R+X
      (le8 0)  ; p_offset
      (le8 (load_base))  ; p_vaddr
      (le8 (load_base))  ; p_paddr
      (le8 filesz)  ; p_filesz
      (le8 filesz)  ; p_memsz
      (le8 4096))))  ; p_align

;; program header 2: PT_LOAD, RW, a zero-filled BSS segment at bin_data_base
;; (clause 2; p_filesz = 0, p_memsz = bin_data_size, p_vaddr ≡ p_offset mod 4096).
(fn bin_phdr_data () (List Int)
  (catb
    (list
      (list 1 0 0 0)  ; p_type = PT_LOAD
      (list 6 0 0 0)  ; p_flags = R+W
      (le8 0)  ; p_offset
      (le8 (bin_data_base))  ; p_vaddr
      (le8 (bin_data_base))  ; p_paddr
      (le8 0)  ; p_filesz = 0 (no file bytes)
      (le8 (bin_data_size))  ; p_memsz = zero-filled reserve
      (le8 4096))))  ; p_align

;; the plainly-executable binary: [ELF hdr:64][phdr0:56][phdr1:56][glue][image].
;; e_entry = load_base + 176 (the glue); the entry function sits at glue offset
;; 131 + entry_off, reached by the glue's `call`.
(fn enc_binelf ((image (List Int)) (entry_off Int)) (List Int)
  (let ((code (eapp (bin_glue entry_off) image)))
    (let ((filesz (+ (bin_hdrs_sz) (elen code))))
      (eapp
        (bin_elf_hdr)
        (eapp (bin_phdr_code filesz) (eapp (bin_phdr_data) code))))))

;; the WRITE-variant binary (clause 5b): same layout, addresses, and PT_LOADs as
;; enc_binelf — only the glue tail differs (bin_glue_w). The driver invokes THIS
;; encoder for a Mem-returning entry; the produced binary sys_writes the payload
;; page to stdout and exits 0.
(fn enc_binelf_w ((image (List Int)) (entry_off Int)) (List Int)
  (let ((code (eapp (bin_glue_w entry_off) image)))
    (let ((filesz (+ (bin_hdrs_sz) (elen code))))
      (eapp
        (bin_elf_hdr)
        (eapp (bin_phdr_code filesz) (eapp (bin_phdr_data) code))))))

;; the TWO-ARG exit-variant binary (clauses 3'/4'): same layout, addresses, and
;; PT_LOADs as enc_binelf — only the glue differs (bin_glue2, 237 bytes; the
;; entry function sits at glue offset 237 + entry_off). The CALLER selects this
;; encoder by the entry's machine arity (4 registers, tools/lowbuild); the
;; encoder itself is arity-blind.
(fn enc_binelf2 ((image (List Int)) (entry_off Int)) (List Int)
  (let ((code (eapp (bin_glue2 entry_off) image)))
    (let ((filesz (+ (bin_hdrs_sz) (elen code))))
      (eapp
        (bin_elf_hdr)
        (eapp (bin_phdr_code filesz) (eapp (bin_phdr_data) code))))))
