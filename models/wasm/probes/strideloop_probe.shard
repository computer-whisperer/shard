;;; strideloop_probe.shard — the STRIDE ≠ 1 loop probe (docs/LOWERING.md
;;; §7.7 residue). Hand-plays the unconditional Mem-return template
;;; (lgw_lp_fill's shape) at a LITERAL stride of 4 — the cell-tag fill
;;; (set the first byte of each 4-byte cell): the uniform-rep runway
;;; shape.
;;;
;;; What changes against stride 1:
;;;   1. THE SCALED RANGE PREMISE: the advancing accum's group-B premise
;;;      becomes (le (+ x (* C (int_of_nat k))) 65536) — the literal C
;;;      rides the spelling, so farkas stays linear (atoms are x and the
;;;      int_of_nat terms; C is a coefficient).
;;;   2. PER-STRIDE HELPER CERTS: loopkit's stride-1 helpers (lg_a1_ms /
;;;      lg_lo1 / lg_32 / lg_kM / lg_shift) are template CONSTANTS; a
;;;      stride-C accum needs the C-scaled instances. Their farkas lists
;;;      are closed formulas in C (mined here at C=4, verified by the
;;;      kernel like any cert):
;;;        guard upper  (le (+ a 1)  65536)   <- (list 1 1 C C)
;;;        advance upper(le (+ a C)  65536)   <- (list 1 1 C C)
;;;        advance lo   (le 0 (+ x C))        <- (list 1 1)
;;;        advance 32   (lt (+ x C) 2^32)     <- (list 1 1)
;;;        counter wrap (lt n 2^32)           <- (list C 1 C 1)
;;;        IH shift     ((x+C) + C*n <= w)    <- (list 1 1 C)
;;;   3. THE STRIDE TWIN: exit local = (sk_adv x C k) — lg_adv with the
;;;      stride as an argument (the loopkit-graduation candidate).
;;; Everything else — stage order, wrap haves, IH discharge shape, fuel
;;; S^(instrs+4)/+4 — is the stride-1 template verbatim.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(import "../../../std/nat.shard")
(import "../wasm.shard")
(import "../loopkit.shard")
(use (:: std mem *))
(use (:: std nat *))
(use (:: models wasm wasm *))
(use (:: models wasm loopkit *))

;; the source article: stamp v at the head byte of each of k 4-byte cells
(fn sk_tag ((m Mem) (d Int) (v Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (sk_tag (mem_set m d v) (+ d 4) v k2))))

;; the stride twin: final position of a stride-s accum after k iterations
(fn sk_adv ((x Int) (s Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z x)
    ((S k2) (sk_adv (+ x s) s k2))))

;; --- the C=4 helper kit (farkas lists = the closed formulas at C=4) ---------

;; store guard, upper: a + 4*(S c) <= 65536  |-  a + 1 <= 65536
(claim skc_a1ms
  (goal ((a Int) (c Nat))
    ((= (le (+ a (* 4 (int_of_nat (S c)))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 (int_of_nat c)) True))
    (= (le (+ a 1) 65536) True))
  (by arith (list 1 1 4 4)))

;; advance, upper: a + 4*(S c) <= 65536  |-  a + 4 <= 65536
(claim skc_ac
  (goal ((a Int) (c Nat))
    ((= (le (+ a (* 4 (int_of_nat (S c)))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 (int_of_nat c)) True))
    (= (le (+ a 4) 65536) True))
  (by arith (list 1 1 4 4)))

;; advance, lower: 0 <= x  |-  0 <= x + 4
(claim skc_lo
  (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (+ x 4)) True))
  (by arith (list 1 1)))

;; advance, wrap bound: x + 4 <= 65536  |-  x + 4 < 2^32
(claim skc_32
  (goal ((x Int)) ((= (le (+ x 4) 65536) True))
    (= (lt (+ x 4) 4294967296) True))
  (by arith (list 1 1)))

;; counter wrap: the scaled range still caps the counter below 2^32
(claim skc_kM
  (goal ((a Int) (c Nat))
    ((= (le (+ a (* 4 (int_of_nat (S c)))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 a) True))
    (= (lt (int_of_nat c) 4294967296) True))
  (by arith (list 4 1 4 1)))

;; range premise steps to the IH: b + 4*(S c) <= w  |-  (b+4) + 4*c <= w
(claim skc_shift
  (goal ((b Int) (w Int) (c Nat))
    ((= (le (+ b (* 4 (int_of_nat (S c)))) w) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c))))
    (= (le (+ (+ b 4) (* 4 (int_of_nat c))) w) True))
  (by arith (list 1 1 4)))

;; --- the machine body: budget guard / store / d += 4 / k -= 1 / loop --------

(fn sk_tag_body () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 0)
    (LocalGet 1)
    (I32Store8)
    (LocalGet 0)
    (I32Const 4)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn sk_tag_func () Func
  (MkFunc 3 0 (list (Block (list (Loop (sk_tag_body)))) (I32Const 0))))

;; --- the worker induction ----------------------------------------------------------

(claim skw_sk_tag
  (goal
    ((x0 Int)
     (x1 Int)
     (st (List Int))
     (m0 Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 x0) True) (= (le (+ x0 (* 4 (int_of_nat k))) 65536) True))
    (=
      (eval_loop
        (S^ 19 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline sk_tag_body)))) (I32Const 0)))
            restfs)
          65536)
        (inline sk_tag_body)
        (list x0 x1 (int_of_nat k))
        st
        m0)
      (Some (OBr 0 st (list (sk_adv x0 4 k) x1 0) (sk_tag m0 x0 x1 k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold eval_loop lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop eval_loop lg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma skc_a1ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop eval_loop lg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma skc_kM)
                lr
                lhs
                ((inst a x0) (inst c k2))
                ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hw0 (= (mod (+ x0 4) 4294967296) (+ x0 4))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ x0 4)))
             ((rewrite-with
                (lemma skc_lo)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma skc_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma skc_ac)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hw0) lr lhs true ())))
         (steps ((unfold sk_tag rhs) (unfold sk_adv rhs) (reduce rhs)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma skc_lo)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma skc_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps ((compute both)))
         refl)))))

;; --- the lowered theorem ------------------------------------------------------------

(claim lowered_sk_tag
  (goal ((x0 Int) (x1 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 x0) True) (= (le (+ x0 (* 4 (int_of_nat k))) 65536) True))
    (=
      (call_fn_mem
        (S^ 23 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline sk_tag_body)))) (I32Const 0)))
            restfs)
          65536)
        0
        (list x0 x1 (int_of_nat k))
        m0)
      (Some (Pair 0 (sk_tag m0 x0 x1 k)))))
  (chain
    (steps ((compute lhs (stop eval_loop lg_fuel))))
    (rewrite-with
      (lemma skw_sk_tag)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))
