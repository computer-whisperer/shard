;;; examples/wasm_rev.shard — the Mem arc demonstrator: an IN-PLACE wasm
;;; algorithm proven down from the functional spec (docs/ISA.md §10, M3
;;; redux at the real ISA).
;;;
;;; The piece: rev8 (slot 0) — two-pointer byte reverse over linear memory,
;;; swapping ends inward while i < j (params i, j = INCLUSIVE end addresses).
;;; The theorem chain, composition = citation:
;;;   rev_loop_worker — the loop body simulates examples/mem_reverse's
;;;     rev_loop step for step (memory framing through std/mem's opaque
;;;     surface; the swap chain falls out of the interpreter SYNTACTICALLY);
;;;   rev8_thm — the call_fn_mem piece theorem: rev8's final memory IS
;;;     (rev_loop mm i j k);
;;;   rev8_reverses — cite mem_reverse's capstone: load a byte list, run the
;;;     BINARY-shaped piece, dump — you get (rev xs). spec ⊑ wasm, with the
;;;     in-place step at the ISA level.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")  ; Mem — the opaque substrate the model threads
(import "../../../std/nat.shard")  ; int_of_nat / half_nat lemmas (the bounds)
(import "../../../examples/mem_reverse.shard")  ; swap / rev_loop / byte_ok / the M3 theory
(import "../../../std/list.shard")  ; rev — the functional spec the capstone reaches
(import "../../../std/arith.shard")  ; sub_zero — the capstone's bound reshuffle
(import "../wasm.shard")
(use (:: std mem *))
(use (:: std nat *))
(use (:: std list rev))
(use (:: std arith sub_zero))
(use (:: examples mem_reverse *))
(use (:: models wasm wasm *))

;; --- the piece -------------------------------------------------------------------

;; loop body: guard (exit when NOT i < j), read m[i] and m[j] BEFORE either
;; store, store m[j] at i then m[i] at j (this order makes the interpreter's
;; memory residue exactly mem_reverse's swap chain), advance the pointers,
;; re-enter. Pointer arithmetic wraps (the model's BAdd/BSub) — the worker
;; cleans it with wrap32_id under the segment bounds.
(fn rev_body () (List Instr)
  (list
    (LocalGet 0)
    (LocalGet 1)
    (I32Bin BLtU)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (LocalGet 0)
    (I32Load8U)
    (LocalGet 0)
    (LocalGet 1)
    (I32Load8U)
    (I32Store8)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 1)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 1)
    (Br 0)))

(fn prev () Func
  (MkFunc 2 0 (list (Block (list (Loop (rev_body)))) (I32Const 0))))

;; one 64KiB page of memory — the segment bound every guard checks against.
(fn rmod () WModule (MkWModule (list (prev)) 65536))

;; --- spec twins (transparent; unfold one guarded step per iteration) --------------

;; the pointers' final positions, counter-indexed like rev_loop (the counter
;; carries structural termination, the guard carries correctness).
(fn fi ((i Int) (j Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z i)
    ((S k2) (if (lt i j) (fi (+ i 1) (- j 1) k2) i))))

(fn fj ((i Int) (j Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z j)
    ((S k2) (if (lt i j) (fj (+ i 1) (- j 1) k2) j))))

;; --- fuel ------------------------------------------------------------------------

;; one S per remaining loop iteration over the slack tail; the concrete
;; budget for a body pass rides OUTSIDE (the worker's S^26 prefix — fuel is
;; a depth bound, and one pass of the 22-instruction body plus the barrel
;; into the next guard needs 26).
(fn pf_rev ((k Nat) (c Nat)) Nat
  (measure (struct k))
  (match k
    (Z c)
    ((S k2) (S (pf_rev k2 c)))))

;; the worker's fuel shape behind an opaque head, so a caller's compute
;; STOPS at the citable (eval_loop …) redex instead of barreling into the
;; first iteration; callers unfold it right before citing the worker.
(fn pf_body ((k Nat) (c Nat)) Nat
  (if (lt (int_of_nat k) 0) c
  (S
    (S
      (S
        (S
          (S
            (S
              (S
                (S
                  (S
                    (S
                      (S
                        (S
                          (S
                            (S
                              (S
                                (S
                                  (S
                                    (S
                                      (S
                                        (S
                                          (S
                                            (S (S (S (S (S (S (pf_rev k c))))))))))))))))))))))))))))))

;; --- arithmetic helpers (single farkas facts) --------------------------------------

;; segment bounds for the four memory guards, from 0<=i, i<j, j<65536.
(claim h_le0j
  (goal ((i Int) (j Int)) ((= (le 0 i) True) (= (lt i j) True))
    (= (le 0 j) True))
  (by arith (list 1 1 1)))

(claim h_i1_ms
  (goal ((i Int) (j Int)) ((= (lt i j) True) (= (lt j 65536) True))
    (= (le (+ i 1) 65536) True))
  (by arith (list 1 1 1)))

(claim h_j1_ms
  (goal ((j Int)) ((= (lt j 65536) True)) (= (le (+ j 1) 65536) True))
  (by arith (list 1 1)))

;; pointer-advance ranges for the wrap32 cleanups and the IH premises.
(claim h_i1_lo
  (goal ((i Int)) ((= (le 0 i) True)) (= (le 0 (+ i 1)) True))
  (by arith (list 1 1)))

(claim h_i1_32
  (goal ((i Int) (j Int)) ((= (lt i j) True) (= (lt j 65536) True))
    (= (lt (+ i 1) 4294967296) True))
  (by arith (list 1 1 1)))

(claim h_j1_lo
  (goal ((i Int) (j Int)) ((= (le 0 i) True) (= (lt i j) True))
    (= (le 0 (- j 1)) True))
  (by arith (list 1 1 1)))

(claim h_j1_32
  (goal ((j Int)) ((= (lt j 65536) True)) (= (lt (- j 1) 4294967296) True))
  (by arith (list 1 1)))

(claim h_j1_ms2
  (goal ((j Int)) ((= (lt j 65536) True)) (= (lt (- j 1) 65536) True))
  (by arith (list 1 1)))

;; exhausted counter forces crossed pointers: (j-i) <= 2*0 |- NOT i<j.
(claim h_cross
  (goal ((i Int) (j Int))
    ((= (le (- j i) (* 2 (int_of_nat Z))) True) (= (int_of_nat Z) 0))
    (= (lt i j) False))
  (by arith (list 1 1 -2)))

(claim h_negk
  (goal ((k Nat)) ((= (le 0 (int_of_nat k)) True))
    (= (lt (int_of_nat k) 0) False))
  (by arith (list 1 1)))

(claim if_false_nat (goal ((x Nat) (y Nat)) () (= (if False x y) y)) auto)

;; --- the loop worker ---------------------------------------------------------------

;; ∀ i j st mm: entering the loop engine with pointers (i, j) in-segment,
;; any stack, any memory, and fuel S^26(pf_rev k c) where k covers the
;; remaining iterations ((j-i) <= 2k — rev_loop_mirror's completion bound),
;; exits via the BrIf branch with the pointers at their final positions,
;; the stack untouched, and the memory EXACTLY (rev_loop mm i j k).
(claim rev_loop_worker
  (goal
    ((i Int)
     (j Int)
     (st (List Int))
     (mm Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 i) True)
     (= (lt j 65536) True)
     (= (le (- j i) (* 2 (int_of_nat k))) True))
    (=
      (eval_loop
        (S
          (S
            (S
              (S
                (S
                  (S
                    (S
                      (S
                        (S
                          (S
                            (S
                              (S
                                (S
                                  (S
                                    (S
                                      (S
                                        (S
                                          (S
                                            (S
                                              (S
                                                (S
                                                  (S
                                                    (S (S (S (S (pf_rev k c)))))))))))))))))))))))))))
        (MkWModule
          (Cons
            (MkFunc
              2
              0
              (list
                (Block
                  (list
                    (Loop
                      (list
                        (LocalGet 0)
                        (LocalGet 1)
                        (I32Bin BLtU)
                        (I32Eqz)
                        (BrIf 1)
                        (LocalGet 1)
                        (LocalGet 0)
                        (I32Load8U)
                        (LocalGet 0)
                        (LocalGet 1)
                        (I32Load8U)
                        (I32Store8)
                        (I32Store8)
                        (LocalGet 0)
                        (I32Const 1)
                        (I32Bin BAdd)
                        (LocalSet 0)
                        (LocalGet 1)
                        (I32Const 1)
                        (I32Bin BSub)
                        (LocalSet 1)
                        (Br 0)))))
                (I32Const 0)))
            restfs)
          65536)
        (list
          (LocalGet 0)
          (LocalGet 1)
          (I32Bin BLtU)
          (I32Eqz)
          (BrIf 1)
          (LocalGet 1)
          (LocalGet 0)
          (I32Load8U)
          (LocalGet 0)
          (LocalGet 1)
          (I32Load8U)
          (I32Store8)
          (I32Store8)
          (LocalGet 0)
          (I32Const 1)
          (I32Bin BAdd)
          (LocalSet 0)
          (LocalGet 1)
          (I32Const 1)
          (I32Bin BSub)
          (LocalSet 1)
          (Br 0))
        (list i j)
        st
        mm)
      (Some (OBr 0 st (list (fi i j k) (fj i j k)) (rev_loop mm i j k)))))
  (induct k
    ((case Z
       (steps
         ((compute lhs))
         (have hg (= (lt i j) False)
           (rewrite-with
             (lemma h_cross)
             lr
             lhs
             ((inst i i) (inst j j))
             ((steps ((rewrite (premise 2) lr lhs true ())) refl)
              (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ())) refl))
             refl)
           (steps ((rewrite (premise hg) lr lhs true ()) (compute both)) refl))))
     (case S
       (k2)
       (case-on (lt i j) Bool
         ((case False
            (steps
              ((unfold pf_rev lhs)
               (reduce lhs)
               (compute both)
               (rewrite (hyp 0) lr both true ())
               (compute both))
              refl))
          (case True
            (steps
              ((unfold pf_rev lhs)
               (reduce lhs)
               (compute lhs)
               (rewrite (hyp 0) lr lhs true ())
               (compute lhs)
               (rewrite (premise 0) lr lhs true ())
               (compute lhs))
              (rewrite-with
                (lemma h_i1_ms)
                lr
                lhs
                ((inst j j))
                ((steps ((rewrite (hyp 0) lr lhs true ())) refl)
                 (steps ((rewrite (premise 1) lr lhs true ())) refl))
                (steps
                  ((compute lhs))
                  (rewrite-with
                    (lemma h_le0j)
                    lr
                    lhs
                    ((inst i i))
                    ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                     (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                    (steps
                      ((compute lhs))
                      (rewrite-with
                        (lemma h_j1_ms)
                        lr
                        lhs
                        ()
                        ((steps ((rewrite (premise 1) lr lhs true ())) refl))
                        (steps
                          ((compute lhs)
                           (rewrite (premise 0) lr lhs true ())
                           (compute lhs))
                          (rewrite-with
                            (lemma h_i1_ms)
                            lr
                            lhs
                            ((inst j j))
                            ((steps ((rewrite (hyp 0) lr lhs true ())) refl)
                             (steps ((rewrite (premise 1) lr lhs true ())) refl))
                            (steps
                              ((compute lhs))
                              (rewrite-with
                                (lemma h_le0j)
                                lr
                                lhs
                                ((inst i i))
                                ((steps
                                   ((rewrite (premise 0) lr lhs true ()))
                                   refl)
                                 (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                                (steps
                                  ((compute lhs))
                                  (rewrite-with
                                    (lemma h_j1_ms)
                                    lr
                                    lhs
                                    ()
                                    ((steps
                                       ((rewrite (premise 1) lr lhs true ()))
                                       refl))
                                    (steps
                                      ((compute lhs))
                                      (have hw1
                                        (= (mod (+ i 1) 4294967296) (+ i 1))
                                        (rewrite-with
                                          (lemma wrap32_id)
                                          lr
                                          lhs
                                          ((inst x (+ i 1)))
                                          ((rewrite-with
                                             (lemma h_i1_lo)
                                             lr
                                             lhs
                                             ((inst i i))
                                             ((steps
                                                ((rewrite
                                                   (premise 0)
                                                   lr
                                                   lhs
                                                   true
                                                   ()))
                                                refl))
                                             refl)
                                           (rewrite-with
                                             (lemma h_i1_32)
                                             lr
                                             lhs
                                             ((inst i i) (inst j j))
                                             ((steps
                                                ((rewrite
                                                   (hyp 0)
                                                   lr
                                                   lhs
                                                   true
                                                   ()))
                                                refl)
                                              (steps
                                                ((rewrite
                                                   (premise 1)
                                                   lr
                                                   lhs
                                                   true
                                                   ()))
                                                refl))
                                             refl))
                                          refl)
                                        (have hw2
                                          (= (mod (- j 1) 4294967296) (- j 1))
                                          (rewrite-with
                                            (lemma wrap32_id)
                                            lr
                                            lhs
                                            ((inst x (- j 1)))
                                            ((rewrite-with
                                               (lemma h_j1_lo)
                                               lr
                                               lhs
                                               ((inst i i) (inst j j))
                                               ((steps
                                                  ((rewrite
                                                     (premise 0)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl)
                                                (steps
                                                  ((rewrite
                                                     (hyp 0)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl))
                                               refl)
                                             (rewrite-with
                                               (lemma h_j1_32)
                                               lr
                                               lhs
                                               ((inst j j))
                                               ((steps
                                                  ((rewrite
                                                     (premise 1)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl))
                                               refl))
                                            refl)
                                          (steps
                                            ((rewrite
                                               (premise hw1)
                                               lr
                                               lhs
                                               true
                                               ())
                                             (rewrite
                                               (premise hw2)
                                               lr
                                               lhs
                                               true
                                               ())
                                             (unfold rev_loop rhs)
                                             (unfold fi rhs)
                                             (unfold fj rhs)
                                             (rewrite (hyp 0) lr rhs true ())
                                             (reduce rhs)
                                             (unfold swap rhs))
                                            (have hih
                                              (=
                                                (eval_loop
                                                  (S
                                                    (S
                                                      (S
                                                        (S
                                                          (S
                                                            (S
                                                              (S
                                                                (S
                                                                  (S
                                                                    (S
                                                                      (S
                                                                        (S
                                                                          (S
                                                                            (S
                                                                              (S
                                                                                (S
                                                                                  (S
                                                                                    (S
                                                                                      (S
                                                                                        (S
                                                                                          (S
                                                                                            (S
                                                                                              (S
                                                                                                (S
                                                                                                  (S
                                                                                                    (S
                                                                                                      (pf_rev
                                                                                                        k2
                                                                                                        c)))))))))))))))))))))))))))
                                                  (MkWModule
                                                    (Cons
                                                      (MkFunc
                                                        2
                                                        0
                                                        (list
                                                          (Block
                                                            (list
                                                              (Loop
                                                                (list
                                                                  (LocalGet 0)
                                                                  (LocalGet 1)
                                                                  (I32Bin BLtU)
                                                                  (I32Eqz)
                                                                  (BrIf 1)
                                                                  (LocalGet 1)
                                                                  (LocalGet 0)
                                                                  (I32Load8U)
                                                                  (LocalGet 0)
                                                                  (LocalGet 1)
                                                                  (I32Load8U)
                                                                  (I32Store8)
                                                                  (I32Store8)
                                                                  (LocalGet 0)
                                                                  (I32Const 1)
                                                                  (I32Bin BAdd)
                                                                  (LocalSet 0)
                                                                  (LocalGet 1)
                                                                  (I32Const 1)
                                                                  (I32Bin BSub)
                                                                  (LocalSet 1)
                                                                  (Br 0)))))
                                                          (I32Const 0)))
                                                      restfs)
                                                    65536)
                                                  (list
                                                    (LocalGet 0)
                                                    (LocalGet 1)
                                                    (I32Bin BLtU)
                                                    (I32Eqz)
                                                    (BrIf 1)
                                                    (LocalGet 1)
                                                    (LocalGet 0)
                                                    (I32Load8U)
                                                    (LocalGet 0)
                                                    (LocalGet 1)
                                                    (I32Load8U)
                                                    (I32Store8)
                                                    (I32Store8)
                                                    (LocalGet 0)
                                                    (I32Const 1)
                                                    (I32Bin BAdd)
                                                    (LocalSet 0)
                                                    (LocalGet 1)
                                                    (I32Const 1)
                                                    (I32Bin BSub)
                                                    (LocalSet 1)
                                                    (Br 0))
                                                  (list (+ i 1) (- j 1))
                                                  st
                                                  (mem_set
                                                    (mem_set
                                                      mm
                                                      i
                                                      (mem_get mm j))
                                                    j
                                                    (mem_get mm i)))
                                                (Some
                                                  (OBr
                                                    0
                                                    st
                                                    (list
                                                      (fi (+ i 1) (- j 1) k2)
                                                      (fj (+ i 1) (- j 1) k2))
                                                    (rev_loop
                                                      (mem_set
                                                        (mem_set
                                                          mm
                                                          i
                                                          (mem_get mm j))
                                                        j
                                                        (mem_get mm i))
                                                      (+ i 1)
                                                      (- j 1)
                                                      k2))))
                                              (rewrite-with
                                                (hyp 1)
                                                lr
                                                lhs
                                                ()
                                                ((rewrite-with
                                                   (lemma h_i1_lo)
                                                   lr
                                                   lhs
                                                   ((inst i i))
                                                   ((steps
                                                      ((rewrite
                                                         (premise 0)
                                                         lr
                                                         lhs
                                                         true
                                                         ()))
                                                      refl))
                                                   refl)
                                                 (rewrite-with
                                                   (lemma h_j1_ms2)
                                                   lr
                                                   lhs
                                                   ((inst j j))
                                                   ((steps
                                                      ((rewrite
                                                         (premise 1)
                                                         lr
                                                         lhs
                                                         true
                                                         ()))
                                                      refl))
                                                   refl)
                                                 (rewrite-with
                                                   (lemma precond_shrink)
                                                   lr
                                                   lhs
                                                   ()
                                                   ((steps
                                                      ((rewrite
                                                         (premise 2)
                                                         lr
                                                         lhs
                                                         true
                                                         ()))
                                                      refl)
                                                    (steps
                                                      ((rewrite
                                                         (lemma int_of_nat_succ)
                                                         lr
                                                         lhs
                                                         true
                                                         ()))
                                                      refl))
                                                   refl))
                                                refl)
                                              (steps
                                                ((rewrite
                                                   (premise hih)
                                                   rl
                                                   rhs
                                                   true
                                                   ())
                                                 (compute both))
                                                refl)))))))))))))))))))))))))

;; final-pointer bound for the capstone: n <= 65536 |- n-1 < 65536.
(claim h_len_ms
  (goal ((x Int)) ((= (le x 65536) True)) (= (lt (- x 1) 65536) True))
  (by arith (list 1 1)))

;; --- the piece theorem (the memory-observable denotation) --------------------------

;; rev8's whole denotation: from ANY memory, with the pointers in-segment and
;; a counter covering the remaining iterations, the piece returns 0 and its
;; final memory IS mem_reverse's rev_loop. S^4 outside covers call_fn_mem's
;; plumbing (seq -> Block -> seq -> Loop); pf_body keeps the loop-entry fuel
;; opaque-headed so the opening compute stops at the worker's redex.
(claim rev8_thm
  (goal ((i Int) (j Int) (mm Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 i) True)
     (= (lt j 65536) True)
     (= (le (- j i) (* 2 (int_of_nat k))) True))
    (=
      (call_fn_mem
        (S (S (S (pf_body k c))))
        (MkWModule
          (Cons
            (MkFunc
              2
              0
              (list
                (Block
                  (list
                    (Loop
                      (list
                        (LocalGet 0)
                        (LocalGet 1)
                        (I32Bin BLtU)
                        (I32Eqz)
                        (BrIf 1)
                        (LocalGet 1)
                        (LocalGet 0)
                        (I32Load8U)
                        (LocalGet 0)
                        (LocalGet 1)
                        (I32Load8U)
                        (I32Store8)
                        (I32Store8)
                        (LocalGet 0)
                        (I32Const 1)
                        (I32Bin BAdd)
                        (LocalSet 0)
                        (LocalGet 1)
                        (I32Const 1)
                        (I32Bin BSub)
                        (LocalSet 1)
                        (Br 0)))))
                (I32Const 0)))
            restfs)
          65536)
        0
        (list i j)
        mm)
      (Some (Pair 0 (rev_loop mm i j k)))))
  (steps
    ((compute lhs))
    (rewrite-with
      (lemma h_negk)
      lr
      lhs
      ()
      ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
      (steps
        ((rewrite (lemma if_false_nat) lr lhs true ()) (reduce lhs))
        (rewrite-with
          (lemma rev_loop_worker)
          lr
          lhs
          ()
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl)
           (steps ((rewrite (premise 2) lr lhs true ())) refl))
          (steps ((compute both)) refl))))))

;; --- the capstone: spec ⊑ wasm, in place -------------------------------------------

;; the final memory of a run (None is unreachable at the theorem's fuel).
(fn out_mem ((r (Option (Pair Int Mem)))) Mem
  (match r
    (None (mem_empty))
    ((Some p)
     (match p
       ((Pair v m2) m2)))))

;; Load a byte list at 0, run the wasm piece over [0, n-1], dump the n
;; cells back out: you get (rev xs) — mem_reverse's capstone carried to the
;; ISA level by citation. Composition IS citation: rev8_thm supplies the
;; final memory as (rev_loop …), mem_reverses finishes.
(claim rev8_reverses
  (goal ((xs (List Int)) (c Nat) (restfs (List Func)))
    ((= (byte_ok xs) True) (= (le (int_of_nat (length_nat xs)) 65536) True))
    (=
      (dump
        0
        (length_nat xs)
        (out_mem
          (call_fn_mem
            (S (S (S (pf_body (half_nat (length_nat xs)) c))))
            (MkWModule
              (Cons
                (MkFunc
                  2
                  0
                  (list
                    (Block
                      (list
                        (Loop
                          (list
                            (LocalGet 0)
                            (LocalGet 1)
                            (I32Bin BLtU)
                            (I32Eqz)
                            (BrIf 1)
                            (LocalGet 1)
                            (LocalGet 0)
                            (I32Load8U)
                            (LocalGet 0)
                            (LocalGet 1)
                            (I32Load8U)
                            (I32Store8)
                            (I32Store8)
                            (LocalGet 0)
                            (I32Const 1)
                            (I32Bin BAdd)
                            (LocalSet 0)
                            (LocalGet 1)
                            (I32Const 1)
                            (I32Bin BSub)
                            (LocalSet 1)
                            (Br 0)))))
                    (I32Const 0)))
                restfs)
              65536)
            0
            (list 0 (- (int_of_nat (length_nat xs)) 1))
            (load xs 0 (mem_empty)))))
      (rev xs)))
  (rewrite-with
    (lemma rev8_thm)
    lr
    lhs
    ()
    ((steps ((compute both)) refl)
     (rewrite-with
       (lemma h_len_ms)
       lr
       lhs
       ()
       ((steps ((rewrite (premise 1) lr lhs true ())) refl))
       refl)
     (steps
       ((rewrite (lemma sub_zero) lr lhs true ()))
       (rewrite-with (lemma half_bound) lr lhs () () refl)))
    (steps
      ((unfold out_mem lhs) (reduce lhs))
      (rewrite-with
        (lemma mem_reverses)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
        refl))))
