;;; pio_vecrun.shard — the mlx-pio vector-gate driver (docs/PIO.md §6, P2).
;;;
;;; Implements the driver/harness contract of mlx-pio's evaluator-spec §9
;;; around the model's pio_run: TX preload (the corpus never streams —
;;; inputs are always <= 4 words), output-pin direction preset, last-value
;;; stimulus latching, and the capture-word projection (bit j = level of
;;; capture pin j, bit 16+j = its direction bit).
;;;
;;; A vector classifies as VFull (exact trace agreement, cycle for cycle),
;;; VPrefix k (the model ended the trace at cycle k by fetching an
;;; off-fragment PSOff slot — every produced word agreed), or VDiv k
;;; (first disagreement at cycle k). The pinned 85/13/3 expectation lives
;;; in pio_vecgate.shard; the vector data is generated by
;;; tools/piovec/gen_vectors.py (regen pin in run_corpus.sh).

(import "../../../kernel/stdlib.shard")  ; List / Option / Pair
(import "../pio.shard")
(import "../encode.shard")
(use (:: models pio pio *))
(use (:: models pio encode *))

;; A test vector: config (code slot Nil — installed from pv_words at run
;; time via dec_prog), the raw 16-bit program words, TX preload words, the
;; output-pin direction mask, capture pins, stimulus mask + values, and
;; the certified per-cycle trace.
(record
  PVec
  (pv_cfg PCfg)
  (pv_words (List Int))
  (pv_ins (List Int))
  (pv_opins Int)
  (pv_cpins (List Int))
  (pv_smask Int)
  (pv_svs (List Int))
  (pv_trace (List Int)))

(type VClass (VFull) (VPrefix Int) (VDiv Int))

;; latched stimulus: the value at cycle i is svs[min(i, len-1)] (empty = 0).
(fn stim_expand ((svs (List Int)) (n Int)) (List Int)
  (measure
    n
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt n 1) Nil
  (match svs
    (Nil (Cons 0 (stim_expand Nil (- n 1))))
    ((Cons v rest)
     (match rest
       (Nil (Cons v (stim_expand svs (- n 1))))
       ((Cons v2 r2) (Cons v (stim_expand rest (- n 1)))))))))

(fn cap_word ((levels Int) (dirs Int) (cpins (List Int)) (j Int)) Int
  (measure (struct cpins))
  (match cpins
    (Nil 0)
    ((Cons p rest)
     (bor
       (bor (bshl (bit_at levels p) j) (bshl (bit_at dirs p) (+ 16 j)))
       (cap_word levels dirs rest (+ j 1))))))

(fn cap_all ((obs (List (Pair Int Int))) (cpins (List Int))) (List Int)
  (measure (struct obs))
  (match obs
    (Nil Nil)
    ((Cons o rest)
     (match o
       ((Pair levels dirs)
        (Cons (cap_word levels dirs cpins 0) (cap_all rest cpins)))))))

;; Compare the produced trace against the certified one. A produced trace
;; is never longer than expected (pio_run consumes one stimulus per word),
;; so the got-longer arm classifies as divergence defensively.
(fn classify ((got (List Int)) (want (List Int)) (i Int)) VClass
  (measure (struct want))
  (match want
    (Nil
      (match got
        (Nil VFull)
        ((Cons g r) (VDiv i))))
    ((Cons w wr)
     (match got
       (Nil (VPrefix i))
       ((Cons g gr) (if (int_eq g w) (classify gr wr (+ i 1)) (VDiv i)))))))

(fn run_vec ((v PVec)) VClass
  (let
    ((cfg (with_code (dec_prog (pv_cfg_of v) (pv_words_of v)) (pv_cfg_of v)))
     (st0 (with_dir_l (pv_opins_of v) (with_tx (pv_ins_of v) (pst_new))))
     (n (flen (pv_trace_of v))))
    (classify
      (cap_all
        (pio_run cfg st0 (pv_smask_of v) (stim_expand (pv_svs_of v) n))
        (pv_cpins_of v))
      (pv_trace_of v)
      0)))

;; Fold the whole corpus into counts + the exceptional sets, vectors
;; numbered by list position: full count, (index, prefix-length) for the
;; clean-prefix vectors, (index, first-bad-cycle) for the divergent ones.
(record
  Gate
  (g_full Int)
  (g_pfx (List (Pair Int Int)))
  (g_div (List (Pair Int Int))))

(fn gate_all ((vs (List PVec)) (i Int)) Gate
  (measure (struct vs))
  (match vs
    (Nil (MkGate 0 Nil Nil))
    ((Cons v rest)
     (let ((g (gate_all rest (+ i 1))))
       (match (run_vec v)
         (VFull (with_g_full (+ (g_full_of g) 1) g))
         ((VPrefix k) (with_g_pfx (Cons (Pair i k) (g_pfx_of g)) g))
         ((VDiv k) (with_g_div (Cons (Pair i k) (g_div_of g)) g)))))))
