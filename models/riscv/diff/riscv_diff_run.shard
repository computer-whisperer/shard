;;; examples/riscv_diff_run.shard — model side of the RISC-V engine differential
;;; (docs/RISCV.md G2). Emits a PLAN: real RV32I/RV64I machine-code bytes for
;;; each module plus vectors whose expected results are computed BY THE MODEL
;;; (rvcall_fn / rvcall_fn_mem). The engine side (examples/riscv_diff.c, run
;;; under qemu-user at both widths) maps the bytes into an executable page and
;;; calls them, comparing the emulated core's result (and memory) against the
;;; model's. Unlike x86 there is no native silicon leg — qemu-user plays V8's
;;; role from the wasm arc (docs/RISCV.md §7.6).
;;;
;;; THE HEADLINE is the WIDTH: the SAME add module is instantiated at RV32 and
;;; RV64, and the same bytes wrap at 2^32 in one qemu and 2^64 in the other.
;;; Every line carries a <width> tag (32|64); the harness is one source built
;;; for both widths, and each qemu invocation processes only its own width's
;;; lines (a module's bytes are byte-identical across widths for everything
;;; except shift-shamt and the RvLi fence — the SEMANTICS differ per core).
;;;
;;; Plan grammar (all integers 16-char little-endian hex; "None" = the model
;;; says the call traps; addresses are REAL absolute addresses, DATA_BASE =
;;; 0x40000000, MAP_FIXED'd by the harness so model-address == core-pointer):
;;;   RVMOD <name> <width> <hexcode>
;;;   RVCASE <name> <width> <argc> <a0> <a1> <a2> <a3> -> <exp>
;;;   RVMEMCASE <name> <width> <argc> <a0> <a1> <a2> <a3> READ <addr> <len>
;;;             -> <exp> <outhex>
;;; The trap vectors (load below the window / store at rvmemhi) expect None:
;;; the model traps, the core SIGSEGVs on the unmapped page, and the harness
;;; scores the caught signal as AGREEMENT (the trap leg of the differential).
;;;
;;; RUN IT:  examples/riscv_diff.sh   (emit + execute under qemu-user, both widths)

(import "../../../kernel/stdlib.shard")
(import "../riscv.shard")
(import "../encode.shard")
(use (:: models riscv riscv *))
(use (:: models riscv encode *))
(import "../../../std/mem")
(use (:: std mem *))

(type World (World Int))
(extern write ((bytes (List Int)) (w World)) World)
(extern exit ((code Int) (w World)) World)

;; --- text plumbing -----------------------------------------------------------

(fn eap ((xs (List Int)) (ys (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (eap t ys)))))

(fn cat ((xss (List (List Int)))) (List Int)
  (measure (struct xss))
  (match xss
    (Nil Nil)
    ((Cons h t) (eap h (cat t)))))

(fn hexd ((d Int)) Int (if (lt d 10) (+ 48 d) (+ 87 d)))

(fn hexs ((bs (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons b t) (Cons (hexd (ediv b 16)) (Cons (hexd (mod b 16)) (hexs t))))))

;; the eight little-endian bytes of a value in [0, 2^64), then 16-char hex.
;; RV32 expectations wrap at 2^32, so their high half is zero; the harness
;; zero-extends the (32-bit) core result to 64 bits before comparing.
(fn le8b ((v Int)) (List Int)
  (let ((u (mod v 18446744073709551616)))
    (list
      (mod u 256)
      (mod (ediv u 256) 256)
      (mod (ediv u 65536) 256)
      (mod (ediv u 16777216) 256)
      (mod (ediv u 4294967296) 256)
      (mod (ediv u 1099511627776) 256)
      (mod (ediv u 281474976710656) 256)
      (mod (ediv u 72057594037927936) 256))))

(fn hx ((v Int)) (List Int) (hexs (le8b v)))

(fn showr ((r (Option Int))) (List Int)
  (match r
    (None "None")
    ((Some v) (hx v))))

;; four padded arg slots (a0..a3; vectors use at most three, a4..a7 stay 0).
(fn argslots4 ((args (List Int))) (List Int)
  (match args
    (Nil (cat (list " " (hx 0) " " (hx 0) " " (hx 0) " " (hx 0))))
    ((Cons a0 t0)
     (match t0
       (Nil (cat (list " " (hx a0) " " (hx 0) " " (hx 0) " " (hx 0))))
       ((Cons a1 t1)
        (match t1
          (Nil (cat (list " " (hx a0) " " (hx a1) " " (hx 0) " " (hx 0))))
          ((Cons a2 t2)
           (match t2
             (Nil (cat (list " " (hx a0) " " (hx a1) " " (hx a2) " " (hx 0))))
             ((Cons a3 t3)
              (cat (list " " (hx a0) " " (hx a1) " " (hx a2) " " (hx a3))))))))))))

(fn argc ((args (List Int))) Int
  (measure (struct args))
  (match args
    (Nil 0)
    ((Cons h t) (+ 1 (argc t)))))

(fn dec1 ((n Int)) (List Int) (list (+ 48 n)))

;; --- the modules (differential-only; single-function, no proof obligation) ---
;; RvCall is fenced in the v1 encoder, so every differential module is a lone
;; function at index 0. mreg = no memory; mmem = the [DATA_BASE, +0x10000)
;; window the harness MAP_FIXEDs.

(fn mreg ((f RvFunc) (w RvXlen)) RvModule (MkRvModule (list f) w 0 0))

(fn mmem ((f RvFunc) (w RvXlen)) RvModule
  (MkRvModule (list f) w 1073741824 1073807360))

;; add(a, b) = a0 + a1 (wrapped at width) — the width headline.
(fn add_f () RvFunc (MkRvFunc 2 (list (RvBin RvAdd A0 A0 (RvSReg A1)))))

;; dec(a) = a - 1 via a NEGATIVE addi immediate (RvSImm -1); pins that the
;; encoder's 12-bit sign-extension agrees with the model's width-wrap.
(fn dec_f () RvFunc (MkRvFunc 1 (list (RvBin RvAdd A0 A0 (RvSImm -1)))))

;; register-source shifts: a0 shifted by a1 (count masked at width).
(fn sllr_f () RvFunc (MkRvFunc 2 (list (RvBin RvSll A0 A0 (RvSReg A1)))))

(fn srlr_f () RvFunc (MkRvFunc 2 (list (RvBin RvSrl A0 A0 (RvSReg A1)))))

(fn srar_f () RvFunc (MkRvFunc 2 (list (RvBin RvSra A0 A0 (RvSReg A1)))))

;; immediate-count shifts: a0 shifted by a baked count k (one fn per count).
(fn slli_f ((k Int)) RvFunc (MkRvFunc 1 (list (RvBin RvSll A0 A0 (RvSImm k)))))

(fn srli_f ((k Int)) RvFunc (MkRvFunc 1 (list (RvBin RvSrl A0 A0 (RvSImm k)))))

(fn srai_f ((k Int)) RvFunc (MkRvFunc 1 (list (RvBin RvSra A0 A0 (RvSImm k)))))

;; slt(a, b) signed vs sltu(a, b) unsigned — the signed/unsigned disagreement.
(fn slt_f () RvFunc (MkRvFunc 2 (list (RvBin RvSlt A0 A0 (RvSReg A1)))))

(fn sltu_f () RvFunc (MkRvFunc 2 (list (RvBin RvSltu A0 A0 (RvSReg A1)))))

;; x0: li x0, 7 (a WRITE, discarded) then add a0, a0, x0 (a READ, = 0) — a
;; rides through unchanged.
(fn x0_f () RvFunc
  (MkRvFunc 1 (list (RvLi X0 7) (RvBin RvAdd A0 A0 (RvSReg X0)))))

;; li(v) = wrapped v into a0 (params 0) — small / lui-range / fence-edge.
(fn li_f ((v Int)) RvFunc (MkRvFunc 0 (list (RvLi A0 v))))

;; count-up register loop: count(n) = n. acc in a1, counter n in a0; a wrong
;; branch offset hangs or crashes (the strong flattening test).
(fn count_f () RvFunc
  (MkRvFunc
    1
    (list
      (RvLi A1 0)
      (RvBlock
        (list
          (RvLoop
            (list
              (RvBrIf (RvBeq A0 X0) 1)
              (RvBin RvAdd A1 A1 (RvSImm 1))
              (RvBin RvAdd A0 A0 (RvSImm -1))
              (RvBr 0)))))
      (RvMv A0 A1))))

;; store+load roundtrip: rt(p, v) stores low byte of v at [p], loads it back
;; into a0 — result = v & 0xFF, and the harness reads memory[p] too.
(fn rt_f () RvFunc
  (MkRvFunc 2 (list (RvStore8 (RvAReg A0) A1) (RvLoad8 A0 (RvAReg A0)))))

;; fill loop: fill(p, v, k) stores v at [p..p+k), returns the final a0 (= p+k).
(fn fill_f () RvFunc
  (MkRvFunc
    3
    (list
      (RvBlock
        (list
          (RvLoop
            (list
              (RvBrIf (RvBeq A2 X0) 1)
              (RvStore8 (RvAReg A0) A1)
              (RvBin RvAdd A0 A0 (RvSImm 1))
              (RvBin RvAdd A2 A2 (RvSImm -1))
              (RvBr 0))))))))

;; trap legs: load below the window / store at rvmemhi — the model traps.
(fn trapld_f () RvFunc (MkRvFunc 1 (list (RvLoad8 A0 (RvAReg A0)))))

(fn trapst_f () RvFunc
  (MkRvFunc 2 (list (RvStore8 (RvAReg A0) A1) (RvMv A0 A1))))

;; --- multi-function CALL modules (docs/RISCV.md G2b: the image layout) --------
;; Entry-first blob: the harness calls the blob START, so the ENTRY (caller)
;; runs first; callees keep their model indices and the encoder computes each
;; `jal ra, off` from the per-index table. A NON-LEAF function (caller/mid)
;; carries the ra spill (prologue/epilogue), so its return survives the calls.
;; Expectations are the MODEL's (rvcall_fn / rvcall_fn_mem at the entry index).

;; leaf inc(a) = a + 1; entry callit(a) = inc(a) + 10 — a FORWARD call (leaf
;; laid after the entry -> positive jal offset) then straight-line code.
(fn inc_f () RvFunc (MkRvFunc 1 (list (RvBin RvAdd A0 A0 (RvSImm 1)))))

(fn callit_f () RvFunc
  (MkRvFunc 1 (list (RvCall 0) (RvBin RvAdd A0 A0 (RvSImm 10)))))

;; leaf sq(a) = a * a (register-source mul); mid sq1(a) = sq(a) + 1 — sq1 is
;; NON-LEAF (the ra spill at depth 2); entry chain(a) = sq1(a) * 2 (via add —
;; no mul-immediate). The three-function nest: layout [chain][sq][sq1], so
;; chain->sq1 is FORWARD and sq1->sq is a BACKWARD jal.
(fn sq_f () RvFunc (MkRvFunc 1 (list (RvBin RvMul A0 A0 (RvSReg A0)))))

(fn sq1_f () RvFunc
  (MkRvFunc 1 (list (RvCall 0) (RvBin RvAdd A0 A0 (RvSImm 1)))))

(fn chain_f () RvFunc
  (MkRvFunc 1 (list (RvCall 1) (RvBin RvAdd A0 A0 (RvSReg A0)))))

;; entry park(a) = sq(a) + a — a live value parked in s1 ACROSS the call. The
;; leaf sq never writes s1, so the model passes it through and the CPU agrees
;; (the encoded prologue/epilogue touch only sp/ra, never a model register).
(fn park_f () RvFunc
  (MkRvFunc 1 (list (RvMv S1 A0) (RvCall 0) (RvBin RvAdd A0 A0 (RvSReg S1)))))

;; the smoke file's sum-loop-with-call: acc in a1, park n in a2, Call add(0)
;; each iteration. sum(n) = n + (n-1) + ... + 1. The loop body contains RvCall,
;; so sum is non-leaf: its ra, spilled once in the prologue, survives every
;; in-loop `jal ra`. add_f (above) is the leaf callee.
(fn sum_f () RvFunc
  (MkRvFunc
    1
    (list
      (RvLi A1 0)
      (RvBlock
        (list
          (RvLoop
            (list
              (RvBrIf (RvBeq A0 X0) 1)
              (RvMv A2 A0)
              (RvCall 0)
              (RvMv A1 A0)
              (RvBin RvAdd A0 A2 (RvSImm -1))
              (RvBr 0)))))
      (RvMv A0 A1))))

;; store callee st(p, v) = *p = v (byte); entry st2(p, v) stores v at p and
;; p+1 THROUGH the callee (a memory effect across the call boundary).
(fn st_f () RvFunc (MkRvFunc 2 (list (RvStore8 (RvAReg A0) A1))))

(fn st2_f () RvFunc
  (MkRvFunc 2 (list (RvCall 0) (RvBin RvAdd A0 A0 (RvSImm 1)) (RvCall 0))))

;; leaf k7(a) = 7; entry early(a): if a == 0, return k7() EARLY through the
;; epilogue expansion (the in-body RvRet inside a non-leaf); else fall through
;; to a + 100. early is non-leaf, so BOTH the in-body RvRet and the trailing
;; return restore ra before ret.
(fn k7_f () RvFunc (MkRvFunc 1 (list (RvLi A0 7))))

(fn early_f () RvFunc
  (MkRvFunc
    1
    (list
      (RvBlock (list (RvBrIf (RvBne A0 X0) 0) (RvCall 0) (RvRet)))
      (RvBin RvAdd A0 A0 (RvSImm 100)))))

;; image module builders: no-memory, and the windowed [DATA_BASE, +0x10000).
(fn imod ((fs (List RvFunc)) (w RvXlen)) RvModule (MkRvModule fs w 0 0))

(fn imodm ((fs (List RvFunc)) (w RvXlen)) RvModule
  (MkRvModule fs w 1073741824 1073807360))

;; --- plan lines --------------------------------------------------------------

(fn rvmod_line ((nm (List Int)) (wd (List Int)) (m RvModule)) (List Int)
  (cat (list "RVMOD " nm " " wd " " (hexs (rv_enc_module m)) "\n")))

(fn rvcase
  ((nm (List Int)) (wd (List Int)) (m RvModule) (args (List Int)) (fuel Int))
  (List Int)
  (cat
    (list
      "RVCASE "
      nm
      " "
      wd
      " "
      (dec1 (argc args))
      (argslots4 args)
      " -> "
      (showr (rvcall_fn (rvfnat fuel) m 0 args))
      "\n")))

(fn memresv ((r (Option (Pair Int Mem)))) (List Int)
  (match r
    (None "None")
    ((Some pr)
     (match pr
       ((Pair v mf) (hx v))))))

(fn memouthex ((r (Option (Pair Int Mem))) (addr Int) (len Nat)) (List Int)
  (match r
    (None "-")
    ((Some pr)
     (match pr
       ((Pair v mf) (hexs (mem_read len mf addr)))))))

(fn rvmemcase
  ((nm (List Int))
   (wd (List Int))
   (m RvModule)
   (args (List Int))
   (addr Int)
   (len Int)
   (fuel Int))
  (List Int)
  (let ((r (rvcall_fn_mem (rvfnat fuel) m 0 args (mem_empty))))
    (cat
      (list
        "RVMEMCASE "
        nm
        " "
        wd
        " "
        (dec1 (argc args))
        (argslots4 args)
        " READ "
        (hx addr)
        " "
        (hx len)
        " -> "
        (memresv r)
        " "
        (memouthex r addr (rvfnat len))
        "\n"))))

;; --- image plan lines (docs/RISCV.md G2b) ------------------------------------
;; A multi-function image at entry k: the bytes come from rv_enc_image (entry
;; laid first) and the expectations from the MODEL at that same entry index
;; (rvcall_fn / rvcall_fn_mem k). The wire grammar is byte-for-byte the same
;; RVMOD/RVCASE/RVMEMCASE the single-function lines use — the harness always
;; calls the blob start, so it needs no image awareness.

(fn rvmod_linei ((nm (List Int)) (wd (List Int)) (m RvModule) (k Int))
  (List Int)
  (cat (list "RVMOD " nm " " wd " " (hexs (rv_enc_image m k)) "\n")))

(fn rvcasek
  ((nm (List Int))
   (wd (List Int))
   (m RvModule)
   (k Int)
   (args (List Int))
   (fuel Int))
  (List Int)
  (cat
    (list
      "RVCASE "
      nm
      " "
      wd
      " "
      (dec1 (argc args))
      (argslots4 args)
      " -> "
      (showr (rvcall_fn (rvfnat fuel) m k args))
      "\n")))

(fn rvmemcasek
  ((nm (List Int))
   (wd (List Int))
   (m RvModule)
   (k Int)
   (args (List Int))
   (addr Int)
   (len Int)
   (fuel Int))
  (List Int)
  (let ((r (rvcall_fn_mem (rvfnat fuel) m k args (mem_empty))))
    (cat
      (list
        "RVMEMCASE "
        nm
        " "
        wd
        " "
        (dec1 (argc args))
        (argslots4 args)
        " READ "
        (hx addr)
        " "
        (hx len)
        " -> "
        (memresv r)
        " "
        (memouthex r addr (rvfnat len))
        "\n"))))

;; one shift module's block: bytes + four value vectors — 0, a small value,
;; the sign bit (2^(W-1)), and all-ones (2^W-1). The last two are sharp: sll
;; wraps the top off, srl fills from the top with zeros (logical), sra smears
;; the sign. Instantiated at ONE width (the count mask differs per width).
(fn shblock
  ((nm (List Int)) (wd (List Int)) (f RvFunc) (w RvXlen) (top Int) (allone Int))
  (List Int)
  (cat
    (list
      (rvmod_line nm wd (mreg f w))
      (rvcase nm wd (mreg f w) (list 0 1) 20)
      (rvcase nm wd (mreg f w) (list 5 1) 20)
      (rvcase nm wd (mreg f w) (list top 1) 20)
      (rvcase nm wd (mreg f w) (list allone 1) 20))))

;; --- the plan ----------------------------------------------------------------
;; DATA_BASE = 0x40000000 = 1073741824; window [DATA_BASE, DATA_BASE+0x10000).
;; The below-window trap addr = DATA_BASE - 1 = 1073741823; the at-hi trap addr
;; = DATA_BASE + 0x10000 = 1073807360 (one past the last mapped byte).

(fn emit () (List Int)
  (cat
    (list
      ;; --- the width headline: SAME add module at both widths ---------------
      (rvmod_line "add" "32" (mreg (add_f) RV32))
      (rvcase "add" "32" (mreg (add_f) RV32) (list 2 3) 20)
      (rvcase "add" "32" (mreg (add_f) RV32) (list 4294967295 2) 20)
      (rvcase "add" "32" (mreg (add_f) RV32) (list 4294967295 1) 20)
      (rvcase "add" "32" (mreg (add_f) RV32) (list 4294967296 4294967296) 20)
      (rvmod_line "add" "64" (mreg (add_f) RV64))
      (rvcase "add" "64" (mreg (add_f) RV64) (list 2 3) 20)
      (rvcase "add" "64" (mreg (add_f) RV64) (list 4294967295 2) 20)
      (rvcase "add" "64" (mreg (add_f) RV64) (list 18446744073709551615 2) 20)
      ;; --- negative addi immediate -----------------------------------------
      (rvmod_line "dec" "32" (mreg (dec_f) RV32))
      (rvcase "dec" "32" (mreg (dec_f) RV32) (list 5) 20)
      (rvcase "dec" "32" (mreg (dec_f) RV32) (list 0) 20)
      (rvmod_line "dec" "64" (mreg (dec_f) RV64))
      (rvcase "dec" "64" (mreg (dec_f) RV64) (list 5) 20)
      (rvcase "dec" "64" (mreg (dec_f) RV64) (list 0) 20)
      ;; --- register-source shifts, both widths (count masking + wrap) -------
      ;; sra of the top value smears the sign to all-ones; the count at the
      ;; mask boundary (32 on RV32 -> 0, 64 on RV64 -> 0) probes the datasheet.
      (rvmod_line "sllr" "32" (mreg (sllr_f) RV32))
      (rvcase "sllr" "32" (mreg (sllr_f) RV32) (list 1 1) 20)
      (rvcase "sllr" "32" (mreg (sllr_f) RV32) (list 1 31) 20)
      (rvcase "sllr" "32" (mreg (sllr_f) RV32) (list 1 32) 20)
      (rvcase "sllr" "32" (mreg (sllr_f) RV32) (list 4294967295 4) 20)
      (rvmod_line "srlr" "32" (mreg (srlr_f) RV32))
      (rvcase "srlr" "32" (mreg (srlr_f) RV32) (list 4294967295 1) 20)
      (rvcase "srlr" "32" (mreg (srlr_f) RV32) (list 2147483648 31) 20)
      (rvmod_line "srar" "32" (mreg (srar_f) RV32))
      (rvcase "srar" "32" (mreg (srar_f) RV32) (list 4294967295 1) 20)
      (rvcase "srar" "32" (mreg (srar_f) RV32) (list 2147483648 1) 20)
      (rvmod_line "srar" "64" (mreg (srar_f) RV64))
      (rvcase "srar" "64" (mreg (srar_f) RV64) (list 18446744073709551615 1) 20)
      (rvcase "srar" "64" (mreg (srar_f) RV64) (list 8 64) 20)
      (rvcase "srar" "64" (mreg (srar_f) RV64) (list 9223372036854775808 1) 20)
      ;; --- immediate-count shifts (RV64 6-bit shamt: 40, and 64->mask 0) ----
      (rvmod_line "slli40" "64" (mreg (slli_f 40) RV64))
      (rvcase "slli40" "64" (mreg (slli_f 40) RV64) (list 1) 20)
      (rvmod_line "srai1" "64" (mreg (srai_f 1) RV64))
      (rvcase
        "srai1"
        "64"
        (mreg (srai_f 1) RV64)
        (list 18446744073709551615)
        20)
      (rvmod_line "slli33" "32" (mreg (slli_f 33) RV32))
      (rvcase "slli33" "32" (mreg (slli_f 33) RV32) (list 1) 20)
      ;; --- slt vs sltu at a signed/unsigned disagreement point --------------
      ;; a = 2^W-1 (= -1 signed, the TOP unsigned), b = 0: slt = 1, sltu = 0.
      (rvmod_line "slt" "64" (mreg (slt_f) RV64))
      (rvcase "slt" "64" (mreg (slt_f) RV64) (list 18446744073709551615 0) 20)
      (rvcase "slt" "64" (mreg (slt_f) RV64) (list 3 5) 20)
      (rvmod_line "sltu" "64" (mreg (sltu_f) RV64))
      (rvcase "sltu" "64" (mreg (sltu_f) RV64) (list 18446744073709551615 0) 20)
      (rvmod_line "slt" "32" (mreg (slt_f) RV32))
      (rvcase "slt" "32" (mreg (slt_f) RV32) (list 4294967295 0) 20)
      (rvmod_line "sltu" "32" (mreg (sltu_f) RV32))
      (rvcase "sltu" "32" (mreg (sltu_f) RV32) (list 4294967295 0) 20)
      ;; --- x0 read (0) and write (discard) ----------------------------------
      (rvmod_line "x0" "64" (mreg (x0_f) RV64))
      (rvcase "x0" "64" (mreg (x0_f) RV64) (list 5) 20)
      (rvmod_line "x0" "32" (mreg (x0_f) RV32))
      (rvcase "x0" "32" (mreg (x0_f) RV32) (list 5) 20)
      ;; --- RvLi at small / lui-range / fence edges (LEGAL values only) ------
      ;; RV32: every value is encodable. RV64 fence = [0,2^31) U [2^64-2^31,
      ;; 2^64); the largest positive-encodable (2^31-1) and the smallest
      ;; negative-range (2^64-2^31) are the boundary witnesses.
      (rvmod_line "li_s" "64" (mreg (li_f 5) RV64))
      (rvcase "li_s" "64" (mreg (li_f 5) RV64) (list) 20)
      (rvmod_line "li_neg" "64" (mreg (li_f -1) RV64))
      (rvcase "li_neg" "64" (mreg (li_f -1) RV64) (list) 20)
      (rvmod_line "li_lui" "64" (mreg (li_f 305419776) RV64))
      (rvcase "li_lui" "64" (mreg (li_f 305419776) RV64) (list) 20)
      ;; 0x7FFFF7FF = 2147481599 is the LARGEST positive RV64 lui+addi value;
      ;; 2^31-1 rounds hi into the sign-extend-negative zone (poison 8), so the
      ;; boundary the fence actually ships is here, not at 2^31.
      (rvmod_line "li_hiedge" "64" (mreg (li_f 2147481599) RV64))
      (rvcase "li_hiedge" "64" (mreg (li_f 2147481599) RV64) (list) 20)
      (rvmod_line "li_negedge" "64" (mreg (li_f 18446744071562067968) RV64))
      (rvcase
        "li_negedge"
        "64"
        (mreg (li_f 18446744071562067968) RV64)
        (list)
        20)
      (rvmod_line "li_big" "32" (mreg (li_f 4294967295) RV32))
      (rvcase "li_big" "32" (mreg (li_f 4294967295) RV32) (list) 20)
      (rvmod_line "li_lui" "32" (mreg (li_f 305419776) RV32))
      (rvcase "li_lui" "32" (mreg (li_f 305419776) RV32) (list) 20)
      ;; --- the count-up loop (strong flattening test) + zero iterations -----
      (rvmod_line "count" "64" (mreg (count_f) RV64))
      (rvcase "count" "64" (mreg (count_f) RV64) (list 0) 40)
      (rvcase "count" "64" (mreg (count_f) RV64) (list 1) 60)
      (rvcase "count" "64" (mreg (count_f) RV64) (list 7) 120)
      (rvcase "count" "64" (mreg (count_f) RV64) (list 100) 1200)
      (rvmod_line "count" "32" (mreg (count_f) RV32))
      (rvcase "count" "32" (mreg (count_f) RV32) (list 0) 40)
      (rvcase "count" "32" (mreg (count_f) RV32) (list 50) 700)
      ;; --- byte store + load at the mapped window ---------------------------
      (rvmod_line "rt" "64" (mmem (rt_f) RV64))
      (rvmemcase
        "rt"
        "64"
        (mmem (rt_f) RV64)
        (list 1073741824 65)
        1073741824
        1
        20)
      (rvmemcase
        "rt"
        "64"
        (mmem (rt_f) RV64)
        (list 1073807359 200)
        1073807359
        1
        20)
      (rvmod_line "rt" "32" (mmem (rt_f) RV32))
      (rvmemcase
        "rt"
        "32"
        (mmem (rt_f) RV32)
        (list 1073741824 300)
        1073741824
        1
        20)
      (rvmod_line "fill" "64" (mmem (fill_f) RV64))
      (rvmemcase
        "fill"
        "64"
        (mmem (fill_f) RV64)
        (list 1073741824 65 8)
        1073741824
        8
        200)
      (rvmod_line "fill" "32" (mmem (fill_f) RV32))
      (rvmemcase
        "fill"
        "32"
        (mmem (fill_f) RV32)
        (list 1073741840 187 4)
        1073741840
        4
        200)
      ;; --- trap legs (model None; the core SIGSEGVs) ------------------------
      (rvmod_line "trapld" "64" (mmem (trapld_f) RV64))
      (rvmemcase
        "trapld"
        "64"
        (mmem (trapld_f) RV64)
        (list 1073741823)
        1073741823
        1
        20)
      (rvmod_line "trapst" "64" (mmem (trapst_f) RV64))
      (rvmemcase
        "trapst"
        "64"
        (mmem (trapst_f) RV64)
        (list 1073807360 65)
        1073807360
        1
        20)
      (rvmod_line "trapld" "32" (mmem (trapld_f) RV32))
      (rvmemcase
        "trapld"
        "32"
        (mmem (trapld_f) RV32)
        (list 1073741823)
        1073741823
        1
        20)
      ;; --- shift blocks (sll/srl/sra at both widths, the wrap witnesses) ----
      (shblock
        "shl64"
        "64"
        (sllr_f)
        RV64
        9223372036854775808
        18446744073709551615)
      (shblock
        "shr64"
        "64"
        (srlr_f)
        RV64
        9223372036854775808
        18446744073709551615)
      (shblock "shl32" "32" (sllr_f) RV32 2147483648 4294967295)
      (shblock "shr32" "32" (srlr_f) RV32 2147483648 4294967295)
      ;; ======== G2b: real jal calls (multi-function images, both widths) =====
      ;; twofn — entry calls a leaf (FORWARD jal): callit(a) = inc(a) + 10.
      (rvmod_linei "twofn" "64" (imod (list (inc_f) (callit_f)) RV64) 1)
      (rvcasek "twofn" "64" (imod (list (inc_f) (callit_f)) RV64) 1 (list 5) 20)
      (rvcasek "twofn" "64" (imod (list (inc_f) (callit_f)) RV64) 1 (list 0) 20)
      (rvmod_linei "twofn" "32" (imod (list (inc_f) (callit_f)) RV32) 1)
      (rvcasek "twofn" "32" (imod (list (inc_f) (callit_f)) RV32) 1 (list 5) 20)
      (rvcasek
        "twofn"
        "32"
        (imod (list (inc_f) (callit_f)) RV32)
        1
        (list 4294967295)
        20)
      ;; nest — chain -> sq1 (FORWARD) -> sq (BACKWARD); sq1 non-leaf (spill at
      ;; depth 2). chain(a) = (a*a + 1) * 2.
      (rvmod_linei "nest" "64" (imod (list (sq_f) (sq1_f) (chain_f)) RV64) 2)
      (rvcasek
        "nest"
        "64"
        (imod (list (sq_f) (sq1_f) (chain_f)) RV64)
        2
        (list 5)
        30)
      (rvcasek
        "nest"
        "64"
        (imod (list (sq_f) (sq1_f) (chain_f)) RV64)
        2
        (list 0)
        30)
      (rvmod_linei "nest" "32" (imod (list (sq_f) (sq1_f) (chain_f)) RV32) 2)
      (rvcasek
        "nest"
        "32"
        (imod (list (sq_f) (sq1_f) (chain_f)) RV32)
        2
        (list 5)
        30)
      ;; RV32 wrap witness: sq1(0x10000)=2^32+1 -> wraps to 1 at RV32; *2 -> 2.
      (rvcasek
        "nest"
        "32"
        (imod (list (sq_f) (sq1_f) (chain_f)) RV32)
        2
        (list 65536)
        30)
      ;; park — a live value parked in s1 across the call: park(a) = a*a + a.
      (rvmod_linei "park" "64" (imod (list (sq_f) (park_f)) RV64) 1)
      (rvcasek "park" "64" (imod (list (sq_f) (park_f)) RV64) 1 (list 5) 20)
      (rvcasek "park" "64" (imod (list (sq_f) (park_f)) RV64) 1 (list 3) 20)
      (rvmod_linei "park" "32" (imod (list (sq_f) (park_f)) RV32) 1)
      (rvcasek "park" "32" (imod (list (sq_f) (park_f)) RV32) 1 (list 5) 20)
      ;; sumcall — the smoke shape: a loop whose body Calls add. sum(4) = 10,
      ;; plus the zero-iteration edge sum(0) = 0. Both widths.
      (rvmod_linei "sumcall" "64" (imod (list (add_f) (sum_f)) RV64) 1)
      (rvcasek "sumcall" "64" (imod (list (add_f) (sum_f)) RV64) 1 (list 4) 300)
      (rvcasek "sumcall" "64" (imod (list (add_f) (sum_f)) RV64) 1 (list 0) 40)
      (rvcasek "sumcall" "64" (imod (list (add_f) (sum_f)) RV64) 1 (list 1) 80)
      (rvmod_linei "sumcall" "32" (imod (list (add_f) (sum_f)) RV32) 1)
      (rvcasek "sumcall" "32" (imod (list (add_f) (sum_f)) RV32) 1 (list 4) 300)
      (rvcasek "sumcall" "32" (imod (list (add_f) (sum_f)) RV32) 1 (list 0) 40)
      ;; st2 — stores v at p and p+1 THROUGH the callee; readback both bytes.
      (rvmod_linei "st2" "64" (imodm (list (st_f) (st2_f)) RV64) 1)
      (rvmemcasek
        "st2"
        "64"
        (imodm (list (st_f) (st2_f)) RV64)
        1
        (list 1073741824 65)
        1073741824
        2
        30)
      (rvmod_linei "st2" "32" (imodm (list (st_f) (st2_f)) RV32) 1)
      (rvmemcasek
        "st2"
        "32"
        (imodm (list (st_f) (st2_f)) RV32)
        1
        (list 1073741840 187)
        1073741840
        2
        30)
      ;; early — an in-body RvRet inside a non-leaf: early(0) = 7 (early return
      ;; through the epilogue), early(5) = 105 (fall through).
      (rvmod_linei "early" "64" (imod (list (k7_f) (early_f)) RV64) 1)
      (rvcasek "early" "64" (imod (list (k7_f) (early_f)) RV64) 1 (list 0) 30)
      (rvcasek "early" "64" (imod (list (k7_f) (early_f)) RV64) 1 (list 5) 30)
      (rvmod_linei "early" "32" (imod (list (k7_f) (early_f)) RV32) 1)
      (rvcasek "early" "32" (imod (list (k7_f) (early_f)) RV32) 1 (list 0) 30)
      (rvcasek "early" "32" (imod (list (k7_f) (early_f)) RV32) 1 (list 5) 30))))

(fn main ((w World)) World (exit 0 (write (emit) w)))
