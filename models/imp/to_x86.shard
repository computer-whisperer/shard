;;; models/imp/to_x86.shard — the imp → x86_64 TRANSLATOR (docs/IMP.md
;;; rung I1c): pure value-level lowering from the neutral machine to
;;; x86 instruction values. The second ISA leg — the one other place
;;; that imports both models. Ordinary shard; the certs that gate its
;;; outputs live with the twins (generate-and-check: nothing here is
;;; trusted, every translated program is proven).
;;;
;;; The target is a REGISTER machine with two-operand destructive ops,
;;; so unlike to_wasm's postorder-to-stack scheme this is a PATTERN
;;; tier: imp locals map to their SysV homes (local i → the i-th of
;;; rdi rsi rdx rcx r8 r9 — args first, zero-initialized extras on the
;;; following homes, which xargs zeroes; params + extras > 6 refuse),
;;; statements compile to the same in-place shapes tools/x86gen emits,
;;; and result expressions compile left-spine into RAX with one R10
;;; right-compound level. RAX doubles as the load scratch (the x86gen
;;; convention); no imp local ever maps to RAX or R10.
;;;
;;; The width story, per target: x86 ops wrap at 2^64, so (IWrap 64 e)
;;; translates to the translation of e — unconditionally faithful —
;;; while IWrap 32 REFUSES here (it is wasm's native width; absorbing
;;; it on x86 would need an explicit mask). The mirror image of
;;; to_wasm, which absorbs 32 and refuses 64: each leg absorbs exactly
;;; its machine's width, and the per-instance bridge certs price
;;; unwrapped ops in that machine's modulus.
;;;
;;; The control encodings are the SELF-CONTAINED label structures of
;;; the wasm leg, with x86's fused conditions (no comparison
;;; materialization — Cond is what jcc sees):
;;;   (IIf c thn els)  -> XBlock( XBlock( XBrIf ⟦c⟧ 0  ⟦els⟧ XBr 1 )
;;;                       ⟦thn⟧ )
;;;   (IWhile (ILoc i) b) -> XBlock( XLoop( XBrIf (CEqz home_i) 1
;;;                          ⟦b⟧ XBr 0 ) )
;;; Refusal is loud by construction (None = no artifact): division
;;; (the XDivU compound needs the rdx:rax preamble — named growth),
;;; comparison ops in value position (fused conditions only), while
;;; conditions other than a bare local, deeper right-compounds.

(import "../../kernel/stdlib.shard")
(import "imp.shard")
(use (:: models imp imp *))
(import "../x86/x86.shard")
(use (:: models x86 x86 *))

(fn ix_app ((a (List XInstr)) (b (List XInstr))) (List XInstr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (ix_app t b)))))

;; the SysV home of an imp local; None past the sixth
(fn ix_home ((i Int)) (Option Reg)
  (if (int_eq i 0) (Some RDI)
  (if (int_eq i 1) (Some RSI)
  (if (int_eq i 2) (Some RDX)
  (if (int_eq i 3) (Some RCX)
  (if (int_eq i 4) (Some R8)
  (if (int_eq i 5) (Some R9)
  None)))))))

;; exact imp ops onto the wrapping two-operand ops; div/rem and the
;; comparisons refuse (compound instruction / fused-condition-only)
(fn ix_op ((o IOp)) (Option XBop)
  (match o
    (IAdd (Some XAdd))
    (ISub (Some XSub))
    (IMul (Some XMul))
    (IDiv None)
    (IRem None)
    (IAnd (Some XAnd))
    (IOr (Some XOr))
    (IXor (Some XXor))
    (IEq None)
    (ILt None)
    (ILe None)))

;; atoms as source operands
(fn ix_src ((e IExp)) (Option Src)
  (match e
    ((IConst n) (Some (SImm n)))
    ((ILoc i)
     (match (ix_home i)
       (None None)
       ((Some r) (Some (SReg r)))))
    ((IBin o a b) None)
    ((IWrap w a) None)
    ((ILoad a) None)))

;; does an atom read local i (the mov+bin clobber fence)
(fn ix_uses ((e IExp) (i Int)) Bool
  (match e
    ((ILoc j) (int_eq j i))
    ((IConst n) False)
    ((IBin o a b) True)
    ((IWrap w a) True)
    ((ILoad a) True)))

;; fused branch conditions: comparison of a local against an atom
(fn ix_cond ((e IExp)) (Option Cond)
  (match e
    ((IBin o a b)
     (match a
       ((ILoc i)
        (match (ix_home i)
          (None None)
          ((Some r)
           (match (ix_src b)
             (None None)
             ((Some s)
              (match o
                (IEq (Some (CEq r s)))
                (ILt (Some (CLtU r s)))
                (ILe (Some (CLeU r s)))
                (IAdd None)
                (ISub None)
                (IMul None)
                (IDiv None)
                (IRem None)
                (IAnd None)
                (IOr None)
                (IXor None)))))))
       ((IConst n) None)
       ((IBin o2 x y) None)
       ((IWrap w x) None)
       ((ILoad x) None)))
    ((IConst n) None)
    ((ILoc i) None)
    ((IWrap w a) None)
    ((ILoad a) None)))

;; compile an expression into an accumulator register, LEFT-SPINE ONLY
;; (atoms on the right); (IWrap 64 e) absorbs — x86's native width
(fn ix_acc ((dst Reg) (e IExp)) (Option (List XInstr))
  (measure (struct e))
  (match e
    ((IConst n) (Some (list (XMovRI dst n))))
    ((ILoc i)
     (match (ix_home i)
       (None None)
       ((Some r) (Some (list (XMovRR dst r))))))
    ((IBin o a b)
     (match (ix_op o)
       (None None)
       ((Some xo)
        (match (ix_src b)
          (None None)
          ((Some bs)
           (match (ix_acc dst a)
             (None None)
             ((Some ia) (Some (ix_app ia (list (XBin xo dst bs)))))))))))
    ((IWrap w a) (if (int_eq w 64) (ix_acc dst a) None))
    ((ILoad a) None)))

;; the result expression into RAX; one right-compound level rides R10
;; (the x86gen temp convention — evaluation order matches iexp's
;; left-then-right)
(fn ix_res ((e IExp)) (Option (List XInstr))
  (match (ix_acc RAX e)
    ((Some is) (Some is))
    (None
      (match e
        ((IBin o a b)
         (match (ix_op o)
           (None None)
           ((Some xo)
            (match (ix_acc RAX a)
              (None None)
              ((Some ia)
               (match (ix_acc R10 b)
                 (None None)
                 ((Some ib)
                  (Some (ix_app ia (ix_app ib (list (XBin xo RAX (SReg R10)))))))))))))
        ((IConst n) None)
        ((ILoc i) None)
        ((IWrap w a) None)
        ((ILoad a) None)))))

;; the statement tier: one structural walk (the to_wasm shape); the
;; ISet patterns are the shapes x86gen emits — in-place when the dst
;; local is the left operand, mov+bin otherwise (fenced against the
;; right operand reading the dst), RAX-scratch for a byte load
(fn ix_stmts ((ss (List IStmt))) (Option (List XInstr))
  (measure (struct ss))
  (match ss
    (Nil (Some Nil))
    ((Cons s t)
     (match (ix_stmts t)
       (None None)
       ((Some it)
        (match s
          ((ISet i e)
           (match (ix_home i)
             (None None)
             ((Some d)
              (match e
                ((IConst n) (Some (Cons (XMovRI d n) it)))
                ((ILoc j)
                 (match (ix_home j)
                   (None None)
                   ((Some r) (Some (Cons (XMovRR d r) it)))))
                ((IBin o a b)
                 (match (ix_op o)
                   (None None)
                   ((Some xo)
                    (match a
                      ((ILoc j)
                       (if (int_eq j i)
                         (match b
                           ((ILoad ae)
                            (match ae
                              ((ILoc aj)
                               (match (ix_home aj)
                                 (None None)
                                 ((Some ar)
                                  (Some
                                    (Cons
                                      (XLoad8 RAX (AReg ar))
                                      (Cons (XBin xo d (SReg RAX)) it))))))
                              ((IConst n) None)
                              ((IBin o2 x y) None)
                              ((IWrap w x) None)
                              ((ILoad x) None)))
                           (_
                             (match (ix_src b)
                               (None None)
                               ((Some bs) (Some (Cons (XBin xo d bs) it))))))
                       (if (ix_uses b i) None
                       (match (ix_home j)
                         (None None)
                         ((Some r)
                          (match (ix_src b)
                            (None None)
                            ((Some bs)
                             (Some (Cons (XMovRR d r) (Cons (XBin xo d bs) it))))))))))
                      ((IConst n) None)
                      ((IBin o2 x y) None)
                      ((IWrap w x) None)
                      ((ILoad x) None)))))
                ((IWrap w a) None)
                ((ILoad ae)
                 (match ae
                   ((ILoc aj)
                    (match (ix_home aj)
                      (None None)
                      ((Some ar) (Some (Cons (XLoad8 d (AReg ar)) it)))))
                   ((IConst n) None)
                   ((IBin o2 x y) None)
                   ((IWrap w x) None)
                   ((ILoad x) None)))))))
          ((IStore ae ve)
           (match ae
             ((ILoc aj)
              (match (ix_home aj)
                (None None)
                ((Some ar)
                 (match (ix_src ve)
                   (None None)
                   ((Some vs) (Some (Cons (XStore8 (AReg ar) vs) it)))))))
             ((IConst n) None)
             ((IBin o2 x y) None)
             ((IWrap w x) None)
             ((ILoad x) None)))
          ((IIf c thn els)
           (match (ix_cond c)
             (None None)
             ((Some xc)
              (match (ix_stmts thn)
                (None None)
                ((Some ithn)
                 (match (ix_stmts els)
                   (None None)
                   ((Some iels)
                    (Some
                      (Cons
                        (XBlock
                          (Cons
                            (XBlock
                              (Cons (XBrIf xc 0) (ix_app iels (list (XBr 1)))))
                            ithn))
                        it)))))))))
          ((IWhile c b)
           (match c
             ((ILoc ci)
              (match (ix_home ci)
                (None None)
                ((Some cr)
                 (match (ix_stmts b)
                   (None None)
                   ((Some ib)
                    (Some
                      (Cons
                        (XBlock
                          (list
                            (XLoop
                              (Cons
                                (XBrIf (CEqz cr) 1)
                                (ix_app ib (list (XBr 0)))))))
                        it)))))))
             ((IConst n) None)
             ((IBin o2 x y) None)
             ((IWrap w x) None)
             ((ILoad x) None)))))))))

;; a function: translated statements, then the result into RAX. The
;; SysV boundary carries at most six locals (args in their homes,
;; extras on the following homes — which xargs zeroes, matching imp's
;; zero-initialized extras).
(fn imp2x_fn ((f IFn)) (Option XFunc)
  (if (le (+ (iparams_of f) (iextra_of f)) 6)
    (match (ix_stmts (ibody_of f))
      (None None)
      ((Some ist)
       (match (ix_res (iresult_of f))
         (None None)
         ((Some ir) (Some (MkXFunc (iparams_of f) (ix_app ist ir)))))))
    None))

;; total unwrapper for stating ground bridge goals
(fn x_of ((o (Option XFunc))) XFunc
  (match o
    ((Some f) f)
    (None (MkXFunc 0 Nil))))

;; the loop-exit alignment adapter: the IWhile encoding exits its
;; XLoop via XBrIf _ 1, which xeval_loop hands back as (XBrk 0 …) — so
;; at the xeval_loop/iwhile boundary, imp's INorm corresponds to
;; (XBrk 0 regs …) where regs = the locals in their SysV homes (xargs
;; rebuilds exactly that record) with rax = the x86-only scratch
;; residue, passed explicitly (0 for loops that never load; the
;; loopkit's xlg_last shape for loops that do). ITrap ↔ XTrap.
(fn ix_out ((ra Int) (r (Option IOut))) (Option XOut)
  (match r
    (None None)
    ((Some o)
     (match o
       ((INorm ls m)
        (match (xargs ls)
          (None None)
          ((Some rs) (Some (XBrk 0 (with_rax ra rs) m)))))
       (ITrap (Some XTrap))))))
