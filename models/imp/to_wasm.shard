;;; models/imp/to_wasm.shard — the imp → wasm TRANSLATOR (docs/IMP.md
;;; rungs I1a/I1b; reworked kind-directed at V2, §2a): pure value-level
;;; lowering from the neutral machine to wasm instruction sequences.
;;; This is the bridge file — the one place that imports BOTH models.
;;; Ordinary shard; the certs that gate its outputs live with the
;;; twins (generate-and-check: nothing here is trusted, every
;;; translated program is proven).
;;;
;;; THE V2 CONTRACT: translation is gated on the well-kinded predicate
;;; (imp2w_fn checks wk_fn first — the §2a membership gate made code)
;;; and is then KIND-DIRECTED instruction selection with a
;;; program-independent alignment: U8/U32 ops lower onto the wrapping
;;; i32 ops, whose wrap IS imp's op-result wrap (same mod), whose
;;; rotate IS imp's band-spelled rotate, and whose trunc emission
;;; (And-mask) IS imp's band-spelled ITrunc — so the per-instance
;;; bridge certs are UNPREMISED: both machines band the call-boundary
;;; args identically (the bridge statement feeds call_fn through
;;; iband_args, exactly what icall does internally) and then compute
;;; the same values at every step. The v1 range-premise apparatus has
;;; no v2 analogue; fit obligations live at spec ⊑ imp, once.
;;;
;;; CAPABILITY SET (this target, today): kinds U8/U32. U64 REFUSES
;;; (None) until the wasm model grows its i64 vocabulary — the §2a
;;; capability doctrine: refusal is loud, a twin using U64 simply has
;;; no wasm leg yet. Non-32 rotate widths refuse likewise.
;;;
;;; The statement encodings are SELF-CONTAINED label structures — every
;;; branch an encoding emits targets one of its own blocks, so nesting
;;; composes without depth adjustment:
;;;   (IIf c thn els)  -> Block( Block( ⟦c⟧ BrIf 0  ⟦els⟧ Br 1 ) ⟦thn⟧ )
;;;                       (BrIf 0 exits the inner block into the then
;;;                       code; the else code's Br 1 skips it)
;;;   (IWhile c body)  -> Block( Loop( ⟦c⟧ I32Eqz BrIf 1  ⟦body⟧ Br 0 ) )
;;;                       (exit = BrIf 1 to the Block; Br 0 re-enters
;;;                       the Loop head)
;;; These are exactly the shapes tools/wasmgen emits for the same
;;; source classes — the ties prove the outputs byte-identical.

(import "../../kernel/stdlib.shard")
(import "imp.shard")
(use (:: models imp imp *))
(import "../wasm/wasm.shard")
(use (:: models wasm wasm *))

(fn iw_app ((a (List Instr)) (b (List Instr))) (List Instr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (iw_app t b)))))

;; the kinds inside this target's capability set (i32-representable)
(fn iw_k32 ((k IKind)) Bool
  (match k
    (U8 True)
    (U32 True)
    (U64 False)))

;; imp ops map onto the i32 ops kind-for-kind: the i32 wrap is imp's
;; op-result wrap, the guards match, the comparisons match
(fn iw_op ((o IOp)) Bop
  (match o
    (IAdd BAdd)
    (ISub BSub)
    (IMul BMul)
    (IDiv BDivU)
    (IRem BRemU)
    (IAnd BAnd)
    (IOr BOr)
    (IXor BXor)
    (IShl BShl)
    (IShr BShrU)
    (IEq BEq)
    (ILt BLtU)
    (ILe BLeU)))

;; postorder stack code for an expression; None = outside this
;; target's capability set (U64 anywhere, pending the i64 vocabulary)
(fn iw_exp ((e IExp)) (Option (List Instr))
  (measure (struct e))
  (match e
    ((IConst n) (Some (list (I32Const n))))
    ((ILoc i) (Some (list (LocalGet i))))
    ((IBin k o a b)
     (if (iw_k32 k)
       (match (iw_exp a)
         (None None)
         ((Some ia)
          (match (iw_exp b)
            (None None)
            ((Some ib) (Some (iw_app ia (iw_app ib (list (I32Bin (iw_op o))))))))))
       None))
    ;; the 32-bit rotation maps to the native i32.rotr — both sides
    ;; band-spell containment, so the bridge is refl-grade
    ((IRotr k a c)
     (match k
       (U8 None)
       (U32
         (match (iw_exp a)
           (None None)
           ((Some ia)
            (match (iw_exp c)
              (None None)
              ((Some ic) (Some (iw_app ia (iw_app ic (list (I32Bin BRotr))))))))))
       (U64 None)))
    ;; zero-extension inside the i32 band is a no-op (U8 values are
    ;; already i32 values); extension INTO U64 waits on the capability
    ((IExt _ kt a) (if (iw_k32 kt) (iw_exp a) None))
    ;; mask-narrowing to U8 emits the And-mask — the same band imp's
    ;; ITrunc computes; narrowing FROM U64 waits on the capability
    ((ITrunc kf kt a)
     (match kf
       (U8 None)
       (U32
         (match kt
           (U8
             (match (iw_exp a)
               (None None)
               ((Some ia)
                (Some (iw_app ia (list (I32Const 255) (I32Bin BAnd)))))))
           (U32 None)
           (U64 None)))
       (U64 None)))
    ((ILoad a)
     (match (iw_exp a)
       (None None)
       ((Some ia) (Some (iw_app ia (list (I32Load8U)))))))))

;; the statement tier: one structural walk over the statement list
;; (recursion descends into IIf branches and IWhile bodies — strict
;; subterms via nested match)
(fn iw_stmts ((ss (List IStmt))) (Option (List Instr))
  (measure (struct ss))
  (match ss
    (Nil (Some Nil))
    ((Cons s t)
     (match (iw_stmts t)
       (None None)
       ((Some it)
        (match s
          ((ISet i e)
           (match (iw_exp e)
             (None None)
             ((Some ie) (Some (iw_app ie (Cons (LocalSet i) it))))))
          ((IStore ae ve)
           (match (iw_exp ae)
             (None None)
             ((Some ia)
              (match (iw_exp ve)
                (None None)
                ((Some iv) (Some (iw_app ia (iw_app iv (Cons (I32Store8) it)))))))))
          ((IIf c thn els)
           (match (iw_exp c)
             (None None)
             ((Some ic)
              (match (iw_stmts thn)
                (None None)
                ((Some ithn)
                 (match (iw_stmts els)
                   (None None)
                   ((Some iels)
                    (Some
                      (Cons
                        (Block
                          (Cons
                            (Block
                              (iw_app
                                ic
                                (Cons (BrIf 0) (iw_app iels (list (Br 1))))))
                            ithn))
                        it)))))))))
          ((IWhile c b)
           (match (iw_exp c)
             (None None)
             ((Some ic)
              (match (iw_stmts b)
                (None None)
                ((Some ib)
                 (Some
                   (Cons
                     (Block
                       (list
                         (Loop
                           (iw_app
                             ic
                             (Cons
                               (I32Eqz)
                               (Cons (BrIf 1) (iw_app ib (list (Br 0)))))))))
                     it)))))))))))))

;; a function: THE GATE FIRST (only well-kinded fns translate — the
;; §2a membership predicate), then translated statements + result
(fn imp2w_fn ((f IFn)) (Option Func)
  (if (wk_fn f)
    (match (iw_stmts (ibody_of f))
      (None None)
      ((Some ist)
       (match (iw_exp (iresult_of f))
         (None None)
         ((Some ir)
          (Some
            (MkFunc (ikn (ikparams_of f)) (ikn (ikextra_of f)) (iw_app ist ir)))))))
    None))

;; total unwrapper for stating ground bridge goals (the empty Func is
;; inert: zero params over an empty body traps on any call)
(fn w_of ((o (Option Func))) Func
  (match o
    ((Some f) f)
    (None (MkFunc 0 0 Nil))))

;; the loop-exit alignment adapter: the IWhile encoding exits its Loop
;; via BrIf 1, which eval_loop hands back as (OBr 0 …) with the entry
;; stack untouched — so at the eval_loop/iwhile boundary, imp's INorm
;; corresponds to (OBr 0 st …) and ITrap to OTrap. The loop worker
;; bridges (imp ⊑ wasm, per program) state their equations through
;; this: eval_loop over the translated body = (iw_out st (iwhile …)).
(fn iw_out ((st (List Int)) (r (Option IOut))) (Option Out)
  (match r
    (None None)
    ((Some o)
     (match o
       ((INorm lc m) (Some (OBr 0 st lc m)))
       (ITrap (Some OTrap))))))
