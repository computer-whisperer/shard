                                          (reduce lhs)))
                                       (case-on (ilset lc i v) Option
                                         ((case None
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ())
                                               (compute both))
                                              refl))
                                          (case Some
                                            (lc2)
