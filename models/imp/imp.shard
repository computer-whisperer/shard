                                                  (ilen lc2))
                                                (steps
                                                  ((unfold ollen lhs)
                                                   (reduce lhs))
                                                  refl))
                                              (have hs3 (= (ilen lc2) (ilen lc))
                                                (steps
                                                  ((rewrite
                                                     (premise hs2)
                                                     rl
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (premise hs1)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl))
                                              (steps
                                                ((rewrite
                                                   (premise hs3)
                                                   rl
                                                   lhs
                                                   true
                                                   ())))
                                              (rewrite-with
                                                (hyp ih)
                                                lr
                                                lhs
                                                ()
                                                ((below)))
                                              (steps
