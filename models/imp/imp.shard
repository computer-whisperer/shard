                                                ((rewrite
                                                   (hyp 0)
                                                   lr
                                                   lhs
                                                   true
                                                   ())
                                                 (reduce lhs)))
                                              (have hs1
                                                (=
                                                  (ollen (ilen lc) (Some lc2))
                                                  (ilen lc))
                                                (chain
                                                  (steps
                                                    ((rewrite
                                                       (hyp 0)
                                                       rl
                                                       lhs
                                                       true
                                                       ())))
                                                  (rewrite-with
