;;; models/imp/probes/vx86_acc_probe.shard — ARC A1 PRICING PROBE (docs/CERT.md
;;; §8): the EXPRESSION LEMMA of the valid_imp_x86 soundness ladder, hand-proven
;;; to price the generic induction before the validator library commits to it.
;;;
;;; The statement family (the first program-generic simulation lemmas in the
;;; imp story — every landed bridge is a ground compute-both instance; these
;;; quantify over the PROGRAM):
;;;
;;;   vxg_seam — the x86 mirror of imp.shard's ist_seam: xeval_seq over an
;;;              appended register-pure prefix = the continuation of the rest
;;;              applied to the prefix's run, at lg_fuel towers (one S per
;;;              instruction position).
;;;   vxg_src  — atom agreement: an ix_src-accepted operand reads the same
;;;              value from the register file that iexp reads from the locals
;;;              spine (inductive through IExt; the IConst leaf is where the
;;;              vx_cb band premise pays; the home map grounds leaf-by-leaf
;;;              under the int_eq descent — no separate map lemma needed).
;;;   vxg_acc  — THE VALUE LEMMA (dst = RAX instance): a completed ix_acc
;;;              emission, run from the aligned file, puts the expression's
;;;              iexp value in RAX and touches nothing else.
;;;
;;; Audit result this file pins (the raw-alignment thesis, V2's dividend):
;;; every accepted ix_acc arm aligns raw-symbolically — identical kernel-fn
;;; trees on both sides — EXCEPT constants (XMovRI/SImm wrap64 on the machine,
;;; raw in iexp): vx_cb (constants sit in the 64-bit register band) is the ONE
;;; premise the generic lemma needs beyond the Some-successes. Shift counts
;;; cost one mod_unique step from the emission guards; IRotr/ITrunc are
;;; refl-grade identical trees.
;;;
;;; Scope fences (named growth, priced later): the R10 dst instance (ix_res's
;;; right-compound leg) clones this file's RAX lemma; the 12-slot spine is the
;;; FULL home file — the shorter-locals padding seam is the statement layer's
;;; business; vx_regi is ix_acc's emission alphabet only (stores/branches
;;; widen it at the statement tier).

(import "../../../kernel/stdlib.shard")
(import "../../../kernel/facts.shard")
(use (:: kernel facts *))
(import "../../../std/mem")
(use (:: std mem *))
(import "../../wasm/loopkit.shard")
(use (:: models wasm loopkit *))
(import "../imp.shard")
(use (:: models imp imp *))
(import "../../x86/x86.shard")
(use (:: models x86 x86 *))
(import "../to_x86.shard")
(use (:: models imp to_x86 *))

;; --- the kit --------------------------------------------------------------------
;; Claim goals spell the locals spine and the register file as LITERALS
;; ((list l0 …) / (MkRegs a0 l3 l2 l6 l7 l1 l0 l4 l5 s10 s11 l8 l9 l10 l11) —
;; homes in ix_home order, RAX/R10/R11 scratch): the rewriter is syntactic,
;; and a folded helper spelling would never match the computed files that
;; consumers hold. The MkRegs field order is rax rcx rdx rbx rbp rsi rdi
;; r8 r9 r10 r11 r12-r15; local k's home carries lk.

;; instruction count as fuel (istn's machine-side mirror)
(fn vx_iln ((xs (List XInstr))) Nat
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons i t) (S (vx_iln t)))))

;; register-pure instruction: completes XNorm inside its own fuel unit,
;; touches neither memory nor control — ix_acc's emission alphabet
(fn vx_regi ((i XInstr)) Bool
  (match i
    ((XMovRI r v) True)
    ((XMovRR d s) True)
    ((XBin o d s) True)
    ((XShlI d k) True)
    ((XShrI d k) True)
    ((XBin32 o d s) True)
    ((XShlI32 d k) True)
    ((XMovRR32 d s) True)
    ((XRorI32 d k) True)
    ((XDivU r) False)
    ((XLoad8 d a) False)
    ((XStore8 a s) False)
    ((XBlock b) False)
    ((XLoop b) False)
    ((XBr d) False)
    ((XBrIf c d) False)
    ((XCall k) False)
    (XRet False)
    (XSyscall False)))

(fn vx_regis ((xs (List XInstr))) Bool
  (measure (struct xs))
  (match xs
    (Nil True)
    ((Cons i t) (if (vx_regi i) (vx_regis t) False))))

;; the continuation adapter: xeval_seq's own dispatch over a prefix output
;; (ist_cont's machine-side mirror)
(fn vx_cont ((f Nat) (m XModule) (b (List XInstr)) (r (Option XOut)))
  (Option XOut)
  (match r
    (None None)
    ((Some out)
     (match out
       ((XNorm rs2 mem2) (xeval_seq f m b rs2 mem2))
       ((XBrk d2 rs2 mem2) r)
       ((XRetO rs2 mem2) r)
       (XTrap r)))))

;; constants sit in the 64-bit register band — the ONE raw-alignment premise
;; (validator-checked; wk implies it but the lemma wants the weakest form)
(fn vx_cb ((e IExp)) Bool
  (measure (struct e))
  (match e
    ((IConst n) (if (le 0 n) (lt n 18446744073709551616) False))
    ((ILoc i) True)
    ((IBin k o a b) (if (vx_cb a) (vx_cb b) False))
    ((IRotr k a c) (if (vx_cb a) (vx_cb c) False))
    ((IExt kf kt a) (vx_cb a))
    ((ITrunc kf kt a) (vx_cb a))
    ((ILoad a) (vx_cb a))))

;; total unwrappers — the Option-INVERSION recipe rides them: seed
;; (= x (vx_oX (Some x))) by compute, rewrite (Some x) back through the
;; premise equation, compute forward to the concrete payload
(fn vx_osrc ((o (Option Src))) Src
  (match o
    (None (SImm 0))
    ((Some s2) s2)))

(fn vx_oint ((o (Option Int))) Int
  (match o
    (None 0)
    ((Some x) x)))

(fn vx_oxi ((o (Option (List XInstr)))) (List XInstr)
  (match o
    (None Nil)
    ((Some xs) xs)))

;; --- the tower/append bookkeeping ------------------------------------------------

;; snoc under the tower: fuel for (xs ++ [i]) at c = fuel for xs at (S c)
(claim vxg_tw_snoc
  (goal ((xs (List XInstr)) (i XInstr) (c Nat)) ()
    (= (lg_fuel (vx_iln (ix_app xs (list i))) c) (lg_fuel (vx_iln xs) (S c))))
  (induct xs
    ((case Nil (steps ((compute both)) refl))
     (case Cons
       (h t)
       (steps
         ((unfold ix_app lhs)
          (reduce lhs)
          (unfold vx_iln lhs)
          (reduce lhs)
          (unfold lg_fuel lhs)
          (reduce lhs)
          (unfold vx_iln rhs)
          (reduce rhs)
          (unfold lg_fuel rhs)
          (reduce rhs)
          (rewrite (hyp 0) lr lhs true ()))
         refl)))))

;; register-purity survives the snoc
(claim vxg_regis_snoc
  (goal ((xs (List XInstr)) (i XInstr))
    ((= (vx_regis xs) True) (= (vx_regi i) True))
    (= (vx_regis (ix_app xs (list i))) True))
  (induct xs
    ((case Nil
       (steps
         ((unfold ix_app lhs)
          (reduce lhs)
          (unfold vx_regis lhs)
          (reduce lhs)
          (rewrite (premise 1) lr lhs true ())
          (reduce lhs)
          (unfold vx_regis lhs)
          (reduce lhs))
         refl))
     (case Cons
       (h t)
       (chain
         (steps
           ((unfold ix_app lhs) (reduce lhs) (unfold vx_regis lhs) (reduce lhs)))
         (case-on (vx_regi h) Bool
           ((case True
              (chain
                (steps ((rewrite (hyp 0) lr lhs true ()) (reduce lhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ()
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)
                   (steps ((rewrite (premise 1) lr lhs true ())) refl)))
                refl))
            (case False
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (reduce lhs))
                    refl))
                (absurd (premise hff)))))))))))

;; --- THE SEAM (ist_seam's machine-side mirror) -----------------------------------
;; Running an appended register-pure prefix = the continuation of the rest
;; applied to the prefix's own run, at one tower unit per instruction
;; position. The g-side tower is arbitrary: a register-pure prefix's run is
;; fuel-insensitive once sufficient.

(claim vxg_seam
  (goal
    ((a (List XInstr))
     (b (List XInstr))
     (f Nat)
     (g Nat)
     (m XModule)
     (rs Regs)
     (mem Mem))
    ((= (vx_regis a) True))
    (=
      (xeval_seq (lg_fuel (vx_iln a) (S f)) m (ix_app a b) rs mem)
      (vx_cont (S f) m b (xeval_seq (lg_fuel (vx_iln a) (S g)) m a rs mem))))
  (induct a
    ((case Nil
       (steps
         ((unfold vx_iln lhs)
          (reduce lhs)
          (unfold lg_fuel lhs)
          (reduce lhs)
          (unfold ix_app lhs)
          (reduce lhs)
          (unfold vx_iln rhs)
          (reduce rhs)
          (unfold lg_fuel rhs)
          (reduce rhs)
          (unfold xeval_seq rhs)
          (reduce rhs)
          (unfold vx_cont rhs)
          (reduce rhs))
         refl))
     (case Cons
       (i0 t)
       (chain
         (steps
           ((unfold vx_iln lhs)
            (reduce lhs)
            (unfold lg_fuel lhs)
            (reduce lhs)
            (unfold ix_app lhs)
            (reduce lhs)
            (unfold xeval_seq lhs)
            (reduce lhs)
            (unfold vx_iln rhs)
            (reduce rhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold xeval_seq rhs)
            (reduce rhs)))
         (case-on i0 XInstr
           ((case XMovRI
              (r vv)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XMovRR
              (d s)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XBin
              (o d s)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XShlI
              (d k)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XShrI
              (d k)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XBin32
              (o d s)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XShlI32
              (d k)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XMovRR32
              (d s)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
