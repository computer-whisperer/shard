;; --- emitted code is register-pure (feeds vxg_seam's premise) --------------------

(claim vxg_accreg
  (goal ((e IExp) (is (List XInstr))) ((= (ix_acc RAX e) (Some is)))
    (= (vx_regis is) True))
  (induct e
    ((case IConst
       (n)
       (chain
         (have hoi (= is (vx_oxi (Some is))) (steps ((compute rhs)) refl))
         (have his (= is (list (XMovRI RAX n)))
           (steps
             ((rewrite (premise hoi) lr lhs true ())
              (rewrite (premise 0) rl lhs true ())
              (compute lhs))
             refl))
         (steps ((rewrite (premise his) lr lhs true ()) (compute lhs)) refl)))
     (case ILoc
       (i)
       (case-on (ix_home i) Option
         ((case None
            (chain
              (have hhome (= (ix_home i) None)
                (steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (chain
                (have hn (= (ix_acc RAX (ILoc i)) None)
                  (steps
                    ((unfold ix_acc lhs)
                     (reduce lhs)
                     (rewrite (premise hhome) lr lhs true ())
                     (reduce lhs)
                     (compute lhs))
                    refl))
                (have hcl (= (Some is) None)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (rewrite (premise hn) lr lhs true ()))
                    refl))
                (absurd (premise hcl)))))
          (case Some
