                  ((rewrite (premise hoi) lr lhs true ())
                   (rewrite (premise 0) rl lhs true ())
                   (unfold ix_acc lhs)
                   (reduce lhs)
                   (rewrite (premise hhome) lr lhs true ())
                   (compute lhs))
                  refl))
              (steps
                ((rewrite (premise his) lr lhs true ()) (compute lhs))
                refl))))))
