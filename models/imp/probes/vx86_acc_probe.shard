                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XRorI32
              (d k)
              (chain
                (steps ((rewrite (hyp 0) lr both true ())))
                (have hfs
                  (= (lg_fuel (vx_iln t) (S f)) (S (lg_fuel (vx_iln t) f)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (have hgs
                  (= (lg_fuel (vx_iln t) (S g)) (S (lg_fuel (vx_iln t) g)))
                  (rewrite-with (lemma lg_snoc) lr lhs () () refl))
                (steps
                  ((rewrite (premise hfs) lr lhs false ())
                   (unfold xeval_instr lhs)
                   (reduce lhs)
                   (rewrite (premise hgs) lr rhs false ())
                   (unfold xeval_instr rhs)
                   (reduce rhs)))
                (have hrt (= (vx_regis t) True)
                  (steps
                    ((rewrite (premise 0) rl rhs true ())
                     (unfold vx_regis rhs)
                     (reduce rhs)
                     (rewrite (hyp 0) lr rhs true ())
                     (unfold vx_regi rhs)
                     (reduce rhs))
                    refl))
                (rewrite-with
                  (hyp ih)
                  lr
                  lhs
                  ((inst g g))
                  ((steps ((rewrite (premise hrt) lr lhs true ())) refl)))
                refl))
            (case XDivU
              (r)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XLoad8
              (d ad)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XStore8
              (ad s)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XBlock
              (bb)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
