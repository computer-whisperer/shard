;; --- THE VALUE LEMMA (dst = RAX): a completed ix_acc emission, run from the
;; aligned file, puts iexp's value in RAX and touches nothing else ------------------

(claim vxg_acc
  (goal
    ((e IExp)
     (l0 Int)
     (l1 Int)
     (l2 Int)
     (l3 Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l10 Int)
     (l11 Int)
     (a0 Int)
     (s10 Int)
     (s11 Int)
     (v Int)
     (is (List XInstr))
     (g Nat)
     (m XModule)
     (mem Mem)
     (msz Int))
    ((= (ix_acc RAX e) (Some is))
     (= (iexp e (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11) mem msz) (Some v))
     (= (vx_cb e) True))
    (=
      (xeval_seq
        (lg_fuel (vx_iln is) (S g))
        m
        is
        (MkRegs a0 l3 l2 l6 l7 l1 l0 l4 l5 s10 s11 l8 l9 l10 l11)
        mem)
      (Some
        (XNorm (MkRegs v l3 l2 l6 l7 l1 l0 l4 l5 s10 s11 l8 l9 l10 l11) mem))))
  (induct e
    ((case IConst
       (n)
       (case-on (le 0 n) Bool
         ((case False
            (chain
              (have hff (= True False)
                (steps
                  ((rewrite (premise 2) rl lhs true ())
                   (unfold vx_cb lhs)
                   (reduce lhs)
                   (rewrite (hyp 0) lr lhs true ())
                   (reduce lhs))
                  refl))
              (absurd (premise hff))))
          (case True
            (case-on (lt n 18446744073709551616) Bool
              ((case False
                 (chain
                   (have hff (= True False)
                     (steps
                       ((rewrite (premise 2) rl lhs true ())
                        (unfold vx_cb lhs)
                        (reduce lhs)
                        (rewrite (hyp 1) lr lhs true ())
                        (reduce lhs)
                        (rewrite (hyp 0) lr lhs true ()))
                       refl))
                   (absurd (premise hff))))
               (case True
                 (chain
                   (have hoi (= is (vx_oxi (Some is)))
                     (steps ((compute rhs)) refl))
                   (have his (= is (list (XMovRI RAX n)))
                     (steps
                       ((rewrite (premise hoi) lr lhs true ())
                        (rewrite (premise 0) rl lhs true ())
                        (compute lhs))
