                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XBr
              (d)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XBrIf
              (c0 d)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XCall
              (k)
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XRet
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff))))
            (case XSyscall
              (chain
                (have hff (= True False)
                  (steps
                    ((rewrite (premise 0) rl lhs true ())
                     (unfold vx_regis lhs)
                     (reduce lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (unfold vx_regi lhs)
                     (reduce lhs))
                    refl))
                (absurd (premise hff)))))))))))

;; --- the atom lemma --------------------------------------------------------------
;; An ix_src-accepted operand reads from the aligned register file exactly
;; what iexp reads from the locals spine. The home map grounds leaf-by-leaf
;; under the int_eq descent; the IConst leaf is where vx_cb pays (SImm
;; wraps64 on the machine, iexp reads raw).

(claim vxg_src
  (goal
    ((e IExp)
     (l0 Int)
     (l1 Int)
     (l2 Int)
     (l3 Int)
     (l4 Int)
     (l5 Int)
     (l6 Int)
     (l7 Int)
     (l8 Int)
     (l9 Int)
     (l10 Int)
     (l11 Int)
     (a0 Int)
     (s10 Int)
     (s11 Int)
     (s Src)
     (vb Int)
     (mem Mem)
     (msz Int))
    ((= (ix_src e) (Some s))
     (= (iexp e (list l0 l1 l2 l3 l4 l5 l6 l7 l8 l9 l10 l11) mem msz) (Some vb))
     (= (vx_cb e) True))
    (= (xsrc (MkRegs a0 l3 l2 l6 l7 l1 l0 l4 l5 s10 s11 l8 l9 l10 l11) s) vb))
  (induct e
    ((case IConst
       (n)
       (case-on (le 0 n) Bool
         ((case False
            (chain
              (have hff (= True False)
                (steps
                  ((rewrite (premise 2) rl lhs true ())
                   (unfold vx_cb lhs)
                   (reduce lhs)
                   (rewrite (hyp 0) lr lhs true ())
                   (reduce lhs))
                  refl))
              (absurd (premise hff))))
          (case True
            (case-on (lt n 18446744073709551616) Bool
              ((case False
                 (chain
                   (have hff (= True False)
                     (steps
                       ((rewrite (premise 2) rl lhs true ())
                        (unfold vx_cb lhs)
                        (reduce lhs)
                        (rewrite (hyp 1) lr lhs true ())
                        (reduce lhs)
                        (rewrite (hyp 0) lr lhs true ()))
                       refl))
                   (absurd (premise hff))))
               (case True
                 (chain
                   (have hss (= s (vx_osrc (Some s)))
                     (steps ((compute rhs)) refl))
                   (have hvv (= vb (vx_oint (Some vb)))
                     (steps ((compute rhs)) refl))
                   (have hs2 (= s (SImm n))
                     (steps
                       ((rewrite (premise hss) lr lhs true ())
                        (rewrite (premise 0) rl lhs true ())
                        (compute lhs))
                       refl))
                   (have hv2 (= vb n)
                     (steps
                       ((rewrite (premise hvv) lr lhs true ())
                        (rewrite (premise 1) rl lhs true ())
                        (compute lhs))
                       refl))
                   (steps
                     ((rewrite (premise hs2) lr lhs true ())
                      (rewrite (premise hv2) lr rhs true ())
                      (unfold xsrc lhs)
                      (reduce lhs)
                      (unfold wrap64 lhs)
                      (reduce lhs)))
                   (rewrite-with
                     (lemma mod_unique)
                     lr
                     lhs
                     ((inst q 0) (inst r n))
                     ((by
                        arith
                        (list (list 1 0 0 0 0 0 0 0) (list 1 0 0 0 0 0 0 0)))
                      (steps ((rewrite (hyp 1) lr lhs true ())) refl)
                      (steps ((rewrite (hyp 0) lr lhs true ())) refl)))
                   refl))))))))
     (case ILoc
       (i)
       (case-on (int_eq i 0) Bool
         ((case True
            (chain
              (have hik (= (int_eq i 0) True)
                (steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (have heq (= i 0)
                (by arith (list (list 1 0 0 0 -1) (list 1 0 0 0 1))))
              (have hss (= s (vx_osrc (Some s))) (steps ((compute rhs)) refl))
              (have hvv (= vb (vx_oint (Some vb))) (steps ((compute rhs)) refl))
              (have hs2 (= s (SReg RDI))
                (steps
                  ((rewrite (premise hss) lr lhs true ())
                   (rewrite (premise 0) rl lhs true ())
                   (rewrite (premise heq) lr lhs true ())
                   (compute lhs))
                  refl))
              (have hv2 (= vb l0)
                (steps
                  ((rewrite (premise hvv) lr lhs true ())
                   (rewrite (premise 1) rl lhs true ())
                   (rewrite (premise heq) lr lhs true ())
                   (compute lhs))
                  refl))
              (steps
                ((rewrite (premise hs2) lr lhs true ())
                 (rewrite (premise hv2) lr rhs true ())
