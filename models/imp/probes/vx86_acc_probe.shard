                           ((unfold ix_acc lhs)
                            (reduce lhs)
                            (rewrite (premise hck) lr lhs true ())
                            (reduce lhs)
                            (rewrite (premise hcc) lr lhs true ())
                            (reduce lhs)
                            (compute lhs))
