;;; examples/lxkernel_probe.shard — ground pins for the Linux kernel model
;;; (models/linux/kernel.shard, docs/X86.md §32 slice W1). These are the
;;; model's defining observations, stated small: the exit truncation, the
;;; write event carrying the OFFERED bytes (read back from a QUANTIFIED
;;; memory — mem is opaque, so ground bytes would go stuck), the oracle
;;; advancing, and the two refusals (exhausted oracle, unmodeled nr).
;;; The differential twin — the REAL kernel agreeing with these arms —
;;; is the W3 gate's business; this file pins what the arms SAY.
;;;
;;; The READ arm (the read rung): the return draw normalizing into
;;; [0, count] (over-ask clamped, negative → 0 = the EOF shape), the
;;; delivered bytes drawn mod-256 off the same stream and STORED at buf
;;; (LxGoM carries the result memory), and the mid-read dry refusal.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(use (:: std mem *))
(import "../kernel.shard")
(use (:: models linux kernel *))

;; exit: terminal, code passed through
(claim lxp_exit
  (goal ((mem Mem)) ()
    (= (lx_step 60 7 0 0 mem (MkLxWorld Nil)) (Some (LxEnd 7 (LxExited 7)))))
  (steps ((compute both)) refl))

;; exit: the kernel keeps only the wait-status byte (300 & 0xFF = 44)
(claim lxp_exit_trunc
  (goal ((mem Mem)) ()
    (= (lx_step 60 300 0 0 mem (MkLxWorld Nil)) (Some (LxEnd 44 (LxExited 44)))))
  (steps ((compute both)) refl))

;; write: one oracle answer consumed, the event records the offered bytes
(claim lxp_write
  (goal ((mem Mem)) ()
    (=
      (lx_step 1 1 100 2 mem (MkLxWorld (list 2)))
      (Some
        (LxGo
          2
          (MkLxWorld Nil)
          (LxWrote 1 (Cons (mem_get mem 100) (Cons (mem_get mem 101) Nil)))))))
  (steps ((compute both)) refl))

;; write of length zero: an answer is still consumed, the offer is empty
(claim lxp_write_z
  (goal ((mem Mem)) ()
    (=
      (lx_step 1 1 100 0 mem (MkLxWorld (list 0)))
      (Some (LxGo 0 (MkLxWorld Nil) (LxWrote 1 Nil)))))
  (steps ((compute both)) refl))

;; write against an exhausted oracle: None — the world-layer resource
;; convention, exactly like fuel
(claim lxp_dry
  (goal ((mem Mem)) () (= (lx_step 1 1 100 2 mem (MkLxWorld Nil)) None))
  (steps ((compute both)) refl))

;; an unmodeled syscall number is REFUSED, never guessed
(claim lxp_unmodeled
  (goal ((mem Mem) (ws (List Int))) ()
    (= (lx_step 999 0 0 0 mem (MkLxWorld ws)) None))
  (steps ((compute both)) refl))

;; --- the read arm (the read rung) --------------------------------------------------

;; full delivery: ret draw = count, two byte draws stored at buf ascending,
;; the event carrying exactly what landed in memory
(claim lxp_read
  (goal ((mem Mem)) ()
    (=
      (lx_step 0 0 100 2 mem (MkLxWorld (list 2 65 66)))
      (Some
        (LxGoM
          2
          (MkLxWorld Nil)
          (LxRead 0 (Cons 65 (Cons 66 Nil)))
          (mem_set (mem_set mem 100 65) 101 66)))))
  (steps ((compute both)) refl))

;; the kernel never delivers more than asked: an over-ask draw clamps to
;; count (same result as the full-delivery pin)
(claim lxp_read_clamp
  (goal ((mem Mem)) ()
    (=
      (lx_step 0 0 100 2 mem (MkLxWorld (list 5 65 66)))
      (Some
        (LxGoM
          2
          (MkLxWorld Nil)
          (LxRead 0 (Cons 65 (Cons 66 Nil)))
          (mem_set (mem_set mem 100 65) 101 66)))))
  (steps ((compute both)) refl))

;; the EOF shape: a zero draw delivers nothing, memory untouched
(claim lxp_read_eof
  (goal ((mem Mem)) ()
    (=
      (lx_step 0 0 100 2 mem (MkLxWorld (list 0)))
      (Some (LxGoM 0 (MkLxWorld Nil) (LxRead 0 Nil) mem))))
  (steps ((compute both)) refl))

;; a negative draw normalizes to 0 (the error leg is named growth; v1
;; draws land in the kernel's success range, exactly as exit masks)
(claim lxp_read_neg
  (goal ((mem Mem)) ()
    (=
      (lx_step 0 0 100 2 mem (MkLxWorld (list -4)))
      (Some (LxGoM 0 (MkLxWorld Nil) (LxRead 0 Nil) mem))))
  (steps ((compute both)) refl))

;; bytes are bytes: a wide draw is mod-256 masked before storing
(claim lxp_read_mask
  (goal ((mem Mem)) ()
    (=
      (lx_step 0 0 100 1 mem (MkLxWorld (list 1 321)))
      (Some
        (LxGoM 1 (MkLxWorld Nil) (LxRead 0 (Cons 65 Nil)) (mem_set mem 100 65)))))
  (steps ((compute both)) refl))

;; the stream running dry MID-READ refuses (the resource convention):
;; the ret draw asks for two bytes, only one remains
(claim lxp_read_dry
  (goal ((mem Mem)) () (= (lx_step 0 0 100 2 mem (MkLxWorld (list 2 65))) None))
  (steps ((compute both)) refl))
