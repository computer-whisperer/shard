;;; tracer_demo — deliberately broken proofs exercising the tracer's failure
;;; diagnostics (kernel/trace.shard): have-justification descent, rewrite-with
;;; obligation descent, Absurd replay, and the in-scope context dump. Every
;;; claim except cond_lemma and t_oblig_fine FAILS BY DESIGN (like the
;;; *_rejects examples); focus each one to see its trace shape:
;;;
;;;   eval run kernel/check.shard examples/tracer_demo.shard t_hyp_idx
;;;
;;; Manual regression for the tracer: if these trace shapes regress (a blind
;;; "FAILS v v v" with no descent, a missing context dump), the tracer broke.

(import "../kernel/stdlib.shard")

(fn andb2 ((a Bool) (b Bool)) Bool
  (match a
    (True b)
    (False False)))

(fn all_t ((b (List Bool))) Bool
  (match b
    (Nil True)
    ((Cons h t) (if h (all_t t) False))))

;; a conditional lemma to cite via rewrite-with
(claim cond_lemma
  (goal ((a Bool)) ((= a True)) (= (andb2 a True) True))
  (steps ((rewrite (premise 0) lr lhs true ()) (compute lhs)) refl))

;; 1. BROKEN HAVE JUSTIFICATION — the historical inv_step shape: simp rhs
;; reduces one layer past the folded lhs, Refl can't close. Expect:
;;   have (…)  JUSTIFICATION FAILS  v v v  + the Refl mismatch + context.
(claim t_have_broken
  (goal ((x (List Bool))) ((= (all_t (Cons True x)) True)) (= True True))
  (have (= (all_t (Cons True x)) True)
    (steps ((rewrite (premise 0) rl rhs true ()) (simp rhs)) refl)
    refl))

;; 2. FAILING REWRITE-WITH OBLIGATION — the cited premise can't discharge
;; (the goal premise says the opposite). Expect:
;;   obligation 0 of rewrite (lemma cond_lemma):  b  =  True  FAILS  v v v
(claim t_oblig_broken
  (goal ((b Bool)) ((= b False)) (= (andb2 b True) True))
  (rewrite-with
    (lemma cond_lemma)
    lr
    lhs
    ((inst a b))
    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
    refl))

;; 3. ABSURD THAT DOESN'T CLASH — the cited fact is consistent. Expect:
;;   Absurd (premise 0) does NOT close — both sides simp to: …  + context.
(claim t_absurd_weak
  (goal ((x Int)) ((= (le 0 x) True)) (= True False))
  (absurd (premise 0)))

;; 4. WRONG HYP INDEX — the historical pm2bh shape: citing the IH slot where
;; the case-on eq lives. Expect: did-NOT-apply + the context dump naming
;; hyp 0 (the case eq) and hyp 1 (the conditional IH, tagged).
(claim t_hyp_idx
  (goal ((b (List Bool))) ((= (all_t b) True)) (= (all_t b) True))
  (induct b
    ((case Nil (steps ((compute both)) refl))
     (case Cons
       (h t)
       (case-on h Bool
         ((case True (steps ((rewrite (hyp 1) lr lhs true ())) refl))
          (case False (absurd (premise 0)))))))))

;; 5. PASSING rewrite-with — obligations must stay SILENT (no trace noise).
(claim t_oblig_fine
  (goal ((c Bool)) ((= c True)) (= (andb2 c True) True))
  (rewrite-with
    (lemma cond_lemma)
    lr
    lhs
    ((inst a c))
    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
    refl))
