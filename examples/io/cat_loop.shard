;;; cat_loop.shard — the ORACLE-DRIVEN LOOP, proven.
;;;
;;; cat_lazy showed a straight-line effectful program's clock theorem. The hard
;;; case is a LOOP whose trip count is decided by the oracle (read until EOF),
;;; not by a structural argument — so reduction gets stuck at the branch on the
;;; oracle and there is no input list to induct on. Two moves crack it:
;;;   1. Split the effect: `oracle_line` is the UNINTERPRETED input oracle (an
;;;      Option, no clock); `tick`/`emit` advance the clock (tick is DEFINED →
;;;      its clock law is a *lemma*; emit is the output extern → an *axiom*).
;;;      So in a proof only the DATA is opaque; all clock arithmetic computes.
;;;   2. Add a FUEL (a Nat) to get a structural measure to induct on. `cat`
;;;      (unbounded) is what RUNS; `cat_fuel` is the same loop with fuel, and we
;;;      prove the clock DISCIPLINE on it for ALL fuel — covering every finite
;;;      run. The loop body case-splits on the oracle via CaseOn.

(import "../../kernel/stdlib.shard")   ; stdlib types (List/Option/Bool/Pair)
(import "../../std/nat.shard")     ; Nat (Z/S)
(import "../../std/order.shard")   ; le_refl / le_succ / le_trans

(type World (World Int))                       ; the clock token
(fn w_clock ((w World)) Int (match w ((World n) n)))

;; tick: advance the clock. DEFINED — so its clock law is a proven lemma.
(fn tick ((w World)) World (match w ((World n) (World (+ n 1)))))

(claim tick_clock
  (goal ((w World)) () (= (w_clock (tick w)) (+ (w_clock w) 1)))
  (case-on w World ((case World (n) (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl)))))

;; the I/O vocabulary -----------------------------------------------------------
;; oracle_line: read the next input line (None at EOF) — UNINTERPRETED, no clock.
;; emit: write a line — the output effect; its clock law is the bridging AXIOM.
(extern oracle_line ((w World)) (Option (List Int)))
(extern emit        ((line (List Int)) (w World)) World)

(axiom emit_clock
  (goal ((line (List Int)) (w World)) () (= (w_clock (emit line w)) (+ (w_clock w) 1))))

;; the program ------------------------------------------------------------------
;; cat (unbounded): read a line; EOF → tick + done; else write (emit) it after a
;; tick, and loop. This is what RUNS (the handler drives oracle_line/emit).
(fn cat ((w World)) World
  (match (oracle_line w)
    (None        (tick w))
    ((Some line) (cat (emit line (tick w))))))

(fn main ((w World)) World (cat w))

;; cat_fuel: the same loop with a Nat fuel — the structural measure we induct on.
(fn cat_fuel ((n Nat) (w World)) World
  (match n
    (Z w)
    ((S k)
      (match (oracle_line w)
        (None        (tick w))
        ((Some line) (cat_fuel k (emit line (tick w))))))))

;; THE CLOCK DISCIPLINE, for the oracle-driven loop --------------------------
;; ∀ n w.  le (w_clock w) (w_clock (cat_fuel n w)) = True
;; The clock NEVER decreases, no matter what the oracle does — every loop step
;; only advances it. Whatever the (uninterpreted) trip count, the run's clocks
;; are monotonic, so no effect ever reuses an earlier clock. Induct on the fuel;
;; CaseOn the oracle; the Some step chains the IH with the per-step advance via
;; le_trans (b = the post-write clock).
(claim cat_mono
  (goal ((n Nat) (w World)) () (= (le (w_clock w) (w_clock (cat_fuel n w))) True))
  (induct n ((case Z (steps ((simp lhs)) (by ord (list)))) (case S (steps ((simp lhs)) (case-on (oracle_line w) Option ((case None (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs) (rewrite (lemma tick_clock) lr lhs true ())) (by ord (list)))) (case Some (line) (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) (rewrite-with (lemma le_trans) lr lhs ((inst b (w_clock (emit line (tick w))))) ((steps ((rewrite (lemma emit_clock) lr lhs true ()) (rewrite (lemma tick_clock) lr lhs true ())) (by ord (list))) (rewrite-with (hyp 1) lr lhs () () refl)) refl))))))))))
