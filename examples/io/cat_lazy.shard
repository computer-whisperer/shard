;;; cat_lazy.shard — LAZY-ORACLE I/O via externs (option C, dynamic effects).
;;;
;;; Unlike echo_world (which pre-slurps all stdin into a data World), here I/O
;;; happens MID-COMPUTATION through `extern` functions with no body. In a proof
;;; they are UNINTERPRETED symbols whose behaviour is given by axioms (the
;;; bridging axioms below); at RUN time the Rust effect handler intercepts the
;;; stuck calls and performs the real read/write (eval.rs set_effect_handler →
;;; bin/check.rs run_program). This is BOUNDARIES.md mechanism (B).
;;;
;;; World is now just the CLOCK TOKEN — the OS holds the real input/output; the
;;; clock is the proof-level sequencing handle each effect advances. The TCB is
;;; exactly the two extern axioms (each effect ticks the clock by 1): the
;;; trusted assumption the handler must satisfy, explicit and auditable.

(type World (World Int))  ; the clock token
(fn w_clock ((w World)) Int
  (match w
    ((World n) n)))

;; project the World out of a read result (the Pair's second component).
(fn world_after ((p (Pair (Option (List Int)) World))) World
  (match p
    ((Pair m w) w)))

;; --- the I/O vocabulary: effectful externs (no body) -----------------------
;; read_line: read one line; None at EOF. write_line: emit a line. Each threads
;; the World, so the clock sequences them and the reducer fires them in order.
(extern read_line ((w World)) (Pair (Option (List Int)) World))
(extern write_line ((line (List Int)) (w World)) World)

;; --- the program: lazy cat -------------------------------------------------
;; Read a line; EOF → done; else write it and loop. The loop is driven by the
;; ORACLE (read_line's None), not a structural argument — this RUNS (the handler
;; supplies the lines) but its whole-loop termination/clock proof needs a
;; measure, unlike echo_world's structural fold (see note at bottom).
(fn cat ((w World)) World
  (match (read_line w)
    ((Pair mline w1)
     (match mline
       (None w1)
       ((Some line) (cat (write_line line w1)))))))

(fn main ((w World)) World (cat w))

;; --- the bridging axioms: the TCB, as equations ----------------------------
;; Each effect advances the clock by exactly 1. The bytes/EOF stay
;; uninterpreted — these say ONLY what a proof needs about sequencing, and are
;; the contract the run-time handler is trusted to meet.
(axiom read_line_ticks
  (goal ((w World)) ()
    (= (w_clock (world_after (read_line w))) (+ (w_clock w) 1))))

(axiom write_line_ticks
  (goal ((line (List Int)) (w World)) ()
    (= (w_clock (write_line line w)) (+ (w_clock w) 1))))

;; --- proof: the clock discipline for a straight-line effectful program -----
;; rw_once does one read then one write; its clock advances by exactly 2 — the
;; effectful analog of echo_world's clock theorem, now with UNINTERPRETED I/O
;; whose sequencing is pinned down purely by the bridging axioms + lia.
(fn rw_once ((line (List Int)) (w World)) World
  (write_line line (world_after (read_line w))))

(claim rw_once_ticks_2
  (goal ((line (List Int)) (w World)) ()
    (= (w_clock (rw_once line w)) (+ (w_clock w) 2)))
  (steps
    ((unfold rw_once lhs)
     (rewrite (lemma write_line_ticks) lr lhs true ())
     (rewrite (lemma read_line_ticks) lr lhs true ()))
    (by arith (list))))
