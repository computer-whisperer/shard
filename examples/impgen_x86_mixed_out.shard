                                                              rw)))))))))))))))))))))))))))
        (MkRegs za 0 x2 0 0 x1 x0 0 0 zb zc 0 0 0 0)
        m)
      (xm_scont
        0
        zb
        zc
        (S f)
        (MkXModule restfs 0 65536)
        rw
        (istmts (S^ 24 (S g)) 65536 (inline gb_imxl_c0_i) (list x0 x1 x2) m))))
  (chain
    (steps ((compute both (stop xm_scont))))
    (case-on (le 0 x2) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ()) (compute both (stop xm_scont))))
           (case-on (lt x2 65536) Bool
             ((case True
                (chain
                  (have hlt2 (= (lt x2 65536) True)
                    (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                  (have hle2 (= (le (+ x2 1) 65536) True)
                    (steps () (by arith (rows (goal 1) (hlt2 1)))))
                  (steps
