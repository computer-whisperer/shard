                                                      (Cons
                                                        (XMovRR RAX RSI)
                                                        (Cons
                                                          (XBin
                                                            XAnd
                                                            RAX
                                                            (SImm 255))
                                                          (Cons
                                                            (XStore8
                                                              (AReg RDX)
                                                              (SReg RAX))
