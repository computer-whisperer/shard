    (rewrite-with (lemma sqs_x_imxl_c0) lr lhs ((inst g c2)) ())
    (case-on
      (istmts (S^ 24 (S c2)) 65536 (inline gb_imxl_c0_i) (list x0 x1 x2) m)
      Option
      ((case None
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute
                both
