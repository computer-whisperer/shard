;;; examples/x86intloop_src.build.shard — the BUILD ENTRY for the x86_64
;;; INT-RETURN loop fragment (docs/X86.md §14 growth) under the
;;; re-founded charter (docs/BUILD.md §4/§5, rung 2): content only.
;;; ARTIFACT bindings, plan assembly, and wire are DERIVED (tools/lowbuild
;;; pinlib); the manifest gate verifies the derived index bindings against
;;; the cert file read raw.
;;;
;;;     (fn build_mods ((t Target)) (List PinMod))   — the standard symbol
;;;
;;; The sum piece is a LEAF cert: the module is the cert's module at
;;; restfs := Nil — [self]. The XFunc literal comes from the GENERATED
;;; cert file itself (x86intloop_out.shard's xi_bsum_func) — no hand
;;; copies; the cert<->binary tie is the BYTETIE gate's. Vectors are
;;; result-only (PV): the harness's data page starts ZEROED, so spec-side
;;; expected values are the source fn over mem_empty (mask-on-read zeros
;;; = the zeroed page) — the loop path and the accumulator are exercised
;;; on silicon; content-dependent sums arrive with the bin rung's engine
;;; leg (payload bytes at BUF, X86.md §22).
;;;
;;; ADDRESSES: the harness MAP_FIXEDs its data page at DATA_BASE =
;;; 0x40000000. The cert PREMISE domain is [0, 65536): the shipped
;;; binary is range-agnostic, so the vectors exercise the mapped
;;; DATA_BASE window while the certs cover the model's low range.
;;;
;;; RUN IT:
;;;   bin/shard_eval run tools/lowbuild/lowbuild.shard pinlib examples/x86intloop_src.build.shard x86

(import "../kernel/stdlib.shard")
(import "x86intloop_src.shard")
(use (:: examples x86intloop_src *))
(import "x86intloop_out.shard")
(use (:: examples x86intloop_out xi_bsum_func))
(use (:: examples x86intloop_out xi_atoi_func))
(import "../std/mem")
(use (:: std mem *))
(import "../models/x86/x86.shard")
(use (:: models x86 x86 *))
(import "../models/x86/encode.shard")
(use (:: models x86 encode enc_func))
(import "../meta/plan")
(use (:: meta plan *))
(import "../meta/build")
(use (:: meta build *))

;; Nat of a small machine count
(fn xnat ((i Int)) Nat (measure i) (if (le i 0) Z (S (xnat (- i 1)))))

;; --- the build entry -------------------------------------------------------------

;; a result vector (PV, no memory image): expected = the source fn over
;; the zeroed page (mem_empty reads 0 everywhere, matching the harness)
(fn rvec ((args (List Int)) (want Int)) PVec (PV 0 args Nil want Nil))

(fn pmod ((nm (List Int)) (f XFunc) (vs (List PVec))) PinMod
  (MkPinMod
    nm
    (enc_func f)
    "examples/x86intloop_out.shard"
    0
    ""
    (list (eapp "lowered_" nm))
    vs))

;; DATA_BASE = 0x40000000
(fn dbase () Int 1073741824)

(fn build_mods ((t Target)) (List PinMod)
  (list
    (pmod
      "xi_bsum"
      (xi_bsum_func)
      (list
        (rvec (list (dbase) 7 5) (xi_bsum (mem_empty) (dbase) 7 (xnat 5)))
        (rvec (list (dbase) 42 0) (xi_bsum (mem_empty) (dbase) 42 (xnat 0)))
        (rvec
          (list (+ (dbase) 3) 0 100)
          (xi_bsum (mem_empty) (+ (dbase) 3) 0 (xnat 100)))))
    (pmod
      "xi_atoi"
      (xi_atoi_func)
      (list
        (rvec (list (dbase) 42 3) (xi_atoi (mem_empty) (dbase) 42 (xnat 3)))
        (rvec (list (dbase) 7 0) (xi_atoi (mem_empty) (dbase) 7 (xnat 0)))
        (rvec
          (list (+ (dbase) 9) 0 40)
          (xi_atoi (mem_empty) (+ (dbase) 9) 0 (xnat 40)))
        (rvec
          (list (dbase) 9223372036854775808 2)
          (xi_atoi (mem_empty) (dbase) 9223372036854775808 (xnat 2)))))))
