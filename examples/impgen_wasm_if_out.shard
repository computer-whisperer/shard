(claim tie_ift
  (goal () ()
    (=
      (iw_stmts (list U32 U32) (ibody_of (it_ift_fn)))
      (Some
        (list
          (LocalGet 0)
          (LocalGet 1)
          (I32Const 255)
          (I32Bin BAnd)
          I32Store8
          (Block
            (list
              (Block
                (list
                  (LocalGet 1)
                  (I32Const 5)
                  (I32Bin BEq)
                  (BrIf 0)
                  (LocalGet 1)
                  (I32Const 2)
                  (I32Bin BAdd)
                  (LocalSet 1)
                  (LocalGet 0)
                  (LocalGet 1)
                  (I32Const 255)
                  (I32Bin BAnd)
                  I32Store8
                  (Br 1)))
              (LocalGet 1)
              (I32Const 1)
              (I32Bin BAdd)
              (LocalSet 1)))))))
  (steps ((compute both)) refl))

(fn gb_ift_i () (List IStmt)
  (list
    (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
    (IIf
      (IBin U32 IEq (ILoc 1) (IConst 5))
      (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1))))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))))))

(fn gb_ift_w () (List Instr)
  (list
    (LocalGet 0)
    (LocalGet 1)
    (I32Const 255)
    (I32Bin BAnd)
    I32Store8
    (Block
      (list
        (Block
          (list
            (LocalGet 1)
            (I32Const 5)
            (I32Bin BEq)
            (BrIf 0)
            (LocalGet 1)
            (I32Const 2)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 0)
            (LocalGet 1)
            (I32Const 255)
            (I32Bin BAnd)
            I32Store8
            (Br 1)))
        (LocalGet 1)
        (I32Const 1)
        (I32Bin BAdd)
        (LocalSet 1)))))

(fn gb_ift_r1_i () (List IStmt)
  (list
    (IIf
      (IBin U32 IEq (ILoc 1) (IConst 5))
      (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1))))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))))))

(fn gb_ift_r1_w () (List Instr)
  (list
    (Block
      (list
        (Block
          (list
            (LocalGet 1)
            (I32Const 5)
            (I32Bin BEq)
            (BrIf 0)
            (LocalGet 1)
            (I32Const 2)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 0)
            (LocalGet 1)
            (I32Const 255)
            (I32Bin BAnd)
            I32Store8
            (Br 1)))
        (LocalGet 1)
        (I32Const 1)
        (I32Bin BAdd)
        (LocalSet 1)))))

(claim sqm_wid_ift
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
