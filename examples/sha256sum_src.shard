;;; examples/sha256sum_src.shard — the I2e-4c DELIVERABLE (docs/IMP.md
;;; I2e-4, docs/X86.md §50): `./sha256sum < FILE` prints the 64 hex
;;; digits of the file's SHA-256 — the first native binary whose INPUT
;;; is a cited effect extern (the read rung's consumer, exactly the
;;; named growth §50 landed for). The entry is WORLD-LEADING (§45
;;; contract) and THIN per the I2e composition ruling: one read, one
;;; branch, the pure pipeline call, one write, one exit — compute
;;; never lives in the I/O proof.
;;;
;;; The SLURP: ONE nw_read at the ground cap 64888 = 64960 − 72 (the
;;; largest input whose padded SHA-256 frame stays below the working
;;; window W@64960 — the weld's shb_pipe_read premise (le (+ wn 72)
;;; 64960) is the cap's derivation). A full read (ret = cap) cannot
;;; distinguish an exactly-cap input from a longer one without a
;;; second read, and v1 issues exactly one (§50's spine restriction):
;;; that leg is the CONTROLLED FAILURE — exit 1, nothing written — and
;;; the artifact theorem's conclusion is the Done ∨ Fail-prefix
;;; disjunction the D8 ruling prescribes. Streaming (read-until-EOF)
;;; is the streaming rung's named growth.
;;;
;;; The read result record carries the delivered count as a NAT: the
;;; machine refinement maps rax = int_of_nat k (the kernel model's
;;; normalized return), and the spec side meets mem_read and the
;;; weld's width premises directly — no Int→Nat conversion apparatus.
;;; The hex digits land at [0,64) overwriting the dead input region —
;;; the machine pipe's own layout (ihx_mem at 0), so the offered-bytes
;;; window of the write event is the same window on both sides.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(import "../std/nat")
(import "../std/sha256")

(use (:: std mem *))

(use (:: std nat *))

(use (:: std sha256 sha256_hex))

(type World (World Int))

;; the read result: advanced world, filled memory, delivered count
(type RdRes (RdRes World Mem Nat))

;; the effect externs (the platform surface's bin-local v1; nw_write /
;; nw_exit = addw's verbatim, nw_read = the §50 rung's spec face)
(extern nw_read ((w World) (m Mem) (fd Int) (buf Int) (cap Int)) RdRes)

(extern nw_write ((w World) (m Mem) (fd Int) (buf Int) (n Int)) World)

(extern nw_exit ((w World) (code Int)) World)

;; the hex deposit: store a byte list ascending at p (the spec twin of
;; the machine pipe's hex pass; its window readback is the weld's
;; trace-meeting lemma)
(fn shs_store ((m Mem) (bs (List Int)) (p Int)) Mem
  (measure (struct bs))
  (match bs
    (Nil m)
    ((Cons b t) (shs_store (mem_set m p b) t (+ p 1)))))

;; the entry: slurp at the cap, branch on the full-read leg, hash the
;; delivered window, deposit + write the 64 hex bytes, exit 0 — World
;; threaded linearly
(fn shs_main ((w World) (m Mem)) World
  (match (nw_read w m 0 0 64888)
    ((RdRes w2 m2 k)
     (if (int_eq (int_of_nat k) 64888) (nw_exit w2 1)
     (nw_exit
       (nw_write w2 (shs_store m2 (sha256_hex (mem_read k m2 0)) 0) 1 0 64)
       0)))))

(bin sha256sum (entry shs_main) (externs nw_read nw_write nw_exit))
