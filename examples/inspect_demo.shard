;;; inspect_demo.shard — the (inspect) step: a goal-state dump WITHOUT
;;; breaking the proof. (inspect) is identity for the checker; its presence
;;; forces the claim's trace block, and the tracer dumps the in-scope
;;; premises/hyps (with their citation indices) at each inspect point.
;;; The authoring idiom: drop (inspect) where you are blind, truncate with
;;; (admit), read the dump, finish the proof, delete both. insp_authoring
;;; keeps that exact shape as the regression (so this file ADMITs, exit 3,
;;; like admit_demo).

(import "../kernel/stdlib.shard")

(fn dbl ((n Int)) Int (+ n n))

(fn bnot ((b Bool)) Bool (if b False True))

(claim insp_pass
  (goal ((n Int)) ((= (lt 0 n) True)) (= (dbl n) (+ n n)))
  (steps ((unfold dbl lhs) (inspect)) refl))

(claim insp_authoring
  (goal ((b Bool)) () (= (bnot (bnot b)) b))
  (case-on b Bool
    ((case True
       (steps ((inspect) (rewrite (hyp 0) lr both true ()) (compute both)) refl))
     (case False admit))))
