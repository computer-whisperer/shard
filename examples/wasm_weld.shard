;;; wasm_weld.shard — the slice-3 COMPILE SCRIPT (docs/ISA.md §6, slice 3):
;;; the first toolchain-as-object-language exercise outside tools/prove.
;;;
;;; A shard program that (1) takes the pieces as VALUES (the Func data from
;;; wasm_pieces.shard — programs as data, no quotation machinery), (2) welds
;;; them into the composite module at the ABI layout [add=0, sum=1, triple=2],
;;; and (3) emits — to stdout — an ordinary shard file: the composite
;;; definition plus its stitched correctness claims, each proven by ONE
;;; rewrite-with of the corresponding weldable piece theorem. The
;;; linker-computed part is the instantiation: each piece's opaque filler
;;; slots and list tail are filled with the actual co-resident pieces.
;;;
;;; The emitted file is the weld CERTIFICATE: an ordinary shard source file
;;; the standard pipeline re-checks. Nothing this script does is trusted —
;;; if it welds wrong, the emitted claims fail to check.
;;;
;;; REGEN:
;;;   bin/shard_eval run examples/wasm_weld.shard > /tmp/weld.tmp
;;;   bin/shard_eval run tools/shardfmt/shardfmt.shard /tmp/weld.tmp \
;;;     > examples/wasm_weld_out.shard

(import "../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "wasm_pieces.shard")
(use (:: examples wasm_pieces *))

(type World (World Int))

(extern write ((bytes (List Int)) (w World)) World)
(extern exit ((code Int) (w World)) World)

;; --- rendering: model values -> shard source text ------------------------------
;; Lists render as explicit Cons spines (always valid; identical AST to the
;; (list …) sugar, so citation matching is unaffected). Output is rough —
;; the regen recipe pipes through shardfmt for the canonical artifact.

;; ints 0..999 — plenty for slot indices, arities, and instruction immediates.
(fn show_int3 ((n Int)) (List Int)
  (if (lt n 10) (list (+ 48 n))
  (if (lt n 100) (list (+ 48 (ediv n 10)) (+ 48 (mod n 10)))
  (list (+ 48 (ediv n 100)) (+ 48 (mod (ediv n 10) 10)) (+ 48 (mod n 10))))))

(fn cat3 ((a (List Int)) (b (List Int)) (c (List Int))) (List Int)
  (wapp a (wapp b c)))

(fn r_bop ((o Bop)) (List Int)
  (match o
    (BAdd "BAdd")
    (BSub "BSub")
    (BMul "BMul")
    (BEq "BEq")
    (BNe "BNe")
    (BLtU "BLtU")
    (BLeU "BLeU")
    (BGtU "BGtU")
    (BGeU "BGeU")))

(fn r_instr ((i Instr)) (List Int)
  (measure (struct i))
  (match i
    ((I32Const n) (cat3 "(I32Const " (show_int3 n) ")"))
    ((I32Bin o) (cat3 "(I32Bin " (r_bop o) ")"))
    (I32Eqz "(I32Eqz)")
    ((LocalGet k) (cat3 "(LocalGet " (show_int3 k) ")"))
    ((LocalSet k) (cat3 "(LocalSet " (show_int3 k) ")"))
    ((Block b) (cat3 "(Block " (r_instrs b) ")"))
    ((Loop b) (cat3 "(Loop " (r_instrs b) ")"))
    ((Br d) (cat3 "(Br " (show_int3 d) ")"))
    ((BrIf d) (cat3 "(BrIf " (show_int3 d) ")"))
    ((Call k) (cat3 "(Call " (show_int3 k) ")"))
    (Return "(Return)")))

(fn r_instrs ((is (List Instr))) (List Int)
  (measure (struct is))
  (match is
    (Nil "Nil")
    ((Cons i t) (cat3 "(Cons " (r_instr i) (cat3 " " (r_instrs t) ")")))))

(fn r_func ((f Func)) (List Int)
  (match f
    ((MkFunc p e b)
     (cat3
       "(MkFunc "
       (show_int3 p)
       (cat3 " " (show_int3 e) (cat3 " " (r_instrs b) ")"))))))

(fn r_funcs ((fs (List Func))) (List Int)
  (measure (struct fs))
  (match fs
    (Nil "Nil")
    ((Cons f t) (cat3 "(Cons " (r_func f) (cat3 " " (r_funcs t) ")")))))

;; --- the linker logic -----------------------------------------------------------

;; the composite, at the ABI layout the pieces were authored against.
(fn composite () (List Func) (list (padd) (psum) (ptriple)))

;; everything BEHIND slot k — a piece's restfs instantiation.
(fn tail_after ((k Int) (fs (List Func))) (List Func)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f t) (if (lt k 1) t (tail_after (- k 1) t)))))

;; the occupant of a filler slot (unreachable None arm keeps this total).
(fn slot ((k Int)) Func
  (match (func_at (composite) k)
    (None (padd))
    ((Some f) f)))

(fn modlit () (List Int) (cat3 "(MkWModule " (r_funcs (composite)) " 0)"))

;; --- the emitted certificate ------------------------------------------------------

(fn cat_all ((xs (List (List Int)))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons h t) (wapp h (cat_all t)))))

(fn emit () (List Int)
  (cat_all
    (list
      ";;; wasm_weld_out.shard — GENERATED by examples/wasm_weld.shard; do not edit.\n"
      ";;; The welded composite [add=0, sum=1, triple=2] and its stitched\n"
      ";;; correctness claims: each is a pure INSTANTIATION of a weldable piece\n"
      ";;; theorem from wasm_pieces.shard, with the piece's opaque filler slots\n"
      ";;; and module tail filled by the actual co-resident pieces. This file is\n"
      ";;; the weld certificate — the checker, not the weld script, is the\n"
      ";;; authority. REGEN: see wasm_weld.shard header.\n"
      "\n"
      "(import \"../kernel/stdlib.shard\")\n"
      "(import \"../models/wasm/wasm.shard\")\n"
      "(use (:: models wasm wasm *))\n"
      "(import \"wasm_pieces.shard\")\n"
      "(use (:: examples wasm_pieces *))\n"
      "\n"
      "(fn cmod () WModule "
      (modlit)
      ")\n"
      "\n"
      ";; ground smoke: the composite computes at literals\n"
      "(claim weld_smoke_add\n"
      "  (goal () () (= (call_fn (fnat 20) (cmod) 0 (list 3 4)) (Some 7)))\n"
      "  (steps ((compute both)) refl))\n"
      "\n"
      "(claim weld_smoke_sum\n"
      "  (goal () () (= (call_fn (fnat 300) (cmod) 1 (list 4)) (Some 10)))\n"
      "  (steps ((compute both)) refl))\n"
      "\n"
      "(claim weld_smoke_triple\n"
      "  (goal () () (= (call_fn (fnat 40) (cmod) 2 (list 5)) (Some 15)))\n"
      "  (steps ((compute both)) refl))\n"
      "\n"
      ";; stitched theorems — one citation each\n"
      "(claim weld_add_thm\n"
      "  (goal ((a Int) (b Int) (c Nat)) ()\n"
      "    (= (call_fn (S (S (S (S (S (S (S (S (S c))))))))) "
      (modlit)
      " 0 (list a b))\n"
      "       (Some (wrap32 (+ a b)))))\n"
      "  (rewrite-with (lemma add_thm) lr lhs\n"
      "    ((inst a a) (inst b b) (inst c c) (inst restfs "
      (r_funcs (tail_after 0 (composite)))
      "))\n"
      "    ()\n"
      "    refl))\n"
      "\n"
      "(claim weld_sum_thm\n"
      "  (goal ((n Int) (c Nat)) ((= (le 0 n) True) (= (lt n 4294967296) True))\n"
      "    (= (call_fn (S (S (S (pf_sum n (S (S (S (S (S (S (S (S (S (S (S (S (S (S c)))))))))))))))))) "
      (modlit)
      " 1 (list n))\n"
      "       (Some (sum_go n 0))))\n"
      "  (rewrite-with (lemma sum_thm) lr lhs\n"
      "    ((inst n n) (inst c c) (inst restfs "
      (r_funcs (tail_after 1 (composite)))
      "))\n"
      "    ((steps ((rewrite (premise 0) lr lhs true ())) refl)\n"
      "     (steps ((rewrite (premise 1) lr lhs true ())) refl))\n"
      "    refl))\n"
      "\n"
      "(claim weld_triple_thm\n"
      "  (goal ((x Int) (c Nat)) ()\n"
      "    (= (call_fn (S (S (S (S (S (S (S (S (S (S (S (S c)))))))))))) "
      (modlit)
      " 2 (list x))\n"
      "       (Some (triple_spec x))))\n"
      "  (rewrite-with (lemma triple_thm) lr lhs\n"
      "    ((inst x x) (inst c c) (inst f1 "
      (r_func (slot 1))
      ") (inst restfs "
      (r_funcs (tail_after 2 (composite)))
      "))\n"
      "    ()\n"
      "    refl))\n")))

(fn main ((w World)) World (exit 0 (write (emit) w)))
