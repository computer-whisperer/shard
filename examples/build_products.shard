;; module-owned products live in their entries (the configuration home,
;; docs/BUILD.md §3/§10 D1): the driver loads each path below as its own
;; closure and appends its build_products — composition, not discovery.
(fn build_entries () (List (List Int))
  (list
    "std/mem/mod.build.shard"
    "std/str/mod.build.shard"
    "std/sha256/mod.build.shard"))
