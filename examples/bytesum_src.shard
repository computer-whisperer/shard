;;; examples/bytesum_src.shard — the A1 BIN-RUNG PILOT (docs/X86.md §22/
;;; §24): the entry READS the payload. `./bytesum hello` exits with the
;;; byte sum of "hello" masked to an exit code (532 & 255 = 20); the
;;; empty payload (no argument) exits 0. The program is the proven cert;
;;; the process boundary is the signed glue contract (clauses 2-4 supply
;;; the entry's premise surface: rdi = BUF with [BUF, BUF+4096) mapped,
;;; rsi = len <= 255).
;;;
;;; Shape (probe examples/xbinsum_probe.shard): bs_go = the §24
;;; Int-return sum loop (fn 0 of the image); bs_main = the entry
;;; wrapper — seeds the accumulator (program logic), calls the loop,
;;; masks the sum to [0, 256). The Nat-typed len param is the loop-cert
;;; convention: the register carries (int_of_nat k).

(import "../kernel/stdlib.shard")
(import "../std/mem")

(use (:: std mem *))

;; the sum loop: k payload bytes starting at p, accumulated onto a
(fn bs_go ((m Mem) (p Int) (a Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z a)
    ((S k2) (bs_go m (+ p 1) (+ a (mem_get m p)) k2))))

;; the entry: exit code = the payload's byte sum, masked
(fn bs_main ((m Mem) (p Int) (k Nat)) Int (band (bs_go m p 0 k) 255))

(bin bytesum (entry bs_main))
