;;; Refinement-type slice 2, the ENFORCEMENT side — both cases must FAIL.
;;; The refined-return obligation is a HARD gate: the body-↔-return relaxation
;;; (tc_fn_body_ret) is only sound because every refined-return fn must DISCHARGE
;;; its predicate. See docs/REFINEMENT.md and refine_return.shard.

(import "../kernel/stdlib.shard")

(fn is_small ((n Int)) Bool (lt n 5))

(type Small (refine Int is_small))

;; (1) FAILING PROOF: 99 is not small, so (is_small (refine_val (big))) computes
;; to False — the supplied proof cannot close (= False True). REJECTED.
(fn big () Small 99)

(returns big (steps ((compute lhs)) refl))

;; (2) MISSING PROOF: nope's body (1) happens to be small, but with no
;; (returns nope …) the invariant is unproven — the gate refuses it anyway.
;; A refined return you don't prove is not admitted. REJECTED.
(fn nope () Small 1)
