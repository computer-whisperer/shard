;;; examples/bin_entry_rejects.shard — the (bin …) entry contract,
;;; NEGATIVE fixture (corpus expects a FAIL line): an entry whose
;;; signature mentions World WITHOUT being exactly (World) -> World is a
;;; HYBRID — neither the I/O contract nor the pure native-bin bridge
;;; form (docs/X86.md §22) — and the check FAILS. The two admitted
;;; shapes are pinned green elsewhere: (World) -> World by
;;; examples/io/cat_loop.shard, the pure value fn by
;;; examples/arglen_src.shard.

(import "../kernel/stdlib.shard")

(type World (World Int))

;; hybrid: takes a World beside a value param, returns a value — the
;; glue contract cannot marshal this and the I/O contract does not fit
(fn be_hybrid ((w World) (n Int)) Int n)

(bin badbin (entry be_hybrid))
