;;; runhom_a — run-mode homonym fixture, module A. rh_helper's NAME is also
;;; defined by runhom_b; rh_pick_a's module-INTERNAL bare call must bind to
;;; THIS file's helper when both modules ride one run closure (the
;;; enc_instr bug shape — see examples/runhom_run.shard).

(fn rh_helper () Int 1)

(fn rh_pick_a () Int (rh_helper))
