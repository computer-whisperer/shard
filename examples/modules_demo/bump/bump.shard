;;; bump — the module IMPL (private). Provides the real body and DISCHARGES the
;;; interface's requirement. When checking the module itself, interface + impl
;;; load together (module-as-a-unit); the impl never restates the goal.
(import "../../../kernel/stdlib.shard")

(fn bump ((x Int)) Int (+ x 3))

(fulfills bump_grows (steps ((unfold bump lhs) (reduce lhs)) (by ord (list))))
