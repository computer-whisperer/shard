;;; bump — the module IMPL (private). Provides the real body and DISCHARGES the
;;; interface's requirement. It imports its own interface (an ordinary `.shard`
;;; FILE import → ungranted), so the requirement loads FIRST as an obligation
;;; and this file's `fulfills` discharges it. The impl never restates the goal.
(import "../../../kernel/stdlib.shard")
(import "mod.req.shard")

(fn bump ((x Int)) Int (+ x 3))

(fulfills bump_grows (steps ((unfold bump lhs) (reduce lhs)) (by ord (list))))
