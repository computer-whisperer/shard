;;; NEGATIVE view: drop the granted lemma. With bump opaque and no lemma, the
;;; goal is UNPROVABLE — `ord` can't see the body. Demonstrates the lemma is
;;; load-bearing: a consumer genuinely cannot reach past the interface. (Expect
;;; this file to FAIL — it is the demo's lia_rejects analogue.)
(import "../../../kernel/stdlib.shard")
(sig fn bump ((x Int)) Int)
(claim grows_without_lemma
  (goal ((a Int)) () (= (lt a (bump a)) True))
  (by ord (list)))
