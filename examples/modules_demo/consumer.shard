;;; consumer — imports the bump MODULE and reasons about `bump` OPAQUELY: it has
;;; the signature + the promised lemma, NOT the body.
;;;
;;; WORKS via the self-hosted selective loader:
;;;   check run kernel/check.shard -- examples/modules_demo/consumer.shard
;;; `(import "bump")` (a bare module name) resolves to bump/mod.req.shard ONLY —
;;; the impl bodies are never loaded — and grants bump_grows as an axiom. So the
;;; proof below goes through the lemma; `bump` is opaque (no body to unfold).
;;;
;;; (The native `check` path still loads the whole module — it does not yet do
;;; selective loading — so it also passes, but without enforcing opacity.)
(import "../../kernel/stdlib.shard")
(import "bump")
(use (:: examples modules_demo bump bump))  ; the opaque `bump` fn into scope
(use (:: examples modules_demo bump *))  ; interface lemmas for citations (Stage 4)

(claim consumer_grows
  (goal ((a Int)) () (= (lt a (bump a)) True))
  (steps ((rewrite (lemma bump_grows) lr lhs true ((inst x a)))) refl))
