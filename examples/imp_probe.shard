;;; examples/imp_probe.shard — the ONE-TIME machine-validation probe for
;;; models/imp (docs/IMP.md §3, rung I0): ground differential claims
;;; checking that the machine means what we intended, before proofs
;;; rest on it (the facts_probe / FLOATS toy-format idiom). This is a
;;; DEVELOPMENT INSTRUMENT, corpus-pinned so the machine's meaning
;;; cannot drift silently — it is NOT a build gate (the DI2 resolution:
;;; imp has no engine leg; the kernel gate is the gate).
;;;
;;; Claims observe scalars only: memory effects are read back through
;;; ILoad inside the probed programs, so every expected value is a
;;; ground Int and (compute both) closes every goal.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(use (:: std mem *))
(import "../models/imp/imp.shard")
(use (:: models imp imp *))

;; --- probe programs ------------------------------------------------------------

;; fn 0: (x y) -> x*2 + (y - x)   [locals, ISet, IBin, result exp]
(fn ip_arith_fn () IFn
  (MkIFn
    2
    1
    (list
      (ISet
        2
        (IBin
          IAdd
          (IBin IMul (ILoc 0) (IConst 2))
          (IBin ISub (ILoc 1) (ILoc 0)))))
    (ILoc 2)))

;; fn 0: (x) -> if x < 10 then 1 else 0   [IIf, comparison]
(fn ip_gate_fn () IFn
  (MkIFn
    1
    1
    (list
      (IIf
        (IBin ILt (ILoc 0) (IConst 10))
        (list (ISet 1 (IConst 1)))
        (list (ISet 1 (IConst 0)))))
    (ILoc 1)))

;; fn 0: (n) -> sum 1..n by countdown   [IWhile, accumulator]
(fn ip_sum_fn () IFn
  (MkIFn
    1
    1
    (list
      (IWhile
        (IBin ILt (IConst 0) (ILoc 0))
        (list
          (ISet 1 (IBin IAdd (ILoc 1) (ILoc 0)))
          (ISet 0 (IBin ISub (ILoc 0) (IConst 1))))))
    (ILoc 1)))

;; fn 0: () -> store 7 at 5, load 5   [IStore + ILoad, same address]
(fn ip_memrw_fn () IFn
  (MkIFn 0 0 (list (IStore (IConst 5) (IConst 7))) (ILoad (IConst 5))))

;; fn 0: () -> store 7 at 5, load 6   [the framing direction]
(fn ip_memfr_fn () IFn
  (MkIFn 0 0 (list (IStore (IConst 5) (IConst 7))) (ILoad (IConst 6))))

;; fn 0: (x) -> wrap8 x   [IWrap]
(fn ip_wrap_fn () IFn (MkIFn 1 0 Nil (IWrap 8 (ILoc 0))))

;; fn 0: (a b) -> a / b   [IDiv; zero divisor traps]
(fn ip_div_fn () IFn (MkIFn 2 0 Nil (IBin IDiv (ILoc 0) (ILoc 1))))

;; fn 0: () -> load at 64 with memsize 64   [OOB traps]
(fn ip_oob_fn () IFn (MkIFn 0 0 Nil (ILoad (IConst 64))))

(fn ip1 ((f IFn)) IProg (MkIProg (list f) 64))

;; --- the probes ----------------------------------------------------------------

(claim ipb_arith
  (goal () ()
    (= (icall (ifnat 10) (ip1 (ip_arith_fn)) 0 (list 3 11)) (Some 14)))
  (steps ((compute both)) refl))

(claim ipb_gate_true
  (goal () () (= (icall (ifnat 10) (ip1 (ip_gate_fn)) 0 (list 5)) (Some 1)))
  (steps ((compute both)) refl))

(claim ipb_gate_false
  (goal () () (= (icall (ifnat 10) (ip1 (ip_gate_fn)) 0 (list 10)) (Some 0)))
  (steps ((compute both)) refl))

(claim ipb_sum
  (goal () () (= (icall (ifnat 40) (ip1 (ip_sum_fn)) 0 (list 5)) (Some 15)))
  (steps ((compute both)) refl))

(claim ipb_sum_zero
  (goal () () (= (icall (ifnat 10) (ip1 (ip_sum_fn)) 0 (list 0)) (Some 0)))
  (steps ((compute both)) refl))

;; the memory probes stop compute at the opaque std/mem surface and
;; close with the surface laws (get_set_byte / get_set_other /
;; get_empty) — the machine's IStore/ILoad wiring is what is probed;
;; the byte algebra is std/mem's own, already gated there
(claim ipb_memrw
  (goal () () (= (icall (ifnat 20) (ip1 (ip_memrw_fn)) 0 Nil) (Some 7)))
  (chain
    (steps ((compute lhs)))
    (rewrite-with
      (lemma get_set_byte)
      lr
      lhs
      ()
      ((steps ((compute both)) refl) (steps ((compute both)) refl)))
    refl))

(claim ipb_memfr
  (goal () () (= (icall (ifnat 20) (ip1 (ip_memfr_fn)) 0 Nil) (Some 0)))
  (chain
    (steps ((compute lhs)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((steps ((compute both)) refl)))
    (rewrite-with (lemma get_empty) lr lhs () ())
    refl))

(claim ipb_wrap
  (goal () () (= (icall (ifnat 10) (ip1 (ip_wrap_fn)) 0 (list 300)) (Some 44)))
  (steps ((compute both)) refl))

(claim ipb_div
  (goal () () (= (icall (ifnat 10) (ip1 (ip_div_fn)) 0 (list 100 7)) (Some 14)))
  (steps ((compute both)) refl))

;; honesty probes: every failure mode is None, loudly
(claim ipb_div0
  (goal () () (= (icall (ifnat 10) (ip1 (ip_div_fn)) 0 (list 100 0)) None))
  (steps ((compute both)) refl))

(claim ipb_oob
  (goal () () (= (icall (ifnat 10) (ip1 (ip_oob_fn)) 0 Nil) None))
  (steps ((compute both)) refl))

(claim ipb_fuel
  (goal () () (= (icall Z (ip1 (ip_sum_fn)) 0 (list 5)) None))
  (steps ((compute both)) refl))

(claim ipb_arity
  (goal () () (= (icall (ifnat 10) (ip1 (ip_arith_fn)) 0 (list 3)) None))
  (steps ((compute both)) refl))

;; ---- rung I2a: the shift/rotate vocabulary -------------------------------------

;; (a k) -> a << k / a >> k  [exact; negative count traps]
(fn ip_shl_fn () IFn (MkIFn 2 0 Nil (IBin IShl (ILoc 0) (ILoc 1))))

(fn ip_shr_fn () IFn (MkIFn 2 0 Nil (IBin IShr (ILoc 0) (ILoc 1))))

;; (a k) -> rotr32(a, k)  [band-spelled containment]
(fn ip_rotr_fn () IFn (MkIFn 2 0 Nil (IRotr 32 (ILoc 0) (ILoc 1))))

(claim ipb_shl
  (goal () () (= (icall (ifnat 10) (ip1 (ip_shl_fn)) 0 (list 5 3)) (Some 40)))
  (steps ((compute both)) refl))

(claim ipb_shr
  (goal () () (= (icall (ifnat 10) (ip1 (ip_shr_fn)) 0 (list 100 3)) (Some 12)))
  (steps ((compute both)) refl))

;; rotr32(0x80000001, 1) = 0xC0000000 — the wrapped-around high bit
(claim ipb_rotr
  (goal () ()
    (=
      (icall (ifnat 10) (ip1 (ip_rotr_fn)) 0 (list 2147483649 1))
      (Some 3221225472)))
  (steps ((compute both)) refl))

;; honesty: a negative shift count traps
(claim ipb_shl_neg
  (goal () () (= (icall (ifnat 10) (ip1 (ip_shl_fn)) 0 (list 5 -1)) None))
  (steps ((compute both)) refl))
