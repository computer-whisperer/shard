;;; examples/parse_src.shard — the B1 RUNG'S DELIVERABLE (docs/X86.md
;;; rung B, slice 1): proven atoi on the EXISTING contract. `./parse 42`
;;; exits 42 — the entry decimal-folds the payload bytes and the 5a glue
;;; exits rax & 255. No div, no OUT page, no contract growth: the fold
;;; only reads, so the cert premise surface is the window pair the glue
;;; already signs (clauses 2-4).
;;;
;;; Shape (probe examples/xfoldloop_probe.shard): ps_go = the decimal
;;; fold — acc' = w64(w64(w64(acc*10) + byte) - 48), THE SPEC SPELLING
;;; THE MACHINE'S WRAPS (§11's law; the accumulator has no usable bound
;;; and a payload byte need not be a digit — the entry is total over raw
;;; bytes, validation is program logic). ps_main = the entry wrapper:
;;; seeds the accumulator, calls the loop, masks to [0, 256) exactly as
;;; bytesum does. The exit code is the parsed value mod 256; the full
;;; value leaves the process at rung B3 when the OUT page lands.

(import "../kernel/stdlib.shard")
(import "../std/mem")

(use (:: std mem *))

;; the decimal fold: k payload bytes starting at p, onto acc a
(fn ps_go ((m Mem) (p Int) (a Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z a)
    ((S k2)
     (ps_go
       m
       (+ p 1)
       (mod
         (-
           (mod
             (+ (mod (* a 10) 18446744073709551616) (mem_get m p))
             18446744073709551616)
           48)
         18446744073709551616)
       k2))))

;; the entry: exit code = the parsed decimal, masked
(fn ps_main ((m Mem) (p Int) (k Nat)) Int (band (ps_go m p 0 k) 255))

(bin parse (entry ps_main))
