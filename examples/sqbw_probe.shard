;;; DEV PROBE (the branch tier, wasm leg): the compositional blueprint
;;; for a mixed body containing a top-level IIf with straight-line
;;; arms -- the claim forms and proof shapes the impgen branch tier
;;; will emit, hand-validated end to end.
;;;
;;; The body: [seg] [branch (store in the then arm)] [counting loop].
;;; Pieces and the chain mirror the V2-5e-4 wasm composition exactly;
;;; the branch piece is the new element:
;;;
;;; 1. THE BRANCH SUB-LEMMA (sqbw_br): open-tail, the segment-lemma
;;;    form verbatim -- the branch chunk's machine code over ANY tail
;;;    rw = es_scont of the standalone imp run. The proof case-ons the
;;;    SHARED comparison scrutinee (both machines stick on it), then
;;;    each arm walks concretely: the encoding's branches target its
;;;    own blocks, so the chunk completes ONorm at the entry stack
;;;    like inline code (stack-neutral from outside). Mem guards
;;;    inside an arm split at the statement-tier polarity dance.
;;; 2. THE SEAM (models/imp ist_seam1): the chain splits the imp walk
;;;    at a branch boundary through the SINGLETON seam -- ist_seam's
;;;    flat premise excludes IIf, but one statement splits off at the
;;;    shared reservoir unconditionally.
;;; 3. THE CHAIN (cmp_sqb_b*): boundary lemmas in the statement-tier
;;;    public form; the branch boundary = ist_seam1 + sub-lemma cite +
;;;    ONE case-on of the shared standalone run + il_slen arity
;;;    exposure (branch exits are SEGMENT-flavored: il_slen, not
;;;    il_wlen) + the next boundary cited at the exit leaf.
;;;
;;; Fuel: continuation after a branch chunk = claim-minus-one
;;; regardless of which arm ran (the machine hands the same reservoir
;;; to head and tail); the else path is the DEEP path through the
;;; inner block (all seven elements including Br 1); the sub-lemma's
;;; own tower covers the deeper arm and chain cites align by pure
;;; S-tower matching.

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")
(import "../models/wasm/wasm.shard")
(import "../models/imp/to_wasm.shard")
(import "../models/wasm/loopkit.shard")
(import "../std/nat.shard")
(import "../std/mem")
(import "imp_scalar.shard")

(use (:: models imp imp *))
(use (:: models wasm wasm *))
(use (:: models imp to_wasm *))
(use (:: models wasm loopkit *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: examples imp_scalar *))

;; --- the body: seg / branch / counting loop -------------------------------------

(fn gb_sqb_s0_i () (List IStmt)
  (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))))

(fn gb_sqb_br_i () (List IStmt)
  (list
    (IIf
      (IBin U32 ILt (ILoc 0) (IConst 3))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 7))))))

(fn gb_sqb_l1_i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))

(fn gb_sqb_l1_w () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (I32Const 2)
    (I32Bin BAdd)
    (LocalSet 1)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn gb_sqb_i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
    (IIf
      (IBin U32 ILt (ILoc 0) (IConst 3))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 7))))
    (ISet 2 (IConst 2))
    (IWhile
      (ILoc 2)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))))

(fn gb_sqb_w () (List Instr)
  (list
    (LocalGet 1)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 1)
    (Block
      (list
        (Block
          (list
            (LocalGet 0)
            (I32Const 3)
            (I32Bin BLtU)
            (BrIf 0)
            (I32Const 7)
            (LocalSet 1)
            (Br 1)))
        (LocalGet 1)
        (I32Const 5)
        (I32Bin BAdd)
        (LocalSet 1)
        (LocalGet 0)
        (LocalGet 1)
        (I32Const 255)
        (I32Bin BAnd)
        (I32Store8)))
    (I32Const 2)
    (LocalSet 2)
    (Block
      (list
        (Loop
          (list
            (LocalGet 2)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (I32Const 2)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 2)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 2)
            (Br 0)))))))

(fn gb_sqb_r1_i () (List IStmt)
  (list
    (IIf
      (IBin U32 ILt (ILoc 0) (IConst 3))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 7))))
    (ISet 2 (IConst 2))
    (IWhile
      (ILoc 2)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))))

(fn gb_sqb_r1_w () (List Instr)
  (list
    (Block
      (list
        (Block
          (list
            (LocalGet 0)
            (I32Const 3)
            (I32Bin BLtU)
            (BrIf 0)
            (I32Const 7)
            (LocalSet 1)
            (Br 1)))
        (LocalGet 1)
        (I32Const 5)
        (I32Bin BAdd)
        (LocalSet 1)
        (LocalGet 0)
        (LocalGet 1)
        (I32Const 255)
        (I32Bin BAnd)
        (I32Store8)))
    (I32Const 2)
    (LocalSet 2)
    (Block
      (list
        (Loop
          (list
            (LocalGet 2)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (I32Const 2)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 2)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 2)
            (Br 0)))))))

(fn gb_sqb_r2_i () (List IStmt)
  (list
    (ISet 2 (IConst 2))
    (IWhile
      (ILoc 2)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))))

(fn gb_sqb_r2_w () (List Instr)
  (list
    (I32Const 2)
    (LocalSet 2)
    (Block
      (list
        (Loop
          (list
            (LocalGet 2)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (I32Const 2)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 2)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 2)
            (Br 0)))))))

;; --- the translation tie ---------------------------------------------------------

(claim tie_sqb
  (goal () () (= (iw_stmts (list U32 U32 U32) (gb_sqb_i)) (Some (gb_sqb_w))))
  (steps ((compute both)) refl))

;; --- the segment lemma (piece 0) --------------------------------------------------

(claim sqs_sqb_s0
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (rw (List Instr))
     (st (List Int))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 4 (S f))
        (MkWModule restfs 65536)
        (Cons
          (LocalGet 1)
          (Cons (I32Const 1) (Cons (I32Bin BAdd) (Cons (LocalSet 1) rw))))
        (Cons x0 (Cons x1 (Cons x2 Nil)))
        st
        m)
      (es_scont
        (S f)
        (MkWModule restfs 65536)
        rw
        st
        (istmts
          (S^ 1 (S g))
          65536
          (inline gb_sqb_s0_i)
          (Cons x0 (Cons x1 (Cons x2 Nil)))
          m))))
  (steps ((compute both)) refl))

;; --- the branch sub-lemma (piece 1) -----------------------------------------------
;; Open-tail over ANY rw; the standalone imp run is the branch
;; SINGLETON (ist_seam1's spelling). One case-on of the shared
;; comparison scrutinee; the then arm carries the store guards.

(claim sqbw_br
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (rw (List Instr))
     (st (List Int))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 13 (S f))
        (MkWModule restfs 65536)
        (Cons
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 3)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (I32Const 7)
                  (LocalSet 1)
                  (Br 1)))
              (LocalGet 1)
              (I32Const 5)
              (I32Bin BAdd)
              (LocalSet 1)
              (LocalGet 0)
              (LocalGet 1)
              (I32Const 255)
              (I32Bin BAnd)
              (I32Store8)))
          rw)
        (Cons x0 (Cons x1 (Cons x2 Nil)))
        st
        m)
      (es_scont
        (S^ 12 (S f))
        (MkWModule restfs 65536)
        rw
        st
        (istmts
          (S^ 5 (S g))
          65536
          (inline gb_sqb_br_i)
          (Cons x0 (Cons x1 (Cons x2 Nil)))
          m))))
  (chain
    (steps ((compute both (stop es_scont))))
    (case-on (lt x0 3) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ()) (compute both (stop es_scont))))
           (case-on (le 0 x0) Bool
             ((case True
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute both (stop es_scont))))
                  (case-on (lt x0 65536) Bool
                    ((case True
                       (chain
                         (have hlt1 (= (lt x0 65536) True)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle1 (= (le (+ x0 1) 65536) True)
                           (steps () (by arith (rows (goal 1) (hlt1 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle1) lr lhs true ())
                            (compute both)))
                         refl))
                     (case False
                       (chain
                         (have hlt1 (= (lt x0 65536) False)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle1 (= (le (+ x0 1) 65536) False)
                           (steps () (by arith (rows (goal 1) (hlt1 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle1) lr lhs true ())
                            (compute both)))
                         refl))))))
              (case False
                (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))))))
       (case False
         (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))))))

;; --- the counter-tied loop worker (piece 2's loop) ---------------------------------

(claim sqmw_sqb_l1
  (goal
    ((x0 Int)
     (x1 Int)
     (rr (List Int))
     (k Nat)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (eval_loop
        (S^ 16 (lg_fuel k c))
        (MkWModule restfs 65536)
        (inline gb_sqb_l1_w)
        (Cons x0 (Cons x1 (Cons (int_of_nat k) rr)))
        st
        m)
      (iw_out
        st
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 2)
          (inline gb_sqb_l1_i)
          (Cons x0 (Cons x1 (Cons (int_of_nat k) rr)))
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold eval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr both true ())))
         (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
           (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
         (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
           (steps
             ((rewrite (premise hs1) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (have hcap (= (lt (int_of_nat k2) 4294967296) True)
           (steps () (by arith (rows (goal 1) (hks 1)))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma iwrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (steps ((rewrite (premise hcap) lr lhs true ())) refl))
             refl))
         (steps ((rewrite (premise hwk) lr both true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst c2 c2))
           ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
         refl)))))

;; --- the chain: boundary 2 (the loop piece, terminal) ------------------------------

(claim cmp_sqb_b2
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 39 c)
        (MkWModule restfs 65536)
        (inline gb_sqb_r2_w)
        (list x0 x1 x2)
        st
        m)
      (iw_sout
        st
        (istmts (S^ 21 c2) 65536 (inline gb_sqb_r2_i) (list x0 x1 x2) m))))
  (chain
    (steps ((compute both (stop iwhile eval_loop lg_fuel int_of_nat))))
    (have hi2 (= (int_of_nat 2) 2)
      (chain
        (have ha2 (= (int_of_nat 2) (int_of_nat (S (S Z))))
          (steps ((compute both)) refl))
        (steps
          ((rewrite (premise ha2) lr lhs true ())
           (rewrite (lemma int_of_nat_succ) lr lhs true ())
           (rewrite (lemma int_of_nat_succ) lr lhs true ())
           (rewrite (lemma int_of_nat_zero) lr lhs true ())
           (compute lhs)))
        refl))
    (have hlc2
      (=
        (Cons x0 (Cons x1 (Cons (int_of_nat 2) Nil)))
        (Cons x0 (Cons x1 (Cons 2 Nil))))
      (steps ((rewrite (premise hi2) lr lhs true ())) refl))
    (steps ((rewrite (premise hlc2) rl both true ())))
    (have hf2i (= (S^ 18 c2) (S^ 9 (lg_fuel 2 (S^ 7 c2))))
      (steps ((compute both)) refl))
    (have hf2m (= (S^ 33 c) (S^ 16 (lg_fuel 2 (S^ 15 c))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hf2i) lr rhs true ())
       (rewrite (premise hf2m) lr lhs true ())))
    (rewrite-with
      (lemma sqmw_sqb_l1)
      lr
      lhs
      ((inst c2 (S^ 7 c2)))
      ((steps ((rewrite (premise hi2) lr lhs true ()) (compute lhs)) refl)))
    (case-on
      (iwhile
        (S^ 9 (lg_fuel 2 (S^ 7 c2)))
        65536
        (ILoc 2)
        (inline gb_sqb_l1_i)
        (Cons x0 (Cons x1 (Cons (int_of_nat 2) Nil)))
        m)
      Option
      ((case None
         (steps
           ((rewrite (hyp 0) lr both true ())
            (compute both (stop lg_fuel int_of_nat)))
           refl))
       (case Some
         (ol)
         (chain
           (steps ((rewrite (hyp 0) lr both true ())))
           (case-on ol IOut
             ((case INorm
                (el mml)
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop lg_fuel int_of_nat)))
                  refl))
              (case ITrap
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop lg_fuel int_of_nat)))
                  refl))))))))))

;; --- the chain: boundary 1 (THE BRANCH PIECE) ---------------------------------------

(claim cmp_sqb_b1
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 40 c)
        (MkWModule restfs 65536)
        (inline gb_sqb_r1_w)
        (list x0 x1 x2)
        st
        m)
      (iw_sout
        st
        (istmts (S^ 22 c2) 65536 (inline gb_sqb_r1_i) (list x0 x1 x2) m))))
  (chain
    (rewrite-with (lemma ist_seam1) lr rhs () ())
    (rewrite-with (lemma sqbw_br) lr lhs ((inst g (S^ 16 c2))) ())
    (case-on
      (istmts
        (S^ 22 c2)
        65536
        (inline gb_sqb_br_i)
        (Cons x0 (Cons x1 (Cons x2 Nil)))
        m)
      Option
      ((case None
         (steps
           ((rewrite (hyp 0) lr both true ())
            (compute both (stop lg_fuel int_of_nat)))
           refl))
       (case Some
         (ob)
         (chain
           (steps ((rewrite (hyp 0) lr both true ())))
           (case-on ob IOut
             ((case INorm
                (eb mmb)
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute
                       both
                       (stop iwhile eval_loop lg_fuel int_of_nat istmts eval_seq))))
                  (case-on eb List
                    ((case Nil
                       (chain
                         (have hbad
                           (=
                             (iolen
                               (ilen (Cons x0 (Cons x1 (Cons x2 Nil))))
                               (Some (INorm eb mmb)))
                             3)
                           (chain
                             (steps
                               ((rewrite (hyp 1) rl lhs true ())
                                (rewrite (hyp 2) rl lhs true ())))
                             (rewrite-with (lemma il_slen) lr lhs () ())
                             (steps ((compute lhs)))
                             refl))
                         (have hlen
                           (=
                             (iolen
                               (ilen (Cons x0 (Cons x1 (Cons x2 Nil))))
                               (Some (INorm eb mmb)))
                             (ilen eb))
                           (steps ((compute both)) refl))
                         (have hg (= (ilen eb) 3)
                           (steps
                             ((rewrite (premise hlen) rl lhs true ())
                              (rewrite (premise hbad) lr lhs true ()))
                             refl))
                         (have hs (= (ilen eb) 0)
                           (steps
                             ((rewrite (hyp 0) lr lhs true ()) (compute lhs))
                             refl))
                         (have hff (= (le 0 0) False)
                           (steps () (by arith (rows (goal 1) (hg 1) (hs -1)))))
                         (absurd (premise hff))))
                     (case Cons
                       (e0 r0)
                       (chain
                         (steps ((rewrite (hyp 0) lr both true ())))
                         (case-on r0 List
                           ((case Nil
                              (chain
                                (have hbad
                                  (=
                                    (iolen
                                      (ilen (Cons x0 (Cons x1 (Cons x2 Nil))))
                                      (Some (INorm eb mmb)))
                                    3)
                                  (chain
                                    (steps
                                      ((rewrite (hyp 2) rl lhs true ())
                                       (rewrite (hyp 3) rl lhs true ())))
                                    (rewrite-with (lemma il_slen) lr lhs () ())
                                    (steps ((compute lhs)))
                                    refl))
                                (have hlen
                                  (=
                                    (iolen
                                      (ilen (Cons x0 (Cons x1 (Cons x2 Nil))))
                                      (Some (INorm eb mmb)))
                                    (ilen eb))
                                  (steps ((compute both)) refl))
                                (have hg (= (ilen eb) 3)
                                  (steps
                                    ((rewrite (premise hlen) rl lhs true ())
                                     (rewrite (premise hbad) lr lhs true ()))
                                    refl))
                                (have hs (= (ilen eb) 1)
                                  (steps
                                    ((rewrite (hyp 1) lr lhs true ())
                                     (rewrite (hyp 0) lr lhs true ())
                                     (compute lhs))
                                    refl))
                                (have hff (= (le 0 0) False)
                                  (steps
                                    ()
                                    (by arith (rows (goal 1) (hg 1) (hs -1)))))
                                (absurd (premise hff))))
                            (case Cons
                              (e1 r1)
                              (chain
                                (steps ((rewrite (hyp 0) lr both true ())))
                                (case-on r1 List
                                  ((case Nil
                                     (chain
                                       (have hbad
                                         (=
                                           (iolen
                                             (ilen
                                               (Cons x0 (Cons x1 (Cons x2 Nil))))
                                             (Some (INorm eb mmb)))
                                           3)
                                         (chain
                                           (steps
                                             ((rewrite (hyp 3) rl lhs true ())
                                              (rewrite (hyp 4) rl lhs true ())))
                                           (rewrite-with
                                             (lemma il_slen)
                                             lr
                                             lhs
                                             ()
                                             ())
                                           (steps ((compute lhs)))
                                           refl))
                                       (have hlen
                                         (=
                                           (iolen
                                             (ilen
                                               (Cons x0 (Cons x1 (Cons x2 Nil))))
                                             (Some (INorm eb mmb)))
                                           (ilen eb))
                                         (steps ((compute both)) refl))
                                       (have hg (= (ilen eb) 3)
                                         (steps
                                           ((rewrite
                                              (premise hlen)
                                              rl
                                              lhs
                                              true
                                              ())
                                            (rewrite
                                              (premise hbad)
                                              lr
                                              lhs
                                              true
                                              ()))
                                           refl))
                                       (have hs (= (ilen eb) 2)
                                         (steps
                                           ((rewrite (hyp 2) lr lhs true ())
                                            (rewrite (hyp 1) lr lhs true ())
                                            (rewrite (hyp 0) lr lhs true ())
                                            (compute lhs))
                                           refl))
                                       (have hff (= (le 0 0) False)
                                         (steps
                                           ()
                                           (by
                                             arith
                                             (rows (goal 1) (hg 1) (hs -1)))))
                                       (absurd (premise hff))))
                                   (case Cons
                                     (e2 r2)
                                     (chain
                                       (steps
                                         ((rewrite (hyp 0) lr both true ())))
                                       (case-on r2 List
                                         ((case Nil
                                            (chain
                                              (steps
                                                ((rewrite
                                                   (hyp 0)
