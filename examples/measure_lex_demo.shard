;; lex-measure fixture (issue #1): a mutual SCC f <-> g over a tree where the
;; f -> g edge is a PASS-THROUGH (same arg t), so a bare (tsz t) measure is not
;; strictly decreasing on it. It needs a LEX measure  M*tsz(t) + offset  — the
;; exact shape check_sequent's SCC requires (M dominates a real size drop; the
;; offset orders the pass-through edges). This exercises prove's lex recognizer
;; (ms_base_sizefn): prove should emit examples/measure_lex_demo.auto.shard with
;; the same recipe it uses for bare measures. Tiny closure ⇒ fast.

(import "../kernel/stdlib.shard")  ; Bool / True / le / Int ops

(type Tr (Lf Int) (Nd Tr Tr))

(fn tsz ((t Tr)) Int
  (measure (struct t))
  (match t
    ((Lf _) 1)
    ((Nd l r) (+ 1 (+ (tsz l) (tsz r))))))

(claim tsz_nd
  (goal ((l Tr) (r Tr)) () (= (tsz (Nd l r)) (+ 1 (+ (tsz l) (tsz r)))))
  (steps ((simp lhs)) refl))

(claim tsz_nonneg
  (goal ((t Tr)) () (= (le 0 (tsz t)) True))
  (subterm-induct
    t
    (case-on t Tr
      ((case Lf
         (n)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case Nd
         (l r)
         (have (= (le 0 (tsz l)) True)
           (rewrite-with (hyp ih) lr lhs () ((below)) refl)
           (have (= (le 0 (tsz r)) True)
             (rewrite-with (hyp ih) lr lhs () ((below)) refl)
             (steps
               ((rewrite (hyp 0) lr lhs true ())
                (rewrite (lemma tsz_nd) lr lhs true ()))
               (by farkas (list 1 1 1))))))))))

;; The mutual SCC. f -> g is a pass-through (same t); g -> f l / f r are drops.
;; Lex measures: f = 2*tsz+2, g = 2*tsz+1.
;;   f->g(t):  2*tsz(t)+1 < 2*tsz(t)+2            (offset, constant gap)
;;   g->f(l):  2*tsz(l)+2 < 2*tsz(Nd l r)+1       (drop: M dominates)
(fn f ((t Tr)) Int
  (measure (+ (* 2 (tsz t)) 2))
  (g t))

(fn g ((t Tr)) Int
  (measure (+ (* 2 (tsz t)) 1))
  (match t
    ((Lf _) 0)
    ((Nd l r) (+ (f l) (f r)))))
