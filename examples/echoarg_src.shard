;;; examples/echoarg_src.shard — the A2 CONTRACT PILOT (docs/X86.md §27):
;;; the glue's WRITE variant, isolated. `./echoarg hello` writes exactly
;;; "hello" to stdout and exits 0; no argument writes nothing. The entry
;;; is the IDENTITY on the payload Mem (probe examples/xid_probe.shard) —
;;; the binary's whole observable behavior is the contract's new clause
;;; (5b: a Mem-returning entry selects sys_write(1, BUF, len) then
;;; sys_exit(0)), with zero loop machinery in the way. The proven part is
;;; deliberately trivial; what this pilot gates is the process boundary.

(import "../kernel/stdlib.shard")
(import "../std/mem")

(use (:: std mem *))

;; the entry: the payload, untouched
(fn ea_main ((m Mem) (p Int) (k Nat)) Mem m)

(bin echoarg (entry ea_main))
