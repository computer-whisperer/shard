;;; rewrite-with demo, on the proof-DSL surface. First prove a conditional
;;; lemma, then cite it via rewrite-with to close a follow-up goal.
;;;
;;; Lemma:  ∀ a : Nat. (a = Z) ⇒ ((add_nat a Z) = Z)
;;; Trivial as math (the premise pins a to Z, then add_nat unfolds to Z by the
;;; Z arm) but exercises the non-empty-premises path.
;;;
;;; Then:  (add_nat Z Z) = Z, closed by citing trivial_lemma — the rewriter
;;; matches (add_nat a Z) against (add_nat Z Z) yielding a→Z, instantiates the
;;; premise to (Z = Z), discharges it with refl, applies the rewrite (lhs
;;; becomes Z), and continues with refl on Z = Z.

(import "../std/nat.shard")

;; ∀ a : Nat. (a = Z) ⇒ (add_nat a Z) = Z
(claim trivial_lemma
  (goal ((a Nat)) ((= a Z))
    (= (add_nat a Z) Z))
  ;; rewrite (premise 0) lr lhs all=true replaces a → Z on lhs; then unfold
  ;; add_nat + reduce collapse to Z. refl.
  (steps
    ((rewrite (premise 0) lr lhs true ())
     (unfold add_nat lhs)
     (reduce lhs))
    refl))

;; (add_nat Z Z) = Z, by citing the conditional lemma.
(claim use_trivial_lemma
  (goal () ()
    (= (add_nat Z Z) Z))
  ;; The rewriter matches the conclusion lhs (add_nat a Z) against the goal lhs
  ;; (add_nat Z Z), captures a→Z; the premise (a = Z) becomes (Z = Z),
  ;; discharged by the one sub-proof (refl). After the rewrite, goal is Z = Z;
  ;; the continuation refl closes.
  (rewrite-with (lemma trivial_lemma) lr lhs
    ()                   ; insts (empty — match-determined)
    (refl)               ; one sub-proof per cited premise
    refl))               ; continuation after the rewrite
