;;; lowergen_loop_src.shard — source articles for lowergen's LOOP fragment
;;; (docs/LOWERING.md §6h): Nat-counted tail recursions in the §6f
;;; template shape. Each lowers to a counter-as-local wasm loop with a
;;; machine-written induction worker + lowered_* theorem.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(use (:: std mem *))

;; fill: constant value across a range (1 advancing accum + a value accum)
(fn lp_fill ((m Mem) (d Int) (v Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (lp_fill (mem_set m d v) (+ d 1) v k2))))

;; copy: forward byte copy (2 advancing accums, read + write per pass)
(fn lp_copy ((m Mem) (s Int) (d Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (lp_copy (mem_set m d (mem_get m s)) (+ s 1) (+ d 1) k2))))

;; stamp: literal value across a range (the literal-value template path)
(fn lp_stamp ((m Mem) (d Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (lp_stamp (mem_set m d 7) (+ d 1) k2))))

;; sum: byte checksum over a range (the INT-RETURN template path — the Z
;; arm returns the accumulator; read-only, no store)
(fn lp_sum ((m Mem) (p Int) (acc Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z acc)
    ((S k2) (lp_sum m (+ p 1) (+ acc (mem_get m p)) k2))))
