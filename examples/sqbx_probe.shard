;;; DEV PROBE (the x86 branch leg, rung IF-1b): the branch INSIDE the
;;; x86 mixed-tier chain. The wasm branch factors into a standalone
;;; sub-lemma (sqbw_probe); x86 cannot -- a sub-lemma's conclusion
;;; must spell its scratch residues, and a branch has NO seal on
;;; either side (ix_cjoin seals flat-flat neighbors only), so the
;;; then arm's dirt (the store's band tree in RAX) rides out of the
;;; branch unspellable. The branch therefore walks INLINE in its
;;; chain lemma, the loop-leg precedent: ONE case-on of the shared
;;; raw-operand comparison scrutinee (iop_val compares unwrapped,
;;; xcond compares rget -- both sides stick on the SAME inner
;;; (lt va vb) term), and each polarity arm walks its own tail text
;;; to the same cite targets. Joins bind by MATCHING: the two arms
;;; park DIFFERENT RAX trees and different machine towers at the next
;;; boundary; its za binder and its fuel binder c absorb both (imp
;;; towers are arm-independent -- istmts hands its continuation the
;;; same reservoir regardless of what the branch's nested arm walk
;;; consumed, so the imp-side cite stays at one shared inst).
;;;
;;; The program: segment [x1+=4] (walks INTO the branch scrutinee) /
;;; branch on (lt x1 9) with a STORE in the then arm (RAX dirt +
;;; guard splits per arm) and a shorter else arm (machine towers
;;; diverge) / counter loop (worker cite per arm) / tail segment
;;; [x1+=3] (the next boundary, cited per arm).

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")
(import "../models/x86/x86.shard")
(import "../models/imp/to_x86.shard")
(import "../models/wasm/loopkit.shard")
(import "../std/nat.shard")
(import "../std/mem")

(use (:: models imp imp *))
(use (:: models x86 x86 *))
(use (:: models imp to_x86 *))
(use (:: models wasm loopkit *))
(use (:: std nat *))
(use (:: std mem *))

;; --- the program (local copies; (inline F) resolves file-locally) ----

(fn sqbx_bi () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
    (IIf
      (IBin U32 ILt (ILoc 1) (IConst 9))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 11))))
    (ISet 2 (IConst 2))
    (IWhile
      (ILoc 2)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
        (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))))

(fn sqbx_bx () (List XInstr)
  (list
    (XBin32 XAdd RSI (SImm 4))
    (XBlock
      (list
        (XBlock (list (XBrIf (CLtU RSI (SImm 9)) 0) (XMovRI RSI 11) (XBr 1)))
        (XBin32 XAdd RSI (SImm 6))
        (XMovRR RAX RSI)
        (XBin XAnd RAX (SImm 255))
        (XStore8 (AReg RDI) (SReg RAX))))
    (XMovRI RDX 2)
    (XBlock
      (list
        (XLoop
          (list
            (XBrIf (CEqz RDX) 1)
            (XBin32 XAdd RSI (SImm 2))
            (XBin32 XSub RDX (SImm 1))
            (XBr 0)))))
    (XBin32 XAdd RSI (SImm 3))
    (XMovRI RAX 0)))

;; boundary tail (rest fn; the spine brakes at the folded call)
(fn sqbx_r1_i () (List IStmt)
  (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))))

(fn sqbx_r1_x () (List XInstr) (list (XBin32 XAdd RSI (SImm 3)) (XMovRI RAX 0)))

;; the leg-0 spines: everything through the loop, braked at r1
(fn sqbx_g0_i () (List IStmt)
  (Cons
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
    (Cons
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (Cons
        (ISet 2 (IConst 2))
        (Cons
          (IWhile
            (ILoc 2)
            (list
              (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
              (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
          (sqbx_r1_i))))))

(fn sqbx_g0_x () (List XInstr)
  (Cons
    (XBin32 XAdd RSI (SImm 4))
    (Cons
      (XBlock
        (Cons
          (XBlock
            (Cons
              (XBrIf (CLtU RSI (SImm 9)) 0)
              (Cons (XMovRI RSI 11) (Cons (XBr 1) Nil))))
          (Cons
            (XBin32 XAdd RSI (SImm 6))
            (Cons
              (XMovRR RAX RSI)
              (Cons
                (XBin XAnd RAX (SImm 255))
                (Cons (XStore8 (AReg RDI) (SReg RAX)) Nil))))))
      (Cons
        (XMovRI RDX 2)
        (Cons
          (XBlock
            (Cons
              (XLoop
                (Cons
                  (XBrIf (CEqz RDX) 1)
                  (Cons
                    (XBin32 XAdd RSI (SImm 2))
                    (Cons (XBin32 XSub RDX (SImm 1)) (Cons (XBr 0) Nil)))))
              Nil))
          (sqbx_r1_x))))))

;; the worker's loop body copies
(fn sqbx_l1_i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))

(fn sqbx_l1_x () (List XInstr)
  (list
    (XBrIf (CEqz RDX) 1)
    (XBin32 XAdd RSI (SImm 2))
    (XBin32 XSub RDX (SImm 1))
    (XBr 0)))

;; --- ties: the local copies ARE the program and its translation ------

(claim sqbx_tie
  (goal () () (= (ix_sstmts (inline sqbx_bi)) (Some (inline sqbx_bx))))
  (steps ((compute both)) refl))

;; the g0 spines compose to the program through the folded tail
(claim sqbx_gtie_i
  (goal () () (= (sqbx_g0_i) (inline sqbx_bi)))
  (steps ((compute both)) refl))

(claim sqbx_gtie_x
  (goal () () (= (sqbx_g0_x) (inline sqbx_bx)))
  (steps ((compute both)) refl))

;; --- the per-file width twins (the generated-file shape) --------------

(claim sqbx_wid
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 4294967296 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim sqbx_wid64
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 18446744073709551616) True))
    (= (mod x 18446744073709551616) x))
  (div-facts
    x
    18446744073709551616
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 18446744073709551616 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 18446744073709551616 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

;; --- the counter-tied worker (scratch-clean body: all three slots ----
;; --- pass through; counter home RDX, slot 2) --------------------------

(claim sqbxw_l1
  (goal
    ((x0 Int)
     (x1 Int)
     (za Int)
     (zb Int)
     (zc Int)
     (k Nat)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (xeval_loop
        (S^ 8 (lg_fuel k c))
        (MkXModule restfs 0 65536)
        (inline sqbx_l1_x)
        (MkRegs za 0 (int_of_nat k) 0 0 x1 x0 0 0 zb zc 0 0 0 0)
        m)
      (ix_mout
        za
        zb
        zc
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 2)
          (inline sqbx_l1_i)
          (list x0 x1 (int_of_nat k))
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold xeval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr both true ())))
         (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
           (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
         (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
           (steps
             ((rewrite (premise hs1) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (have hcap (= (lt (int_of_nat k2) 4294967296) True)
           (steps () (by arith (rows (goal 1) (hks 1)))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma sqbx_wid)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (steps ((rewrite (premise hcap) lr lhs true ())) refl))
             refl))
         (steps ((rewrite (premise hwk) lr both true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst c2 c2))
           ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
         refl)))))

;; --- boundary 1: the terminal segment (za dies at the terminal seal) --

(claim sqbx_b1
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (za Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 16 c)
        (MkXModule restfs 0 65536)
        (sqbx_r1_x)
        (MkRegs za 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 12 c2) 65536 (sqbx_r1_i) (list x0 x1 x2) m))))
  (chain
    (steps
      ((unfold sqbx_r1_x lhs) (reduce lhs) (unfold sqbx_r1_i rhs) (reduce rhs)))
    (steps
      ((compute
         both
         (stop iwhile xeval_loop lg_fuel int_of_nat sqbx_r1_x sqbx_r1_i))))
    (steps ((compute both (stop lg_fuel int_of_nat))))
    refl))

;; --- the leg (boundary 0): entry segment, THE BRANCH (one case-on of
;; --- the shared comparison, both arms continue), per-arm worker cite,
;; --- exposure, and the per-arm b1 cite (za + fuel bind by matching) ---

(claim sqbx_leg
  (goal
    ((x0 Int) (x1 Int) (x2 Int) (m Mem) (c Nat) (c2 Nat) (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 46 c)
        (MkXModule restfs 0 65536)
        (inline sqbx_g0_x)
        (MkRegs 0 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 16 c2) 65536 (inline sqbx_g0_i) (list x0 x1 x2) m))))
  (chain
    (have hi2 (= (int_of_nat 2) 2)
      (chain
        (have ha2 (= (int_of_nat 2) (int_of_nat (S^ 2 Z)))
          (steps ((compute both)) refl))
        (steps
          ((rewrite (premise ha2) lr lhs true ())
           (rewrite (lemma int_of_nat_succ) lr lhs true ())
           (rewrite (lemma int_of_nat_succ) lr lhs true ())
           (rewrite (lemma int_of_nat_zero) lr lhs true ())
           (compute lhs)))
        refl))
    (have hxk1 (= (XMovRI RDX (int_of_nat 2)) (XMovRI RDX 2))
      (steps ((rewrite (premise hi2) lr lhs true ())) refl))
    (steps ((rewrite (premise hxk1) rl lhs false ())))
    (have hik1 (= (ISet 2 (IConst (int_of_nat 2))) (ISet 2 (IConst 2)))
      (steps ((rewrite (premise hi2) lr lhs true ())) refl))
    (steps ((rewrite (premise hik1) rl rhs false ())))
    (steps
      ((compute
         both
         (stop iwhile xeval_loop lg_fuel int_of_nat sqbx_r1_x sqbx_r1_i))))
    (case-on (lt (mod (+ x1 4) 4294967296) 9) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute
                both
                (stop iwhile xeval_loop lg_fuel int_of_nat sqbx_r1_x sqbx_r1_i))))
           (case-on (le 0 x0) Bool
             ((case True
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute
                       both
                       (stop iwhile xeval_loop lg_fuel int_of_nat sqbx_r1_x
                         sqbx_r1_i))))
                  (case-on (lt x0 65536) Bool
                    ((case True
                       (chain
                         (have hlt1 (= (lt x0 65536) True)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle1 (= (le (+ x0 1) 65536) True)
                           (steps () (by arith (rows (goal 1) (hlt1 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle1) lr lhs true ())
                            (compute
                              both
                              (stop iwhile xeval_loop lg_fuel int_of_nat
                                sqbx_r1_x sqbx_r1_i))))
                         (have hkw1
                           (=
                             (mod (int_of_nat 2) 18446744073709551616)
                             (int_of_nat 2))
                           (rewrite-with
                             (lemma sqbx_wid64)
                             lr
                             lhs
                             ((inst x (int_of_nat 2)))
                             ((rewrite-with
                                (lemma int_of_nat_nonneg)
                                lr
                                lhs
                                ()
                                ()
                                refl)
                              (steps
                                ((rewrite (premise hi2) lr lhs true ())
                                 (compute lhs))
                                refl))
                             refl))
                         (steps ((rewrite (premise hkw1) lr lhs true ())))
                         (have hf1i (= (S^ 11 c2) (S^ 9 (lg_fuel 2 c2)))
                           (steps ((compute both)) refl))
                         (have hf1m (= (S^ 39 c) (S^ 8 (lg_fuel 2 (S^ 29 c))))
                           (steps ((compute both)) refl))
                         (steps
                           ((rewrite (premise hf1i) lr rhs true ())
                            (rewrite (premise hf1m) lr lhs true ())))
                         (rewrite-with
                           (lemma sqbxw_l1)
                           lr
                           lhs
                           ((inst c2 c2))
                           ((steps
                              ((rewrite (premise hi2) lr lhs true ())
                               (compute lhs))
                              refl)))
                         (case-on
                           (iwhile
                             (S^ 9 (lg_fuel 2 c2))
                             65536
                             (ILoc 2)
                             (inline sqbx_l1_i)
                             (list
                               x0
                               (mod (+ (mod (+ x1 4) 4294967296) 6) 4294967296)
                               (int_of_nat 2))
                             (mem_set
                               m
                               x0
                               (band
                                 (mod
                                   (+ (mod (+ x1 4) 4294967296) 6)
                                   4294967296)
                                 255)))
                           Option
                           ((case None
                              (chain
                                (steps
                                  ((rewrite (hyp 0) lr both true ())
                                   (compute
                                     both
                                     (stop iwhile xeval_loop lg_fuel int_of_nat
                                       istmts xeval_seq sqbx_r1_x sqbx_r1_i))))
                                refl))
                            (case Some
                              (o1)
                              (chain
                                (steps ((rewrite (hyp 0) lr both true ())))
                                (case-on o1 IOut
                                  ((case INorm
                                     (lc1 mm1)
                                     (chain
                                       (steps
                                         ((rewrite (hyp 0) lr both true ())))
                                       (have hc1i (= (lg_fuel 2 c2) (S^ 2 c2))
                                         (steps ((compute both)) refl))
                                       (have hc1m
                                         (= (lg_fuel 2 (S^ 29 c)) (S^ 31 c))
                                         (steps ((compute both)) refl))
                                       (steps
                                         ((rewrite
                                            (premise hc1i)
                                            lr
                                            both
                                            true
                                            ())
                                          (rewrite
                                            (premise hc1m)
                                            lr
                                            both
                                            true
                                            ())
                                          (compute
                                            both
                                            (stop iwhile xeval_loop lg_fuel
                                              int_of_nat istmts xeval_seq
                                              sqbx_r1_x sqbx_r1_i))))
                                       (case-on lc1 List
                                         ((case Nil
                                            (chain
                                              (have hbad
                                                (=
                                                  (iolen
                                                    (ilen
                                                      (list
                                                        x0
                                                        (mod
                                                          (+
                                                            (mod
                                                              (+ x1 4)
                                                              4294967296)
                                                            6)
                                                          4294967296)
                                                        (int_of_nat 2)))
                                                    (Some (INorm lc1 mm1)))
                                                  3)
                                                (chain
                                                  (steps
                                                    ((rewrite
                                                       (hyp 1)
                                                       rl
                                                       lhs
                                                       true
                                                       ())
                                                     (rewrite
                                                       (hyp 2)
                                                       rl
                                                       lhs
                                                       true
                                                       ())))
                                                  (rewrite-with
                                                    (lemma il_wlen)
                                                    lr
                                                    lhs
                                                    ()
                                                    ())
                                                  (steps ((compute lhs)))
                                                  refl))
                                              (have hlen
                                                (=
                                                  (iolen
                                                    (ilen
                                                      (list
                                                        x0
                                                        (mod
                                                          (+
                                                            (mod
                                                              (+ x1 4)
                                                              4294967296)
                                                            6)
                                                          4294967296)
                                                        (int_of_nat 2)))
                                                    (Some (INorm lc1 mm1)))
                                                  (ilen lc1))
                                                (steps ((compute both)) refl))
                                              (have hg (= (ilen lc1) 3)
                                                (steps
                                                  ((rewrite
                                                     (premise hlen)
                                                     rl
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (premise hbad)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl))
                                              (have hs (= (ilen lc1) 0)
                                                (steps
                                                  ((rewrite
                                                     (hyp 0)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (compute lhs))
                                                  refl))
                                              (have hff (= (le 0 0) False)
                                                (steps
                                                  ()
                                                  (by
                                                    arith
                                                    (rows
                                                      (goal 1)
                                                      (hg 1)
                                                      (hs -1)))))
                                              (absurd (premise hff))))
                                          (case Cons
                                            (e1_0 r1_0)
                                            (chain
                                              (steps
                                                ((rewrite
                                                   (hyp 0)
                                                   lr
                                                   both
                                                   true
                                                   ())
                                                 (compute
                                                   both
                                                   (stop iwhile xeval_loop
                                                     lg_fuel int_of_nat istmts
                                                     xeval_seq sqbx_r1_x
                                                     sqbx_r1_i))))
                                              (case-on r1_0 List
                                                ((case Nil
                                                   (chain
                                                     (have hbad
                                                       (=
                                                         (iolen
                                                           (ilen
                                                             (list
                                                               x0
                                                               (mod
                                                                 (+
                                                                   (mod
                                                                     (+ x1 4)
                                                                     4294967296)
                                                                   6)
                                                                 4294967296)
                                                               (int_of_nat 2)))
                                                           (Some
                                                             (INorm lc1 mm1)))
                                                         3)
                                                       (chain
                                                         (steps
                                                           ((rewrite
                                                              (hyp 2)
                                                              rl
                                                              lhs
                                                              true
                                                              ())
                                                            (rewrite
                                                              (hyp 3)
                                                              rl
                                                              lhs
                                                              true
                                                              ())))
                                                         (rewrite-with
                                                           (lemma il_wlen)
                                                           lr
                                                           lhs
                                                           ()
                                                           ())
                                                         (steps ((compute lhs)))
                                                         refl))
                                                     (have hlen
                                                       (=
                                                         (iolen
                                                           (ilen
                                                             (list
                                                               x0
                                                               (mod
                                                                 (+
                                                                   (mod
                                                                     (+ x1 4)
                                                                     4294967296)
                                                                   6)
                                                                 4294967296)
                                                               (int_of_nat 2)))
                                                           (Some
                                                             (INorm lc1 mm1)))
                                                         (ilen lc1))
                                                       (steps
                                                         ((compute both))
                                                         refl))
                                                     (have hg (= (ilen lc1) 3)
                                                       (steps
                                                         ((rewrite
                                                            (premise hlen)
                                                            rl
                                                            lhs
                                                            true
                                                            ())
                                                          (rewrite
                                                            (premise hbad)
                                                            lr
                                                            lhs
                                                            true
                                                            ()))
                                                         refl))
                                                     (have hs (= (ilen lc1) 1)
                                                       (steps
                                                         ((rewrite
                                                            (hyp 1)
                                                            lr
                                                            lhs
                                                            true
                                                            ())
                                                          (rewrite
                                                            (hyp 0)
                                                            lr
                                                            lhs
                                                            true
                                                            ())
                                                          (compute lhs))
                                                         refl))
                                                     (have hff
                                                       (= (le 0 0) False)
                                                       (steps
                                                         ()
                                                         (by
                                                           arith
                                                           (rows
                                                             (goal 1)
                                                             (hg 1)
                                                             (hs -1)))))
                                                     (absurd (premise hff))))
                                                 (case Cons
                                                   (e1_1 r1_1)
                                                   (chain
                                                     (steps
                                                       ((rewrite
                                                          (hyp 0)
