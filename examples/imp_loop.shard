;;; examples/imp_loop.shard — imp twins of the LOOP fragment
;;; (docs/IMP.md rung I0): representative members of the loop fragment
;;; class (examples/wasmgen_loop_src.shard) re-spelled as imp while
;;; loops, with spec ⊑ imp certs by induction on the Nat counter. The
;;; store twin (lp_fill) and the read-accumulate twin (lp_sum) cover
;;; the class's two memory directions.
;;;
;;; The collapse is DIRECT because Mem is the shared substrate: the
;;; imp run constructs literally the same mem_set/mem_get terms as the
;;; spec's recursion, so the workers align them by induction with no
;;; byte-level reasoning — and no width residue exists anywhere (imp
;;; scalars are exact; the wasm twins' wrap32 haves have no analogue).
;;;
;;; Fuel rides models/wasm/loopkit's lg_fuel tower (one S per
;;; iteration) inside a constant S^ reservoir: the reservoir covers
;;; the body's DEPTH each iteration and is restored by the tower's S
;;; ((S^ E (S x)) and (S^ (+ E 1) x) are the same tree), so the
;;; re-entry fuel is exactly the induction hypothesis's shape. The
;;; loopkit is imported for its Int/Nat lemma kit (lg_fuel, lg_adv,
;;; lg_ne, lg_sub, lg_lo1, lg_shift — all wasm-free; imp is the kit's
;;; second speaker, noted for the meta/ graduation queue).

(import "../kernel/stdlib.shard")
(import "../std/nat.shard")
(use (:: std nat *))
(import "../std/mem")
(use (:: std mem *))
(import "wasmgen_loop_src.shard")
(use (:: examples wasmgen_loop_src *))
(import "../models/imp/imp.shard")
(use (:: models imp imp *))
(import "../models/wasm/loopkit.shard")
(use (:: models wasm loopkit *))

;; --- programs ------------------------------------------------------------------

(fn il_prog ((f IFn)) IProg (MkIProg (list f) 65536))

;; (d v n): while n != 0 { mem[d] := v; d += 1; n -= 1 }
(fn il_fill_body () (List IStmt)
  (list
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin IAdd (ILoc 0) (IConst 1)))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))))

(fn il_fill_fn () IFn
  (MkIFn 3 0 (list (IWhile (ILoc 2) (il_fill_body))) (IConst 0)))

;; (p acc n): while n != 0 { acc += mem[p]; p += 1; n -= 1 } -> acc
(fn il_sum_body () (List IStmt)
  (list
    (ISet 1 (IBin IAdd (ILoc 1) (ILoad (ILoc 0))))
    (ISet 0 (IBin IAdd (ILoc 0) (IConst 1)))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))))

(fn il_sum_fn () IFn
  (MkIFn 3 0 (list (IWhile (ILoc 2) (il_sum_body))) (ILoc 1)))

;; --- the one new range lemma (the machine's strict store/load bound) ------------

;; a + (S c) <= 65536  |-  a < 65536  (the IStore/ILoad guard shape)
(claim im_lt
  (goal ((a Int) (c Nat))
    ((= (le (+ a (int_of_nat (S c))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 (int_of_nat c)) True))
    (= (lt a 65536) True))
  (by arith (list 1 1 1 1)))

;; --- the fill worker: induction on the counter --------------------------------

(claim imw_fill
  (goal ((d Int) (v Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (iwhile
        (S^ 10 (lg_fuel k c))
        65536
        (ILoc 2)
        (inline il_fill_body)
        (list d v (int_of_nat k))
        m0)
      (Some (INorm (list (lg_adv d k) v 0) (lp_fill m0 d v k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold iwhile lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop iwhile lg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (lemma im_lt)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop iwhile lg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps ((unfold lp_fill rhs) (unfold lg_adv rhs) (reduce rhs)))
         (steps ((compute both)))
         refl)))))

;; --- the sum worker: the read direction ----------------------------------------

(claim imw_sum
  (goal ((p Int) (acc Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 p) True) (= (le (+ p (int_of_nat k)) 65536) True))
    (=
      (iwhile
        (S^ 10 (lg_fuel k c))
        65536
        (ILoc 2)
        (inline il_sum_body)
        (list p acc (int_of_nat k))
        m0)
      (Some (INorm (list (lg_adv p k) (lp_sum m0 p acc k) 0) m0))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold iwhile lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop iwhile lg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (lemma im_lt)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop iwhile lg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr lhs true ())
            (compute lhs (stop iwhile lg_fuel))))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps ((unfold lp_sum rhs) (unfold lg_adv rhs) (reduce rhs)))
         (steps ((compute both)))
         refl)))))

;; --- the pins: spec ⊑ imp at the call boundary ---------------------------------

(claim imp_lp_fill
  (goal ((d Int) (v Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (icall_mem
        (S^ 12 (lg_fuel k c))
        (il_prog (il_fill_fn))
        0
        (list d v (int_of_nat k))
        m0)
      (Some (Pair 0 (lp_fill m0 d v k)))))
  (chain
    (steps ((compute lhs (stop iwhile lg_fuel))))
    (rewrite-with
      (lemma imw_fill)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))

(claim imp_lp_sum
  (goal ((p Int) (acc Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 p) True) (= (le (+ p (int_of_nat k)) 65536) True))
    (=
      (icall_mem
        (S^ 12 (lg_fuel k c))
        (il_prog (il_sum_fn))
        0
        (list p acc (int_of_nat k))
        m0)
      (Some (Pair (lp_sum m0 p acc k) m0))))
  (chain
    (steps ((compute lhs (stop iwhile lg_fuel))))
    (rewrite-with
      (lemma imw_sum)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))
