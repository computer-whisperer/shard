;;; examples/lib_form_rejects.shard — the (lib …) form, NEGATIVE fixture
;;; (corpus expects nonzero exit): an export naming a bodyless sig is not
;;; implemented, and an accepts entry naming a non-export is a phantom
;;; exception declaration — both are ill-formed and the check FAILS.

(import "../kernel/stdlib.shard")

(fn lr_inc ((a Int)) Int (+ a 1))

(sig fn lr_ghost ((a Int)) Int)

(lib
  lr_kit
  (exports lr_inc lr_ghost)
  (accepts (lr_inc wrap32) (lr_phantom wrap32)))
