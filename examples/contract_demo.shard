;;; contract_demo.shard — axiom + requirement/fulfills on the proof-DSL surface.
;;;
;;; Exercises the goal-only and proof-only decls of the proof language:
;;;   (axiom NAME (goal …))            — admitted without proof
;;;   (requirement NAME (goal …))      — a pending obligation (the contract)
;;;   (fulfills NAME <proof-dsl>)      — discharges it (the goal comes from the
;;;                                      requirement; never restated)

(import "../kernel/stdlib.shard")   ; stdlib types (List/Option/Bool/Pair)
(import "../std/nat.shard")

;; A native axiom: admitted without proof, available to later citations.
(axiom add_zero_left (goal ((n Nat)) () (= (add_nat Z n) n)))

;; A native requirement: the obligation, stated once.
(requirement add_zero_right (goal ((n Nat)) () (= (add_nat n Z) n)))

;; Its fulfillment, in the proof DSL — the goal is looked up from the contract.
(fulfills add_zero_right
  (induct n
    ((case Z
       (steps ((unfold add_nat lhs) (reduce lhs)) refl))
     (case S
       (steps ((unfold add_nat lhs)
               (reduce lhs)
               (rewrite (hyp 0) lr lhs true ()))
              refl)))))
