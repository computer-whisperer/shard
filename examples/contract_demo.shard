;;; contract_demo.shard — axiom + requirement/fulfills on the proof-DSL surface.
;;;
;;; Exercises the goal-only and proof-only decls of the proof language:
;;;   (axiom NAME (goal …))            — admitted without proof
;;;   (requirement NAME (goal …))      — a pending obligation (the contract)
;;;   (fulfills NAME <proof-dsl>)      — discharges it (the goal comes from the
;;;                                      requirement; never restated)
;;;
;;; Module-world note: the fulfillment is an induction that `unfold`s its
;;; subject, so this demo OWNS that subject — `add` is defined here. (When the
;;; requirement/fulfills pair spans a real module interface↔impl, the impl owns
;;; the function the same way; a CONSUMER would instead cite the proven lemma.
;;; See examples/modules_demo/ and std/nat/.)

(import "../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)

;; Nat and add, defined and OWNED here (so the fulfillment may unfold add).
(type Nat (Z) (S Nat))
(fn add ((a Nat) (b Nat)) Nat
  (match a
    (Z b)
    ((S k) (S (add k b)))))

;; A native axiom: admitted without proof, available to later citations.
(axiom add_zero_left (goal ((n Nat)) () (= (add Z n) n)))

;; A native requirement: the obligation, stated once.
(requirement add_zero_right (goal ((n Nat)) () (= (add n Z) n)))

;; Its fulfillment, in the proof DSL — the goal is looked up from the contract.
(fulfills add_zero_right
  (induct n
    ((case Z (steps ((unfold add lhs) (reduce lhs)) refl))
     (case S
       (steps
         ((unfold add lhs) (reduce lhs) (rewrite (hyp 0) lr lhs true ()))
         refl)))))
