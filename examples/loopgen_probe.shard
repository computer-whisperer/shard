;;; loopgen_probe.shard — THE LOOP-GENERATION PROBE (docs/LOWERING.md
;;; ratification round). Question: can the emitter machine-generate a LOOP
;;; piece — the induction worker + piece theorem — from a recursive source
;;; fn? This file hand-plays the generator on a fixed template, every line
;;; derived by mechanical rule from the source fn; any step that needs
;;; per-instance creativity is a probe failure.
;;;
;;; THE FRAGMENT (loop template v1): Nat-counted tail recursion
;;;     (fn NAME ((m Mem) (a1 Int) … (an Int) (k Nat)) Mem
;;;       (match k
;;;         (Z m)
;;;         ((S k2) (NAME (mem_set … one trailing store …) U1 … Un k2))))
;;; with accum updates Ui ∈ { ai, (+ ai 1) } and the per-iteration body in
;;; the mem fragment's shape (reads pre-write). COUNTER-AS-LOCAL design:
;;; the machine carries k as an i32 local (ENC = the uniform type rule
;;; Nat ↦ int_of_nat) — guard (LocalGet kk / I32Eqz / BrIf 1), decrement
;;; by BSub — a direct transliteration of the source recursion. No ghost
;;; end-pointer parameter (contrast the hand-written wasm_copy piece), so
;;; the public signature is the source signature and every guard fact is
;;; template-constant.
;;;
;;; GENERATED ITEMS (per file: fuel fn, stride twin, 7 helper certs with
;;; PINNED farkas certificates — template-constant, no enumeration; per
;;; fn: body/func literals, worker induction, lowered_* theorem):
;;;   - worker: induct k; Z case = pure compute (guard exits ground);
;;;     S case = the staged pass (unfold fuel/eval_loop, guard decider,
;;;     premise-rewrite the address guards in code order, then counter
;;;     collapse + wrap32_id haves, open the spec one step on the rhs,
;;;     cite the IH at the advanced accums, compute both).
;;;   - theorem: plumbing compute into the loop (fuel = worker + 4), one
;;;     worker citation, pass-through premise discharges.
;;;   - fuel: S^(instrs+4) over (lg_fuel k c) — one S per iteration; the
;;;     loop re-enters at exactly fuel-1, so the IH spelling aligns at
;;;     ANY sufficient body budget (instrs+4 is the charged formula).
;;; Two instances: fill_loop (new spec, 1 advancing accum + constant
;;; store) and mem_copy's copy_loop (the REAL spec, 2 advancing accums +
;;; load/store) — the machine-template twin of the hand-written copy8.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(import "../std/nat.shard")
(import "mem_copy.shard")
(import "../models/wasm/wasm.shard")
(use (:: std mem *))
(use (:: std nat *))
(use (:: models wasm wasm *))
(use (:: examples mem_copy copy_loop))

;; --- per-file generated kit: fuel, stride twin, helper certs ----------------------

;; one S per remaining iteration over the slack tail (the pfc shape).
(fn lg_fuel ((k Nat) (c Nat)) Nat
  (measure (struct k))
  (match k
    (Z c)
    ((S k2) (S (lg_fuel k2 c)))))

;; final position of a stride-1 accum after k iterations (the cs/cd shape;
;; ONE twin per stride, shared by every advancing accum in the file).
(fn lg_adv ((x Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z x)
    ((S k2) (lg_adv (+ x 1) k2))))

;; guard decider, S case: the counter local reads 1 + n with n >= 0.
(claim lg_ne
  (goal ((n Int)) ((= (le 0 n) True)) (= (int_eq (+ 1 n) 0) False))
  (by arith (list -1 1)))

;; counter collapse: the BSub residue's argument is (1 + n) - 1.
(claim lg_sub (goal ((n Int)) () (= (- (+ 1 n) 1) n)) (by arith (list)))

;; counter wrap upper bound: any range premise caps the counter below 2^32.
(claim lg_kM
  (goal ((a Int) (c Nat))
    ((= (le (+ a (int_of_nat (S c))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 a) True))
    (= (lt (int_of_nat c) 4294967296) True))
  (by arith (list 1 1 1 1)))

;; address guard, upper: a + (S c) <= 65536  |-  a + 1 <= 65536.
(claim lg_a1_ms
  (goal ((a Int) (c Nat))
    ((= (le (+ a (int_of_nat (S c))) 65536) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))
     (= (le 0 (int_of_nat c)) True))
    (= (le (+ a 1) 65536) True))
  (by arith (list 1 1 1 1)))

;; pointer-advance ranges for the wrap32 cleanups.
(claim lg_lo1
  (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (+ x 1)) True))
  (by arith (list 1 1)))

(claim lg_32
  (goal ((x Int)) ((= (le (+ x 1) 65536) True))
    (= (lt (+ x 1) 4294967296) True))
  (by arith (list 1 1)))

;; range premise steps to the IH: a + (S c) <= w  |-  (a+1) + c <= w.
(claim lg_shift
  (goal ((b Int) (w Int) (c Nat))
    ((= (le (+ b (int_of_nat (S c))) w) True)
     (= (int_of_nat (S c)) (+ 1 (int_of_nat c))))
    (= (le (+ (+ b 1) (int_of_nat c)) w) True))
  (by arith (list 1 1 1)))

;; --- instance 1: fill --------------------------------------------------------------

;; the source fn (in a real build this lives in the source module).
(fn fill_loop ((m Mem) (d Int) (v Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (fill_loop (mem_set m d v) (+ d 1) v k2))))

;; generated body: guard / store / d++ / k-- / re-enter. Locals: d=0 v=1 kk=2.
(fn fl_body () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 0)
    (LocalGet 1)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn fl_func () Func
  (MkFunc 3 0 (list (Block (list (Loop (fl_body)))) (I32Const 0))))

;; the worker: 15 body instrs -> S^19 (instrs + 4).
(claim lgw_fill
  (goal
    ((d Int)
     (v Int)
     (st (List Int))
     (mm Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (eval_loop
        (S^ 19 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline fl_body)))) (I32Const 0)))
            restfs)
          65536)
        (inline fl_body)
        (list d v (int_of_nat k))
        st
        mm)
      (Some (OBr 0 st (list (lg_adv d k) v 0) (fill_loop mm d v k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold eval_loop lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop eval_loop lg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop eval_loop lg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma lg_kM)
                lr
                lhs
                ((inst a d) (inst c k2))
                ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hwd (= (mod (+ d 1) 4294967296) (+ d 1))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ d 1)))
             ((rewrite-with
                (lemma lg_lo1)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma lg_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma lg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hwd) lr lhs true ())))
         (steps ((unfold fill_loop rhs) (unfold lg_adv rhs) (reduce rhs)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps ((compute both)))
         refl)))))

;; the piece theorem: worker + 4 plumbing levels.
(claim lowered_fill_loop
  (goal ((d Int) (v Int) (mm Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (call_fn_mem
        (S^ 23 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline fl_body)))) (I32Const 0)))
            restfs)
          65536)
        0
        (list d v (int_of_nat k))
        mm)
      (Some (Pair 0 (fill_loop mm d v k)))))
  (chain
    (steps ((compute lhs (stop eval_loop lg_fuel))))
    (rewrite-with
      (lemma lgw_fill)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))

;; --- instance 2: copy (mem_copy's REAL spec fn) -----------------------------------

;; generated body: guard / m[d]:=m[s] / s++ / d++ / k-- / re-enter.
;; Locals: s=0 d=1 kk=2.
(fn cp_body () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (LocalGet 0)
    (I32Load8U)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 1)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 1)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn cp_func () Func
  (MkFunc 3 0 (list (Block (list (Loop (cp_body)))) (I32Const 0))))

;; the worker: 20 body instrs -> S^24.
(claim lgw_copy
  (goal
    ((s Int)
     (d Int)
     (st (List Int))
     (mm Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 s) True)
     (= (le 0 d) True)
     (= (le (+ s (int_of_nat k)) 65536) True)
     (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (eval_loop
        (S^ 24 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline cp_body)))) (I32Const 0)))
            restfs)
          65536)
        (inline cp_body)
        (list s d (int_of_nat k))
        st
        mm)
      (Some (OBr 0 st (list (lg_adv s k) (lg_adv d k) 0) (copy_loop mm s d k)))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold eval_loop lhs)
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop eval_loop lg_fuel))
            (rewrite (premise 0) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 2) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute lhs (stop eval_loop lg_fuel))
            (rewrite (premise 1) lr lhs true ())
            (compute lhs (stop eval_loop lg_fuel))))
         (rewrite-with
           (lemma lg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 3) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute lhs (stop eval_loop lg_fuel))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr lhs true ())))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma lg_kM)
                lr
                lhs
                ((inst a s) (inst c k2))
                ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hws (= (mod (+ s 1) 4294967296) (+ s 1))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ s 1)))
             ((rewrite-with
                (lemma lg_lo1)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma lg_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma lg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hws) lr lhs true ())))
         (have hwd (= (mod (+ d 1) 4294967296) (+ d 1))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ d 1)))
             ((rewrite-with
                (lemma lg_lo1)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 1) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma lg_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma lg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hwd) lr lhs true ())))
         (steps ((unfold copy_loop rhs) (unfold lg_adv rhs) (reduce rhs)))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 3) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         (steps ((compute both)))
         refl)))))

;; the piece theorem: worker + 4 plumbing levels.
(claim lowered_copy_loop
  (goal ((s Int) (d Int) (mm Mem) (c Nat) (k Nat) (restfs (List Func)))
    ((= (le 0 s) True)
     (= (le 0 d) True)
     (= (le (+ s (int_of_nat k)) 65536) True)
     (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (call_fn_mem
        (S^ 28 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline cp_body)))) (I32Const 0)))
            restfs)
          65536)
        0
        (list s d (int_of_nat k))
        mm)
      (Some (Pair 0 (copy_loop mm s d k)))))
  (chain
    (steps ((compute lhs (stop eval_loop lg_fuel))))
    (rewrite-with
      (lemma lgw_copy)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))
