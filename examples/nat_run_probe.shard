;;; nat_run_probe.shard — RUN-mode conformance probe for the Nat former.
;;;
;;; Exercises the ENGINE path (ev / eval.rs / compiled chain): ground Nat
;;; construction (packs to a literal under a packing engine, stays a ctor
;;; tree under a pre-Nat engine), view/tree matching, and deep patterns.
;;; Output must be identical under every engine — "OK\n", exit 0.
;;;
;;; RUN: bin/shard_eval run examples/nat_run_probe.shard
;;;   or ./rust_bootstrap/target/release/eval run examples/nat_run_probe.shard

(import "../kernel/stdlib.shard")

(type World (World Int))

(extern write ((bytes (List Int)) (w World)) World)
(extern exit ((code Int) (w World)) World)

;; Int -> Nat (the fnat shape)
(fn nof ((k Int)) Nat
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) Z (S (nof (- k 1)))))

;; Nat -> Int, one S peel at a time (matcher-heavy)
(fn nval ((n Nat)) Int
  (measure (struct n))
  (match n
    (Z 0)
    ((S k) (+ 1 (nval k)))))

;; deep pattern: halving via (S (S k))
(fn nhalf ((n Nat)) Nat
  (measure (struct n))
  (match n
    (Z Z)
    ((S Z) Z)
    ((S (S k)) (S (nhalf k)))))

(fn ok ((b Bool)) Int (if b 0 1))

(fn checks () Int
  (+
    (ok (int_eq (nval (nof 1000)) 1000))
    (+
      (ok (int_eq (nval (nhalf (nof 1001))) 500))
      (+ (ok (int_eq (nval (nhalf Z)) 0)) (ok (int_eq (nval (S (S (S Z)))) 3))))))

(fn main ((w World)) World
  (if (int_eq (checks) 0) (exit 0 (write "OK\n" w))
  (exit 1 (write "MISMATCH\n" w))))
