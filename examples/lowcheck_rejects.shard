;;; examples/lowcheck_rejects.shard — the NEGATIVE fixture for
;;; tools/lowcheck (P4a). The claims below are kernel-TRUE (they check
;;; green in this very corpus) but SCHEMA-NONCONFORMING: no restfs binder,
;;; and the module's function chain is closed with Nil instead of the
;;; restfs tail — a certificate like this cannot participate in linking,
;;; however true it is. lowcheck must refuse both (exit 1) — one per
;;; target form (wasm call_fn, x86 xcall_fn). Truth and composability are
;;; different gates; the consumer checks both.

(import "../kernel/stdlib.shard")
(import "../models/wasm/wasm.shard")
(import "../models/x86/x86.shard")
(use (:: models wasm wasm *))
(use (:: models x86 x86 *))

(claim lowered_bogus
  (goal ((a Int) (b Int) (c Nat)) ()
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BAdd))) Nil)
          0)
        0
        (list a b))
      (Some (wrap32 (+ a b)))))
  (steps ((compute both)) refl))

(claim lowered_xbogus
  (goal ((a Int) (b Int) (c Nat)) ()
    (=
      (xcall_fn
        (S^ 6 c)
        (MkXModule
          (Cons
            (MkXFunc 2 (list (XMovRR RAX RDI) (XBin XAdd RAX (SReg RSI))))
            Nil)
          0)
        0
        (list a b))
      (Some (wrap64 (+ a b)))))
  (steps ((compute both)) refl))
