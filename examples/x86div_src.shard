;;; examples/x86div_src.shard — source fns for the x86_64 DIV fragment
;;; (docs/X86.md §31, rung B2; probe examples/xdiv_probe.shard): the
;;; compound divide through the straight-line walk. v1 pins itoa's two
;;; reads exactly — the whole body is (ediv PARAM +LIT) or
;;; (mod PARAM +LIT), at most two Int params (the divide clobbers rdx,
;;; param 3's home). tools/x86gen emits examples/x86div_out.shard: per fn
;;; an EMITTED div-facts guard lemma (xdg_*, farkas multipliers
;;; divisor-spliced) and the lowered theorem whose premises are the
;;; standard §11 pair on the DIVIDEND param. This lib is x86-ONLY: the
;;; wasm32 fragment's literal-divisor pieces carry ZERO premises (its
;;; ops re-wrap at every step), so a dual-target div export would trip
;;; the accepts law's no-phantom rule — named growth, deferred until a
;;; dual-target consumer demands it.

(import "../kernel/stdlib.shard")

;; itoa's quotient read: the next accumulator
(fn xd_q10 ((a Int)) Int (ediv a 10))

;; itoa's remainder read: the digit
(fn xd_r10 ((a Int)) Int (mod a 10))

;; a non-decimal divisor pins the spliced guard multipliers
(fn xd_q7 ((a Int)) Int (ediv a 7))
