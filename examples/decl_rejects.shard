;;; decl_rejects — EXPECTED TO FAIL: a malformed declaration (here a claim
;;; missing its proof) must be a HARD failure naming the decl, never a silent
;;; drop. Before this gate, a decl-stream parse failure skipped the WHOLE
;;; source's decls outcome-less — this file would have reported "0 passed,
;;; 0 failed" and looked clean (fine_claim below never gets an outcome line
;;; either: the stream fails as a unit). Checking this file must report:
;;;
;;;   FAIL  __decls__
;;;   malformed declaration (claim deliberately_proofless ...) [source N of the import closure]
;;;
;;; (cf. parse_rejects — reject-tests assert the FAIL.)

(fn idg ((x Int)) Int x)

(claim fine_claim
  (goal ((a Int)) () (= (idg a) a))
  (steps ((unfold idg lhs) (reduce lhs)) refl))

(claim deliberately_proofless (goal ((a Int)) () (= (idg a) a)))
