;;; demo vocab — a req-scope SIBLING: spec vocabulary living INSIDE the
;;; module's mod.req/ directory, beside the interface entry. This is the
;;; arrangement the req-scope gate exists to make possible: the interface may
;;; import this file (both are req-scope) but could never import an impl file.
;;; Its module path COLLAPSES the mod.req segment (reader.shard
;;; drop_req_dir_segs), so these names live at
;;; `examples::req_dir_demo::demo::vocab` — exactly as if this file sat in the
;;; module root.
(import "../../../../kernel/stdlib.shard")

(fn twice ((n Int)) Int (+ n n))

;; vocab stays VERIFIED: claims here are checked in every closure that loads
;; the interface (req-scope is not granted-scope; only requirements in the
;; granted entry become axioms).
(claim twice_5_is_10 (goal () () (= (twice 5) 10)) (steps ((simp lhs)) refl))
