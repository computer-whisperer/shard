;;; consumer — imports the dir-form `demo` module bare and reasons through its
;;; interface: the opaque `double` sig, the promised lemma, AND the req-scope
;;; sibling's vocabulary (vocab.shard rides in the interface closure). The use
;;; paths have NO mod.req segment — the collapse (drop_req_dir_segs) is what
;;; this file pins.
(import "../../kernel/stdlib.shard")
(import "demo")
(use (:: examples req_dir_demo demo double))  ; the opaque sig fn
(use (:: examples req_dir_demo demo vocab twice))  ; the sibling's vocab fn
(use (:: examples req_dir_demo demo *))  ; interface lemmas for citations

(claim consumer_double_is_twice
  (goal ((a Int)) () (= (double a) (twice a)))
  (steps ((rewrite (lemma double_is_twice) lr lhs true ((inst x a)))) refl))
