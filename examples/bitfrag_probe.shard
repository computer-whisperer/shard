;;; bitfrag_probe.shard — the emitter bitwise design probe (docs/LOWERING.md
;;; §6z): band/bor/bxor as pure-fragment ops, probed by hand before
;;; mechanization.
;;;
;;; THE STRUCTURE (why this slice is smaller than div): bop_val applies
;;; the kernel prims DIRECTLY — (BAnd (Some (band a b))), total, no wrap,
;;; no guard. A bitwise node therefore sticks nowhere, contributes NO
;;; premise and NO discharge event; the machine spelling IS the spec
;;; spelling, and the folded prim term just rides the residue. Arith
;;; nodes CONTAINING bitwise subterms take the normal wrap premise pair —
;;; the bounds are the CONSUMER's to discharge, and std/bits is the kit
;;; (band_le_l / bor_le32 / mask_byte …, see examples/bits_demo.shard).
;;;
;;; Cases: the bare trio (zero premises, plain proof) / literal mask /
;;; arith over a bitwise node (the wrap event fires at a band-containing
;;; spelling) / a bitwise node as a DIV DIVISOR (the §6y stage's guard
;;; premise spelled at the bor term — no wrap flush needed, the divisor
;;; spelling is already clean).

(import "../kernel/stdlib.shard")
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))

;; ---- the source fns (the fragment instances) ----------------------------------

(fn bt_and ((a Int) (b Int)) Int (band a b))

(fn bt_or ((a Int) (b Int)) Int (bor a b))

(fn bt_xor ((a Int) (b Int)) Int (bxor a b))

(fn bt_mask ((a Int)) Int (band a 255))

(fn bt_arith ((a Int) (b Int)) Int (+ (band a b) 1))

(fn bt_div ((a Int) (b Int)) Int (ediv a (bor b 1)))

;; ---- the bare trio: zero premises, the plain one-shot proof ---------------------

(claim btp_and
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List Func))) ()
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons
            (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BAnd)))
            restfs)
          0)
        0
        (list x0 x1))
      (Some (bt_and x0 x1))))
  (steps ((compute lhs) (unfold bt_and rhs) (reduce rhs)) refl))

(claim btp_or
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List Func))) ()
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons
            (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BOr)))
            restfs)
          0)
        0
        (list x0 x1))
      (Some (bt_or x0 x1))))
  (steps ((compute lhs) (unfold bt_or rhs) (reduce rhs)) refl))

(claim btp_xor
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List Func))) ()
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons
            (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BXor)))
            restfs)
          0)
        0
        (list x0 x1))
      (Some (bt_xor x0 x1))))
  (steps ((compute lhs) (unfold bt_xor rhs) (reduce rhs)) refl))

;; ---- literal mask: the emblematic use, still zero premises ----------------------

(claim btp_mask
  (goal ((x0 Int) (c Nat) (restfs (List Func))) ()
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule
          (Cons
            (MkFunc 1 0 (list (LocalGet 0) (I32Const 255) (I32Bin BAnd)))
            restfs)
          0)
        0
        (list x0))
      (Some (bt_mask x0))))
  (steps ((compute lhs) (unfold bt_mask rhs) (reduce rhs)) refl))

;; ---- arith over bitwise: the wrap event fires at a band-containing spelling -----

(claim btp_arith
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List Func)))
    ((= (le 0 (+ (band x0 x1) 1)) True)
     (= (lt (+ (band x0 x1) 1) 4294967296) True))
    (=
      (call_fn
        (S^ 13 c)
        (MkWModule
          (Cons
            (MkFunc
              2
              0
              (list
                (LocalGet 0)
                (LocalGet 1)
                (I32Bin BAnd)
                (I32Const 1)
                (I32Bin BAdd)))
            restfs)
          0)
        0
        (list x0 x1))
      (Some (bt_arith x0 x1))))
  (chain
    (steps ((compute lhs) (unfold bt_arith rhs) (reduce rhs)))
    (have w0 (= (mod (+ (band x0 x1) 1) 4294967296) (+ (band x0 x1) 1))
      (rewrite-with
        (lemma wrap32_id)
        lr
        lhs
        ((inst x (+ (band x0 x1) 1)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w0) lr lhs true ())))
    refl))

;; ---- bitwise divisor: the §6y stage at an already-clean bor spelling ------------

(claim btp_div
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List Func)))
    ((= (le 1 (bor x1 1)) True))
    (=
      (call_fn
        (S^ 13 c)
        (MkWModule
          (Cons
            (MkFunc
              2
              0
              (list
                (LocalGet 0)
                (LocalGet 1)
                (I32Const 1)
                (I32Bin BOr)
                (I32Bin BDivU)))
            restfs)
          0)
        0
        (list x0 x1))
      (Some (bt_div x0 x1))))
  (chain
    (steps ((compute lhs) (unfold bt_div rhs) (reduce rhs)))
    (steps ((rewrite (premise 0) lr lhs true ()) (compute lhs)))
    refl))
