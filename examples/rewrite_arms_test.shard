;;; rewrite_arms_test — the rewrite-into-Match-arms extension (checker.shard
;;; rewrite_all). When `compute` stalls on a stuck scrutinee, ceval REIFIES the
;;; un-entered arm bodies into the goal (open_many_arms residuals); facts the
;;; arm bodies depend on must then be rewritable IN PLACE or no amount of
;;; compute/rewrite alternation converges. rewrite_all descends into arm bodies
;;; when the cited pattern & replacement are BVar-free (always true for sequent
;;; equations). This file is the minimal regression: the claim FAILS without
;;; the arm descent — step 2's rewrite finds its only occurrence inside the
;;; reified True-arm.

(import "../kernel/stdlib.shard")

(fn g ((a Bool) (k Int)) Int
  (match a
    (True (if (int_eq k 1) 3 4))
    (False 9)))

;; compute lhs -> (match a ((True (if (int_eq k 1) 3 4)) (False 9))) : the
;; scrutinee `a` is abstract, so the guard `int_eq k 1` now lives in a reified
;; arm BODY. Rewrite it there (premise 1), then resolve the scrutinee
;; (premise 0), then compute to the literal.
(claim rewrite_reaches_arm_body
  (goal ((a Bool) (k Int)) ((= a True) (= (int_eq k 1) True)) (= (g a k) 3))
  (steps
    ((compute lhs)
     (rewrite (premise 1) lr lhs true ())
     (rewrite (premise 0) lr lhs true ())
     (compute lhs))
    refl))
