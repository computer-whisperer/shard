;;; axiom_kind_rejects.shard — an unrecognized (kind …) clause on an axiom is
;;; a MALFORMED declaration: a hard decl-stream failure naming the form, never
;;; a silently-untagged admission. Expected:
;;;   FAIL  __decls__ / malformed declaration (axiom bad_kind ...)
;;;   0 passed, 1 failed

(import "../kernel/stdlib.shard")

(axiom bad_kind (kind load_bearing) (goal ((n Int)) () (= (+ n 0) n)))
