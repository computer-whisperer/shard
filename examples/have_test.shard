;;; have_test.shard — regression test for the (have …) tactic: the CUT rule.
;;; `(have E proof-of-E rest)` proves E in the current context, then proves the
;;; goal with E appended as the LAST premise (cited as the next index). This is
;;; the forward-reasoning primitive: extract a fact from a Bool invariant, then
;;; feed it to a later step as a clean premise. The chained extraction below
;;; mirrors exactly how board_ok inverts the snake invariant.

(import "../kernel/stdlib.shard")

(fn conj ((a Bool) (b Bool)) Bool
  (match a
    (True b)
    (False False)))

(claim conj_l
  (goal ((a Bool) (b Bool)) ((= (conj a b) True)) (= a True))
  (induct a ((case True refl) (case False (absurd (premise 0))))))
(claim conj_r
  (goal ((a Bool) (b Bool)) ((= (conj a b) True)) (= b True))
  (induct a
    ((case True (steps ((rewrite (premise 0) rl rhs true ()) (simp rhs)) refl))
     (case False (absurd (premise 0))))))

;; A two-deep nested conjunction (the shape of head_ok ∘ in_range).
(fn g3 ((p Int) (q Int) (r Int)) Bool (conj (le 1 p) (conj (le 1 q) (le 1 r))))

;; Extract the INNERMOST conjunct (le 1 r) by cutting the inner conjunction
;; first, then projecting it — the pattern that nested rewrite-with alone makes
;; fragile. `have` makes it linear: each cut becomes a clean premise.
;;
;; The cut's own proof discharges conj_r's premise `conj (le 1 p) (…) = True`
;; from `g3 … = True` by `rewrite (premise 0) rl rhs` (True ↦ g3) then
;; `compute both` — folding g3 open drives both sides to the same stuck NF.
(claim extract_inner
  (goal ((p Int) (q Int) (r Int)) ((= (g3 p q r) True)) (= (le 1 r) True))
  (have (= (conj (le 1 q) (le 1 r)) True)
    (rewrite-with
      (lemma conj_r)
      lr
      lhs
      ((inst a (le 1 p)) (inst b (conj (le 1 q) (le 1 r))))
      ((steps ((rewrite (premise 0) rl rhs true ()) (compute both)) refl))
      refl)
    ;; now (premise 1) = the cut, in exact form — project le 1 r straight off it
    (rewrite-with
      (lemma conj_r)
      lr
      lhs
      ((inst a (le 1 q)) (inst b (le 1 r)))
      ((steps ((rewrite (premise 1) lr lhs true ())) refl))
      refl)))
