;;; Refinement-type slice 2b: the intro side — the decidable downcast refine_try.
;;; (refine_try R EXPR) : (Option R) computes R's predicate on EXPR, reducing to
;;; (Some EXPR) when it holds and None otherwise (Some is wrapped ONLY when PRED
;;; is True — the soundness invariant). The Some payload is a genuine R-value, so
;;; a match arm binds s : R and refine-fact then grants R's invariant. The type
;;; R is written bare; the reader carries it as a marker. See docs/REFINEMENT.md.

(import "../kernel/stdlib.shard")

(fn is_small ((n Int)) Bool (lt n 5))

(type Small (refine Int is_small))

;; downcast then project back: the Some path returns the value (via refine_val),
;; the None path returns 0. Exercises reader + typer (s : Small) + the reducer.
(fn classify ((n Int)) Int
  (match (refine_try Small n)
    ((Some s) (refine_val s))
    (None 0)))

;; 3 < 5 → (Some 3) → 3
(claim classify_small
  (goal () () (= (classify 3) 3))
  (steps ((compute lhs)) refl))

;; 9 ≥ 5 → None → 0
(claim classify_big
  (goal () () (= (classify 9) 0))
  (steps ((compute lhs)) refl))
