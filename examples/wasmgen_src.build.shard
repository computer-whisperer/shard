                  (I32Bin BLeU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 1)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

;; --- the staged div fragment's modules (docs/LOWERING.md §6y) --------------------

(fn m_divq () WModule
