                  (I32Bin BLtU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (LocalGet 0)
              (I32Const 1)
              (I32Bin BSub)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_le () WModule
