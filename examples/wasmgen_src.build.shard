;;; examples/wasmgen_src.build.shard — the mod.build ENTRY (P4b →
;;; docs/LOWERING.md §6o): assembles the artifact set for
;;; examples/wasmgen_src.shard as a native Plan value.
;;;
;;;     (fn build ((t Target)) Plan)     — PURE; the whole interface
;;;
;;; One single-function module per fn (the cert's module literal at
;;; restfs := Nil, no memory), one manifest entry each
;;; (lowered_<fn> over export f0), and CASE vectors whose expected value
;;; is the SOURCE fn applied directly (spec-side semantics, not the
;;; model; u32-safe args only — the certs' premise discipline).
;;; The driver (tools/lowbuild/lowbuild.shard) renders the wire lines.
;;;
;;; The func literals here are copied from the generated certs; the
;;; cert↔binary tie is CHECKED by the BYTETIE gate (tools/bytetie —
;;; docs/LOWERING.md §6i), so drift fails the build.
;;;
;;; RUN IT:  bin/shard_eval run tools/lowbuild/lowbuild.shard examples/wasmgen_src.build.shard | node examples/wasm_diff.mjs /dev/stdin

(import "../kernel/stdlib.shard")
(import "wasmgen_src.shard")
(use (:: examples wasmgen_src *))
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../models/wasm/encode.shard")
(use (:: models wasm encode *))
(import "../meta/plan")
(use (:: meta plan *))

;; --- the binaries: one single-function module per source fn -------------------

(fn m_add1 () WModule
  (MkWModule
    (list (MkFunc 1 0 (list (LocalGet 0) (I32Const 1) (I32Bin BAdd))))
    0))

(fn m_add () WModule
  (MkWModule
    (list (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BAdd))))
    0))

(fn m_sub () WModule
  (MkWModule
    (list (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BSub))))
    0))

(fn m_mix () WModule
  (MkWModule
    (list
      (MkFunc
        2
        0
        (list
          (LocalGet 0)
          (I32Const 2)
          (I32Bin BMul)
          (LocalGet 1)
          (LocalGet 0)
          (I32Bin BSub)
          (I32Bin BAdd))))
    0))

(fn m_id () WModule (MkWModule (list (MkFunc 1 0 (list (LocalGet 0)))) 0))

(fn m_share () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (LocalGet 0)
          (LocalGet 0)
          (I32Bin BMul)
          (LocalSet 1)
          (LocalGet 1)
          (LocalGet 1)
          (I32Bin BAdd))))
    0))

(fn m_nest () WModule
  (MkWModule
    (list
      (MkFunc
        2
        2
        (list
          (LocalGet 0)
          (LocalGet 1)
          (I32Bin BAdd)
          (LocalSet 2)
          (LocalGet 2)
          (I32Const 2)
          (I32Bin BMul)
          (LocalSet 3)
          (LocalGet 3)
          (LocalGet 2)
          (I32Bin BAdd))))
    0))

(fn m_alias () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list (LocalGet 0) (LocalSet 1) (LocalGet 1) (I32Const 1) (I32Bin BAdd))))
    0))

(fn m_gate () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 10)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 1)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_sel () WModule
  (MkWModule
    (list
      (MkFunc
        2
        1
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 0)
                  (I32Bin BEq)
                  (BrIf 0)
                  (LocalGet 1)
                  (I32Const 2)
                  (I32Bin BMul)
                  (LocalSet 2)
                  (Br 1)))
              (LocalGet 1)
              (I32Const 1)
              (I32Bin BAdd)
              (LocalSet 2)))
          (LocalGet 2))))
    0))

(fn m_clamp2 () WModule
  (MkWModule
    (list
      (MkFunc
        1
        2
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 10)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (Block
                    (list
                      (Block
                        (list
                          (LocalGet 0)
                          (I32Const 100)
                          (I32Bin BLtU)
                          (BrIf 0)
                          (I32Const 2)
                          (LocalSet 2)
                          (Br 1)))
                      (I32Const 1)
                      (LocalSet 2)))
                  (LocalGet 2)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 0)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_selsq () WModule
  (MkWModule
    (list
      (MkFunc
        2
        2
        (list
          (LocalGet 0)
          (LocalGet 0)
          (I32Bin BMul)
          (LocalSet 2)
          (Block
            (list
              (Block
                (list
                  (LocalGet 1)
                  (I32Const 0)
                  (I32Bin BEq)
                  (BrIf 0)
                  (LocalGet 2)
                  (LocalGet 1)
                  (I32Bin BAdd)
                  (LocalSet 3)
                  (Br 1)))
              (LocalGet 2)
              (LocalSet 3)))
          (LocalGet 3))))
    0))

(fn m_dec () WModule
  (MkWModule
