;; --- the build entry -------------------------------------------------------------

(fn art ((nm (List Int))) PArt
  (PA
    nm
    (wapp "lowered_" nm)
    "examples/wasmgen_out.shard"
    "models/wasm/wasm.shard"
    0
    ""
    "none"))

(fn pv ((args (List Int)) (want Int)) PVec (PV 0 args Nil want Nil))

(fn pmod ((nm (List Int)) (m WModule) (vs (List PVec))) PMod
  (PM nm (enc_module m) (list (art nm)) vs))

(fn build ((t Target)) Plan
  (MkPlan
    (list
      (pmod
        "lg_add1"
        (m_add1)
        (list
          (pv (list 5) (lg_add1 5))
          (pv (list 4294967294) (lg_add1 4294967294))))
      (pmod
        "lg_add"
        (m_add)
        (list
          (pv (list 7 9) (lg_add 7 9))
          (pv (list 4294967290 5) (lg_add 4294967290 5))))
      (pmod
        "lg_sub"
        (m_sub)
        (list
          (pv (list 20 5) (lg_sub 20 5))
          (pv (list 4294967295 4294967295) (lg_sub 4294967295 4294967295))))
      (pmod
        "lg_mix"
        (m_mix)
        (list (pv (list 3 10) (lg_mix 3 10)) (pv (list 4 1000) (lg_mix 4 1000))))
      (pmod
        "lg_id"
        (m_id)
        (list
          (pv (list 42) (lg_id 42))
          (pv (list 4294967295) (lg_id 4294967295))))
      (pmod
        "lg_share"
        (m_share)
        (list (pv (list 5) (lg_share 5)) (pv (list 46000) (lg_share 46000))))
      (pmod
        "lg_nest"
        (m_nest)
        (list
          (pv (list 3 10) (lg_nest 3 10))
          (pv (list 100000 200000) (lg_nest 100000 200000))))
      (pmod
        "lg_alias"
        (m_alias)
        (list
          (pv (list 41) (lg_alias 41))
          (pv (list 4294967294) (lg_alias 4294967294))))
      (pmod
        "lg_gate"
        (m_gate)
        (list (pv (list 5) (lg_gate 5)) (pv (list 10) (lg_gate 10))))
      (pmod
        "lg_sel"
        (m_sel)
        (list (pv (list 0 7) (lg_sel 0 7)) (pv (list 3 7) (lg_sel 3 7))))
      (pmod
        "lg_clamp2"
        (m_clamp2)
        (list
          (pv (list 5) (lg_clamp2 5))
          (pv (list 50) (lg_clamp2 50))
          (pv (list 200) (lg_clamp2 200))))
      (pmod
        "lg_selsq"
        (m_selsq)
        (list (pv (list 3 0) (lg_selsq 3 0)) (pv (list 3 4) (lg_selsq 3 4))))
      (pmod
        "lg_dec"
        (m_dec)
        (list
          (pv (list 5) (lg_dec 5))
          (pv (list 0) (lg_dec 0))
          (pv (list 4294967295) (lg_dec 4294967295))))
      (pmod
        "lg_le"
        (m_le)
        (list
          (pv (list 5) (lg_le 5))
          (pv (list 10) (lg_le 10))
          (pv (list 11) (lg_le 11))
          (pv (list 4294967295) (lg_le 4294967295))))
      (pmod
        "lg_divq"
        (m_divq)
        (list
          (pv (list 100 7) (lg_divq 100 7))
          (pv (list 4294967295 2) (lg_divq 4294967295 2))
          (pv (list 5 10) (lg_divq 5 10))))
      (pmod
        "lg_divr"
        (m_divr)
        (list
          (pv (list 100 7) (lg_divr 100 7))
          (pv (list 4294967295 2) (lg_divr 4294967295 2))
          (pv (list 5 10) (lg_divr 5 10))))
      (pmod
        "lg_divw"
        (m_divw)
        (list
          (pv (list 10 30) (lg_divw 10 30))
          (pv (list 0 4294967295) (lg_divw 0 4294967295))
          (pv (list 7 8) (lg_divw 7 8))))
      (pmod
        "lg_divl"
        (m_divl)
        (list
          (pv (list 100) (lg_divl 100))
          (pv (list 4294967295) (lg_divl 4294967295))))
      (pmod
        "lg_diva"
        (m_diva)
        (list
          (pv (list 100 7) (lg_diva 100 7))
          (pv (list 4294967294 1) (lg_diva 4294967294 1))))
      (pmod
        "lg_divs"
        (m_divs)
        (list
          (pv (list 100 7) (lg_divs 100 7))
          (pv (list 4294967295 2) (lg_divs 4294967295 2))))
      (pmod
        "lg_divd"
        (m_divd)
        (list
          (pv (list 100 7) (lg_divd 100 7))
          (pv (list 4294967295 2) (lg_divd 4294967295 2))))
      (pmod
        "lg_divn"
        (m_divn)
        (list
          (pv (list 1000 7 3) (lg_divn 1000 7 3))
          (pv (list 4294967295 1 1) (lg_divn 4294967295 1 1))))
      (pmod
        "lg_band"
        (m_band)
        (list
          (pv (list 4042322160 267452160) (lg_band 4042322160 267452160))
          (pv (list 4294967295 255) (lg_band 4294967295 255))
          (pv (list 0 4294967295) (lg_band 0 4294967295))))
      (pmod
        "lg_bor"
        (m_bor)
        (list
          (pv (list 2863311530 1431655765) (lg_bor 2863311530 1431655765))
          (pv (list 0 0) (lg_bor 0 0))))
      (pmod
        "lg_bxor"
        (m_bxor)
        (list
          (pv (list 4294967295 2863311530) (lg_bxor 4294967295 2863311530))
          (pv (list 1431655765 1431655765) (lg_bxor 1431655765 1431655765))))
      (pmod
        "lg_bmask"
        (m_bmask)
        (list
          (pv (list 4294967295) (lg_bmask 4294967295))
          (pv (list 256) (lg_bmask 256))
          (pv (list 300) (lg_bmask 300))))
      (pmod
        "lg_barith"
        (m_barith)
        (list
          (pv (list 255 15) (lg_barith 255 15))
          (pv (list 4294967295 4294967294) (lg_barith 4294967295 4294967294))))
      (pmod
        "lg_bdiv"
        (m_bdiv)
        (list
          (pv (list 100 6) (lg_bdiv 100 6))
          (pv (list 4294967295 0) (lg_bdiv 4294967295 0))))
      (pmod
        "lg_bif"
        (m_bif)
        (list (pv (list 0 255) (lg_bif 0 255)) (pv (list 5 255) (lg_bif 5 255))))
      (pmod
        "lg_bifp"
        (m_bifp)
        (list
          (pv (list 0 255) (lg_bifp 0 255))
          (pv (list 7 4294967295) (lg_bifp 7 4294967295))))
      (pmod
        "lg_bshare"
        (m_bshare)
        (list (pv (list 255) (lg_bshare 255)) (pv (list 16) (lg_bshare 16)))))))
