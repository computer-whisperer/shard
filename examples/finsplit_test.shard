;;; finsplit_test.shard — regression test for the (fin-split …) tactic: bounded
;;; integer case analysis (finite enumeration). The faithfulness-style goal
;;; below reduces to "an abstract Int in a concrete range is one of its values"
;;; — provable by NO linear theory (farkas reasons over ℚ), but closed by a
;;; single fin-split over the cited bounds, each value discharged by compute.
;;;
;;; Soundness guards (validated separately, each must FAIL): a GAP in the
;;; enumeration, coverage stopping short of the upper bound, proving a FALSEHOOD,
;;; and a malformed bound citation are all rejected by do_fin_split.

(import "../kernel/stdlib.shard")

(fn cellg ((hc Int) (c Int)) Int (if (int_eq hc c) 79 32))
(fn row ((hc Int) (c Int)) (List Int)
  (measure (- 5 c) (by farkas (list 1 0)) (by farkas (list 1 1)))
  (if (lt 4 c) Nil (Cons (cellg hc c) (row hc (+ c 1)))))  ; cols 0..4
(fn render_row ((hc Int)) (List Int) (row hc 0))
(fn has79 ((xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (int_eq h 79) True (has79 t)))))

;; The head 'O'(79) is drawn at an ABSTRACT interior column hc (1<=hc<=3); the
;; detector must find it. fin-split enumerates hc over [1,3] (bounds cited as
;; premises 0 and 1); each concrete value computes straight to True.
(claim faith_finsplit
  (goal ((hc Int)) ((= (le 1 hc) True) (= (le hc 3) True))
    (= (has79 (render_row hc)) True))
  (fin-split
    hc
    (premise 0)
    (premise 1)
    ((case 1 (steps ((compute lhs)) refl))
     (case 2 (steps ((compute lhs)) refl))
     (case 3 (steps ((compute lhs)) refl)))))
