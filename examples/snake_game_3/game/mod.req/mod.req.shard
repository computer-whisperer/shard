;;; game — the PURE-CORE submodule's interface (dir form). TIER 2: this is
;;; implementation-owned SCAFFOLDING under the bin's apex contract
;;; (../../mod.req/ — the reviewed artifact promise). Nothing here may appear
;;; in a (bin … requires) list; these requirements exist to be CITED by the
;;; io layer's proofs of the tier-1 requirements, and may churn as the
;;; implementation discovers what it needs to assert about itself.
;;;
;;; GameState is OPAQUE (`sig type` — v1's friction note acted on): consumers
;;; and requirements reason only through the accessor sigs, so the
;;; representation (including the PRNG state inside it) is invisible and free
;;; to change. The spec vocabulary lives in the req-scope sibling geom.shard.
;;;
;;; The requirement set GROWS PER SLICE — this file states exactly what the
;;; present impl discharges, so every commit's corpus is clean. Slice 1 =
;;; v1's R1–R4 as machine requirements plus init facts; slice 2 = food on
;;; the board; slice 3 = I3 collision soundness; slice 4 = I1 body
;;; distinctness; slice 5 = I2 food on a FREE cell (and the board-full
;;; refinements to food_in_bounds_eat / step_survives_clear).
(import "../../../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../../../std/list")  ; len — the length requirements' vocabulary
(import "geom.shard")  ; req-scope sibling: nouns + movement/board algebra
(use (:: examples snake_game_3 game geom *))
(use (:: std list len))

;; ---- the opaque state + its surface ----------------------------------------

(sig type GameState)

(sig fn init ((seed Int)) GameState)  ; a fresh game from a caller seed
(sig fn step ((g GameState) (i Heading)) GameState)  ; one tick: steer + move

(sig fn snake_of ((g GameState)) (List Pos))  ; body, head first
(sig fn dir_of ((g GameState)) Heading)
(sig fn food_of ((g GameState)) Pos)
(sig fn score_of ((g GameState)) Int)
(sig fn status_of ((g GameState)) Status)

;; ---- init facts -------------------------------------------------------------

(requirement init_alive
  (goal ((seed Int)) () (= (status_of (init seed)) Alive)))

(requirement init_nonempty
  (goal ((seed Int)) () (= (nonempty (snake_of (init seed))) True)))

;; the io layer's run-anchors (slice 12): the input-response chain folds the
;; heading over the key trace from a known start, and seeds the head-bounds
;; invariant at the first state.

(requirement init_dir
  (goal ((seed Int)) () (= (dir_of (init seed)) Right)))

(requirement init_head_in_bounds
  (goal ((seed Int)) ()
    (= (in_bounds (snake_head (snake_of (init seed)))) True)))

;; ---- R1 — DEATH IS ABSORBING (safety) ---------------------------------------
;; Once dead, a tick is a no-op: the whole state is unchanged.

(requirement death_absorbing
  (goal ((g GameState) (i Heading)) ((= (status_of g) Dead)) (= (step g i) g)))

;; ---- R4 — NO 180° REVERSAL (input safety) -----------------------------------
;; A reversing steer is ignored: you cannot turn straight back into your own
;; neck. Unconditional — the dead case is a step-is-identity corollary.

(requirement no_reversal
  (goal ((g GameState) (i Heading)) ((= i (opposite (dir_of g))))
    (= (dir_of (step g i)) (dir_of g))))

;; the full steering equation (slice 12): a live tick's stored heading is
;; exactly `steer` of the input — what the io layer's trace-heading fold
;; aligns against. no_reversal above stays as the reviewed R4 surface (it is
;; the steer-equation's reversal arm).

(requirement dir_follows_steer
  (goal ((g GameState) (i Heading)) ((= (status_of g) Alive))
    (= (dir_of (step g i)) (steer (dir_of g) i))))

;; ---- R3 — HEAD ADVANCES BY THE STEERED HEADING ------------------------------
;; The snake moves exactly one cell in the steered direction. The body field
;; advances on EVERY live tick (death is recorded only in status), so this
;; needs no collision casing.

(requirement head_advances
  (goal ((g GameState) (i Heading)) ((= (status_of g) Alive))
    (=
      (snake_head (snake_of (step g i)))
      (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))))

;; a live tick's snake is never empty (the new head is consed on the front —
;; slice 12: the io chain re-establishes the detectors' nonempty premise
;; along a run).

(requirement step_nonempty
  (goal ((g GameState) (i Heading)) ((= (status_of g) Alive))
    (= (nonempty (snake_of (step g i))) True)))

;; ---- R2 — LENGTH BOOKKEEPING (growth is tied to eating) ---------------------
;; A live tick grows the snake by exactly one cell when the steered head
;; lands on food, by zero otherwise. The nonempty precondition is v1's
;; contract refinement: the move case is false for an empty snake, and every
;; reachable Alive state has one (init_nonempty seeds the invariant).
;; The eating test is spelled FOOD-FIRST — (pos_eq (food_of g) NEWHEAD) —
;; the same argument order as pos_mem's head test, so the food-freeness
;; proofs consume these premises directly (pos_eq is not known symmetric).

(requirement length_eat
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (= (nonempty (snake_of g)) True)
     (=
       (pos_eq
         (food_of g)
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))
       True))
    (= (len (snake_of (step g i))) (+ (len (snake_of g)) 1))))

(requirement length_move
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (= (nonempty (snake_of g)) True)
     (=
       (pos_eq
         (food_of g)
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))
       False))
    (= (len (snake_of (step g i))) (len (snake_of g)))))

;; ---- FOOD PLACEMENT (slice 2, refined by slice 5) ---------------------------
;; Fresh food is always ON THE BOARD. The eat-tick fact is conditioned on the
;; tick SURVIVING (an eating tick may end the run — see I3 below): on a dying
;; tick the food cell is dead-frame furniture and nothing is promised.

(requirement init_food_in_bounds
  (goal ((seed Int)) () (= (in_bounds (food_of (init seed))) True)))

(requirement food_in_bounds_eat
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (=
       (pos_eq
         (food_of g)
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))
       True)
     (= (status_of (step g i)) Alive))
    (= (in_bounds (food_of (step g i))) True)))

;; a non-eating live tick leaves the food where it was.
(requirement food_preserved_move
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (=
       (pos_eq
         (food_of g)
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))
       False))
    (= (food_of (step g i)) (food_of g))))

;; ---- I3 — COLLISION SOUNDNESS (slice 3, weakened by slice 5) ----------------
;; A live tick that collides — steered head out of bounds or on the body —
;; dies, unconditionally. The converse survival promise covers NON-EATING
;; ticks: an eating tick that exhausts the board (no free cell left for the
;; respawn scan) also ends the run, and ruling that out for a roomy board
;; would take a counting argument (pigeonhole) this contract deliberately
;; avoids — the check-anyway-freeze principle. Board-full is end-of-play.

(requirement step_dies_on_collision
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (=
       (collides
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i)))
         (snake_of g))
       True))
    (= (status_of (step g i)) Dead)))

(requirement step_survives_clear
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (=
       (collides
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i)))
         (snake_of g))
       False)
     (=
       (pos_eq
         (food_of g)
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i))))
       False))
    (= (status_of (step g i)) Alive)))

;; a tick the game SURVIVES has its head on the board (slice 12): surviving
;; means the steered head didn't collide, and out-of-bounds is a collision.
;; This is how the io layer keeps the head-detector premises alive along a
;; run without inverting `collides` itself.

(requirement step_alive_in_bounds
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive) (= (status_of (step g i)) Alive))
    (= (in_bounds (snake_head (snake_of (step g i)))) True)))

;; ---- I1 — BODY DISTINCTNESS (slice 4) ----------------------------------------
;; The snake never overlaps itself: distinct at init, and preserved by every
;; live tick whose steered head lands clear — the SAME collides = False
;; premise as step_survives_clear, so a consumer chains I3 + I1 down any
;; surviving run. A colliding tick is the run's last (death_absorbing freezes
;; the state after it), so every state that keeps playing has a distinct body.

(requirement init_distinct
  (goal ((seed Int)) () (= (distinct (snake_of (init seed))) True)))

(requirement step_distinct
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (= (distinct (snake_of g)) True)
     (=
       (collides
         (addpos (snake_head (snake_of g)) (delta (steer (dir_of g) i)))
         (snake_of g))
       False))
    (= (distinct (snake_of (step g i))) True)))

;; ---- I2 — FOOD ON A FREE CELL (slice 5) --------------------------------------
;; The food never sits on the snake: true at init, and preserved by every
;; tick the game SURVIVES (alive-after conditioning, like food_in_bounds_eat:
;; a move tick can't step onto food — that would be an eating tick — and an
;; eating tick that survives found a fresh free cell; a tick that dies makes
;; no food promise, and death freezes the state). Together with I1 this is
;; what makes a frame's food glyph mean something: a live frame's food cell
;; is exactly one cell, on the board, and not under the snake.

(requirement init_food_free
  (goal ((seed Int)) ()
    (= (pos_mem (food_of (init seed)) (snake_of (init seed))) False)))

(requirement step_food_free
  (goal ((g GameState) (i Heading))
    ((= (status_of g) Alive)
     (= (pos_mem (food_of g) (snake_of g)) False)
     (= (status_of (step g i)) Alive))
    (= (pos_mem (food_of (step g i)) (snake_of (step g i))) False)))
