;; P2/P3 over MAIN: one get_args effect (both logs preserved), then the
;; start bridge at init — whose anchors are exactly the slice-12 game
;; requirements — at the opaque fuel; exit preserves both logs.
(fulfills io_input_moves
  (case-on (get_args w) Pair
    ((case Pair
       (args w1)
       (steps
         ((unfold moves_ok lhs)
          (unfold main lhs)
          (unfold main lhs)
          (rewrite (hyp 0) lr lhs true ())
          (reduce lhs)
          (rewrite (lemma exit_output) lr lhs true ())
          (rewrite (lemma exit_input) lr lhs true ()))
         (rewrite-with
           (lemma play_moves_start)
           lr
           lhs
           ()
           ((steps ((rewrite (lemma init_alive) lr lhs true ())) refl)
            (steps ((rewrite (lemma init_nonempty) lr lhs true ())) refl)
            (steps ((rewrite (lemma init_head_in_bounds) lr lhs true ())) refl)
            (steps
              ((rewrite (lemma init_dir) lr lhs true ())
               (unfold dir_vec lhs)
               (reduce lhs))
              refl)
            (rewrite-with
              (lemma args_output)
              lr
              lhs
              ((inst w w) (inst args args))
              ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (steps ((rewrite (premise 0) lr lhs true ())) refl))
            (rewrite-with
              (lemma args_input)
              lr
              lhs
              ((inst w w) (inst args args))
              ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (steps ((rewrite (premise 1) lr lhs true ())) refl)))
           refl))))))
