                                            (steps
                                              ((unfold write_frame lhs)
                                               (rewrite
                                                 (lemma write_input)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              (rewrite-with
                                                (lemma key_input)
                                                lr
                                                lhs
                                                ((inst w w) (inst o o))
                                                ((steps
                                                   ((rewrite
                                                      (hyp 3)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                (steps
                                                  ((rewrite
                                                     (lemma mgo_dir_snoc)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (premise 6)
                                                     lr
                                                     lhs
                                                     true
