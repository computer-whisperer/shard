;;; snake — the EXECUTABLE of snake_game_3: key decoding, the fuel-bounded
;;; play loop, and `main`. This is the io slice's IMPL HALF; the tier-1
;;; contract (../mod.req/) still carries the promise in prose — formal
;;; requirements + the (bin …) form land with the contract slice, and this
;;; file will then discharge them.
;;;
;;; The game and render modules are consumed through their PUBLIC surfaces
;;; (bare module imports): GameState stays opaque; the loop sees init / step
;;; / status_of / dir_of and `render`. At RUN the mode-aware loader swaps in
;;; the impl bodies and the same file plays.
;;;
;;; PLAY IT (REPL-style, line-buffered — a key then Enter):
;;;     ./rust_bootstrap/target/release/eval run examples/snake_game_3/snake.shard [SEED]
;;;   w/a/s/d + Enter steer; any other key + Enter advances in the current
;;;   heading; `q` (or Ctrl-D / EOF) quits. The PRNG seed is argv[0] (decimal;
;;;   default when absent) — a run is a pure function of (args, keys): P6.
;;;
;;; Loop discipline (the eventual contract's shape, v2-proven):
;;;   - one frame per consumed key, written AFTER the step — each frame is
;;;     the response to the key just typed;
;;;   - death ends play: the collision frame is written, then the loop stops
;;;     reading input and main exits 0 (P4);
;;;   - every write is preceded by the ANSI clear (io owns screen control —
;;;     the renderer is pure board→bytes).
(import "../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../std/order")  ; le_trans — the clock-chaining vocabulary
(import "mod.req/bin.shard")  ; OWN interface FIRST (ungranted): the
; tier-1 contract loads as obligations — board dims discharged below
(import "game")  ; the game module interface: init / step / accessors
(import "render")  ; the render module interface: render
(use (:: examples snake_game_3 game *))
(use (:: examples snake_game_3 game geom *))
(use (:: examples snake_game_3 render *))
(use (:: examples snake_game_3 board board_w))
(use (:: examples snake_game_3 board board_h))
(use (:: examples snake_game_3 *))
(use (:: examples snake_game_3 frame *))
(use (:: examples snake_game_3 entity *))
(use (:: examples snake_game_3 moves *))
(use (:: std order *))
(use (:: std list append))
(use (:: std list append_nil_left))
(use (:: std list append_cons))

;; ---- board dims (discharging the tier-1 opaque sigs) -------------------------
;; The artifact's concrete size. The ONLY place licensed to reduce the dims;
;; everything above (game, render, the contract) is size-symbolic.

(fn board_w () Int 16)

(fn board_h () Int 12)

(fulfills board_w_pos (steps ((compute lhs)) refl))

(fulfills board_h_pos (steps ((compute lhs)) refl))

(fulfills board_w_min (steps ((compute lhs)) refl))

(fulfills board_h_min (steps ((compute lhs)) refl))

;; ---- the World observable (discharging the tier-1 sig) -----------------------
;; The World type and externs now live in the contract; the clock observable
;; gets its body here (proofs never unfold it — the bolts are the bridge).

(fn w_clock ((w World)) Int
  (match w
    ((World n) n)))

;; ---- input boundary: the steer decoder --------------------------------------
;;   w 119 → Up    a 97 → Left    s 115 → Down    d 100 → Right
;; Unrecognized keys are inert (return the current heading — the step then
;; advances straight). The no-reversal rule is the game module's business.

(fn key_heading ((k Int) (cur Heading)) Heading
  (if (int_eq k 119) Up
  (if (int_eq k 115) Down
  (if (int_eq k 97) Left
  (if (int_eq k 100) Right
  cur)))))

;; ---- output boundary: one frame per tick -------------------------------------
;; The tier-1 clear (clear_bytes), then the rendered board. Local monomorphic
;; append (the dangling-type-pivot rule: keep proof-facing citations pinned).

(fn io_app ((xs (List Int)) (ys (List Int))) (List Int)
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (io_app t ys)))))

(fn write_frame ((g GameState) (w World)) World
  (write (io_app (clear_bytes) (render g)) w))

;; ---- the play loop ------------------------------------------------------------
;; One tick = read a key (None/EOF or `q` stops), steer + step, write the
;; post-step frame, recurse — unless the step died: the collision frame is
;; still written, then play ENDS (P4). Int fuel bounds the loop for the
;; coming ∀-fuel proofs (WfInduct on the fuel measure); proof-facing body,
;; so it stays let-free (tick names the stepped state instead).

(fn tick ((g GameState) (k Int)) GameState (step g (key_heading k (dir_of g))))

(fn play ((f Int) (g GameState) (w World)) World
  (if (lt 0 f)
    (match (key_oracle w)
      ((Pair None w1) w1)
      ((Pair (Some k) w1)
       (if (int_eq k 113) w1
       (match (status_of (tick g k))
         (Dead (write_frame (tick g k) w1))
         (Alive (play (- f 1) (tick g k) (write_frame (tick g k) w1)))))))
    w))

;; ---- the executable -------------------------------------------------------------
;; The seed is argv[0] parsed as decimal (leading digits; default constant
;; when absent or non-numeric) — no entropy extern, replayable runs (P6).
;; `fuel` is the opaque global step budget: large at RUN, abstract in the
;; coming proofs (cited through the ∀-fuel worker, never reduced).

(fn seed_digits ((bs (List Int)) (acc Int)) Int
  (match bs
    (Nil acc)
    ((Cons b t)
     (if (le 48 b) (if (le b 57) (seed_digits t (+ (* acc 10) (- b 48))) acc)
     acc))))

(fn seed_of ((args (List (List Int)))) Int
  (match args
    (Nil 20260611)
    ((Cons a _) (seed_digits a 0))))

(fn fuel () Int 1000000000)

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1) (exit 0 (play (fuel) (init (seed_of args)) w1)))))

;; ===========================================================================
;; P5 — CLOCK DISCIPLINE.
;; ===========================================================================

;; The private ∀-fuel WORKER: the clock is monotone across the play loop for
;; EVERY Int fuel, by well-founded induction on the fuel measure. Each tick's
;; arms chain the clock bolts (key_clock, write_clock); the Alive arm chains
;; the IH through le_trans at the post-write world.
(claim play_clock_mono
  (goal ((f Int) (g GameState) (w World)) ()
    (= (le (w_clock w) (w_clock (play f g w))) True))
  (wf-induct f
    (case-on (lt 0 f) Bool
      ((case True
         (have (= (lt 0 f) True) (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (case-on (key_oracle w) Pair
             ((case Pair
                (o w1)
                (have (= (w_clock w1) (+ (w_clock w) 1))
                  (rewrite-with
                    (lemma key_clock)
                    lr
                    lhs
                    ((inst w w) (inst o o))
                    ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
                    refl)
                  (case-on o Option
                    ((case None
                       (steps
                         ((unfold play lhs)
                          (rewrite (premise 0) lr lhs true ())
                          (reduce lhs)
                          (rewrite (hyp 1) lr lhs true ())
                          (rewrite (hyp 0) lr lhs true ())
                          (reduce lhs)
                          (rewrite (premise 1) lr lhs true ()))
                         (by farkas (list 1 0 0))))
                     (case Some
                       (k)
                       (case-on (int_eq k 113) Bool
                         ((case True
                            (steps
                              ((unfold play lhs)
                               (rewrite (premise 0) lr lhs true ())
                               (reduce lhs)
                               (rewrite (hyp 2) lr lhs true ())
                               (rewrite (hyp 1) lr lhs true ())
                               (reduce lhs)
                               (rewrite (hyp 0) lr lhs true ())
                               (reduce lhs)
                               (rewrite (premise 1) lr lhs true ()))
                              (by farkas (list 1 0 0))))
                          (case False
                            (case-on (status_of (tick g k)) Status
                              ((case Dead
                                 (steps
                                   ((unfold play lhs)
                                    (rewrite (premise 0) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 3) lr lhs true ())
                                    (rewrite (hyp 2) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 1) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs)
                                    (unfold write_frame lhs)
                                    (rewrite (lemma write_clock) lr lhs true ())
                                    (rewrite (premise 1) lr lhs true ()))
                                   (by farkas (list 1 0 0))))
                               (case Alive
                                 (steps
                                   ((unfold play lhs)
                                    (rewrite (premise 0) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 3) lr lhs true ())
                                    (rewrite (hyp 2) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 1) lr lhs true ())
                                    (reduce lhs)
                                    (rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs))
                                   (rewrite-with
                                     (lemma le_trans)
                                     lr
                                     lhs
                                     ((inst
                                        b
                                        (w_clock (write_frame (tick g k) w1))))
                                     ((steps
                                        ((unfold write_frame lhs)
                                         (rewrite
                                           (lemma write_clock)
                                           lr
                                           lhs
                                           true
                                           ())
                                         (rewrite (premise 1) lr lhs true ()))
                                        (by farkas (list 1 0 0)))
                                      (rewrite-with
                                        (hyp 5)
                                        lr
                                        lhs
                                        ()
                                        ((by farkas (list 1 1 0))
                                         (by farkas (list 1 0 0)))
                                        refl))
                                     refl)))))))))))))))))
       (case False
         (have (= (lt 0 f) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps
             ((unfold play lhs)
              (rewrite (premise 0) lr lhs true ())
              (reduce lhs))
             (by ord (list)))))))))

;; P5 over MAIN: one get_args effect (args_clock), then the worker at the
;; opaque fuel, then exit (clock-preserving fiction) — chained by le_trans.
(fulfills main_clock_mono
  (case-on (get_args w) Pair
    ((case Pair
       (args w1)
       (have (= (w_clock w1) (+ (w_clock w) 1))
         (rewrite-with
           (lemma args_clock)
           lr
           lhs
           ((inst w w) (inst args args))
           ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
           refl)
         (steps
           ((unfold main lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (rewrite (lemma exit_clock) lr lhs true ()))
           (rewrite-with
             (lemma le_trans)
             lr
             lhs
             ((inst b (w_clock w1)))
             ((steps
                ((rewrite (premise 0) lr lhs true ()))
                (by farkas (list 1 0)))
              (steps ((rewrite (lemma play_clock_mono) lr lhs true ())) refl))
             refl)))))))

;; ===========================================================================
;; P1 — COMPLETE FRAMES.
;; ===========================================================================

;; every emitted byte string is one screen update: the clear computes off
;; the front, and the rest is a frame by the render module's granted
;; render_is_frame — unconditional in the state, so the preservation worker
;; needs no per-state invariant.
(claim screen_ok
  (goal ((g GameState)) ()
    (= (is_screen (io_app (clear_bytes) (render g))) True))
  (have
    (=
      (io_app (clear_bytes) (render g))
      (Cons
        27
        (Cons 91 (Cons 50 (Cons 74 (Cons 27 (Cons 91 (Cons 72 (render g)))))))))
    (steps ((compute lhs)) refl)
    (have
      (=
        (after_prefix
          (clear_bytes)
          (Cons
            27
            (Cons
              91
              (Cons 50 (Cons 74 (Cons 27 (Cons 91 (Cons 72 (render g)))))))))
        (Some (render g)))
      (steps ((compute lhs)) refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (unfold is_screen lhs)
         (rewrite (premise 1) lr lhs true ())
         (reduce lhs)
         (rewrite (lemma render_is_frame) lr lhs true ()))
        refl))))

;; fold the screen predicate over a one-element append (v2's all_arena_snoc).
(claim all_screens_snoc
  (goal ((xs (List (List Int))) (y (List Int))) ()
    (=
      (all_screens (append xs (Cons y Nil)))
      (if (all_screens xs) (is_screen y) False)))
  (induct xs
    ((case Nil
       (steps
         ((rewrite (lemma append_nil_left) lr lhs true ()) (simp both))
         (case-on (is_screen y) Bool
           ((case True
              (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))
            (case False
              (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))))))
     (case Cons
       (h t)
       (steps
         ((rewrite (lemma append_cons) lr lhs true ())
          (simp lhs)
          (rewrite (hyp 0) lr lhs true ())
          (simp rhs))
         (case-on (is_screen h) Bool
           ((case True
              (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl))
            (case False
              (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl)))))))))

;; WfInduct's termination obligation, as a lemma (farkas reads premises).
(claim step_nonneg
  (goal ((x Int)) ((= (lt 0 x) True)) (= (le 0 (- x 1)) True))
  (by farkas (list 1 1)))

;; the ∀-fuel worker: the all-screens invariant rides the loop — every arm
;; either preserves the log (key_output) or appends one screen_ok frame
;; (write_output + the snoc fold).
(claim play_screens_preserve
  (goal ((f Int) (g GameState) (w World)) ((= (all_screens (w_output w)) True))
    (= (all_screens (w_output (play f g w))) True))
  (wf-induct f
    (case-on (lt 0 f) Bool
      ((case False
         (steps
           ((unfold play lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (rewrite (premise 0) lr lhs true ()))
           refl))
       (case True
         (steps
           ((unfold play lhs) (rewrite (hyp 0) lr lhs true ()) (reduce lhs))
           (case-on (key_oracle w) Pair
             ((case Pair
                (o w1)
                (steps
                  ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                  (case-on o Option
                    ((case None
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (rewrite-with
                           (lemma key_output)
                           lr
                           lhs
                           ((inst w w) (inst o o))
                           ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                           (steps ((rewrite (premise 0) lr lhs true ())) refl))))
                     (case Some
                       (k)
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (case-on (int_eq k 113) Bool
                           ((case True
                              (steps
                                ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                                (rewrite-with
                                  (lemma key_output)
                                  lr
                                  lhs
                                  ((inst w w) (inst o o))
                                  ((steps
                                     ((rewrite (hyp 2) lr lhs true ()))
                                     refl))
                                  (steps
                                    ((rewrite (premise 0) lr lhs true ()))
                                    refl))))
                            (case False
                              (steps
                                ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                                (case-on (status_of (tick g k)) Status
                                  ((case Dead
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs)
                                        (unfold write_frame lhs)
                                        (rewrite
                                          (lemma write_output)
                                          lr
                                          lhs
                                          true
                                          ())
                                        (rewrite
                                          (lemma all_screens_snoc)
                                          lr
                                          lhs
                                          true
                                          ()))
                                       (rewrite-with
                                         (lemma key_output)
                                         lr
                                         lhs
                                         ((inst w w) (inst o o))
                                         ((steps
                                            ((rewrite (hyp 3) lr lhs true ()))
                                            refl))
                                         (steps
                                           ((rewrite (premise 0) lr lhs true ())
                                            (rewrite
                                              (lemma screen_ok)
                                              lr
                                              lhs
                                              true
                                              ())
                                            (reduce lhs))
                                           refl))))
                                   (case Alive
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       (rewrite-with
                                         (hyp 5)
                                         lr
                                         lhs
                                         ()
                                         ((steps
                                            ((unfold write_frame lhs)
                                             (rewrite
                                               (lemma write_output)
                                               lr
                                               lhs
                                               true
                                               ())
                                             (rewrite
                                               (lemma all_screens_snoc)
                                               lr
                                               lhs
                                               true
                                               ()))
                                            (rewrite-with
                                              (lemma key_output)
                                              lr
                                              lhs
                                              ((inst w w) (inst o o))
                                              ((steps
                                                 ((rewrite
                                                    (hyp 3)
                                                    lr
                                                    lhs
                                                    true
                                                    ()))
                                                 refl))
                                              (steps
                                                ((rewrite
                                                   (premise 0)
                                                   lr
                                                   lhs
                                                   true
                                                   ())
                                                 (rewrite
                                                   (lemma screen_ok)
                                                   lr
                                                   lhs
                                                   true
                                                   ())
                                                 (reduce lhs))
                                                refl)))
                                          (rewrite-with
                                            (lemma step_nonneg)
                                            lr
                                            lhs
                                            ((inst x f))
                                            ((steps
                                               ((rewrite (hyp 4) lr lhs true ()))
                                               refl))
                                            refl)
                                          (by ord (list)))
                                         refl)))))))))))))))))))))))

;; P1 over MAIN: one get_args effect (args_output preserves the log), the
;; worker at the opaque fuel, exit preserves.
(fulfills frames_are_screens
  (case-on (get_args w) Pair
    ((case Pair
       (args w1)
       (steps
         ((unfold main lhs)
          (rewrite (hyp 0) lr lhs true ())
          (reduce lhs)
          (rewrite (lemma exit_output) lr lhs true ()))
         (rewrite-with
           (lemma play_screens_preserve)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma args_output)
              lr
              lhs
              ((inst w w) (inst args args))
              ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
              (steps ((rewrite (premise 0) lr lhs true ())) refl)))
           refl))))))

;; ===========================================================================
;; P2/P3 — INPUT RESPONSE.
;; ===========================================================================

;; the geom heading as the contract's vector vocabulary (the io bridge —
;; tier-1 cannot name geom's Heading, so the impl translates).
(fn dir_vec ((d Heading)) (Pair Int Int)
  (match d
    (Up (Pair 0 (- 0 1)))
    (Down (Pair 0 1))
    (Left (Pair (- 0 1) 0))
    (Right (Pair 1 0))))

;; the bounds gate inverts to the game-coordinate bounds: a gated-on screen
;; cell (+ y 1, + x 1) is an in-bounds game cell (x, y). The if-form gate
;; splits leaf-by-leaf (any False leaf contradicts the premise), then the
;; four atoms transport by one farkas each.
(claim co_in_bounds
  (goal ((x Int) (y Int)) ((= (cell_on (+ y 1) (+ x 1)) True))
    (= (in_bounds (Pos x y)) True))
  (case-on (le 1 (+ y 1)) Bool
    ((case False
       (have (= True False)
         (steps
           ((rewrite (premise 0) rl lhs true ())
            (unfold cell_on lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs))
           refl)
         (absurd (premise 1))))
     (case True
       (case-on (le (+ y 1) (board_h)) Bool
         ((case False
            (have (= True False)
              (steps
                ((rewrite (premise 0) rl lhs true ())
                 (unfold cell_on lhs)
                 (rewrite (hyp 1) lr lhs true ())
                 (reduce lhs)
                 (rewrite (hyp 0) lr lhs true ())
                 (reduce lhs))
                refl)
              (absurd (premise 1))))
          (case True
            (case-on (le 1 (+ x 1)) Bool
              ((case False
                 (have (= True False)
                   (steps
                     ((rewrite (premise 0) rl lhs true ())
                      (unfold cell_on lhs)
                      (rewrite (hyp 2) lr lhs true ())
                      (reduce lhs)
                      (rewrite (hyp 1) lr lhs true ())
                      (reduce lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (reduce lhs))
                     refl)
                   (absurd (premise 1))))
               (case True
                 (case-on (le (+ x 1) (board_w)) Bool
                   ((case False
                      (have (= True False)
                        (steps
                          ((rewrite (premise 0) rl lhs true ())
                           (unfold cell_on lhs)
                           (rewrite (hyp 3) lr lhs true ())
                           (reduce lhs)
                           (rewrite (hyp 2) lr lhs true ())
                           (reduce lhs)
                           (rewrite (hyp 1) lr lhs true ())
                           (reduce lhs)
                           (rewrite (hyp 0) lr lhs true ())
                           (reduce lhs))
                          refl)
                        (absurd (premise 1))))
                    (case True
                      (have (= (le 1 (+ y 1)) True)
                        (steps ((rewrite (hyp 3) lr lhs true ())) refl)
                        (have (= (le (+ y 1) (board_h)) True)
                          (steps ((rewrite (hyp 2) lr lhs true ())) refl)
                          (have (= (le 1 (+ x 1)) True)
                            (steps ((rewrite (hyp 1) lr lhs true ())) refl)
                            (have (= (le (+ x 1) (board_w)) True)
                              (steps ((rewrite (hyp 0) lr lhs true ())) refl)
                              (have (= (le 0 x) True)
                                (by farkas (list 1 0 0 0 1 0))
                                (have (= (lt x (board_w)) True)
                                  (by farkas (list 1 0 0 0 0 1 0))
                                  (have (= (le 0 y) True)
                                    (by farkas (list 1 0 1 0 0 0 0 0))
                                    (have (= (lt y (board_h)) True)
                                      (by farkas (list 1 0 0 1 0 0 0 0 0))
                                      (steps
                                        ((unfold in_bounds lhs)
                                         (reduce lhs)
                                         (rewrite (premise 5) lr lhs true ())
                                         (rewrite (premise 6) lr lhs true ())
                                         (rewrite (premise 7) lr lhs true ())
                                         (rewrite (premise 8) lr lhs true ())
                                         (compute lhs))
                                        refl))))))))))))))))))))))

;; the decode bridge: the contract's trace-heading fold step agrees with the
;; binary's decoder + the game's steer, heading by heading. Five key arms
;; (the decoder's test order), four ground heading leaves each.
(claim steer_bridge
  (goal ((d Heading) (k Int)) ()
    (= (steer_vec (dir_vec d) (Some k)) (dir_vec (steer d (key_heading k d)))))
  (case-on (int_eq k 119) Bool
    ((case True
       (steps
         ((unfold steer_vec lhs)
          (reduce lhs)
          (unfold steer_key lhs)
          (unfold key_heading rhs)
          (rewrite (hyp 0) lr both true ())
          (reduce both))
         (case-on d Heading
           ((case Up
              (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))
            (case Down
              (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))
            (case Left
              (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))
            (case Right
              (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl))))))
     (case False
       (case-on (int_eq k 115) Bool
         ((case True
            (steps
              ((unfold steer_vec lhs)
               (reduce lhs)
               (unfold steer_key lhs)
               (unfold key_heading rhs)
               (rewrite (hyp 1) lr both true ())
               (reduce both)
               (rewrite (hyp 0) lr both true ())
               (reduce both))
              (case-on d Heading
                ((case Up
                   (steps
                     ((rewrite (hyp 0) lr both true ()) (compute both))
                     refl))
                 (case Down
                   (steps
                     ((rewrite (hyp 0) lr both true ()) (compute both))
                     refl))
                 (case Left
                   (steps
                     ((rewrite (hyp 0) lr both true ()) (compute both))
                     refl))
                 (case Right
                   (steps
                     ((rewrite (hyp 0) lr both true ()) (compute both))
                     refl))))))
          (case False
            (case-on (int_eq k 97) Bool
              ((case True
                 (steps
                   ((unfold steer_vec lhs)
                    (reduce lhs)
                    (unfold steer_key lhs)
                    (unfold key_heading rhs)
                    (rewrite (hyp 2) lr both true ())
                    (reduce both)
                    (rewrite (hyp 1) lr both true ())
                    (reduce both)
                    (rewrite (hyp 0) lr both true ())
                    (reduce both))
                   (case-on d Heading
                     ((case Up
                        (steps
                          ((rewrite (hyp 0) lr both true ()) (compute both))
                          refl))
                      (case Down
                        (steps
                          ((rewrite (hyp 0) lr both true ()) (compute both))
                          refl))
                      (case Left
                        (steps
                          ((rewrite (hyp 0) lr both true ()) (compute both))
                          refl))
                      (case Right
                        (steps
                          ((rewrite (hyp 0) lr both true ()) (compute both))
                          refl))))))
               (case False
                 (case-on (int_eq k 100) Bool
                   ((case True
                      (steps
                        ((unfold steer_vec lhs)
                         (reduce lhs)
                         (unfold steer_key lhs)
                         (unfold key_heading rhs)
                         (rewrite (hyp 3) lr both true ())
                         (reduce both)
                         (rewrite (hyp 2) lr both true ())
                         (reduce both)
                         (rewrite (hyp 1) lr both true ())
                         (reduce both)
                         (rewrite (hyp 0) lr both true ())
                         (reduce both))
                        (case-on d Heading
                          ((case Up
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Down
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Left
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Right
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))))))
                    (case False
                      (steps
                        ((unfold steer_vec lhs)
                         (reduce lhs)
                         (unfold steer_key lhs)
                         (unfold key_heading rhs)
                         (rewrite (hyp 3) lr both true ())
                         (reduce both)
                         (rewrite (hyp 2) lr both true ())
                         (reduce both)
                         (rewrite (hyp 1) lr both true ())
                         (reduce both)
                         (rewrite (hyp 0) lr both true ())
                         (reduce both))
                        (case-on d Heading
                          ((case Up
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Down
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Left
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))
                           (case Right
                             (steps
                               ((rewrite (hyp 0) lr both true ())
                                (compute both))
                               refl))))))))))))))))))

;; a logged update's payload is its rendered frame (the clear computes off
;; the front — the screen_ok walk, as an equation).
(claim payload_update
  (goal ((g GameState)) ()
    (= (payload (io_app (clear_bytes) (render g))) (render g)))
  (steps ((compute lhs)) refl))

;; THE PER-TICK FACT: across one tick of a live, head-on-board state, the
;; written update responds to the key exactly as the contract's fold says —
;; head_shown pins both frames' detectors, head_advances + steer_bridge
;; align the geometry, and the bounds gate (off-board response = the
;; wall-death frame) discharges via co_in_bounds when on.
(claim move_shown
  (goal ((g GameState) (k Int))
    ((= (status_of g) Alive)
     (= (nonempty (snake_of g)) True)
     (= (in_bounds (snake_head (snake_of g))) True))
    (=
      (shows_move
        (Some (io_app (clear_bytes) (render g)))
        (io_app (clear_bytes) (render (step g (key_heading k (dir_of g)))))
        (dir_vec (steer (dir_of g) (key_heading k (dir_of g)))))
      True))
  (case-on (snake_head (snake_of g)) Pos
    ((case Pos
       (hx hy)
       (have (= (head_at (render g)) (Some (Pair (+ hy 1) (+ hx 1))))
         (rewrite-with
           (lemma head_shown)
           lr
           lhs
           ((inst x hx) (inst y hy))
           ((steps ((rewrite (hyp 0) lr lhs true ())) refl)
            (steps
              ((rewrite (hyp 0) rl lhs true ())
               (rewrite (premise 2) lr lhs true ()))
              refl))
           refl)
         (have (= (payload (io_app (clear_bytes) (render g))) (render g))
           (steps ((rewrite (lemma payload_update) lr lhs true ())) refl)
           (have
             (=
               (payload
                 (io_app
                   (clear_bytes)
                   (render (step g (key_heading k (dir_of g))))))
               (render (step g (key_heading k (dir_of g)))))
             (steps ((rewrite (lemma payload_update) lr lhs true ())) refl)
             (case-on (steer (dir_of g) (key_heading k (dir_of g))) Heading
               ((case Up
                  (have (= (+ hx 0) hx) (by lia (list))
                    (have (= (+ hy (- 0 1)) (- hy 1)) (by lia (list))
                      (have
                        (=
                          (snake_head
                            (snake_of (step g (key_heading k (dir_of g)))))
                          (Pos hx (- hy 1)))
                        (rewrite-with
                          (lemma head_advances)
                          lr
                          lhs
                          ()
                          ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                          (steps
                            ((rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (unfold delta lhs)
                             (reduce lhs)
                             (unfold addpos lhs)
                             (reduce lhs)
                             (rewrite (premise 6) lr lhs true ())
                             (rewrite (premise 7) lr lhs true ()))
                            refl))
                        (have (= (+ (+ hy 1) (- 0 1)) (+ (- hy 1) 1))
                          (by lia (list))
                          (have (= (+ (+ hx 1) 0) (+ hx 1)) (by lia (list))
                            (have (= (dir_vec Up) (Pair 0 (- 0 1)))
                              (steps ((unfold dir_vec lhs) (reduce lhs)) refl)
                              (steps
                                ((unfold shows_move lhs)
                                 (reduce lhs)
                                 (rewrite (premise 4) lr lhs true ())
                                 (rewrite (premise 3) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise 5) lr lhs true ())
                                 (rewrite (hyp 0) lr lhs true ())
                                 (rewrite (premise 11) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise 9) lr lhs true ())
                                 (rewrite (premise 10) lr lhs true ()))
                                (case-on (cell_on (+ (- hy 1) 1) (+ hx 1)) Bool
                                  ((case True
                                     (have
                                       (= (in_bounds (Pos hx (- hy 1))) True)
                                       (rewrite-with
                                         (lemma co_in_bounds)
                                         lr
                                         lhs
                                         ()
                                         ((steps
                                            ((rewrite (hyp 0) lr lhs true ()))
                                            refl))
                                         refl)
                                       (have
                                         (=
                                           (head_at
                                             (render
                                               (step
                                                 g
                                                 (key_heading k (dir_of g)))))
                                           (Some (Pair (+ (- hy 1) 1) (+ hx 1))))
                                         (rewrite-with
                                           (lemma head_shown)
                                           lr
                                           lhs
                                           ((inst x hx) (inst y (- hy 1)))
                                           ((steps
                                              ((rewrite
                                                 (premise 8)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              refl)
                                            (steps
                                              ((rewrite
                                                 (premise 12)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              refl))
                                           refl)
                                         (have
                                           (=
                                             (int_eq
                                               (+ (- hy 1) 1)
                                               (+ (- hy 1) 1))
                                             True)
                                           (by eqdec (list))
                                           (have
                                             (= (int_eq (+ hx 1) (+ hx 1)) True)
                                             (by eqdec (list))
                                             (steps
                                               ((rewrite (hyp 0) lr lhs true ())
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 13)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (reduce lhs)
                                                (unfold vec_eq lhs)
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 14)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 15)
                                                  lr
                                                  lhs
                                                  true
                                                  ()))
                                               refl))))))
                                   (case False
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       refl))))))))))))
                (case Down
                  (have (= (+ hx 0) hx) (by lia (list))
                    (have
                      (=
                        (snake_head
                          (snake_of (step g (key_heading k (dir_of g)))))
                        (Pos hx (+ hy 1)))
                      (rewrite-with
                        (lemma head_advances)
                        lr
                        lhs
                        ()
                        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                        (steps
                          ((rewrite (hyp 1) lr lhs true ())
                           (rewrite (hyp 0) lr lhs true ())
                           (unfold delta lhs)
                           (reduce lhs)
                           (unfold addpos lhs)
                           (reduce lhs)
                           (rewrite (premise 6) lr lhs true ()))
                          refl))
                      (have (= (+ (+ hx 1) 0) (+ hx 1)) (by lia (list))
                        (have (= (dir_vec Down) (Pair 0 1))
                          (steps ((unfold dir_vec lhs) (reduce lhs)) refl)
                          (steps
                            ((unfold shows_move lhs)
                             (reduce lhs)
                             (rewrite (premise 4) lr lhs true ())
                             (rewrite (premise 3) lr lhs true ())
                             (reduce lhs)
                             (rewrite (premise 5) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (rewrite (premise 9) lr lhs true ())
                             (reduce lhs)
                             (rewrite (premise 8) lr lhs true ()))
                            (case-on (cell_on (+ (+ hy 1) 1) (+ hx 1)) Bool
                              ((case True
                                 (have (= (in_bounds (Pos hx (+ hy 1))) True)
                                   (rewrite-with
                                     (lemma co_in_bounds)
                                     lr
                                     lhs
                                     ()
                                     ((steps
                                        ((rewrite (hyp 0) lr lhs true ()))
                                        refl))
                                     refl)
                                   (have
                                     (=
                                       (head_at
                                         (render
                                           (step g (key_heading k (dir_of g)))))
                                       (Some (Pair (+ (+ hy 1) 1) (+ hx 1))))
                                     (rewrite-with
                                       (lemma head_shown)
                                       lr
                                       lhs
                                       ((inst x hx) (inst y (+ hy 1)))
                                       ((steps
                                          ((rewrite (premise 7) lr lhs true ()))
                                          refl)
                                        (steps
                                          ((rewrite (premise 10) lr lhs true ()))
                                          refl))
                                       refl)
                                     (have
                                       (=
                                         (int_eq (+ (+ hy 1) 1) (+ (+ hy 1) 1))
                                         True)
                                       (by eqdec (list))
                                       (have (= (int_eq (+ hx 1) (+ hx 1)) True)
                                         (by eqdec (list))
                                         (steps
                                           ((rewrite (hyp 0) lr lhs true ())
                                            (reduce lhs)
                                            (rewrite
                                              (premise 11)
                                              lr
                                              lhs
                                              true
                                              ())
                                            (reduce lhs)
                                            (unfold vec_eq lhs)
                                            (reduce lhs)
                                            (rewrite
                                              (premise 12)
                                              lr
                                              lhs
                                              true
                                              ())
                                            (reduce lhs)
                                            (rewrite
                                              (premise 13)
                                              lr
                                              lhs
                                              true
                                              ()))
                                           refl))))))
                               (case False
                                 (steps
                                   ((rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs))
                                   refl))))))))))
                (case Left
                  (have (= (+ hx (- 0 1)) (- hx 1)) (by lia (list))
                    (have (= (+ hy 0) hy) (by lia (list))
                      (have
                        (=
                          (snake_head
                            (snake_of (step g (key_heading k (dir_of g)))))
                          (Pos (- hx 1) hy))
                        (rewrite-with
                          (lemma head_advances)
                          lr
                          lhs
                          ()
                          ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                          (steps
                            ((rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (unfold delta lhs)
                             (reduce lhs)
                             (unfold addpos lhs)
                             (reduce lhs)
                             (rewrite (premise 6) lr lhs true ())
                             (rewrite (premise 7) lr lhs true ()))
                            refl))
                        (have (= (+ (+ hy 1) 0) (+ hy 1)) (by lia (list))
                          (have (= (+ (+ hx 1) (- 0 1)) (+ (- hx 1) 1))
                            (by lia (list))
                            (have (= (dir_vec Left) (Pair (- 0 1) 0))
                              (steps ((unfold dir_vec lhs) (reduce lhs)) refl)
                              (steps
                                ((unfold shows_move lhs)
                                 (reduce lhs)
                                 (rewrite (premise 4) lr lhs true ())
                                 (rewrite (premise 3) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise 5) lr lhs true ())
                                 (rewrite (hyp 0) lr lhs true ())
                                 (rewrite (premise 11) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise 9) lr lhs true ())
                                 (rewrite (premise 10) lr lhs true ()))
                                (case-on (cell_on (+ hy 1) (+ (- hx 1) 1)) Bool
                                  ((case True
                                     (have
                                       (= (in_bounds (Pos (- hx 1) hy)) True)
                                       (rewrite-with
                                         (lemma co_in_bounds)
                                         lr
                                         lhs
                                         ()
                                         ((steps
                                            ((rewrite (hyp 0) lr lhs true ()))
                                            refl))
                                         refl)
                                       (have
                                         (=
                                           (head_at
                                             (render
                                               (step
                                                 g
                                                 (key_heading k (dir_of g)))))
                                           (Some (Pair (+ hy 1) (+ (- hx 1) 1))))
                                         (rewrite-with
                                           (lemma head_shown)
                                           lr
                                           lhs
                                           ((inst x (- hx 1)) (inst y hy))
                                           ((steps
                                              ((rewrite
                                                 (premise 8)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              refl)
                                            (steps
                                              ((rewrite
                                                 (premise 12)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              refl))
                                           refl)
                                         (have
                                           (= (int_eq (+ hy 1) (+ hy 1)) True)
                                           (by eqdec (list))
                                           (have
                                             (=
                                               (int_eq
                                                 (+ (- hx 1) 1)
                                                 (+ (- hx 1) 1))
                                               True)
                                             (by eqdec (list))
                                             (steps
                                               ((rewrite (hyp 0) lr lhs true ())
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 13)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (reduce lhs)
                                                (unfold vec_eq lhs)
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 14)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 15)
                                                  lr
                                                  lhs
                                                  true
                                                  ()))
                                               refl))))))
                                   (case False
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       refl))))))))))))
                (case Right
                  (have (= (+ hy 0) hy) (by lia (list))
                    (have
                      (=
                        (snake_head
                          (snake_of (step g (key_heading k (dir_of g)))))
                        (Pos (+ hx 1) hy))
                      (rewrite-with
                        (lemma head_advances)
                        lr
                        lhs
                        ()
                        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                        (steps
                          ((rewrite (hyp 1) lr lhs true ())
                           (rewrite (hyp 0) lr lhs true ())
                           (unfold delta lhs)
                           (reduce lhs)
                           (unfold addpos lhs)
                           (reduce lhs)
                           (rewrite (premise 6) lr lhs true ()))
                          refl))
                      (have (= (+ (+ hy 1) 0) (+ hy 1)) (by lia (list))
                        (have (= (dir_vec Right) (Pair 1 0))
                          (steps ((unfold dir_vec lhs) (reduce lhs)) refl)
                          (steps
                            ((unfold shows_move lhs)
                             (reduce lhs)
                             (rewrite (premise 4) lr lhs true ())
                             (rewrite (premise 3) lr lhs true ())
                             (reduce lhs)
                             (rewrite (premise 5) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (rewrite (premise 9) lr lhs true ())
                             (reduce lhs)
                             (rewrite (premise 8) lr lhs true ()))
                            (case-on (cell_on (+ hy 1) (+ (+ hx 1) 1)) Bool
                              ((case True
                                 (have (= (in_bounds (Pos (+ hx 1) hy)) True)
                                   (rewrite-with
                                     (lemma co_in_bounds)
                                     lr
                                     lhs
                                     ()
                                     ((steps
                                        ((rewrite (hyp 0) lr lhs true ()))
                                        refl))
                                     refl)
                                   (have
                                     (=
                                       (head_at
                                         (render
                                           (step g (key_heading k (dir_of g)))))
                                       (Some (Pair (+ hy 1) (+ (+ hx 1) 1))))
                                     (rewrite-with
                                       (lemma head_shown)
                                       lr
                                       lhs
                                       ((inst x (+ hx 1)) (inst y hy))
                                       ((steps
                                          ((rewrite (premise 7) lr lhs true ()))
                                          refl)
                                        (steps
                                          ((rewrite (premise 10) lr lhs true ()))
                                          refl))
                                       refl)
                                     (have (= (int_eq (+ hy 1) (+ hy 1)) True)
                                       (by eqdec (list))
                                       (have
                                         (=
                                           (int_eq
                                             (+ (+ hx 1) 1)
                                             (+ (+ hx 1) 1))
                                           True)
                                         (by eqdec (list))
                                         (steps
                                           ((rewrite (hyp 0) lr lhs true ())
                                            (reduce lhs)
                                            (rewrite
                                              (premise 11)
                                              lr
                                              lhs
                                              true
                                              ())
                                            (reduce lhs)
                                            (unfold vec_eq lhs)
                                            (reduce lhs)
                                            (rewrite
                                              (premise 12)
                                              lr
                                              lhs
                                              true
                                              ())
                                            (reduce lhs)
                                            (rewrite
                                              (premise 13)
                                              lr
                                              lhs
                                              true
                                              ()))
                                           refl))))))
                               (case False
                                 (steps
                                   ((rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs))
                                   refl)))))))))))))))))))

;; ---- private input-response helpers (proof scaffolding, not contract vocab) --

;; positional lockstep: one consumed key per written frame.
(fn same_shape ((outs (List (List Int))) (ins (List (Option Int)))) Bool
  (match outs
    (Nil
      (match ins
        (Nil True)
        ((Cons i it) False)))
    ((Cons o ot)
     (match ins
       (Nil False)
       ((Cons i it) (same_shape ot it))))))

;; the moves_go prev-carry after walking outs from prev p: the LAST frame.
(fn mgo_last ((p (Option (List Int))) (outs (List (List Int))))
  (Option (List Int))
  (match outs
    (Nil p)
    ((Cons f rest) (mgo_last (Some f) rest))))

;; the moves_go heading-carry after folding ins from heading h.
(fn mgo_dir ((h (Pair Int Int)) (ins (List (Option Int)))) (Pair Int Int)
  (match ins
    (Nil h)
    ((Cons mk rest) (mgo_dir (steer_vec h mk) rest))))

;; ---- snoc lemmas: one appended (frame, key) pair ------------------------------

(claim same_shape_snoc
  (goal
    ((outs (List (List Int)))
     (ins (List (Option Int)))
     (y (List Int))
     (mk (Option Int)))
    ((= (same_shape outs ins) True))
    (= (same_shape (append outs (Cons y Nil)) (append ins (Cons mk Nil))) True))
  (induct outs
    ((case Nil
       (induct ins
         ((case Nil
            (rewrite-with
              (lemma append_nil_left)
              lr
              lhs
              ((inst ys (Cons y Nil)))
              ()
              (rewrite-with
                (lemma append_nil_left)
                lr
                lhs
                ((inst ys (Cons mk Nil)))
                ()
                (steps
                  ((unfold same_shape lhs)
                   (reduce lhs)
                   (unfold same_shape lhs)
                   (reduce lhs))
                  refl))))
          (case Cons (i it) (absurd (premise 0))))))
     (case Cons
       (f frest)
       (induct ins
         ((case Nil (absurd (premise 0)))
          (case Cons
            (i it)
            (rewrite-with
              (lemma append_cons)
              lr
              lhs
              ((inst h f) (inst t frest) (inst ys (Cons y Nil)))
              ()
              (rewrite-with
                (lemma append_cons)
                lr
                lhs
                ((inst h i) (inst t it) (inst ys (Cons mk Nil)))
                ()
                (steps
                  ((unfold same_shape lhs) (reduce lhs))
                  (rewrite-with
                    (hyp 0)
                    lr
                    lhs
                    ()
                    ((steps
                       ((rewrite (premise 0) rl rhs true ())
                        (unfold same_shape rhs)
                        (reduce rhs))
                       refl))
                    refl)))))))))))

(claim mgo_last_snoc
  (goal ((outs (List (List Int))) (p (Option (List Int))) (y (List Int))) ()
    (= (mgo_last p (append outs (Cons y Nil))) (Some y)))
  (induct outs
    ((case Nil
       (rewrite-with
         (lemma append_nil_left)
         lr
         lhs
         ((inst ys (Cons y Nil)))
         ()
         (steps
           ((unfold mgo_last lhs)
            (reduce lhs)
            (unfold mgo_last lhs)
            (reduce lhs))
           refl)))
     (case Cons
       (f rest)
       (rewrite-with
         (lemma append_cons)
         lr
         lhs
         ((inst h f) (inst t rest) (inst ys (Cons y Nil)))
         ()
         (steps
           ((unfold mgo_last lhs) (reduce lhs))
           (rewrite-with (hyp 0) lr lhs () () refl)))))))

(claim mgo_dir_snoc
  (goal ((ins (List (Option Int))) (h (Pair Int Int)) (mk (Option Int))) ()
    (= (mgo_dir h (append ins (Cons mk Nil))) (steer_vec (mgo_dir h ins) mk)))
  (induct ins
    ((case Nil
       (rewrite-with
         (lemma append_nil_left)
         lr
         lhs
         ((inst ys (Cons mk Nil)))
         ()
         (steps
           ((unfold mgo_dir lhs)
            (reduce lhs)
            (unfold mgo_dir lhs)
            (reduce lhs)
            (unfold mgo_dir rhs)
            (reduce rhs))
           refl)))
     (case Cons
       (i it)
       (rewrite-with
         (lemma append_cons)
         lr
         lhs
         ((inst h i) (inst t it) (inst ys (Cons mk Nil)))
         ()
         (steps
           ((unfold mgo_dir lhs) (reduce lhs) (unfold mgo_dir rhs) (reduce rhs))
           (rewrite-with (hyp 0) lr lhs () () refl)))))))

;; a trailing key with no frame (the quit/EOF tick) never breaks the walk.
(claim moves_ext
  (goal
    ((outs (List (List Int)))
     (ins (List (Option Int)))
     (h (Pair Int Int))
     (p (Option (List Int)))
     (mk (Option Int)))
    ((= (same_shape outs ins) True) (= (moves_go h p outs ins) True))
    (= (moves_go h p outs (append ins (Cons mk Nil))) True))
  (induct outs
    ((case Nil (steps ((unfold moves_go lhs) (reduce lhs)) refl))
     (case Cons
       (f frest)
       (induct ins
         ((case Nil (absurd (premise 0)))
          (case Cons
            (i it)
            (rewrite-with
              (lemma append_cons)
              lr
              lhs
              ((inst h i) (inst t it) (inst ys (Cons mk Nil)))
              ()
              (steps
                ((unfold moves_go lhs) (reduce lhs))
                (case-on (shows_move p f (steer_vec h i)) Bool
                  ((case True
                     (steps
                       ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                       (rewrite-with
                         (hyp 1)
                         lr
                         lhs
                         ()
                         ((steps
                            ((rewrite (premise 0) rl rhs true ())
                             (unfold same_shape rhs)
                             (reduce rhs))
                            refl)
                          (steps
                            ((rewrite (premise 1) rl rhs true ())
                             (unfold moves_go rhs)
                             (reduce rhs)
                             (rewrite (hyp 0) lr rhs true ())
                             (reduce rhs))
                            refl))
                         refl)))
                   (case False
                     (have (= True False)
                       (steps
                         ((rewrite (premise 1) rl lhs true ())
                          (unfold moves_go lhs)
                          (reduce lhs)
                          (rewrite (hyp 0) lr lhs true ())
                          (reduce lhs))
                         refl)
                       (absurd (premise 2)))))))))))))))

;; fold one appended (frame, key) pair into the walk: the new pair's check
;; is exactly shows_move at the two carries (the last frame, the folded
;; heading through the new key).
(claim moves_snoc
  (goal
    ((outs (List (List Int)))
     (ins (List (Option Int)))
     (h (Pair Int Int))
     (p (Option (List Int)))
     (f2 (List Int))
     (mk (Option Int)))
    ((= (same_shape outs ins) True)
     (= (moves_go h p outs ins) True)
     (= (shows_move (mgo_last p outs) f2 (steer_vec (mgo_dir h ins) mk)) True))
    (=
      (moves_go h p (append outs (Cons f2 Nil)) (append ins (Cons mk Nil)))
      True))
  (induct outs
    ((case Nil
       (induct ins
         ((case Nil
            (rewrite-with
              (lemma append_nil_left)
              lr
              lhs
              ((inst ys (Cons f2 Nil)))
              ()
              (rewrite-with
                (lemma append_nil_left)
                lr
                lhs
                ((inst ys (Cons mk Nil)))
                ()
                (have (= (shows_move p f2 (steer_vec h mk)) True)
                  (steps
                    ((rewrite (premise 2) rl rhs true ())
                     (unfold mgo_last rhs)
                     (reduce rhs)
                     (unfold mgo_dir rhs)
                     (reduce rhs))
                    refl)
                  (steps
                    ((unfold moves_go lhs)
                     (reduce lhs)
                     (rewrite (premise 3) lr lhs true ())
                     (reduce lhs)
                     (unfold moves_go lhs)
                     (reduce lhs))
                    refl)))))
          (case Cons (i it) (absurd (premise 0))))))
     (case Cons
       (f frest)
       (induct ins
         ((case Nil (absurd (premise 0)))
          (case Cons
            (i it)
            (rewrite-with
              (lemma append_cons)
              lr
              lhs
              ((inst h f) (inst t frest) (inst ys (Cons f2 Nil)))
              ()
              (rewrite-with
                (lemma append_cons)
                lr
                lhs
                ((inst h i) (inst t it) (inst ys (Cons mk Nil)))
                ()
                (steps
                  ((unfold moves_go lhs) (reduce lhs))
                  (case-on (shows_move p f (steer_vec h i)) Bool
                    ((case True
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (rewrite-with
                           (hyp 1)
                           lr
                           lhs
                           ()
                           ((steps
                              ((rewrite (premise 0) rl rhs true ())
                               (unfold same_shape rhs)
                               (reduce rhs))
                              refl)
                            (steps
                              ((rewrite (premise 1) rl rhs true ())
                               (unfold moves_go rhs)
                               (reduce rhs)
                               (rewrite (hyp 0) lr rhs true ())
                               (reduce rhs))
                              refl)
                            (steps
                              ((rewrite (premise 2) rl rhs true ())
                               (unfold mgo_last rhs)
                               (reduce rhs)
                               (unfold mgo_dir rhs)
                               (reduce rhs))
                              refl))
                           refl)))
                     (case False
                       (have (= True False)
                         (steps
                           ((rewrite (premise 1) rl lhs true ())
                            (unfold moves_go lhs)
                            (reduce lhs)
                            (rewrite (hyp 0) lr lhs true ())
                            (reduce lhs))
                           refl)
                         (absurd (premise 3))))))))))))))))

;; the ∀-fuel worker: the moves invariant rides the loop. Premises 0-2 keep
;; the per-tick lemma's state facts alive (re-established by the slice-12
;; game requirements), 3-4 say the logs-so-far pass the walk in lockstep,
;; 5-6 tie the walk's two carries to the LIVE state: the last written update
;; is THIS state's frame, the folded heading is THIS state's heading. Each
;; tick: quit/EOF extend input only (moves_ext); a written tick folds its
;; pair in by moves_snoc, whose per-pair obligation is exactly move_shown
;; after the carries rewrite (premises 5-6 + steer_bridge).
(claim play_moves_preserve
  (goal ((f Int) (g GameState) (w World))
    ((= (status_of g) Alive)
     (= (nonempty (snake_of g)) True)
     (= (in_bounds (snake_head (snake_of g))) True)
     (= (same_shape (w_output w) (w_input w)) True)
     (= (moves_go (Pair 1 0) None (w_output w) (w_input w)) True)
     (= (mgo_last None (w_output w)) (Some (io_app (clear_bytes) (render g))))
     (= (mgo_dir (Pair 1 0) (w_input w)) (dir_vec (dir_of g))))
    (=
      (moves_go (Pair 1 0) None (w_output (play f g w)) (w_input (play f g w)))
      True))
  (wf-induct f
    (case-on (lt 0 f) Bool
      ((case False
         (steps
           ((unfold play lhs)
            (unfold play lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (rewrite (premise 4) lr lhs true ()))
           refl))
       (case True
         (steps
           ((unfold play lhs)
            (unfold play lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs))
           (case-on (key_oracle w) Pair
             ((case Pair
                (o w1)
                (steps
                  ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                  (case-on o Option
                    ((case None
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (rewrite-with
                           (lemma key_output)
                           lr
                           lhs
                           ((inst w w) (inst o o))
                           ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                           (rewrite-with
                             (lemma key_input)
                             lr
                             lhs
                             ((inst w w) (inst o o))
                             ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                             (rewrite-with
                               (lemma moves_ext)
                               lr
                               lhs
                               ()
                               ((steps
                                  ((rewrite (premise 3) lr lhs true ()))
                                  refl)
                                (steps
                                  ((rewrite (premise 4) lr lhs true ()))
                                  refl))
                               refl)))))
                     (case Some
                       (k)
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (case-on (int_eq k 113) Bool
                           ((case True
                              (steps
                                ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                                (rewrite-with
                                  (lemma key_output)
                                  lr
                                  lhs
                                  ((inst w w) (inst o o))
                                  ((steps
                                     ((rewrite (hyp 2) lr lhs true ()))
                                     refl))
                                  (rewrite-with
                                    (lemma key_input)
                                    lr
                                    lhs
                                    ((inst w w) (inst o o))
                                    ((steps
                                       ((rewrite (hyp 2) lr lhs true ()))
                                       refl))
                                    (rewrite-with
                                      (lemma moves_ext)
                                      lr
                                      lhs
                                      ()
                                      ((steps
                                         ((rewrite (premise 3) lr lhs true ()))
                                         refl)
                                       (steps
                                         ((rewrite (premise 4) lr lhs true ()))
                                         refl))
                                      refl)))))
                            (case False
                              (have
                                (=
                                  (status_of (tick g k))
                                  (status_of
                                    (step g (key_heading k (dir_of g)))))
                                (steps ((unfold tick lhs)) refl)
                                (steps
                                  ((rewrite (hyp 0) lr lhs true ())
                                   (reduce lhs)
                                   (rewrite (premise 7) lr lhs true ()))
                                  (case-on
                                    (status_of
                                      (step g (key_heading k (dir_of g))))
                                    Status
                                    ((case Dead
                                       (steps
                                         ((rewrite (hyp 0) lr lhs true ())
                                          (reduce lhs)
                                          (unfold write_frame lhs)
                                          (unfold write_frame lhs)
                                          (rewrite
                                            (lemma write_output)
                                            lr
                                            lhs
                                            true
                                            ())
                                          (rewrite
                                            (lemma write_input)
                                            lr
                                            lhs
                                            true
                                            ()))
                                         (rewrite-with
                                           (lemma key_output)
                                           lr
                                           lhs
                                           ((inst w w) (inst o o))
                                           ((steps
                                              ((rewrite (hyp 3) lr lhs true ()))
                                              refl))
                                           (rewrite-with
                                             (lemma key_input)
                                             lr
                                             lhs
                                             ((inst w w) (inst o o))
                                             ((steps
                                                ((rewrite
                                                   (hyp 3)
                                                   lr
                                                   lhs
                                                   true
                                                   ()))
                                                refl))
                                             (rewrite-with
                                               (lemma moves_snoc)
                                               lr
                                               lhs
                                               ()
                                               ((steps
                                                  ((rewrite
                                                     (premise 3)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl)
                                                (steps
                                                  ((rewrite
                                                     (premise 4)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl)
                                                (steps
                                                  ((rewrite
                                                     (premise 5)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (premise 6)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (hyp 2)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (lemma steer_bridge)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (unfold tick lhs))
                                                  (rewrite-with
                                                    (lemma move_shown)
                                                    lr
                                                    lhs
                                                    ()
                                                    ((steps
                                                       ((rewrite
                                                          (premise 0)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl)
                                                     (steps
                                                       ((rewrite
                                                          (premise 1)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl)
                                                     (steps
                                                       ((rewrite
                                                          (premise 2)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl))
                                                    refl)))
                                               refl)))))
                                     (case Alive
                                       (steps
                                         ((rewrite (hyp 0) lr lhs true ())
                                          (reduce lhs))
                                         (rewrite-with
                                           (hyp 5)
                                           lr
                                           lhs
                                           ()
                                           ((steps
                                              ((unfold tick lhs)
                                               (rewrite (hyp 0) lr lhs true ()))
                                              refl)
                                            (steps
                                              ((unfold tick lhs))
                                              (rewrite-with
                                                (lemma step_nonempty)
                                                lr
                                                lhs
                                                ()
                                                ((steps
                                                   ((rewrite
                                                      (premise 0)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                refl))
                                            (steps
                                              ((unfold tick lhs))
                                              (rewrite-with
                                                (lemma step_alive_in_bounds)
                                                lr
                                                lhs
                                                ()
                                                ((steps
                                                   ((rewrite
                                                      (premise 0)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl)
                                                 (steps
                                                   ((rewrite
                                                      (hyp 0)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                refl))
                                            (steps
                                              ((unfold write_frame lhs)
                                               (unfold write_frame lhs)
                                               (rewrite
                                                 (lemma write_output)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma write_input)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              (rewrite-with
                                                (lemma key_output)
                                                lr
                                                lhs
                                                ((inst w w) (inst o o))
                                                ((steps
                                                   ((rewrite
                                                      (hyp 3)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                (rewrite-with
                                                  (lemma key_input)
                                                  lr
                                                  lhs
                                                  ((inst w w) (inst o o))
                                                  ((steps
                                                     ((rewrite
                                                        (hyp 3)
                                                        lr
                                                        lhs
                                                        true
                                                        ()))
                                                     refl))
                                                  (rewrite-with
                                                    (lemma same_shape_snoc)
                                                    lr
                                                    lhs
                                                    ()
                                                    ((steps
                                                       ((rewrite
                                                          (premise 3)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl))
                                                    refl))))
                                            (steps
                                              ((unfold write_frame lhs)
                                               (unfold write_frame lhs)
                                               (rewrite
                                                 (lemma write_output)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma write_input)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              (rewrite-with
                                                (lemma key_output)
                                                lr
                                                lhs
                                                ((inst w w) (inst o o))
                                                ((steps
                                                   ((rewrite
                                                      (hyp 3)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                (rewrite-with
                                                  (lemma key_input)
                                                  lr
                                                  lhs
                                                  ((inst w w) (inst o o))
                                                  ((steps
                                                     ((rewrite
                                                        (hyp 3)
                                                        lr
                                                        lhs
                                                        true
                                                        ()))
                                                     refl))
                                                  (rewrite-with
                                                    (lemma moves_snoc)
                                                    lr
                                                    lhs
                                                    ()
                                                    ((steps
                                                       ((rewrite
                                                          (premise 3)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl)
                                                     (steps
                                                       ((rewrite
                                                          (premise 4)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl)
                                                     (steps
                                                       ((rewrite
                                                          (premise 5)
                                                          lr
                                                          lhs
                                                          true
                                                          ())
                                                        (rewrite
                                                          (premise 6)
                                                          lr
                                                          lhs
                                                          true
                                                          ())
                                                        (rewrite
                                                          (hyp 2)
                                                          lr
                                                          lhs
                                                          true
                                                          ())
                                                        (rewrite
                                                          (lemma steer_bridge)
                                                          lr
                                                          lhs
                                                          true
                                                          ())
                                                        (unfold tick lhs))
                                                       (rewrite-with
                                                         (lemma move_shown)
                                                         lr
                                                         lhs
                                                         ()
                                                         ((steps
                                                            ((rewrite
                                                               (premise 0)
                                                               lr
                                                               lhs
                                                               true
                                                               ()))
                                                            refl)
                                                          (steps
                                                            ((rewrite
                                                               (premise 1)
                                                               lr
                                                               lhs
                                                               true
                                                               ()))
                                                            refl)
                                                          (steps
                                                            ((rewrite
                                                               (premise 2)
                                                               lr
                                                               lhs
                                                               true
                                                               ()))
                                                            refl))
                                                         refl)))
                                                    refl))))
                                            (steps
                                              ((unfold write_frame lhs)
                                               (rewrite
                                                 (lemma write_output)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
