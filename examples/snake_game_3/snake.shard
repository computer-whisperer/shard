                                                       ((rewrite
                                                          (premise 0)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl))
                                                    refl))))
                                            (rewrite-with
                                              (lemma step_nonneg)
                                              lr
                                              lhs
                                              ((inst x f))
                                              ((steps
                                                 ((rewrite
                                                    (hyp 4)
                                                    lr
                                                    lhs
                                                    true
                                                    ()))
                                                 refl))
                                              refl)
                                            (by ord (list)))
                                           refl))))))))))))))))))))))))

;; the empty-log bridge: at the run's start both carries are vacuous (no
;; previous frame — shows_move pins nothing), so the first tick unrolls by
;; hand and hands the worker carries that ARE the first written pair.
(claim play_moves_start
  (goal ((f Int) (g GameState) (w World))
    ((= (status_of g) Alive)
     (= (nonempty (snake_of g)) True)
     (= (in_bounds (snake_head (snake_of g))) True)
     (= (dir_vec (dir_of g)) (Pair 1 0))
     (= (w_output w) Nil)
     (= (w_input w) Nil))
    (=
      (moves_go (Pair 1 0) None (w_output (play f g w)) (w_input (play f g w)))
      True))
  (case-on (lt 0 f) Bool
    ((case False
       (steps
         ((unfold play lhs)
          (unfold play lhs)
          (rewrite (hyp 0) lr lhs true ())
          (reduce lhs)
          (rewrite (premise 4) lr lhs true ())
          (unfold moves_go lhs)
          (reduce lhs))
         refl))
     (case True
       (steps
         ((unfold play lhs)
          (unfold play lhs)
          (rewrite (hyp 0) lr lhs true ())
          (reduce lhs))
         (case-on (key_oracle w) Pair
           ((case Pair
              (o w1)
              (steps
                ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                (case-on o Option
                  ((case None
                     (steps
                       ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                       (rewrite-with
                         (lemma key_output)
                         lr
                         lhs
                         ((inst w w) (inst o o))
                         ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                         (steps
                           ((rewrite (premise 4) lr lhs true ())
                            (unfold moves_go lhs)
                            (reduce lhs))
                           refl))))
                   (case Some
                     (k)
                     (steps
                       ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                       (case-on (int_eq k 113) Bool
                         ((case True
                            (steps
                              ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                              (rewrite-with
                                (lemma key_output)
                                lr
                                lhs
                                ((inst w w) (inst o o))
                                ((steps ((rewrite (hyp 2) lr lhs true ())) refl))
                                (steps
                                  ((rewrite (premise 4) lr lhs true ())
                                   (unfold moves_go lhs)
                                   (reduce lhs))
                                  refl))))
                          (case False
                            (have
                              (=
                                (status_of (tick g k))
                                (status_of (step g (key_heading k (dir_of g)))))
                              (steps ((unfold tick lhs)) refl)
                              (steps
                                ((rewrite (hyp 0) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (premise 6) lr lhs true ()))
                                (case-on
                                  (status_of
                                    (step g (key_heading k (dir_of g))))
                                  Status
                                  ((case Dead
                                     (have
                                       (=
                                         (shows_move
                                           None
                                           (io_app
                                             (clear_bytes)
                                             (render (tick g k)))
                                           (steer_vec (Pair 1 0) o))
                                         True)
                                       (steps
                                         ((unfold shows_move lhs) (reduce lhs))
                                         refl)
                                       (steps
                                         ((rewrite (hyp 0) lr lhs true ())
                                          (reduce lhs)
                                          (unfold write_frame lhs)
                                          (unfold write_frame lhs)
                                          (rewrite
                                            (lemma write_output)
                                            lr
                                            lhs
                                            true
                                            ())
                                          (rewrite
                                            (lemma write_input)
                                            lr
                                            lhs
                                            true
                                            ()))
                                         (rewrite-with
                                           (lemma key_output)
                                           lr
                                           lhs
                                           ((inst w w) (inst o o))
                                           ((steps
                                              ((rewrite (hyp 3) lr lhs true ()))
                                              refl))
                                           (rewrite-with
                                             (lemma key_input)
                                             lr
                                             lhs
                                             ((inst w w) (inst o o))
                                             ((steps
                                                ((rewrite
                                                   (hyp 3)
                                                   lr
                                                   lhs
                                                   true
                                                   ()))
                                                refl))
                                             (steps
                                               ((rewrite
                                                  (premise 4)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (rewrite
                                                  (premise 5)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (rewrite
                                                  (lemma append_nil_left)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (unfold moves_go lhs)
                                                (reduce lhs)
                                                (rewrite
                                                  (premise 7)
                                                  lr
                                                  lhs
                                                  true
                                                  ())
                                                (reduce lhs)
                                                (unfold moves_go lhs)
                                                (reduce lhs))
                                               refl))))))
                                   (case Alive
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       (rewrite-with
                                         (lemma play_moves_preserve)
                                         lr
                                         lhs
                                         ()
                                         ((steps
                                            ((unfold tick lhs)
                                             (rewrite (hyp 0) lr lhs true ()))
                                            refl)
                                          (steps
                                            ((unfold tick lhs))
                                            (rewrite-with
                                              (lemma step_nonempty)
                                              lr
                                              lhs
                                              ()
                                              ((steps
                                                 ((rewrite
                                                    (premise 0)
                                                    lr
                                                    lhs
                                                    true
                                                    ()))
                                                 refl))
                                              refl))
                                          (steps
                                            ((unfold tick lhs))
                                            (rewrite-with
                                              (lemma step_alive_in_bounds)
                                              lr
                                              lhs
