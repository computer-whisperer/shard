;;; entity.shard — TIER-1 spec vocabulary, part 2: the ENTITY DETECTORS. frame.shard pins the SHAPE of a frame; these
;;; detectors say WHERE a glyph sits, so requirements can talk about the
;;; screen cell an entity occupies — over the output bytes, never a
;;; GameState field.
;;;
;;; Glyphs: head '@' = 64, food '*' = 42 (body 'O' = 79, blank ' ' = 32,
;;; wall '#' = 35, newline 10). The head byte is distinct from the body's so
;;; the head detector stays well-defined as the snake grows.
;;;
;;; Coordinates are SCREEN cells over the split rows: row 0 is the top wall
;;; row, column 0 the left wall byte — game cell (Pos x y) sits at screen
;;; (row (+ y 1), col (+ x 1)). On a frame is_frame accepts, no border or
;;; terminator byte equals an entity glyph, so a found glyph is necessarily
;;; interior.
(import "../../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "frame.shard")  ; tier-1 sibling: split_rows + the frame shape
(use (:: examples snake_game_3 frame *))

;; the first cell in a row holding glyph g, as its column index (counting
;; from c at the row head). The newline terminator never equals an entity
;; glyph, so the scan self-limits at the end of the row.
(fn row_find ((g Int) (c Int) (r (List Int))) (Option Int)
  (measure (struct r))
  (match r
    (Nil None)
    ((Cons b rest) (if (int_eq b g) (Some c) (row_find g (+ c 1) rest)))))

;; the first cell (row-major over the split rows, counting rows from rw)
;; holding glyph g, as (Pair row col).
(fn rows_find ((g Int) (rw Int) (rs (List (List Int)))) (Option (Pair Int Int))
  (measure (struct rs))
  (match rs
    (Nil None)
    ((Cons r rest)
     (match (row_find g 0 r)
       (None (rows_find g (+ rw 1) rest))
       ((Some c) (Some (Pair rw c)))))))

(fn find_glyph ((g Int) (f (List Int))) (Option (Pair Int Int))
  (rows_find g 0 (split_rows f)))

(fn head_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 64 f))  ; '@'

(fn food_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 42 f))  ; '*'
