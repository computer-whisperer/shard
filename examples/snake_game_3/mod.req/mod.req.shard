;;; snake_game_3 — the BIN CONTRACT (TIER 1). The reviewed, mission-critical
;;; promise of the ARTIFACT: a playable terminal snake binary. Requirements
;;; here anchor ONLY to `main`'s observables (w_output / w_input / w_exit /
;;; the clock) bridged by the extern bolt axioms — never to an internal
;;; function, type, or module surface. The (bin … requires) list cites THIS
;;; file's names and nothing else.
;;;
;;; ORGANIZATION (the two-tier requirement pyramid, ratified 2026-06-12):
;;;   TIER 1 (this file)  — the artifact's promise. Reviewed; stable; the
;;;     statements a reader audits to trust the binary. Formal requirements
;;;     land here together with `main` and the bolts (the io slice) — they
;;;     are not statable earlier, so until then this file carries the
;;;     contract in prose.
;;;   TIER 2 (submodules)  — implementation-owned scaffolding: each internal
;;;     module (game/, render/, …) carries its own mod.req/ asserting the
;;;     properties the layer above cites. Subordinate; may churn; never
;;;     promised to the artifact's consumer. See game/mod.req/.
;;;
;;; THE PROMISE (prose now; formal requirements with the io slice):
;;;   P1  Every update writes a complete bordered frame of the board —
;;;       nothing else ever reaches w_output (the v2 frames_are_arenas /
;;;       frames_are_boards shape).
;;;   P2  Frames are FAITHFUL: the rendered board shows exactly the game
;;;       state's snake and food cells (the render faithfulness chain).
;;;   P3  Input steers: w/a/s/d bytes (and only they) change the heading,
;;;       per the no-reversal rule; unrecognized bytes are inert.
;;;   P4  Death ends play: after a collision frame the run stops reading
;;;       input and exits cleanly (exit 0).
;;;   P5  Clock discipline: main's World clock is monotone — every effect
;;;       is accounted for, none reused (main_clock_mono).
;;;   P6  The PRNG seed comes from argv (default constant when absent):
;;;       a run is a pure function of (args, key input) — REPLAYABLE; no
;;;       entropy extern, randomness adds nothing to the trust surface.
;;;
;;; THE TIER-1 VOCABULARY (landed with the io arc): board.shard (the opaque
;;; dims + their atomic facts — the bin impl discharges the concrete size),
;;; frame.shard (the byte-level frame-shape predicate), entity.shard (the
;;; head/food detectors). Contract-owned and self-contained; the game and
;;; render submodules cite DOWNWARD into this vocabulary, never the
;;; reverse.
;;;
;;; EXPECTED TIER-2 SCAFFOLDING (sketch — the implementation owns the
;;; details): the pure core's movement/length/death algebra (game/mod.req/ —
;;; landed: death_absorbing, no_reversal, head_advances, length_eat/move);
;;; food placement on a free in-bounds cell via std/rng's draw-range pair
;;; (I2 — coming); body distinctness (I1) and collision soundness (I3),
;;; which P2's faithfulness needs to mean anything; the renderer's
;;; frame-shape and cell-faithfulness lemmas.
(import "../../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../../std/list")  ; append — the output-log accumulator
(import "board.shard")  ; tier-1 vocabulary: the opaque board dims
(import "frame.shard")  ; tier-1 vocabulary: the byte-level frame shape
(import "entity.shard")  ; tier-1 vocabulary: the head/food detectors
(use (:: examples snake_game_3 board *))
(use (:: examples snake_game_3 frame *))
(use (:: std list append))

;; ===========================================================================
;; THE FORMAL CONTRACT — grows per slice. Landed: the run boundary (P5).
;; Every requirement is about `main`'s observables bridged by the bolt
;; axioms below; no requirement names an internal function, type, or
;; module surface.
;; ===========================================================================

;; ---- the board dims (vocabulary: board.shard; the bin impl discharges) ------
;; Stated ATOMICALLY (no conjunctions): each fact is exactly the premise
;; shape a citation wants — positivity is the spelling the renderer's
;; alignment proofs consume; the minimums keep a bordered interior with
;; room to play.

(requirement board_w_pos (goal () () (= (lt 0 (board_w)) True)))

(requirement board_h_pos (goal () () (= (lt 0 (board_h)) True)))

(requirement board_w_min (goal () () (= (le 4 (board_w)) True)))

(requirement board_h_min (goal () () (= (le 4 (board_h)) True)))

;; ---- the World and its observables -----------------------------------------

(type World (World Int))  ; the sequencing-clock token

(sig fn w_clock ((w World)) Int)  ; observable: the sequencing clock

(sig fn w_output ((w World)) (List (List Int)))  ; observable: frames written

;; ---- the I/O boundary main may touch ----------------------------------------

(extern get_args ((w World)) (Pair (List (List Int)) World))  ; argv slice
(extern key_oracle ((w World)) (Pair (Option Int) World))  ; next key byte
(extern write ((bytes (List Int)) (w World)) World)  ; emit bytes
(extern exit ((code Int) (w World)) World)  ; end the process

;; ---- THE BOLTS (clock family — P5's trust surface) ----------------------------
;; Each clocked effect advances the sequencing clock by exactly one; exit
;; ends the process, so its returned World is proof fiction — it preserves
;; the clock. Dumb one-line equations, auditable by inspection; the (bin
;; trusts) list below names exactly these.

(axiom write_clock
  (kind operational)
  (goal ((bytes (List Int)) (w World)) ()
    (= (w_clock (write bytes w)) (+ (w_clock w) 1))))

(axiom key_clock
  (kind operational)
  (goal ((w World) (o (Option Int)) (w1 World)) ((= (key_oracle w) (Pair o w1)))
    (= (w_clock w1) (+ (w_clock w) 1))))

(axiom args_clock
  (kind operational)
  (goal ((w World) (args (List (List Int))) (w1 World))
    ((= (get_args w) (Pair args w1)))
    (= (w_clock w1) (+ (w_clock w) 1))))

(axiom exit_clock
  (kind operational)
  (goal ((code Int) (w World)) () (= (w_clock (exit code w)) (w_clock w))))

;; ---- THE BOLTS (output family — P1's trust surface) ---------------------------
;; `write` APPENDS its bytes to the output log; every other effect
;; PRESERVES the log (exit's returned World is the same proof fiction as
;; its clock line).

(axiom write_output
  (kind operational)
  (goal ((bytes (List Int)) (w World)) ()
    (= (w_output (write bytes w)) (append (w_output w) (Cons bytes Nil)))))

(axiom key_output
  (kind operational)
  (goal ((w World) (o (Option Int)) (w1 World)) ((= (key_oracle w) (Pair o w1)))
    (= (w_output w1) (w_output w))))

(axiom args_output
  (kind operational)
  (goal ((w World) (args (List (List Int))) (w1 World))
    ((= (get_args w) (Pair args w1)))
    (= (w_output w1) (w_output w))))

(axiom exit_output
  (kind operational)
  (goal ((code Int) (w World)) () (= (w_output (exit code w)) (w_output w))))

;; ---- the executable -----------------------------------------------------------
;; `main` is the SUBJECT of every requirement; `fuel` is the opaque global
;; step budget (large at RUN, abstract in CHECK — proofs cite the ∀-fuel
;; worker at it, never reducing it; opacity ENFORCES fuel-uniformity).

(sig fn main ((w World)) World)

(sig fn fuel () Int)

;; ---- P5 — CLOCK DISCIPLINE ------------------------------------------------------
;; The running binary only ever advances its sequencing clock — every
;; effect is accounted for, none reused.

(requirement main_clock_mono
  (goal ((w World)) () (= (le (w_clock w) (w_clock (main w))) True)))

;; ---- P1 — COMPLETE FRAMES -------------------------------------------------------
;; Every byte string the binary writes is one SCREEN UPDATE: the ANSI clear,
;; then a complete bordered frame — nothing else ever reaches w_output.
;; Preservation form: the running binary starts with an empty log
;; (all_screens Nil = True), so its entire output is screen updates.

(requirement frames_are_screens
  (goal ((w World)) ((= (all_screens (w_output w)) True))
    (= (all_screens (w_output (main w))) True)))
