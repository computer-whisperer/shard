;;; bin.shard — THE ARTIFACT DECLARATION. A separate file so that
;;; consumers importing the contract for its vocabulary and requirements
;;; (the game/render interfaces) never trip the bin's acceptance gates —
;;; entry/trusts/requires are about BUILDING the artifact, and only the
;;; artifact's own check (snake.shard's closure) loads this file.
(import "mod.req.shard")  ; the apex contract: requirements + bolts + sigs
(use (:: examples snake_game_3 *))

;; ---- THE ARTIFACT ---------------------------------------------------------
;; The acceptance contract: `requires` cites tier-1 names only; `trusts`
;; names the bolt axioms (the binary's TCB); `externs` the I/O boundary
;; main may touch — NO entropy extern is listed, which is P6's
;; machine-checked half (a run is a function of args + keys).

(bin snake
  (entry main)
  (externs get_args key_oracle write exit)
  (trusts write_clock key_clock args_clock exit_clock write_output key_output
    args_output exit_output key_input write_input args_input exit_input)
  (requires board_w_pos board_h_pos board_w_min board_h_min main_clock_mono
    frames_are_screens io_input_moves))
