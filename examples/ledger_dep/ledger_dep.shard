;;; ledger_dep — the IMPL (private): supplies dep_bump's body (which makes
;;; the interface's dep_bolt axiom true, though axioms are admitted, never
;;; proven) and discharges the dep_fact promise.
(import "../../kernel/stdlib.shard")
(import "mod.req.shard")  ; own interface (ungranted): requirement as obligation
(use (:: examples ledger_dep dep_bump))  ; sig→def rebind: our def supplies the sig

(fn dep_bump ((x Int)) Int (+ x 1))

(fulfills dep_fact (by arith (list 1)))
