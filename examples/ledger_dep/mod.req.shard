;;; ledger_dep — the trust_ledger pin's GRANTED dependency: a minimal module
;;; whose interface carries one AXIOM (the consumer inherits it as an
;;; "upstream axiom" — the I/O-bolt stand-in) and one REQUIREMENT (inherited
;;; as "granted (upstream-proven)"). Exists so the ledger pin exercises the
;;; granted-source colors without leaning on std internals: library trees
;;; (std/, meta/, models/) are theorem-only (kernel/facts.shard rule), so
;;; upstream axioms can only ever come from app-tree modules like this one.
(import "../../kernel/stdlib.shard")

(sig fn dep_bump ((x Int)) Int)  ; opaque exported signature

;; the bolt stand-in: an upstream-TRUSTED interface axiom about the opaque fn.
(axiom dep_bolt
  (kind operational)
  (goal ((x Int)) () (= (lt x (dep_bump x)) True)))

;; the upstream-PROVEN promise (discharged in ledger_dep.shard).
(requirement dep_fact (goal ((n Int)) () (= (le (+ n n) (* 2 n)) True)))
