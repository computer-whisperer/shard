;; ===========================================================================
;; CORE — parse (lex cs) = parse_expr cs.  Same shape as loop_eq's outer cases
;; (lex/skip_ws align via ws_lex; first token decides), but `parse` only
;; consumes the leading number, then loop_eq bridges the tail.
;; ===========================================================================
(claim CORE
  (goal ((cs (List Int))) () (= (parse (lex cs)) (parse_expr cs)))
  (steps ((unfold lex lhs) (rewrite (lemma ws_lex) lr lhs true ()) (unfold parse_expr rhs)) (case-on (skip_ws cs) List ((case Nil (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl)) (case Cons (c rst) (case-on (is_digit c) Bool ((case True (steps ((rewrite (hyp 1) lr lhs true ())) (rewrite-with (lemma lex_digit_head) lr lhs () ((steps ((rewrite (hyp 0) lr lhs true ())) refl)) (steps ((simp lhs) (rewrite (lemma loop_eq) lr lhs true ()) (unfold strip lhs) (rewrite (hyp 1) lr rhs true ()) (simp rhs) (rewrite (hyp 0) lr rhs true ())) (rewrite-with (lemma numr_eta) lr rhs ((inst r (take_digits rst (digit_val c)))) () (steps ((reduce rhs)) refl)))))) (case False (steps ((rewrite (hyp 1) lr both true ()) (simp rhs) (rewrite (hyp 0) lr rhs true ()) (simp rhs)) (case-on (int_eq c 43) Bool ((case True (rewrite-with (lemma lex_plus_head) lr lhs () ((steps ((rewrite (hyp 1) lr lhs true ())) refl) (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (steps ((simp lhs)) refl))) (case False (case-on (int_eq c 45) Bool ((case True (rewrite-with (lemma lex_minus_head) lr lhs () ((steps ((rewrite (hyp 2) lr lhs true ())) refl) (steps ((rewrite (hyp 1) lr lhs true ())) refl) (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (steps ((simp lhs)) refl))) (case False (rewrite-with (lemma lex_bad_head) lr lhs () ((steps ((rewrite (hyp 2) lr lhs true ())) refl) (steps ((rewrite (hyp 1) lr lhs true ())) refl) (steps ((rewrite (hyp 0) lr lhs true ())) refl) (rewrite-with (lemma skipws_head_nonws) lr lhs ((inst cs cs) (inst d c) (inst rrr rst)) ((steps ((rewrite (hyp 3) lr lhs true ())) refl)) refl)) (steps ((simp lhs)) refl)))))))))))))))))

;; ===========================================================================
;; run_eq_spec — THE HEADLINE.  run cs = spec_run cs, for ALL inputs.
;; eval_opt congruence over CORE.
;; ===========================================================================
(claim run_eq_spec
  (goal ((cs (List Int))) () (= (run cs) (spec_run cs)))
  (steps ((unfold run lhs) (rewrite (lemma CORE) lr lhs true ()) (unfold spec_run rhs)) refl))
