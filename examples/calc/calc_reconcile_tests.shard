;;; Reconciliation validation: after teaching the lexer to reject illegal
;;; bytes (TBad), the implementation `run` should AGREE with the reference
;;; `spec_run` on every input. Each claim proves  run cs = spec_run cs
;;; directly by Compute Both on a concrete cs (no expected value hardcoded
;;; — Refl closes iff the two sides compute to the same Option Int). This
;;; is the per-example evidence; the universal  ∀cs. run cs = spec_run cs
;;; is the next (proof) milestone.

(import "calc_spec.shard")  ; brings in calc.shard (run, lex) + spec_run

;; --- accepted inputs (both sides Some v) ---
;; "1+2"
(claim r_1plus2
  (goal () () (= (run (list 49 43 50)) (spec_run (list 49 43 50))))
  (steps ((compute both)) refl))
;; "1 + 2" (whitespace)
(claim r_ws
  (goal () () (= (run (list 49 32 43 32 50)) (spec_run (list 49 32 43 32 50))))
  (steps ((compute both)) refl))
;; "12-3"
(claim r_sub
  (goal () () (= (run (list 49 50 45 51)) (spec_run (list 49 50 45 51))))
  (steps ((compute both)) refl))
;; "1+2-3" (chain)
(claim r_chain
  (goal () () (= (run (list 49 43 50 45 51)) (spec_run (list 49 43 50 45 51))))
  (steps ((compute both)) refl))

;; --- rejected inputs (both sides None) ---
;; "1@+2" — THE formerly-divergent case: old run = Some 3, spec = None. Now both None.
(claim r_garbage
  (goal () () (= (run (list 49 64 43 50)) (spec_run (list 49 64 43 50))))
  (steps ((compute both)) refl))
;; "1@2"
(claim r_garbage2
  (goal () () (= (run (list 49 64 50)) (spec_run (list 49 64 50))))
  (steps ((compute both)) refl))
;; "+1"
(claim r_leadop
  (goal () () (= (run (list 43 49)) (spec_run (list 43 49))))
  (steps ((compute both)) refl))
;; ""
(claim r_empty
  (goal () () (= (run (list)) (spec_run (list))))
  (steps ((compute both)) refl))
;; "1+"
(claim r_trailop
  (goal () () (= (run (list 49 43)) (spec_run (list 49 43))))
  (steps ((compute both)) refl))
;; "1 2" (two numbers, no op)
(claim r_twonum
  (goal () () (= (run (list 49 32 50)) (spec_run (list 49 32 50))))
  (steps ((compute both)) refl))
;; tab/newline whitespace "1\t-\n2" = [49 9 45 10 50]
(claim r_tabnl
  (goal () () (= (run (list 49 9 45 10 50)) (spec_run (list 49 9 45 10 50))))
  (steps ((compute both)) refl))
