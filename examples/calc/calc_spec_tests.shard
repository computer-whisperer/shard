;;; Behavioral validation of the spec by GROUND EVALUATION (the Compute
;;; tactic). These are the "run the spec on examples" checks that let a
;;; human sign off that the requirement IS the intent. Each is one Compute:
;;; the input is fully concrete, so Compute drives spec_run to a value.
(import "../../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)
(import "calc_spec.shard")

;; "1+2" = [49 43 50] -> Some 3
(claim t_1plus2
  (goal () () (= (spec_run (list 49 43 50)) (Some 3)))
  (steps ((compute lhs)) refl))

;; "1 + 2" = [49 32 43 32 50] -> Some 3   (whitespace allowed)
(claim t_ws
  (goal () () (= (spec_run (list 49 32 43 32 50)) (Some 3)))
  (steps ((compute lhs)) refl))

;; "12-3" = [49 50 45 51] -> Some 9
(claim t_sub
  (goal () () (= (spec_run (list 49 50 45 51)) (Some 9)))
  (steps ((compute lhs)) refl))

;; "1+2-3" = [49 43 50 45 51] -> Some 0   (left-assoc chain)
(claim t_chain
  (goal () () (= (spec_run (list 49 43 50 45 51)) (Some 0)))
  (steps ((compute lhs)) refl))

;; "1@+2" = [49 64 43 50] -> None   (garbage byte off-grammar; the live lexer ACCEPTS this)
(claim t_garbage
  (goal () () (= (spec_run (list 49 64 43 50)) None))
  (steps ((compute lhs)) refl))

;; "+1" = [43 49] -> None   (leading operator)
(claim t_leadop
  (goal () () (= (spec_run (list 43 49)) None))
  (steps ((compute lhs)) refl))

;; "" = [] -> None   (empty)
(claim t_empty
  (goal () () (= (spec_run (list)) None))
  (steps ((compute lhs)) refl))

;; "1+" = [49 43] -> None   (trailing operator)
(claim t_trailop
  (goal () () (= (spec_run (list 49 43)) None))
  (steps ((compute lhs)) refl))

;; "1 2" = [49 32 50] -> None   (two numbers, no operator)
(claim t_twonum
  (goal () () (= (spec_run (list 49 32 50)) None))
  (steps ((compute lhs)) refl))
