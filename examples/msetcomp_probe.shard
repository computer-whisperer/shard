;;; msetcomp_probe.shard — the MSET FRAME-FLOW probe (mod.build design,
;;; docs/LOWERING.md arc; the arc-after of callcomp_probe.shard).
;;;
;;; Question under test: when a CALLEE WRITES memory, how does the frame
;;; flow to the caller's cert? Hypothesis: entirely through citation —
;;; the callee's cert returns its memory effect DENOTATIONALLY as an
;;; abstract (mem_set m0 a v) term, so
;;;   1. the caller's later observations instantiate their own callee
;;;      certs AT the post-write memory (the arbitrary-m0 framed schema
;;;      earning its keep at call boundaries), and
;;;   2. std/mem's existing surface laws (get_set_other here) collapse
;;;      framed reads — no frame companions, no memory-equality theory,
;;;      no new kernel or model machinery.
;;;
;;; Three articles on top of callcomp's mget_f/mget_thm/call_bridge:
;;;   1. mset_thm  — the writing callee: byte store as a module function
;;;      (index 1 behind mget_f; concrete prefix = the regenerate-at-link
;;;      module shape). Returns the raw value; the store needs NO premise
;;;      on v — mem_set truncates observationally.
;;;   2. setget_thm — THE FRAME CONSUMER: store v at x, then read y ≠ x
;;;      by call. The read's cert is cited at m0 := (mem_set m0 x v) and
;;;      get_set_other collapses the value to (mem_get m0 y) while the
;;;      final memory keeps the write.
;;;   3. bump_thm  — read-modify-write: the callee cert cited with a
;;;      COMPUTED argument (v := (mem_get m0 x) + 1), the shape every
;;;      real in-place algorithm has.
;;;
;;; The consumers park callee return values in a scratch local (LocalSet)
;;; rather than a Drop — the model has no Drop, and P2c's locals-not-stack
;;; discipline is what the emitter speaks anyway.

(import "../kernel/stdlib.shard")
(import "../std/mem")  ; mem_get/mem_set surface: get_lo/get_hi/get_set_other
(import "../models/wasm/wasm.shard")
(import "callcomp_probe.shard")  ; mget_thm + call_bridge + sum_lo/sum_hi
(use (:: std mem *))
(use (:: models wasm wasm *))
(use (:: examples callcomp_probe *))

;; PROBE FINDING: (inline NAME) is same-file-only (reader-level table), so a
;; consumer file cannot ride a FOREIGN fn's body into its statements. Cert
;; statements pin function LITERALS, and citation matching is structural —
;; so a byte-identical local copy of callcomp's mget_f works, and mget_thm
;; (stated over the same literal) applies to it. If callcomp's mget_f ever
;; drifts, the bridge citations here fail loudly. The real fix lives in the
;; regenerate-at-link story: the link-time generator splices literals.
(fn mget_c () Func (MkFunc 1 0 (list (LocalGet 0) (I32Load8U))))

;; --- the callee: mset = byte store as a module function ------------------------

;; params (addr, value): push addr, push value, store; return the raw value
;; (single-result v1 — the scratch-local discipline discards it caller-side).
(fn mset_f () Func
  (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Store8) (LocalGet 1))))

;; the writing callee's conformance cert, standard framed schema: arbitrary
;; initial memory, ∀ fuel slack, ∀ restfs — at INDEX 1 behind mget_f (a
;; cert pins its module prefix; at link time it is regenerated for the
;; final layout). The memory effect is the SPEC-LEVEL (mem_set m0 a v):
;; consumers reason about the post-call memory with std/mem's surface only.
(claim mset_thm
  (goal ((a Int) (v Int) (m0 Mem) (c Nat) (restfs (List Func)))
    ((= (le 0 a) True) (= (le (+ a 1) 65536) True))
    (=
      (call_fn_mem
        (S^ 10 c)
        (MkWModule (Cons (inline mget_c) (Cons (inline mset_f) restfs)) 65536)
        1
        (list a v)
        m0)
      (Some (Pair v (mem_set m0 a v)))))
  (chain
    (steps
      ((compute lhs)
       (rewrite (premise 0) lr lhs true ())
       (compute
         lhs
         (stop pop_n eval_seq wrev wapp zeros wlen params_of body_of extra_of))
       (rewrite (premise 1) lr lhs true ())
       (compute lhs)))
    refl))

;; --- the frame consumer: write x, read y, frame past the write -----------------

;; params (x, y, v), one scratch local: store v at x (call 1), park the
;; return, read y (call 0). The read is the FRAMED observation.
(fn setget_f () Func
  (MkFunc
    3
    1
    (list (LocalGet 0) (LocalGet 2) (Call 1) (LocalSet 3) (LocalGet 1) (Call 0))))

;; the frame-flow statement: the value is the ORIGINAL byte at y — the
;; callee's write is invisible to the read (premise: y ≠ x) — while the
;; final memory carries the write. Proof shape: bridge + mset_thm hands
;; back (mem_set m0 x v); bridge + mget_thm is instantiated AT that
;; memory; get_set_other finishes. The callees' bodies are never entered.
(claim setget_thm
  (goal ((x Int) (y Int) (v Int) (m0 Mem) (c Nat) (restfs (List Func)))
    ((= (le 0 x) True)
     (= (le (+ x 1) 65536) True)
     (= (le 0 y) True)
     (= (le (+ y 1) 65536) True)
     (= (int_eq y x) False))
    (=
      (call_fn_mem
        (S^ 30 c)
        (MkWModule
          (Cons
            (inline mget_c)
            (Cons (inline mset_f) (Cons (inline setget_f) restfs)))
          65536)
        2
        (list x y v)
        m0)
      (Some (Pair (mem_get m0 y) (mem_set m0 x v)))))
  (chain
    (steps ((compute lhs (stop eval_call))))
    (rewrite-with
      (lemma call_bridge)
      lr
      lhs
      ((inst f (inline mset_f))
       (inst popped (Cons v (Cons x Nil)))
       (inst rest Nil)
       (inst args (Cons x (Cons v Nil)))
       (inst v v)
       (inst mem2 (mem_set m0 x v)))
      ((steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (rewrite-with
         (lemma mset_thm)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl)
          (steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((compute lhs (stop eval_call))))
    (rewrite-with
      (lemma call_bridge)
      lr
      lhs
      ((inst f (inline mget_c))
       (inst popped (Cons y Nil))
       (inst rest Nil)
       (inst args (Cons y Nil))
       (inst v (mem_get (mem_set m0 x v) y))
       (inst mem2 (mem_set m0 x v)))
      ((steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (rewrite-with
         (lemma mget_thm)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 2) lr lhs true ())) refl)
          (steps ((rewrite (premise 3) lr lhs true ())) refl))
         refl)))
    (steps ((compute lhs)))
    (rewrite-with
      (lemma get_set_other)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 4) lr lhs true ())) refl))
      refl)))

;; --- the read-modify-write consumer: a COMPUTED callee argument ----------------

;; params (x): read m[x] (call 0), add 1, store back (call 1), return the
;; stored value. The mset cert is cited at v := (mem_get m0 x) + 1 — an
;; argument the caller COMPUTED, not one it was passed.
(fn bump_f () Func
  (MkFunc
    1
    0
    (list
      (LocalGet 0)
      (LocalGet 0)
      (Call 0)
      (I32Const 1)
      (I32Bin BAdd)
      (Call 1))))

;; index 3 of the four-function module: citing callees at 0/1 from deeper
;; in the table. The +1 wraps at the BAdd; get_lo/get_hi bound the read so
;; wrap32_id (via callcomp's sum_lo/sum_hi at q := 1) collapses the mod
;; BEFORE the second bridge — the callee cert then matches the clean sum.
(claim bump_thm
  (goal ((x Int) (m0 Mem) (c Nat) (restfs (List Func)))
    ((= (le 0 x) True) (= (le (+ x 1) 65536) True))
    (=
      (call_fn_mem
        (S^ 30 c)
        (MkWModule
          (Cons
            (inline mget_c)
            (Cons
              (inline mset_f)
              (Cons (inline setget_f) (Cons (inline bump_f) restfs))))
          65536)
        3
        (list x)
        m0)
      (Some (Pair (+ (mem_get m0 x) 1) (mem_set m0 x (+ (mem_get m0 x) 1))))))
  (chain
    (steps ((compute lhs (stop eval_call))))
    (rewrite-with
      (lemma call_bridge)
      lr
      lhs
      ((inst f (inline mget_c))
       (inst popped (Cons x Nil))
       (inst rest (Cons x Nil))
       (inst args (Cons x Nil))
       (inst v (mem_get m0 x))
       (inst mem2 m0))
      ((steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (rewrite-with
         (lemma mget_thm)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl)
          (steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((compute lhs (stop eval_call))))
    (have h1 (= (le 0 (mem_get m0 x)) True)
      (steps ((rewrite (lemma get_lo) lr lhs true ())) refl))
    (have h2 (= (lt (mem_get m0 x) 256) True)
      (steps ((rewrite (lemma get_hi) lr lhs true ())) refl))
    (have hw (= (mod (+ (mem_get m0 x) 1) 4294967296) (+ (mem_get m0 x) 1))
      (rewrite-with
        (lemma wrap32_id)
        lr
        lhs
        ((inst x (+ (mem_get m0 x) 1)))
        ((rewrite-with
           (lemma sum_lo)
           lr
           lhs
           ()
           ((steps ((rewrite (premise h1) lr lhs true ())) refl)
            (steps ((compute both)) refl))
           refl)
         (rewrite-with
           (lemma sum_hi)
           lr
           lhs
           ()
           ((steps ((rewrite (premise h2) lr lhs true ())) refl)
            (steps ((compute both)) refl))
           refl))
        refl))
    (steps ((rewrite (premise hw) lr lhs true ())))
    (rewrite-with
      (lemma call_bridge)
      lr
      lhs
      ((inst f (inline mset_f))
       (inst popped (Cons (+ (mem_get m0 x) 1) (Cons x Nil)))
       (inst rest Nil)
       (inst args (Cons x (Cons (+ (mem_get m0 x) 1) Nil)))
       (inst v (+ (mem_get m0 x) 1))
       (inst mem2 (mem_set m0 x (+ (mem_get m0 x) 1))))
      ((steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (steps ((compute both)) refl)
       (rewrite-with
         (lemma mset_thm)
         lr
         lhs
         ()
         ((steps ((rewrite (premise 0) lr lhs true ())) refl)
          (steps ((rewrite (premise 1) lr lhs true ())) refl))
         refl)))
    (steps ((compute lhs)) refl)))
