;;; div_pairs.shard — the explicitly-paired division operators.
;;;
;;; Semantics lives in the operator NAME: `/`+`tmod` is the truncating
;;; pair (both round toward zero, remainder follows the dividend);
;;; `ediv`+`mod` is the Euclidean pair (remainder always in [0, |b|)).
;;; Each satisfies a = b*q + r on ALL of Int. The MIXED pair `/`+`mod`
;;; does not — the final claim pins the falsity that lived in std/div's
;;; old div_mod_10_id axiom (since DELETED; the proof surface now carries
;;; only euclidean ediv_mod_10_id, an unconditional theorem).
;;; Expected: 7 passed, 1 failed.

(import "../kernel/stdlib.shard")

;; truncating pair identity at a negative dividend.
(claim tpair_neg
  (goal () () (= (+ (* 10 (/ -7 10)) (tmod -7 10)) -7))
  (steps ((compute both)) refl))

;; Euclidean pair identity at the same point.
(claim epair_neg
  (goal () () (= (+ (* 10 (ediv -7 10)) (mod -7 10)) -7))
  (steps ((compute both)) refl))

;; the quotients/remainders themselves: trunc rounds toward zero,
;; Euclidean rounds toward -inf with a non-negative remainder.
(claim trunc_div_neg (goal () () (= (/ -7 10) 0)) (steps ((compute both)) refl))

(claim tmod_neg (goal () () (= (tmod -7 10) -7)) (steps ((compute both)) refl))

(claim ediv_neg (goal () () (= (ediv -7 10) -1)) (steps ((compute both)) refl))

;; division by zero is STUCK, not a crash: all four variants are guarded
;; in BOTH reduction tables (prim.rs and reduce.shard's object reducer),
;; so compute leaves the calls untouched and refl still matches.
(claim div_by_zero_stuck
  (goal () ()
    (=
      (+ (+ (/ 5 0) (mod 5 0)) (+ (tmod 5 0) (ediv 5 0)))
      (+ (+ (/ 5 0) (mod 5 0)) (+ (tmod 5 0) (ediv 5 0)))))
  (steps ((compute both)) refl))

;; likewise the raw-Int shifts outside their [0, 64) amount domain —
;; the same guard prim.rs's shift_amount applies (divergence found by
;; the prim conformance sweep, rust_bootstrap/src/lib.rs).
(claim shift_oob_stuck
  (goal () () (= (+ (bshl 1 64) (bshr 1 -1)) (+ (bshl 1 64) (bshr 1 -1))))
  (steps ((compute both)) refl))

;; THE PIN: the mixed pair `/`+`mod` is NOT an identity on negatives —
;; lhs computes to 3. This claim must FAIL; it is exactly the instance
;; that made the old unconditional axiom unsound.
(claim mixed_pair_false_on_negatives
  (goal () () (= (+ (* 10 (/ -7 10)) (mod -7 10)) -7))
  (steps ((compute both)) refl))
