;;; pending_demo.shard — regression pin for PENDING-requirement surfacing:
;;; a requirement stated with NO fulfills anywhere in the closure used to
;;; vanish from the report (silent-pending); it now renders a PEND line and
;;; is counted, without failing the run (the bin form is where unmet
;;; requirements become hard errors).

(import "../kernel/stdlib.shard")

(fn triple ((n Int)) Int (+ n (+ n n)))

(requirement triple_pos
  (goal ((n Int)) ((= (lt 0 n) True)) (= (lt 0 (triple n)) True)))

;; an ordinary proven claim alongside, so the file isn't vacuous.
(claim triple_two (goal () () (= (triple 2) 6)) (steps ((compute lhs)) refl))
