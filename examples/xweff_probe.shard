;;; examples/xweff_probe.shard — the W4c design article (docs/X86.md §44):
;;; the PURITY DISPATCH in weval_call, and the effectful entry's
;;; composition shape.
;;;
;;; The W2 world layer mirrored the base evaluator uniformly and priced
;;; per-callee bridge lemmas for pure callees. Composition exposed that
;;; price: a data-dependent loop callee's bridge is either a mutual fuel
;;; induction or a lemma-for-lemma twin of the pure worker — the
;;; B-tripwire's named failure. The dispatch restores §32's ratified
;;; delegation at the ONE boundary where it is fuel-exact: weval_call on
;;; a callee with no effect-point (xfn_eff at the ground weff_budget)
;;; DELEGATES to xeval_call at the same fuel, so a pure callee's W call
;;; site computes to (wlift w (xeval_call …)) and the EXISTING
;;; regs-general cert welds in through xcall_bridge — no bridge lemma,
;;; no twin, no new premise family.
;;;
;;; Pinned here: (1) the dispatch FIRES, symbolically — a pure callee
;;; under weval_call IS the lifted base call; (2) an effectful callee
;;; still takes the mirror arm — the write shim AS A CALLEE, its §10
;;; clobber form intact; (3) THE COMPOSITION: an entry whose spine calls
;;; a pure callee (welded by cert through the dispatch, never walked),
;;; marshals its result into the write shim, and ends in the exit shim —
;;; one equation, xrun_w = WExit with the two-event trace, the §32 bin
;;; contract shape over a COMPOSED body. The oracle draws (write return
;;; + rcx/r11 trash) are quantified and absent from the conclusion: the
;;; program ignores the write's return (the v1 offered-bytes
;;; discipline), and no cert can depend on the trash.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(use (:: std mem *))
(import "../models/x86/x86.shard")
(use (:: models x86 x86 *))
(import "../models/linux/kernel.shard")
(use (:: models linux kernel *))
(import "../models/x86/world.shard")
(use (:: models x86 world *))

;; --- the module: entry + pure callee + the two shims -------------------------------
;;
;; entry (0): rdi := 42; call the pure callee; rsi := its rax (the
;; program-computed buffer address); rdx := 3; rdi := 1 (stdout); call
;; the write shim; rdi := 0; call the exit shim.
;; pure callee (1): rax := rdi + 1 — stands in for any proven callee;
;; the weld below never looks inside it, only at its cert.
;; write shim (2) / exit shim (3): the xworld_probe bodies, verbatim.
(fn wfx_entry_body () (List XInstr)
  (list
    (XMovRI RDI 42)
    (XCall 1)
    (XMovRR RSI RAX)
    (XMovRI RDX 3)
    (XMovRI RDI 1)
    (XCall 2)
    (XMovRI RDI 0)
    (XCall 3)))

(fn wfx_callee_body () (List XInstr)
  (list (XMovRR RAX RDI) (XBin XAdd RAX (SImm 1))))

(fn wfx_write_body () (List XInstr) (list (XMovRI RAX 1) XSyscall))

(fn wfx_exit_body () (List XInstr) (list (XMovRI RAX 60) XSyscall))

;; --- (1) the dispatch fires: a pure callee under weval_call IS the lifted base -----
(claim wfx_delegate
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (w LxWorld)
     (c Nat))
    ()
    (=
      (weval_call
        (S c)
        (MkXModule
          (Cons
            (MkXFunc 0 (inline wfx_entry_body))
            (Cons
              (MkXFunc 1 (inline wfx_callee_body))
              (Cons
                (MkXFunc 3 (inline wfx_write_body))
                (Cons (MkXFunc 1 (inline wfx_exit_body)) Nil))))
          0
          0)
        1
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        w)
      (wlift
        w
        (xeval_call
          (S c)
          (MkXModule
            (Cons
              (MkXFunc 0 (inline wfx_entry_body))
              (Cons
                (MkXFunc 1 (inline wfx_callee_body))
                (Cons
                  (MkXFunc 3 (inline wfx_write_body))
                  (Cons (MkXFunc 1 (inline wfx_exit_body)) Nil))))
            0
            0)
          1
          (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
          mem))))
  (steps ((compute both)) refl))

;; --- (2) an effectful callee still mirrors: the write shim AS A CALLEE -------------
;;
;; the §10 clobber form through weval_call: rax/rcx/r11 oracle-drawn,
;; everything else verbatim, world advanced three answers, one event.
(claim wfx_mirror
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (r Int)
     (t1 Int)
     (t2 Int)
     (ws (List Int))
     (c Nat))
    ()
    (=
      (weval_call
        (S^ 5 c)
        (MkXModule
          (Cons
            (MkXFunc 0 (inline wfx_entry_body))
            (Cons
              (MkXFunc 1 (inline wfx_callee_body))
              (Cons
                (MkXFunc 3 (inline wfx_write_body))
                (Cons (MkXFunc 1 (inline wfx_exit_body)) Nil))))
          0
          0)
        2
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        (MkLxWorld (Cons r (Cons t1 (Cons t2 ws)))))
      (Some
        (WNorm
          (MkRegs
            (mod r 18446744073709551616)
            (mod t1 18446744073709551616)
            d0
            b0
            p0
            si0
            di0
            e8
            e9
            e10
            (mod t2 18446744073709551616)
            e12
            e13
            e14
            e15)
          mem
          (MkLxWorld ws)
          (Cons (LxWrote di0 (lx_read mem si0 d0)) Nil)))))
  (steps ((compute both)) refl))

;; --- the pure callee's regs-general cert (the §10 form the weld consumes) ----------
(claim wfx_callee_cert
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (c Nat))
    ()
    (=
      (xrun_regs
        (S^ 4 c)
        (MkXModule
          (Cons
            (MkXFunc 0 (inline wfx_entry_body))
            (Cons
              (MkXFunc 1 (inline wfx_callee_body))
              (Cons
                (MkXFunc 3 (inline wfx_write_body))
                (Cons (MkXFunc 1 (inline wfx_exit_body)) Nil))))
          0
          0)
        1
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem)
      (Some
        (Pair
          (MkRegs
            (mod (+ di0 1) 18446744073709551616)
            c0
            d0
            b0
            p0
            si0
            di0
            e8
            e9
            e10
            e11
            e12
            e13
            e14
            e15)
          mem))))
  (steps ((compute both)) refl))

;; --- (3) THE COMPOSITION: pure weld + write + exit = one WExit equation ------------
;;
;; the entry's whole behavior: pure work by CITED CERT (never walked),
;; its result marshalled into the write shim's buffer register, the
;; two-event trace, terminal WExit 0. r/t1/t2 (the write's return and
;; the syscall trash) are quantified and do not appear in the
;; conclusion.
(claim wfx_compose
  (goal
    ((a0 Int)
     (c0 Int)
     (d0 Int)
     (b0 Int)
     (p0 Int)
     (si0 Int)
     (di0 Int)
     (e8 Int)
     (e9 Int)
     (e10 Int)
     (e11 Int)
     (e12 Int)
     (e13 Int)
     (e14 Int)
     (e15 Int)
     (mem Mem)
     (r Int)
     (t1 Int)
     (t2 Int)
     (ws (List Int))
     (c Nat))
    ()
    (=
      (xrun_w
        (S^ 24 c)
        (MkXModule
          (Cons
            (MkXFunc 0 (inline wfx_entry_body))
            (Cons
              (MkXFunc 1 (inline wfx_callee_body))
              (Cons
                (MkXFunc 3 (inline wfx_write_body))
                (Cons (MkXFunc 1 (inline wfx_exit_body)) Nil))))
          0
          0)
        0
        (MkRegs a0 c0 d0 b0 p0 si0 di0 e8 e9 e10 e11 e12 e13 e14 e15)
        mem
        (MkLxWorld (Cons r (Cons t1 (Cons t2 ws)))))
      (Some
        (WExit 0 (Cons (LxWrote 1 (lx_read mem 43 3)) (Cons (LxExited 0) Nil))))))
  (chain
    (steps ((compute lhs (stop xeval_call))))
    (rewrite-with
      (lemma xcall_bridge)
      lr
      lhs
      ((inst f (MkXFunc 1 (inline wfx_callee_body)))
       (inst rs2 (MkRegs 43 c0 d0 b0 p0 si0 42 e8 e9 e10 e11 e12 e13 e14 e15))
       (inst mem2 mem))
      ((steps ((compute both)) refl)
       (chain
         (rewrite-with (lemma wfx_callee_cert) lr lhs ((inst c (S^ 16 c))) ())
         (steps ((compute both)))
         refl)))
    (steps ((compute both)))
    refl))
