;;; examples/sha256sum/sha256sum_x86_out.shard — the sha256sum BIN's x86 MODULE
;;; (docs/IMP.md I2e-4c-3, docs/X86.md §50): HAND-BUILT per the I2e-3
;;; weld pattern (no tool growth) — the imp-generated stage code
;;; splices into one executable image whose machine walk lands on the
;;; weld's shx_pipe_read memory term.
;;;
;;; THE SHAPE (the I2e composition ruling, operationalized): the
;;; World-leading main is THIN — read at the ground cap, branch on the
;;; full-read leg, ONE call into the PURE PIPE, write, exit. The pipe
;;; fn (init → pad → count → fold → hex) is a PURE artifact behind a
;;; single call boundary: its body is 11 instructions, under the world
;;; layer's effect budget, so weval_call DELEGATES it whole into the
;;; base tower where the weld's xeval_seq stage claims compose via
;;; xcall_bridge. (The 577-instruction init body is OVER the budget —
;;; a direct stage call from the world tower would take the mirror
;;; arm, where the weld claims cannot fire. The pipe boundary is not a
;;; convenience: it is what makes the composition typecheck.)
;;;
;;; The module window is the weld's [0, 65536) frame (W@64960 K@65216
;;; H@65472; spill cells at 65504) — NOT addw's 6 MiB glue window: the
;;; stage claims spell the window inside their statements. The
;;; ELF/loader story for a low window is the gate slice's business.
;;;
;;; The oracle discipline (models/linux/kernel.shard): the read draws
;;; 1 (return) + ret (bytes, mod-256 masked) + 2 (rcx/r11 trash); the
;;; write draws 1 + 2; the exit draws nothing. The artifact claims
;;; quantify RAW draws and spell the delivered list (shs_msk bs) — the
;;; strongest reading, the read-pin precedent.

(import "../../kernel/stdlib.shard")
(import "../../kernel/facts.shard")
(import "../../models/x86/x86.shard")
(import "../../models/x86/encode.shard")
(import "../../models/x86/loopkit.shard")
(import "../../models/wasm/loopkit.shard")
(import "../../models/linux/kernel.shard")
(import "../../models/x86/world.shard")
(import "../../std/nat.shard")
(import "../../std/mem")
(import "../../std/bits")
(import "../../std/sha256/sha256.imp.shard")
(import "../../std/sha256/sha256.weld.shard")
(import "../../std/sha256/impgen_x86_out.shard")
(import "sha256sum_src.shard")

(use (:: kernel facts *))

(use (:: models x86 x86 *))

(use (:: models wasm loopkit *))

(use (:: models linux kernel *))

(use (:: models x86 world *))

(use (:: std nat *))

(use (:: std mem *))

(use (:: std bits *))

(use (:: std sha256 sha256_hex))

(use (:: std sha256 sha256.imp *))

