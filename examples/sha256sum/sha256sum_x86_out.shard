;; --- the fold-loop body, byte-copied from the weld (shb_xbody: (inline …)
;; resolves against the file's OWN nullary fns only) ------------------------

(fn shs_xbody () (List XInstr)
  (list
    (XBrIf (CEqz RDX) 1)
    (XMovRR RCX R12)
    (XMovRI RBX 65504)
    (XStore8 (AReg RBX) (SReg RCX))
    (XShrI RCX 8)
    (XMovRI RBX 65505)
    (XStore8 (AReg RBX) (SReg RCX))
    (XMovRR RCX RDX)
    (XMovRI RBX 65506)
    (XStore8 (AReg RBX) (SReg RCX))
    (XShrI RCX 8)
    (XMovRI RBX 65507)
    (XStore8 (AReg RBX) (SReg RCX))
    (XMovRI R13 64960)
    (XCall 0)
    (XMovRI RBX 65505)
    (XLoad8 R12 (AReg RBX))
    (XShlI R12 8)
    (XMovRI RBX 65504)
    (XLoad8 RCX (AReg RBX))
    (XBin XAdd R12 (SReg RCX))
    (XBin XAdd R12 (SImm 64))
    (XMovRI RBX 65507)
    (XLoad8 RDX (AReg RBX))
    (XShlI RDX 8)
    (XMovRI RBX 65506)
    (XLoad8 RCX (AReg RBX))
    (XBin XAdd RDX (SReg RCX))
    (XBin XSub RDX (SImm 1))
    (XMovRI RCX 0)
    (XMovRI RBX 0)
    (XMovRI RBP 0)
    (XMovRI RSI 0)
    (XMovRI RDI 0)
    (XMovRI R8 0)
    (XMovRI R9 0)
    (XBr 0)))

;; --- the pure pipe: init → pad → block count → fold → hex -----------------
;; Entry: rsi = the byte count n, rdi = 0 (the message base), rax/rbx/
;; rbp/r9-r15 zero, rcx/rdx/r8 arbitrary. The count computation is the
;; machine's own ediv-by-64: add 72, shr 6 (the weld's block-count
;; witness premise ties it to int_of_nat k). Exit: the hex window is
;; [0,64), registers all zero but rsi=65504 rdi=64.

(fn shs_pipe_body () (List XInstr)
  (list
    (XCall 2)
    (XMovRI RDI 0)
    (XCall 3)
    (XBin XAdd RSI (SImm 72))
    (XShrI RSI 6)
    (XMovRI RCX 0)
    (XMovRI R8 0)
    (XCall 1)
    (XMovRI RSI 65472)
    (XMovRI R12 0)
    (XCall 4)))

;; --- the thin World main --------------------------------------------------
;; read(0, 0, 64888); if ret == 64888 exit(1); pipe; write(1, 0, 64);
;; exit(0). The success path lives inside the block and ends at the
;; terminal exit call; the full-read branch breaks out to the fail
;; tail. rax/r11 are re-zeroed after the read (the shim's trash) so
;; the pipe sees the stage entry discipline.

(fn shs_main_body () (List XInstr)
  (list
    (XMovRI RDI 0)
    (XMovRI RSI 0)
    (XMovRI RDX 64888)
    (XCall 7)
    (XMovRR RSI RAX)
    (XMovRI RAX 0)
    (XMovRI R11 0)
    (XBlock
      (list
        (XBrIf (CEq RSI (SImm 64888)) 0)
        (XCall 5)
        (XMovRI RDI 1)
        (XMovRI RSI 0)
        (XMovRI RDX 64)
        (XCall 8)
        (XMovRI RDI 0)
        (XCall 9)))
    (XMovRI RDI 1)
    (XCall 9)))

;; --- the shim bodies (models/x86/linux.shard's, local copies) -------------

(fn shs_read_body () (List XInstr) (list (XMovRI RAX 0) XSyscall))

(fn shs_write_body () (List XInstr) (list (XMovRI RAX 1) XSyscall))

(fn shs_exit_body () (List XInstr) (list (XMovRI RAX 60) XSyscall))

;; --- stream vocabulary (local twins: the module surface exports no
;; list kit, and the artifact statements need append/length/mask) ----------

(fn shs_app ((a (List Int)) (b (List Int))) (List Int)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (shs_app t b)))))

(fn shs_len ((bs (List Int))) Nat
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons b t) (S (shs_len t)))))

(fn shs_msk ((bs (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons b t) (Cons (mod b 256) (shs_msk t)))))

;; --- the lib image --------------------------------------------------------

(fn shs_xfuncs () (List XFunc)
  (Cons
    (MkXFunc 0 (gb_shblock_x))
    (Cons
      (MkXFunc
        2
        (list
          (XMovRR R12 RDI)
          (XMovRR RDX RSI)
          (XMovRI RDI 0)
          (XMovRI RSI 0)
          (XBlock (list (XLoop (shs_xbody))))))
      (Cons
        (MkXFunc 0 (gb_shinit_x))
        (Cons
          (MkXFunc 0 (gb_shpad_x))
          (Cons
            (MkXFunc 0 (gb_shhex_x))
            (Cons
              (MkXFunc 0 (shs_pipe_body))
              (Cons
                (MkXFunc 0 (shs_main_body))
                (Cons
                  (MkXFunc 3 (shs_read_body))
                  (Cons
                    (MkXFunc 3 (shs_write_body))
                    (Cons (MkXFunc 1 (shs_exit_body)) Nil)))))))))))

(fn shs_exports () (List XExport) (list (XX "shs_main" 6)))

(fn shs_entry_bytes ((k Int)) (List Int) (enc_image (shs_xfuncs) k))

(fn shs_elf_image () (List Int) (enc_image_ord (shs_xfuncs)))

(fn shs_elf_offsets () (List Int) (img_offs_ord (shs_xfuncs) 0))

;; --- kit: shr-6 is ediv-64 (the block-count computation) ------------------

(claim shs_shr6
  (goal ((a Int)) ((= (le 0 a) True)) (= (bshr a 6) (ediv a 64)))
  (chain
    (have hp (= (pow2 6) 64)
      (chain
        (have h6 (= 6 (+ 5 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h6) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (have h5 (= 5 (+ 4 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h5) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (have h4 (= 4 (+ 3 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h4) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (have h3 (= 3 (+ 2 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h3) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (have h2 (= 2 (+ 1 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h2) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (have h1 (= 1 (+ 0 1)) (steps ((compute both)) refl))
        (steps ((rewrite (premise h1) lr lhs true ())))
        (rewrite-with (lemma pow2_s) lr lhs () ((steps ((compute both)) refl)))
        (steps ((rewrite (lemma pow2_z) lr lhs true ()) (compute both)) refl)))
    (rewrite-with
      (lemma shr_pow2)
      lr
      lhs
      ((inst k 6))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((compute both)) refl)))
    (steps ((rewrite (premise hp) lr lhs true ())) refl)))

;; --- kit: bulk fuel push (the loop-fuel reshape at the fold call) ---------

(claim shs_fuel_push
  (goal ((k Nat) (c Nat)) () (= (lg_fuel k (S^ 133 c)) (S^ 133 (lg_fuel k c))))
  (induct k
    ((case Z (steps ((compute both)) refl))
     (case S
       (k2)
       (chain
         (have hs (= (lg_fuel (S k2) (S^ 133 c)) (S (lg_fuel k2 (S^ 133 c))))
           (steps ((unfold lg_fuel lhs) (reduce lhs)) refl))
         (have hs2 (= (lg_fuel (S k2) c) (S (lg_fuel k2 c)))
           (steps ((unfold lg_fuel lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hs) lr lhs true ())
            (rewrite (premise hs2) lr rhs true ())
            (rewrite (hyp 0) lr lhs true ()))
           refl))))))
;; --- kit: the oracle take lemma -------------------------------------------
;; lx_take splits the drawn stream at the delivered length: the byte
;; segment masks (mod-256) into the delivered list, the tail flows on.

(claim shs_take_go
  (goal ((bs (List Int)) (t (List Int)) (i Int)) ()
    (=
      (lx_take_r (shs_app bs t) i (+ i (int_of_nat (shs_len bs))))
      (Some (Pair (shs_msk bs) t))))
  (induct bs
    ((case Nil
       (chain
         (have hz (= (int_of_nat (shs_len Nil)) (int_of_nat Z))
           (steps ((compute both)) refl))
         (have ha (= (shs_app Nil t) t)
           (steps ((unfold shs_app lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hz) lr lhs true ())
            (rewrite (lemma int_of_nat_zero) lr lhs true ())
            (rewrite (premise ha) lr lhs true ())
            (unfold lx_take_r lhs)))
         (have hlt (= (lt i (+ i 0)) False) (by arith (rows (goal 1))))
         (steps ((rewrite (premise hlt) lr lhs true ()) (compute both)))
         refl))
     (case Cons
       (b bs2)
       (chain
         (have hl (= (shs_len (Cons b bs2)) (S (shs_len bs2)))
           (steps ((unfold shs_len lhs) (reduce lhs)) refl))
         (have ha (= (shs_app (Cons b bs2) t) (Cons b (shs_app bs2 t)))
           (steps ((unfold shs_app lhs) (reduce lhs)) refl))
         (have hm (= (shs_msk (Cons b bs2)) (Cons (mod b 256) (shs_msk bs2)))
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hl) lr lhs true ())
            (rewrite (lemma int_of_nat_succ) lr lhs true ())
            (rewrite (premise ha) lr lhs true ())
            (rewrite (premise hm) lr rhs true ())
            (unfold lx_take_r lhs)))
         (have hnn (= (le 0 (int_of_nat (shs_len bs2))) True)
           (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
         (have hlt (= (lt i (+ i (+ 1 (int_of_nat (shs_len bs2))))) True)
           (by arith (rows (goal 1) (hnn 1))))
         (steps
           ((rewrite (premise hlt) lr lhs true ())
            (compute
              lhs
              (stop lx_take_r shs_app shs_msk shs_len int_of_nat mod))))
         (have hsh
           (=
             (+ i (+ 1 (int_of_nat (shs_len bs2))))
             (+ (+ i 1) (int_of_nat (shs_len bs2))))
           (by arith (list (list 1) (list 1))))
         (steps
           ((rewrite (premise hsh) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ())
            (compute both (stop shs_msk mod))))
         refl)))))

(claim shs_take
  (goal ((bs (List Int)) (t (List Int))) ()
    (=
      (lx_take (shs_app bs t) (int_of_nat (shs_len bs)))
      (Some (Pair (shs_msk bs) t))))
  (chain
    (steps ((unfold lx_take lhs)))
    (have hz (= (int_of_nat (shs_len bs)) (+ 0 (int_of_nat (shs_len bs))))
      (by arith (list (list 1) (list 1))))
    (steps
      ((rewrite (premise hz) lr lhs true ())
       (rewrite (lemma shs_take_go) lr lhs true ()))
      refl)))

;; --- kit: fill framing + readback -----------------------------------------

;; a fill strictly above the probe is invisible
(claim shs_fill_below
  (goal ((ds (List Int)) (m Mem) (q Int) (p Int)) ((= (lt p q) True))
    (= (mem_get (lx_fill m q ds) p) (mem_get m p)))
  (induct ds
    ((case Nil
       (chain
         (have hf (= (lx_fill m q Nil) m)
           (steps ((unfold lx_fill lhs) (reduce lhs)) refl))
         (steps ((rewrite (premise hf) lr lhs true ())) refl)))
     (case Cons
       (d t)
       (chain
         (have hf
           (= (lx_fill m q (Cons d t)) (lx_fill (mem_set m q d) (+ q 1) t))
           (steps ((unfold lx_fill lhs) (reduce lhs)) refl))
         (steps ((rewrite (premise hf) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1) (0 1))))))
         (rewrite-with
           (lemma get_set_other)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma ish_ne_lt)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)))
         refl)))))

;; the delivered window reads back as the masked list
(claim shs_fill_read
  (goal ((ds (List Int)) (m Mem) (p Int)) ()
    (= (mem_read (shs_len ds) (lx_fill m p ds) p) (shs_msk ds)))
  (induct ds
    ((case Nil
       (chain
         (have hz
           (= (mem_read (shs_len Nil) (lx_fill m p Nil) p) (mem_read Z m p))
           (steps ((compute both (stop mem_read))) refl))
         (steps
           ((rewrite (premise hz) lr lhs true ())
            (rewrite (lemma mem_read_z) lr lhs true ())
            (compute both)))
         refl))
     (case Cons
       (d t)
       (chain
         (have hl (= (shs_len (Cons d t)) (S (shs_len t)))
           (steps ((unfold shs_len lhs) (reduce lhs)) refl))
         (have hf
           (= (lx_fill m p (Cons d t)) (lx_fill (mem_set m p d) (+ p 1) t))
           (steps ((unfold lx_fill lhs) (reduce lhs)) refl))
         (have hm (= (shs_msk (Cons d t)) (Cons (mod d 256) (shs_msk t)))
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hl) lr lhs true ())
            (rewrite (premise hf) lr lhs true ())
            (rewrite (premise hm) lr rhs true ())
            (rewrite (lemma mem_read_s) lr lhs true ())))
         (rewrite-with
           (lemma shs_fill_below)
           lr
           lhs
           ()
           ((steps () (by arith (rows (goal 1))))))
         (steps
           ((rewrite (lemma get_set) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ()))
           refl))))))

;; masking is idempotent; masking preserves length
(claim shs_msk_id
  (goal ((bs (List Int))) () (= (shs_msk (shs_msk bs)) (shs_msk bs)))
  (induct bs
    ((case Nil
       (chain
         (have hm (= (shs_msk Nil) Nil)
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hm) lr both true ())
            (rewrite (premise hm) lr lhs true ()))
           refl)))
     (case Cons
       (b t)
       (chain
         (have hm (= (shs_msk (Cons b t)) (Cons (mod b 256) (shs_msk t)))
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps ((rewrite (premise hm) lr both true ())))
         (have hm2
           (=
             (shs_msk (Cons (mod b 256) (shs_msk t)))
             (Cons (mod (mod b 256) 256) (shs_msk (shs_msk t))))
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps ((rewrite (premise hm2) lr lhs true ())))
         (have hmm (= (mod (mod b 256) 256) (mod b 256))
           (rewrite-with
             (lemma mod_unique)
             lr
             lhs
             ((inst q 0) (inst r (mod b 256)))
             ((steps () (by arith (list (list 1) (list 1))))
              (rewrite-with
                (lemma mod_lo)
                lr
                lhs
                ()
                ((steps ((compute lhs)) refl))
                refl)
              (rewrite-with
                (lemma mod_hi)
                lr
                lhs
                ()
                ((steps ((compute lhs)) refl))
                refl))
             refl))
         (steps
           ((rewrite (premise hmm) lr lhs true ())
            (rewrite (hyp 0) lr lhs true ()))
           refl))))))

(claim shs_len_msk
  (goal ((bs (List Int))) () (= (shs_len (shs_msk bs)) (shs_len bs)))
  (induct bs
    ((case Nil
       (chain
         (have hm (= (shs_msk Nil) Nil)
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (steps ((rewrite (premise hm) lr lhs true ())) refl)))
     (case Cons
       (b t)
       (chain
         (have hm (= (shs_msk (Cons b t)) (Cons (mod b 256) (shs_msk t)))
           (steps ((unfold shs_msk lhs) (reduce lhs)) refl))
         (have hl2
           (=
             (shs_len (Cons (mod b 256) (shs_msk t)))
             (S (shs_len (shs_msk t))))
           (steps ((unfold shs_len lhs) (reduce lhs)) refl))
         (have hl (= (shs_len (Cons b t)) (S (shs_len t)))
           (steps ((unfold shs_len lhs) (reduce lhs)) refl))
         (steps
           ((rewrite (premise hm) lr lhs true ())
            (rewrite (premise hl2) lr lhs true ())
            (rewrite (premise hl) lr rhs true ())
            (rewrite (hyp 0) lr lhs true ()))
           refl))))))

;; --- kit: the event-window bridge (lx_read at the ground 64 IS mem_read) --

(claim shs_lxrd64
  (goal ((m Mem)) () (= (lx_read m 0 64) (mem_read 64 m 0)))
  (chain
    (have hb (= (mem_read 64 m 0) (mem_read (S^ 64 Z) m 0))
      (steps ((compute both (stop mem_read))) refl))
    (steps
      ((compute lhs (stop mem_get))
       (rewrite (premise hb) lr rhs true ())
       (rewrite (lemma mem_read_s) lr rhs true ())
