;;; natview pin, RETURN position (CANON.md slice 3 companion): a nonneg
;;; Int literal is a ground Nat at the fn-return position — the same
;;; tc_nat_lit_view that call arguments get (friction #6's last gap; the
;;; canonical C6 spelling must TYPE everywhere the tower did). Variables
;;; still never coerce (natview_rejects pins the refusal side).
(import "../kernel/stdlib.shard")

(fn nv_ret_lit () Nat 2)

(fn nv_ret_zero () Nat 0)

;; the canonical rewrite of a whole-body tower keeps checking
(fn nv_ret_succ ((n Nat)) Nat (S n))

;; the goal spells the Nat as a tower — goal positions are C6-EXEMPT
;; (they exist to relate spellings) and the goal type gate wants Nat=Nat
(claim nv_ret_lit_val
  (goal () () (= (nv_ret_lit) (S (S Z))))
  (steps ((compute both)) refl))
