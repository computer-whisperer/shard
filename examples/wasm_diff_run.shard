;;; wasm_diff_run.shard — the differential PLAN emitter (ISA slice 4).
;;;
;;; RUN-mode script: encodes the welded composite (and a constant-width probe
;;; module) to real .wasm bytes and prints a plan — modules as hex plus test
;;; vectors whose expected results are computed BY THE MODEL (call_fn), not
;;; hardcoded. examples/wasm_diff.sh feeds the plan to a real engine
;;; (node/V8 via examples/wasm_diff.mjs) and compares. This is the dev-side
;;; exercise of the "engine conforms to model" trust leaf: agreement is
;;; evidence for the leaf, disagreement is a model bug or an encoder bug —
;;; either way loud, never a silent proof-side artifact.
;;;
;;; Plan format (one record per line):
;;;   MOD <name> <hex-bytes>
;;;   CASE <name> f<k> <args...> -> <expected>   (expected: u32 decimal | None)
;;;
;;; RUN: bash examples/wasm_diff.sh

(import "../kernel/stdlib.shard")
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../models/wasm/encode.shard")
(use (:: models wasm encode *))
(import "wasm_pieces.shard")
(use (:: examples wasm_pieces *))
(import "wasm_rev.shard")
(use (:: examples wasm_rev prev))
(import "wasm_copy.shard")
(use (:: examples wasm_copy pcopy))
(import "callcomp_probe.shard")
(use (:: examples callcomp_probe mget_f))
(use (:: examples callcomp_probe sum2_f))
(import "mem_reverse.shard")
(use (:: examples mem_reverse load))
(use (:: examples mem_reverse dump))
(use (:: examples mem_reverse length_nat))
(import "../std/mem")
(use (:: std mem *))

(type World (World Int))

(extern write ((bytes (List Int)) (w World)) World)
(extern exit ((code Int) (w World)) World)

;; the welded composite, same ABI layout as the slice-3 certificate.
(fn dmod () WModule (MkWModule (list (padd) (psum) (ptriple)) 0))

;; constant-width probe: one function per interesting I32Const immediate —
;; every sleb width boundary, both signs of the signed view, and negative
;; immediates (the model wraps them; the encoder must mirror that).
(fn kf ((c Int)) Func (MkFunc 0 0 (list (I32Const c))))

(fn kmod () WModule
  (MkWModule
    (list
      (kf 0)
      (kf 1)
      (kf 63)
      (kf 64)
      (kf 8191)
      (kf 8192)
      (kf 1048575)
      (kf 1048576)
      (kf 134217727)
      (kf 134217728)
      (kf 2147483647)
      (kf 2147483648)
      (kf 4294967295)
      (kf -1)
      (kf -64))
    0))

;; the in-place byte-reverse piece (wasm_rev.shard), with its 64KiB memory.
(fn rmod2 () WModule (MkWModule (list (prev)) 65536))

;; the forward byte-copy piece (wasm_copy.shard), same one-page memory.
(fn cmod2 () WModule (MkWModule (list (pcopy)) 65536))

;; call-composition module (callcomp_probe.shard): f0 = mget (byte read as a
;; module function), f1 = sum2 (two byte reads BY CALL + add). The only plan
;; entries exercising the model's Call instruction against the engine.
(fn ccmod () WModule (MkWModule (list (mget_f) (sum2_f)) 65536))

;; --- plan rendering -------------------------------------------------------------

(fn cat ((xs (List (List Int)))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons h t) (wapp h (cat t)))))

(fn hexd ((d Int)) Int (if (lt d 10) (+ 48 d) (+ 87 d)))

(fn hexs ((bs (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons b t) (Cons (hexd (ediv b 16)) (Cons (hexd (mod b 16)) (hexs t))))))

(fn showr ((r (Option Int))) (List Int)
  (match r
    (None "None")
    ((Some v) (dec v))))

(fn showargs ((xs (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons h t) (wapp " " (wapp (dec h) (showargs t))))))

(fn mod_line ((nm (List Int)) (m WModule)) (List Int)
  (cat (list "MOD " nm " " (hexs (enc_module m)) "\n")))

;; a vector: run the MODEL at generous ground fuel, print what it said.
(fn case_line ((nm (List Int)) (m WModule) (k Int) (args (List Int)) (fuel Int))
  (List Int)
  (cat
    (list
      "CASE "
      nm
      " f"
      (dec k)
      (showargs args)
      " -> "
      (showr (call_fn (fnat fuel) m k args))
      "\n")))

(fn kcase ((k Int)) (List Int) (case_line "kmod" (kmod) k (list) 10))

;; a memory vector: preload the bytes at 0, run the MODEL's call_fn_mem,
;; print result + the readback — the engine side replays both.
(fn show_memr ((r (Option (Pair Int Mem))) (n Nat)) (List Int)
  (match r
    (None "None -")
    ((Some pr)
     (match pr
       ((Pair v mf) (cat (list (dec v) " " (hexs (dump 0 n mf)))))))))

(fn memcase_line
  ((nm (List Int))
   (m WModule)
   (k Int)
   (args (List Int))
   (fuel Int)
   (membytes (List Int)))
  (List Int)
  (cat
    (list
      "MEMCASE "
      nm
      " f"
      (dec k)
      (showargs args)
      " MEM "
      (hexs membytes)
      " -> "
      (show_memr
        (call_fn_mem (fnat fuel) m k args (load membytes 0 (mem_empty)))
        (length_nat membytes))
      "\n")))

(fn emit () (List Int)
  (cat
    (list
      (mod_line "dmod" (dmod))
      (mod_line "kmod" (kmod))
      (mod_line "rmod2" (rmod2))
      (mod_line "cmod2" (cmod2))
      (mod_line "ccmod" (ccmod))
      (case_line "dmod" (dmod) 0 (list 3 4) 20)
      (case_line "dmod" (dmod) 0 (list 4294967290 10) 20)
      (case_line "dmod" (dmod) 0 (list 2147483648 2147483648) 20)
      (case_line "dmod" (dmod) 1 (list 0) 50)
      (case_line "dmod" (dmod) 1 (list 1) 50)
      (case_line "dmod" (dmod) 1 (list 10) 100)
      (case_line "dmod" (dmod) 1 (list 100) 500)
      (case_line "dmod" (dmod) 2 (list 0) 30)
      (case_line "dmod" (dmod) 2 (list 5) 30)
      (case_line "dmod" (dmod) 2 (list 4294967295) 30)
      (memcase_line "rmod2" (rmod2) 0 (list 0 5) 200 (list 1 2 3 4 5 6))
      (memcase_line "rmod2" (rmod2) 0 (list 1 4) 200 (list 1 2 3 4 5 6))
      (memcase_line "rmod2" (rmod2) 0 (list 0 2) 200 (list 10 20 30))
      (memcase_line "rmod2" (rmod2) 0 (list 0 0) 200 (list 7))
      (memcase_line "rmod2" (rmod2) 0 (list 3 1) 200 (list 9 9 9 9))
      (memcase_line "cmod2" (cmod2) 0 (list 0 3 3) 200 (list 1 2 3 0 0 0))
      (memcase_line "cmod2" (cmod2) 0 (list 0 4 2) 200 (list 5 6 0 0 0 0))
      (memcase_line "cmod2" (cmod2) 0 (list 2 3 3) 200 (list 8 9 250 0))
      (memcase_line "cmod2" (cmod2) 0 (list 0 1 3) 200 (list 42 7 7 7))
      (memcase_line "cmod2" (cmod2) 0 (list 0 0 0) 200 (list 11 22))
      (memcase_line "ccmod" (ccmod) 0 (list 3) 200 (list 5 7 11 13 200 250))
      (memcase_line "ccmod" (ccmod) 1 (list 0 1) 200 (list 5 7 11 13 200 250))
      (memcase_line "ccmod" (ccmod) 1 (list 4 5) 200 (list 5 7 11 13 200 250))
      (memcase_line "ccmod" (ccmod) 1 (list 2 2) 200 (list 5 7 11 13 200 250))
      (kcase 0)
      (kcase 1)
      (kcase 2)
      (kcase 3)
      (kcase 4)
      (kcase 5)
      (kcase 6)
      (kcase 7)
      (kcase 8)
      (kcase 9)
      (kcase 10)
      (kcase 11)
      (kcase 12)
      (kcase 13)
      (kcase 14))))

(fn main ((w World)) World (exit 0 (write (emit) w)))
