;;; tie_probe.shard — bin/rebuild.sh's BYTE-TIE fixture: a minimal World
;;; app over the standard engine externs, lowered + codegen'd by BOTH the
;;; boot engine and the Rust interpreter on every fast rebuild; the
;;; artifacts must be byte-identical (the chain is deterministic, so any
;;; divergence is a boot-engine miscompile caught before it propagates).
(import "../kernel/stdlib.shard")

(type World (World Int))

(extern get_args ((w World)) (Pair (List (List Int)) World))

(extern write ((bytes (List Int)) (w World)) World)

(extern exit ((code Int) (w World)) World)

(fn tie_len ((xs (List (List Int)))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ rest) (+ 1 (tie_len rest)))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (if (lt (tie_len args) 100) (exit 0 (write "tie\n" w1)) (exit 1 w1)))))
