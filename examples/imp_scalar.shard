;;; examples/imp_scalar.shard — imp twins of the STRAIGHT-LINE fragment
;;; (docs/IMP.md rung I0): representative members of the scalar
;;; fragment class (examples/wasmgen_src.shard) re-spelled as imp
;;; functions, with spec ⊑ imp certs. The twins are EXACT — imp
;;; scalars are unbounded Int, so no width premises exist anywhere
;;; except the one IWrap demonstration at the end (imp's neutrality:
;;; premises appear exactly where wrap ops are used, and the width
;;; story belongs to the imp ⊑ ISA legs at rung I1).
;;;
;;; Pure-expression twins run in ONE fuel unit ((S c) — icall's
;;; statement list is empty); branching twins carry a small constant
;;; reservoir. PROOF GATES ONLY (the DI2 resolution): these certs are
;;; the whole gate; there is no engine leg at imp.

(import "../kernel/stdlib.shard")
(import "wasmgen_src.shard")
(use (:: examples wasmgen_src *))
(import "../models/imp/imp.shard")
(use (:: models imp imp *))

;; a one-function program; the scalar twins own no memory
(fn it_prog ((f IFn)) IProg (MkIProg (list f) 0))

;; --- the twins -----------------------------------------------------------------

(fn it_add1_fn () IFn (MkIFn 1 0 Nil (IBin IAdd (ILoc 0) (IConst 1))))

(fn it_add_fn () IFn (MkIFn 2 0 Nil (IBin IAdd (ILoc 0) (ILoc 1))))

(fn it_mix_fn () IFn
  (MkIFn
    2
    0
    Nil
    (IBin IAdd (IBin IMul (ILoc 0) (IConst 2)) (IBin ISub (ILoc 1) (ILoc 0)))))

(fn it_sel_fn () IFn
  (MkIFn
    2
    1
    (list
      (IIf
        (IBin IEq (ILoc 0) (IConst 0))
        (list (ISet 2 (IBin IAdd (ILoc 1) (IConst 1))))
        (list (ISet 2 (IBin IMul (ILoc 1) (IConst 2))))))
    (ILoc 2)))

(fn it_clamp2_fn () IFn
  (MkIFn
    1
    1
    (list
      (IIf
        (IBin ILt (ILoc 0) (IConst 10))
        (list (ISet 1 (IConst 0)))
        (list
          (IIf
            (IBin ILt (ILoc 0) (IConst 100))
            (list (ISet 1 (IConst 1)))
            (list (ISet 1 (IConst 2)))))))
    (ILoc 1)))

(fn it_divq_fn () IFn (MkIFn 2 0 Nil (IBin IDiv (ILoc 0) (ILoc 1))))

;; --- the certs: spec ⊑ imp, exact and unpremised -------------------------------

(claim imp_lg_add1
  (goal ((x Int) (c Nat)) ()
    (= (icall (S c) (it_prog (it_add1_fn)) 0 (list x)) (Some (lg_add1 x))))
  (steps ((compute both)) refl))

(claim imp_lg_add
  (goal ((x Int) (y Int) (c Nat)) ()
    (= (icall (S c) (it_prog (it_add_fn)) 0 (list x y)) (Some (lg_add x y))))
  (steps ((compute both)) refl))

(claim imp_lg_mix
  (goal ((x Int) (y Int) (c Nat)) ()
    (= (icall (S c) (it_prog (it_mix_fn)) 0 (list x y)) (Some (lg_mix x y))))
  (steps ((compute both)) refl))

(claim imp_lg_sel
  (goal ((x Int) (y Int) (c Nat)) ()
    (= (icall (S^ 8 c) (it_prog (it_sel_fn)) 0 (list x y)) (Some (lg_sel x y))))
  (chain
    (steps ((compute lhs) (unfold lg_sel rhs) (reduce rhs)))
    (case-on (int_eq x 0) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           refl))
       (case False
         (chain
           (steps ((rewrite (hyp False) lr both true ()) (compute both)))
           refl))))))

(claim imp_lg_clamp2
  (goal ((x Int) (c Nat)) ()
    (=
      (icall (S^ 10 c) (it_prog (it_clamp2_fn)) 0 (list x))
      (Some (lg_clamp2 x))))
  (chain
    (steps ((compute lhs) (unfold lg_clamp2 rhs) (reduce rhs)))
    (case-on (lt x 10) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           refl))
       (case False
         (chain
           (steps ((rewrite (hyp False) lr both true ()) (compute both)))
           (case-on (lt x 100) Bool
             ((case True
                (chain
                  (steps ((rewrite (hyp True) lr both true ()) (compute both)))
                  refl))
              (case False
                (chain
                  (steps ((rewrite (hyp False) lr both true ()) (compute both)))
                  refl))))))))))

;; the honest corner: division carries its divisor premise
(claim imp_lg_divq
  (goal ((x Int) (y Int) (c Nat)) ((= (le 1 y) True))
    (= (icall (S c) (it_prog (it_divq_fn)) 0 (list x y)) (Some (lg_divq x y))))
  (chain
    (steps ((compute lhs) (unfold lg_divq rhs)))
    (steps ((rewrite (premise 0) lr lhs true ()) (compute lhs)))
    refl))

;; --- the IWrap demonstration ----------------------------------------------------
;; One wrapped twin, to pin the premise discipline: wrap is the ONLY
;; place a width premise exists at imp. In-range wrap is the identity
;; (the wrap32_id statement, restated here over the machine's ipow2).

(fn it_add1w_fn () IFn
  (MkIFn 1 0 Nil (IWrap 32 (IBin IAdd (ILoc 0) (IConst 1)))))

(claim iwrap32_id
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 4294967296 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim imp_lg_add1_wrapped
  (goal ((x Int) (c Nat))
    ((= (le 0 (+ x 1)) True) (= (lt (+ x 1) 4294967296) True))
    (= (icall (S c) (it_prog (it_add1w_fn)) 0 (list x)) (Some (lg_add1 x))))
  (chain
    (steps ((compute lhs) (unfold lg_add1 rhs)))
    (rewrite-with
      (lemma iwrap32_id)
      lr
      lhs
      ((inst x (+ x 1)))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    refl))
