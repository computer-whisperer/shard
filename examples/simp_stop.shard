;;; simp_stop.shard — pins for (simp SIDE (stop FN …)): the simp-side stop
;;; fence, twin of compute's stop set. A stopped head never fires (no
;;; δ-unfold, no primitive step) while its args still reduce — strictly
;;; fewer reductions than plain simp, so soundness is unchanged. The tool
;;; for keeping a citable spelling folded through normalization.
;;;
;;; The pins are BEHAVIORAL: each proof cites a lemma that only matches the
;;; folded spelling, so a leaking fence (simp firing the stopped call) would
;;; fail the citation with "no match".

(import "../kernel/stdlib.shard")

(fn triple ((x Int)) Int (* 3 x))
(fn wrap ((x Int)) Int (+ (triple x) 1))

(claim triple_2 (goal () () (= (triple 2) 6)) (steps ((compute lhs)) refl))

;; baseline: after the unfold, plain simp computes through triple.
(claim simp_plain_computes
  (goal () () (= (wrap 2) 7))
  (steps ((unfold wrap lhs) (simp lhs)) refl))

;; the fence: (triple 2) survives the same normalization folded, and the
;; citation lands on it. Without the fence the first simp yields 7 and the
;; rewrite fails with "no match".
(claim simp_stop_ground
  (goal () () (= (wrap 2) 7))
  (steps
    ((unfold wrap lhs)
     (simp lhs (stop triple))
     (rewrite (lemma triple_2) lr lhs true ())
     (simp lhs))
    refl))

;; args still reduce INSIDE the fenced call: (+ 1 1) normalizes to 2 under
;; the stopped head — the citation needs exactly (triple 2) to match.
(claim simp_stop_args_reduce
  (goal () () (= (+ (triple (+ 1 1)) 1) 7))
  (steps
    ((simp lhs (stop triple))
     (rewrite (lemma triple_2) lr lhs true ())
     (simp lhs))
    refl))

;; the recursive-fn shape (why the fence exists): a ctor-scrutinee match
;; body passes simp's gate, so plain simp would eat the call one layer —
;; the fence keeps the spelling the step lemma matches against.
(fn len2 ((xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ t) (+ 1 (len2 t)))))

(claim len2_cons
  (goal ((h Int) (t (List Int))) () (= (len2 (Cons h t)) (+ 1 (len2 t))))
  (steps ((unfold len2 lhs) (reduce lhs)) refl))

(claim simp_stop_recursive
  (goal ((a Int)) () (= (len2 (Cons a Nil)) 1))
  (steps
    ((simp lhs (stop len2))
     (rewrite (lemma len2_cons) lr lhs true ())
     (simp lhs))
    refl))
