;;; bytes_facts.shard — the Bytes PROOF SURFACE (issue #2 phase 2).
;;;
;;; One kernel-justified premise-injection step (checker.shard):
;;;   (bytes-fact E CONT)   E's prim-level facts, by head shape:
;;;     (bcat a b)      blen e = (blen a) + (blen b), plus the three
;;;                     non-negativity ranges              [p+0..p+3]
;;;     (bslice b i j)  0 <= blen e, blen e <= blen b, 0 <= blen b
;;;     (bidx b i)      0 <= e, e <= 255, 0 <= blen b
;;;     other Bytes term: 0 <= blen e
;;; The facts mention only prims (blen/bidx terms are Int atoms), so
;;; lia/farkas read them linearly. The list-model bridge (list_of_bytes
;;; homomorphisms) is std/bytes territory, not the kernel's.
;;;
;;; Expected: 5 passed, 1 failed (the non-Bytes target pin).

(import "../kernel/stdlib.shard")

;; the defining length equation, cited directly. Premises after the
;; step: p0 the blen equation, p1-p3 the ranges.
(claim cat_len_eq
  (goal ((a Bytes) (b Bytes)) () (= (blen (bcat a b)) (+ (blen a) (blen b))))
  (bytes-fact (bcat a b) (steps ((rewrite (premise 0) lr lhs true ())) refl)))

;; concatenation never shrinks: blen a <= blen (bcat a b). Farkas over
;; p0 (the equation) and p2 (0 <= blen b).
(claim cat_grows
  (goal ((a Bytes) (b Bytes)) () (= (le (blen a) (blen (bcat a b))) True))
  (bytes-fact (bcat a b) (by farkas (list 1 1 0 1 0))))

;; a slice never outgrows its source — p1 verbatim.
(claim slice_len_bound
  (goal ((b Bytes) (i Int) (j Int)) ()
    (= (le (blen (bslice b i j)) (blen b)) True))
  (bytes-fact
    (bslice b i j)
    (steps ((rewrite (premise 1) lr lhs true ())) refl)))

;; every byte read is below 256 (out-of-range reads are 0, so the
;; bound is unconditional). Farkas from p1 (e <= 255).
(claim idx_below_256
  (goal ((b Bytes) (i Int)) () (= (lt (bidx b i) 256) True))
  (bytes-fact (bidx b i) (by farkas (list 1 0 1 0))))

;; two injections compose: the nested cat's length, premises stacking
;; in order (outer p0-p3, inner p4-p7), with a NAMED have on top citing
;; both — the desugar premise-count interplay this file pins.
(claim cat_assoc_len
  (goal ((a Bytes) (b Bytes) (c Bytes)) ()
    (= (blen (bcat (bcat a b) c)) (+ (+ (blen a) (blen b)) (blen c))))
  (bytes-fact
    (bcat (bcat a b) c)
    (bytes-fact
      (bcat a b)
      (have total (= (blen (bcat (bcat a b) c)) (+ (blen (bcat a b)) (blen c)))
        (steps ((rewrite (premise 0) lr lhs true ())) refl)
        (steps
          ((rewrite (premise total) lr lhs true ())
           (rewrite (premise 4) lr lhs true ()))
          refl)))))

;; FAIL pin: a bytes-fact on a non-Bytes target is REJECTED by the cut
;; gate (the emitted blen fact does not type) — the step fails loudly.
(claim bytes_fact_rejects_int
  (goal ((n Int)) () (= (le 0 n) True))
  (bytes-fact n refl))
