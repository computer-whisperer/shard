;;; examples/arglen_src.shard — the BIN-RUNG PILOT (docs/X86.md §21/§22):
;;; a plain shard function + a (bin …) declaration, compiled by BIN mode
;;; (tools/x86gen) into a PLAINLY EXECUTABLE Linux ELF — `./arglen hello`
;;; exits with code 5. The entry fn is proven code; the `_start` glue is
;;; byte-moving plumbing under the signed GLUE CONTRACT (models/x86/
;;; elf.shard): argv[1] is copied into the RW segment as [len:8 LE]
;;; [payload], main is called with (rdi = BUF, rsi = len), the exit code
;;; is the low 8 bits of main's result.
;;;
;;; A0 fragment: main ignores the buffer and answers the LENGTH argument
;;; — the whole pipeline (bin decl -> BIN mode -> derived plan -> gates
;;; -> executable) with zero fragment growth. Reading the buffer's BYTES
;;; through std/mem is the A1 rung (mem fns in the image), where the
;;; glue contract's address-bounds clauses get their first citation.
;;;
;;; THE BIN-BOUNDARY LAW (user-ratified 2026-07-08): a bin's cert premise
;;; surface must be exactly what the glue contract supplies — nothing
;;; else. v1 glue supplies no premise families, so the surface must be
;;; EMPTY (the accepts gate's bin arm enforces it; arithmetic premises
;;; mean fixing the types, not signing an exception).

(import "../kernel/stdlib.shard")

;; the program: exit code = length of argv[1] (0 if absent/empty; the
;; glue's MAXLEN clause caps len at 255, so the code is always exact).
;; buf (the payload base) is unused in A0 — it is the A1 rung's argument.
(fn ag_main ((buf Int) (n Int)) Int n)

(bin arglen (entry ag_main))
