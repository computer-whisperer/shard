;;; The BRANCH-IN-LOOP-BODY impgen source pin (rung IF-2): counting
;;; loops whose BODY holds an IIf -- the generated workers mirror the
;;; sqblw/sqblx blueprint probes piece for piece (one case-on of the
;;; shared raw comparison scrutinee inside the induct step, per-region
;;; guard case-ons, per-arm IH cites binding by matching).
;;;
;;; it_ifl_fn = the blueprint program verbatim: seg / loop with a
;;; branch-headed body (store in the then arm) / tail seg.
;;; it_ifl2_fn = the full region structure: a body PREFIX with store
;;; guards, an IEq scrutinee over the walked (banded) accumulator, a
;;; guard-free then arm, and an else arm whose store DUPLICATES the
;;; prefix guards -- the per-region dedup law (never across the
;;; polarity case-on) and the conflated-trap closure of repeated
;;; case-ons, exercised inside the worker.
;;; it_ifl3_fn = the STORE-FREE member (IF-2c): no stores anywhere, so
;;; every guard region is empty -- locks the mixed tier's zero-guard
;;; branch-in-loop path (worker = polarity case-on only) on both
;;; targets.
;;; it_ifl4_fn = NESTED branch in the loop body (rung 3b-b): an inner
;;; IIf heads the outer then arm, its else leaf stores -- the worker
;;; grows a fork-then-guards tree (per-leaf IH cites at hyp depths
;;; 2/4/1, band-decrement checked at every leaf), both targets.
;;; it_ifl5_fn = REPEATED (second top-level) branch in the loop body:
;;; the tree fold rides the store and the second IIf behind the first
;;; fork per arm -- a guards-then-fork run in the then arm; in the
;;; else arm x1 is the constant 11, so the second scrutinee walks
;;; GROUND and the fork FOLDS in the walker (both machines compute
;;; straight through a constant comparison -- no case-on). Three
;;; leaves, both targets.

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")

(use (:: models imp imp *))

(fn it_ifl_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (IIf
            (IBin U32 ILt (ILoc 1) (IConst 9))
            (list
              (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
              (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
            (list (ISet 1 (IConst 11))))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifl2_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 2 (IConst 2))
      (IWhile
        (ILoc 2)
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
          (IIf
            (IBin U32 IEq (ILoc 1) (IConst 5))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2))))
            (list (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7))))
    (ILoc 1)
    U32))

(fn it_ifl3_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (IIf
            (IBin U32 ILt (ILoc 1) (IConst 9))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6))))
            (list (ISet 1 (IConst 11))))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifl4_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (IIf
            (IBin U32 ILt (ILoc 1) (IConst 9))
            (list
              (IIf
                (IBin U32 ILt (ILoc 1) (IConst 5))
                (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6))))
                (list (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))))
            (list (ISet 1 (IConst 11))))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifl5_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 2 (IConst 2))
      (IWhile
        (ILoc 2)
        (list
          (IIf
            (IBin U32 ILt (ILoc 1) (IConst 9))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6))))
            (list (ISet 1 (IConst 11))))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
          (IIf
            (IBin U32 IEq (ILoc 1) (IConst 5))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2))))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn ifx_prog ((f IFn)) IProg (MkIProg (list f) 65536))
