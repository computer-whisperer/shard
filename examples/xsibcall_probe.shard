;;; examples/xsibcall_probe.shard — the GENERATED-CALLEE-CERT hand-play
;;; (docs/X86.md §16 probe): sibling pure functions composed by citation,
;;; in the exact form the emitter will generate. New territory over the
;;; §10 hand-play (xsumsq) and the §15 mem probe: the caller theorems are
;;; in the LOWERED form — spec-call RHS with wrap-bound premises — so the
;;; callee spec functions must OPEN under the closing compute (they are
;;; transparent same-file fns, unlike std/mem's opaque surface), and the
;;; wrap discharge chain runs AFTER the bridge rewrites on the same
;;; premise numbering.
;;;
;;; Module convention (the §15 layout): callee at index 0, caller at 1 =
;;; the entry; entry-first image at encode time. The caller parks its
;;; params off the marshalling homes into r10/r11, marshals each call's
;;; argument into rdi, and for a two-call body evaluates the RIGHT call
;;; first, parking its result in rcx across the left call (rcx passes
;;; through the callee cert verbatim — clobber {rax} is all the callee
;;; touches). The callee body is never computed into.

(import "../kernel/stdlib.shard")
(import "../std/mem")
(import "../models/x86/x86.shard")

(use (:: std mem *))
(use (:: models x86 x86 *))

;; --- the specs -------------------------------------------------------------------

(fn xps_sq ((x Int)) Int (* x x))

(fn xps_chain ((x Int)) Int (+ (* x 3) 5))

(fn xps_sumsq ((a Int) (b Int)) Int (+ (xps_sq a) (xps_sq b)))

(fn xps_use ((a Int)) Int (xps_chain a))

;; --- the callee function literals ---------------------------------------------------
;; Left-spine bodies: the leftmost atom materializes into rax, every
;; further node is a two-operand op on rax — the whole body writes ONLY
;; rax, so the cert's clobber set is {rax} by construction.

(fn xps_sq_f () XFunc
  (MkXFunc 1 (list (XMovRR RAX RDI) (XBin XMul RAX (SReg RDI)))))

(fn xps_chain_f () XFunc
  (MkXFunc
    1
    (list (XMovRR RAX RDI) (XBin XMul RAX (SImm 3)) (XBin XAdd RAX (SImm 5)))))

;; --- the clobber-set certs (the §10 form, emitter-shaped) ---------------------------
;; All fifteen register fields quantified; the result record literal
;; reads off as the clobber set: rax = the body's honest postorder wrap
;; spelling over the entry homes, the other fourteen fields verbatim.

(claim xps_sq_cert
  (goal
    ((c Nat)
     (restfs (List XFunc))
     (mlo Int)
     (mhi Int)
     (mem Mem)
     (rax Int)
     (rcx Int)
     (rdx Int)
     (rbx Int)
     (rbp Int)
     (rsi Int)
     (rdi Int)
     (r8 Int)
     (r9 Int)
     (r10 Int)
     (r11 Int)
     (r12 Int)
     (r13 Int)
     (r14 Int)
     (r15 Int))
    ()
    (=
      (xrun_regs
        (S^ 3 c)
        (MkXModule (Cons (inline xps_sq_f) restfs) mlo mhi)
        0
        (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15)
        mem)
      (Some
        (Pair
          (MkRegs
            (wrap64 (* rdi rdi))
            rcx
            rdx
            rbx
            rbp
            rsi
            rdi
            r8
            r9
            r10
            r11
            r12
            r13
            r14
            r15)
          mem))))
  (steps ((compute both)) refl))

(claim xps_chain_cert
  (goal
    ((c Nat)
     (restfs (List XFunc))
     (mlo Int)
     (mhi Int)
     (mem Mem)
     (rax Int)
     (rcx Int)
     (rdx Int)
     (rbx Int)
     (rbp Int)
     (rsi Int)
     (rdi Int)
     (r8 Int)
     (r9 Int)
     (r10 Int)
     (r11 Int)
     (r12 Int)
     (r13 Int)
     (r14 Int)
     (r15 Int))
    ()
    (=
      (xrun_regs
        (S^ 4 c)
        (MkXModule (Cons (inline xps_chain_f) restfs) mlo mhi)
        0
        (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15)
        mem)
      (Some
        (Pair
          (MkRegs
            (wrap64 (+ (wrap64 (* rdi 3)) 5))
            rcx
            rdx
            rbx
            rbp
            rsi
            rdi
            r8
            r9
            r10
            r11
            r12
            r13
            r14
            r15)
          mem))))
  (steps ((compute both)) refl))

;; --- the caller function literals ---------------------------------------------------

;; sumsq: park a b, evaluate sq(b) first (right operand), park it in rcx,
;; then sq(a), then combine on the result home
(fn xps_sumsq_f () XFunc
  (MkXFunc
    2
    (list
      (XMovRR R10 RDI)
      (XMovRR R11 RSI)
      (XMovRR RDI R11)
      (XCall 0)
      (XMovRR RCX RAX)
      (XMovRR RDI R10)
      (XCall 0)
      (XBin XAdd RAX (SReg RCX)))))

;; use: park a, marshal, single call — the result is already in rax
(fn xps_use_f () XFunc
  (MkXFunc 1 (list (XMovRR R10 RDI) (XMovRR RDI R10) (XCall 0))))

;; --- the composed theorems (the LOWERED form) ---------------------------------------

;; two calls: each stopped fold rewritten by xcall_bridge, its run
;; premise discharged by xps_sq_cert (no cert premises — pure callee);
;; then the standard wrap64_id chain per unique node of the INLINED
;; effective body, postorder; then the spec RHS opens (unfold + closing
;; compute both, which also opens the transparent xps_sq calls).
(claim xps_sumsq_thm
  (goal ((a Int) (b Int) (c Nat) (restfs (List XFunc)) (mem Mem))
    ((= (le 0 (* a a)) True)
     (= (lt (* a a) 18446744073709551616) True)
     (= (le 0 (* b b)) True)
     (= (lt (* b b) 18446744073709551616) True)
     (= (le 0 (+ (* a a) (* b b))) True)
     (= (lt (+ (* a a) (* b b)) 18446744073709551616) True))
    (=
      (xcall_fn_mem
        (S^ 18 c)
        (MkXModule
          (Cons (inline xps_sq_f) (Cons (inline xps_sumsq_f) restfs))
          0
          0)
        1
        (list a b)
        mem)
      (Some (Pair (xps_sumsq a b) mem))))
  (chain
    (steps ((compute lhs (stop xeval_call))))
    (rewrite-with
      (lemma xcall_bridge)
      lr
      lhs
      ((inst f (inline xps_sq_f))
       (inst rs2 (MkRegs (wrap64 (* b b)) 0 0 0 0 b b 0 0 a b 0 0 0 0))
       (inst mem2 mem))
      ((steps ((compute both)) refl)
       (chain
         (rewrite-with (lemma xps_sq_cert) lr lhs () ())
         (steps ((compute both)))
         refl)))
    (steps ((compute lhs (stop xeval_call))))
    (rewrite-with
      (lemma xcall_bridge)
      lr
      lhs
      ((inst f (inline xps_sq_f))
       (inst
         rs2
         (MkRegs (wrap64 (* a a)) (wrap64 (* b b)) 0 0 0 b a 0 0 a b 0 0 0 0))
       (inst mem2 mem))
      ((steps ((compute both)) refl)
       (chain
         (rewrite-with (lemma xps_sq_cert) lr lhs () ())
         (steps ((compute both)))
         refl)))
    (steps ((compute lhs)))
    (have w0 (= (mod (* a a) 18446744073709551616) (* a a))
      (rewrite-with
        (lemma wrap64_id)
        lr
        lhs
        ((inst x (* a a)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w0) lr lhs true ())))
    (have w1 (= (mod (* b b) 18446744073709551616) (* b b))
      (rewrite-with
        (lemma wrap64_id)
        lr
        lhs
        ((inst x (* b b)))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w1) lr lhs true ())))
    (have w2
      (= (mod (+ (* a a) (* b b)) 18446744073709551616) (+ (* a a) (* b b)))
      (rewrite-with
        (lemma wrap64_id)
        lr
        lhs
        ((inst x (+ (* a a) (* b b))))
        ((steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w2) lr lhs true ())))
    (steps ((unfold xps_sumsq rhs) (reduce rhs)))
    (steps ((compute both)))
    refl))

;; single call to the two-node callee: one bridge, then the callee's OWN
;; wrap nodes discharge on the caller side (the cert result carries them
;; into the residue).
(claim xps_use_thm
  (goal ((a Int) (c Nat) (restfs (List XFunc)) (mem Mem))
    ((= (le 0 (* a 3)) True)
     (= (lt (* a 3) 18446744073709551616) True)
     (= (le 0 (+ (* a 3) 5)) True)
     (= (lt (+ (* a 3) 5) 18446744073709551616) True))
    (=
      (xcall_fn_mem
        (S^ 12 c)
        (MkXModule
          (Cons (inline xps_chain_f) (Cons (inline xps_use_f) restfs))
          0
          0)
        1
        (list a)
        mem)
      (Some (Pair (xps_use a) mem))))
  (chain
    (steps ((compute lhs (stop xeval_call))))
    (rewrite-with
      (lemma xcall_bridge)
      lr
      lhs
      ((inst f (inline xps_chain_f))
       (inst
         rs2
         (MkRegs (wrap64 (+ (wrap64 (* a 3)) 5)) 0 0 0 0 0 a 0 0 a 0 0 0 0 0))
       (inst mem2 mem))
      ((steps ((compute both)) refl)
       (chain
         (rewrite-with (lemma xps_chain_cert) lr lhs () ())
         (steps ((compute both)))
         refl)))
    (steps ((compute lhs)))
    (have w0 (= (mod (* a 3) 18446744073709551616) (* a 3))
      (rewrite-with
        (lemma wrap64_id)
        lr
        lhs
        ((inst x (* a 3)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w0) lr lhs true ())))
    (have w1 (= (mod (+ (* a 3) 5) 18446744073709551616) (+ (* a 3) 5))
      (rewrite-with
        (lemma wrap64_id)
        lr
        lhs
        ((inst x (+ (* a 3) 5)))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise w1) lr lhs true ())))
    (steps ((unfold xps_use rhs) (reduce rhs)))
    (steps ((compute both)))
    refl))
