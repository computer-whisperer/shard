;; AST-size generator fixture (issue #1): a small binary tree, its size, and a
;; recursive fn `tcount` carrying a BARE numeric (measure (tsz t)). Each of
;; tcount's two recursive sites needs the measure-proof recipe:
;;   decrease  tsz CHILD < tsz t   (rewrite t=(Nd l r), simp, have nonneg of the
;;                                   OTHER child, farkas)
;;   nonneg    0 <= tsz CHILD      (cite tsz_nonneg)
;; tools/prove should generate examples/measure_tree_demo.auto.shard; the gate
;; then replays it. Fast to check (tiny closure), unlike reader.

(import "../kernel/stdlib.shard")  ; Bool / True / le / Int ops

(type Tr (Lf Int) (Nd Tr Tr))

(fn tsz ((t Tr)) Int
  (measure (struct t))
  (match t
    ((Lf _) 1)
    ((Nd l r) (+ 1 (+ (tsz l) (tsz r))))))

;; defining equation (one structural unfold)
(claim tsz_nd
  (goal ((l Tr) (r Tr)) () (= (tsz (Nd l r)) (+ 1 (+ (tsz l) (tsz r)))))
  (steps ((simp lhs)) refl))

;; nonneg by subterm-induction: the Nd case proves both children's bound from
;; the strong IH via (below), then farkas over the unfolded size.
(claim tsz_nonneg
  (goal ((t Tr)) () (= (le 0 (tsz t)) True))
  (subterm-induct
    t
    (case-on t Tr
      ((case Lf
         (n)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case Nd
         (l r)
         (have (= (le 0 (tsz l)) True)
           (rewrite-with (hyp ih) lr lhs () ((below)) refl)
           (have (= (le 0 (tsz r)) True)
             (rewrite-with (hyp ih) lr lhs () ((below)) refl)
             (steps
               ((rewrite (hyp 0) lr lhs true ())
                (rewrite (lemma tsz_nd) lr lhs true ()))
               (by farkas (list 1 1 1))))))))))

(fn tcount ((t Tr)) Int
  (measure (tsz t))
  (match t
    ((Lf _) 0)
    ((Nd l r) (+ (tcount l) (tcount r)))))
