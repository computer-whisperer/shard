;;; str_demo.shard — std/str CONSUMER probe: the opaque Str interface (issue #2
;;; / refinement-type slice 6). A consumer sees Str abstractly — its inhabitants
;;; are valid UTF-8 by a PROVEN requirement (str_valid), not by trusted
;;; construction discipline. This is the forall-over-type invariant the Rust
;;; newtype ceiling cannot state: every value of the type carries the property.
;;;
;;; Note the validity is a cited FACT, not a computation: utf8_decode over an
;;; opaque Bytes cannot reduce here (no body in the interface). The validator's
;;; computation is pinned separately by examples/utf8_compute.shard.

(import "../kernel/stdlib.shard")
(import "../std/bytes")  ; Bytes — the carrier type
(import "../std/str")  ; the opaque Str + its proven requirements
(use (:: std bytes *))
(use (:: std str *))

;; every inhabitant of Str is valid UTF-8 — str_valid (the interface's PROVEN
;; requirement) cited like any lemma. The headline of the strings arc.
(claim every_str_is_valid
  (goal ((s Str)) () (= (utf8_valid (bytes_of s)) True))
  (rewrite-with (lemma str_valid) lr lhs () () refl))

;; the byte length of a string is non-negative — rides str_len_nonneg through
;; the opaque type.
(claim str_len_is_nonneg
  (goal ((s Str)) () (= (le 0 (str_len s)) True))
  (rewrite-with (lemma str_len_nonneg) lr lhs () () refl))

;; str_len agrees with the byte length of the projection — the length algebra
;; composes across the Str/Bytes boundary.
(claim len_through_projection
  (goal ((s Str)) () (= (str_len s) (blen (bytes_of s))))
  (rewrite-with (lemma str_len_is_blen) lr lhs () () refl))
