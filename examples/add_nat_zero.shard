;;; add_nat_zero.shard — add_n_zero (∀ n : Nat. add n Z = n): a non-trivial
;;; INDUCTION demo on the proof-DSL surface.
;;;
;;; Module-world note: an induction proof must `unfold` the function it reasons
;;; about, so this demo OWNS that function — `add` is defined right here. (A
;;; consumer may NOT unfold another module's opaque `add_nat`; it reasons via
;;; that module's EXPORTED lemmas instead. This file is about the induction
;;; mechanic, so it keeps its subject local — see examples/modules_demo/ for the
;;; consumer-via-interface pattern.)
;;;
;;; Proof shape:
;;;   Z case: (add Z Z) = Z. unfold add opens the body, reduce ι-fires the Z
;;;     arm; lhs is Z. refl closes Z = Z.
;;;   S case: (add (S _f) Z) = (S _f), IH at (hyp 0): (add _f Z) = _f. unfold +
;;;     reduce → lhs (S (add _f Z)); rewrite the IH lhs→ _f; lhs is (S _f). refl.

(import "../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)

;; Nat and add, defined and OWNED here (so the proof may unfold add).
(type Nat (Z) (S Nat))
(fn add ((a Nat) (b Nat)) Nat
  (measure (struct a))
  (match a
    (Z b)
    ((S k) (S (add k b)))))

;; ∀ n : Nat. add n Z = n
(claim add_n_zero
  (goal ((n Nat)) () (= (add n Z) n))
  (induct n
    ((case Z (steps ((unfold add lhs) (reduce lhs)) refl))
     (case S
       (steps
         ((unfold add lhs) (reduce lhs) (rewrite (hyp 0) lr lhs true ()))
         refl)))))
