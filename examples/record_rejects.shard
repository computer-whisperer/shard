;;; record_rejects.shard — MUST-FAIL: a malformed (record …) is refused
;;; loudly, never silently skipped. The duplicate field name makes
;;; rx_fields_of refuse, so the whole file takes the parse-failure path
;;; (accepted-by-absence is the failure mode this guards against).

(import "../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)

(record Dup (x Int) (x Bool))
