;;; examples/lowergen_src.build.shard — the mod.build ENTRY (P4b →
;;; docs/LOWERING.md §6o): assembles the artifact set for
;;; examples/lowergen_src.shard as a native Plan value.
;;;
;;;     (fn build ((t Target)) Plan)     — PURE; the whole interface
;;;
;;; One single-function module per fn (the cert's module literal at
;;; restfs := Nil, no memory), one manifest entry each
;;; (lowered_<fn> over export f0), and CASE vectors whose expected value
;;; is the SOURCE fn applied directly (spec-side semantics, not the
;;; model; u32-safe args only — the certs' premise discipline).
;;; The driver (tools/lowbuild/lowbuild.shard) renders the wire lines.
;;;
;;; The func literals here are copied from the generated certs; the
;;; cert↔binary tie is CHECKED by the BYTETIE gate (tools/bytetie —
;;; docs/LOWERING.md §6i), so drift fails the build.
;;;
;;; RUN IT:  bin/shard_eval run tools/lowbuild/lowbuild.shard examples/lowergen_src.build.shard | node examples/wasm_diff.mjs /dev/stdin

(import "../kernel/stdlib.shard")
(import "lowergen_src.shard")
(use (:: examples lowergen_src *))
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../models/wasm/encode.shard")
(use (:: models wasm encode *))
(import "../meta/plan")
(use (:: meta plan *))

;; --- the binaries: one single-function module per source fn -------------------

(fn m_add1 () WModule
  (MkWModule
    (list (MkFunc 1 0 (list (LocalGet 0) (I32Const 1) (I32Bin BAdd))))
    0))

(fn m_add () WModule
  (MkWModule
    (list (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BAdd))))
    0))

(fn m_sub () WModule
  (MkWModule
    (list (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BSub))))
    0))

(fn m_mix () WModule
  (MkWModule
    (list
      (MkFunc
        2
        0
        (list
          (LocalGet 0)
          (I32Const 2)
          (I32Bin BMul)
          (LocalGet 1)
          (LocalGet 0)
          (I32Bin BSub)
          (I32Bin BAdd))))
    0))

(fn m_id () WModule (MkWModule (list (MkFunc 1 0 (list (LocalGet 0)))) 0))

(fn m_share () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (LocalGet 0)
          (LocalGet 0)
          (I32Bin BMul)
          (LocalSet 1)
          (LocalGet 1)
          (LocalGet 1)
          (I32Bin BAdd))))
    0))

(fn m_nest () WModule
  (MkWModule
    (list
      (MkFunc
        2
        2
        (list
          (LocalGet 0)
          (LocalGet 1)
          (I32Bin BAdd)
          (LocalSet 2)
          (LocalGet 2)
          (I32Const 2)
          (I32Bin BMul)
          (LocalSet 3)
          (LocalGet 3)
          (LocalGet 2)
          (I32Bin BAdd))))
    0))

(fn m_alias () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list (LocalGet 0) (LocalSet 1) (LocalGet 1) (I32Const 1) (I32Bin BAdd))))
    0))

(fn m_gate () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 10)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 1)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_sel () WModule
  (MkWModule
    (list
      (MkFunc
        2
        1
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 0)
                  (I32Bin BEq)
                  (BrIf 0)
                  (LocalGet 1)
                  (I32Const 2)
                  (I32Bin BMul)
                  (LocalSet 2)
                  (Br 1)))
              (LocalGet 1)
              (I32Const 1)
              (I32Bin BAdd)
              (LocalSet 2)))
          (LocalGet 2))))
    0))

(fn m_clamp2 () WModule
  (MkWModule
    (list
      (MkFunc
        1
        2
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 10)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (Block
                    (list
                      (Block
                        (list
                          (LocalGet 0)
                          (I32Const 100)
                          (I32Bin BLtU)
                          (BrIf 0)
                          (I32Const 2)
                          (LocalSet 2)
                          (Br 1)))
                      (I32Const 1)
                      (LocalSet 2)))
                  (LocalGet 2)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 0)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_selsq () WModule
  (MkWModule
    (list
      (MkFunc
        2
        2
        (list
          (LocalGet 0)
          (LocalGet 0)
          (I32Bin BMul)
          (LocalSet 2)
          (Block
            (list
              (Block
                (list
                  (LocalGet 1)
                  (I32Const 0)
                  (I32Bin BEq)
                  (BrIf 0)
                  (LocalGet 2)
                  (LocalGet 1)
                  (I32Bin BAdd)
                  (LocalSet 3)
                  (Br 1)))
              (LocalGet 2)
              (LocalSet 3)))
          (LocalGet 3))))
    0))

(fn m_dec () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (Block
            (list
              (Block
                (list
                  (I32Const 0)
                  (LocalGet 0)
                  (I32Bin BLtU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (LocalGet 0)
              (I32Const 1)
              (I32Bin BSub)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

(fn m_le () WModule
  (MkWModule
    (list
      (MkFunc
        1
        1
        (list
          (Block
            (list
              (Block
                (list
                  (LocalGet 0)
                  (I32Const 10)
                  (I32Bin BLeU)
                  (BrIf 0)
                  (I32Const 0)
                  (LocalSet 1)
                  (Br 1)))
              (I32Const 1)
              (LocalSet 1)))
          (LocalGet 1))))
    0))

;; --- the build entry -------------------------------------------------------------

(fn art ((nm (List Int))) PArt
  (PA
    nm
    (wapp "lowered_" nm)
    "examples/lowergen_out.shard"
    "models/wasm/wasm.shard"
    0
    ""
    "none"))

(fn pv ((args (List Int)) (want Int)) PVec (PV 0 args Nil want Nil))

(fn pmod ((nm (List Int)) (m WModule) (vs (List PVec))) PMod
  (PM nm (enc_module m) (list (art nm)) vs))

(fn build ((t Target)) Plan
  (MkPlan
    (list
      (pmod
        "lg_add1"
        (m_add1)
        (list
          (pv (list 5) (lg_add1 5))
          (pv (list 4294967294) (lg_add1 4294967294))))
      (pmod
        "lg_add"
        (m_add)
        (list
          (pv (list 7 9) (lg_add 7 9))
          (pv (list 4294967290 5) (lg_add 4294967290 5))))
      (pmod
        "lg_sub"
        (m_sub)
        (list
          (pv (list 20 5) (lg_sub 20 5))
          (pv (list 4294967295 4294967295) (lg_sub 4294967295 4294967295))))
      (pmod
        "lg_mix"
        (m_mix)
        (list (pv (list 3 10) (lg_mix 3 10)) (pv (list 4 1000) (lg_mix 4 1000))))
      (pmod
        "lg_id"
        (m_id)
        (list
          (pv (list 42) (lg_id 42))
          (pv (list 4294967295) (lg_id 4294967295))))
      (pmod
        "lg_share"
        (m_share)
        (list (pv (list 5) (lg_share 5)) (pv (list 46000) (lg_share 46000))))
      (pmod
        "lg_nest"
        (m_nest)
        (list
          (pv (list 3 10) (lg_nest 3 10))
          (pv (list 100000 200000) (lg_nest 100000 200000))))
      (pmod
        "lg_alias"
        (m_alias)
        (list
          (pv (list 41) (lg_alias 41))
          (pv (list 4294967294) (lg_alias 4294967294))))
      (pmod
        "lg_gate"
        (m_gate)
        (list (pv (list 5) (lg_gate 5)) (pv (list 10) (lg_gate 10))))
      (pmod
        "lg_sel"
        (m_sel)
        (list (pv (list 0 7) (lg_sel 0 7)) (pv (list 3 7) (lg_sel 3 7))))
      (pmod
        "lg_clamp2"
        (m_clamp2)
        (list
          (pv (list 5) (lg_clamp2 5))
          (pv (list 50) (lg_clamp2 50))
          (pv (list 200) (lg_clamp2 200))))
      (pmod
        "lg_selsq"
        (m_selsq)
        (list (pv (list 3 0) (lg_selsq 3 0)) (pv (list 3 4) (lg_selsq 3 4))))
      (pmod
        "lg_dec"
        (m_dec)
        (list
          (pv (list 5) (lg_dec 5))
          (pv (list 0) (lg_dec 0))
          (pv (list 4294967295) (lg_dec 4294967295))))
      (pmod
        "lg_le"
        (m_le)
        (list
          (pv (list 5) (lg_le 5))
          (pv (list 10) (lg_le 10))
          (pv (list 11) (lg_le 11))
          (pv (list 4294967295) (lg_le 4294967295)))))))
