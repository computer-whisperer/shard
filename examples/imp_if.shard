;;; The BRANCH-TIER impgen source pin (rung IF-1): mixed bodies with a
;;; top-level IIf -- the generated wasm legs mirror the sqbw_probe
;;; blueprint piece for piece (the branch sub-lemma + the singleton
;;; seam at the chain); the x86 legs decline with the honest note
;;; until the branch leg lands (rung 1b).
;;;
;;; it_ifm_fn = the full mixed shape: segment / branch with a store in
;;; the then arm / counting loop / tail segment -- covers the mid-chain
;;; branch piece (segment boundary cites it, it cites the loop
;;; boundary; on x86 the branch leg cites the tail boundary per arm).
;;; it_ift_fn = memful straight-line + TERMINAL branch -- covers the
;;; dispatch widening (a loop-free memful body with a branch routes to
;;; the mixed tier) and the branch piece as the LAST piece.
;;; it_ifs_fn = ADJACENT top-level branches (rung IF-3a): the first
;;; branch seals behind itself (the translator's seal-after-branch
;;; rule) and its leg composes through the sqbr_x sub-lemma -- the
;;; seal is the join; the second branch is the IF-1c terminal leg.
;;; The store prefix seals too (chunk-grain legs), covering the
;;; sealed-flat entry sub-lemma in the same chain.
;;; it_ifn_fn = NESTED branch in a SEALED chunk (rung 3b): it_ifs with
;;; an inner IIf heading the first branch's then arm -- the sub-lemma
;;; walks a case-on TREE (the inner scrutinee case-ons inside the
;;; outer arm; the outer tail's store guards duplicate under both
;;; inner arms; the seal joins every leaf).
;;; it_ifn2_fn = NESTED + REPEATED branches in a TERMINAL leg (rung
;;; 3b): two sequential inner IIfs in the then arm of a
;;; ground-terminated branch leg -- the leg tail folds into every
;;; leaf (five leaves ride the same store guards), one spine call
;;; over the whole tree.
;;; it_ifn3_fn = the rung-3b FENCE lock: a nested-arm branch leg
;;; bounded by a counting loop -- x86 declines loud ("nested branch
;;; in a loop-bounded leg"); wasm generates FULL (its branch
;;; sub-lemmas are position-independent).

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")

(use (:: models imp imp *))

(fn it_ifm_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
      (IIf
        (IBin U32 ILt (ILoc 0) (IConst 9))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ift_fn () IFn
  (MkIFn
    (list U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 IEq (ILoc 1) (IConst 5))
        (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1))))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))))
    (ILoc 1)
    U32))

(fn it_ifs_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (IIf
        (IBin U32 IEq (ILoc 2) (IConst 5))
        (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
        (list (ISet 2 (IConst 7))))
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifn_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (IIf
            (IBin U32 ILt (ILoc 2) (IConst 5))
            (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
            (list (ISet 2 (IConst 7))))
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (IIf
        (IBin U32 IEq (ILoc 2) (IConst 5))
        (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
        (list (ISet 2 (IConst 7))))
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifn2_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (IIf
            (IBin U32 ILt (ILoc 2) (IConst 5))
            (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
            (list (ISet 2 (IConst 7))))
          (IIf
            (IBin U32 IEq (ILoc 1) (IConst 3))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1))))
            (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))))
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6))))
        (list (ISet 1 (IConst 11))))
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ifn3_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (IIf
            (IBin U32 ILt (ILoc 2) (IConst 5))
            (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
            (list (ISet 2 (IConst 7))))
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn ifx_prog ((f IFn)) IProg (MkIProg (list f) 65536))
