;;; The BRANCH-TIER impgen source pin (rung IF-1): mixed bodies with a
;;; top-level IIf -- the generated wasm legs mirror the sqbw_probe
;;; blueprint piece for piece (the branch sub-lemma + the singleton
;;; seam at the chain); the x86 legs decline with the honest note
;;; until the branch leg lands (rung 1b).
;;;
;;; it_ifm_fn = the full mixed shape: segment / branch with a store in
;;; the then arm / counting loop / tail segment -- covers the mid-chain
;;; branch piece (segment boundary cites it, it cites the loop
;;; boundary; on x86 the branch leg cites the tail boundary per arm).
;;; it_ift_fn = memful straight-line + TERMINAL branch -- covers the
;;; dispatch widening (a loop-free memful body with a branch routes to
;;; the mixed tier) and the branch piece as the LAST piece.

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")

(use (:: models imp imp *))

(fn it_ifm_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
      (IIf
        (IBin U32 ILt (ILoc 0) (IConst 9))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (ISet 2 (IConst 3))
      (IWhile
        (ILoc 2)
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
          (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(fn it_ift_fn () IFn
  (MkIFn
    (list U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 IEq (ILoc 1) (IConst 5))
        (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1))))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))))
    (ILoc 1)
    U32))

(fn ifx_prog ((f IFn)) IProg (MkIProg (list f) 65536))
