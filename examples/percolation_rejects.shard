;;; NEGATIVE FIXTURE for the percolation-twin gate (docs/X86.md §49):
;;; arglen's out with a smuggled XSyscall in the claimed body — an
;;; effect-point in a module whose declared surface is empty. bytetie
;;; must REFUSE this file (the corpus negative gate asserts nonzero
;;; exit); it is never kernel-checked, its equation is deliberately
;;; false. DO NOT "fix" it.
(import "../kernel/stdlib.shard")
(import "../models/x86/x86.shard")
(import "../models/x86/encode.shard")
(import "arglen_src.shard")
(use (:: models x86 x86 *))
(use (:: models x86 encode XExport))
(use (:: models x86 encode XX))
(use (:: models x86 encode enc_image))
(use (:: models x86 encode enc_image_ord))
(use (:: models x86 encode img_offs_ord))
(use (:: std mem *))
(use (:: examples arglen_src *))

(claim lowered_ag_main
  (goal ((x0 Int) (x1 Int) (c Nat) (restfs (List XFunc)) (mem Mem)) ()
    (=
      (xcall_fn_mem
        (S^ 5 c)
        (MkXModule
          (Cons (MkXFunc 2 (list (XMovRR RAX RSI) XSyscall)) restfs)
          0
          0)
        0
        (list x0 x1)
        mem)
      (Some (Pair (ag_main x0 x1) mem))))
  (chain (steps ((compute lhs) (unfold ag_main rhs) (reduce rhs))) refl))

(fn arglen_xfuncs () (List XFunc)
  (Cons (MkXFunc 2 (list (XMovRR RAX RSI) XSyscall)) Nil))

(fn arglen_exports () (List XExport) (list (XX "ag_main" 0)))

(fn arglen_entry_bytes ((k Int)) (List Int) (enc_image (arglen_xfuncs) k))

(fn arglen_elf_image () (List Int) (enc_image_ord (arglen_xfuncs)))
(fn arglen_elf_offsets () (List Int) (img_offs_ord (arglen_xfuncs) 0))
