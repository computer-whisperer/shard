;;; examples/add/add_src.shard — the W4b RUNG'S DELIVERABLE (docs/X86.md
;;; §42-§43): the TWO-ARGUMENT bin. `./add 2 3` exits 5 — the entry
;;; decimal-folds BOTH payloads, adds (THE SPEC SPELLS THE MACHINE'S ADD
;;; WRAP, §11's law — two folds can exceed 2^64), and masks to an exit
;;; code. The full value leaves the process on the permanent channel at
;;; W4c, where the entry itself writes stdout through the cited
;;; sys_write shim; this bin pins the TWO-ARG GLUE (argv[2] at BUF2 =
;;; 0x600100; entry receives rdi/rsi/rdx/rcx) and the two-call wrapper
;;; composition (probe examples/xbinadd_probe.shard).

(import "../../kernel/stdlib.shard")
(import "../../std/mem")

(use (:: std mem *))

;; the decimal fold (B1's, verbatim): k payload bytes at p, onto acc a
(fn ad_go ((m Mem) (p Int) (a Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z a)
    ((S k2)
     (ad_go
       m
       (+ p 1)
       (mod
         (-
           (mod
             (+ (mod (* a 10) 18446744073709551616) (mem_get m p))
             18446744073709551616)
           48)
         18446744073709551616)
       k2))))

;; the entry: parse both, add (the spec spells the wrap), mask
(fn ad_main ((m Mem) (p1 Int) (k1 Nat) (p2 Int) (k2 Nat)) Int
  (band
    (mod (+ (ad_go m p1 0 k1) (ad_go m p2 0 k2)) 18446744073709551616)
    255))

(bin add (entry ad_main))
