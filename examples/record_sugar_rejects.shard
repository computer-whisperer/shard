;;; record_sugar_rejects.shard — MUST-FAIL: a (make …) that misses a field
;;; is refused at expansion (all fields required exactly once — construction
;;; exhaustiveness is the point of the sugar). The file takes the
;;; parse-failure path.

(import "../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)

(record Score (points Int) (lives Int))

(fn broken () Score (make Score (points 1)))
