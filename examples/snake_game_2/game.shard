;; ---- step behaviour, by example (ground compute — an executable spec) -------
;; These GROUND demos are a licensed exception to dimension-opacity: their
;; computes reduce the concrete 32s inside in_range (ground examples are
;; exactly where that is the point).
;; 'w' (119 → Up): the head climbs one row, stays Alive (drop_last of the
;; length-1 body is Nil, so motion is unchanged from the head-only game).
(claim step_up_demo
  (goal () ()
    (= (step 119 (init)) (GS (Cons (Pos 2 1) Nil) Up (Pos 4 2) 0 Alive 0)))
  (steps ((unfold init lhs) (compute lhs)) refl))
;; 'd' (100 → Right): the head advances one column.
(claim step_right_demo
  (goal () ()
    (= (step 100 (init)) (GS (Cons (Pos 3 2) Nil) Right (Pos 4 2) 0 Alive 0)))
  (steps ((unfold init lhs) (compute lhs)) refl))
;; 'a' (97 → Left) from col 1 aims at col 0 — the left wall — so the snake
;; FREEZES in place and the status flips to Dead (die+freeze on wall).
(claim step_wall_death_demo
  (goal () ()
    (=
      (step 97 (GS (Cons (Pos 1 1) Nil) Up (Pos 4 2) 0 Alive 0))
      (GS (Cons (Pos 1 1) Nil) Left (Pos 4 2) 0 Dead 0)))
  (steps ((compute lhs)) refl))
;; EATING: the head one cell left of the food steps onto it — the body GROWS
;; (tail kept), the score bumps, and the food respawns at the first free
;; interior cell row-major from (1,1).
(claim step_eat_demo
  (goal () ()
    (=
      (step 100 (GS (Cons (Pos 3 2) Nil) Right (Pos 4 2) 0 Alive 0))
      (GS (Cons (Pos 4 2) (Cons (Pos 3 2) Nil)) Right (Pos 1 1) 1 Alive 0)))
  (steps ((compute lhs)) refl))
;; TAIL-CHASE is legal: a length-4 loop whose head targets the cell its own
;; tail-end is vacating this tick — drop_last frees it before the collision
;; check, so the snake advances (classic snake rule).
(claim step_tail_chase_demo
  (goal () ()
    (=
      (step
        119
        (GS
          (Cons
            (Pos 2 3)
            (Cons (Pos 3 3) (Cons (Pos 3 2) (Cons (Pos 2 2) Nil))))
          Left
          (Pos 6 6)
          0
          Alive
          0))
      (GS
        (Cons (Pos 2 2) (Cons (Pos 2 3) (Cons (Pos 3 3) (Cons (Pos 3 2) Nil))))
        Up
        (Pos 6 6)
        0
        Alive
        0)))
  (steps ((compute lhs)) refl))
;; SELF-COLLISION: with a length-5 body the same move hits a cell that is NOT
;; the tail-end — the snake freezes and dies.
(claim step_self_collision_demo
  (goal () ()
    (=
      (step
        119
        (GS
          (Cons
            (Pos 2 3)
            (Cons
              (Pos 3 3)
              (Cons (Pos 3 2) (Cons (Pos 2 2) (Cons (Pos 1 2) Nil)))))
          Left
          (Pos 6 6)
          0
          Alive
          0))
      (GS
        (Cons
          (Pos 2 3)
          (Cons
            (Pos 3 3)
            (Cons (Pos 3 2) (Cons (Pos 2 2) (Cons (Pos 1 2) Nil)))))
        Up
        (Pos 6 6)
        0
        Dead
        0)))
  (steps ((compute lhs)) refl))

;; ---- input-response: head displacement matches the key --------------------
;; orb_tr closes a "the RIGHT disjunct holds" obligation (orb scrutinizes its
;; LEFT operand, so a True on the right needs the lemma). disp_* reduce the
;; stepped head to a Pos LITERAL under each wasd key's guard facts; cell_* do
;; the same for the observable move_cell displacement — including the
;; (col,row)->(row,col) swap between the game Pos and the on-screen cell. The
;; literal forms are what head_at_finds needs on each side of a step; together
;; they are the size-independent glue of the symbolic move_shown (below, after
;; the detector chain). Later directions carry the PRECEDING guards as False —
;; key_heading/move_cell test the keys in order, so the earlier ifs must
;; collapse before the matching one fires; move_shown's per-key case split
;; supplies exactly these facts.

(claim orb_tr
  (goal ((a Bool)) () (= (orb a True) True))
  (induct a
    ((case True (steps ((compute lhs)) refl))
     (case False (steps ((compute lhs)) refl)))))

(claim disp_w
  (goal ((c Int) (r Int) (key Int) (hd Heading)) ((= (int_eq key 119) True))
    (= (move_head (Pos c r) (key_heading key hd)) (Pos c (- r 1))))
  (steps
    ((compute both) (rewrite (premise 0) lr both true ()) (compute both))
    refl))
(claim disp_s
  (goal ((c Int) (r Int) (key Int) (hd Heading))
    ((= (int_eq key 119) False) (= (int_eq key 115) True))
    (= (move_head (Pos c r) (key_heading key hd)) (Pos c (+ r 1))))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (compute both))
    refl))
(claim disp_a
  (goal ((c Int) (r Int) (key Int) (hd Heading))
    ((= (int_eq key 119) False)
     (= (int_eq key 115) False)
     (= (int_eq key 97) True))
    (= (move_head (Pos c r) (key_heading key hd)) (Pos (- c 1) r)))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (rewrite (premise 2) lr both true ())
     (compute both))
    refl))
(claim disp_d
  (goal ((c Int) (r Int) (key Int) (hd Heading))
    ((= (int_eq key 119) False)
     (= (int_eq key 115) False)
     (= (int_eq key 97) False)
     (= (int_eq key 100) True))
    (= (move_head (Pos c r) (key_heading key hd)) (Pos (+ c 1) r)))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (rewrite (premise 2) lr both true ())
     (rewrite (premise 3) lr both true ())
     (compute both))
    refl))

(claim cell_w
  (goal ((r Int) (c Int) (key Int)) ((= (int_eq key 119) True))
    (= (move_cell (Pair r c) key) (Pair (- r 1) c)))
  (steps
    ((compute both) (rewrite (premise 0) lr both true ()) (compute both))
    refl))
(claim cell_s
  (goal ((r Int) (c Int) (key Int))
    ((= (int_eq key 119) False) (= (int_eq key 115) True))
    (= (move_cell (Pair r c) key) (Pair (+ r 1) c)))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (compute both))
    refl))
(claim cell_a
  (goal ((r Int) (c Int) (key Int))
    ((= (int_eq key 119) False)
     (= (int_eq key 115) False)
     (= (int_eq key 97) True))
    (= (move_cell (Pair r c) key) (Pair r (- c 1))))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (rewrite (premise 2) lr both true ())
     (compute both))
    refl))
(claim cell_d
  (goal ((r Int) (c Int) (key Int))
    ((= (int_eq key 119) False)
     (= (int_eq key 115) False)
     (= (int_eq key 97) False)
     (= (int_eq key 100) True))
    (= (move_cell (Pair r c) key) (Pair r (+ c 1))))
  (steps
    ((compute both)
     (rewrite (premise 0) lr both true ())
     (rewrite (premise 1) lr both true ())
     (rewrite (premise 2) lr both true ())
     (rewrite (premise 3) lr both true ())
     (compute both))
    refl))

;; reflexivity of the observed-cell comparison: the eqdec haves give the
;; abstract int_eq facts, then the comparison folds to True.
(claim ope_refl
  (goal ((r Int) (c Int)) ()
    (= (opt_pair_eq (Some (Pair r c)) (Some (Pair r c))) True))
  (have (= (int_eq r r) True) (by eqdec (list))
    (have (= (int_eq c c) True) (by eqdec (list))
      (steps
        ((unfold opt_pair_eq lhs)
         (reduce lhs)
         (unfold pair_eq lhs)
         (reduce lhs)
         (rewrite (premise 0) lr lhs true ())
         (rewrite (premise 1) lr lhs true ())
         (unfold andb lhs)
         (reduce lhs))
        refl))))
