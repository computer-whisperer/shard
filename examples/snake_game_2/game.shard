;;; game.shard — the PURE GAME layer of the snake_game_2 impl: nouns-to-motion.
;;; The design constants, the input transform `key_heading`, the head motion
;;; `move_head`, the multi-segment transition `step` (eating, growth, the
;;; option-escape food scan), the occupancy invariant `inv`, the start state
;;; `init` — plus their claims: invariant preservation (inv_step + the
;;; drop_last/scan lemma families), the ground step demos, and the
;;; input-response glue (disp_* / cell_* / ope_refl) the renderer chain consumes.
;;;
;;; Layering (this module's impl is split so iteration on one layer never
;;; parses the layers above it):
;;;   game.shard    — state + step + invariant            (this file)
;;;   render.shard  — the renderer + faithfulness lemmas  (imports this)
;;;   snake_io.shard — the play loop + ALL fulfillments   (the entry)
;;; Checking this file standalone proves just the game layer (the contract's
;;; requirements load as obligations and report unmet — that is expected; only
;;; the entry discharges them all).

(import "../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../std/nat.shard")  ; Nat (Z/S)
(import "../../std/order.shard")  ; le_refl / le_trans / `by ord`
(import "mod.req/mod.req.shard")  ; the interface — nouns (GameState/Heading/Pos) + sigs
(import "mod.req/arena.shard")  ; move_cell / opt_pair_eq / orb — the observable vocab

;; ---- design constants -------------------------------------------------------
;; The concrete board size, discharging arena.shard's opaque sigs. OPAQUE IN
;; PROOFS BY DISCIPLINE (like `fuel`): every lemma cites the board_min_size
;; bounds and otherwise treats (board_w)/(board_h) as symbols — no proof may
;; compute or unfold a dimension-bearing term outside the licensed ground spots
;; (board_min_size, the step demos). Changing the size here must re-check the
;; whole contract unchanged; that recheck IS the enforcement.
(fn board_w () Int 32)
(fn board_h () Int 32)

;; ---- boundary transform bodies (shadow the interface sigs on self-check) ---

;; INPUT: one raw key byte -> a heading. Unrecognized keys keep `cur`.
(fn key_heading ((k Int) (cur Heading)) Heading
  (if (int_eq k 119) Up
  (if (int_eq k 115) Down
  (if (int_eq k 97) Left
  (if (int_eq k 100) Right
  cur)))))

(fn notb ((b Bool)) Bool
  (match b
    (True False)
    (False True)))
(fn pos_eq ((p Pos) (q Pos)) Bool
  (match p
    ((Pos a b)
     (match q
       ((Pos c d) (andb (int_eq a c) (int_eq b d)))))))
(fn in_range ((c Int) (r Int)) Bool
  (andb
    (le 1 c)
    (andb (le c (- (board_w) 2)) (andb (le 1 r) (le r (- (board_h) 2))))))

(fn pos_in_range ((p Pos)) Bool
  (match p
    ((Pos c r) (in_range c r))))

(fn pos_member ((p Pos) (b (List Pos))) Bool
  (match b
    (Nil False)
    ((Cons q t) (if (pos_eq q p) True (pos_member p t)))))

(fn drop_last ((b (List Pos))) (List Pos)
  (match b
    (Nil Nil)
    ((Cons p t)
     (match t
       (Nil Nil)
       (_ (Cons p (drop_last t)))))))

(fn all_in_range ((b (List Pos))) Bool
  (match b
    (Nil True)
    ((Cons p t) (if (pos_in_range p) (all_in_range t) False))))

(fn no_dup ((b (List Pos))) Bool
  (match b
    (Nil True)
    ((Cons p t) (if (pos_member p t) False (no_dup t)))))


;; ---- the food scan (option-escape) ------------------------------------------
;; first free interior cell, row-major from (1,1), against occupancy b.
(fn scan_row ((r Int) (c Int) (b (List Pos))) (Option Pos)
  (if (lt (- (board_w) 2) c) None
  (if (pos_member (Pos c r) b) (scan_row r (+ c 1) b)
  (Some (Pos c r)))))

(fn scan_rows ((r Int) (b (List Pos))) (Option Pos)
  (if (lt (- (board_h) 2) r) None
  (match (scan_row r 1 b)
    (None (scan_rows (+ r 1) b))
    ((Some p) (Some p)))))

(fn find_free ((b (List Pos))) (Option Pos) (scan_rows 1 b))

;; soundness carrier: whatever the scan returned is interior and off-b — as a
;; single Bool over the OPTION, so no ctor-injectivity inversion is ever needed.
(fn free_ok ((o (Option Pos)) (b (List Pos))) Bool
  (match o
    (None True)
    ((Some p) (andb (pos_in_range p) (notb (pos_member p b))))))

(fn move_head ((p Pos) (hd Heading)) Pos
  (match p
    ((Pos c r)
     (match hd
       (Up (Pos c (- r 1)))
       (Down (Pos c (+ r 1)))
       (Left (Pos (- c 1) r))
       (Right (Pos (+ c 1) r))))))

;; ---- THE NEW STEP (multi-segment, eat/grow, check-anyway-freeze) ------------
;; Decision tree on the target cell t = move_head h (key_heading k hd):
;;   off-board                -> freeze+Dead          (wall)
;;   t = food:
;;     t on body              -> freeze+Dead          (can't happen under inv;
;;                                                     checked so no_dup is
;;                                                     by-construction)
;;     no free cell for food  -> freeze+Dead          (board full: the food
;;                                                     acts as a wall — the
;;                                                     option-escape, no
;;                                                     pigeonhole proof)
;;     else                   -> EAT: grow (keep tail), score+1, respawn food
;;   t on body-minus-tail-end -> freeze+Dead          (self-collision; the
;;                                                     vacated tail cell is a
;;                                                     legal target)
;;   else                     -> MOVE: advance, drop the tail-end
(fn step ((k Int) (s GameState)) GameState
  (match s
    ((GS body hd food sc st sd)
     (match body
       (Nil s)
       ((Cons h tl)
        (if (pos_in_range (move_head h (key_heading k hd)))
          (if (pos_eq (move_head h (key_heading k hd)) food)
            (if (pos_member (move_head h (key_heading k hd)) (Cons h tl))
              (GS (Cons h tl) (key_heading k hd) food sc Dead sd)
              (match
                (find_free (Cons (move_head h (key_heading k hd)) (Cons h tl)))
                (None (GS (Cons h tl) (key_heading k hd) food sc Dead sd))
                ((Some f1)
                 (GS
                   (Cons (move_head h (key_heading k hd)) (Cons h tl))
                   (key_heading k hd)
                   f1
                   (+ sc 1)
                   Alive
                   sd))))
          (if
            (pos_member
              (move_head h (key_heading k hd))
              (drop_last (Cons h tl)))
            (GS (Cons h tl) (key_heading k hd) food sc Dead sd)
            (GS
              (Cons (move_head h (key_heading k hd)) (drop_last (Cons h tl)))
              (key_heading k hd)
              food
              sc
              Alive
              sd)))
          (GS (Cons h tl) (key_heading k hd) food sc Dead sd)))))))

;; ---- THE NEW INVARIANT (occupancy) -------------------------------------------
;; nonempty body, every segment interior, no self-overlap, food interior and
;; off-body. Unconditional in status; nothing reads heading/score/seed.
(fn inv ((s GameState)) Bool
  (match s
    ((GS body hd food sc st sd)
     (match body
       (Nil False)
       ((Cons h tl)
        (andb
          (all_in_range body)
          (andb
            (no_dup body)
            (andb (pos_in_range food) (notb (pos_member food body))))))))))

;; ---- the start state -------------------------------------------------------
;; Head (col 2, row 2), food (col 4, row 2) — both interior. TRANSPARENT by
;; design (no sig in the interface): the ground demos and the entry's
;; board/moves fulfillments prove their base cases by computing through it.
(fn init () GameState (GS (Cons (Pos 2 2) Nil) Up (Pos 4 2) 0 Alive 0))

;; ---- Bool-conjunction inversion (induct-on-Bool: the false branch's premise
;; ---- reduces to a literal clash, closed by absurd) -------------------------
(claim andb_tl
  (goal ((a Bool) (b Bool)) ((= (andb a b) True)) (= a True))
  (induct a ((case True refl) (case False (absurd (premise 0))))))

(claim andb_tr
  (goal ((a Bool) (b Bool)) ((= (andb a b) True)) (= b True))
  (induct a
    ((case True (steps ((rewrite (premise 0) rl rhs true ()) (simp rhs)) refl))
     (case False (absurd (premise 0))))))

(claim notb_t
  (goal ((b Bool)) ((= (notb b) True)) (= b False))
  (induct b ((case True (absurd (premise 0))) (case False refl))))

;; ---- drop_last preservation (the three list inductions) ---------------------

;; membership-miss survives drop_last (contrapositive of sublist membership).
(claim pm_dl_false
  (goal ((p Pos) (b (List Pos))) ((= (pos_member p b) False))
    (= (pos_member p (drop_last b)) False))
  (induct b
    ((case Nil (steps ((compute lhs)) refl))
     (case Cons
       (q t)
       (induct t
         ((case Nil (steps ((compute lhs)) refl))
          (case Cons
            (q2 t2)
            (case-on (pos_eq q p) Bool
              ((case True
                 (have (= True False)
                   (steps
                     ((rewrite (premise 0) rl rhs true ())
                      (unfold pos_member rhs)
                      (reduce rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (reduce rhs))
                     refl)
                   (absurd (premise 1))))
               (case False
                 (have (= (pos_member p (Cons q2 t2)) False)
                   (steps
                     ((rewrite (premise 0) rl rhs true ())
                      (unfold pos_member rhs)
                      (reduce rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (reduce rhs))
                     refl)
                   (steps
                     ((unfold drop_last lhs)
                      (reduce lhs)
                      (unfold pos_member lhs)
                      (reduce lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (reduce lhs))
                     (rewrite-with
                       (hyp 2)
                       lr
                       lhs
                       ()
                       ((steps ((rewrite (premise 1) lr lhs true ())) refl))
                       refl)))))))))))))

;; containment survives drop_last (a sublist keeps all_in_range).
(claim dl_air
  (goal ((b (List Pos))) ((= (all_in_range b) True))
    (= (all_in_range (drop_last b)) True))
  (induct b
    ((case Nil (steps ((compute lhs)) refl))
     (case Cons
       (p t)
       (induct t
         ((case Nil (steps ((compute lhs)) refl))
          (case Cons
            (q t2)
            (case-on (pos_in_range p) Bool
              ((case False
                 (have (= True False)
                   (steps
                     ((rewrite (premise 0) rl lhs true ())
                      (unfold all_in_range lhs)
                      (reduce lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (reduce lhs))
                     refl)
                   (absurd (premise 1))))
               (case True
                 (have (= (all_in_range (Cons q t2)) True)
                   (steps
                     ((rewrite (premise 0) rl rhs true ())
                      (unfold all_in_range rhs)
                      (reduce rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (reduce rhs))
                     refl)
                   (steps
                     ((unfold drop_last lhs)
                      (reduce lhs)
                      (unfold all_in_range lhs)
                      (reduce lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (reduce lhs))
                     (rewrite-with
                       (hyp 2)
                       lr
                       lhs
                       ()
                       ((steps ((rewrite (premise 1) lr lhs true ())) refl))
                       refl)))))))))))))

;; distinctness survives drop_last (via pm_dl_false on the head's misses).
(claim dl_nodup
  (goal ((b (List Pos))) ((= (no_dup b) True)) (= (no_dup (drop_last b)) True))
  (induct b
    ((case Nil (steps ((compute lhs)) refl))
     (case Cons
       (p t)
       (induct t
         ((case Nil (steps ((compute lhs)) refl))
          (case Cons
            (q t2)
            (case-on (pos_member p (Cons q t2)) Bool
              ((case True
                 (have (= True False)
                   (steps
                     ((rewrite (premise 0) rl lhs true ())
                      (unfold no_dup lhs)
                      (reduce lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (reduce lhs))
                     refl)
                   (absurd (premise 1))))
               (case False
                 (have (= (no_dup (Cons q t2)) True)
                   (steps
                     ((rewrite (premise 0) rl rhs true ())
                      (unfold no_dup rhs)
                      (reduce rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (reduce rhs))
                     refl)
                   (steps
                     ((unfold drop_last lhs)
                      (reduce lhs)
                      (unfold no_dup lhs)
                      (reduce lhs))
                     (rewrite-with
                       (lemma pm_dl_false)
                       lr
                       lhs
                       ()
                       ((steps ((rewrite (hyp 0) lr lhs true ())) refl))
                       (steps
                         ((reduce lhs))
                         (rewrite-with
                           (hyp 2)
                           lr
                           lhs
                           ()
                           ((steps ((rewrite (premise 1) lr lhs true ())) refl))
                           refl)))))))))))))))

;; ---- scan soundness (wf-induct, mirroring the row_find lemma shapes) --------

;; arithmetic helpers (farkas reads goal premises, so these are lemmas — the
;; callers discharge each premise from a case hypothesis; cf. step_nonneg).
(claim le_succ
  (goal ((x Int)) ((= (le 1 x) True)) (= (le 1 (+ x 1)) True))
  (by farkas (list 1 1)))

(claim lt_false_le
  (goal ((a Int) (x Int)) ((= (lt a x) False)) (= (le x a) True))
  (by farkas (list 1 1)))

(claim scan_nonneg
  (goal ((w Int) (x Int)) ((= (lt (- w 2) x) False))
    (= (le 0 (- w (+ x 1))) True))
  (by farkas (list 1 1)))

;; per-row: whatever scan_row yields is interior (row bounds from premises,
;; column bounds from the guard) and off-b (the member check just failed).
(claim scan_row_ok
  (goal ((r Int) (c Int) (b (List Pos)))
    ((= (le 1 r) True) (= (le r (- (board_h) 2)) True) (= (le 1 c) True))
    (= (free_ok (scan_row r c b) b) True))
  (wf-induct (- (board_w) c)
    (case-on (lt (- (board_w) 2) c) Bool
      ((case True
         (steps
           ((unfold scan_row lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (unfold free_ok lhs)
            (reduce lhs))
           refl))
       (case False
         (case-on (pos_member (Pos c r) b) Bool
           ((case True
              (steps
                ((unfold scan_row lhs)
                 (rewrite (hyp 1) lr lhs true ())
                 (reduce lhs)
                 (rewrite (hyp 0) lr lhs true ())
                 (reduce lhs))
                (rewrite-with
                  (hyp 2)
                  lr
                  lhs
                  ()
                  ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                   (steps ((rewrite (premise 1) lr lhs true ())) refl)
                   (rewrite-with
                     (lemma le_succ)
                     lr
                     lhs
                     ((inst x c))
                     ((steps ((rewrite (premise 2) lr lhs true ())) refl))
                     refl)
                   (rewrite-with
                     (lemma scan_nonneg)
                     lr
                     lhs
                     ((inst w (board_w)) (inst x c))
                     ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                     refl)
                   (by ord (list)))
                  refl)))
            (case False
              (steps
                ((unfold scan_row lhs)
                 (rewrite (hyp 1) lr lhs true ())
                 (reduce lhs)
                 (rewrite (hyp 0) lr lhs true ())
                 (reduce lhs)
                 (unfold free_ok lhs)
                 (reduce lhs)
                 (rewrite (hyp 0) lr lhs true ())
                 (unfold pos_in_range lhs)
                 (reduce lhs)
                 (unfold in_range lhs)
                 (rewrite (premise 0) lr lhs true ())
                 (rewrite (premise 1) lr lhs true ())
                 (rewrite (premise 2) lr lhs true ()))
                (rewrite-with
                  (lemma lt_false_le)
                  lr
                  lhs
                  ((inst a (- (board_w) 2)) (inst x c))
                  ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                  (steps ((compute lhs)) refl)))))))))))

;; over rows: chain the per-row fact through the row walk.
(claim scan_rows_ok
  (goal ((r Int) (b (List Pos))) ((= (le 1 r) True))
    (= (free_ok (scan_rows r b) b) True))
  (wf-induct (- (board_h) r)
    (case-on (lt (- (board_h) 2) r) Bool
      ((case True
         (steps
           ((unfold scan_rows lhs)
            (rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (unfold free_ok lhs)
            (reduce lhs))
           refl))
       (case False
         (case-on (scan_row r 1 b) Option
           ((case None
              (steps
                ((unfold scan_rows lhs)
                 (rewrite (hyp 1) lr lhs true ())
                 (reduce lhs)
                 (rewrite (hyp 0) lr lhs true ())
                 (reduce lhs))
                (rewrite-with
                  (hyp 2)
                  lr
                  lhs
                  ()
                  ((rewrite-with
                     (lemma le_succ)
                     lr
                     lhs
                     ((inst x r))
                     ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                     refl)
                   (rewrite-with
                     (lemma scan_nonneg)
                     lr
                     lhs
                     ((inst w (board_h)) (inst x r))
                     ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                     refl)
                   (by ord (list)))
                  refl)))
            (case Some
              (p)
              (have (= (free_ok (Some p) b) True)
                (steps
                  ((rewrite (hyp 0) rl lhs true ()))
                  (rewrite-with
                    (lemma scan_row_ok)
                    lr
                    lhs
                    ()
                    ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                     (rewrite-with
                       (lemma lt_false_le)
                       lr
                       lhs
                       ((inst a (- (board_h) 2)) (inst x r))
                       ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                       refl)
                     (by ord (list)))
                    refl))
                (steps
                  ((unfold scan_rows lhs)
                   (rewrite (hyp 1) lr lhs true ())
                   (reduce lhs)
                   (rewrite (hyp 0) lr lhs true ())
                   (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()))
                  refl))))))))))

;; the entry: find_free starts the walk at row 1.
(claim find_free_ok
  (goal ((b (List Pos))) () (= (free_ok (find_free b) b) True))
  (steps
    ((unfold find_free lhs))
    (rewrite-with
      (lemma scan_rows_ok)
      lr
      lhs
      ((inst r 1) (inst b b))
      ((by ord (list)))
      refl)))

;; CONTAINMENT — step preserves the occupancy invariant. The decision tree is
;; cased leaf by leaf: every freeze leaf returns the body/food unchanged (the
;; invariant is rebuilt verbatim from the inverted conjuncts); the EAT leaf
;; grows by the checked-free target and cites find_free_ok for the respawned
;; food; the MOVE leaf advances by the checked-free target and pushes the
;; conjuncts through drop_last (dl_air / dl_nodup / pm_dl_false). The inversion
;; itself is the standard have-chain of andb_tl/andb_tr cuts discharged by
;; rewrite-rl + compute-both against `inv s`.
(claim inv_step
  (goal ((k Int) (s GameState)) ((= (inv s) True)) (= (inv (step k s)) True))
  (induct s
    ((case GS
       (body hd food sc st sd)
       (induct body
         ((case Nil (absurd (premise 0)))
          (case Cons
            (h tl)
            (have (= (all_in_range (Cons h tl)) True)
              (rewrite-with
                (lemma andb_tl)
                lr
                lhs
                ((inst
                   b
                   (andb
                     (no_dup (Cons h tl))
                     (andb
                       (pos_in_range food)
                       (notb (pos_member food (Cons h tl)))))))
                ((steps
                   ((rewrite (premise 0) rl rhs true ()) (compute both))
                   refl))
                refl)
              (have
                (=
                  (andb
                    (no_dup (Cons h tl))
                    (andb
                      (pos_in_range food)
                      (notb (pos_member food (Cons h tl)))))
                  True)
                (rewrite-with
                  (lemma andb_tr)
                  lr
                  lhs
                  ((inst a (all_in_range (Cons h tl))))
                  ((steps
                     ((rewrite (premise 0) rl rhs true ()) (compute both))
                     refl))
                  refl)
                (have (= (no_dup (Cons h tl)) True)
                  (rewrite-with
                    (lemma andb_tl)
                    lr
                    lhs
                    ((inst
                       b
                       (andb
                         (pos_in_range food)
                         (notb (pos_member food (Cons h tl))))))
                    ((steps ((rewrite (premise 2) lr lhs true ())) refl))
                    refl)
                  (have
                    (=
                      (andb
                        (pos_in_range food)
                        (notb (pos_member food (Cons h tl))))
                      True)
                    (rewrite-with
                      (lemma andb_tr)
                      lr
                      lhs
                      ((inst a (no_dup (Cons h tl))))
                      ((steps ((rewrite (premise 2) lr lhs true ())) refl))
                      refl)
                    (have (= (pos_in_range food) True)
                      (rewrite-with
                        (lemma andb_tl)
                        lr
                        lhs
                        ((inst b (notb (pos_member food (Cons h tl)))))
                        ((steps ((rewrite (premise 4) lr lhs true ())) refl))
                        refl)
                      (have (= (notb (pos_member food (Cons h tl))) True)
                        (rewrite-with
                          (lemma andb_tr)
                          lr
                          lhs
                          ((inst a (pos_in_range food)))
                          ((steps ((rewrite (premise 4) lr lhs true ())) refl))
                          refl)
                        (have (= (pos_member food (Cons h tl)) False)
                          (rewrite-with
                            (lemma notb_t)
                            lr
                            lhs
                            ()
                            ((steps ((rewrite (premise 6) lr lhs true ())) refl))
                            refl)
                          (steps
                            ((unfold step lhs) (reduce lhs))
                            (case-on
                              (pos_in_range (move_head h (key_heading k hd)))
                              Bool
                              ((case False
                                 (steps
                                   ((rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs)
                                    (unfold inv lhs)
                                    (reduce lhs)
                                    (rewrite (premise 1) lr lhs true ())
                                    (rewrite (premise 3) lr lhs true ())
                                    (rewrite (premise 5) lr lhs true ())
                                    (rewrite (premise 7) lr lhs true ())
                                    (compute lhs))
                                   refl))
                               (case True
                                 (steps
                                   ((rewrite (hyp 0) lr lhs true ())
                                    (reduce lhs))
                                   (case-on
                                     (pos_eq
                                       (move_head h (key_heading k hd))
                                       food)
                                     Bool
                                     ((case True
                                        (steps
                                          ((rewrite (hyp 0) lr lhs true ())
                                           (reduce lhs))
                                          (case-on
                                            (pos_member
                                              (move_head h (key_heading k hd))
                                              (Cons h tl))
                                            Bool
                                            ((case True
                                               (steps
                                                 ((rewrite
                                                    (hyp 0)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (reduce lhs)
                                                  (unfold inv lhs)
                                                  (reduce lhs)
                                                  (rewrite
                                                    (premise 1)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (rewrite
                                                    (premise 3)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (rewrite
                                                    (premise 5)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (rewrite
                                                    (premise 7)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (compute lhs))
                                                 refl))
                                             (case False
                                               (steps
                                                 ((rewrite
                                                    (hyp 0)
                                                    lr
                                                    lhs
                                                    true
                                                    ())
                                                  (reduce lhs))
                                                 (case-on
                                                   (find_free
                                                     (Cons
                                                       (move_head
                                                         h
                                                         (key_heading k hd))
                                                       (Cons h tl)))
                                                   Option
                                                   ((case None
                                                      (steps
                                                        ((rewrite
                                                           (hyp 0)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (reduce lhs)
                                                         (unfold inv lhs)
                                                         (reduce lhs)
                                                         (rewrite
                                                           (premise 1)
                                                           lr
                                                           lhs
