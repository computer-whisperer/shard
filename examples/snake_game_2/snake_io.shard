;;; snake_io — the IMPL (private) for the snake_game_2 module. Supplies the
;;; boundary bodies + the play loop, and DISCHARGES the contract's requirements
;;; via `fulfills`. It imports its own interface as an ordinary `.shard` FILE
;;; (ungranted), so each requirement loads as an OBLIGATION; the goals are never
;;; restated here (single source of truth in mod.req.shard).
;;;
;;; This is the FUNGIBLE half: bodies and proofs. Review attention belongs on
;;; mod.req.shard (the signatures, the write_clock axiom, the requirements) —
;;; the checker guarantees this file conforms to it.
;;;
;;; `render` is a real board_w x board_h grid renderer — it draws the bordered
;;; arena with the snake head and food in the interior. The dimensions are the
;;; module's DESIGN CONSTANTS: opaque sigs in arena.shard, concrete bodies
;;; (32 x 32) below. They are opaque BY DISCIPLINE, not mechanism (compute will
;;; happily reduce a nullary body): every lemma treats the size symbolically,
;;; citing the board_min_size bounds and never computing a dimension-bearing
;;; term — only the board_min_size fulfillment and the ground demos reduce the
;;; 32s. The discipline is auditable by re-checking at a different (asymmetric)
;;; size: nothing but those licensed spots may notice. `play_fuel` runs a real
;;; `step` (head-only motion; die+freeze on wall OR food): each tick reads a
;;; key, advances, then renders the POST-step state. The loop stays board-valid
;;; forever because the CONTAINMENT invariant `inv` (length-1 head, interior,
;;; clear of the fixed food) is preserved by `step` (inv_step). The symbolic
;;; (fin-split-free) faithfulness bridge inv -> is_board (frame s) is the
;;; in-progress rebuild; until it lands, frames_are_arenas / frames_are_boards
;;; are honest UNMET obligations in the bin report. Eating/growth
;;; (variable-length body) is the deferred next slice.
;;;
;;; PLAY IT (REPL-style, line-buffered — a key then Enter):
;;;     ./rust_bootstrap/target/release/eval run examples/snake_game_2/snake_io.shard
;;;   w/a/s/d + Enter move the head; any other key + Enter advances in the current
;;;   heading; `q` (or Ctrl-D) quits. The interior is a 30×30 field (cols
;;;   1..30, rows 1..30); the head dies+freezes on a wall OR on the food at
;;;   (4,2). The host backs `key_oracle` with the `read_key` stdin extern
;;;   (eval.shard / eval.rs); the proofs treat key_oracle as uninterpreted, so
;;;   they hold for THIS handler (or any other). Each displayed frame is the
;;;   POST-step state — the immediate response to the key just typed.

(import "../../kernel/stdlib.shard")   ; List / Option / Bool / Pair
(import "../../std/nat.shard")     ; Nat (Z/S)
(import "../../std/order.shard")   ; le_refl / le_trans / `by ord`
(import "mod.req.shard")       ; the interface (ungranted) — requirements as obligations
(import "arena.shard")         ; is_board / all_board / is_arena — the spec vocab the proofs cite

;; ---- design constants -------------------------------------------------------
;; The concrete board size, discharging arena.shard's opaque sigs. OPAQUE IN
;; PROOFS BY DISCIPLINE (like `fuel`): every lemma cites the board_min_size
;; bounds and otherwise treats (board_w)/(board_h) as symbols — no proof may
;; compute or unfold a dimension-bearing term outside the licensed ground spots
;; (board_min_size, the step demos). Changing the size here must re-check the
;; whole contract unchanged; that recheck IS the enforcement.
(fn board_w () Int 32)
(fn board_h () Int 32)

;; ---- private helpers ------------------------------------------------------
(fn app_int ((xs (List Int)) (ys (List Int))) (List Int)   ; list append
  (match xs (Nil ys) ((Cons h t) (Cons h (app_int t ys)))))

;; ---- boundary transform bodies (shadow the interface sigs on self-check) ---

;; INPUT: one raw key byte -> a heading. Unrecognized keys keep `cur`.
(fn key_heading ((k Int) (cur Heading)) Heading
  (if (int_eq k 119) Up
    (if (int_eq k 115) Down
      (if (int_eq k 97) Left
        (if (int_eq k 100) Right cur)))))

;; take the first n bytes (n <= 0 -> Nil). `if`-first so `take 0 = Nil` WITHOUT
;; inspecting the list — that keeps the clear-prefix proof from forcing `render`.
(fn take ((n Int) (xs (List Int))) (List Int)
  (if (le n 0) Nil
    (match xs
      (Nil Nil)
      ((Cons h t) (Cons h (take (- n 1) t))))))

;; OUTPUT: a frame = clear screen (ANSI ESC[2J ESC[H), then the board.
;;
;; The board is a real board_w x board_h grid drawn row-major. A `Pos` is
;; `(Pos col row)`. The perimeter (row 0/board_h-1, col 0/board_w-1) is wall
;; '#'(35); an interior cell holds the snake head 'O'(79) if any body cell sits
;; there, else the food '*'(42), else space(32). `render s` yields the
;; board_h x (board_w + 1)-byte body; `frame` prepends the 7-byte clear. This
;; is the genuine renderer the board requirements force — `is_board (frame s)`
;; holds exactly because every perimeter cell is wall and the head & food are
;; drawn inside.
(fn on_border ((r Int) (c Int)) Bool
  (if (int_eq r 0) True
    (if (int_eq r (- (board_h) 1)) True
      (if (int_eq c 0) True (int_eq c (- (board_w) 1))))))

(fn pos_is ((p Pos) (r Int) (c Int)) Bool
  (match p ((Pos x y) (if (int_eq x c) (int_eq y r) False))))

(fn body_has ((body (List Pos)) (r Int) (c Int)) Bool
  (match body (Nil False) ((Cons p t) (if (pos_is p r c) True (body_has t r c)))))

(fn glyph ((s GameState) (r Int) (c Int)) Int
  (if (on_border r c) 35
    (match s ((GS body hd food sc st sd)
      (if (body_has body r c) 79
        (if (pos_is food r c) 42 32))))))

(fn render_row ((s GameState) (r Int) (c Int)) (List Int)
  (if (lt (- (board_w) 1) c) (Cons 10 Nil)
    (Cons (glyph s r c) (render_row s r (+ c 1)))))

(fn render_rows ((s GameState) (r Int)) (List Int)
  (if (lt (- (board_h) 1) r) Nil
    (app_int (render_row s r 0) (render_rows s (+ r 1)))))

(fn render ((s GameState)) (List Int) (render_rows s 0))
(fn frame ((s GameState)) (List Int)
  (app_int (list 27 91 50 74 27 91 72) (render s)))

;; ---- the game step (head-only motion; die+freeze on wall OR food) ----------
;; A Pos is (Pos col row). Interior = cols 1..board_w-2, rows 1..board_h-2. The
;; head advances one cell in its key-decoded heading; if the target is a wall
;; OR the food cell it FREEZES (head stays, status Dead) — so the head is never
;; drawn on a wall or over the food. `head_ok` is exactly the board invariant:
;; head interior AND head != food. Eating/growth are deferred (food is an
;; obstacle for now), so the snake stays length-1 and `inv` is preserved by
;; construction.
(fn notb ((b Bool)) Bool (match b (True False) (False True)))
(fn pos_eq ((p Pos) (q Pos)) Bool
  (match p ((Pos a b) (match q ((Pos c d) (andb (int_eq a c) (int_eq b d)))))))
(fn in_range ((c Int) (r Int)) Bool
  (andb (le 1 c)
    (andb (le c (- (board_w) 2))
      (andb (le 1 r) (le r (- (board_h) 2))))))
(fn head_ok ((p Pos)) Bool
  (match p ((Pos c r) (andb (in_range c r) (notb (pos_eq (Pos c r) (Pos 4 2)))))))
(fn move_head ((p Pos) (hd Heading)) Pos
  (match p ((Pos c r)
    (match hd
      (Up    (Pos c (- r 1)))
      (Down  (Pos c (+ r 1)))
      (Left  (Pos (- c 1) r))
      (Right (Pos (+ c 1) r))))))
(fn step ((k Int) (s GameState)) GameState
  (match s ((GS body hd food sc st sd)
    (match body
      ((Cons h Nil)
        (if (head_ok (move_head h (key_heading k hd)))
            (GS (Cons (move_head h (key_heading k hd)) Nil) (key_heading k hd) food sc Alive sd)
            (GS (Cons h Nil) (key_heading k hd) food sc Dead sd)))
      (_ s)))))

;; The board invariant the moving snake maintains: length-1, head interior &
;; clear of the (fixed) food. `step` preserves it by construction (the head only
;; ever moves to a head_ok cell, else freezes).
(fn inv ((s GameState)) Bool
  (match s ((GS body hd food sc st sd)
    (match body
      ((Cons h Nil) (andb (head_ok h) (pos_eq food (Pos 4 2))))
      (_ False)))))

;; The food field, as a structural projection. The board worker threads the
;; food's fixed value (Pos 4 2) as a RAW equation `game_food s = (Pos 4 2)`
;; (directly rewritable) — sidestepping the int_eq inversion that pulling food
;; out of inv's Bool `pos_eq` conjunct would otherwise require. `step` never
;; touches food, so this rides the loop unchanged (food_step).
(fn game_food ((s GameState)) Pos (match s ((GS body hd food sc st sd) food)))

;; ---- Bool-conjunction inversion (induct-on-Bool: the false branch's premise
;; ---- reduces to a literal clash, closed by absurd) -------------------------
(claim andb_tl (goal ((a Bool) (b Bool)) ((= (andb a b) True)) (= a True))
  (induct a ((case True refl) (case False (absurd (premise 0))))))

(claim andb_tr (goal ((a Bool) (b Bool)) ((= (andb a b) True)) (= b True))
  (induct a
    ((case True  (steps ((rewrite (premise 0) rl rhs true ()) (simp rhs)) refl))
     (case False (absurd (premise 0))))))

(claim notb_t (goal ((b Bool)) ((= (notb b) True)) (= b False))
  (induct b ((case True (absurd (premise 0))) (case False refl))))

;; CONTAINMENT — step preserves the invariant. inv only inspects head_ok of the
;; head; in the MOVE branch head_ok(target)=True is the case hypothesis, in the
;; FREEZE branch the head is unchanged so inv collapses to inv s — so neither
;; branch needs any positional arithmetic. The non-length-1 bodies contradict
;; inv s (absurd). `food` rides along unchanged, so `pos_eq food (4,2)=True` is
;; pulled straight from inv s in both live branches.
(claim inv_step
  (goal ((k Int) (s GameState)) ((= (inv s) True)) (= (inv (step k s)) True))
  (induct s
    ((case GS (body hd food sc st sd)
       (induct body
         ((case Nil (absurd (premise 0)))
          (case Cons (h tl)
            (induct tl
              ((case Cons (h2 tl2) (absurd (premise 0)))
               (case Nil
                 (steps ((unfold step lhs) (simp lhs))
                   (case-on (head_ok (move_head h (key_heading k hd))) Bool
                     ((case True
                        (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)
                                (rewrite (hyp 0) lr lhs true ()) (simp lhs))
                          (rewrite-with (lemma andb_tr) lr lhs
                            ((inst a (head_ok h)) (inst b (pos_eq food (Pos 4 2))))
                            ((steps ((rewrite (premise 0) rl rhs true ()) (simp rhs)) refl))
                            refl)))
                      (case False
                        (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)
                                (rewrite (premise 0) rl rhs true ()) (simp rhs)) refl)))))))))))))))

;; CONTAINMENT (food) — step never moves the food; it rides every transition
;; unchanged. Same shape as inv_step: the only live branch is the length-1 body,
;; where the head moves or freezes but food is copied verbatim either way.
(claim food_step
  (goal ((k Int) (s GameState)) () (= (game_food (step k s)) (game_food s)))
  (induct s
    ((case GS (body hd food sc st sd)
       (induct body
         ((case Nil (steps ((compute both)) refl))
          (case Cons (h tl)
            (induct tl
              ((case Cons (h2 tl2) (steps ((compute both)) refl))
               (case Nil
                 (steps ((unfold step lhs) (simp lhs))
                   (case-on (head_ok (move_head h (key_heading k hd))) Bool
                     ((case True  (steps ((rewrite (hyp 0) lr lhs true ()) (compute both)) refl))
                      (case False (steps ((rewrite (hyp 0) lr lhs true ()) (compute both)) refl)))))))))))))))

;; ---- step behaviour, by example (ground compute — an executable spec, and
;; ---- the runtime evidence that `step` genuinely MOVES the head) -------------
;; These GROUND demos are a licensed exception to dimension-opacity: their
;; computes reduce the concrete 32s inside in_range (ground examples are
;; exactly where that is the point).
;; 'w' (119 → Up): the head climbs one row, stays Alive.
(claim step_up_demo
  (goal () () (= (step 119 (init)) (GS (Cons (Pos 2 1) Nil) Up (Pos 4 2) 0 Alive 0)))
  (steps ((unfold init lhs) (compute lhs)) refl))
;; 'd' (100 → Right): the head advances one column.
(claim step_right_demo
  (goal () () (= (step 100 (init)) (GS (Cons (Pos 3 2) Nil) Right (Pos 4 2) 0 Alive 0)))
  (steps ((unfold init lhs) (compute lhs)) refl))
;; 'a' (97 → Left) from col 1 aims at col 0 — the left wall — so the head
;; FREEZES in place and the status flips to Dead (die+freeze on wall). The
;; `le 1 0` conjunct kills in_range before the symbolic bounds are consulted,
;; so this one computes without touching the constants at all.
(claim step_wall_death_demo
  (goal () ()
    (= (step 97 (GS (Cons (Pos 1 1) Nil) Up (Pos 4 2) 0 Alive 0))
       (GS (Cons (Pos 1 1) Nil) Left (Pos 4 2) 0 Dead 0)))
  (steps ((compute lhs)) refl))

;; ---- input-response: head displacement matches the key --------------------
;; pos_cell bridges a head Pos (col,row) to the observed (row,col) cell that
;; head_at reports. orb_tr closes the "held in place" disjunct (orb scrutinizes
;; its LEFT operand, so a True on the right needs the case-split). These are
;; the SIZE-INDEPENDENT pieces of the input-response story — they survived the
;; fin-split purge verbatim and become load-bearing again in the symbolic
;; move_shown rebuild.
(fn pos_cell ((p Pos)) (Pair Int Int) (match p ((Pos c r) (Pair r c))))

(claim orb_tr (goal ((a Bool)) () (= (orb a True) True))
  (induct a ((case True (steps ((compute lhs)) refl))
             (case False (steps ((compute lhs)) refl)))))

;; per-direction alignment: under the decoded wasd key, move_head's effect on the
;; head Pos matches the observable move_cell on the (row,col) head — including the
;; col/row swap. Each: compute exposes the int_eq guard, the premise sets it True,
;; compute fires both ifs to the matching direction.
(claim align_w (goal ((key Int) (c Int) (r Int) (hd Heading)) ((= (int_eq key 119) True))
    (= (pos_cell (move_head (Pos c r) (key_heading key hd))) (move_cell (Pair r c) key)))
  (steps ((compute both) (rewrite (premise 0) lr both true ()) (compute both)) refl))
;; (later directions carry the PRECEDING guards as False — key_heading/move_cell
;; test the keys in order, so the earlier ifs must collapse before the matching
;; one fires. move_shown's per-key case split supplies exactly these facts.)
(claim align_s (goal ((key Int) (c Int) (r Int) (hd Heading))
      ((= (int_eq key 119) False) (= (int_eq key 115) True))
    (= (pos_cell (move_head (Pos c r) (key_heading key hd))) (move_cell (Pair r c) key)))
  (steps ((compute both) (rewrite (premise 0) lr both true ())
          (rewrite (premise 1) lr both true ()) (compute both)) refl))
(claim align_a (goal ((key Int) (c Int) (r Int) (hd Heading))
      ((= (int_eq key 119) False) (= (int_eq key 115) False) (= (int_eq key 97) True))
    (= (pos_cell (move_head (Pos c r) (key_heading key hd))) (move_cell (Pair r c) key)))
  (steps ((compute both) (rewrite (premise 0) lr both true ())
          (rewrite (premise 1) lr both true ()) (rewrite (premise 2) lr both true ())
          (compute both)) refl))
(claim align_d (goal ((key Int) (c Int) (r Int) (hd Heading))
      ((= (int_eq key 119) False) (= (int_eq key 115) False)
       (= (int_eq key 97) False) (= (int_eq key 100) True))
    (= (pos_cell (move_head (Pos c r) (key_heading key hd))) (move_cell (Pair r c) key)))
  (steps ((compute both) (rewrite (premise 0) lr both true ())
          (rewrite (premise 1) lr both true ()) (rewrite (premise 2) lr both true ())
          (rewrite (premise 3) lr both true ()) (compute both)) refl))

;; ===========================================================================
;; RENDERER FAITHFULNESS, SYMBOLIC (fin-split-free; dimensions stay opaque).
;;
;; The chain: defining-equation lemmas (guard-premise style — the caller
;; discharges each recursion guard by have+farkas+rewrite, nothing is ever
;; computed through a dimension-bearing term) -> per-row inductions (wf-induct
;; on column/row remainder measures) -> split_rows/render alignment (take_rr /
;; drop_rr / split_render) -> arena_frame: EVERY rendered frame is a complete
;; arena, for any state, at any conforming board size.
;;
;; board_w_lo/board_h_lo are the licensed bound facts (the one unfold of the
;; concrete constants outside board_min_size/the demos); every other lemma
;; treats the dimensions as opaque atoms in farkas arithmetic.
;; ===========================================================================

(claim board_w_lo (goal () () (= (le 6 (board_w)) True))
  (steps ((unfold board_w lhs)) (by ord (list))))
(claim board_h_lo (goal () () (= (le 4 (board_h)) True))
  (steps ((unfold board_h lhs)) (by ord (list))))

(claim rr_stop
  (goal ((s GameState) (r Int) (c Int)) ((= (lt (- (board_w) 1) c) True))
    (= (render_row s r c) (Cons 10 Nil)))
  (steps ((unfold render_row lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs)) refl))

(claim rr_step
  (goal ((s GameState) (r Int) (c Int)) ((= (lt (- (board_w) 1) c) False))
    (= (render_row s r c) (Cons (glyph s r c) (render_row s r (+ c 1)))))
  (steps ((unfold render_row lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs)) refl))

(claim rows_stop
  (goal ((s GameState) (r Int)) ((= (lt (- (board_h) 1) r) True))
    (= (render_rows s r) Nil))
  (steps ((unfold render_rows lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs)) refl))

(claim rows_step
  (goal ((s GameState) (r Int)) ((= (lt (- (board_h) 1) r) False))
    (= (render_rows s r) (app_int (render_row s r 0) (render_rows s (+ r 1)))))
  (steps ((unfold render_rows lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs)) refl))

(claim app_nil (goal ((ys (List Int))) () (= (app_int Nil ys) ys))
  (steps ((unfold app_int lhs) (reduce lhs)) refl))

(claim app_cons
  (goal ((h Int) (t (List Int)) (ys (List Int))) ()
    (= (app_int (Cons h t) ys) (Cons h (app_int t ys))))
  (steps ((unfold app_int lhs) (reduce lhs)) refl))

;; glyph at a border cell is the wall byte.
(claim glyph_wall
  (goal ((s GameState) (r Int) (c Int)) ((= (on_border r c) True))
    (= (glyph s r c) 35))
  (steps ((unfold glyph lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs)) refl))

;; a top/bottom row is wall at EVERY column (the orb premise covers both).
(claim glyph_wall_row
  (goal ((s GameState) (r Int) (c Int))
        ((= (orb (int_eq r 0) (int_eq r (- (board_h) 1))) True))
    (= (glyph s r c) 35))
  (case-on (int_eq r 0) Bool
    ((case True
       (have (= (on_border r c) True)
         (steps ((unfold on_border lhs) (rewrite (hyp 0) lr lhs true ()) (reduce lhs)) refl)
         (rewrite-with (lemma glyph_wall) lr lhs ()
           ((steps ((rewrite (premise 1) lr lhs true ())) refl))
           refl)))
     (case False
       (have (= (int_eq r (- (board_h) 1)) True)
         (steps ((rewrite (premise 0) rl rhs true ())
                 (rewrite (hyp 0) lr rhs true ())
                 (unfold orb rhs) (reduce rhs)) refl)
         (have (= (on_border r c) True)
           (steps ((unfold on_border lhs)
                   (rewrite (hyp 0) lr lhs true ()) (reduce lhs)
                   (rewrite (premise 1) lr lhs true ()) (reduce lhs)) refl)
           (rewrite-with (lemma glyph_wall) lr lhs ()
             ((steps ((rewrite (premise 2) lr lhs true ())) refl))
             refl)))))))

;; a wall row (top or bottom): from column c on, the rendered row is exactly
;; the remaining (board_w - c) wall cells and the newline.
(claim wall_cells_row
  (goal ((s GameState) (r Int) (c Int))
        ((= (orb (int_eq r 0) (int_eq r (- (board_h) 1))) True)
         (= (le 0 c) True)
         (= (le c (board_w)) True))
    (= (wall_cells (- (board_w) c) (render_row s r c)) True))
  (wf-induct (- (board_w) c)
    (case-on (le (- (board_w) c) 0) Bool
      ((case True
         ;; c = board_w: the row is just the newline; wall_cells 0 accepts it.
         (have (= (le (- (board_w) c) 0) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps ((unfold wall_cells lhs)
                   (rewrite (premise 3) lr lhs true ())
                   (reduce lhs))
             (rewrite-with (lemma rr_stop) lr lhs ()
               ((by farkas (list 1 0 0 0 1)))
               (steps ((reduce lhs) (unfold nl lhs))
                 (by eqdec (list)))))))
       (case False
         ;; c < board_w: peel one wall cell and recurse.
         (have (= (le (- (board_w) c) 0) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps ((unfold wall_cells lhs)
                   (rewrite (premise 3) lr lhs true ())
                   (reduce lhs))
             (rewrite-with (lemma rr_step) lr lhs ()
               ((by farkas (list 1 0 0 0 1)))
               (steps ((reduce lhs))
                 (rewrite-with (lemma glyph_wall_row) lr lhs ()
                   ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                   (have (= (int_eq 35 (wall)) True)
                     (steps ((unfold wall lhs)) (by eqdec (list)))
                     (have (= (- (- (board_w) c) 1) (- (board_w) (+ c 1)))
                       (by lia (list))
                       (steps ((rewrite (premise 4) lr lhs true ())
                               (reduce lhs)
                               (rewrite (premise 5) lr lhs true ()))
                         (rewrite-with (hyp 1) lr lhs ()
                           ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                            (by farkas (list 1 0 1 0 0 0 0))
                            (by farkas (list 1 0 0 0 1 0 0))
                            (by farkas (list 1 0 0 0 1 0 0))
                            (by farkas (list 1 0 0 0 0 0 0)))
                           refl))))))))))))))

;; an interior row's middle: from column c (1 <= c <= board_w - 1) on, the
;; rendered row is (board_w - 1 - c) unconstrained cells, then wall, newline.
(claim free_cells_row
  (goal ((s GameState) (r Int) (c Int))
        ((= (int_eq r 0) False)
         (= (int_eq r (- (board_h) 1)) False)
         (= (le 1 c) True)
         (= (le c (- (board_w) 1)) True))
    (= (free_cells (- (- (board_w) 1) c) (render_row s r c)) True))
  (wf-induct (- (- (board_w) 1) c)
    (case-on (le (- (- (board_w) 1) c) 0) Bool
      ((case True
         ;; c = board_w - 1: the closing wall cell, then the newline.
         (have (= (le (- (- (board_w) 1) c) 0) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (have (= (int_eq c 0) False)
             (by farkas (list -1 0 0 1 0 0))
             (have (= (int_eq c (- (board_w) 1)) True)
               (by farkas (list (list 1 0 0 0 1 0 0) (list 1 0 0 0 0 1 0)))
               (have (= (on_border r c) True)
                 (steps ((unfold on_border lhs)
                         (rewrite (premise 0) lr lhs true ()) (reduce lhs)
                         (rewrite (premise 1) lr lhs true ()) (reduce lhs)
                         (rewrite (premise 5) lr lhs true ()) (reduce lhs)
                         (rewrite (premise 6) lr lhs true ())) refl)
                 (steps ((unfold free_cells lhs)
                         (rewrite (premise 4) lr lhs true ())
                         (reduce lhs))
                   (rewrite-with (lemma rr_step) lr lhs ()
                     ((by farkas (list 1 0 0 0 1 0 0 0 0)))
                     (rewrite-with (lemma rr_stop) lr lhs ()
                       ((by farkas (list 1 0 0 0 0 1 0 0 0)))
                       (steps ((reduce lhs))
                         (rewrite-with (lemma glyph_wall) lr lhs ()
                           ((steps ((rewrite (premise 7) lr lhs true ())) refl))
                           (have (= (int_eq 35 (wall)) True)
                             (steps ((unfold wall lhs)) (by eqdec (list)))
                             (have (= (int_eq 10 (nl)) True)
                               (steps ((unfold nl lhs)) (by eqdec (list)))
                               (steps ((rewrite (premise 8) lr lhs true ())
                                       (rewrite (premise 9) lr lhs true ())
                                       (unfold andb lhs)
                                       (reduce lhs))
                                 refl)))))))))))))
       (case False
         ;; c < board_w - 1: skip one unconstrained cell and recurse.
         (have (= (le (- (- (board_w) 1) c) 0) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps ((unfold free_cells lhs)
                   (rewrite (premise 4) lr lhs true ())
                   (reduce lhs))
             (rewrite-with (lemma rr_step) lr lhs ()
               ((by farkas (list 1 0 0 0 0 1)))
               (steps ((reduce lhs))
                 (have (= (- (- (- (board_w) 1) c) 1) (- (- (board_w) 1) (+ c 1)))
                   (by lia (list))
                   (steps ((rewrite (premise 5) lr lhs true ()))
                     (rewrite-with (hyp 1) lr lhs ()
                       ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                        (steps ((rewrite (premise 1) lr lhs true ())) refl)
                        (by farkas (list 1 0 0 1 0 0 0))
                        (by farkas (list 1 0 0 0 0 1 0))
                        (by farkas (list 1 0 0 0 0 1 0))
                        (by farkas (list 1 0 0 0 0 0 0)))
                       refl))))))))))))

;; take/drop with count (board_w - c) + 1 consume EXACTLY one rendered row
;; (from column c) off an app_int; split_render is the corollary at c = 0
;; that split_rows peels whole rendered rows.
(claim take_rr
  (goal ((s GameState) (r Int) (c Int) (Y (List Int)))
        ((= (le 0 c) True) (= (le c (board_w)) True))
    (= (take (+ (- (board_w) c) 1) (app_int (render_row s r c) Y))
       (render_row s r c)))
  (wf-induct (- (board_w) c)
    (case-on (le (- (board_w) c) 0) Bool
      ((case True
         (have (= (le (- (board_w) c) 0) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (rewrite-with (lemma rr_stop) lr lhs ()
             ((by farkas (list 1 0 0 1)))
             (rewrite-with (lemma rr_stop) lr rhs ()
               ((by farkas (list 1 0 0 1)))
               (have (= (le (+ (- (board_w) c) 1) 0) False)
                 (by farkas (list 1 0 1 0))
                 (have (= (- (+ (- (board_w) c) 1) 1) (- (board_w) c))
                   (by lia (list))
                   (steps ((rewrite (lemma app_cons) lr lhs true ())
                           (rewrite (lemma app_nil) lr lhs true ())
                           (unfold take lhs)
                           (rewrite (premise 3) lr lhs true ())
                           (reduce lhs)
                           (rewrite (premise 4) lr lhs true ())
                           (unfold take lhs)
                           (rewrite (premise 2) lr lhs true ())
                           (reduce lhs))
                     refl)))))))
       (case False
         (have (= (le (- (board_w) c) 0) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (rewrite-with (lemma rr_step) lr lhs ()
             ((by farkas (list 1 0 0 1)))
             (rewrite-with (lemma rr_step) lr rhs ()
               ((by farkas (list 1 0 0 1)))
               (have (= (le (+ (- (board_w) c) 1) 0) False)
                 (by farkas (list 1 0 0 1))
                 (have (= (- (+ (- (board_w) c) 1) 1) (+ (- (board_w) (+ c 1)) 1))
                   (by lia (list))
                   (steps ((rewrite (lemma app_cons) lr lhs true ())
                           (unfold take lhs)
                           (rewrite (premise 3) lr lhs true ())
                           (reduce lhs)
                           (rewrite (premise 4) lr lhs true ()))
                     (rewrite-with (hyp 1) lr lhs ()
                       ((by farkas (list 1 1 0 0 0 0))
                        (by farkas (list 1 0 0 1 0 0))
                        (by farkas (list 1 0 0 1 0 0))
                        (by farkas (list 1 0 0 0 0 0)))
                       refl))))))))))))

(claim drop_rr
  (goal ((s GameState) (r Int) (c Int) (Y (List Int)))
        ((= (le 0 c) True) (= (le c (board_w)) True))
    (= (drop (+ (- (board_w) c) 1) (app_int (render_row s r c) Y)) Y))
  (wf-induct (- (board_w) c)
    (case-on (le (- (board_w) c) 0) Bool
      ((case True
         (have (= (le (- (board_w) c) 0) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (rewrite-with (lemma rr_stop) lr lhs ()
             ((by farkas (list 1 0 0 1)))
             (have (= (le (+ (- (board_w) c) 1) 0) False)
               (by farkas (list 1 0 1 0))
               (have (= (- (+ (- (board_w) c) 1) 1) (- (board_w) c))
                 (by lia (list))
                 (steps ((rewrite (lemma app_cons) lr lhs true ())
                         (rewrite (lemma app_nil) lr lhs true ())
                         (unfold drop lhs)
                         (rewrite (premise 3) lr lhs true ())
                         (reduce lhs)
                         (rewrite (premise 4) lr lhs true ())
                         (unfold drop lhs)
                         (rewrite (premise 2) lr lhs true ())
                         (reduce lhs))
                   refl))))))
       (case False
         (have (= (le (- (board_w) c) 0) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (rewrite-with (lemma rr_step) lr lhs ()
             ((by farkas (list 1 0 0 1)))
             (have (= (le (+ (- (board_w) c) 1) 0) False)
               (by farkas (list 1 0 0 1))
               (have (= (- (+ (- (board_w) c) 1) 1) (+ (- (board_w) (+ c 1)) 1))
                 (by lia (list))
                 (steps ((rewrite (lemma app_cons) lr lhs true ())
                         (unfold drop lhs)
                         (rewrite (premise 3) lr lhs true ())
                         (reduce lhs)
                         (rewrite (premise 4) lr lhs true ()))
                   (rewrite-with (hyp 1) lr lhs ()
                     ((by farkas (list 1 1 0 0 0 0))
                      (by farkas (list 1 0 0 1 0 0))
                      (by farkas (list 1 0 0 1 0 0))
                      (by farkas (list 1 0 0 0 0 0)))
                     refl)))))))))))

;; split_rows peels exactly one rendered row off render_rows (r <= board_h-1).
(claim split_render
  (goal ((s GameState) (r Int))
        ((= (le 0 r) True) (= (le r (- (board_h) 1)) True))
    (= (split_rows (render_rows s r))
       (Cons (render_row s r 0) (split_rows (render_rows s (+ r 1))))))
  (rewrite-with (lemma rows_step) lr lhs ()
    ((by farkas (list 1 0 1)))
    (have (= (le 6 (board_w)) True)
      (steps ((rewrite (lemma board_w_lo) lr lhs true ())) refl)
      (rewrite-with (lemma rr_step) lr lhs ()
        ((by farkas (list 1 0 0 1)))
        (have (= (+ (board_w) 1) (+ (- (board_w) 0) 1))
          (by lia (list))
          (steps ((rewrite (lemma app_cons) lr lhs true ())
                  (unfold split_rows lhs)
                  (reduce lhs)
                  (rewrite (lemma app_cons) rl lhs true ()))
            (rewrite-with (lemma rr_step) rl lhs ()
              ((by farkas (list 1 0 0 1 0)))
              (rewrite-with (lemma rr_step) rl lhs ()
                ((by farkas (list 1 0 0 1 0)))
                (steps ((rewrite (premise 3) lr lhs true ()))
                  (rewrite-with (lemma take_rr) lr lhs ()
                    ((by ord (list))
                     (by farkas (list 1 0 0 1 0)))
                    (rewrite-with (lemma drop_rr) lr lhs ()
                      ((by ord (list))
                       (by farkas (list 1 0 0 1 0)))
                      refl)))))))))))

;; split_rows of an empty body is no rows (the defining Nil equation —
;; needed as a REWRITE because unfold cannot reach inside a Match).
(claim split_nil (goal () () (= (split_rows Nil) Nil))
  (steps ((unfold split_rows lhs) (reduce lhs)) refl))

;; a top/bottom rendered row passes wall_row.
(claim wall_row_render
  (goal ((s GameState) (r Int))
        ((= (orb (int_eq r 0) (int_eq r (- (board_h) 1))) True))
    (= (wall_row (render_row s r 0)) True))
  (have (= (le 6 (board_w)) True)
    (steps ((rewrite (lemma board_w_lo) lr lhs true ())) refl)
    (have (= (board_w) (- (board_w) 0))
      (by lia (list))
      (steps ((unfold wall_row lhs)
              (rewrite (premise 2) lr lhs true ()))
        (rewrite-with (lemma wall_cells_row) lr lhs ()
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (by ord (list))
           (by farkas (list 1 0 1 0)))
          refl)))))

;; an interior rendered row passes ends_row.
(claim ends_row_render
  (goal ((s GameState) (r Int))
        ((= (int_eq r 0) False)
         (= (int_eq r (- (board_h) 1)) False))
    (= (ends_row (render_row s r 0)) True))
  (have (= (le 6 (board_w)) True)
    (steps ((rewrite (lemma board_w_lo) lr lhs true ())) refl)
    (have (= (int_eq 0 0) True)
      (by eqdec (list))
      (have (= (on_border r 0) True)
        (steps ((unfold on_border lhs)
                (rewrite (premise 0) lr lhs true ()) (reduce lhs)
                (rewrite (premise 1) lr lhs true ()) (reduce lhs)
                (rewrite (premise 3) lr lhs true ()) (reduce lhs)) refl)
        (rewrite-with (lemma rr_step) lr lhs ()
          ((by farkas (list 1 0 0 1 0 0)))
          (steps ((unfold ends_row lhs) (reduce lhs))
            (rewrite-with (lemma glyph_wall) lr lhs ()
              ((steps ((rewrite (premise 4) lr lhs true ())) refl))
              (have (= (int_eq 35 (wall)) True)
                (steps ((unfold wall lhs)) (by eqdec (list)))
                (have (= (- (board_w) 2) (- (- (board_w) 1) 1))
                  (by lia (list))
                  (have (= (+ 0 1) 1)
                    (by lia (list))
                    (steps ((rewrite (premise 5) lr lhs true ())
                            (unfold andb lhs)
                            (reduce lhs)
                            (rewrite (premise 6) lr lhs true ())
                            (rewrite (premise 7) lr lhs true ()))
                      (rewrite-with (lemma free_cells_row) lr lhs ()
                        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
                         (steps ((rewrite (premise 1) lr lhs true ())) refl)
                         (by ord (list))
                         (by farkas (list 1 0 0 1 0 0 0 0)))
                        refl))))))))))))

;; from row r (1 <= r <= board_h-1) down, the split rendered rows pass
;; mid_rows with the remaining count.
(claim mid_rows_render
  (goal ((s GameState) (r Int))
        ((= (le 1 r) True) (= (le r (- (board_h) 1)) True))
    (= (mid_rows (- (- (board_h) 1) r) (split_rows (render_rows s r))) True))
  (wf-induct (- (- (board_h) 1) r)
    (case-on (le (- (- (board_h) 1) r) 0) Bool
      ((case True
         ;; r = board_h - 1: exactly the bottom wall row remains.
         (have (= (le (- (- (board_h) 1) r) 0) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (have (= (int_eq r (- (board_h) 1)) True)
             (by farkas (list (list 1 0 1 0) (list 1 0 0 1)))
             (have (= (orb (int_eq r 0) (int_eq r (- (board_h) 1))) True)
               (steps ((rewrite (premise 3) lr lhs true ())
                       (rewrite (lemma orb_tr) lr lhs true ())) refl)
               (steps ((unfold mid_rows lhs)
                       (rewrite (premise 2) lr lhs true ())
                       (reduce lhs))
                 (rewrite-with (lemma split_render) lr lhs ()
                   ((by farkas (list 1 1 0 0 0 0))
                    (steps ((rewrite (premise 1) lr lhs true ())) refl))
                   (rewrite-with (lemma rows_stop) lr lhs ()
                     ((by farkas (list 1 0 0 1 0 0)))
                     (steps ((rewrite (lemma split_nil) lr lhs true ())
                             (reduce lhs))
                       (rewrite-with (lemma wall_row_render) lr lhs ()
                         ((steps ((rewrite (premise 4) lr lhs true ())) refl))
                         refl)))))))))
       (case False
         ;; r < board_h - 1: one interior row, then recurse.
         (have (= (le (- (- (board_h) 1) r) 0) False)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps ((unfold mid_rows lhs)
                   (rewrite (premise 2) lr lhs true ())
                   (reduce lhs))
             (rewrite-with (lemma split_render) lr lhs ()
               ((by farkas (list 1 1 0 0))
                (steps ((rewrite (premise 1) lr lhs true ())) refl))
               (steps ((reduce lhs))
                 (rewrite-with (lemma ends_row_render) lr lhs ()
                   ((by farkas (list -1 1 0 0))
                    (by farkas (list 1 0 0 1)))
                   (have (= (- (- (- (board_h) 1) r) 1) (- (- (board_h) 1) (+ r 1)))
                     (by lia (list))
                     (steps ((unfold andb lhs)
                             (reduce lhs)
                             (rewrite (premise 3) lr lhs true ()))
                       (rewrite-with (hyp 1) lr lhs ()
                         ((by farkas (list 1 1 0 0 0))
                          (by farkas (list 1 0 0 1 0))
                          (by farkas (list 1 0 0 1 0))
                          (by farkas (list 1 0 0 0 0)))
                         refl))))))))))))) 

;; the clear prefix: structural over the concrete 7-byte spine (X stays stuck,
;; no dimension fn is reachable — a LICENSED compute).
(claim sc_clear
  (goal ((X (List Int))) ()
    (= (starts_clear (app_int (list 27 91 50 74 27 91 72) X)) True))
  (steps ((compute lhs)) refl))

(claim drop7_clear
  (goal ((X (List Int))) ()
    (= (drop 7 (app_int (list 27 91 50 74 27 91 72) X)) X))
  (steps ((compute lhs)) refl))

;; THE PER-FRAME FACT: every rendered frame is a complete arena — for ANY
;; state, at ANY conforming board size. Fin-split-free and size-symbolic.
(claim arena_frame
  (goal ((s GameState)) () (= (is_arena (frame s)) True))
  (have (= (le 4 (board_h)) True)
    (steps ((rewrite (lemma board_h_lo) lr lhs true ())) refl)
    (have (= (int_eq 0 0) True)
      (by eqdec (list))
      (have (= (orb (int_eq 0 0) (int_eq 0 (- (board_h) 1))) True)
        (steps ((rewrite (premise 1) lr lhs true ())
                (unfold orb lhs) (reduce lhs)) refl)
        (have (= (+ 0 1) 1)
          (by lia (list))
          (have (= (- (board_h) 2) (- (- (board_h) 1) 1))
            (by lia (list))
            (steps ((unfold is_arena lhs)
                    (unfold frame lhs)
                    (unfold frame lhs)
                    (rewrite (lemma sc_clear) lr lhs true ())
                    (rewrite (lemma drop7_clear) lr lhs true ())
                    (unfold andb lhs)
                    (reduce lhs)
                    (unfold render lhs)
                    (unfold is_body lhs))
              (rewrite-with (lemma split_render) lr lhs ()
                ((by ord (list))
                 (by farkas (list 1 1 0 0 0 0)))
                (steps ((reduce lhs))
                  (rewrite-with (lemma wall_row_render) lr lhs ()
                    ((steps ((rewrite (premise 2) lr lhs true ())) refl))
                    (steps ((unfold andb lhs)
                            (reduce lhs)
                            (rewrite (premise 3) lr lhs true ())
                            (rewrite (premise 4) lr lhs true ()))
                      (rewrite-with (lemma mid_rows_render) lr lhs ()
                        ((by ord (list))
                         (by farkas (list 1 1 0 0 0 0)))
                        refl))))))))))))

;; ---- the world / play loop ------------------------------------------------
(fn w_clock ((w World)) Int (match w ((World n) n)))

;; The bounded play loop on an INT fuel: while fuel > 0, read a key (oracle,
;; which THREADS the world — clock + input trace); idle -> stop; else STEP on the
;; key and WRITE the POST-step frame `(frame (step key s))`, recursing on (f - 1)
;; with `(step key s)`. Rendering the post-step state (not the pre-step `s`) is
;; what makes each frame the RESPONSE to the key just read — forced by the
;; io_input_moves requirement. key_oracle and write are both clock effects per
;; tick. Int fuel so the runtime budget can be countably large; the proofs use
;; WfInduct on the fuel measure.
(fn play_fuel ((f Int) (s GameState) (w World)) World
  (if (lt 0 f)
      (match (key_oracle w)
        ((Pair None w1)       w1)
        ((Pair (Some key) w1) (play_fuel (- f 1) (step key s) (write (frame (step key s)) w1))))
      w))

;; ---- the executable -------------------------------------------------------
;; `fuel` is the opaque global step budget — a large Int at RUN, abstract in
;; CHECK (the proof cites the ∀-fuel lemma at it, never reducing it). `main` is
;; the entry the contract is about — it runs the private `play_fuel` worker from
;; `init` for `fuel` steps.
(fn fuel () Int 1000000000)                             ; large budget (opaque in proofs)
(fn init () GameState (GS (Cons (Pos 2 2) Nil) Up (Pos 4 2) 0 Alive 0))   ; head (col2,row2), food (col4,row2) — both interior
(fn main ((w World)) World (play_fuel (fuel) (init) w))

;; ===========================================================================
;; FULFILLMENTS — discharge the contract's requirements.
;; ===========================================================================

;; INPUT BOUNDARY — documented keys decode to their headings.
(fulfills io_key_w (steps ((unfold key_heading lhs) (simp lhs)) refl))
(fulfills io_key_a (steps ((unfold key_heading lhs) (simp lhs)) refl))
(fulfills io_key_s (steps ((unfold key_heading lhs) (simp lhs)) refl))
(fulfills io_key_d (steps ((unfold key_heading lhs) (simp lhs)) refl))

;; An unrecognized key is inert: collapse each guard via its disequality.
(fulfills io_key_inert
  (steps ((unfold key_heading lhs)
          (rewrite (premise 0) lr lhs true ())   ; int_eq k 119 -> False
          (rewrite (premise 1) lr lhs true ())   ; int_eq k 115 -> False
          (rewrite (premise 2) lr lhs true ())   ; int_eq k 97  -> False
          (rewrite (premise 3) lr lhs true ())   ; int_eq k 100 -> False
          (simp lhs))                            ; if False .. -> cur
    refl))

;; OUTPUT BOUNDARY — the first 7 bytes of any frame clear the screen.
;; compute (ungated) drives frame -> app_int -> take to NF; `take 0` returns Nil
;; before touching `render s`, so the open `s` never blocks reduction.
(fulfills io_frame_clears
  (steps ((compute lhs)) refl))

;; RUN BOUNDARY — clock monotonicity, now stated over MAIN.
;;
;; WfInduct's termination obligation for the (- f 1) recursion: from 0 < f the
;; predecessor is non-negative. farkas reads goal PREMISES, so this is a lemma
;; (its premise `lt 0 f` is then discharged from the case hypothesis).
(claim step_nonneg
  (goal ((x Int)) ((= (lt 0 x) True)) (= (le 0 (- x 1)) True))
  (by farkas (list 1 1)))

;; The private ∀-fuel WORKER lemma: monotone for EVERY Int fuel, by WELL-FOUNDED
;; induction on the fuel measure `f`. case-on (lt 0 f): the base (f<=0) returns
;; w; the step writes once (write_clock) and recurses on (f-1), chaining the IH
;; (Hyp 2) via le_trans. Citing the IH discharges 0<=f-1 (step_nonneg, premise
;; from the lt-hyp at Hyp 1) and f-1<f (ord). The once-proven, fuel-uniform fact.
(claim play_clock_mono
  (goal ((f Int) (s GameState) (w World)) ()
    (= (le (w_clock w) (w_clock (play_fuel f s w))) True))
  (wf-induct f
    (case-on (lt 0 f) Bool
      ((case False
         (steps ((unfold play_fuel lhs) (rewrite (hyp 0) lr lhs true ()) (simp lhs))
           (by ord (list))))
       (case True
         (steps ((unfold play_fuel lhs) (rewrite (hyp 0) lr lhs true ()) (simp lhs))
           (case-on (key_oracle w) Pair
             ((case Pair (o w1)
                (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs))
                  (case-on o Option
                    ;; hyps now: 0 o-eq, 1 pair-eq, 2 lt-fact, 3 IH
                    ((case None
                       ;; loop returns w1; w_clock w1 = w_clock w + 1 (key_clock)
                       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs))
                         (rewrite-with (lemma key_clock) lr lhs ((inst w w) (inst o o) (inst w1 w1))
                           ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                           (by ord (list)))))
                     (case Some (key)
                       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs))
                         (rewrite-with (lemma le_trans) lr lhs
                           ((inst b (w_clock (write (frame (step key s)) w1))))
                           ;; prem1: w_clock w <= w_clock(write (frame s) w1) = (w_clock w +1)+1
                           ((steps ((rewrite (lemma write_clock) lr lhs true ()))
                              (rewrite-with (lemma key_clock) lr lhs ((inst w w) (inst o o) (inst w1 w1))
                                ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                                (by ord (list))))
                            ;; prem2: the IH at (f-1, step key s, write (frame s) w1)
                            (rewrite-with (hyp 3) lr lhs ()
                              ((rewrite-with (lemma step_nonneg) lr lhs ((inst x f))
                                 ((steps ((rewrite (hyp 2) lr lhs true ())) refl))
                                 refl)
                               (by ord (list)))
                              refl))
                           refl)))))))))))))))

;; THE CONTRACT REQUIREMENT, over main: unfold `main` to expose
;; `play_fuel (fuel) (init) w`, then cite the worker lemma INSTANTIATED at the
;; opaque `fuel`. The proof never reduces `fuel` — it is O(1) in the runtime
;; budget. This is the whole point: the requirement is about main, proven
;; uniformly in fuel.
(fulfills main_clock_mono
  (steps ((unfold main lhs)
          (rewrite (lemma play_clock_mono) lr lhs true ()))
    refl))

;; ===========================================================================
;; OUTPUT-CONTENT BOUNDARY — a complete arena / board every update.
;;
;; The shape (shared by arena and board): each tick the loop WRITES one frame,
;; which `write_output` appends to the log. So the log only ever grows by a
;; snoc, and the spec predicate over the log (`all_arena`/`all_board`) is
;; preserved iff the appended frame satisfies the per-frame predicate. Two
;; ingredients:
;;   1. a SNOC lemma — folding the predicate over `append xs (Cons y Nil)`;
;;   2. a per-frame fact — `is_arena (frame s)` / `is_board (frame s)`, threaded
;;      as a worker premise and discharged at the concrete `init` (compute).
;; The worker then mirrors play_clock_mono: WfInduct on fuel, cite the IH after
;; the write — here with NO transitivity, since the goal IS the IH conclusion.
;; ===========================================================================

;; ---- snoc lemmas: fold the spec predicate over a one-element append ---------
;; `append` is opaque (std/list) so it is peeled by its defining equations;
;; the per-element guard `is_arena h` / `is_board h` is abstract, so each step
;; case-splits it — both branches then close by refl (no Absurd, no premises,
;; so the IH is a plain equation).
(claim all_arena_snoc
  (goal ((xs (List (List Int))) (y (List Int))) ()
    (= (all_arena (append xs (Cons y Nil)))
       (if (all_arena xs) (is_arena y) False)))
  (induct xs
    ((case Nil
       (steps ((rewrite (lemma append_nil_left) lr lhs true ()) (simp both))
         (case-on (is_arena y) Bool
           ((case True  (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))
            (case False (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))))))
     (case Cons (h t)
       (steps ((rewrite (lemma append_cons) lr lhs true ())
               (simp lhs)
               (rewrite (hyp 0) lr lhs true ())
               (simp rhs))
         (case-on (is_arena h) Bool
           ((case True  (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl))
            (case False (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl)))))))))

(claim all_board_snoc
  (goal ((xs (List (List Int))) (y (List Int))) ()
    (= (all_board (append xs (Cons y Nil)))
       (if (all_board xs) (is_board y) False)))
  (induct xs
    ((case Nil
       (steps ((rewrite (lemma append_nil_left) lr lhs true ()) (simp both))
         (case-on (is_board y) Bool
           ((case True  (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))
            (case False (steps ((rewrite (hyp 0) lr both true ()) (simp lhs)) refl))))))
     (case Cons (h t)
       (steps ((rewrite (lemma append_cons) lr lhs true ())
               (simp lhs)
               (rewrite (hyp 0) lr lhs true ())
               (simp rhs))
         (case-on (is_board h) Bool
           ((case True  (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl))
            (case False (steps ((rewrite (hyp 0) lr both true ()) (simp both)) refl)))))))))


;; ===========================================================================
;; PENDING REBUILD — frames_are_boards.
;;
;; The fin-split enumeration proofs (board_from_inv / head_at_finds / board_ok
;; / move_shown) were REMOVED when the board went parametric: fin-split needs
;; literal bounds, and enumerating a 30×30 interior was never the right shape.
;; frames_are_arenas is re-proven below on the symbolic arena_frame chain;
;; frames_are_boards (the entity detectors) is the in-progress remainder and
;; stays an honest UNMET obligation in the bin report until it lands.
;; ===========================================================================


;; ---- the ∀-fuel arena worker: every written frame is an arena --------------
;; The play loop only ever appends `frame (step key s)` to the output log, and
;; arena_frame says ANY rendered frame is an arena — so the all_arena invariant
;; rides the loop with no per-state premise at all. WfInduct on fuel; the
;; ι-only `reduce` replaces the old `simp` so nothing ever δ-unfolds the frame
;; inside write's arguments (at 32×32 that would concretize ~1k stuck cells).
(claim play_arena_preserve
  (goal ((f Int) (s GameState) (w World))
        ((= (all_arena (w_output w)) True))
    (= (all_arena (w_output (play_fuel f s w))) True))
  (wf-induct f
    (case-on (lt 0 f) Bool
      ((case False
         (steps ((unfold play_fuel lhs) (rewrite (hyp 0) lr lhs true ()) (reduce lhs)
                 (rewrite (premise 0) lr lhs true ())) refl))
       (case True
         (steps ((unfold play_fuel lhs) (rewrite (hyp 0) lr lhs true ()) (reduce lhs))
           (case-on (key_oracle w) Pair
             ((case Pair (o w1)
                (steps ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                  (case-on o Option
                    ;; hyps: 0 o-eq, 1 pair-eq, 2 lt-fact, 3 IH
                    ((case None
                       (steps ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (rewrite-with (lemma key_output) lr lhs ((inst w w) (inst o o) (inst w1 w1))
                           ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                           (steps ((rewrite (premise 0) lr lhs true ())) refl))))
                     (case Some (key)
                       (steps ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (rewrite-with (hyp 3) lr lhs ()
                           ;; IH premise: the log stays all_arena after the write —
                           ;; write_output + snoc; key_output folds w1's log to w's;
                           ;; the appended frame is an arena by arena_frame.
                           ((steps ((rewrite (lemma write_output)   lr lhs true ())
                                    (rewrite (lemma all_arena_snoc) lr lhs true ()))
                              (rewrite-with (lemma key_output) lr lhs ((inst w w) (inst o o) (inst w1 w1))
                                ((steps ((rewrite (hyp 1) lr lhs true ())) refl))
                                (steps ((rewrite (premise 0) lr lhs true ())
                                        (rewrite (lemma arena_frame) lr lhs true ())
                                        (reduce lhs)) refl)))
                            (rewrite-with (lemma step_nonneg) lr lhs ((inst x f))
                              ((steps ((rewrite (hyp 2) lr lhs true ())) refl)) refl)
                            (by ord (list)))
                           refl)))))))))))))))

;; R-ARENA, over main: cite the worker at s=init with the requirement's own
;; log premise. fuel stays opaque (cited, never reduced); the per-frame fact
;; needs NO init-specific reasoning — arena_frame covers every state.
(fulfills frames_are_arenas
  (steps ((unfold main lhs))
    (rewrite-with (lemma play_arena_preserve) lr lhs ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl))
      refl)))

;; ---- design-constant bound: the ONE fulfillment licensed to reduce the 32s --
(fulfills board_min_size
  (steps ((unfold board_w lhs) (unfold board_h lhs) (compute lhs)) refl))
