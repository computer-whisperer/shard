                                               ((rewrite (hyp 1) lr lhs true ()))
                                               refl))
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ()))
                                              refl))
                                          (rewrite-with
                                            (lemma shown_move)
                                            lr
                                            lhs
                                            ((inst hc hcol)
                                             (inst hr hrow)
