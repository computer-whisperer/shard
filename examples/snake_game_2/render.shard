;; ===========================================================================
;; INPUT-RESPONSE, SYMBOLIC — move_shown: across one tick, a wasd key is
;; visible on screen as a one-cell head displacement in that key's direction,
;; or a hold (the move was blocked: wall, self-collision, or a full board).
;; Stated and proven over the rendered frames only, for ANY body shape, at
;; any conforming board size.
;;
;; Factoring: shown_move / shown_hold are the two shapes of the per-tick fact
;; over LITERAL heads and ABSTRACT TAILS — "the frames show heads one
;; move_cell apart" / "the frames show the same head" — each taking in_range
;; premises and doing the bound extraction + head_at_finds work once.
;; move_shown case-splits on the key, then walks step's decision tree
;; (off-board / eat: blocked, board-full, grown / self-collision / move),
;; reduces the stepped head to a literal via disp_* (cell_* supplying the
;; displacement equation), and hands each of the 25 leaves to the right
;; workhorse. This is the per-tick fact the io_input_moves chain consumes.
;; ===========================================================================

(claim shown_move
  (goal
    ((hc Int)
     (hr Int)
     (nc Int)
     (nr Int)
     (tl (List Pos))
     (tl2 (List Pos))
     (hd Heading)
     (hd2 Heading)
     (food Pos)
     (food2 Pos)
     (sc Int)
     (sc2 Int)
     (st Status)
     (st2 Status)
     (sd Int)
     (sd2 Int)
     (k Int))
    ((= (in_range hc hr) True)
     (= (in_range nc nr) True)
     (= (move_cell (Pair hr hc) k) (Pair nr nc))
     (= (is_wasd k) True))
    (=
      (step_shows
        (frame (GS (Cons (Pos hc hr) tl) hd food sc st sd))
        (frame (GS (Cons (Pos nc nr) tl2) hd2 food2 sc2 st2 sd2))
        k)
      True))
  (have (= (le 1 hc) True)
    (rewrite-with
      (lemma andb_tl)
