(claim shown_hold
  (goal
    ((hc Int)
     (hr Int)
     (hd Heading)
     (hd2 Heading)
     (food Pos)
     (food2 Pos)
     (sc Int)
     (sc2 Int)
     (st Status)
     (st2 Status)
     (sd Int)
     (sd2 Int)
     (k Int))
    ((= (head_ok (Pos hc hr)) True))
    (=
      (step_shows
        (frame (GS (Cons (Pos hc hr) Nil) hd food sc st sd))
        (frame (GS (Cons (Pos hc hr) Nil) hd2 food2 sc2 st2 sd2))
        k)
      True))
  (have (= (in_range hc hr) True)
    (rewrite-with
      (lemma andb_tl)
      lr
      lhs
      ((inst a (in_range hc hr)) (inst b (notb (pos_eq (Pos hc hr) (Pos 4 2)))))
      ((steps
         ((rewrite (premise 0) rl rhs true ())
          (unfold head_ok rhs)
          (reduce rhs))
         refl))
      refl)
    (have (= (le 1 hc) True)
      (rewrite-with
        (lemma andb_tl)
        lr
        lhs
        ((inst a (le 1 hc))
         (inst
           b
           (andb
             (le hc (- (board_w) 2))
             (andb (le 1 hr) (le hr (- (board_h) 2))))))
        ((steps
           ((rewrite (premise 1) rl rhs true ())
            (unfold in_range rhs)
            (reduce rhs))
           refl))
        refl)
      (have
        (=
          (andb
            (le hc (- (board_w) 2))
            (andb (le 1 hr) (le hr (- (board_h) 2))))
          True)
        (rewrite-with
          (lemma andb_tr)
          lr
          lhs
          ((inst a (le 1 hc))
           (inst
             b
             (andb
               (le hc (- (board_w) 2))
               (andb (le 1 hr) (le hr (- (board_h) 2))))))
          ((steps
             ((rewrite (premise 1) rl rhs true ())
              (unfold in_range rhs)
              (reduce rhs))
