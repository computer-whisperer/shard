                        (rewrite (hyp 0) lr lhs true ())
                        (reduce lhs))
                       refl))))))))))))

(claim move_shown
  (goal ((k Int) (s GameState)) ((= (inv s) True))
    (= (step_shows (frame s) (frame (step k s)) k) True))
  (induct s
    ((case GS
       (body hd food sc st sd)
       (induct body
         ((case Nil (absurd (premise 0)))
          (case Cons
            (h tl)
            (induct tl
              ((case Cons (h2 tl2) (absurd (premise 0)))
               (case Nil
                 (induct h
                   ((case Pos
                      (hcol hrow)
                      (have (= (head_ok (Pos hcol hrow)) True)
                        (rewrite-with
                          (lemma andb_tl)
                          lr
                          lhs
                          ((inst a (head_ok (Pos hcol hrow)))
                           (inst b (pos_eq food (Pos 4 2))))
                          ((steps
                             ((rewrite (premise 0) rl rhs true ())
                              (unfold inv rhs)
                              (reduce rhs))
                             refl))
                          refl)
                        (case-on (int_eq k 119) Bool
                          ((case True
                             (steps
                               ((unfold step lhs) (reduce lhs))
                               (case-on
                                 (head_ok
                                   (move_head
                                     (Pos hcol hrow)
                                     (key_heading k hd)))
                                 Bool
                                 ((case True
                                    (steps
                                      ((rewrite (hyp 0) lr lhs true ())
                                       (reduce lhs))
                                      (rewrite-with
                                        (lemma disp_w)
                                        lr
                                        lhs
                                        ((inst c hcol)
                                         (inst r hrow)
                                         (inst key k)
                                         (inst hd hd))
                                        ((steps
                                           ((rewrite (hyp 1) lr lhs true ()))
                                           refl))
                                        (have
                                          (=
                                            (head_ok (Pos hcol (- hrow 1)))
                                            True)
                                          (rewrite-with
                                            (lemma disp_w)
                                            rl
                                            lhs
                                            ((inst c hcol)
                                             (inst r hrow)
                                             (inst key k)
