          refl)
        (have (= (le hc (- (board_w) 2)) True)
          (rewrite-with
            (lemma andb_tl)
            lr
            lhs
            ((inst a (le hc (- (board_w) 2)))
             (inst b (andb (le 1 hr) (le hr (- (board_h) 2)))))
            ((steps ((rewrite (premise 3) lr lhs true ())) refl))
            refl)
          (have (= (andb (le 1 hr) (le hr (- (board_h) 2))) True)
            (rewrite-with
              (lemma andb_tr)
              lr
              lhs
              ((inst a (le hc (- (board_w) 2)))
               (inst b (andb (le 1 hr) (le hr (- (board_h) 2)))))
              ((steps ((rewrite (premise 3) lr lhs true ())) refl))
              refl)
            (have (= (le 1 hr) True)
              (rewrite-with
                (lemma andb_tl)
                lr
                lhs
                ((inst a (le 1 hr)) (inst b (le hr (- (board_h) 2))))
                ((steps ((rewrite (premise 5) lr lhs true ())) refl))
                refl)
              (have (= (le hr (- (board_h) 2)) True)
                (rewrite-with
                  (lemma andb_tr)
                  lr
                  lhs
                  ((inst a (le 1 hr)) (inst b (le hr (- (board_h) 2))))
                  ((steps ((rewrite (premise 5) lr lhs true ())) refl))
                  refl)
                (case-on (is_wasd k) Bool
                  ((case True
                     (steps
                       ((unfold step_shows lhs)
                        (rewrite (hyp 0) lr lhs true ())
                        (reduce lhs))
                       (rewrite-with
                         (lemma head_at_finds)
                         lr
                         lhs
                         ((inst hc hc)
                          (inst hr hr)
                          (inst hd hd2)
                          (inst food food2)
                          (inst sc sc2)
                          (inst st st2)
                          (inst sd sd2))
                         ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                          (steps ((rewrite (premise 4) lr lhs true ())) refl)
                          (steps ((rewrite (premise 6) lr lhs true ())) refl)
                          (steps ((rewrite (premise 7) lr lhs true ())) refl))
