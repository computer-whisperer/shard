;;; snake_io.req — the CONTRACT for the snake game's I/O BOUNDARY.
;;;
;;; A second take on the requirement-isolation experiment (see
;;; ../snake_game/README.md). The first attempt contracted against the pure
;;; TRANSITION `step : GameState -> Heading -> GameState` — intermediate
;;; state — and the surface lemmas leaked implementation internals
;;; (`game_ate`, `steer`, the GS field layout) into the frozen contract. That
;;; is the representation-coupling smell the convention is meant to avoid.
;;;
;;; This contract instead pins the EXTREME I/O: the raw bytes that cross the
;;; boundary. The snake program reads one key byte at a time and writes a
;;; frame of bytes per tick, so the true external interface is two pure
;;; transforms:
;;;
;;;     key_heading : Int -> Heading -> Heading      ; a key byte -> a steer
;;;     frame       : GameState -> (List Int)        ; a state  -> output bytes
;;;
;;; Neither names a GS field. `GameState` appears only as an OPAQUE noun (the
;;; thing a frame renders); the contract never inspects it. So an
;;; implementation may rewrite the state layout, the collision rules, the
;;; food RNG — anything beneath the boundary — and as long as the byte maps
;;; below still hold, every dependent of this surface is undisturbed.
;;;
;;; NOTE ON THE WORLD LOOP. The play loop (`read_key -> step -> write ->
;;; loop`) is also I/O-boundary behaviour, but `read_key`/`write` are
;;; uninterpreted externs in proofs — so a requirement cannot speak about
;;; "what the user pressed" without an oracle axiom. The cleanly stateable
;;; loop property is the input-AGNOSTIC clock discipline (the `cat_mono`
;;; analog: the world clock never decreases, so no two effects share a
;;; sequencing token). It is sketched as IO-LOOP below and left for a later
;;; slice — it needs a fuel-bounded `play` to carry the induction.

;; ---- the noun vocabulary (self-contained; pulled from the first contract) --
;; The IO requirements only need `Heading` (the steer's codomain) and
;; `GameState` (an OPAQUE noun — the thing a frame renders; the contract never
;; inspects its fields). `Pos`/`Status` exist only because `GameState`'s
;; declaration mentions them. shard has no opaque-type export yet, so the
;; layout is visible here — but, by design, NO requirement below reads it.

(type Heading  (Up) (Down) (Left) (Right))
(type Status   (Alive) (Dead))
(type Pos      (Pos Int Int))
(type GameState
  (GS (List Pos)   ; snake body, head first
      Heading      ; current heading
      Pos          ; food cell
      Int          ; score
      Status       ; Alive | Dead
      Int))        ; rng seed

;; ===========================================================================
;; INPUT BOUNDARY — the steer decoder (R-IN).
;;
;; `key_heading k cur` decodes one raw key byte into the heading to steer by,
;; keeping the current heading on any unrecognized key. The documented keys:
;;   w (119) -> Up    a (97) -> Left    s (115) -> Down    d (100) -> Right
;; ===========================================================================

(requirement io_key_w
  (Goal (list (Param 'cur (ty Heading))) (list)
    (Equation (Call 'key_heading (list (IntLit 119) (FVar 'cur))) (Ctor 'Up (list)))))

(requirement io_key_a
  (Goal (list (Param 'cur (ty Heading))) (list)
    (Equation (Call 'key_heading (list (IntLit 97) (FVar 'cur))) (Ctor 'Left (list)))))

(requirement io_key_s
  (Goal (list (Param 'cur (ty Heading))) (list)
    (Equation (Call 'key_heading (list (IntLit 115) (FVar 'cur))) (Ctor 'Down (list)))))

(requirement io_key_d
  (Goal (list (Param 'cur (ty Heading))) (list)
    (Equation (Call 'key_heading (list (IntLit 100) (FVar 'cur))) (Ctor 'Right (list)))))

;; R-IN default — UNRECOGNIZED KEYS ARE INERT.
;;   k ∉ {119,97,115,100}  ⟹  key_heading k cur = cur
;; The strong one: no stray byte may secretly steer. Phrased with the four
;; disequalities as premises (int_eq k KEY = False).
(requirement io_key_inert
  (Goal (list (Param 'k (ty Int)) (Param 'cur (ty Heading)))
    (list (Equation (Call 'int_eq (list (FVar 'k) (IntLit 119))) (Ctor 'False (list)))
          (Equation (Call 'int_eq (list (FVar 'k) (IntLit 115))) (Ctor 'False (list)))
          (Equation (Call 'int_eq (list (FVar 'k) (IntLit 97)))  (Ctor 'False (list)))
          (Equation (Call 'int_eq (list (FVar 'k) (IntLit 100))) (Ctor 'False (list))))
    (Equation (Call 'key_heading (list (FVar 'k) (FVar 'cur))) (FVar 'cur))))

;; ===========================================================================
;; OUTPUT BOUNDARY — the frame encoder (R-OUT).
;;
;; Every frame the program writes must begin by clearing the screen, so the
;; terminal shows one board per tick rather than a scroll. The clear sequence
;; is ANSI ESC[2J ESC[H = bytes 27 91 50 74 27 91 72. The requirement is a
;; black-box statement about the first seven output bytes — it never mentions
;; how the board itself is rendered.
;; ===========================================================================

;; NOTE (goal-encoding footgun): the RHS object list must be written as the
;; EXPLICIT reflected datum — (Ctor 'Cons (list (IntLit ..) ..)). Writing it
;; as `(list 27 91 ..)` elaborates to a bare Cons/IntLit chain one reflection
;; level off, which PARSES but cannot be un-reflected at `fulfills` time.
(requirement io_frame_clears
  (Goal (list (Param 's (ty GameState))) (list)
    (Equation (Call 'take (list (IntLit 7) (Call 'frame (list (FVar 's)))))
      (Ctor 'Cons (list (IntLit 27)
        (Ctor 'Cons (list (IntLit 91)
          (Ctor 'Cons (list (IntLit 50)
            (Ctor 'Cons (list (IntLit 74)
              (Ctor 'Cons (list (IntLit 27)
                (Ctor 'Cons (list (IntLit 91)
                  (Ctor 'Cons (list (IntLit 72)
                    (Ctor 'Nil (list)))))))))))))))))))

;; ===========================================================================
;; LOOP BOUNDARY — clock discipline (IO-LOOP) — SKETCHED, not yet formal.
;;
;; ∀ s w.  w_clock w  ≤  w_clock (play s w)
;; The world clock is monotonic across a play loop of any length: every tick
;; writes-then-reads (two effects, clock += 2) and recurses, so the clock
;; only ever grows — no effect reuses a sequencing token. Input-agnostic
;; (true whatever read_key returns). Mirrors cat_loop's `cat_mono`; needs a
;; fuel-bounded `play_fuel` to carry the induction. Deferred to its own slice.
;; ===========================================================================
