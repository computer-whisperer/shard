;;; arena.shard — REVIEWED SPEC VOCABULARY for the snake game's output.
;;;
;;; This is the part nothing proves: it DEFINES what "a complete arena frame"
;;; means as a predicate over the raw output bytes, and its fidelity to "what a
;;; player sees" rests on human inspection, not a theorem. So it is written to
;;; be dumb and obvious — fixed dimensions, structural row checks, no cleverness.
;;;
;;; An arena is a W x H grid, serialized as the ANSI clear prefix followed by H
;;; rows of W cell-bytes each terminated by a newline. The border is the
;;; perimeter: the top and bottom rows are ALL wall; every interior row begins
;;; and ends with a wall. Interior cells are unconstrained (snake/food/empty).
;;;
;;; Dimensions are tiny and concrete so the predicate is eval-checkable and the
;;; eventual per-frame proof stays small. W=6, H=4.

(import "../../kernel/stdlib.shard")   ; List / Option / Bool / Pair

;; ---- dimensions & glyphs --------------------------------------------------
(fn wall () Int 35)     ; '#'
(fn nl   () Int 10)     ; '\n'
;; clear = ANSI ESC[2J ESC[H = 27 91 50 74 27 91 72  (7 bytes)
;; row   = 6 cells + newline = 7 bytes ; body = 4 rows = 28 ; frame = 7 + 28 = 35

;; ---- tiny list helpers (self-contained for inspection) --------------------
(fn leni ((xs (List Int))) Int
  (match xs (Nil 0) ((Cons h t) (+ 1 (leni t)))))

(fn take ((n Int) (xs (List Int))) (List Int)
  (if (le n 0) Nil
    (match xs (Nil Nil) ((Cons h t) (Cons h (take (- n 1) t))))))

(fn drop ((n Int) (xs (List Int))) (List Int)
  (if (le n 0) xs
    (match xs (Nil Nil) ((Cons h t) (drop (- n 1) t)))))

(fn nth ((i Int) (xs (List Int))) Int
  (match xs (Nil (- 0 1)) ((Cons h t) (if (le i 0) h (nth (- i 1) t)))))

(fn andb ((a Bool) (b Bool)) Bool (match a (True b) (False False)))

;; every byte of xs equals v
(fn all_eq ((v Int) (xs (List Int))) Bool
  (match xs (Nil True) ((Cons h t) (if (int_eq h v) (all_eq v t) False))))

;; ---- row decomposition ----------------------------------------------------
;; split fixed-width 7-byte rows off the body (a malformed short body yields a
;; short final row, which the row checks below reject).
(fn split_rows ((bs (List Int))) (List (List Int))
  (match bs
    (Nil Nil)
    (_ (Cons (take 7 bs) (split_rows (drop 7 bs))))))

;; a full wall row: 6 wall cells then newline.
(fn wall_row ((r (List Int))) Bool
  (andb (all_eq (wall) (take 6 r)) (int_eq (nth 6 r) (nl))))

;; an interior row: left & right cells are wall, terminated by newline.
;; (interior cells nth 1..4 are unconstrained — snake/food/empty live there.)
(fn ends_row ((r (List Int))) Bool
  (andb (int_eq (nth 0 r) (wall))
    (andb (int_eq (nth 5 r) (wall)) (int_eq (nth 6 r) (nl)))))

;; the body must be EXACTLY: wall / interior / interior / wall (H=4). Any other
;; row count -> not an arena (this is what makes a partial frame fail).
(fn is_body ((rs (List (List Int)))) Bool
  (match rs
    ((Cons r0 (Cons r1 (Cons r2 (Cons r3 Nil))))
      (andb (wall_row r0)
        (andb (ends_row r1) (andb (ends_row r2) (wall_row r3)))))
    (_ False)))

;; the clear prefix is present?
(fn starts_clear ((bs (List Int))) Bool
  (andb (int_eq (nth 0 bs) 27) (andb (int_eq (nth 1 bs) 91)
    (andb (int_eq (nth 2 bs) 50) (andb (int_eq (nth 3 bs) 74)
      (andb (int_eq (nth 4 bs) 27) (andb (int_eq (nth 5 bs) 91)
        (int_eq (nth 6 bs) 72))))))))

;; THE PREDICATE: a complete arena frame = full size, clears the screen, and a
;; well-formed bordered body. A short/partial/placeholder frame fails on size
;; AND on body shape.
(fn is_arena ((bs (List Int))) Bool
  (andb (int_eq (leni bs) 35)
    (andb (starts_clear bs)
      (is_body (split_rows (drop 7 bs))))))

;; every frame in an output log is a complete arena.
(fn all_arena ((fs (List (List Int)))) Bool
  (match fs (Nil True) ((Cons f t) (if (is_arena f) (all_arena t) False))))

;; ===========================================================================
;; ENTITY DETECTORS — finding the snake & food in a rendered frame.
;;
;; The next design chunk: a frame is not just a bordered arena, it shows the
;; game ENTITIES, contained inside the walls. These detectors locate a glyph in
;; the interior by grid coordinate, so requirements can talk about WHERE the
;; snake is on screen — over the output bytes, never an internal GS field.
;; Glyphs: head 'O' = 79, food '*' = 42 (empty ' ' = 32, wall '#' = 35).
;; ===========================================================================

;; the byte at interior grid cell (r,c): clear prefix (7) + r full rows (7 each)
;; + c into the row.
(fn cell_at ((r Int) (c Int) (f (List Int))) Int (nth (+ 7 (+ (* r 7) c)) f))

;; first interior cell (rows 1..2, cols 1..4, row-major) holding glyph g, else
;; None. Spelled out cell-by-cell so the search space is obvious on inspection.
(fn find_glyph ((g Int) (f (List Int))) (Option (Pair Int Int))
  (if (int_eq (cell_at 1 1 f) g) (Some (Pair 1 1))
   (if (int_eq (cell_at 1 2 f) g) (Some (Pair 1 2))
    (if (int_eq (cell_at 1 3 f) g) (Some (Pair 1 3))
     (if (int_eq (cell_at 1 4 f) g) (Some (Pair 1 4))
      (if (int_eq (cell_at 2 1 f) g) (Some (Pair 2 1))
       (if (int_eq (cell_at 2 2 f) g) (Some (Pair 2 2))
        (if (int_eq (cell_at 2 3 f) g) (Some (Pair 2 3))
         (if (int_eq (cell_at 2 4 f) g) (Some (Pair 2 4))
          None)))))))))

(fn head_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 79 f))   ; the snake head 'O'
(fn food_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 42 f))   ; the food '*'

(fn has_glyph ((o (Option (Pair Int Int)))) Bool
  (match o (None False) ((Some p) True)))

;; a well-formed BOARD: an intact arena with BOTH the snake head and the food
;; drawn in the interior. is_arena already forbids any non-wall byte on the
;; border, so "head/food in the interior" means the entities are CONTAINED —
;; the snake can never be rendered on or through a wall.
(fn is_board ((f (List Int))) Bool
  (andb (is_arena f)
    (andb (has_glyph (head_at f)) (has_glyph (food_at f)))))

(fn all_board ((fs (List (List Int)))) Bool
  (match fs (Nil True) ((Cons f t) (if (is_board f) (all_board t) False))))
