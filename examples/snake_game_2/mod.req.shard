;;; snake_game_2 — the module INTERFACE: the reviewed CONTRACT for the snake
;;; game's I/O boundary. BODYLESS — exported signatures, the boundary's extern
;;; bolt axiom, and the promised requirements; no bodies, no proofs. The impl
;;; (snake_io.shard) supplies the bodies and DISCHARGES every requirement.
;;;
;;; A second take on requirement-isolation (see ../snake_game/README.md). The
;;; first attempt contracted against the pure TRANSITION `step` and leaked GS
;;; fields / steer / game_ate into the frozen contract. This one pins the bytes
;;; that cross the boundary. Two flavours of requirement now sit side by side,
;;; spanning the spectrum we want to be able to express:
;;;
;;;   - BOUNDARY TRANSFORMS (io_key_* / io_frame_clears) — black-box maps on the
;;;     in/out bytes, naming no state field. A pure-equation contract: cheap,
;;;     but still about internal pure fns (key_heading / frame).
;;;   - RUN DISCIPLINE (snake_clock_mono) — a property of the ACTUAL loop,
;;;     anchored to the `write` EXTERN through the `write_clock` bolt axiom.
;;;     This is the genuinely bin-shaped requirement: it quantifies over the
;;;     program's execution, not a pure input. It is the cat_mono analog the
;;;     first draft only sketched as prose (the "IO-LOOP" TODO).
;;;
;;; GameState is carried concretely here only because the boundary transforms'
;;; signatures mention it; by design NO requirement reads its fields.

(import "../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../std/nat.shard")  ; Nat (Z/S) — stdlib nouns (fuel is now Int + WfInduct)
(import "../../std/order.shard")  ; le_refl / le_trans — clock monotonicity
(import "../../std/list.shard")  ; append — the output log accumulator
(import "arena.shard")  ; is_arena / all_arena — the REVIEWED output spec vocabulary

;; ---- THE ARTIFACT ---------------------------------------------------------
;; `snake` is an executable. Its acceptance contract is the `requires` list —
;; every name a property of `main` or a boundary transform. `check` reports
;; each MET/UNMET, so the two pending obligations (frames_are_arenas/_boards)
;; are surfaced, not silently skipped. `trusts` names the bolt axioms that are
;; the binary's TCB; `externs` the I/O boundary `main` may touch.
(bin snake
  (entry main)
  (externs key_oracle write)
  (trusts write_clock write_output write_input key_clock key_output key_input)
  (requires board_min_size io_key_w io_key_a io_key_s io_key_d io_key_inert
    io_frame_clears main_clock_mono frames_are_arenas frames_are_boards
    io_input_moves))

;; ---- noun vocabulary (self-contained) -------------------------------------
(type Heading (Up) (Down) (Left) (Right))  ; the steer codomain
(type Status (Alive) (Dead))
(type Pos (Pos Int Int))
(type GameState
  (GS
    (List Pos)  ; snake body, head first
    Heading  ; current heading
    Pos  ; food cell
    Int  ; score
    Status  ; Alive | Dead
    Int))  ; rng seed

;; ---- design constants: the board dimensions --------------------------------
;; board_w / board_h are declared as opaque sigs in arena.shard (this file
;; imports it, so they cannot live here); their CONTRACT lives here. The impl
;; picks the concrete size (32 x 32) and must discharge this minimum: wide and
;; tall enough for a bordered interior holding the fixed food at (col 4, row 2).
;; Everything else — the vocabulary, the requirements, every proof — treats the
;; dimensions symbolically; this fulfillment (and the ground step demos) are
;; the only places licensed to reduce the concrete values.
(requirement board_min_size
  (goal () () (= (andb (le 6 (board_w)) (le 4 (board_h))) True)))

;; ---- the I/O boundary: bytes in, bytes out --------------------------------
;; Opaque signatures (stuck in proofs like externs); the impl bodies shadow
;; them on self-check, so the fulfillments may unfold their own definitions.
(sig fn key_heading ((k Int) (cur Heading)) Heading)  ; a key byte -> a steer
(sig fn frame ((s GameState)) (List Int))  ; a state    -> output bytes
(sig fn take ((n Int) (xs (List Int))) (List Int))  ; first n bytes (std/list candidate)

;; ===========================================================================
;; INPUT BOUNDARY — the steer decoder (R-IN).
;;   w 119 -> Up   a 97 -> Left   s 115 -> Down   d 100 -> Right
;; ===========================================================================
(requirement io_key_w (goal ((cur Heading)) () (= (key_heading 119 cur) Up)))
(requirement io_key_a (goal ((cur Heading)) () (= (key_heading 97 cur) Left)))
(requirement io_key_s (goal ((cur Heading)) () (= (key_heading 115 cur) Down)))
(requirement io_key_d (goal ((cur Heading)) () (= (key_heading 100 cur) Right)))

;; R-IN default — unrecognized keys are inert (no stray byte may steer).
(requirement io_key_inert
  (goal ((k Int) (cur Heading))
    ((= (int_eq k 119) False)
     (= (int_eq k 115) False)
     (= (int_eq k 97) False)
     (= (int_eq k 100) False))
    (= (key_heading k cur) cur)))

;; ===========================================================================
;; OUTPUT BOUNDARY — every frame clears the screen first (R-OUT).
;; The clear sequence is ANSI ESC[2J ESC[H = 27 91 50 74 27 91 72. A black-box
;; statement about the first seven output bytes — never how the board renders.
;; ===========================================================================
(requirement io_frame_clears
  (goal ((s GameState)) () (= (take 7 (frame s)) (list 27 91 50 74 27 91 72))))

;; ===========================================================================
;; RUN BOUNDARY — clock discipline over the play loop (R-LOOP).
;;
;; The world clock never decreases across a play loop of any length: each tick
;; WRITES one frame (clock += 1) and recurses, so no two effects share a
;; sequencing token. Input-agnostic — true whatever the key oracle returns. The
;; fuel-bounded `play_fuel` carries the induction (covers every finite run);
;; the unbounded `play` is what would actually run. Anchored to the `write`
;; extern by the `write_clock` bolt axiom — the auditable TCB line.
;; ===========================================================================

(type World (World Int))  ; the sequencing-clock token
(sig fn w_clock ((w World)) Int)  ; the observable: the world's clock
(sig fn w_input ((w World)) (List (Option Int)))  ; the observable: keys consumed so far

;; THE EXECUTABLE and its hidden scaffolding. `main` is the SUBJECT of every
;; requirement below — no requirement names anything but `main` + the I/O
;; observables. `fuel` is the opaque global step budget: abstract in CHECK (the
;; proof can never reduce it, so proof cost is independent of the runtime value)
;; and the real large value in RUN — its opacity is load-bearing, so it stays a
;; `sig fn`. The start state `init` and the `play` worker are private impl
;; scaffolding (no requirement names them); init in particular must be
;; TRANSPARENT so the board requirements can prove its frame is a real board, so
;; it is NOT declared here — it lives only in the impl as a concrete `fn`.
(sig fn main ((w World)) World)  ; THE EXECUTABLE — what every requirement is about
(sig fn fuel () Int)  ; opaque global step budget (large Int at RUN, abstract in CHECK)

;; key_oracle now THREADS the World: it is a clocked, sequenced effect that
;; records the key it yielded onto the input trace `w_input` — the symmetric
;; twin of `write`/`w_output`. Making the consumed input an OBSERVABLE is what
;; lets a requirement relate output frames to the keys that drove them (without
;; it, the contract is structurally blind to input — see io_input_moves below).
(extern key_oracle ((w World)) (Pair (Option Int) World))  ; next key; clocked + traced
(extern write ((bytes (List Int)) (w World)) World)  ; emit a frame; clock + output effect

;; THE BOLTS — the whole trust surface tying the proofs to the real I/O
;; primitives. Each effect (write, key_oracle) pins its action on each
;; observable (clock, output log, input trace); the cross-terms are PRESERVATION
;; (an effect leaves the other observable untouched). Dumb one-line equations,
;; auditable by inspection.
;;
;; -- clock: both effects advance the sequencing clock by exactly one.
(axiom write_clock
  (goal ((bytes (List Int)) (w World)) ()
    (= (w_clock (write bytes w)) (+ (w_clock w) 1))))
(axiom key_clock
  (goal ((w World) (o (Option Int)) (w1 World)) ((= (key_oracle w) (Pair o w1)))
    (= (w_clock w1) (+ (w_clock w) 1))))

;; -- input trace: key_oracle APPENDS the key it returned; write PRESERVES it.
(axiom key_input
  (goal ((w World) (o (Option Int)) (w1 World)) ((= (key_oracle w) (Pair o w1)))
    (= (w_input w1) (append (w_input w) (Cons o Nil)))))
(axiom write_input
  (goal ((bytes (List Int)) (w World)) ()
    (= (w_input (write bytes w)) (w_input w))))

;; R-LOOP, stated over MAIN: the running binary only ever advances its
;; sequencing clock — no effect reuses a token. Proven via an internal
;; ∀-fuel worker lemma instantiated at the opaque `fuel`, so the proof cost is
;; independent of fuel's runtime value (opacity ENFORCES the uniformity).
(requirement main_clock_mono
  (goal ((w World)) () (= (le (w_clock w) (w_clock (main w))) True)))

;; ===========================================================================
;; OUTPUT-CONTENT BOUNDARY — a complete arena every update (R-ARENA).
;;
;; The headline whole-binary requirement: EVERY frame the program writes is a
;; complete bordered arena (`is_arena`, arena.shard). This is "a border that
;; updates every frame" — the binary must re-emit a full W x H bordered grid on
;; every single update, not draw a border once and scroll.
;;
;; It is keyed to the binary's I/O through a SECOND bolt axiom, `write_output`:
;; where `write_clock` exposed the sequencing clock, `write_output` exposes the
;; CONTENT — `write` appends its bytes to the world's output log. The two
;; axioms together are the whole trust surface tying the proof to the real
;; output primitive.
;;
;; Stated as a PRESERVATION invariant over the play loop: if the log is all
;; arenas so far, it still is after any number of ticks. The running binary
;; starts with an empty log (`all_arena Nil = True`), so its entire output is
;; arenas. Discharging this FORCES a real renderer: the proof cannot close
;; without `is_arena (frame s) = True` for every state `s`, and `is_arena`
;; rejects the current placeholder frame (validated by eval). That per-frame
;; obligation is what drags the implementation toward an actual working app.
;; ===========================================================================

(sig fn w_output ((w World)) (List (List Int)))  ; the observable: frames written so far

;; -- output log: `write` APPENDS its frame; key_oracle PRESERVES it.
(axiom write_output
  (goal ((bytes (List Int)) (w World)) ()
    (= (w_output (write bytes w)) (append (w_output w) (Cons bytes Nil)))))
(axiom key_output
  (goal ((w World) (o (Option Int)) (w1 World)) ((= (key_oracle w) (Pair o w1)))
    (= (w_output w1) (w_output w))))

;; DISCHARGED (snake_io.shard) — a real grid renderer makes every frame an
;; arena, preserved across the loop by `play_arena_preserve` (WfInduct on fuel +
;; the `all_arena_snoc` lemma over the write-appended log).
(requirement frames_are_arenas
  (goal ((w World)) ((= (all_arena (w_output w)) True))
    (= (all_arena (w_output (main w))) True)))

;; ===========================================================================
;; ENTITY-CONTAINMENT BOUNDARY — a contained snake & food every update (R-BOARD).
;;
;; Strengthens R-ARENA: every emitted frame is not just a bordered arena but a
;; well-formed BOARD — the snake head and the food are both drawn IN THE
;; INTERIOR (`is_board`, arena.shard). Because the arena check forbids any
;; non-wall byte on the perimeter, "in the interior" means the entities are
;; CONTAINED: the snake is never rendered on or through a wall. This is the
;; observable form of the snake game's containment invariant — stated over the
;; output bytes, citing the entity detectors, never an internal GS field.
;;
;; Same I/O keying (the `write_output` bolt) and same preservation shape as
;; R-ARENA. Discharging it forces a renderer that actually DRAWS the snake and
;; food inside the walls every frame: an empty arena (which satisfies R-ARENA)
;; FAILS is_board — validated by eval. board ⊃ arena, so this subsumes R-ARENA.
;; ===========================================================================

;; DISCHARGED (snake_io.shard) — the renderer draws the head & food inside the
;; walls, so `is_board (frame init)` holds; `play_board_preserve` lifts it over
;; the loop exactly as for arenas. board ⊃ arena, so this subsumes R-ARENA.
(requirement frames_are_boards
  (goal ((w World)) ((= (all_board (w_output w)) True))
    (= (all_board (w_output (main w))) True)))

;; ===========================================================================
;; INPUT-RESPONSE BOUNDARY — the screen tracks the keys, whole-run (R-MOVES).
;;
;; Lifts the per-tick input response to the entire run: pair every emitted
;; frame with the input that drove it (one key per frame, in order — both
;; logs are observables); every consecutive frame pair keyed by a wasd byte
;; shows the detected head moved ONE CELL in that key's direction, or held in
;; place (a blocked move — the freeze). Stated over main's two I/O traces
;; alone via moves_ok (arena.shard); the premises pin the binary's start:
;; nothing written, nothing consumed. This is the requirement the w_input
;; observable was introduced for — without it the contract is structurally
;; blind to input.
;;
;; Discharged (snake_io.shard) by the play_moves_preserve worker — its
;; mgo_last carry ties the log's LAST frame to the live game state, so each
;; tick's obligation is exactly the per-tick move_shown — plus
;; play_moves_start to bridge the empty-log first tick.
;; ===========================================================================

(requirement io_input_moves
  (goal ((w World)) ((= (w_output w) Nil) (= (w_input w) Nil))
    (= (moves_ok (w_output (main w)) (w_input (main w))) True)))
