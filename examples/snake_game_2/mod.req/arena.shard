;;; arena.shard — REVIEWED SPEC VOCABULARY for the snake game's output.
;;;
;;; This is the part nothing proves: it DEFINES what "a complete arena frame"
;;; means as a predicate over the raw output bytes, and its fidelity to "what a
;;; player sees" rests on human inspection, not a theorem. So it is written to
;;; be dumb and obvious — counted structural row checks, no cleverness.
;;;
;;; An arena is a W x H grid, serialized as the ANSI clear prefix followed by H
;;; rows of W cell-bytes each terminated by a newline. The border is the
;;; perimeter: the top and bottom rows are ALL wall; every interior row begins
;;; and ends with a wall. Interior cells are unconstrained (snake/food/empty).
;;;
;;; W and H are DESIGN CONSTANTS — board_w / board_h below: opaque signatures
;;; here, concrete bodies in the impl (32 x 32). Every predicate recurses on
;;; counted runs instead of fixed offsets, so nothing in this file depends on
;;; the concrete size; the PROOFS treat the dimensions symbolically too — by
;;; discipline (only the contract's board_min_size fulfillment and the ground
;;; demos may reduce them), auditable by re-checking at a different size.
;;; Exact frame size is still pinned, just structurally: wall_cells/free_cells
;;; demand an exact cell run ending at the newline AND the row end, and
;;; is_body counts exactly board_h rows off the (board_w + 1)-wide split.

(import "../../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../../std/list")  ; len/take/drop + len_nonneg/len_cons/drop_shortens (measure)
(use (:: std list *))

;; ---- design constants & glyphs --------------------------------------------
;; Declared HERE rather than in mod.req.shard only because mod.req.shard
;; imports this file; their CONTRACT (the minimum size) is mod.req.shard's
;; board_min_size requirement, discharged by the impl's concrete bodies.
(sig fn board_w () Int)  ; cells per row   (>= 6 — board_min_size)
(sig fn board_h () Int)  ; rows per frame  (>= 4 — board_min_size)

(fn wall () Int 35)  ; '#'
(fn nl () Int 10)  ; '\n'
;; clear = ANSI ESC[2J ESC[H = 27 91 50 74 27 91 72  (7 bytes)
;; row   = board_w cells + newline ; body = board_h rows ; frame = 7 + body

;; ---- tiny list helpers (take/drop/len from std/list) ----------------------
(fn nth ((i Int) (xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil (- 0 1))
    ((Cons h t) (if (le i 0) h (nth (- i 1) t)))))

(fn andb ((a Bool) (b Bool)) Bool
  (match a
    (True b)
    (False False)))

;; ---- row checks (counted runs — each row's exact length is pinned here) ---
;; a full wall row: exactly n more wall cells, then the newline, then the END
;; of the row. Any other byte, a short row, or trailing bytes -> False.
(fn wall_cells ((n Int) (r (List Int))) Bool
  (measure (struct r))
  (if (le n 0)
    (match r
      ((Cons b Nil) (int_eq b (nl)))
      (_ False))
    (match r
      ((Cons b rest) (if (int_eq b (wall)) (wall_cells (- n 1) rest) False))
      (_ False))))
(fn wall_row ((r (List Int))) Bool (wall_cells (board_w) r))

;; an interior row: a wall cell, n unconstrained interior cells (snake/food/
;; empty live there), then wall, newline, END.
(fn free_cells ((n Int) (r (List Int))) Bool
  (measure (struct r))
  (if (le n 0)
    (match r
      ((Cons b (Cons b2 Nil)) (andb (int_eq b (wall)) (int_eq b2 (nl))))
      (_ False))
    (match r
      ((Cons b rest) (free_cells (- n 1) rest))
      (_ False))))
(fn ends_row ((r (List Int))) Bool
  (match r
    ((Cons b rest) (andb (int_eq b (wall)) (free_cells (- (board_w) 2) rest)))
    (_ False)))

;; ---- row decomposition ----------------------------------------------------
;; split fixed-width (board_w + 1)-byte rows off the body (a malformed short
;; body yields a short final row, which the row checks above reject).
;; Recurses on (drop K (Cons h t)) (= drop K bs in this arm) where K=board_w+1.
;; The (Cons h t) match + binder-referencing recursion arg is what lets the
;; measure (len bs) descend (Phase D): the arm equation is kept, so len bs >= 1,
;; and drop_shortens gives the strict drop. The (le K 0) guard supplies K >= 1
;; (board_w is opaque here; its >= 6 lives at the apex — for board_w > 0 the
;; guard is never taken, so split_rows is unchanged). premises 0 = arm eq,
;; 1 = guard.
(fn split_rows ((bs (List Int))) (List (List Int))
  (measure
    (len bs)
    (steps
      ((rewrite (premise 0) lr lhs true ()))
      (have (= (le 1 (+ (board_w) 1)) True) (by farkas (list 1 0 1))
        (have (= (le 0 (len t)) True)
          (rewrite-with (lemma len_nonneg) lr lhs ((inst xs t)) () refl)
          (have (= (le 1 (len (Cons h t))) True)
            (steps
              ((rewrite (lemma len_cons) lr lhs true ()))
              (by farkas (list 1 0 0 0 1)))
            (have
              (=
                (le
                  (+ (len (drop (+ (board_w) 1) (Cons h t))) 1)
                  (len (Cons h t)))
                True)
              (rewrite-with
                (lemma drop_shortens)
                lr
                lhs
                ((inst n (+ (board_w) 1)) (inst xs (Cons h t)))
                ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (steps ((rewrite (premise 4) lr lhs true ())) refl))
                refl)
              (by farkas (list 1 0 0 0 0 0 1)))))))
    (rewrite-with
      (lemma len_nonneg)
      lr
      lhs
      ((inst xs (drop (+ (board_w) 1) (Cons h t))))
      ()
      refl))
  (match bs
    (Nil Nil)
    ((Cons h t)
     (if (le (+ (board_w) 1) 0) Nil
     (Cons
       (take (+ (board_w) 1) bs)
       (split_rows (drop (+ (board_w) 1) (Cons h t))))))))

;; the body must be EXACTLY: a wall row, board_h - 2 interior rows, a wall
;; row. The count is the recursion fuel; any other row count -> not an arena
;; (this is what makes a partial or oversized frame fail).
(fn mid_rows ((n Int) (rs (List (List Int)))) Bool
  (measure (struct rs))
  (if (le n 0)
    (match rs
      ((Cons r Nil) (wall_row r))
      (_ False))
    (match rs
      ((Cons r rest) (andb (ends_row r) (mid_rows (- n 1) rest)))
      (_ False))))
(fn is_body ((rs (List (List Int)))) Bool
  (match rs
    ((Cons r0 rest) (andb (wall_row r0) (mid_rows (- (board_h) 2) rest)))
    (_ False)))

;; the clear prefix is present?
(fn starts_clear ((bs (List Int))) Bool
  (andb
    (int_eq (nth 0 bs) 27)
    (andb
      (int_eq (nth 1 bs) 91)
      (andb
        (int_eq (nth 2 bs) 50)
        (andb
          (int_eq (nth 3 bs) 74)
          (andb
            (int_eq (nth 4 bs) 27)
            (andb (int_eq (nth 5 bs) 91) (int_eq (nth 6 bs) 72))))))))

;; THE PREDICATE: a complete arena frame = clears the screen, then a
;; well-formed bordered body. A short/partial/placeholder frame fails on the
;; body shape (short rows, wrong row count).
(fn is_arena ((bs (List Int))) Bool
  (andb (starts_clear bs) (is_body (split_rows (drop 7 bs)))))

;; every frame in an output log is a complete arena.
(fn all_arena ((fs (List (List Int)))) Bool
  (measure (struct fs))
  (match fs
    (Nil True)
    ((Cons f t) (if (is_arena f) (all_arena t) False))))

;; ===========================================================================
;; ENTITY DETECTORS — finding the snake & food in a rendered frame.
;;
;; A frame is not just a bordered arena, it shows the game ENTITIES, contained
;; inside the walls. These detectors locate a glyph by grid coordinate, so
;; requirements can talk about WHERE the snake is on screen — over the output
;; bytes, never an internal GS field.
;; Glyphs: head '@' = 64, body 'O' = 79, food '*' = 42 (empty ' ' = 32,
;; wall '#' = 35). The head byte is DISTINCT from the body byte so the head
;; detector below stays well-defined when the snake grows: "the first 'O'"
;; would be whichever segment scans first, not the head.
;; ===========================================================================

;; the first cell in a row holding glyph g, as its column index (counting from
;; c at the row head). The newline terminator never equals an entity glyph, so
;; the scan self-limits at the end of the row.
(fn row_find ((g Int) (c Int) (r (List Int))) (Option Int)
  (measure (struct r))
  (match r
    (Nil None)
    ((Cons b rest) (if (int_eq b g) (Some c) (row_find g (+ c 1) rest)))))

;; the first cell (row-major over the split rows, counting rows from rw)
;; holding glyph g, as (Pair row col).
(fn rows_find ((g Int) (rw Int) (rs (List (List Int)))) (Option (Pair Int Int))
  (measure (struct rs))
  (match rs
    (Nil None)
    ((Cons r rest)
     (match (row_find g 0 r)
       (None (rows_find g (+ rw 1) rest))
       ((Some c) (Some (Pair rw c)))))))

;; Where the old fixed-size vocabulary spelled out the interior cells one by
;; one, the parametric form scans EVERY cell of the body, row-major; row 0 is
;; the top wall row, so reported coordinates live on the same grid the border
;; occupies. On a frame is_arena accepts, no border or terminator byte can
;; equal an entity glyph (walls are '#', terminators '\n'), so a found glyph
;; is necessarily INTERIOR — the containment reading is unchanged.
(fn find_glyph ((g Int) (f (List Int))) (Option (Pair Int Int))
  (rows_find g 0 (split_rows (drop 7 f))))

(fn head_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 64 f))  ; the snake head '@'
(fn food_at ((f (List Int))) (Option (Pair Int Int)) (find_glyph 42 f))  ; the food '*'

(fn has_glyph ((o (Option (Pair Int Int)))) Bool
  (match o
    (None False)
    ((Some p) True)))

;; a well-formed BOARD: an intact arena with BOTH the snake head and the food
;; drawn in it — and by the containment reading above, drawn in the INTERIOR:
;; the snake can never be rendered on or through a wall.
(fn is_board ((f (List Int))) Bool
  (andb (is_arena f) (andb (has_glyph (head_at f)) (has_glyph (food_at f)))))

(fn all_board ((fs (List (List Int)))) Bool
  (measure (struct fs))
  (match fs
    (Nil True)
    ((Cons f t) (if (is_board f) (all_board t) False))))

;; ===========================================================================
;; INPUT-RESPONSE VOCABULARY — relating consecutive frames to the input keys.
;;
;; A frame is not just a valid board, it is the RESPONSE to the key the player
;; pressed. These predicates pin that purely over the boundary bytes — a key
;; in, two frames out — naming no game state. Glyph geometry: head positions
;; are (row, col) as `head_at` reports them; w/a/s/d displace the head by one
;; cell (w/s on the row, a/d on the column).
;; ===========================================================================

(fn orb ((a Bool) (b Bool)) Bool
  (match a
    (True True)
    (False b)))

;; the four steer keys; any other byte imposes no displacement constraint.
(fn is_wasd ((k Int)) Bool
  (if (int_eq k 119) True
  (if (int_eq k 115) True
  (if (int_eq k 97) True
  (if (int_eq k 100) True
  False)))))

;; displace an observed (row, col) head one cell in the key's direction
;; (w=119 up, s=115 down, a=97 left, d=100 right); a non-wasd key holds it.
(fn move_cell ((p (Pair Int Int)) (k Int)) (Pair Int Int)
  (match p
    ((Pair row col)
     (if (int_eq k 119) (Pair (- row 1) col)
     (if (int_eq k 115) (Pair (+ row 1) col)
     (if (int_eq k 97) (Pair row (- col 1))
     (if (int_eq k 100) (Pair row (+ col 1))
     (Pair row col))))))))

(fn pair_eq ((a (Pair Int Int)) (b (Pair Int Int))) Bool
  (match a
    ((Pair a1 a2)
     (match b
       ((Pair b1 b2) (andb (int_eq a1 b1) (int_eq a2 b2)))))))

(fn opt_pair_eq ((a (Option (Pair Int Int))) (b (Option (Pair Int Int)))) Bool
  (match a
    (None
      (match b
        (None True)
        ((Some q) False)))
    ((Some p)
     (match b
       (None False)
       ((Some q) (pair_eq p q))))))

(fn move_opt ((o (Option (Pair Int Int))) (k Int)) (Option (Pair Int Int))
  (match o
    (None None)
    ((Some p) (Some (move_cell p k)))))

;; the per-tick check: across two consecutive frames keyed by a WASD byte, the
;; detected head either advanced one cell in that key's direction or held in
;; place (a blocked move — wall/food). Non-wasd keys assert nothing here (their
;; "continue current heading" movement is history-dependent, not key-determined;
;; inert steering is pinned separately by io_key_inert).
(fn step_shows ((prev (List Int)) (cur (List Int)) (k Int)) Bool
  (if (is_wasd k)
    (orb
      (opt_pair_eq (head_at cur) (move_opt (head_at prev) k))
      (opt_pair_eq (head_at cur) (head_at prev)))
    True))

;; THE PREDICATE: every consecutive pair of emitted frames is the proper
;; response to the key recorded for it. `prev` is the previous frame (None
;; before the first — which has no predecessor to check); each input keys the
;; transition INTO the frame appended alongside it. A trailing/short input list
;; is harmless (the walk stops when the frames run out).
(fn moves_go
  ((prev (Option (List Int)))
   (outs (List (List Int)))
   (ins (List (Option Int))))
  Bool
  (measure (struct outs))
  (match outs
    (Nil True)
    ((Cons f frest)
     (match ins
       (Nil False)
       ((Cons mk irest)
        (match prev
          (None (moves_go (Some f) frest irest))
          ((Some pf)
           (match mk
             (None (moves_go (Some f) frest irest))
             ((Some k)
              (if (step_shows pf f k) (moves_go (Some f) frest irest) False))))))))))

(fn moves_ok ((outs (List (List Int))) (ins (List (Option Int)))) Bool
  (moves_go None outs ins))
