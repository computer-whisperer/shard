        True)
      (rewrite-with
        (lemma bxor_lt32)
        lr
        lhs
        ((inst a (bxor x0 (mod (* 8192 x0) 4294967296)))
         (inst b (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072)))
        ((steps ((rewrite (premise hA_lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hA_lt) lr lhs true ())) refl)
         (steps ((rewrite (premise hQ_lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hQ_lt) lr lhs true ())) refl))
        refl))
    (have wB
      (=
        (mod
          (bxor
            (bxor x0 (mod (* 8192 x0) 4294967296))
            (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))
          4294967296)
        (bxor
          (bxor x0 (mod (* 8192 x0) 4294967296))
          (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072)))
      (rewrite-with
        (lemma wrap32_id)
        lr
        lhs
        ((inst
           x
           (bxor
             (bxor x0 (mod (* 8192 x0) 4294967296))
             (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))))
        ((steps ((rewrite (premise hB_lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hB_lt) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise wB) lr rhs true ())))
    (have b5
      (=
        (bshl
          (bxor
            (bxor x0 (mod (* 8192 x0) 4294967296))
            (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))
          5)
        (*
          32
          (bxor
            (bxor x0 (mod (* 8192 x0) 4294967296))
            (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))))
      (rewrite-with
        (lemma shl5_mul)
        lr
        lhs
        ((inst
           a
           (bxor
             (bxor x0 (mod (* 8192 x0) 4294967296))
             (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))))
        ((steps ((rewrite (premise hB_lo) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise b5) lr rhs true ())))
    (have hR_lo
      (=
        (le
