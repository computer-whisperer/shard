        ((steps ((rewrite (premise hR_lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hR_lt) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise wR) lr rhs true ())))
    refl))

;; ---- the seed shape: tail-if + nested same-file calls (call-through) ------------
;; The machine COMPUTES THROUGH the Call instructions (the callee literal
;; is in the module spine; no bridge, no callee cert — lib-mode structural
;; transparency); the spec unfolds the callee by name. The condition's
;; val-projection collapses GLOBALLY before the case-on (its atom-have
;; normalizes both the machine b2i residue's operand and the spec if);
;; each arm then runs the full word cascade over its own tree — the
;; ground arm's machine side crunches to a literal, the cascade brings
;; the opaque spec tower down to the same literal.

(fn wf_step ((w U32)) U32 (u32_xor w (u32_shl w 13)))

(fn wf_pick ((seed Int)) U32
  (let ((w (u32 seed)))
    (if (int_eq (u32_val w) 0) (wf_step (wf_step (u32 42)))
    (wf_step (wf_step w)))))

(claim wfp_pick
  (goal ((x0 Int) (c Nat) (restfs (List Func)))
    ((= (le 0 x0) True) (= (lt x0 4294967296) True))
    (=
      (call_fn
        (S^ 100 c)
        (MkWModule
          (Cons
            (MkFunc
              1
              0
              (list
                (LocalGet 0)
                (I32Const 8192)
                (LocalGet 0)
                (I32Bin BMul)
                (I32Bin BXor)))
            (Cons
              (MkFunc
                1
                2
                (list
                  (LocalGet 0)
                  (LocalSet 1)
                  (Block
                    (list
                      (Block
                        (list
                          (LocalGet 1)
                          (I32Const 0)
                          (I32Bin BEq)
                          (BrIf 0)
                          (LocalGet 1)
                          (Call 0)
                          (Call 0)
                          (LocalSet 2)
                          (Br 1)))
                      (I32Const 42)
                      (Call 0)
                      (Call 0)
                      (LocalSet 2)))
                  (LocalGet 2)))
              restfs))
          0)
        1
        (list x0))
      (Some (u32_val (wf_pick x0)))))
  (chain
    (steps
      ((compute lhs)
       (unfold wf_pick rhs)
       (reduce rhs)
       (unfold wf_step rhs)
       (reduce rhs)))
    (have hc (= (u32_val (u32 x0)) x0)
      (chain
        (rewrite-with (lemma u32_val_of) lr lhs ((inst nn x0)) ())
        (rewrite-with
          (lemma wrap32_id)
          lr
          lhs
          ((inst x x0))
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl)))
    (steps ((rewrite (premise hc) lr rhs true ())))
    (case-on (int_eq x0 0) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           (have otT
             (=
