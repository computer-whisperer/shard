;;; wordfrag_probe.shard — the WORD fragment design probe (docs/LOWERING.md
;;; §7.8): std/word u32 ops as pure-fragment source vocabulary, probed by
;;; hand before mechanization. The instance is std/rng's xorshift32 round
;;; (13/17/5) — the fragment's first consumer — as a local U32 twin.
;;;
;;; THE STRUCTURE (why this slice is premise-light): a word op's defining
;;; equation IS the machine op's semantics — u32-wrapping arithmetic
;;; (add/sub/mul, and shl spelled as the §6x slice-D constant multiply)
;;; opens to the exact wrap32 residue the interpreter leaves, so those
;;; nodes contribute NOTHING: no wrap premise pair, no wrap_id event. The
;;; only content is (a) the per-ARGUMENT width premise pair — the opaque
;;; rep admits out-of-range Int images, so the cert constrains the arg's
;;; image once (an i32 satisfies it by representation at any real
;;; boundary); (b) a rep-collapse per BITWISE node — bop_val applies
;;; band/bor/bxor unwrapped while the surface re-wraps, so wrap32_id fires
;;; with derived bounds (std/bits closure facts, mod_lo/mod_hi); (c) the
;;; same collapse per shr node over the quotient-bound helper pair below.
;;;
;;; Statement form (ratified 2026-07-10): Int binders; ENC = the u32 maker
;;; spec-side, DEC = u32_val — the §2 adapter slots in the module's own
;;; vocabulary. The proof never pierces the opaque type: it cites the
;;; surface defining equations (u32_xor_val …), the std/bits literal
;;; bridges (shl13_mul/shl5_mul/shr17_div), and wrap32_id.

(import "../kernel/stdlib.shard")
(import "../kernel/facts.shard")
(import "../models/wasm/wasm.shard")
(import "../std/word")
(import "../std/bits")
(use (:: kernel facts *))
(use (:: models wasm wasm *))
(use (:: std word *))
(use (:: std bits *))

;; ---- the source fn: one xorshift32 round over the opaque U32 ------------------

(fn wf_mix ((w U32)) U32
  (let ((a (u32_xor w (u32_shl w 13))))
    (let ((b (u32_xor a (u32_shr a 17)))) (u32_xor b (u32_shl b 5)))))

;; ---- quotient bounds at the shr width: the wrap32_id premise pair for a
;; ---- division node (div-facts at the literal divisor; farkas by formula) -------

(claim wq17_lo
  (goal ((a Int)) ((= (le 0 a) True)) (= (le 0 (ediv a 131072)) True))
  (div-facts a 131072 q (by arith (list 131072 1 -1 0 1 131072))))

(claim wq17_lt32
  (goal ((a Int)) ((= (le 0 a) True) (= (lt a 4294967296) True))
    (= (lt (ediv a 131072) 4294967296) True))
  (div-facts a 131072 q (by arith (list 131072 0 1 1 1 0 -131072))))

;; ---- the lowered cert, hand-played ---------------------------------------------
;; Machine: xor = push both operands (source order) + BXor; shl k = the
;; constant multiply, coefficient pushed FIRST so the residue spells
;; (* 2^k x) = the std/bits bridge's spelling; shr k = BDivU at the literal
;; power (guard computes away). Locals 1/2 = the source lets a/b.

(claim wfp_mix
  (goal ((x0 Int) (c Nat) (restfs (List Func)))
    ((= (le 0 x0) True) (= (lt x0 4294967296) True))
    (=
      (call_fn
        (S^ 37 c)
        (MkWModule
          (Cons
            (MkFunc
              1
              2
              (list
                (LocalGet 0)
                (I32Const 8192)
                (LocalGet 0)
                (I32Bin BMul)
                (I32Bin BXor)
                (LocalSet 1)
                (LocalGet 1)
                (LocalGet 1)
                (I32Const 131072)
                (I32Bin BDivU)
                (I32Bin BXor)
                (LocalSet 2)
                (LocalGet 2)
                (I32Const 32)
                (LocalGet 2)
                (I32Bin BMul)
                (I32Bin BXor)))
            restfs)
          0)
        0
        (list x0))
      (Some (u32_val (wf_mix (u32 x0))))))
  (chain
    (steps ((compute lhs) (unfold wf_mix rhs) (reduce rhs)))
    (have o1
      (=
        (u32_val
          (u32_xor
            (u32_xor
              (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
              (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
            (u32_shl
              (u32_xor
                (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
                (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
              5)))
        (mod
          (bxor
            (u32_val
              (u32_xor
                (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
                (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
            (u32_val
              (u32_shl
                (u32_xor
                  (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
                  (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
                5)))
          4294967296))
      (rewrite-with
        (lemma u32_xor_val)
        lr
        lhs
        ((inst
           a
           (u32_xor
             (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
             (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
         (inst
           b
           (u32_shl
             (u32_xor
               (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
               (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
             5)))
        ()
        refl))
    (steps ((rewrite (premise o1) lr rhs true ())))
    (have o2
      (=
        (u32_val
          (u32_shl
            (u32_xor
              (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
              (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
            5))
        (mod
          (bshl
            (u32_val
              (u32_xor
                (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
                (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
            5)
          4294967296))
      (rewrite-with
        (lemma u32_shl_val)
        lr
        lhs
        ((inst
           x
           (u32_xor
             (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
             (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
         (inst k 5))
        ()
        refl))
    (steps ((rewrite (premise o2) lr rhs true ())))
    (have o3
      (=
        (u32_val
          (u32_xor
            (u32_xor (u32 x0) (u32_shl (u32 x0) 13))
            (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
        (mod
          (bxor
            (u32_val (u32_xor (u32 x0) (u32_shl (u32 x0) 13)))
            (u32_val (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
          4294967296))
      (rewrite-with
        (lemma u32_xor_val)
        lr
        lhs
        ((inst a (u32_xor (u32 x0) (u32_shl (u32 x0) 13)))
         (inst b (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17)))
        ()
        refl))
    (steps ((rewrite (premise o3) lr rhs true ())))
    (have o4
      (=
        (u32_val (u32_shr (u32_xor (u32 x0) (u32_shl (u32 x0) 13)) 17))
        (mod
          (bshr (u32_val (u32_xor (u32 x0) (u32_shl (u32 x0) 13))) 17)
          4294967296))
      (rewrite-with
        (lemma u32_shr_val)
        lr
        lhs
        ((inst x (u32_xor (u32 x0) (u32_shl (u32 x0) 13))) (inst k 17))
        ()
        refl))
    (steps ((rewrite (premise o4) lr rhs true ())))
    (have o5
      (=
        (u32_val (u32_xor (u32 x0) (u32_shl (u32 x0) 13)))
        (mod
          (bxor (u32_val (u32 x0)) (u32_val (u32_shl (u32 x0) 13)))
          4294967296))
      (rewrite-with
        (lemma u32_xor_val)
        lr
        lhs
        ((inst a (u32 x0)) (inst b (u32_shl (u32 x0) 13)))
        ()
        refl))
    (steps ((rewrite (premise o5) lr rhs true ())))
    (have o6
      (=
        (u32_val (u32_shl (u32 x0) 13))
        (mod (bshl (u32_val (u32 x0)) 13) 4294967296))
      (rewrite-with
        (lemma u32_shl_val)
        lr
        lhs
        ((inst x (u32 x0)) (inst k 13))
        ()
        refl))
    (steps ((rewrite (premise o6) lr rhs true ())))
    (have hx (= (u32_val (u32 x0)) x0)
      (chain
        (rewrite-with (lemma u32_val_of) lr lhs ((inst nn x0)) ())
        (rewrite-with
          (lemma wrap32_id)
          lr
          lhs
          ((inst x x0))
          ((steps ((rewrite (premise 0) lr lhs true ())) refl)
           (steps ((rewrite (premise 1) lr lhs true ())) refl))
          refl)))
    (steps ((rewrite (premise hx) lr rhs true ())))
    (have b13 (= (bshl x0 13) (* 8192 x0))
      (rewrite-with
        (lemma shl13_mul)
        lr
        lhs
        ((inst a x0))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise b13) lr rhs true ())))
    (have hA_lo (= (le 0 (bxor x0 (mod (* 8192 x0) 4294967296))) True)
      (rewrite-with
        (lemma bxor_lo)
        lr
        lhs
        ((inst a x0) (inst b (mod (* 8192 x0) 4294967296)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (rewrite-with
           (lemma mod_lo)
           lr
           lhs
           ()
           ((steps ((compute both)) refl))
           refl))
        refl))
    (have hA_lt (= (lt (bxor x0 (mod (* 8192 x0) 4294967296)) 4294967296) True)
      (rewrite-with
        (lemma bxor_lt32)
        lr
        lhs
        ((inst a x0) (inst b (mod (* 8192 x0) 4294967296)))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl)
         (rewrite-with
           (lemma mod_lo)
           lr
           lhs
           ()
           ((steps ((compute both)) refl))
           refl)
         (rewrite-with
           (lemma mod_hi)
           lr
           lhs
           ()
           ((steps ((compute both)) refl))
           refl))
        refl))
    (have wA
      (=
        (mod (bxor x0 (mod (* 8192 x0) 4294967296)) 4294967296)
        (bxor x0 (mod (* 8192 x0) 4294967296)))
      (rewrite-with
        (lemma wrap32_id)
        lr
        lhs
        ((inst x (bxor x0 (mod (* 8192 x0) 4294967296))))
        ((steps ((rewrite (premise hA_lo) lr lhs true ())) refl)
         (steps ((rewrite (premise hA_lt) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise wA) lr rhs true ())))
    (have b17
      (=
        (bshr (bxor x0 (mod (* 8192 x0) 4294967296)) 17)
        (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072))
      (rewrite-with
        (lemma shr17_div)
        lr
        lhs
        ((inst a (bxor x0 (mod (* 8192 x0) 4294967296))))
        ((steps ((rewrite (premise hA_lo) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise b17) lr rhs true ())))
    (have hQ_lo
      (= (le 0 (ediv (bxor x0 (mod (* 8192 x0) 4294967296)) 131072)) True)
      (rewrite-with
        (lemma wq17_lo)
        lr
        lhs
