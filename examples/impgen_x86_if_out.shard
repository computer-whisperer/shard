(fn gb_ifn3_i () (List IStmt)
  (Cons
    (IIf
      (IBin U32 ILt (ILoc 1) (IConst 9))
      (list
        (IIf
          (IBin U32 ILt (ILoc 2) (IConst 5))
          (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
          (list (ISet 2 (IConst 7))))
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 11))))
    (Cons
      (ISet 2 (IConst 3))
      (Cons
        (IWhile
          (ILoc 2)
          (list
            (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
            (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))
        (gb_ifn3_r1_i)))))

(fn gb_ifn3_x () (List XInstr)
  (Cons
    (XBlock
      (list
        (XBlock (list (XBrIf (CLtU RSI (SImm 9)) 0) (XMovRI RSI 11) (XBr 1)))
        (XBlock
          (list
            (XBlock (list (XBrIf (CLtU RDX (SImm 5)) 0) (XMovRI RDX 7) (XBr 1)))
            (XBin32 XAdd RDX (SImm 2))))
        (XBin32 XAdd RSI (SImm 6))
        (XMovRR RAX RSI)
        (XBin XAnd RAX (SImm 255))
        (XStore8 (AReg RDI) (SReg RAX))))
    (Cons
      (XMovRI RDX 3)
      (Cons
        (XBlock
          (list
            (XLoop
              (list
                (XBrIf (CEqz RDX) 1)
                (XBin32 XAdd RSI (SImm 2))
                (XBin32 XSub RDX (SImm 1))
                (XBr 0)))))
        (gb_ifn3_r1_x)))))

(fn gb_ifn3_r1_i () (List IStmt)
  (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))))

(fn gb_ifn3_r1_x () (List XInstr)
  (list (XBin32 XAdd RSI (SImm 3)) (XMovRI RAX 0)))

(claim sqm_wid_ifn3
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
