;;; examples/upcase_src.shard — the A2 RUNG'S DELIVERABLE (docs/X86.md
;;; §28, on the §27 in-place contract): `./upcase hello` writes `HELLO`
;;; to stdout and exits 0. The entry TRANSFORMS the payload page in
;;; place and returns it; the glue's write variant (contract clause 5b,
;;; selected by the Mem return type) sys_writes [BUF, BUF+len) and exits
;;; 0. No out-buffer, no third argument — the page the payload arrived on
;;; is the page that leaves.
;;;
;;; The entry IS the loop: a one-pointer read-modify-write whose store
;;; value is the range shift. On a flagless ISA that is a nested-XBlock
;;; diamond inside the loop body — one unsigned compare of (b - 97)
;;; against the range width 26, because below 97 the wrap64 subtraction
;;; lands near 2^64. The proof forks with it (three legs, the machine
;;; condition pinned per leg by models/x86/loopkit's xlg_xf* bridges,
;;; bytehood from std/mem's get_lo/get_hi).
;;;
;;; The cert's premise surface is EXACTLY the glue contract's window pair
;;; on the payload pointer and its count — clauses 2-4, role-checked by
;;; tools/lowcheck/accepts.shard against the entry's own arguments. The
;;; empty payload (no argument) writes nothing and exits 0; a 300-byte
;;; argument is truncated to 255 by clause 3 and 255 bytes come back.

(import "../kernel/stdlib.shard")
(import "../std/mem")

(use (:: std mem *))

;; the entry: upcase k payload bytes in place at p, return the page
(fn uc_main ((m Mem) (p Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2)
     (uc_main
       (mem_set
         m
         p
         (if (le 97 (mem_get m p))
           (if (le (mem_get m p) 122) (- (mem_get m p) 32) (mem_get m p))
           (mem_get m p)))
       (+ p 1)
       k2))))

(bin upcase (entry uc_main))
