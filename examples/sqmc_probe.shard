;;; DEV PROBE (the compositional leg): per-piece bridging for a mixed
;;; body -- machine SEGMENT LEMMAS in OPEN-SPINE form (ground instrs as
;;; a Cons-spine ending in a variable tail, the worker-locals trick at
;;; code grain) with the es_scont adapter dispatching the imp segment
;;; run into the machine continuation; the imp side splits at the same
;;; boundary via ist_seam (the proven append seam); the composition
;;; claim chains piece citations with opaque case-var states between
;;; pieces, so goals stay piece-sized (the monolithic leg's churn
;;; killer -- see the V2-5e-4 blocker record).
;;;
;;; Fuel shape (derived): eval_instr peels its own S, so a k-instr
;;; segment runs at (S^ k (S f)) and the continuation enters the tail
;;; at (S f); istmts mirrors with (S^ n (S g)) for n stmts (the Nil
;;; peel of the standalone run eats the +1).

(import "../kernel/stdlib.shard")
(import "../models/imp/imp.shard")
(import "../models/wasm/wasm.shard")
(import "../models/imp/to_wasm.shard")
(import "../models/wasm/loopkit.shard")
(import "../std/nat.shard")
(import "../std/mem")
(import "imp_scalar.shard")

(use (:: models imp imp *))
(use (:: models wasm wasm *))
(use (:: models imp to_wasm *))
(use (:: models wasm loopkit *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: examples imp_scalar *))

;; segment 1 (imp): acc += 5; mem[ptr] := trunc8(acc)
(fn sqmc_s1i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))))

;; --- the open-spine segment lemma for segment 1 -------------------------------
;; Machine walk of seg1's 9 instrs followed by ANY tail rw = the
;; es_scont dispatch of seg1's imp run into rw. UNPREMISED; the store
;; guards split honestly (both machines trap together).
(claim sqmc_s1
  (goal
    ((y0 Int)
     (y1 Int)
     (y2 Int)
     (rw (List Instr))
     (st (List Int))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 9 (S f))
        (MkWModule restfs 65536)
        (Cons (LocalGet 1)
          (Cons (I32Const 5)
            (Cons (I32Bin BAdd)
              (Cons (LocalSet 1)
                (Cons (LocalGet 2)
                  (Cons (LocalGet 1)
                    (Cons (I32Const 255)
                      (Cons (I32Bin BAnd) (Cons (I32Store8) rw)))))))))
        (Cons y0 (Cons y1 (Cons y2 Nil)))
        st
        m)
      (es_scont
        (S f)
        (MkWModule restfs 65536)
        rw
        st
        (istmts
          (S^ 2 (S g))
          65536
          (inline sqmc_s1i)
          (Cons y0 (Cons y1 (Cons y2 Nil)))
          m))))
  (chain
    (steps
      ((compute both (stop es_scont))))
    (case-on (le 0 y2) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute both (stop es_scont))))
           (case-on (lt y2 65536) Bool
             ((case True
                (chain
                  (have hlt1 (= (lt y2 65536) True)
                    (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                  (have hle1 (= (le (+ y2 1) 65536) True)
                    (steps () (by arith (rows (goal 1) (hlt1 1)))))
                  (steps
                    ((rewrite (hyp 0) lr rhs true ())
                     (rewrite (premise hle1) lr lhs true ())
                     (compute both)))
                  refl))
              (case False
                (chain
                  (have hlt1 (= (lt y2 65536) False)
                    (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                  (have hle1 (= (le (+ y2 1) 65536) False)
                    (steps () (by arith (rows (goal 1) (hlt1 1)))))
                  (steps
                    ((rewrite (hyp 0) lr rhs true ())
                     (rewrite (premise hle1) lr lhs true ())
                     (compute both)))
                  refl))))))
       (case False
         (steps
           ((rewrite (hyp 0) lr both true ())
            (compute both))
           refl))))))

(fn sqmc_l1i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
    (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))

(fn sqmc_l2i () (List IStmt)
  (list
    (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
    (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))

(fn sqmc_l1w () (List Instr)
  (list
    (LocalGet 0)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 1)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 0)
    (Br 0)))

(fn sqmc_l2w () (List Instr)
  (list
    (LocalGet 0)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (LocalGet 2)
    (I32Const 255)
    (I32Bin BAnd)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 0)
    (Br 0)))
;; --- worker 1: the memless counting loop (no splits, IH at hyp 0) ------------------
(claim sqmc_wk1
  (goal
    ((x1 Int)
     (x2 Int)
     (rr (List Int))
     (k Nat)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (eval_loop
        (S^ 16 (lg_fuel k c))
        (MkWModule restfs 65536)
        (inline sqmc_l1w)
        (Cons (int_of_nat k) (Cons x1 (Cons x2 rr)))
        st
        m)
      (iw_out
        st
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 0)
          (inline sqmc_l1i)
          (Cons (int_of_nat k) (Cons x1 (Cons x2 rr)))
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold eval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr both true ())))
         (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
           (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
         (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
           (steps
             ((rewrite (premise hs1) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (have hcap (= (lt (int_of_nat k2) 4294967296) True)
           (steps () (by arith (rows (goal 1) (hks 1)))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma iwrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (steps ((rewrite (premise hcap) lr lhs true ())) refl))
             refl))
         (steps ((rewrite (premise hwk) lr both true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst c2 c2))
           ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
         refl)))))

;; --- worker 2: the store loop (two splits, IH at hyp 2) ----------------------------
(claim sqmc_wk2
  (goal
    ((x1 Int)
     (x2 Int)
     (rr (List Int))
     (k Nat)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (eval_loop
        (S^ 17 (lg_fuel k c))
        (MkWModule restfs 65536)
        (inline sqmc_l2w)
        (Cons (int_of_nat k) (Cons x1 (Cons x2 rr)))
        st
        m)
      (iw_out
        st
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 0)
          (inline sqmc_l2i)
          (Cons (int_of_nat k) (Cons x1 (Cons x2 rr)))
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold eval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (case-on (le 0 x1) Bool
           ((case True
              (chain
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop eval_loop iwhile lg_fuel iw_out))))
                (case-on (lt x1 65536) Bool
                  ((case True
                     (chain
                       (have hlt1 (= (lt x1 65536) True)
                         (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                       (have hle1 (= (le (+ x1 1) 65536) True)
                         (steps () (by arith (rows (goal 1) (hlt1 1)))))
                       (steps
                         ((rewrite (hyp 0) lr rhs true ())
                          (rewrite (premise hle1) lr lhs true ())
                          (compute both (stop eval_loop iwhile lg_fuel iw_out))))
                       (have hsub
                         (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
                         (rewrite-with (lemma lg_sub) lr lhs () () refl))
                       (steps ((rewrite (premise hsub) lr both true ())))
                       (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
                         (steps
                           ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                           refl))
                       (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
                         (steps
                           ((rewrite (premise hs1) rl lhs true ())
                            (rewrite (premise 0) lr lhs true ()))
                           refl))
                       (have hcap (= (lt (int_of_nat k2) 4294967296) True)
                         (steps () (by arith (rows (goal 1) (hks 1)))))
                       (have hwk
                         (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
                         (rewrite-with
                           (lemma iwrap32_id)
                           lr
                           lhs
                           ((inst x (int_of_nat k2)))
                           ((rewrite-with
                              (lemma int_of_nat_nonneg)
                              lr
                              lhs
                              ()
                              ()
                              refl)
                            (steps
                              ((rewrite (premise hcap) lr lhs true ()))
                              refl))
                           refl))
                       (steps ((rewrite (premise hwk) lr both true ())))
                       (rewrite-with
                         (hyp 2)
                         lr
                         lhs
                         ((inst c2 c2))
                         ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
                       refl))
                   (case False
                     (chain
                       (have hlt1 (= (lt x1 65536) False)
                         (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                       (have hle1 (= (le (+ x1 1) 65536) False)
                         (steps () (by arith (rows (goal 1) (hlt1 1)))))
                       (steps
                         ((rewrite (hyp 0) lr rhs true ())
                          (rewrite (premise hle1) lr lhs true ())
                          (compute both (stop lg_fuel))))
                       refl))))))
            (case False
              (chain
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop lg_fuel))))
                refl)))))))))


;; segment 2 (imp): acc += 7
(fn sqmc_s2i () (List IStmt)
  (list (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))))

;; segment 3 (imp): ptr += 3
(fn sqmc_s3i () (List IStmt)
  (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

;; the whole imp body: seg1 | loop1 | seg2 | loop2 | seg3
(fn sqmc_body () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

;; the imp rest slices (piece boundaries; reader-inlined in the haves)
(fn sqmc_r1i () (List IStmt)
  (list
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqmc_r2i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqmc_r3i () (List IStmt)
  (list
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqmc_r4i () (List IStmt)
  (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

;; the whole machine spine and its rest slices
(fn sqmc_winstrs () (List Instr)
  (list
    (LocalGet 1)
    (I32Const 5)
    (I32Bin BAdd)
    (LocalSet 1)
    (LocalGet 2)
    (LocalGet 1)
    (I32Const 255)
    (I32Bin BAnd)
    (I32Store8)
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (I32Const 1)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 1)
    (I32Const 7)
    (I32Bin BAdd)
    (LocalSet 1)
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (LocalGet 2)
            (I32Const 255)
            (I32Bin BAnd)
            (I32Store8)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 2)
    (I32Const 3)
    (I32Bin BAdd)
    (LocalSet 2)))

(fn sqmc_r1w () (List Instr)
  (list
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (I32Const 1)
            (I32Bin BAdd)
            (LocalSet 1)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 1)
    (I32Const 7)
    (I32Bin BAdd)
    (LocalSet 1)
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (LocalGet 2)
            (I32Const 255)
            (I32Bin BAnd)
            (I32Store8)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 2)
    (I32Const 3)
    (I32Bin BAdd)
    (LocalSet 2)))

(fn sqmc_r2w () (List Instr)
  (list
    (LocalGet 1)
    (I32Const 7)
    (I32Bin BAdd)
    (LocalSet 1)
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (LocalGet 2)
            (I32Const 255)
            (I32Bin BAnd)
            (I32Store8)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 2)
    (I32Const 3)
    (I32Bin BAdd)
    (LocalSet 2)))

(fn sqmc_r3w () (List Instr)
  (list
    (I32Const 1)
    (LocalSet 0)
    (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
            (BrIf 1)
            (LocalGet 1)
            (LocalGet 2)
            (I32Const 255)
            (I32Bin BAnd)
            (I32Store8)
            (LocalGet 0)
            (I32Const 1)
            (I32Bin BSub)
            (LocalSet 0)
            (Br 0)))))
    (LocalGet 2)
    (I32Const 3)
    (I32Bin BAdd)
    (LocalSet 2)))

(fn sqmc_r4w () (List Instr)
  (list (LocalGet 2) (I32Const 3) (I32Bin BAdd) (LocalSet 2)))

;; the translation tie at the 3-slot U32 frame
(claim sqmc_tie
  (goal () ()
    (= (iw_stmts (list U32 U32 U32) (sqmc_body)) (Some (sqmc_winstrs))))
  (steps ((compute both)) refl))

;; --- the memless segment lemmas (open spine) -----------------------------------
(claim sqmc_s2
  (goal
    ((y0 Int)
     (y1 Int)
     (y2 Int)
     (rw (List Instr))
     (st (List Int))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 4 (S f))
        (MkWModule restfs 65536)
        (Cons (LocalGet 1)
          (Cons (I32Const 7) (Cons (I32Bin BAdd) (Cons (LocalSet 1) rw))))
        (Cons y0 (Cons y1 (Cons y2 Nil)))
        st
        m)
      (es_scont
        (S f)
        (MkWModule restfs 65536)
        rw
        st
        (istmts
          (S^ 1 (S g))
          65536
          (inline sqmc_s2i)
          (Cons y0 (Cons y1 (Cons y2 Nil)))
          m))))
  (steps ((compute both)) refl))

(claim sqmc_s3
  (goal
    ((y0 Int)
     (y1 Int)
     (y2 Int)
     (rw (List Instr))
     (st (List Int))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 4 (S f))
        (MkWModule restfs 65536)
        (Cons (LocalGet 2)
          (Cons (I32Const 3) (Cons (I32Bin BAdd) (Cons (LocalSet 2) rw))))
        (Cons y0 (Cons y1 (Cons y2 Nil)))
        st
        m)
      (es_scont
        (S f)
        (MkWModule restfs 65536)
        rw
        st
        (istmts
          (S^ 1 (S g))
          65536
          (inline sqmc_s3i)
          (Cons y0 (Cons y1 (Cons y2 Nil)))
          m))))
  (steps ((compute both)) refl))

;; --- the compositional two-loop bridge ------------------------------------------
;; The monolithic sqm2_leg narrative re-told at piece grain: segment
;; lemmas jump the straight-line chunks (opaque case-var states between
;; pieces), ist_seam splits the imp walk at each boundary, the machine
;; tail folds behind rest-fns, and the loop pieces run the established
;; loop-head machinery (ladder, respell, reshape, worker cite, shared
;; iwhile case-on, il_wlen exit exposure). Goals stay piece-sized.
(claim sqmc_leg
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (st (List Int))
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List Func)))
    ()
    (=
      (eval_seq
        (S^ 60 c)
        (MkWModule restfs 65536)
        (inline sqmc_winstrs)
        (list x0 x1 x2)
        st
        m)
      (iw_sout
        st
        (istmts (S^ 40 c2) 65536 (inline sqmc_body) (list x0 x1 x2) m))))
  (chain
    (have hsp1
      (= (inline sqmc_body) (isapp (inline sqmc_s1i) (inline sqmc_r1i)))
      (steps ((compute both)) refl))
    (have hfg1
      (= (S^ 40 c2) (lg_fuel (istn (inline sqmc_s1i)) (S (S^ 37 c2))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hsp1) lr rhs true ())
       (rewrite (premise hfg1) lr rhs true ())))
    (rewrite-with
      (lemma ist_seam)
      lr
      rhs
      ((inst g c2))
      ((steps ((compute lhs)) refl)))
    (have hfg1b
      (= (lg_fuel (istn (inline sqmc_s1i)) (S c2)) (S^ 2 (S c2)))
      (steps ((compute both)) refl))
    (steps ((rewrite (premise hfg1b) lr rhs true ())))
    (rewrite-with (lemma sqmc_s1) lr lhs ((inst g c2)) ())
    (have hfw1
      (=
        (inline sqmc_r1w)
        (Cons (I32Const 1)
          (Cons (LocalSet 0)
            (Cons (Block (list (Loop (list
            (LocalGet 0)
            (I32Eqz)
