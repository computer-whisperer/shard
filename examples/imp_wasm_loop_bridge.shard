;;; examples/imp_wasm_loop_bridge.shard — imp ⊑ wasm, the LOOP class
;;; (docs/IMP.md rung I1b). Four claim families:
;;;
;;;   TIES     — the translator's output IS the generated artifact:
;;;              (imp2w_fn (il_*_fn)) = (Some (lp_*_func)), stated
;;;              directly against the named funcs of the generated
;;;              cert file (examples/wasmgen_loop_out.shard). The
;;;              IWhile encoding reproduces wasmgen's loop shape
;;;              byte for byte.
;;;   WORKERS  — the machine-vs-machine loop alignment, per program:
;;;              eval_loop over the translated body = (iw_out st
;;;              (iwhile … over the imp body)), by induction on the
;;;              counter. THE M×N KILL LIVES HERE: these inductions
;;;              never mention the spec — the width-residue apparatus
;;;              (wrap32 haves) burns off on the wasm side against
;;;              the imp machine's exact ops, so no per-program
;;;              spec ⊑ wasm worker is ever needed again. The two
;;;              towers share one slack tail (the denotation bridges
;;;              restore independent fuels).
;;;   BRIDGES  — the denotation boundary: call_fn_mem over the
;;;              translated module = icall_mem over the imp program.
;;;   COMPOSE  — spec ⊑ imp (imp_lp_*, rung I0) chains with imp ⊑
;;;              wasm (this file) into spec ⊑ wasm in two rewrites —
;;;              the statement lowered_lp_* makes, reached through
;;;              the neutral machine.
;;;
;;; PROOF GATES ONLY (DI2): no engine leg exists at imp; the wasm
;;; artifacts these certs describe are gated by the existing wasm
;;; machinery when they ship.

(import "../kernel/stdlib.shard")
(import "../std/nat.shard")
(use (:: std nat *))
(import "../std/mem")
(use (:: std mem *))
(import "wasmgen_loop_src.shard")
(use (:: examples wasmgen_loop_src *))
(import "wasmgen_loop_out.shard")
(use (:: examples wasmgen_loop_out *))
(import "../models/imp/imp.shard")
(use (:: models imp imp *))
(import "../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../models/imp/to_wasm.shard")
(use (:: models imp to_wasm *))
(import "../models/wasm/loopkit.shard")
(use (:: models wasm loopkit *))
(import "imp_loop.shard")
(use (:: examples imp_loop *))

;; --- local body copies for the (inline …) sugar ---------------------------------
;; (inline F) resolves against THIS file's nullary fns only, so the four
;; loop bodies the claims state are copied here — and tied to their
;; originals by the tie_*body claims below, so the copies cannot drift.

(fn br_fill_w () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 0)
    (LocalGet 1)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn br_sum_w () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 1)
    (LocalGet 0)
    (I32Load8U)
    (I32Bin BAdd)
    (LocalSet 1)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn br_fill_i () (List IStmt)
  (list
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin IAdd (ILoc 0) (IConst 1)))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))))

(fn br_sum_i () (List IStmt)
  (list
    (ISet 1 (IBin IAdd (ILoc 1) (ILoad (ILoc 0))))
    (ISet 0 (IBin IAdd (ILoc 0) (IConst 1)))
    (ISet 2 (IBin ISub (ILoc 2) (IConst 1)))))

;; --- the ties: translator output = the generated artifact -----------------------

(claim tie_fill
  (goal () () (= (imp2w_fn (il_fill_fn)) (Some (lp_fill_func))))
  (steps ((compute both)) refl))

(claim tie_sum
  (goal () () (= (imp2w_fn (il_sum_fn)) (Some (lp_sum_func))))
  (steps ((compute both)) refl))

;; the local body copies are the originals, byte for byte
(claim tie_fill_wbody
  (goal () () (= (br_fill_w) (lp_fill_body)))
  (steps ((compute both)) refl))

(claim tie_sum_wbody
  (goal () () (= (br_sum_w) (lp_sum_body)))
  (steps ((compute both)) refl))

(claim tie_fill_ibody
  (goal () () (= (br_fill_i) (il_fill_body)))
  (steps ((compute both)) refl))

(claim tie_sum_ibody
  (goal () () (= (br_sum_i) (il_sum_body)))
  (steps ((compute both)) refl))

;; --- the fill worker bridge: both machines, one induction -----------------------

(claim iww_fill
  (goal
    ((d Int)
     (v Int)
     (st (List Int))
     (m0 Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (eval_loop
        (S^ 19 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline br_fill_w)))) (I32Const 0)))
            restfs)
          65536)
        (inline br_fill_w)
        (list d v (int_of_nat k))
        st
        m0)
      (iw_out
        st
        (iwhile
          (S^ 10 (lg_fuel k c))
          65536
          (ILoc 2)
          (inline br_fill_i)
          (list d v (int_of_nat k))
          m0))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold eval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute both (stop eval_loop iwhile lg_fuel iw_out))
            (rewrite (premise 0) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma im_lt)
           lr
           rhs
           ((inst c k2))
           ((steps ((rewrite (premise 1) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma lg_kM)
                lr
                lhs
                ((inst a d) (inst c k2))
                ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hw0 (= (mod (+ d 1) 4294967296) (+ d 1))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ d 1)))
             ((rewrite-with
                (lemma lg_lo1)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma lg_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma lg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hw0) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)))
         refl)))))

;; --- the sum worker bridge: the read direction + the accumulator invariant ------

(claim iww_sum
  (goal
    ((p Int)
     (acc Int)
     (st (List Int))
     (m0 Mem)
     (c Nat)
     (k Nat)
     (restfs (List Func)))
    ((= (le 0 p) True)
     (= (le 0 acc) True)
     (= (le (+ p (int_of_nat k)) 65536) True)
     (= (le (+ acc (* 256 (int_of_nat k))) 4294967296) True))
    (=
      (eval_loop
        (S^ 21 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline br_sum_w)))) (LocalGet 1)))
            restfs)
          65536)
        (inline br_sum_w)
        (list p acc (int_of_nat k))
        st
        m0)
      (iw_out
        st
        (iwhile
          (S^ 10 (lg_fuel k c))
          65536
          (ILoc 2)
          (inline br_sum_i)
          (list p acc (int_of_nat k))
          m0))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold eval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps
           ((compute both (stop eval_loop iwhile lg_fuel iw_out))
            (rewrite (premise 0) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (rewrite-with
           (lemma lg_a1_ms)
           lr
           lhs
           ((inst c k2))
           ((steps ((rewrite (premise 2) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma im_lt)
           lr
           rhs
           ((inst c k2))
           ((steps ((rewrite (premise 2) lr lhs true ())) refl)
            (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
            (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps
           ((rewrite (premise hsub) lr both true ())
            (compute both (stop eval_loop iwhile lg_fuel iw_out))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (rewrite-with
                (lemma lg_kM)
                lr
                lhs
                ((inst a p) (inst c k2))
                ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl))
             refl))
         (steps ((rewrite (premise hwk) lr lhs true ())))
         (have hw0 (= (mod (+ p 1) 4294967296) (+ p 1))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ p 1)))
             ((rewrite-with
                (lemma lg_lo1)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                refl)
              (rewrite-with
                (lemma lg_32)
                lr
                lhs
                ()
                ((rewrite-with
                   (lemma lg_a1_ms)
                   lr
                   lhs
                   ((inst c k2))
                   ((steps ((rewrite (premise 2) lr lhs true ())) refl)
                    (steps
                      ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                      refl)
                    (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                   refl))
                refl))
             refl))
         (steps ((rewrite (premise hw0) lr lhs true ())))
         (have hwa
           (= (mod (+ acc (mem_get m0 p)) 4294967296) (+ acc (mem_get m0 p)))
           (rewrite-with
             (lemma wrap32_id)
             lr
             lhs
             ((inst x (+ acc (mem_get m0 p))))
             ((rewrite-with
                (lemma lg_sum_lo)
                lr
                lhs
                ()
                ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                 (rewrite-with (lemma get_lo) lr lhs () () refl))
                refl)
              (rewrite-with
                (lemma lg_sum_32)
                lr
                lhs
                ((inst c k2))
                ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                 (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
                 (rewrite-with (lemma get_hi) lr lhs () () refl)
                 (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))
                refl))
             refl))
         (steps ((rewrite (premise hwa) lr lhs true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ()
           ((rewrite-with
              (lemma lg_lo1)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 0) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_sum_lo)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 1) lr lhs true ())) refl)
               (rewrite-with (lemma get_lo) lr lhs () () refl))
              refl)
            (rewrite-with
              (lemma lg_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 2) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
              refl)
            (rewrite-with
              (lemma lg_sum_shift)
              lr
              lhs
              ()
              ((steps ((rewrite (premise 3) lr lhs true ())) refl)
               (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)
               (rewrite-with (lemma get_hi) lr lhs () () refl))
              refl)))
         refl)))))

;; --- the denotation bridges: call_fn_mem = icall_mem -----------------------------

(claim imp_w_fill
  (goal ((d Int) (v Int) (m0 Mem) (c Nat) (c2 Nat) (k Nat))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (call_fn_mem
        (S^ 23 (lg_fuel k c))
        (MkWModule (list (w_of (imp2w_fn (il_fill_fn)))) 65536)
        0
        (list d v (int_of_nat k))
        m0)
      (icall_mem
        (S^ 12 (lg_fuel k c2))
        (il_prog (il_fill_fn))
        0
        (list d v (int_of_nat k))
        m0)))
  (chain
    (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
    (rewrite-with
      (lemma iww_fill)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imw_fill)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imw_fill)
      lr
      rhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))

(claim imp_w_sum
  (goal ((p Int) (acc Int) (m0 Mem) (c Nat) (c2 Nat) (k Nat))
    ((= (le 0 p) True)
     (= (le 0 acc) True)
     (= (le (+ p (int_of_nat k)) 65536) True)
     (= (le (+ acc (* 256 (int_of_nat k))) 4294967296) True))
    (=
      (call_fn_mem
        (S^ 25 (lg_fuel k c))
        (MkWModule (list (w_of (imp2w_fn (il_sum_fn)))) 65536)
        0
        (list p acc (int_of_nat k))
        m0)
      (icall_mem
        (S^ 12 (lg_fuel k c2))
        (il_prog (il_sum_fn))
        0
        (list p acc (int_of_nat k))
        m0)))
  (chain
    (steps ((compute both (stop eval_loop iwhile lg_fuel iw_out))))
    (rewrite-with
      (lemma iww_sum)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imw_sum)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imw_sum)
      lr
      rhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))

;; --- the compositions: the factored tower closes over loops ---------------------

;; spec ⊑ wasm for the translated fill — lowered_lp_fill's statement,
;; reached through the neutral machine in two rewrites
(claim wcomp_lp_fill
  (goal ((d Int) (v Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 d) True) (= (le (+ d (int_of_nat k)) 65536) True))
    (=
      (call_fn_mem
        (S^ 23 (lg_fuel k c))
        (MkWModule (list (w_of (imp2w_fn (il_fill_fn)))) 65536)
        0
        (list d v (int_of_nat k))
        m0)
      (Some (Pair 0 (lp_fill m0 d v k)))))
  (chain
    (rewrite-with
      (lemma imp_w_fill)
      lr
      lhs
      ((inst c2 Z))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imp_lp_fill)
      lr
      lhs
      ((inst c Z))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    refl))

(claim wcomp_lp_sum
  (goal ((p Int) (acc Int) (m0 Mem) (c Nat) (k Nat))
    ((= (le 0 p) True)
     (= (le 0 acc) True)
     (= (le (+ p (int_of_nat k)) 65536) True)
     (= (le (+ acc (* 256 (int_of_nat k))) 4294967296) True))
    (=
      (call_fn_mem
        (S^ 25 (lg_fuel k c))
        (MkWModule (list (w_of (imp2w_fn (il_sum_fn)))) 65536)
        0
        (list p acc (int_of_nat k))
        m0)
      (Some (Pair (lp_sum m0 p acc k) m0))))
  (chain
    (rewrite-with
      (lemma imp_w_sum)
      lr
      lhs
      ((inst c2 Z))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)
       (steps ((rewrite (premise 3) lr lhs true ())) refl)))
    (rewrite-with
      (lemma imp_lp_sum)
      lr
      lhs
      ((inst c Z))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 2) lr lhs true ())) refl)))
    refl))
