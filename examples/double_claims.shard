;;; Claims about the `double` fn declared in double_lib.shard, on the
;;; proof-DSL surface.
;;;
;;; The (use-module …) form below loads double_lib.shard as a user module;
;;; subsequent (claim …) forms get that module passed as the `m` arg to
;;; check_sequent, so a `simp` step can unfold `double`.

(use-module "double_lib.shard")

;; (double 5) = 10. simp lhs unfolds double then fires +; refl closes 10 = 10.
(claim double_5_is_10
  (goal () ()
    (= (double 5) 10))
  (steps ((simp lhs)) refl))

;; (double 4) = (+ 3 5). simp both reduces lhs (double 4 → 8) and rhs (3+5 → 8);
;; refl closes 8 = 8.
(claim double_4_meets_3_plus_5
  (goal () ()
    (= (double 4) (+ 3 5)))
  (steps ((simp both)) refl))
