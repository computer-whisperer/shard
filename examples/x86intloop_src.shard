;;; examples/x86intloop_src.shard — source fn for the x86_64 INT-RETURN
;;; loop fragment (docs/X86.md §14 growth; probe
;;; examples/xintloop_probe.shard, the wasm §6ab twin): the SUM shape —
;;; a Nat-counted loop whose Z arm returns an ACCUMULATOR and whose sum
;;; accumulator takes the data-dependent update (+ acc (mem_get m p)).
;;; This is bytesum, the A1 bin rung's entry shape (X86.md §22).
;;; v1 fences (loud refusals at the emitter): exactly two accumulators —
;;; the advancing address first, the sum second; scan/flag shapes are
;;; named growth. tools/x86gen emits examples/x86intloop_out.shard from
;;; this file: per fn a body/func literal pair, the induction WORKER
;;; (xliw_*), and the standard lowered-conformance theorem, citing
;;; models/x86/loopkit's kit facts (xlg_last + the sum-invariant trio).

(import "../kernel/stdlib.shard")
(import "../std/mem")

(use (:: std mem *))

;; the probed template's exact shape: sum of k bytes starting at p,
;; accumulated onto a
(fn xi_bsum ((m Mem) (p Int) (a Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z a)
    ((S k2) (xi_bsum m (+ p 1) (+ a (mem_get m p)) k2))))
