;;; wasmgen_call_src.shard — the CALLS-IN-LOOPS source set (docs/
;;; LOWERING.md; probe: examples/callloop_probe.shard). A mem-fragment
;;; callee followed by a loop that CALLS it per iteration: cw_put stores
;;; a value at both bytes of a 2-byte cell; cw_fill walks k cells at
;;; stride 2 calling cw_put on each — the uniform-rep cell runway shape.
;;; The emitter writes cw_put's portable + linked certs as usual, and
;;; cw_fill's whole unit into the LINKED file (structural form: the
;;; callee's literal rides the module spine, so the cert regenerates on
;;; callee edits — the §6f portability limit).

(import "../kernel/stdlib.shard")
(import "../std/mem")
(import "../std/nat.shard")
(use (:: std mem *))
(use (:: std nat *))

;; the callee: store v at both bytes of the 2-byte cell at d
(fn cw_put ((m Mem) (d Int) (v Int)) Mem (mem_set (mem_set m d v) (+ d 1) v))

;; the loop: fill k 2-byte cells starting at d by calling cw_put
(fn cw_fill ((m Mem) (d Int) (v Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2) (cw_fill (cw_put m d v) (+ d 2) v k2))))
