;;; auto_demo.auto.shard — proof sidecar for auto_demo.shard. The checker
;;; replays the (proof-for NAME PROOF) entry for each `auto` proof in that
;;; file; regenerate with the proof solver (entries here are hand-written —
;;; the solver does not exist yet).

(proof-for plus_comm_auto (by lia (list)))

(proof-for add_n_zero_auto
  (induct n
    ((case Z (steps ((unfold add lhs) (reduce lhs)) refl))
     (case S
       (steps
         ((unfold add lhs) (reduce lhs) (rewrite (hyp 0) lr lhs true ()))
         refl)))))

(proof-for add_zero_right
  (induct n
    ((case Z (steps ((unfold add lhs) (reduce lhs)) refl))
     (case S
       (steps
         ((unfold add lhs) (reduce lhs) (rewrite (hyp 0) lr lhs true ()))
         refl)))))
