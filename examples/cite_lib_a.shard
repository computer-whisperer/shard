;;; Stage-4 regression fixture: module A proves `shared_fact` = one equation.
;;; cite_resolves.shard cites the SAME bare name from module B with a
;;; DIFFERENT equation — resolution must pick the right module's lemma.
(import "../kernel/stdlib.shard")

(fn fa ((n Int)) Int (+ n 1))

(claim shared_fact
  (goal ((n Int)) () (= (fa n) (+ n 1)))
  (steps ((compute both)) refl))
