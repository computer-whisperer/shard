;;; float_val_compute.shard — COMPUTE pins for the L1 exact value
;;; (docs/FLOATS.md §3, rung R1 slice 1; the utf8_compute pattern).
;;;
;;; The core exposes the exact value as the Int pair fval_num/fval_den (those
;;; compute in any closure — pinned in std/float/mod.req/float.shard's own pins would
;;; also work, but they belong with the bridge); the CLAIM-level rat spelling
;;; (rat_make (fval_num f x) (fval_den f x)) needs the rat IMPL in the
;;; closure to reduce, so this file imports both impls explicitly (as-is,
;;; ungranted). A Rat-typed term inside a claim carries no refined-return
;;; obligation — the reason the core speaks Ints (see float.shard's header).

(import "../kernel/stdlib.shard")
(import "../std/rat/rat.shard")  ; the rat IMPL — rat_make/rat_num/rat_den bodies
(import "../std/float/mod.req/float.shard")  ; the L1 model
(use (:: std rat *))
(use (:: std float float *))

;; --- the Int pair ----------------------------------------------------------------

;; F32 1.0 = (Fin + 2^23 0): e = 0 < MW = 23, so the raw pair is
;; (2^23, 2^23) — UNREDUCED by design; the rat bridge below normalizes.
(claim pair_f32_one_num
  (goal () () (= (fval_num (fmt_f32) (Fin False 8388608 0)) 8388608))
  (steps ((compute both)) refl))
(claim pair_f32_one_den
  (goal () () (= (fval_den (fmt_f32) (Fin False 8388608 0)) (fpow2 23)))
  (steps ((compute both)) refl))

;; 4.0 = (Fin + 2^23 2): e < MW still — pair (2^23, 2^21).
(claim pair_f32_four_den
  (goal () () (= (fval_den (fmt_f32) (Fin False 8388608 2)) (fpow2 21)))
  (steps ((compute both)) refl))

;; a genuinely integral case: e = 24 >= MW folds the power in.
(claim pair_f32_big
  (goal () () (= (fval_num (fmt_f32) (Fin False 8388608 24)) 16777216))
  (steps ((compute both)) refl))

;; the smallest F32 subnormal: 1 / 2^149.
(claim pair_f32_submin_num
  (goal () () (= (fval_num (fmt_f32) (Fin False 1 -126)) 1))
  (steps ((compute both)) refl))
(claim pair_f32_submin_den
  (goal () () (= (fval_den (fmt_f32) (Fin False 1 -126)) (fpow2 149)))
  (steps ((compute both)) refl))

;; --- the rat bridge: val = rat_make num den ----------------------------------------

;; F32 1.0 normalizes to 1/1.
(claim val_f32_one_num
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_f32) (Fin False 8388608 0))
          (fval_den (fmt_f32) (Fin False 8388608 0))))
      1))
  (steps ((compute both)) refl))
(claim val_f32_one_den
  (goal () ()
    (=
      (rat_den
        (rat_make
          (fval_num (fmt_f32) (Fin False 8388608 0))
          (fval_den (fmt_f32) (Fin False 8388608 0))))
      1))
  (steps ((compute both)) refl))

;; F32 1.5 = (Fin + (2^23 + 2^22) 0) normalizes to 3/2.
(claim val_f32_threehalf_num
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_f32) (Fin False 12582912 0))
          (fval_den (fmt_f32) (Fin False 12582912 0))))
      3))
  (steps ((compute both)) refl))
(claim val_f32_threehalf_den
  (goal () ()
    (=
      (rat_den
        (rat_make
          (fval_num (fmt_f32) (Fin False 12582912 0))
          (fval_den (fmt_f32) (Fin False 12582912 0))))
      2))
  (steps ((compute both)) refl))

;; -2.0 = (Fin - 2^23 1): the sign rides the numerator through normalization.
(claim val_f32_negtwo_num
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_f32) (Fin True 8388608 1))
          (fval_den (fmt_f32) (Fin True 8388608 1))))
      -2))
  (steps ((compute both)) refl))

;; both signed zeros collapse to the canonical rat zero (val is many-one
;; exactly at zero; the VIEW keeps them distinct).
(claim val_f32_negzero
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_f32) (Fin True 0 -126))
          (fval_den (fmt_f32) (Fin True 0 -126))))
      0))
  (steps ((compute both)) refl))
(claim val_f32_negzero_den
  (goal () ()
    (=
      (rat_den
        (rat_make
          (fval_num (fmt_f32) (Fin True 0 -126))
          (fval_den (fmt_f32) (Fin True 0 -126))))
      1))
  (steps ((compute both)) refl))

;; f8e4m3fn's real maximum: 448 = 14 * 2^5 at the top-row slot (m 14, e 8).
(claim val_f8fn_max
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_f8e4m3fn) (Fin False 14 8))
          (fval_den (fmt_f8e4m3fn) (Fin False 14 8))))
      448))
  (steps ((compute both)) refl))

;; BF16 shares F32's exponent range: 1.0 sits at (Fin + 2^7 0).
(claim val_bf16_one
  (goal () ()
    (=
      (rat_num
        (rat_make
          (fval_num (fmt_bf16) (Fin False 128 0))
          (fval_den (fmt_bf16) (Fin False 128 0))))
      1))
  (steps ((compute both)) refl))
