;;; parse_rejects — EXPECTED TO FAIL: exercises the parse-failure diagnosis
;;; (reader.shard parse_diag / build_module_d). The claim below is missing one
;;; closing paren, so checking this file must report:
;;;
;;;   FAIL  __module__
;;;   unclosed form (claim deliberately_unclosed ...) at line 12 -- missing 1 ')' [source N of the import closure]
;;;
;;; (cf. lia_rejects / module_gate_rejects — reject-tests assert the FAIL.)

(fn idf ((x Int)) Int x)

(claim deliberately_unclosed
  (goal ((a Int)) ()
    (= (idf a) a))
  (steps ((unfold idf lhs) (reduce lhs)) refl)
