;;; lowergen — the certifying emitter (docs/LOWERING.md §6): the scalar
;;; let/if fragment. For every fn in the target file whose body is
;;; arithmetic over Int params, u32 literals (+ - * only), single-binding
;;; lets, and tail-position ifs over int_eq/lt comparisons, emit:
;;;   - the wasm function literal (postorder stack code; one LocalSet per
;;;     let, locals allocated after the params in textual order; each if
;;;     a Block/BrIf/Br diamond — True exits the inner block to the THEN
;;;     code, False falls through the ELSE code), and
;;;   - the standard lowered-conformance claim (docs/LOWERING.md §2) with
;;;     its full proof, in chain form mirroring the branch tree: compute
;;;     lhs + unfold/ζ-reduce SPEC rhs; per if a case-on with the fixed
;;;     arm template (rewrite ctor-named case hyp into both sides, compute
;;;     both — the probe-pinned fuel max+slack law needs ONE tower for the
;;;     longest path, no per-branch fuel); per unique arith node,
;;;     discharged in the REGION where its code executes, a named have
;;;     citing wrap32_id once + an all-occurrences rewrite of the have
;;;     fact (the sharing-proof pattern — a let-bound value read k times
;;;     duplicates k-fold under ζ but is discharged once).
;;; The emitted statement generator IS the schema consensus mechanism; the
;;; output is deterministic (weld discipline: regenerable byte-identical
;;; after shardfmt).
;;;
;;; THE CONTRACT (lower.shard's): front end is the KERNEL'S by library
;;; import; refuse, don't guess — any body outside the fragment is a loud
;;; per-fn error and exit 1. Fragment rules: all params Int, return Int;
;;; body nodes are params, let-bound names, literals in [0, 2^32), and
;;; binary + - *; lets bind exactly one name; ifs in TAIL position only,
;;; conditions = int_eq/lt over params/aliases/literals (no arith in
;;; conditions — wraps must never enter the case-on spelling); every arith
;;; node of the SUBSTITUTED body must contain a param (constant-fold
;;; ground subtrees in the source). PRE caveat: arm range premises
;;; quantify over the WHOLE contract (see the tail-walk note).
;;;
;;; THE MEM FRAGMENT (first param Mem): bodies that read/write bytes lower
;;; to wasm Calls against std/mem's shipped artifact functions and the
;;; proofs COMPOSE BY CITATION (call_bridge + lowered_mem_get/set) — the
;;; callee bodies are never computed into. See the mem-fragment section
;;; below for the fragment rules and the stage law.
;;;
;;; THE KIT: the reusable emitter library lives in tools/low — doc.shard
;;; (output documents + path/header text), schema.shard (canonical-expr
;;; spelling, premise layouts, statement builders), proof.shard (the
;;; wrap-event / call_bridge / link-derivation proof templates). This
;;; file keeps what is genuinely the app: the fragment walks, claim
;;; assembly, the module walk, and the CLI.
;;;
;;; RUN IT:  bin/shard_eval run tools/lowergen/lowergen.shard SRC OUT.raw
;;;          then shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reader.shard")
(import "../low/doc.shard")
(import "../low/schema.shard")
(import "../low/proof.shard")

(use (:: kernel loader resolve_closure))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term BVar))
(use (:: kernel term Call))
(use (:: kernel term Let))
(use (:: kernel term If))
(use (:: kernel term IntLit))
(use (:: kernel term Match))
(use (:: kernel term Arm))
(use (:: kernel term Pat))
(use (:: kernel term PCtor))
(use (:: kernel term PVar))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term append_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module FnTrie))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: tools low doc *))
(use (:: tools low schema *))
(use (:: tools low proof *))


;; ---- the fragment ------------------------------------------------------------
;;
;; TWO WALKS, TWO CONCERNS (the let design, docs/LOWERING.md §6):
;;   - CODE is emitted from the ORIGINAL let tree — sharing preserved, one
;;     LocalSet per binding, locals allocated in textual order after the
;;     params (deterministic → regen-stable).
;;   - PREMISES/CITATIONS come from the ζ-SUBSTITUTED body — the kernel
;;     opens lets by substitution, so the compute residue's mod-sites are
;;     exactly the substituted tree's arith nodes. Duplicates (a shared
;;     local read twice) dedupe by spelling into ONE citation; an unused
;;     binding's nodes never appear at all.
;; gen_e does the code walk and simultaneously builds the CANONICAL
;; substituted expr (params as FVars named x0…, let-free, BVar-free);
;; nodes_e then collects the unique arith nodes postorder from it.

;; canonical walk result: instr docs (emission order), instr count, next
;; free local index, canonical substituted expr.
(type G (GOk (List Doc) Int Int Expr) (GErr (List Int)))

(fn gen_e ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) G
  (measure (struct e))
  (match e
    ((BVar i)
     (match (env_at env i)
       ((Some (Pair ce k))
        (GOk
          (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil)
          1
          nxt
          ce))
       (None
         (let ((pos (- (- n 1) (- i (env_len env)))))
           (GOk
             (Cons (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")")) Nil)
             1
             nxt
             (FVar (xsym pos)))))))
    ((IntLit k)
     (if (le 0 k)
       (if (lt k 4294967296)
         (GOk
           (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil)
           1
           nxt
           e)
         (GErr "literal outside [0, 2^32)"))
       (GErr "literal outside [0, 2^32)")))
    ((Call q as)
     (match (bop_of q)
       (None (GErr "call outside the fragment (only + - * allowed)"))
       ((Some opd)
        (match as
          ((Cons a (Cons b Nil))
           (match (gen_e n env nxt a)
             ((GErr m) (GErr m))
             ((GOk ia ca nxa cea)
              (match (gen_e n env nxa b)
                ((GErr m) (GErr m))
                ((GOk ib cb nxb ceb)
                 (GOk
                   (dapp
                     ia
                     (dapp
                       ib
                       (Cons (dcat3 (DStr "(I32Bin ") opd (DStr ")")) Nil)))
                   (+ ca (+ cb 1))
                   nxb
                   (Call q (Cons cea (Cons ceb Nil)))))))))
          (_ (GErr "arith call must be binary"))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (GErr m))
          ((GOk ir cr nxr cer)
           (match (gen_e n (Cons (Pair cer nxr) env) (+ nxr 1) body)
             ((GErr m) (GErr m))
             ((GOk ib cb nxb ceb)
              (GOk
                (dapp
                  ir
                  (Cons (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")")) ib))
                (+ cr (+ cb 1))
                nxb
                ceb))))))
       (_ (GErr "let must bind exactly one name (split into nested lets)"))))
    (_ (GErr "body outside the scalar let/straight-line fragment"))))

;; ---- premise nodes (the substituted tree's arith sites) -----------------------


;; unique arith nodes, postorder (children before parents, so each node's
;; spelling is already child-unwrapped at its discharge point)
(type NRes (NOk (List Expr)) (NErr (List Int)))

(fn nodes_e ((e Expr) (acc (List Expr))) NRes
  (measure (struct e))
  (match e
    ((Call _ as)
     (match as
       ((Cons a (Cons b Nil))
        (match (nodes_e a acc)
          ((NErr m) (NErr m))
          ((NOk acc1)
           (match (nodes_e b acc1)
             ((NErr m) (NErr m))
             ((NOk acc2)
              (if (has_fv e)
                (NOk (if (node_seen (spell e) acc2) acc2 (node_add e acc2)))
                (NErr
                  "ground arithmetic subtree (constant-fold it in the source)")))))))
       (_ (NErr "arith call must be binary"))))
    (_ (NOk acc))))

;; ---- tail walk: the branch/region tree -----------------------------------------
;;
;; `if` lives in TAIL position (the fn body's result spine after lets, and
;; arm tails — nested ifs and arm-local lets allowed). The proof mirrors the
;; branch tree: one case-on per if, and each arith node is discharged in the
;; REGION where its code executes — pre-branch let bindings before the
;; case-on, arm-local nodes inside their arm — deduped against ancestor
;; regions (a spelling rewritten pre-branch stays rewritten when the arm's
;; compute resumes from the rewritten term).
;;
;; Conditions are (int_eq c1 c2) / (lt c1 c2) with operands whose CANONICAL
;; form is a param or literal (FVar/IntLit — bare params, let-ALIASES,
;; literals). Wraps never enter a condition, so the case-on spelling matches
;; the compute residue on both sides. Arith inside a condition is refused.
;;
;; PRE caveat (v1): arm range premises quantify over the WHOLE contract —
;; (if (lt 0 x) (- x 1) 0) would demand 0 <= x-1 globally. Arm expressions
;; must be in-range on the full domain; condition-relative premises are
;; future work.


;; region tree: RTv = the tail is a value (region nodes incl. enclosing let
;; bindings'); RTif = pre-branch nodes + canonical condition + arm trees.
;; Both carry the full code, instr count, and next-free-local for the tail.
(type RT
  (RTv (List Doc) Int Int (List Expr))
  (RTif (List Doc) Int Int (List Expr) Expr RT RT))

(type TRes (TOk RT) (TErr (List Int)))

(fn rt_nxt ((r RT)) Int
  (match r
    ((RTv _ _ nxt _) nxt)
    ((RTif _ _ nxt _ _ _ _) nxt)))

(fn rt_count ((r RT)) Int
  (match r
    ((RTv _ c _ _) c)
    ((RTif _ c _ _ _ _ _) c)))

(fn rt_code ((r RT)) (List Doc)
  (match r
    ((RTv code _ _ _) code)
    ((RTif code _ _ _ _ _ _) code)))

;; prepend an enclosing let binding (code + nodes) onto the tail's top region
(fn rt_prepend ((code (List Doc)) (cnt Int) (ns (List Expr)) (r RT)) RT
  (match r
    ((RTv rcode rc rnxt rns)
     (RTv (dapp code rcode) (+ cnt rc) rnxt (dapp_e ns rns)))
    ((RTif rcode rc rnxt rns cond a b)
     (RTif (dapp code rcode) (+ cnt rc) rnxt (dapp_e ns rns) cond a b))))

;; the diamond, result through a fresh LOCAL rl:
;;   Block [ Block [ COND, BrIf 0, ELSE…, LocalSet rl, Br 1 ],
;;           THEN…, LocalSet rl ]
;;   LocalGet rl
;; BrIf pops b2i(COND): nonzero (True) exits the inner block to THEN; zero
;; (False) falls through ELSE and Br 1 exits the outer block. The result
;; local is LOAD-BEARING for the REAL ISA: wasm blocks are typed and these
;; are void — every block boundary must have an EMPTY stack (V8 rejects a
;; value flowing out of a void block; the model's untyped Block would not
;; have caught it — the engine gate did). Locals-not-stack across block
;; edges is the same discipline the hand-written loop pieces follow.
(fn diamond
  ((cond_code (List Doc))
   (then_code (List Doc))
   (else_code (List Doc))
   (rl Int))
  (List Doc)
  (Cons
    (dcat3
      (DStr "(Block (list (Block (list ")
      (djoin
        (dapp
          cond_code
          (dapp
            (Cons (DStr "(BrIf 0)") Nil)
            (dapp
              else_code
              (Cons
                (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")"))
                (Cons (DStr "(Br 1)") Nil))))))
      (dcat3
        (DStr ")) ")
        (djoin
          (dapp
            then_code
            (Cons (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")")) Nil)))
        (DStr "))")))
    (Cons (dcat3 (DStr "(LocalGet ") (dint rl) (DStr ")")) Nil)))

(fn gen_t ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) TRes
  (measure (struct e))
  (match e
    ((If c a b)
     (match c
       ((Call q ops)
        (match (cond_op q)
          (None (TErr "if condition outside the fragment (int_eq/lt only)"))
          ((Some opd)
           (match ops
             ((Cons c1 (Cons c2 Nil))
              (match (gen_e n env nxt c1)
                ((GErr m) (TErr m))
                ((GOk i1 n1 nx1 ce1)
                 (match (gen_e n env nx1 c2)
                   ((GErr m) (TErr m))
                   ((GOk i2 n2 nx2 ce2)
                    (if (cond_operand_ok ce1)
                      (if (cond_operand_ok ce2)
                        (match (gen_t n env (+ nx2 1) a)
                          ((TErr m) (TErr m))
                          ((TOk rta)
                           (match (gen_t n env (rt_nxt rta) b)
                             ((TErr m) (TErr m))
                             ((TOk rtb)
                              (TOk
                                (RTif
                                  (diamond
                                    (dapp
                                      i1
                                      (dapp
                                        i2
                                        (Cons
                                          (dcat3
                                            (DStr "(I32Bin ")
                                            opd
                                            (DStr ")"))
                                          Nil)))
                                    (rt_code rta)
                                    (rt_code rtb)
                                    nx2)
                                  (+
                                    (+ n1 (+ n2 1))
                                    (+ (rt_count rta) (+ (rt_count rtb) 7)))
                                  (rt_nxt rtb)
                                  Nil
                                  (Call q (Cons ce1 (Cons ce2 Nil)))
                                  rta
                                  rtb))))))
                        (TErr
                          "if condition operand must be a param or literal (no arith in conditions)"))
                      (TErr
                        "if condition operand must be a param or literal (no arith in conditions)")))))))
             (_ (TErr "if condition must be a binary comparison"))))))
       (_ (TErr "if condition outside the fragment (int_eq/lt only)"))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (TErr m))
          ((GOk ir cr nxr cer)
           (match (nodes_e cer Nil)
             ((NErr m) (TErr m))
             ((NOk rns)
              (match (gen_t n (Cons (Pair cer nxr) env) (+ nxr 1) body)
                ((TErr m) (TErr m))
                ((TOk rt)
                 (TOk
                   (rt_prepend
                     (dapp
                       ir
                       (Cons
                         (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")"))
                         Nil))
                     (+ cr 1)
                     rns
                     rt)))))))))
       (_ (TErr "let must bind exactly one name (split into nested lets)"))))
    (_
      (match (gen_e n env nxt e)
        ((GErr m) (TErr m))
        ((GOk code cnt nx ce)
         (match (nodes_e ce Nil)
           ((NErr m) (TErr m))
           ((NOk ns) (TOk (RTv code cnt nx ns)))))))))

;; ---- proof emission over the region tree ---------------------------------------


(fn rt_pres ((r RT) (acc (List Expr))) (List Expr)
  (measure (struct r))
  (match r
    ((RTv _ _ _ ns) (add_unique ns acc))
    ((RTif _ _ _ ns _ a b) (rt_pres b (rt_pres a (add_unique ns acc))))))


;; the region's discharge items: nodes not already discharged in an ancestor
;; region (nor earlier in this one). Returns (items doc, next have counter,
;; ancestors incl. this region's nodes).
(fn pr_items ((ns (List Expr)) (anc (List Expr)) (pres (List Expr)) (j Int))
  (Pair (Pair Doc Int) (List Expr))
  (measure (struct ns))
  (match ns
    (Nil (Pair (Pair (DStr "") j) anc))
    ((Cons e t)
     (if (node_seen (spell e) anc) (pr_items t anc pres j)
     (match (pr_items t (node_add e anc) pres (+ j 1))
       ((Pair (Pair d j2) anc2)
        (Pair (Pair (DCat (pr_event e pres j) d) j2) anc2)))))))

;; region body = discharge items + closer (refl, or the case-on tree).
;; Each arm re-enters via the fixed template: rewrite the ctor-named case
;; hyp into BOTH sides, compute both to resume past the fired branch.
(fn pr_region ((r RT) (anc (List Expr)) (pres (List Expr)) (j Int))
  (Pair Doc Int)
  (measure (struct r))
  (match r
    ((RTv _ _ _ ns)
     (match (pr_items ns anc pres j)
       ((Pair (Pair items j2) _) (Pair (DCat items (DStr "refl")) j2))))
    ((RTif _ _ _ ns cond a b)
     (match (pr_items ns anc pres j)
       ((Pair (Pair items j2) anc2)
        (match (pr_region a anc2 pres j2)
          ((Pair da j3)
           (match (pr_region b anc2 pres j3)
             ((Pair db j4)
              (Pair
                (dcat3
                  (dcat3
                    (dcat3 items (DStr "(case-on ") (pr_e cond))
                    (DStr
                      " Bool ((case True (chain (steps ((rewrite (hyp True) lr both true ()) (compute both))) ")
                    da)
                  (dcat3
                    (DStr
                      ")) (case False (chain (steps ((rewrite (hyp False) lr both true ()) (compute both))) ")
                    db
                    (DStr "))))"))
                  (DStr ""))
                j4))))))))))

;; ---- the mem fragment: bodies that CALL std/mem's shipped artifacts -----------
;;
;; Source fns (m Mem) (x Int) … whose bodies read/write bytes lower to
;; wasm Calls against std/mem's artifact module (call-per-byte v1; the
;; probes' composed-by-citation discipline, mechanized):
;;   - Int return: arith over params/literals + (mem_get m ADDR) reads;
;;     memory returned untouched — RHS (Some (Pair (SPEC m0 args) m0)).
;;   - Mem return: a SINGLE TRAILING (mem_set m ADDR VAL) (lets allowed
;;     above it). All reads happen pre-write, so no aliasing premises are
;;     needed; write-then-read stays a hand piece until condition-relative
;;     premises exist. RHS (Some (Pair VAL (SPEC m0 args))).
;; The emitted module is (Cons mget (Cons mset (Cons SELF restfs))) at
;; index 2 — std/mem's minimal-prefix convention; the callee literals are
;; SPLICED by the generator (the (inline …) same-file rule's link-time
;; answer), and the proofs cite lowered_mem_get/lowered_mem_set through
;; call_bridge, never computing into the callee bodies.
;;
;; THE STAGE LAW (the machine-order discharge discipline): arith nodes are
;; collected during the CODE walk — a let-bound value collects once (later
;; reads are LocalGets of the already-collapsed local), a recomputed
;; spelling collects AGAIN (its wrap re-materializes after the earlier
;; all-occurrences fire and needs a fresh event). At each call site the
;; proof emits (compute lhs (stop eval_call)), flushes the pending wrap
;; events (every so-far-materialized occurrence — stack, locals, and the
;; folded call's arguments — is on the lhs and collapses), then rewrites
;; by call_bridge with CLEAN spellings. PREs are per unique (kind,
;; spelling): wrap bounds for arith nodes, address bounds for read/write
;; addresses (the callee certs' own premise shapes).

;; the spliced std/mem artifact literals (std/mem/mem.wasm.shard's fns —
;; drift fails loudly at the kernel gate when the citations stop matching)
(fn mget_lit () Doc (DStr "(MkFunc 1 0 (list (LocalGet 0) (I32Load8U)))"))

(fn mset_lit () Doc
  (DStr
    "(MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Store8) (LocalGet 1)))"))

(fn memq_named ((q QName) (s Symbol)) Bool
  (match q
    ((QName mp nm)
     (if (sym_eq nm s)
       (sym_list_eq mp (Cons (quote std) (Cons (quote mem) Nil)))
       False))))


;; ---- the mem walk: code + symbolic machine state + staged proof ----------------
;;
;; state: code docs, instr count, next free local, symbolic stack (clean
;; spellings, top first), proof doc so far, have counter, tagged PREs,
;; pending wrap events, get/set counts.
(type MSt
  (MkMSt
    (List Doc)
    Int
    Int
    (List Expr)
    Doc
    Int
    (List PItem)
    (List Expr)
    Int
    Int))

(type MRes (MOk MSt Expr) (MErr (List Int)))

;; is this arg the fn's Mem param (textual position 0, not let-bound)?
(fn is_mem_param ((e Expr) (env (List (Pair Expr Int))) (n Int)) Bool
  (match e
    ((BVar i)
     (match (env_at env i)
       (None (int_eq (- (- n 1) (- i (env_len env))) 0))
       ((Some _) False)))
    (_ False)))

(fn mg_e ((n Int) (nn Int) (env (List (Pair Expr Int))) (st MSt) (e Expr)) MRes
  (measure (struct e))
  (match st
    ((MkMSt code cnt nxt stk prf j pres pend gets sets)
     (match e
       ((BVar i)
        (match (env_at env i)
          ((Some (Pair ce k))
           (MOk
             (MkMSt
               (dapp
                 code
                 (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil))
               (+ cnt 1)
               nxt
               (Cons ce stk)
               prf
               j
               pres
               pend
               gets
               sets)
             ce))
          (None
            (let ((pos (- (- n 1) (- i (env_len env)))))
              (if (int_eq pos 0)
                (MErr
                  "the Mem param may appear only as the memory argument of mem_get/mem_set")
                (let ((ce (FVar (xsym (- pos 1)))))
                  (MOk
                    (MkMSt
                      (dapp
                        code
                        (Cons
                          (dcat3
                            (DStr "(LocalGet ")
                            (dint (- pos 1))
                            (DStr ")"))
                          Nil))
                      (+ cnt 1)
                      nxt
                      (Cons ce stk)
                      prf
                      j
                      pres
                      pend
                      gets
                      sets)
                    ce)))))))
       ((IntLit k)
        (if (le 0 k)
          (if (lt k 4294967296)
            (MOk
              (MkMSt
                (dapp
                  code
                  (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil))
                (+ cnt 1)
                nxt
                (Cons e stk)
                prf
                j
                pres
                pend
                gets
                sets)
              e)
            (MErr "literal outside [0, 2^32)"))
          (MErr "literal outside [0, 2^32)")))
       ((Call q as)
        (match (bop_of q)
          ((Some opd)
           (match as
             ((Cons a (Cons b Nil))
              (match (mg_e n nn env st a)
                ((MErr m) (MErr m))
                ((MOk st1 cea)
                 (match (mg_e n nn env st1 b)
                   ((MErr m) (MErr m))
                   ((MOk st2 ceb)
                    (let ((node (Call q (Cons cea (Cons ceb Nil)))))
                      (if (has_fv node)
                        (match st2
                          ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2)
                           (match s2
                             ((Cons _ (Cons _ below))
                              (MOk
                                (MkMSt
                                  (dapp
                                    c2
                                    (Cons
                                      (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                      Nil))
                                  (+ n2 1)
                                  x2
                                  (Cons node below)
                                  p2
                                  j2
                                  (if (wrap_seen (spell node) pr2) pr2
                                  (pit_add pr2 (PWrap node)))
                                  (dapp_e pd2 (Cons node Nil))
                                  g2
                                  w2)
                                node))
                             (_ (MErr "internal: stack underflow at arith")))))
                        (MErr
                          "ground arithmetic subtree (constant-fold it in the source)"))))))))
             (_ (MErr "arith call must be binary"))))
          (None
            (if (memq_named q (quote mem_get))
              (match as
                ((Cons marg (Cons addr Nil))
                 (if (is_mem_param marg env n)
                   (match (mg_e n nn env st addr)
                     ((MErr m) (MErr m))
                     ((MOk st1 cea)
                      (match st1
                        ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1)
                         (match s1
                           ((Cons _ below)
                            (let
                              ((pr1b (pit_add pr1 (PGet cea (- nn (+ n1 3))))))
                              (match (m_flush pd1 pr1b j1)
                                ((Pair evd j2)
                                 (let
                                   ((rnode
                                      (Call
                                        q
                                        (Cons (FVar (quote m0)) (Cons cea Nil)))))
                                   (MOk
                                     (MkMSt
                                       (dapp c1 (Cons (DStr "(Call 0)") Nil))
                                       (+ n1 1)
                                       x1
                                       (Cons rnode below)
                                       (dcat3
                                         p1
                                         (DCat (m_stage_open) evd)
                                         (m_bridge_get
                                           cea
                                           below
                                           rnode
                                           (+ 3 (poff pr1))))
                                       j2
                                       pr1b
                                       Nil
                                       (+ g1 1)
                                       w1)
                                     rnode))))))
                           (_ (MErr "internal: stack underflow at mem_get")))))))
                   (MErr "mem_get's memory argument must be the fn's Mem param")))
                (_ (MErr "mem_get must have exactly (m ADDR)")))
            (if (memq_named q (quote mem_set))
              (MErr
                "mem_set only as the trailing body of a Mem-returning fn (single write, v1)")
              (MErr "call outside the mem fragment (+ - * mem_get only)"))))))
       ((Let bs body)
        (match bs
          ((Cons rhs Nil)
           (match (mg_e n nn env st rhs)
             ((MErr m) (MErr m))
             ((MOk st1 cer)
              (match st1
                ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1)
                 (match s1
                   ((Cons _ below)
                    (mg_e
                      n
                      nn
                      (Cons (Pair cer x1) env)
                      (MkMSt
                        (dapp
                          c1
                          (Cons
                            (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                            Nil))
                        (+ n1 1)
                        (+ x1 1)
                        below
                        p1
                        j1
                        pr1
                        pd1
                        g1
                        w1)
                      body))
                   (_ (MErr "internal: stack underflow at let"))))))))
          (_ (MErr "let must bind exactly one name (split into nested lets)"))))
       (_
         (MErr
           "body outside the mem fragment (straight-line + lets; no if yet)"))))))

;; the Mem-returning tail: lets above a single trailing mem_set
(fn mg_tail ((n Int) (nn Int) (env (List (Pair Expr Int))) (st MSt) (e Expr))
  MRes
  (measure (struct e))
  (match e
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (mg_e n nn env st rhs)
          ((MErr m) (MErr m))
          ((MOk st1 cer)
           (match st1
             ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1)
              (match s1
                ((Cons _ below)
                 (mg_tail
                   n
                   nn
                   (Cons (Pair cer x1) env)
                   (MkMSt
                     (dapp
                       c1
                       (Cons
                         (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                         Nil))
                     (+ n1 1)
                     (+ x1 1)
                     below
                     p1
                     j1
                     pr1
                     pd1
                     g1
                     w1)
                   body))
                (_ (MErr "internal: stack underflow at let"))))))))
       (_ (MErr "let must bind exactly one name (split into nested lets)"))))
    ((Call q as)
     (if (memq_named q (quote mem_set))
       (match as
         ((Cons marg (Cons addr (Cons val Nil)))
          (if (is_mem_param marg env n)
            (match (mg_e n nn env st addr)
              ((MErr m) (MErr m))
              ((MOk st1 cea)
               (match (mg_e n nn env st1 val)
                 ((MErr m) (MErr m))
                 ((MOk st2 cev)
                  (match st2
                    ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2)
                     (match s2
                       ((Cons _ (Cons _ below))
                        (let
                          ((pr2b (pit_add pr2 (PSet cea cev (- nn (+ n2 3))))))
                          (match (m_flush pd2 pr2b j2)
                            ((Pair evd j3)
                             (MOk
                               (MkMSt
                                 (dapp c2 (Cons (DStr "(Call 1)") Nil))
                                 (+ n2 1)
                                 x2
                                 (Cons cev below)
                                 (dcat3
                                   p2
                                   (DCat (m_stage_open) evd)
                                   (m_bridge_set cea cev below (+ 3 (poff pr2))))
                                 j3
                                 pr2b
                                 Nil
                                 g2
                                 (+ w2 1))
                               cev)))))
                       (_ (MErr "internal: stack underflow at mem_set")))))))))
            (MErr "mem_set's memory argument must be the fn's Mem param")))
         (_ (MErr "mem_set must have exactly (m ADDR VAL)")))
       (MErr
         "Mem-returning body must be a trailing (mem_set m ADDR VAL) (single write, v1)")))
    (_
      (MErr
        "Mem-returning body must be a trailing (mem_set m ADDR VAL) (single write, v1)"))))


;; ---- the LOOP fragment: Nat-counted tail recursion (docs/LOWERING.md §6f/§6h) ---
;;
;; Source shape:  (fn NAME ((m Mem) (a1 Int) … (an Int) (k Nat)) Mem
;;                  (match k (Z m) ((S k2) (NAME WORK U1 … Un k2))))
;; with updates Ui = ai | (+ ai 1) and WORK = (mem_set m A V), A an
;; ADVANCING accum, V = an accum | a u32 literal | (mem_get m A2) with A2
;; advancing. Lowers COUNTER-AS-LOCAL: k rides as an i32 local (ENC =
;; int_of_nat), guard LocalGet/I32Eqz/BrIf 1, decrement by BSub — direct
;; byte ops, a LEAF cert (calls-in-loops cannot ride the portable form;
;; §6f). The worker is a machine-written INDUCTION on k citing
;; models/wasm/loopkit.shard's template constants; the theorem adds 4
;; plumbing levels. Fuel: worker = S^(instrs+4) over (lg_fuel k c) —
;; eval_loop re-enters at exactly fuel-1, so the IH spelling aligns at
;; any sufficient body budget. int_of_nat is module-opaque under proof
;; compute, so both cases OPEN it by its defining lemmas (int_of_nat_zero
;; / int_of_nat_succ) before computing — the §6f opacity law. Premise
;; layout: one nonneg + one range pair PER ADVANCING ACCUM (nonnegs
;; first, param order).

(fn qn_eq ((a QName) (b QName)) Bool
  (match a
    ((QName am an)
     (match b
       ((QName bm bn) (if (sym_eq an bn) (sym_list_eq am bm) False))))))

;; the store value: an accum read, a u32 literal, or a byte read at an
;; advancing accum
(type LVal (LVAcc Int) (LVLit Int) (LVRead Int))

(type LRec (LROk (List Bool) Int LVal) (LRErr (List Int)))

;; accum index of an S-arm BVar: accum i (of n) sits at BVar (n+1-i)
(fn lp_acc ((e Expr) (n Int)) (Option Int)
  (match e
    ((BVar b)
     (let ((i (- (+ n 1) b))) (if (le 0 i) (if (lt i n) (Some i) None) None)))
    (_ None)))

(fn lp_is_mem_arg ((e Expr) (n Int)) Bool
  (match e
    ((BVar b) (int_eq b (+ n 2)))
    (_ False)))

(fn bool_at ((bs (List Bool)) (i Int)) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t) (if (int_eq i 0) h (bool_at t (- i 1))))))

;; one accumulator update: itself (Some False) or (+ itself 1) (Some True)
(fn lp_upd ((u Expr) (n Int) (i Int)) (Option Bool)
  (match u
    ((BVar b) (if (int_eq b (- (+ n 1) i)) (Some False) None))
    ((Call q as)
     (if (core_named q (quote +))
       (match as
         ((Cons a (Cons b Nil))
          (match a
            ((BVar ab)
             (if (int_eq ab (- (+ n 1) i))
               (match b
                 ((IntLit one) (if (int_eq one 1) (Some True) None))
                 (_ None))
               None))
            (_ None)))
         (_ None))
       None))
    (_ None)))

;; the self-call's tail: n updates then the peeled counter (BVar 0)
(fn lp_updk ((us (List Expr)) (n Int) (i Int)) (Option (List Bool))
  (measure (struct us))
  (match us
    (Nil None)
    ((Cons u t)
     (match t
       (Nil
         (match u
           ((BVar b) (if (int_eq b 0) (if (int_eq i n) (Some Nil) None) None))
           (_ None)))
       ((Cons _ _)
        (match (lp_upd u n i)
          (None None)
          ((Some f)
           (match (lp_updk t n (+ i 1))
             (None None)
             ((Some fs) (Some (Cons f fs)))))))))))

(fn lp_val ((e Expr) (n Int) (adv (List Bool))) (Option LVal)
  (match e
    ((BVar _)
     (match (lp_acc e n)
       ((Some i) (Some (LVAcc i)))
       (None None)))
    ((IntLit l) (if (le 0 l) (if (lt l 4294967296) (Some (LVLit l)) None) None))
    ((Call q as)
     (if (memq_named q (quote mem_get))
       (match as
         ((Cons marg (Cons aarg Nil))
          (if (lp_is_mem_arg marg n)
            (match (lp_acc aarg n)
              ((Some i) (if (bool_at adv i) (Some (LVRead i)) None))
              (None None))
            None))
         (_ None))
       None))
    (_ None)))

(fn lp_workc ((w Expr) (n Int) (adv (List Bool))) LRec
  (match w
    ((Call q as)
     (if (memq_named q (quote mem_set))
       (match as
         ((Cons marg (Cons aarg (Cons varg Nil)))
          (if (lp_is_mem_arg marg n)
            (match (lp_acc aarg n)
              ((Some ai)
               (if (bool_at adv ai)
                 (match (lp_val varg n adv)
                   ((Some v) (LROk adv ai v))
                   (None
                     (LRErr
                       "store value must be an accum, a u32 literal, or (mem_get m ADV-ACCUM)")))
                 (LRErr "store address must be an ADVANCING accumulator")))
              (None (LRErr "store address must be an accumulator")))
            (LRErr "mem_set's memory argument must be the fn's Mem param")))
         (_ (LRErr "mem_set must have exactly (m ADDR VAL)")))
       (LRErr "loop work must be a single (mem_set m ADDR VAL)")))
    (_ (LRErr "loop work must be a single (mem_set m ADDR VAL)"))))

(fn is_pvar ((p Pat)) Bool
  (match p
    (PVar True)
    (_ False)))

(fn lp_zarm ((pz Pat) (zb Expr) (n Int)) Bool
  (match pz
    ((PCtor qz zps)
     (match zps
       (Nil
         (if (core_named qz (quote Z))
           (match zb
             ((BVar mb) (int_eq mb (+ n 1)))
             (_ False))
           False))
       ((Cons _ _) False)))
    (_ False)))

(fn lp_spat ((ps Pat)) Bool
  (match ps
    ((PCtor qs sps)
     (if (core_named qs (quote S))
       (match sps
         ((Cons pv Nil) (is_pvar pv))
         (_ False))
       False))
    (_ False)))

(fn lp_sarm ((sb Expr) (q QName) (n Int)) LRec
  (match sb
    ((Call q2 args)
     (if (qn_eq q2 q)
       (match args
         ((Cons w rest)
          (match (lp_updk rest n 0)
            (None
              (LRErr
                "self-call updates must be ACCUM or (+ ACCUM 1), ending in the peeled counter"))
            ((Some adv) (lp_workc w n adv))))
         (Nil (LRErr "self-call must carry WORK, the updates, and the counter")))
       (LRErr "S arm must be a tail self-call")))
    (_ (LRErr "S arm must be a tail self-call"))))

(fn lp_recognize ((q QName) (n Int) (body Expr)) LRec
  (match body
    ((Match scr arms)
     (match scr
       ((BVar b)
        (if (int_eq b 0)
          (match arms
            ((Cons (Arm pz zb) (Cons (Arm ps sb) Nil))
             (if (lp_zarm pz zb n)
               (if (lp_spat ps) (lp_sarm sb q n)
               (LRErr "second match arm must be ((S k2) ...)"))
               (LRErr "first match arm must be (Z m)")))
            (_ (LRErr "loop match must have exactly the Z and S arms")))
          (LRErr "loop match must scrutinize the Nat counter (the last param)")))
       (_ (LRErr "loop match must scrutinize the Nat counter (the last param)"))))
    (_ (LRErr "loop body must be a match on the Nat counter"))))

;; ---- loop codegen ----------------------------------------------------------------

(fn lp_lget ((k Int)) Doc
  (dconc (list (DStr "(LocalGet ") (dint k) (DStr ")"))))

(fn lp_const ((k Int)) Doc
  (dconc (list (DStr "(I32Const ") (dint k) (DStr ")"))))

(fn lp_lset ((k Int)) Doc
  (dconc (list (DStr "(LocalSet ") (dint k) (DStr ")"))))

(fn lp_valcode ((v LVal)) (List Doc)
  (match v
    ((LVAcc i) (Cons (lp_lget i) Nil))
    ((LVLit l) (Cons (lp_const l) Nil))
    ((LVRead i) (Cons (lp_lget i) (Cons (DStr "(I32Load8U)") Nil)))))

(fn lp_vlen ((v LVal)) Int
  (match v
    ((LVAcc _) 1)
    ((LVLit _) 1)
    ((LVRead _) 2)))

(fn lp_advcode ((adv (List Bool)) (i Int)) (List Doc)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t)
     (if h
       (dapp
         (list (lp_lget i) (lp_const 1) (DStr "(I32Bin BAdd)") (lp_lset i))
         (lp_advcode t (+ i 1)))
       (lp_advcode t (+ i 1))))))

;; guard / work / advances / decrement / re-enter (instrs = 10 + vlen + 4*nAdv)
(fn lp_code ((n Int) (adv (List Bool)) (ai Int) (v LVal)) (List Doc)
  (dapp
    (list (lp_lget n) (DStr "(I32Eqz)") (DStr "(BrIf 1)") (lp_lget ai))
    (dapp
      (lp_valcode v)
      (dapp
        (Cons (DStr "(I32Store8)") Nil)
        (dapp
          (lp_advcode adv 0)
          (list
            (lp_lget n)
            (lp_const 1)
            (DStr "(I32Bin BSub)")
            (lp_lset n)
            (DStr "(Br 0)")))))))

;; ---- loop claim assembly ----------------------------------------------------------

(fn lp_nadv ((bs (List Bool))) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (+ (if h 1 0) (lp_nadv t)))))

;; number of advancing accums among the first i (= accum i's nonneg premise ix)
(fn lp_advpos ((bs (List Bool)) (i Int)) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (if (int_eq i 0) 0 (+ (if h 1 0) (lp_advpos t (- i 1)))))))

(fn lp_first_adv ((bs (List Bool)) (i Int)) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (if h i (lp_first_adv t (+ i 1))))))

(fn lp_prems_lo ((bs (List Bool)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if h (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True) ")))
       (DStr ""))
       (lp_prems_lo t (+ i 1))))))

(fn lp_prems_rng ((bs (List Bool)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if h
         (dconc
           (list
             (DStr "(= (le (+ x")
             (dint i)
             (DStr " (int_of_nat k)) 65536) True) ")))
         (DStr ""))
       (lp_prems_rng t (+ i 1))))))

;; exit locals: advancing -> (lg_adv xi k), static -> xi, counter -> 0
(fn lp_exits ((bs (List Bool)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr "0"))
    ((Cons h t)
     (DCat
       (if h (dconc (list (DStr "(lg_adv x") (dint i) (DStr " k) ")))
       (dconc (list (DStr "x") (dint i) (DStr " "))))
       (lp_exits t (+ i 1))))))

;; address-guard occurrences, code order: the load's (if any), then the store's
(fn lp_occs ((ai Int) (v LVal)) (List Int)
  (match v
    ((LVRead i2) (Cons i2 (Cons ai Nil)))
    (_ (Cons ai Nil))))

;; one address-guard stage: premise-rewrite the nonneg guard, cite lg_a1_ms
;; for the upper guard, compute on
(fn lp_stage ((p Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint r)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

(fn lp_stages ((occs (List Int)) (adv (List Bool)) (na Int)) Doc
  (measure (struct occs))
  (match occs
    (Nil (DStr ""))
    ((Cons i t)
     (DCat
       (lp_stage (lp_advpos adv i) (+ na (lp_advpos adv i)))
       (lp_stages t adv na)))))

;; the counter wrap: (1+n)-1 collapse, then wrap32_id via lg_kM off the
;; FIRST advancing accum's range premise
(fn lp_hwk ((f Int) (na Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma lg_kM) lr lhs ((inst a x")
      (dint f)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint na)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise 0) lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; one advancing accum's pointer-advance wrap have + all-occurrences rewrite
(fn lp_hw ((p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " 1) 4294967296) (+ x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl)) refl) (rewrite-with (lemma lg_32) lr lhs () ((rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

(fn lp_hws ((bs (List Bool)) (i Int) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if h (DCat (lp_hw p i na) (lp_hws t (+ i 1) (+ p 1) na))
     (lp_hws t (+ i 1) p na)))))

;; the IH's premise discharges: lg_lo1 per advancing accum, then lg_shift
(fn lp_lo1s ((bs (List Bool)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if h
       (DCat
         (dconc
           (list
             (DStr
               "(rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl)) refl) ")))
         (lp_lo1s t (+ p 1)))
       (lp_lo1s t p)))))

(fn lp_shifts ((bs (List Bool)) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if h
       (DCat
         (dconc
           (list
             (DStr
               "(rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise ")
             (dint (+ na p))
             (DStr
               ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
         (lp_shifts t (+ p 1) na))
       (lp_shifts t p na)))))

;; pass-through premise steps (theorem -> worker), one per advancing accum
(fn lp_pass1 ((bs (List Bool)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if h
       (DCat
         (dconc
           (list
             (DStr "(steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl) ")))
         (lp_pass1 t (+ p 1)))
       (lp_pass1 t p)))))

;; the SELF literal as spelled in claims ((inline …) rides the emitted body fn)
(fn lp_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (I32Const 0)))"))))

(fn lp_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List Bool))
   (ai Int)
   (v LVal)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr
          "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (eval_loop (S^ ")
        (dint p)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) (inline ")
        nm
        (DStr "_body) (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
        (lp_exits adv 0)
        (DStr ") (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
        (lp_stages (lp_occs ai v) adv na)
        (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)))) ")
        (lp_hwk (lp_first_adv adv 0) na)
        (lp_hws adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr
          " rhs) (unfold lg_adv rhs) (reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
        (lp_lo1s adv 0)
        (lp_shifts adv 0 na)
        (DStr ")) (steps ((compute both))) refl)))))")
        (DStr (nl))))))

(fn lp_thm ((nm Doc) (mids (List Type)) (n Int) (adv (List Bool)) (p4 Int)) Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p4)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + worker + theorem, one unit per source fn
(fn lp_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List Bool))
   (ai Int)
   (v LVal)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lp_code n adv ai v))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (I32Const 0))))")
      (DStr (nl))
      (lp_worker nm mids n adv ai v p)
      (lp_thm nm mids n adv (+ p 4)))))

(fn emit_claim_loop ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (if (is_mem_ty rty)
       (match ts
         ((Cons _ rest)
          (match (ts_lasto rest)
            ((Some lt)
             (if (is_nat_ty lt)
               (let ((mids (ts_mids rest)))
                 (if (all_int mids)
                   (let ((n (count_ts mids)))
                     (if (lt 0 n)
                       (match (lp_recognize q n body)
                         ((LRErr m) (cerr_at q m))
                         ((LROk adv ai v)
                          (let
                            ((cnt (+ 10 (+ (lp_vlen v) (* 4 (lp_nadv adv))))))
                            (COk
                              (lp_unit
                                (dsym (qn_name q))
                                mids
                                n
                                adv
                                ai
                                v
                                (+ cnt 4))
                              (DStr "")))))
                       (cerr_at q "loop fn needs at least one Int accumulator")))
                   (cerr_at q "loop accumulators must all be Int")))
               (cerr_at q "loop fn's last param must be the Nat counter")))
            (None (cerr_at q "loop fn needs (m Mem) (accums Int...) (k Nat)"))))
         (Nil (cerr_at q "loop fn needs params")))
       (cerr_at q "loop fn must return Mem")))))

;; ---- claim emission ----------------------------------------------------------


(type CRes (COk Doc Doc) (CErr (List Int)))

(fn cerr_at ((q QName) (m (List Int))) CRes
  (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))


;; the PORTABLE claim (the primary cert): module abstract, callee slots
;; abstract binders, premises = spine + arities + the item list. The
;; callee bytes appear NOWHERE — a callee edit leaves this file byte-
;; identical; only the linked derivation regenerates.
(fn m_claim_port
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc)
   (prf Doc)
   (evd Doc))
  Doc
  (dcat3
    (dcat3
      (dcat3
        (DStr "(claim lowered_")
        (dsym (qn_name q))
        (dcat3
          (DStr " (goal (")
          (pr_binds ints 0)
          (DStr
            "(m0 Mem) (m WModule) (f0 Func) (f1 Func) (restm (List Func)) (c Nat)) ((= (funcs_of m) (Cons f0 (Cons f1 (Cons ")))
      (DCat self (DStr " restm)))) (= (params_of f0) 1) (= (params_of f1) 2) "))
      (pits_prems pres))
    (dcat3
      (dcat3 (DStr ") (= (call_fn_mem (S^ ") (dint nn) (DStr " c) m 2 (list "))
      (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
      (dcat3
        (dcat3
          (DStr
            ")) (chain (steps ((compute lhs (stop eval_call funcs_of)) (rewrite (premise 0) lr lhs true ()) (unfold ")
          (dsym (qn_name q))
          (DStr " rhs) (reduce rhs))) "))
        prf
        (DStr "(steps ((compute lhs))) ")))
    (dcat3 evd (DStr "refl))") (DStr (nl)))))

;; ---- the LINKED derivation (the artifact form, derived by citation) ------------


;; the LINKED claim: the structural artifact statement, proven by ONE
;; citation of the portable cert (zero interpreter steps)
(fn m_claim_link
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc))
  Doc
  (let ((as (addrs_of pres Nil)))
    (dcat3
      (dcat3
        (dcat3
          (DStr "(claim linked_")
          (dsym (qn_name q))
          (dcat3
            (DStr " (goal (")
            (pr_binds ints 0)
            (DStr "(m0 Mem) (c Nat) (restfs (List Func))) (")))
        (DCat (link_addr_prems as) (link_wrap_prems pres))
        (dcat3
          (dcat3
            (DStr ") (= (call_fn_mem (S^ ")
            (dint nn)
            (DStr " c) (MkWModule (Cons "))
          (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
          (dcat3
            (DCat (DStr " (Cons ") self)
            (DStr " restfs))) 65536) 2 (list ")
            (DStr ""))))
      (dcat3
        (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
        (dcat3
          (dcat3
            (DStr ")) (chain (rewrite-with (lemma lowered_")
            (dsym (qn_name q))
            (DStr ") lr lhs ((inst m (MkWModule (Cons "))
          (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
          (dcat3
            (DCat (DStr " (Cons ") self)
            (DStr " restfs))) 65536)) (inst f0 ")
            (DStr "")))
        (dcat3
          (dcat3 (mget_lit) (DStr ") (inst f1 ") (mset_lit))
          (DStr
            ") (inst restm restfs)) ((steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) ")
          (link_subs
            pres
            as
            (* 2 (addr_count as))
            0
            "lowered_mem_get"
            "lowered_mem_set")))
      (dcat3 (DStr ")) refl))") (DStr (nl)) (DStr "")))))

;; dispatch by return type, shared by both passes
(fn mg_walk ((n Int) (nn Int) (rty Type) (body Expr)) MRes
  (let ((st0 (MkMSt Nil 0 (- n 1) Nil (DStr "") 0 Nil Nil 0 0)))
    (if (is_int_ty rty) (mg_e n nn Nil st0 body)
    (if (is_mem_ty rty) (mg_tail n nn Nil st0 body)
    (MErr "return type must be Int or Mem")))))

;; TWO-PASS: behavior premises embed site fuels, which depend on the
;; total tower — pass 1 counts, pass 2 emits. Budget: each call site is
;; charged 2x its callee's tower + 1 (callee growth within 2x relinks
;; without touching this cert).
(fn emit_claim_mem ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (match ts
       (Nil (cerr_at q "no params"))
       ((Cons _ ints)
        (if (all_int ints)
          (let ((n (count_ts ts)))
            (match (mg_walk n 0 rty body)
              ((MErr m) (cerr_at q m))
              ((MOk st1 ce1)
               (match st1
                 ((MkMSt cd1 cnt1 nx1 sk1 pf1 j1 pr1 pd1 gets1 sets1)
                  (if (int_eq (+ gets1 sets1) 0)
                    (cerr_at
                      q
                      "no memory operations (use the scalar fragment: drop the Mem param)")
                    (let
                      ((nn (+ (* 2 cnt1) (+ 3 (+ (* 13 gets1) (* 21 sets1))))))
                      (match (mg_walk n nn rty body)
                        ((MErr m) (cerr_at q m))
                        ((MOk st ce)
                         (match st
                           ((MkMSt code cnt nxt stk prf j pres pend gets sets)
                            (match (m_flush pend pres j)
                              ((Pair evd _)
                               (let ((self (m_self_lit n nxt code)))
                                 (let ((rhs (m_rhs q ints rty ce)))
                                   (COk
                                     (m_claim_port q ints nn self pres rhs prf
                                       evd)
                                     (m_claim_link q ints nn self pres rhs)))))))))))))))))
          (cerr_at q "params after the Mem param must all be Int")))))))

(fn fn_is_loop ((f FnDef)) Bool
  (match f
    ((FnDef _ ts _ body)
     (match ts
       ((Cons t0 _)
        (if (is_mem_ty t0)
          (match body
            ((Match _ _) True)
            (_ False))
          False))
       (Nil False)))))

(fn emit_claim ((f FnDef)) CRes
  (match f
    ((FnDef _ ts _ _)
     (match ts
       ((Cons t0 _)
        (if (is_mem_ty t0)
          (if (fn_is_loop f) (emit_claim_loop f) (emit_claim_mem f))
          (emit_claim_pure f)))
       (Nil (emit_claim_pure f))))))

(fn emit_claim_pure ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (if (all_int ts)
       (if (is_int_ty rty)
         (match (gen_t (count_ts ts) Nil (count_ts ts) body)
           ((TErr m)
            (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
           ((TOk rt)
            (let ((nodes (rt_pres rt Nil)))
              (match (pr_region rt Nil nodes 0)
                ((Pair proof_body _)
                 (COk
                   (dcat3
                     (dcat3
                       (dcat3
                         (DStr "(claim lowered_")
                         (dsym (qn_name q))
                         (dcat3
                           (DStr " (goal (")
                           (pr_binds ts 0)
                           (DStr "(c Nat) (restfs (List Func))) (")))
                       (pr_prems nodes)
                       (dcat3
                         (dcat3
                           (DStr ") (= (call_fn (S^ ")
                           (dint (+ (* 2 (rt_count rt)) 3))
                           (DStr " c) (MkWModule (Cons (MkFunc "))
                         (dint (count_ts ts))
                         (dcat3
                           (dcat3
                             (DCat (sp) (dint (- (rt_nxt rt) (count_ts ts))))
                             (DStr " (list ")
                             (djoin (rt_code rt)))
                           (DStr ")) restfs) 0) 0 (list ")
                           (DStr ""))))
                     (dcat3
                       (pr_args ts 0)
                       (dcat3 (DStr ")) (Some (") (dsym (qn_name q)) (DStr ""))
                       (dcat3
                         (pr_args_lead ts)
                         (DStr "))))")
                         (dcat3
                           (dcat3
                             (DStr " (chain (steps ((compute lhs) (unfold ")
                             (dsym (qn_name q))
                             (DStr " rhs) (reduce rhs))) "))
                           proof_body
                           (DStr "))"))))
                     (DStr (nl)))
                   (DStr "")))))))
         (CErr
           (append_int (chars_of_sym (qn_name q)) ": return type is not Int")))
       (CErr (append_int (chars_of_sym (qn_name q)) ": params are not all Int"))))))


;; ---- module walk -------------------------------------------------------------

(type ERes (EOk Doc Doc Bool Bool) (EErr (List Int)))

(fn fn_is_mem ((f FnDef)) Bool
  (match f
    ((FnDef _ ts _ _)
     (match ts
       ((Cons t0 _) (is_mem_ty t0))
       (Nil False)))))

(fn emit_fns
  ((fns (List FnDef))
   (modpath (List Symbol))
   (accp Doc)
   (accl Doc)
   (memf Bool)
   (loopf Bool))
  ERes
  (measure (struct fns))
  (match fns
    (Nil (EOk accp accl memf loopf))
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (match q
          ((QName mp _)
           (if (sym_list_eq mp modpath)
             (match (emit_claim f)
               ((CErr m) (EErr m))
               ((COk dp dl)
                (let ((isl (fn_is_loop f)))
                  (let ((ism (if isl False (fn_is_mem f))))
                    (emit_fns
                      rest
                      modpath
                      (DCat accp (DCat (DStr (nl)) dp))
                      (if ism (DCat accl (DCat (DStr (nl)) dl)) accl)
                      (if memf True ism)
                      (if loopf True isl))))))
             (emit_fns rest modpath accp accl memf loopf)))))))))


(fn header ((target (List Int)) (memf Bool) (loopf Bool)) Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/lowergen (the certifying emitter, scalar let/straight-line fragment) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport "../kernel/stdlib.shard")
      (if (if memf True loopf) (dimport "../std/mem") (DStr ""))
      (if loopf (dimport "../std/nat.shard") (DStr ""))
      (dimport "../models/wasm/wasm.shard")
      (if loopf (dimport "../models/wasm/loopkit.shard") (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
      (if loopf (DStr (append_int "(use (:: models wasm loopkit *))" (nl)))
      (DStr ""))
      (if (if memf True loopf) (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr ""))
      (if loopf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl))))))

;; the LINKED file's header: needs the shipped certs AND the portable file
(fn link_header ((target (List Int)) (portout (List Int))) Doc
  (dcat3
    (dcat3
      (DStr
        ";;; GENERATED by tools/lowergen (the LINKED derivations for the mem fragment) --")
      (DStr (nl))
      (dcat3
        (DStr ";;; DO NOT EDIT; regenerate from ")
        (DStr target)
        (DStr (append_int "." (nl)))))
    (dcat3
      (dimport "../kernel/stdlib.shard")
      (dimport "../std/mem")
      (dcat3
        (dimport "../models/wasm/wasm.shard")
        (dimport "../std/mem/mem.wasm.shard")
        (DCat
          (dimport (basename_go portout Nil))
          (dimport (basename_go target Nil)))))
    (dcat3
      (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
      (dcat3
        (DStr (append_int "(use (:: std mem *))" (nl)))
        (DStr (append_int "(use (:: std mem mem.wasm *))" (nl)))
        (use_sibling target portout))
      (use_of target))))

;; ---- driver ------------------------------------------------------------------

(fn prelude_ctors_l () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn fail2 ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn wrote2 ((out (List Int)) (lo (List Int)) (w World)) World
  (exit
    0
    (write
      (append_int
        "wrote "
        (append_int out (append_int " " (append_int lo (nl)))))
      w)))

(fn gen_run
  ((target (List Int)) (out (List Int)) (linko (Option (List Int))) (w World))
  World
  (match (resolve_closure target True w)
    ((Pair Nil w1) (fail2 (append_int "cannot read closure of " target) w1))
    ((Pair srcs w1)
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors_l)
         1)
       ((BMFail diag) (fail2 diag w1))
       ((BMOk m)
        (match m
          ((Module _ fns _ _ _)
           (match
             (emit_fns
               fns
               (split_slash (until_dot target) Nil)
               (DStr "")
               (DStr "")
               False
               False)
             ((EErr msg)
              (exit 1 (write (append_int "refused: " (append_int msg (nl))) w1)))
             ((EOk bodyp bodyl memf loopf)
              (match
                (write_file
                  out
                  (doc_flat (DCat (header target memf loopf) bodyp) Nil)
                  w1)
                ((Pair ok w2)
                 (if ok
                   (if memf
                     (match linko
                       (None
                         (fail2
                           "mem-fragment fns present -- usage: lowergen SRC OUT LINKOUT"
                           w2))
                       ((Some lo)
                        (match
                          (write_file
                            lo
                            (doc_flat (DCat (link_header target out) bodyl) Nil)
                            w2)
                          ((Pair ok2 w3)
                           (if ok2 (wrote2 out lo w3)
                           (fail2 (append_int "cannot write " lo) w3))))))
                     (exit
                       0
                       (write (append_int "wrote " (append_int out (nl))) w2)))
                   (fail2 (append_int "cannot write " out) w2)))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target (Cons out Nil)) (gen_run target out None w1))
       ((Cons target (Cons out (Cons lo Nil)))
        (gen_run target out (Some lo) w1))
       (_ (fail2 "usage: lowergen SRC OUT [LINKOUT]" w1))))))
