;;; tools/low/certnav — the lowering library's raw-cert navigation:
;;; locating the call_fn / call_fn_mem (wasm) and xcall_fn /
;;; xcall_fn_mem (x86) applications in a lowered claim's conclusion —
;;; the conclusion-boundary POLICY consumer tools classify certs by.
;;; The generic raw-form kit (reading forms, symbol tests, the inline
;;; table) lives in meta/forms.

(import "../../kernel/stdlib.shard")
(import "../../kernel/reader.shard")
(import "../../meta/forms")

(use (:: kernel reader SExpr))
(use (:: kernel reader SSym))
(use (:: kernel reader SList))
(use (:: meta forms *))

;; find the first call_fn / call_fn_mem application anywhere in the term
(fn find_call ((s SExpr)) (Option (List SExpr))
  (measure (struct s))
  (match s
    ((SList items)
     (match items
       ((Cons h rest)
        (if (is_sym h (quote call_fn)) (Some items)
        (if (is_sym h (quote call_fn_mem)) (Some items)
        (find_call_list items))))
       (Nil None)))
    (_ None)))

(fn find_call_list ((ss (List SExpr))) (Option (List SExpr))
  (measure (struct ss))
  (match ss
    (Nil None)
    ((Cons h t)
     (match (find_call h)
       ((Some r) (Some r))
       (None (find_call_list t))))))

;; find the first xcall_fn / xcall_fn_mem application anywhere in the
;; term — the x86_64 conclusion boundary (docs/X86.md)
(fn find_xcall ((s SExpr)) (Option (List SExpr))
  (measure (struct s))
  (match s
    ((SList items)
     (match items
       ((Cons h rest)
        (if (is_sym h (quote xcall_fn)) (Some items)
        (if (is_sym h (quote xcall_fn_mem)) (Some items)
        (find_xcall_list items))))
       (Nil None)))
    (_ None)))

(fn find_xcall_list ((ss (List SExpr))) (Option (List SExpr))
  (measure (struct ss))
  (match ss
    (Nil None)
    ((Cons h t)
     (match (find_xcall h)
       ((Some r) (Some r))
       (None (find_xcall_list t))))))

;; find the first xrun_w application anywhere in the term — the WORLD
;; BIN's conclusion boundary (docs/X86.md §32/§47): the ONE bin equation
;; xrun_w … = Some (WExit code trace)
(fn find_xrun_w ((s SExpr)) (Option (List SExpr))
  (measure (struct s))
  (match s
    ((SList items)
     (match items
       ((Cons h rest)
        (if (is_sym h (quote xrun_w)) (Some items) (find_xrun_w_list items)))
       (Nil None)))
    (_ None)))

(fn find_xrun_w_list ((ss (List SExpr))) (Option (List SExpr))
  (measure (struct ss))
  (match ss
    (Nil None)
    ((Cons h t)
     (match (find_xrun_w h)
       ((Some r) (Some r))
       (None (find_xrun_w_list t))))))
