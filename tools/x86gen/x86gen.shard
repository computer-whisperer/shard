          ") lr lhs () ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (premise 3) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((compute lhs))) (steps ((unfold ")
        nm
        (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")))))

(fn xbw_unit ((q QName) (cs Symbol) (fold Bool) (wl Int) (wh Int)) Doc
  (let ((nm (dsym (qn_name q))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr
          "_body () (List XInstr) (list (XMovRR RDX RSI) (XMovRI RSI 0) (XCall 0) (XBin XAnd RAX (SImm 255))))")
        (DStr (nl))
        (DStr "(fn ")
        nm
        (DStr "_func () XFunc (MkXFunc 2 (")
        nm
        (DStr "_body)))")
        (DStr (nl))
        (if fold (DStr "")
        (dconc
          (list
            (DStr "(claim xsumk_")
            (dsym cs)
            (DStr " (goal ((x Int) (k Nat)) ((= (le ")
            (dint wl)
            (DStr " x) True) (= (le (+ x (int_of_nat k)) ")
            (dint wh)
            (DStr
              ") True)) (= (le (+ 0 (* 256 (int_of_nat k))) 18446744073709551616) True)) (by arith (list 1 256 256)))")
