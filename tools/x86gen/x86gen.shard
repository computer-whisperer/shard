        (sp)
        (dint wh)
        (DStr
          ") 0 (MkRegs 0 0 (int_of_nat k) 0 0 0 x0 0 0 0 0 0 0 0 0) m0) (Some (Pair (MkRegs (")
        (dsym cs)
        (DStr " m0 x0 0 k) 0 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x0 0 k) (xlg_adv x0 k) 0 0 0 0 0 0 0 0) m0)))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma ")
        (DStr (if fold "xlfw_" "xliw_"))
        (dsym cs)
        (if fold
          (DStr
            ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))")
          (dconc
            (list
              (DStr
                ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((compute both)) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl) (rewrite-with (lemma xsumk_")
              (dsym cs)
              (DStr
                ") lr lhs ((inst x x0)) ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl)) refl))) (steps ((compute both))) refl))"))))
        (DStr (nl))
        (DStr "(claim lowered_")
        nm
        (DStr
          " (goal ((x0 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr ") True)) (= (xcall_fn_mem (S^ ")
        (dint (if fold 21 19))
        (DStr " (xlg_fuel k c)) (MkXModule (Cons ")
        (xbw_ll cs)
        (DStr " (Cons (MkXFunc 2 (inline ")
        nm
        (DStr "_body)) restfs)) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr ") 1 (list x0 (int_of_nat k)) m0) (Some (Pair (")
        nm
        (DStr
          " m0 x0 k) m0)))) (chain (steps ((compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f ")
        (xbw_ll cs)
        (DStr ") (inst rs2 (MkRegs (")
        (dsym cs)
        (DStr " m0 x0 0 k) 0 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x0 0 k) (xlg_adv x0 k) 0 0 0 0 0 0 0 0)) (inst mem2 m0)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert_")
        (dsym cs)
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((unfold ")
        nm
        (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; ---- the WORLD BIN route (docs/X86.md §47) ----------------------------------------
;;
;; A (bin …) with DECLARED EXTERNS is the W4c effectful shape: fn 0 the
;; decimal fold, fn 1 the do-while store, fn 2 the pointer twin, fn 3 the
;; World-LEADING entry (World first and last, §45's driver contract); the
;; write/exit shims are appended to the image after the entry. World is
;; ERASED as a phantom (linear threading makes that sound); the extern
;; calls lower to the reviewed shim bodies (models/x86/linux.shard) and
;; the emitted contract is §32's ONE bin equation: xrun_w … = Some
;; (WExit 0 trace). v1 pins the whole arrangement — decimal digits, the
;; 0x600400 buffer end, the ghost bound 20, fd 1, exit code 0 — behind
;; named refusals; every constant is template text cut from the checked
;; prototype (examples/addw/addw_x86_out.shard, the §41 discipline).

;; the do-while store fn's literal, spelled as its own claims spell it
(fn xdw_ll ((ds Symbol)) Doc
  (dconc
    (list
      (DStr "(MkXFunc 2 (list (XBlock (list (XLoop (inline ")
      (dsym ds)
      (DStr "_body))))))"))))

;; the open cons prefixes of the world bin's image: the fold before the
;; store unit (own index 1); fold + store before the pointer twin (2)
(fn xgw_pre1 ((cs Symbol)) Doc (dconc (list (DStr "(Cons ") (xbw_ll cs) (sp))))

(fn xgw_pre2 ((cs Symbol) (ds Symbol)) Doc
  (dconc (list (DStr "(Cons ") (xbw_ll cs) (DStr " (Cons ") (xdw_ll ds) (sp))))

;; the source's World type: a nullary user TCon named World (the driver's
;; entry contract owns the deep check; the emitter only recognizes)
(fn xis_world_ty ((t Type)) Bool
  (match t
    ((TCon q args)
     (match args
       (Nil (sym_eq (qn_name q) (quote World)))
       (_ False)))
    (_ False)))

;; a ground S-tower's depth, or -1 (the v1 ghost bound is spelled as
;; literal S's in the source; 20 covers every 64-bit value)
(fn xnat_depth ((e Expr)) Int
  (measure (struct e))
  (match e
    ((Ctor q as)
     (match as
       (Nil (if (sym_eq (qn_name q) (quote Z)) 0 -1))
       ((Cons a Nil)
        (if (sym_eq (qn_name q) (quote S))
          (let ((d2 (xnat_depth a))) (if (lt d2 0) -1 (+ d2 1)))
          -1))
       (_ -1)))
    (_ -1)))

;; the entry's sum binding: (mod (+ (CS m p1 0 k1) (CS m p2 0 k2)) W) —
;; the World param LEADS, so the payload binders sit at the SAME indices
;; as the pure two-call wrapper's and xbw2_call applies verbatim
(fn xbww_sum ((e Expr) (cs Symbol)) Bool
  (match e
    ((Call mq (Cons adde (Cons (IntLit w) Nil)))
     (if (core_named mq (quote mod))
       (if (int_eq w 18446744073709551616)
         (match adde
           ((Call aq (Cons f1 (Cons f2 Nil)))
            (if (core_named aq (quote +))
              (if (xbw2_call f1 cs 3 2) (xbw2_call f2 cs 1 0) False)
              False))
           (_ False))
         False)
       False))
    (_ False)))

;; the digits binding, one let deep: (DS m s 6292480 (S^ 20 Z))
(fn xbww_dig ((e Expr) (ds Symbol)) Bool
  (match e
    ((Call dq (Cons (BVar mv) (Cons (BVar sv) (Cons (IntLit p) (Cons tw Nil)))))
     (if (sym_eq (qn_name dq) ds)
       (if (int_eq mv 5)
         (if (int_eq sv 0)
           (if (int_eq p 6292480) (int_eq (xnat_depth tw) 20) False)
           False)
         False)
       False))
    (_ False)))

;; the start binding, two lets deep: (SS s 6292480 (S^ 20 Z))
(fn xbww_st ((e Expr) (ss Symbol)) Bool
  (match e
    ((Call sq (Cons (BVar sv) (Cons (IntLit p) (Cons tw Nil))))
     (if (sym_eq (qn_name sq) ss)
       (if (int_eq sv 1)
         (if (int_eq p 6292480) (int_eq (xnat_depth tw) 20) False)
         False)
       False))
    (_ False)))

;; the write length: (mod (- 6292480 st) W) — the offered byte count
(fn xbww_len ((e Expr)) Bool
  (match e
    ((Call mq (Cons sub (Cons (IntLit w) Nil)))
     (if (core_named mq (quote mod))
       (if (int_eq w 18446744073709551616)
         (match sub
           ((Call sq (Cons (IntLit p) (Cons (BVar sv) Nil)))
            (if (core_named sq (quote -))
              (if (int_eq p 6292480) (int_eq sv 0) False)
              False))
           (_ False))
         False)
       False))
    (_ False)))

;; the exit tail, three lets deep: (XE (XW w m2 1 st LEN) 0) — World
;; threaded linearly through both effect externs, fd 1, exit code 0
(fn xbww_tail ((e Expr) (xw Symbol) (xe Symbol)) Bool
  (match e
    ((Call eq2 (Cons inner (Cons (IntLit code) Nil)))
     (if (sym_eq (qn_name eq2) xe)
       (if (int_eq code 0)
         (match inner
           ((Call
              wq
              (Cons
                (BVar wv)
                (Cons
                  (BVar m2v)
                  (Cons (IntLit fd) (Cons (BVar stv) (Cons lene Nil))))))
            (if (sym_eq (qn_name wq) xw)
              (if (int_eq wv 8)
                (if (int_eq m2v 1)
                  (if (int_eq fd 1) (if (int_eq stv 0) (xbww_len lene) False)
                  False)
                  False)
                False)
              False))
           (_ False))
         False)
       False))
    (_ False)))

;; the WORLD-LEADING entry shape (v1): params ((w World) (m Mem) (p1 Int)
;; (k1 Nat) (p2 Int) (k2 Nat)), World return, body = the three nested
;; lets (sum, digits, start) closed by the write/exit tail
(fn xbww_shape
  ((ts (List Type))
   (rty Type)
   (body Expr)
   (cs Symbol)
   (ds Symbol)
   (ss Symbol)
   (xw Symbol)
   (xe Symbol))
  Bool
  (match ts
    ((Cons t0 (Cons t1 (Cons t2 (Cons t3 (Cons t4 (Cons t5 Nil))))))
     (if (xis_world_ty t0)
       (if (is_mem_ty t1)
         (if (is_int_ty t2)
           (if (is_nat_ty t3)
             (if (is_int_ty t4)
               (if (is_nat_ty t5)
                 (if (xis_world_ty rty)
                   (match body
                     ((Let (Cons srhs Nil) b1)
                      (if (xbww_sum srhs cs)
                        (match b1
                          ((Let (Cons drhs Nil) b2)
                           (if (xbww_dig drhs ds)
                             (match b2
                               ((Let (Cons strhs Nil) b3)
                                (if (xbww_st strhs ss) (xbww_tail b3 xw xe)
                                False))
                               (_ False))
                             False))
                          (_ False))
                        False))
                     (_ False))
                   False)
                 False)
               False)
             False)
           False)
         False)
       False))
    (_ False)))

;; the GROUND-GHOST companions (docs/X86.md §45): the do-while ghost
;; bound is ground (20 covers every 64-bit value), and the type gate
;; refuses a ground Nat in fn-ARGUMENT position inside a citation's
;; (inst ...) term. These wrappers carry the bound so the welds
;; instantiate over Int and Mem only; the final compute unfolds them.
(fn xgw_comps ((bn Doc) (ds Doc) (ss Doc)) Doc
  (dconc
    (list
      (DStr "(fn ")
      bn
      (DStr "_dg_byte ((n Int)) Int (mod (+ (mod (")
      ds
      (DStr "_hd n (S^ 20 Z)) 10) 48) 18446744073709551616))")
      (DStr (nl))
      (DStr "(fn ")
      bn
      (DStr "_dg_len ((n Int)) Int (")
      ds
      (DStr "_len n (S^ 20 Z)))")
      (DStr (nl))
      (DStr "(fn ")
      bn
      (DStr "_dg_mem ((m Mem) (n Int) (p Int)) Mem (")
      ds
      (DStr " m n p (S^ 20 Z)))")
      (DStr (nl))
      (DStr "(fn ")
      bn
      (DStr "_st_at ((n Int) (p Int)) Int (")
      ss
      (DStr " n p (S^ 20 Z)))")
      (DStr (nl))
      (DStr "(fn ")
      bn
      (DStr "_st_byte ((n Int)) Int (mod (")
      ss
      (DStr "_hd n (S^ 20 Z)) 10))")
      (DStr (nl)))))

;; the sum's range facts (the unit certs' n-premises, discharged at
;; the welds): euclidean mod range on the wrap + the ghost power bound
(fn xgw_sr ((bn Doc) (ds Doc) (ss Doc)) Doc
  (dconc
    (list
      (DStr "(claim x")
      bn
      (DStr
        "_sr0 (goal ((a Int) (b Int)) () (= (le 0 (mod (+ a b) 18446744073709551616)) True)) (div-facts (+ a b) 18446744073709551616 q (by arith (list 1 0 1 0 0))))")
      (DStr (nl))
      (DStr "(claim x")
      bn
      (DStr
        "_sr1 (goal ((a Int) (b Int)) () (= (lt (mod (+ a b) 18446744073709551616) 18446744073709551616) True)) (div-facts (+ a b) 18446744073709551616 q (by arith (list 1 0 0 1 0))))")
      (DStr (nl))
      (DStr "(claim x")
      bn
      (DStr
        "_sr2 (goal ((a Int) (b Int)) () (= (lt (mod (+ a b) 18446744073709551616) (")
      ds
      (DStr
        "_pow (S^ 20 Z))) True)) (chain (steps ((compute lhs))) (div-facts (+ a b) 18446744073709551616 q (by arith (list 1 0 0 1 0)))))")
      (DStr (nl))
      (DStr "(claim x")
      bn
      (DStr
        "_sr3 (goal ((a Int) (b Int)) () (= (lt (mod (+ a b) 18446744073709551616) (")
      ss
      (DStr
        "_pow (S^ 20 Z))) True)) (chain (steps ((compute lhs))) (div-facts (+ a b) 18446744073709551616 q (by arith (list 1 0 0 1 0)))))")
      (DStr (nl)))))

;; the ghost bound, evaluated: int_of_nat is OPAQUE behind std/nat's
;; surface, so the window premises reach their literals through the
;; succ/zero ladder
(fn xgw_k19 ((bn Doc)) Doc
  (dconc
    (list
      (DStr "(claim x")
      bn
      (DStr
