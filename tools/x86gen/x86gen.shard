;; the POINTER route (params (Int Int Nat), Int return — defeats both
;; fn_is_loop and the all-Int path, so it gets its own xg_claim case)
(fn fn_is_dwptr ((f FnDef)) Bool
  (match f
    ((FnDef _ ts rty body)
     (match ts
       ((Cons t0 (Cons t1 (Cons t2 Nil)))
        (if (is_int_ty t0)
          (if (is_int_ty t1)
            (if (is_nat_ty t2)
              (if (is_int_ty rty)
                (match body
                  ((Match _ _) True)
                  (_ False))
                False)
              False)
            False)
          False))
       (_ False)))))

(fn xg_claim_dwptr ((f FnDef) (wl Int) (wh Int)) XCR
  (match f
    ((FnDef q ts rty body)
     (match (xdp_shape q body)
       ((Some d) (XCOk (xdp_unit q d wl wh)))
       (None
