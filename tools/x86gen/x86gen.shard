          ")) ((rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl) (steps ((compute both)) refl)) refl)) refl)) (steps ((rewrite (premise hw0) lr lhs true ()))) (steps ((unfold ")
        nm
