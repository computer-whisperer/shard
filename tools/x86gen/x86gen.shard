;; ---- the DO-WHILE (value-condition) loop family (docs/X86.md §38-§41;
;; ---- probe examples/xitoa_probe.shard — the itoa design article) ---------------
;;
;; The trip count is a function of the DATA (loop while the quotient is
;; nonzero); the Nat is a GHOST bound the machine never sees — machine
;; args are the Ints only, and the premise surface is the §11 pair on n,
;; the ghost power bound, and the DOWNWARD window pair. Two shapes:
;;
;;   STORE ((m Mem) (n Int) (p Int) (k Nat)) -> Mem   (digits, predecrement)
;;     (match k (Z m) ((S k2)
;;       (let ((m2 (mem_set m (- p 1) (mod (+ (mod n D) C) W))))
;;         (if (int_eq (ediv n D) 0) m2 (SELF m2 (ediv n D) (- p 1) k2)))))
;;   POINTER ((n Int) (p Int) (k Nat)) -> Int          (the start-pointer twin)
;;     (match k (Z p) ((S k2)
;;       (if (int_eq (ediv n D) 0) (- p 1) (SELF (ediv n D) (- p 1) k2))))
;;
;; Emitted per unit: body/func literals, the D-spliced spec companions
;; (pow/hd, + len for the store shape), FOUR div guards through the
;; kernel div-facts step (fact order [id, rlo, rhi, qdef]; multipliers
;; divisor-spliced, probe-pinned), the worker induction (xdww_*/xdpw_*,
;; the §39 proof templated), and the lowered theorem. The divisor-free
;; template constants are loopkit's xlg_qinv / xlg_dw*. D and C are
;; imm32 literals; window low is pinned 0 (the harness page and the bin
;; page both).

;; (mod E 2^64) -> E
(fn xdw_w64 ((e Expr)) (Option Expr)
  (match e
    ((Call q as)
     (if (core_named q (quote mod))
       (match as
         ((Cons b (Cons w Nil))
          (match w
            ((IntLit ww) (if (int_eq ww 18446744073709551616) (Some b) None))
            (_ None)))
         (_ None))
       None))
    (_ None)))

;; (- (BVar pi) 1)
(fn xdw_p1 ((e Expr) (pi Int)) Bool
  (match e
    ((Call q as)
     (if (core_named q (quote -))
       (match as
         ((Cons a (Cons b Nil))
          (match a
            ((BVar ab)
             (if (int_eq ab pi)
               (match b
                 ((IntLit bb) (int_eq bb 1))
                 (_ False))
               False))
            (_ False)))
         (_ False))
       False))
    (_ False)))

;; (ediv (BVar ni) D) -> D  (imm32, positive)
(fn xdw_q ((e Expr) (ni Int)) (Option Int)
  (match e
    ((Call q as)
     (if (core_named q (quote ediv))
       (match as
         ((Cons a (Cons b Nil))
          (match a
            ((BVar ab)
             (if (int_eq ab ni)
               (match b
                 ((IntLit d)
                  (if (lt 0 d) (if (lt d 2147483648) (Some d) None) None))
                 (_ None))
               None))
            (_ None)))
         (_ None))
       None))
    (_ None)))

;; (int_eq (ediv (BVar ni) D) 0) -> D
(fn xdw_cond ((e Expr) (ni Int)) (Option Int)
  (match e
    ((Call q as)
     (if (core_named q (quote int_eq))
       (match as
         ((Cons a (Cons b Nil))
          (match b
            ((IntLit z) (if (int_eq z 0) (xdw_q a ni) None))
            (_ None)))
         (_ None))
       None))
    (_ None)))

;; the stored byte (mod (+ (mod (BVar ni) D) C) W) -> (Pair D C)
(fn xdw_byte ((e Expr) (ni Int)) (Option (Pair Int Int))
  (match (xdw_w64 e)
    (None None)
    ((Some e1)
     (match e1
       ((Call qp pas)
        (if (core_named qp (quote +))
          (match pas
            ((Cons md (Cons cl Nil))
             (match cl
               ((IntLit c)
                (if (le 0 c)
                  (if (lt c 2147483648)
                    (match md
                      ((Call qm mas)
