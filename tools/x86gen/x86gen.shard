;; ---- the Int-return DECIMAL-FOLD loop (probe examples/xfoldloop_probe) ---------
;;
;; (fn NAME ((m Mem) (p Int) (a Int) (k Nat)) Int
;;   (match k (Z a) ((S k2) (NAME m (+ p 1)
;;     (mod (- (mod (+ (mod (* a A) W) (mem_get m p)) W) C) W) k2))))
;; — the LFOk shape (atoi's; rung B). THE SPEC SPELLS THE MACHINE'S WRAPS
;; (§11's law): a parse accumulator has no usable bound, so where the sum
;; shape carried the k-scaled wrap invariant and wrap64_id haves, the
;; fold carries NO accumulator premise and discharges nothing — the
;; machine's nested mod term IS the spec's update, syntactically. Premise
;; surface = the window pair on the address alone (the glue contract's).
;; Module literal, register file, and rax residue (kit xlg_last) are the
;; sum unit's; body is 8 instructions, fuel 12/16 probe-validated.

;; the fold premise text: the window pair on the address, nothing else
(fn xlf_prems ((wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr "((= (le ")
      (dint wl)
      (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
      (dint wh)
      (DStr ") True))"))))

;; body + func + worker induction + lowered theorem (the probe templated)
(fn xlf_unit ((q QName) (mids (List Type)) (a Int) (c Int) (wl Int) (wh Int))
  Doc
