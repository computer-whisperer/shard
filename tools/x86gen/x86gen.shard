        nm
        (DStr "_pow (S k))) True) (= (le (+ ")
        (dint (+ wl 1))
        (DStr " (int_of_nat k)) p) True) (= (le p ")
        (dint wh)
        (DStr
          ") True)) (= (xcall_fn_mem (S^ 16 (xlg_fuel k c)) (MkXModule (Cons (MkXFunc 2 (list (XBlock (list (XLoop (inline ")
        nm
        (DStr "_body)))) (XMovRR RAX RSI))) restfs) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr ") 0 (list n p) mem) (Some (Pair (")
        nm
        (DStr
          " n p (S k)) mem)))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xdpw_")
        nm
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (premise 3) lr lhs true ())) refl) (steps ((rewrite (premise 4) lr lhs true ())) refl))) (steps ((compute both)) refl)))")))))

;; ---- the COPY loop (probe examples/xcopyloop_probe) ----------------------------
;;
;; (fn NAME ((m Mem) (s Int) (d Int) (k Nat)) Mem
;;   (match k (Z m) ((S k2) (NAME (mem_set m d (mem_get m s)) (+ s 1) (+ d 1) k2))))
;; — the LVRead store value of lp_recognize's LROk (wasm's twin emits it
;; directly; x86 has no mem-to-mem move, so the byte lands in rax). v1
;; pins the probe exactly: two advancing accums, the READ address first,
;; the store address second. The worker closes rax over the kit's
;; xlg_lastc — which threads the memory, since this loop's own store
;; changes what the next load sees — and QUANTIFIES the entry rax (ra);
;; the piece's epilogue XMovRI RAX 0 overwrites the residue, keeping the
;; Mem-return (Pair 0 mem') conclusion. Two address guards per iteration
;; (the load, then the store), so the guard stage runs twice.

;; the module literal: [the epilogue'd loop func | restfs], self at 0
(fn xlc_mod ((nm Doc) (wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr "(MkXModule (Cons (MkXFunc 3 (list (XBlock (list (XLoop (inline ")
      nm
      (DStr "_body)))) (XMovRI RAX 0))) restfs) ")
      (dint wl)
      (sp)
      (dint wh)
      (DStr ")"))))

;; the window pair on BOTH addresses (mark's premise set)
(fn xlc_prems ((wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr "((= (le ")
      (dint wl)
      (DStr " x0) True) (= (le ")
      (dint wl)
      (DStr " x1) True) (= (le (+ x0 (int_of_nat k)) ")
      (dint wh)
      (DStr ") True) (= (le (+ x1 (int_of_nat k)) ")
      (dint wh)
      (DStr ") True))"))))

;; one address guard stage: the lo premise, then xlg_a1_ms at its pair
(fn xlc_stage ((pa Int) (pb Int)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop xeval_loop xlg_fuel)) (rewrite (premise ")
      (dint pa)
      (DStr
        ") lr lhs true ()) (compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint pb)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; body + func + worker induction + lowered theorem (the probe
