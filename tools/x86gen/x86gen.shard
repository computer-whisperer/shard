;; the WORLD entry's whole emission: companions, range facts, the
;; int_of_nat ladder, the fold's re-fueled site certs, the entry body,
;; the shims, the ground-fuel do-while site certs, the bin equation
(fn xgw_entry ((q QName) (bnm Symbol) (cs Symbol) (ds Symbol) (ss Symbol)) Doc
  (let ((nm (dsym (qn_name q))))
    (let ((bn (dsym bnm)))
      (let ((csd (dsym cs)))
        (let ((dsd (dsym ds)))
          (let ((ssd (dsym ss)))
            (dconc
              (list
                (xgw_comps bn dsd ssd)
                (xgw_sr bn dsd ssd)
                (xgw_k19 bn)
                (xgw_cert12 csd)
                (xgw_ebody nm)
                (xgw_shims bn)
                (xgw_cert3 bn csd dsd)
                (xgw_cert4 bn csd dsd ssd)
                (xgw_loww bn csd dsd ssd nm)))))))))

;; claims + the xfuncs cons spine (closed by xlib_funcs_doc at count 6) +
;; the entry's name at its image index
(type XBS (XBSOk Doc Doc (List (Pair Symbol Int))) (XBSErr (List Int)))

;; the file's own fns, source order (the closure's imports skipped)
(fn xbinw_own ((fns (List FnDef)) (modpath (List Symbol))) (List FnDef)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (match q
          ((QName mp _)
           (if (sym_list_eq mp modpath) (Cons f (xbinw_own rest modpath))
           (xbinw_own rest modpath)))))))))

;; the image function list: fold, store, twin, entry, then the shims
(fn xbinw_accf ((cs Symbol) (ds Symbol) (ss Symbol) (en Symbol) (bnm Symbol))
  Doc
  (dconc
    (list
      (DStr "(Cons (")
      (dsym cs)
      (DStr "_func) (Cons (")
      (dsym ds)
      (DStr "_func) (Cons (")
      (dsym ss)
      (DStr "_func) (Cons (")
      (dsym en)
      (DStr "_func) (Cons (")
      (dsym bnm)
      (DStr "_write_func) (Cons (")
      (dsym bnm)
      (DStr "_exit_func) "))))

;; stage 4/4: the World-leading entry, then the assembled result
(fn xbinw_entry
  ((f3 FnDef)
   (bnm Symbol)
   (xw Symbol)
   (xe Symbol)
   (cs Symbol)
   (ds Symbol)
   (ss Symbol)
   (d0 Doc)
   (d1 Doc)
   (d2 Doc))
  XBS
  (match f3
    ((FnDef q3 ts3 rty3 body3)
     (if (xbww_shape ts3 rty3 body3 cs ds ss xw xe)
       (XBSOk
         (dconc
           (list
             (DStr (nl))
             d0
             (DStr (nl))
             d1
             (DStr (nl))
             d2
             (DStr (nl))
             (xgw_entry q3 bnm cs ds ss)))
         (xbinw_accf cs ds ss (qn_name q3) bnm)
         (Cons (Pair (qn_name q3) 3) Nil))
       (XBSErr
         "the world bin's fn 3 must be the World-LEADING two-call entry (v1 pins the shape: sum, digits at 6292480 ghost 20, start, write fd 1, exit 0)")))))

;; stage 3/4: the pointer twin (decimal, module context fold + store)
(fn xbinw_dp
  ((f2 FnDef)
   (f3 FnDef)
   (bnm Symbol)
   (xw Symbol)
   (xe Symbol)
   (cs Symbol)
   (ds Symbol)
   (d0 Doc)
   (d1 Doc)
   (wl Int)
   (wh Int))
  XBS
  (match f2
    ((FnDef q2 ts2 rty2 body2)
     (if (fn_is_dwptr f2)
       (match (xdp_shape q2 body2)
         ((Some d)
          (if (int_eq d 10)
            (xbinw_entry
              f3
              bnm
              xw
              xe
              cs
              ds
              (qn_name q2)
              d0
              d1
              (xdp_core q2 d wl wh (xgw_pre2 cs ds) 2))
            (XBSErr "the world bin's pointer twin is decimal (v1)")))
         (None
           (XBSErr
             "the world bin's fn 2 must be the do-while POINTER TWIN (v1)")))
       (XBSErr "the world bin's fn 2 must be the do-while POINTER TWIN (v1)")))))

;; stage 2/4: the do-while store (decimal/ASCII, module context = fold)
(fn xbinw_dw
  ((f1 FnDef)
   (f2 FnDef)
   (f3 FnDef)
   (bnm Symbol)
   (xw Symbol)
   (xe Symbol)
   (cs Symbol)
   (d0 Doc)
   (wl Int)
   (wh Int))
  XBS
  (match f1
    ((FnDef q1 ts1 rty1 body1)
     (if (fn_is_loop f1)
       (if (is_mem_ty rty1)
         (match (xdw_shape q1 body1)
           ((Some dwp)
            (match dwp
              ((Pair dwd dwc)
               (if (int_eq dwd 10)
                 (if (int_eq dwc 48)
                   (xbinw_dp
                     f2
                     f3
                     bnm
                     xw
                     xe
                     cs
                     (qn_name q1)
                     d0
                     (xdw_core q1 dwd dwc wl wh (xgw_pre1 cs) 1)
                     wl
                     wh)
                   (XBSErr "the world bin's digit store is decimal/ASCII (v1)"))
                 (XBSErr "the world bin's digit store is decimal/ASCII (v1)")))))
           (None
             (XBSErr "the world bin's fn 1 must be the do-while STORE (v1)")))
         (XBSErr "the world bin's fn 1 must be the do-while STORE (v1)"))
       (XBSErr "the world bin's fn 1 must be the do-while STORE (v1)")))))

;; stage 1/4: the decimal fold (the pure callee; its unit + xlfw cert are
;; the standing lib route's, emitted through xg_claim_loop)
(fn xbinw_fold
  ((f0 FnDef)
   (f1 FnDef)
   (f2 FnDef)
   (f3 FnDef)
   (bnm Symbol)
   (xw Symbol)
   (xe Symbol)
   (wl Int)
   (wh Int))
  XBS
  (match f0
    ((FnDef q0 ts0 rty0 body0)
     (if (fn_is_loop f0)
       (if (is_int_ty rty0)
         (if (xbw_isfold f0)
           (match (xg_claim_loop f0 wl wh)
             ((XCErr m) (XBSErr m))
             ((XCOk d0) (xbinw_dw f1 f2 f3 bnm xw xe (qn_name q0) d0 wl wh)))
           (XBSErr "the world bin's fn 0 must be the decimal FOLD (v1)"))
         (XBSErr "the world bin's fn 0 must be the decimal FOLD (v1)"))
       (XBSErr "the world bin's fn 0 must be the decimal FOLD (v1)")))))

;; the machine: exactly four own fns, in the pinned order
(fn xemit_binw
  ((own (List FnDef)) (bnm Symbol) (xw Symbol) (xe Symbol) (wl Int) (wh Int))
  XBS
  (match own
    ((Cons f0 (Cons f1 (Cons f2 (Cons f3 Nil))))
     (xbinw_fold f0 f1 f2 f3 bnm xw xe wl wh))
    (_
      (XBSErr
        "the world bin is fold + do-while store + pointer twin + World entry, in source order (v1)"))))

;; claims, the xfuncs cons spine (open), name -> index, count
(type XLE (XLEOk Doc Doc (List (Pair Symbol Int)) Int) (XLEErr (List Int)))

(fn xemit_fns_lib
  ((fns (List FnDef))
   (modpath (List Symbol))
   (seen (List FnDef))
   (k Int)
   (accp Doc)
   (accf Doc)
   (accn (List (Pair Symbol Int)))
   (lloop (Option (Pair Symbol Bool)))
   (wl Int)
   (wh Int))
  XLE
  (measure (struct fns))
  (match fns
    (Nil (XLEOk accp accf accn k))
    ((Cons f rest)
     (match f
       ((FnDef q ts rty body)
        (match q
          ((QName mp nm)
           (if (sym_list_eq mp modpath)
             (if (fn_is_loop f)
               ;; a loop may be fn 0 of a lib/bin file. An INT-return loop
               ;; is a wrapper's callee (it registers as lloop); a
               ;; MEM-return loop is the artifact's own entry — the §27
               ;; write-variant contract's shape, with no wrapper after it
               ;; (docs/X86.md §28). xg_claim_loop owns the return-type
               ;; dispatch and its own shape refusals.
               (if (int_eq k 0)
                 (match (xg_claim_loop f wl wh)
                   ((XCErr m) (XLEErr m))
                   ((XCOk d)
                    (xemit_fns_lib
                      rest
                      modpath
                      (Cons f seen)
                      1
                      (DCat accp (DCat (DStr (nl)) d))
                      (DCat
                        accf
                        (dconc
                          (list (DStr "(Cons (") (dsym nm) (DStr "_func) "))))
                      (Cons (Pair nm 0) accn)
                      (if (is_int_ty rty) (Some (Pair nm (xbw_isfold f))) lloop)
                      wl
                      wh)))
                 (XLEErr "a loop must be fn 0 of the lib file (v1)"))
               (if (fn_is_mem f)
                 (if (xid_shape ts rty body)
                   (if (int_eq k 0)
                     (xemit_fns_lib
                       rest
                       modpath
                       (Cons f seen)
                       1
                       (DCat accp (DCat (DStr (nl)) (xid_unit q wl wh)))
                       (DCat accf (dcat3 (DStr "(Cons ") (xid_flit) (sp)))
                       (Cons (Pair nm 0) accn)
                       lloop
                       wl
                       wh)
                     (XLEErr
                       "the identity entry must be fn 0 of the bin file (v1)"))
                   (match lloop
                     ((Some (Pair cs fold))
                      (if (xbw_shape ts rty body cs)
                        (if (int_eq k 1)
                          (xemit_fns_lib
                            rest
                            modpath
                            (Cons f seen)
                            2
                            (DCat
                              accp
                              (DCat (DStr (nl)) (xbw_unit q cs fold wl wh)))
                            (DCat
                              accf
                              (dconc
                                (list
                                  (DStr "(Cons (")
                                  (dsym nm)
                                  (DStr "_func) "))))
                            (Cons (Pair nm 1) accn)
                            lloop
                            wl
                            wh)
                          (XLEErr
                            "the entry wrapper must immediately follow its loop (v1)"))
                      (if (xbw2_shape ts rty body cs)
                        (if fold
                          (if (int_eq k 1)
                            (xemit_fns_lib
                              rest
                              modpath
                              (Cons f seen)
                              2
                              (DCat
                                accp
                                (DCat (DStr (nl)) (xbw2_unit q cs wl wh)))
                              (DCat
                                accf
                                (dconc
                                  (list
                                    (DStr "(Cons (")
                                    (dsym nm)
                                    (DStr "_func) "))))
                              (Cons (Pair nm 1) accn)
                              lloop
                              wl
                              wh)
                            (XLEErr
                              "the entry wrapper must immediately follow its loop (v1)"))
                          (XLEErr
                            "the two-call wrapper needs the fold callee (v1)"))
                        (XLEErr
                          "mem fns are not in the x86 lib fragment yet (v1 lib mem shape: the band-masked seeded sum call against fn 0)"))))
                     (None
                       (XLEErr "mem fns are not in the x86 lib fragment yet"))))
                 (match (xc_target body seen)
                   ((Some _)
                    (XLEErr "call fns are not in the x86 lib fragment yet"))
                   (None
                     (match (xg_claim f k)
                       ((XCErr m) (XLEErr m))
                       ((XCOk d)
                        (match (xlib_flit f)
                          (None (XLEErr "lib literal generation failed"))
                          ((Some flit)
                           (xemit_fns_lib
                             rest
                             modpath
                             (Cons f seen)
                             (+ k 1)
                             (DCat accp (DCat (DStr (nl)) d))
                             (DCat accf (dcat3 (DStr "(Cons ") flit (sp)))
                             (Cons (Pair nm k) accn)
                             lloop
                             wl
                             wh)))))))))
             (xemit_fns_lib rest modpath seen k accp accf accn lloop wl wh)))))))))

(fn xlib_funcs_doc ((lname Symbol) (accf Doc) (k Int)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr ";; the lib image: every fn of the file at its source-order index")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_xfuncs () (List XFunc) ")
      accf
      (DStr "Nil")
      (xpr_rpars k)
      (DStr ")")
      (DStr (nl)))))

(fn xlib_exp_at ((x Symbol) (ns (List (Pair Symbol Int)))) (Option Int)
  (measure (struct ns))
  (match ns
    (Nil None)
    ((Cons (Pair n i) rest) (if (sym_eq x n) (Some i) (xlib_exp_at x rest)))))

(fn xlib_exp_entries ((exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (measure (struct exps))
  (match exps
    (Nil (Some (DStr "")))
    ((Cons x rest)
     (match (xlib_exp_at x ns)
       (None None)
       ((Some i)
        (match (xlib_exp_entries rest ns)
          (None None)
          ((Some d)
           (Some
             (DCat
               (dconc
                 (list
                   (DStr " (XX ")
                   (DStr (list 34))
                   (dsym x)
                   (DStr (list 34))
                   (sp)
                   (dint i)
                   (DStr ")")))
               d)))))))))

(fn xlib_exports_doc
  ((lname Symbol) (exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (match (xlib_exp_entries exps ns)
    (None None)
    ((Some entries)
     (Some
       (dconc
         (list
           (DStr (nl))
           (DStr
             ";; the export table: the (lib …) declaration's names, by index")
           (DStr (nl))
           (DStr "(fn ")
           (dsym lname)
           (DStr "_exports () (List XExport) (list")
           entries
           (DStr "))")
           (DStr (nl))))))))

;; the per-entry encoding, spec-side: the plan driver evaluates this
;; instead of importing target encoders — export k is laid FIRST (the
;; harness calls the blob's start); indices inside the image never move
(fn xlib_bytes_doc ((lname Symbol)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr
        ";; the encoded image, one layout per export: enc_image with entry k")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_entry_bytes ((k Int)) (List Int) (enc_image (")
      (dsym lname)
      (DStr "_xfuncs) k))")
      (DStr (nl))
      (DStr (nl))
      (DStr
        ";; the ELF harness inputs (docs/X86.md §20): the index-order image")
      (DStr (nl))
      (DStr ";; (entry = the stub, not a lib fn) and its per-index offsets")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_elf_image () (List Int) (enc_image_ord (")
      (dsym lname)
      (DStr "_xfuncs)))")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_elf_offsets () (List Int) (img_offs_ord (")
      (dsym lname)
      (DStr "_xfuncs) 0))")
      (DStr (nl)))))

;; the (lib …) declaration of the TARGET source, if any. A (bin …)
;; declaration is admitted AS a one-export lib (docs/X86.md §22): the
;; image machinery is identical — one image, the entry at its
;; source-order index — and the differences (the argv glue, the
;; glue-contract surface law) live in the ELF builder and the accepts
;; gate's bin arm, never in the emitter.
;; the TARGET source's artifact declaration: a (lib …), or the (bin …)
;; kept WHOLE — the world route needs the externs; the exit-variant bin
;; is admitted as a one-export lib downstream (docs/X86.md §22)
(type XDecl (XDLib Lib) (XDBin Bin))

(fn xlib_scan_forms ((forms (List SExpr))) (Option XDecl)
  (measure (struct forms))
  (match forms
    (Nil None)
    ((Cons f rest)
     (if (is_lib_form f)
       (match (lib_of_form f)
         (None (xlib_scan_forms rest))
         ((Some l) (Some (XDLib l))))
     (if (is_bin_form f)
       (match (bin_of_form f)
         (None (xlib_scan_forms rest))
         ((Some b) (Some (XDBin b))))
       (xlib_scan_forms rest))))))

(fn xlib_scan ((srcs (List SrcEntry)) (target (List Int))) (Option XDecl)
  (measure (struct srcs))
  (match srcs
    (Nil None)
    ((Cons (SrcEntry path _ src) rest)
     (if (int_list_eq path target)
       (match (read_all src)
         (None None)
         ((Some forms) (xlib_scan_forms forms)))
       (xlib_scan rest target)))))

;; the LIB file's header: the model, the encoder (XExport/XX for the
;; export table, enc_image for the per-entry bytes), and the source
(fn xany_loop ((fns (List FnDef))) Bool
  (measure (struct fns))
  (match fns
    (Nil False)
    ((Cons f rest) (if (fn_is_loop f) True (xany_loop rest)))))

(fn xlib_header ((target (List Int)) (lf Bool) (wf Bool)) Doc
  (dconc
    (list
      (if wf
        (DStr
          ";;; GENERATED by tools/x86gen (WORLD BIN mode: one image, the effectful entry) --")
        (DStr
          ";;; GENERATED by tools/x86gen (LIB mode: one image, named exports) --"))
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (dimport (append_int (updots target) "models/x86/x86.shard"))
      (dimport (append_int (updots target) "models/x86/encode.shard"))
      (if lf (dimport (append_int (updots target) "models/x86/loopkit.shard"))
      (DStr ""))
      (if wf (dimport (append_int (updots target) "models/linux/kernel.shard"))
      (DStr ""))
      (if wf (dimport (append_int (updots target) "models/x86/world.shard"))
      (DStr ""))
      (if lf (dimport (append_int (updots target) "std/nat.shard")) (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models x86 x86 *))" (nl)))
      (if lf (DStr (append_int "(use (:: models x86 loopkit *))" (nl)))
      (DStr ""))
      (if wf (DStr (append_int "(use (:: models linux kernel *))" (nl)))
      (DStr ""))
      (if wf (DStr (append_int "(use (:: models x86 world *))" (nl))) (DStr ""))
      (if lf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
      (DStr (append_int "(use (:: models x86 encode XExport))" (nl)))
      (DStr (append_int "(use (:: models x86 encode XX))" (nl)))
      (DStr (append_int "(use (:: models x86 encode enc_image))" (nl)))
      (DStr (append_int "(use (:: models x86 encode enc_image_ord))" (nl)))
      (DStr (append_int "(use (:: models x86 encode img_offs_ord))" (nl)))
      (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl))))))

;; lib mode: emit the position-general claims + the image function list +
;; the export table + the per-entry encoding.
(fn xlib_run
  ((l Lib)
   (fns (List FnDef))
   (target (List Int))
   (out (List Int))
   (binf Bool)
   (w World))
  World
  (match l
    ((Lib lname exps _acc)
     (match
       (xemit_fns_lib
         fns
         (split_slash (until_dot target) Nil)
         Nil
         0
         (DStr "")
         (DStr "")
         Nil
         None
         (if binf (xw_blo) (xw_hlo))
         (if binf (xw_bhi) (xw_hhi)))
       ((XLEErr msg)
        (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))
       ((XLEOk bodyp accf ns k)
        (match (xlib_exports_doc lname exps ns)
          (None
            (exit
              1
              (write
                "refused: a (lib exports) name is not an emitted fn of this file\n"
                w)))
          ((Some expdoc)
           (match
             (write_file
               out
               (doc_flat
                 (dconc
                   (list
                     (xlib_header target (xany_loop fns) False)
                     bodyp
                     (xlib_funcs_doc lname accf k)
                     expdoc
                     (xlib_bytes_doc lname)))
                 Nil)
               w)
             ((Pair ok w2)
              (if ok
                (exit 0 (write (append_int "wrote " (append_int out (nl))) w2))
                (xfail (append_int "cannot write " out) w2)))))))))))

;; world bin mode: the pinned four-fn machine, the entry at image index 3,
;; the shims appended — six image functions, one export
(fn xbinw_run
  ((bnm Symbol)
   (entry Symbol)
   (xw Symbol)
   (xe Symbol)
   (fns (List FnDef))
   (target (List Int))
   (out (List Int))
   (w World))
  World
  (match
    (xemit_binw
      (xbinw_own fns (split_slash (until_dot target) Nil))
      bnm
      xw
      xe
      (xw_blo)
      (xw_bhi))
    ((XBSErr msg)
     (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))
    ((XBSOk bodyp accf ns)
     (match (xlib_exports_doc bnm (Cons entry Nil) ns)
       (None
         (exit
           1
           (write
             "refused: the (bin entry) name is not the emitted World entry\n"
             w)))
       ((Some expdoc)
        (match
          (write_file
            out
            (doc_flat
              (dconc
                (list
                  (xlib_header target True True)
                  bodyp
                  (xlib_funcs_doc bnm accf 6)
                  expdoc
                  (xlib_bytes_doc bnm)))
              Nil)
            w)
          ((Pair ok w2)
           (if ok
             (exit 0 (write (append_int "wrote " (append_int out (nl))) w2))
             (xfail (append_int "cannot write " out) w2)))))))))

;; a (bin …) routes by its extern surface: none = the exit-variant bin,
;; admitted AS a one-export lib (docs/X86.md §22); exactly two = the W4c
;; world bin (write then exit); anything else is refused
(fn xbin_dispatch
  ((b Bin) (fns (List FnDef)) (target (List Int)) (out (List Int)) (w World))
  World
  (match b
    ((Bin bname entry exts _t _r)
     (match exts
       (Nil (xlib_run (Lib bname (Cons entry Nil) Nil) fns target out True w))
       ((Cons xw (Cons xe Nil)) (xbinw_run bname entry xw xe fns target out w))
       (_
         (exit
           1
           (write
             "refused: a bin declares no externs (the exit variant) or exactly two -- write then exit (the world bin, v1)\n"
             w)))))))

;; ---- driver -----------------------------------------------------------------------

(fn prelude_ctors_l () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn xfail ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn xgen_run ((target (List Int)) (out (List Int)) (w World)) World
  (match (resolve_closure target True w)
    ((Pair Nil w1) (xfail (append_int "cannot read closure of " target) w1))
    ((Pair srcs w1)
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors_l)
         1)
       ((BMFail diag) (xfail diag w1))
       ((BMOk m)
        (match m
          ((Module _ fns _ _ _)
           (match (xlib_scan srcs target)
             ((Some (XDLib l)) (xlib_run l fns target out False w1))
             ((Some (XDBin b)) (xbin_dispatch b fns target out w1))
             (None
               (match
                 (xg_fns
                   fns
                   (split_slash (until_dot target) Nil)
                   Nil
                   Nil
                   Nil
                   (DStr "")
                   False
                   False)
                 ((XEErr msg)
                  (exit
                    1
                    (write (append_int "refused: " (append_int msg (nl))) w1)))
                 ((XEOk body loopf memf)
                  (match
                    (write_file
                      out
                      (doc_flat (DCat (xg_header target loopf memf) body) Nil)
                      w1)
                    ((Pair ok w2)
                     (if ok
                       (exit
                         0
                         (write (append_int "wrote " (append_int out (nl))) w2))
                       (xfail (append_int "cannot write " out) w2)))))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target (Cons out Nil)) (xgen_run target out w1))
       (_ (xfail "usage: x86gen SRC OUT" w1))))))
