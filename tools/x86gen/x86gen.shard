          " m0 x0 x1 k))))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlcw_")
        nm
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (premise 3) lr lhs true ())) refl))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; the copy shape's v1 fences: exactly two accums, both +1, the READ
;; address accum 0, the store address accum 1 (the probe's pinning)
(fn xlc_shape_ok ((n Int) (adv (List LStr)) (ai Int) (j Int)) Bool
  (if (int_eq n 2)
    (if (int_eq j 0)
      (if (int_eq ai 1)
        (match adv
          ((Cons (LSInc) (Cons (LSInc) Nil)) True)
          (_ False))
        False)
      False)
    False))

;; the loop-fn gate: param slicing + the shared recognizer + v1 fences
;; the TRANSFORM loop (docs/X86.md §28): a one-pointer read-modify-write
;; whose store value is the range shift `(if (le LO b) (if (le b HI) (- b
;; D) b) b)` at b = (mem_get m p). The ISA has no cmov and no setcc, so
;; the transform is a nested-XBlock DIAMOND inside the loop body — the
;; only place in the tree where one loop iteration branches. The range
;; test is ONE unsigned compare against the WIDTH (HI - LO) + 1, because
;; below LO the wrap64 subtraction lands near 2^64; conds do not negate
;; at use, so the taken branch is the SKIP.
;;
;; The worker's S case forks on the SPEC's conditions and pins the
;; MACHINE cond per leg with loopkit's xlg_xf* bridges (std/mem's
;; get_lo/get_hi supply bytehood; the ground legs — 0 <= LO, HI < 256,
;; (HI - LO) + 1 = W — ride (compute both), the window pair's idiom).
;; Residues xlg_lastxf / xlg_lastsc thread the loop's own memory; the
;; epilogue (XMovRI RAX 0) keeps them out of the theorem. 9-instruction
;; body: S^13 worker / S^17 theorem (nesting is free — fuel is
;; DEPTH-shaped). Counter home RSI leaves RCX as the compare scratch.
;; Probe: examples/xtransform_probe.shard.
(fn xlx_unit ((q QName) (lo Int) (hi Int) (d Int) (wl Int) (wh Int)) Doc
  (let ((nm (dsym (qn_name q))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr
          "_body () (List XInstr) (list (XBrIf (CEqz RSI) 1) (XLoad8 RAX (AReg RDI)) (XMovRR RCX RAX) (XBin XSub RCX (SImm ")
        (dint lo)
        (DStr ")) (XBlock (list (XBlock (list (XBrIf (CLtU RCX (SImm ")
        (dint (+ (- hi lo) 1))
        (DStr ")) 0) (XBr 1))) (XBin XSub RAX (SImm ")
        (dint d)
        (DStr
          ")))) (XStore8 (AReg RDI) (SReg RAX)) (XBin XAdd RDI (SImm 1)) (XBin XSub RSI (SImm 1)) (XBr 0))) (fn ")
        nm
        (DStr "_func () XFunc (MkXFunc 2 (list (XBlock (list (XLoop (")
        nm
        (DStr "_body)))) (XMovRI RAX 0)))) (claim xlxw_")
        nm
        (DStr
          " (goal ((ra Int) (rc Int) (x0 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr
          ") True)) (= (xeval_loop (S^ 13 (xlg_fuel k c)) (MkXModule (Cons (MkXFunc 2 (list (XBlock (list (XLoop (inline ")
        nm
        (DStr "_body)))) (XMovRI RAX 0))) restfs) ")
        (dint wl)
        (DStr " ")
        (dint wh)
        (DStr ") (inline ")
        nm
        (DStr
          "_body) (MkRegs ra rc 0 0 0 (int_of_nat k) x0 0 0 0 0 0 0 0 0) m0) (Some (XBrk 0 (MkRegs (xlg_lastxf m0 x0 ")
        (dint lo)
        (DStr " ")
        (dint hi)
        (DStr " ")
        (dint d)
        (DStr " ra k) (xlg_lastsc m0 x0 ")
        (dint lo)
        (DStr " ")
        (dint hi)
        (DStr " ")
        (dint d)
        (DStr " rc k) 0 0 0 0 (xlg_adv x0 k) 0 0 0 0 0 0 0 0) (")
        nm
        (DStr
          " m0 x0 k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold xlg_fuel lhs) (reduce lhs) (unfold xeval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute")
        (DStr
