                                     (Some (Pair d c))
                                     None))))
                               (None None)))
                            (_ None)))
                         (_ None))
                       None)))
                  None))))
            (_ None))
          None))
       (_ None)))
    (_ None)))

;; the POINTER S arm (k2=0 k=1 p=2 n=3):
;; (if (int_eq (ediv n D) 0) (- p 1) (SELF (ediv n D) (- p 1) k2))
(fn xdp_sarm ((self QName) (e Expr)) (Option Int)
