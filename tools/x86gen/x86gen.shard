          " m0 x0 k1 x2 k2) m0)))) (chain (steps ((compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (MkXFunc 3 (list (XBlock (list (XLoop (inline ")
        (dsym cs)
        (DStr "_body)))) (XMovRR RAX RSI)))) (inst rs2 (MkRegs (")
        (dsym cs)
        (DStr " m0 x0 0 k1) (int_of_nat k2) 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x0 0 k1) (xlg_adv x0 k1) x2 (int_of_nat k2) 0 0 0 0 0 0)) (inst mem2 m0)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert1_")
        (dsym cs)
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (MkXFunc 3 (list (XBlock (list (XLoop (inline ")
        (dsym cs)
        (DStr "_body)))) (XMovRR RAX RSI)))) (inst rs2 (MkRegs (")
        (dsym cs)
        (DStr " m0 x2 0 k2) (")
        (dsym cs)
        (DStr " m0 x0 0 k1) 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x2 0 k2) (xlg_adv x2 k2) x2 (int_of_nat k2) 0 0 0 0 0 0)) (inst mem2 m0)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert2_")
        (dsym cs)
