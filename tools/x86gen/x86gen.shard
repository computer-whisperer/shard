;;; x86gen — the certifying x86_64 emitter (docs/X86.md §11-§18): the
;;; pure fragment (straight-line/lets/ifs), the loop fragment (§14), the
;;; mem fragment (§15), the call fragment (§16 — sibling calls through
;;; GENERATED clobber-set certs), the chain tier (§17 — certs for
;;; callers, clobber-aware allocation), and calls in loops (§18 — the
;;; bridge inside the induction, home-aligned store callees, the CInfo
;;; registry routing). For every fn in the target
;;; file whose body is arithmetic over Int params (+ - * band bor bxor),
;;; literals in [0, 2^31) (the encoder's imm32 fence), single-binding
;;; lets, and tail-position ifs (int_eq/lt/le fused conditions, §12),
;;; emit:
;;;   - the XFunc literal (two-operand register code against the SysV
;;;     argument homes; emitter-time register allocation, docs/X86.md
;;;     §4.1 — the generator is untrusted, the cert speaks about the
;;;     ALLOCATED program), and
;;;   - the standard lowered-conformance claim (docs/LOWERING.md §2 at
;;;     the xcall_fn_mem boundary) with its full machine-written proof:
;;;     compute lhs + unfold/ζ-reduce SPEC rhs, then per unique arith
;;;     node a named have citing wrap64_id once + an all-occurrences
;;;     rewrite (the wasm pure fragment's chain, modulus 2^64; bitwise
;;;     nodes are transparent and claim nothing, the §6z discipline;
;;;     premises/helpers/proof from meta/proof's §6j condition-path
;;;     walk at the wrap64 key).
;;;
;;; REGISTER ALLOCATION (the piece wasm never needed): values live in
;;; registers, allocation is STACK-SHAPED — the temp pool is a fixed
;;; register sequence and the walk threads a next-free INDEX exactly the
;;; way the wasm walk threads its next-local counter. Params stay pinned
;;; in their SysV homes (rdi rsi rdx rcx r8 r9 — never written; XBin dst
;;; is always a pool register); the pool is the CALLER-SAVED file first
;;; (rax r10 r11) then the UNUSED argument homes (r9 r8 rcx rdx rsi rdi
;;; as param count permits) — callee-saved registers are never touched,
;;; so a generated piece's clobber story stays SysV-clean by
;;; construction. A binary op materializes its LEFT operand into the
;;; next pool register (two-operand ops destroy dst), takes its RIGHT
;;; operand in place (register or immediate source), and frees
;;; everything above the result. Let bindings hold their register until
;;; scope exit (binding reg = its stack slot). No spills in v1
;;; (docs/X86.md §5): pool exhaustion is a loud refusal.
;;;
;;; THE CONTRACT (lower.shard's): front end is the KERNEL'S by library
;;; import; refuse, don't guess — any body outside the fragment is a
;;; loud per-fn error and exit 1. No ediv/mod (x86 div is a compound
;;; rdx:rax op, a §5 named growth path); at most six Int params.
;;;
;;; TWO WALKS, TWO CONCERNS (the wasm let design, docs/LOWERING.md §6):
;;; code is emitted from the ORIGINAL let tree (sharing preserved — a
;;; binding is computed once into its register); premises/citations come
;;; from the ζ-SUBSTITUTED body (the kernel opens lets by substitution,
;;; so the compute residue's mod-sites are the substituted tree's arith
;;; nodes, deduped by spelling).
;;;
;;; THE KIT: meta/doc (documents) and tools/low/schema.shard
;;; (canonical-expr spelling, binder envs, node sets, type predicates,
;;; binder/arg printers) import UNCHANGED — the front/back split
;;; (docs/LOWERING.md §6ae) doing its job; this file is the x86 BACK
;;; END: the register walk, claim assembly, proof emission, module walk,
;;; and CLI. (tools/wasmgen is the wasm back end, same shape.)
;;;
;;; RUN IT:  bin/shard_eval run tools/x86gen/x86gen.shard SRC OUT.raw
;;;          then shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reader.shard")
(import "../../meta/doc")
(import "../../meta/proof")
(import "../../meta/spell")
(import "../low/schema.shard")
(import "../../meta/shape")

(use (:: kernel loader resolve_closure))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term BVar))
(use (:: kernel term Call))
(use (:: kernel term Let))
(use (:: kernel term If))
(use (:: kernel term IntLit))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term core_named))
(use (:: kernel term append_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module FnTrie))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: kernel reader read_all))
(use (:: kernel reader SExpr))
(use (:: kernel reader is_lib_form))
(use (:: kernel reader lib_of_form))
(use (:: kernel reader Lib))
(use (:: kernel reader is_bin_form))
(use (:: kernel reader bin_of_form))
(use (:: kernel reader Bin))
(use (:: kernel reader SrcEntry))
(use (:: kernel loader int_list_eq))
(use (:: meta doc *))
(use (:: meta proof pw_region))
(use (:: meta proof pw_items))
(use (:: meta proof MkPWR))
(use (:: meta proof WrapK))
(use (:: meta proof MkWrapK))
(use (:: meta spell *))
(use (:: tools low schema *))
(use (:: meta shape RT))
(use (:: meta shape RTv))
(use (:: meta shape RTif))
(use (:: meta shape TRes))
(use (:: meta shape TOk))
(use (:: meta shape TErr))
(use (:: meta shape rt_count))
(use (:: meta shape rt_code))
(use (:: meta shape rt_prepend))
(use (:: meta shape is_bit_op))
(use (:: meta shape nodes_e))
(use (:: meta shape NOk))
(use (:: meta shape NErr))
(use (:: meta shape fn_is_loop))
(use (:: meta shape qn_eq))
(use (:: meta shape lp_recognize))
(use (:: meta shape LROk))
(use (:: meta shape LRCall))
(use (:: meta shape LRErr))
(use (:: meta shape li_recognize))
(use (:: meta shape LIOk))
(use (:: meta shape LIErr))
(use (:: meta shape LStr))
(use (:: meta shape LSStat))
(use (:: meta shape LSInc))
(use (:: meta shape LSDec))
(use (:: meta shape LSIncK))
(use (:: meta shape LVal))
(use (:: meta shape LVAcc))
(use (:: meta shape LVLit))
(use (:: meta shape LVRead))
(use (:: meta shape ls_adv))
(use (:: meta shape ls_at))
(use (:: meta shape LKArg))
(use (:: meta shape LKAcc))
(use (:: meta shape LKLit))
(use (:: meta shape CInfo))
(use (:: meta shape MkCInfo))
(use (:: meta shape reg_find))
(use (:: meta shape reg_add))

;; ---- the register file at the meta level ---------------------------------------
;;
;; Registers are TEXT here (the emitter writes source); the model's Reg
;; ctors are spelled, never constructed.

;; SysV argument home of param k (k < 6, checked at the fn gate)
(fn xhome ((k Int)) Doc
  (if (int_eq k 0) (DStr "RDI")
  (if (int_eq k 1) (DStr "RSI")
  (if (int_eq k 2) (DStr "RDX")
  (if (int_eq k 3) (DStr "RCX")
  (if (int_eq k 4) (DStr "R8")
  (DStr "R9")))))))

;; temp-pool candidates in allocation order, each with the param index
;; that claims it as a home (-1 = never a home). Caller-saved scratch
;; first, then unused argument homes, last-home first.
(fn xcands () (List (Pair (List Int) Int))
  (list
    (Pair "RAX" (- 0 1))
    (Pair "R10" (- 0 1))
    (Pair "R11" (- 0 1))
    (Pair "R9" 5)
    (Pair "R8" 4)
    (Pair "RCX" 3)
    (Pair "RDX" 2)
    (Pair "RSI" 1)
    (Pair "RDI" 0)))

;; the k-th pool register for a fn with n params (None = pool exhausted).
;; Pool slot 0 is ALWAYS rax (the result home) — the root walk relies on
;; it (result index 0 needs no final mov).
(fn xpool_go ((cs (List (Pair (List Int) Int))) (n Int) (k Int))
  (Option (List Int))
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons c t)
     (match c
       ((Pair nm claim)
        (if (if (lt claim 0) True (le n claim))
          (if (int_eq k 0) (Some nm) (xpool_go t n (- k 1)))
          (xpool_go t n k)))))))

(fn xreg_at ((n Int) (k Int)) (Option Doc)
  (match (xpool_go (xcands) n k)
    (None None)
    ((Some nm) (Some (DStr nm)))))

;; ---- instruction and operand spellings ------------------------------------------

(fn xi_movrr ((d Doc) (s Doc)) Doc
  (dconc (list (DStr "(XMovRR ") d (sp) s (DStr ")"))))

(fn xi_movri ((d Doc) (v Int)) Doc
  (dconc (list (DStr "(XMovRI ") d (sp) (dint v) (DStr ")"))))

(fn xi_bin ((o Doc) (d Doc) (s Doc)) Doc
  (dconc (list (DStr "(XBin ") o (sp) d (sp) s (DStr ")"))))

(fn xs_reg ((r Doc)) Doc (dcat3 (DStr "(SReg ") r (DStr ")")))

(fn xs_imm ((v Int)) Doc (dcat3 (DStr "(SImm ") (dint v) (DStr ")")))

;; ---- target vocabulary -----------------------------------------------------------

;; the WRAP ops (xbop_val wraps at 2^64: each node claims a premise pair
;; and a wrap64_id citation)
(fn xbop_of ((q QName)) (Option Doc)
  (if (core_named q (quote +)) (Some (DStr "XAdd"))
  (if (core_named q (quote -)) (Some (DStr "XSub"))
  (if (core_named q (quote *)) (Some (DStr "XMul"))
  None))))

;; the TRANSPARENT bitwise ops (xbop_val applies the prims directly —
;; total, no wrap; no premise, no discharge, docs/LOWERING.md §6z)
(fn xtop_of ((q QName)) (Option Doc)
  (if (core_named q (quote band)) (Some (DStr "XAnd"))
  (if (core_named q (quote bor)) (Some (DStr "XOr"))
  (if (core_named q (quote bxor)) (Some (DStr "XXor"))
  None))))

;; either table
(fn xop_of ((q QName)) (Option Doc)
  (match (xbop_of q)
    ((Some d) (Some d))
    (None (xtop_of q))))

;; ---- the value walk --------------------------------------------------------------

;; operand view of an ATOM: a param reads from its SysV home, a let-bound
;; name from its pool register, a literal is an immediate. XONo = not an
;; atom (evaluate it); XOBad = a loud fragment refusal.
(type XO (XOReg Doc Expr) (XOImm Int Expr) (XONo) (XOBad (List Int)))

(fn xoper ((n Int) (env (List (Pair Expr Int))) (e Expr)) XO
  (match e
    ((BVar i)
     (match (env_at env i)
       ((Some (Pair ce k))
        (match (xreg_at n k)
          ((Some r) (XOReg r ce))
          (None (XOBad "register pool exhausted (no spills in v1)"))))
       (None
         (let ((pos (- (- n 1) (- i (env_len env)))))
           (XOReg (xhome pos) (FVar (xsym pos)))))))
    ((IntLit v)
     (if (le 0 v)
       (if (lt v 2147483648) (XOImm v e)
       (XOBad "literal outside [0, 2^31) (the imm32 fence)"))
       (XOBad "literal outside [0, 2^31) (the imm32 fence)")))
    (_ XONo)))

;; walk result: instr docs (emission order), instr count, next free pool
;; index, RESULT pool index, canonical substituted expr
(type XG (XGOk (List Doc) Int Int Int Expr) (XGErr (List Int)))

;; assemble a binary node once both sides are placed: the canonical node,
;; the ground-subtree gate, the XBin, and the frees (everything above the
;; result index is dead — including any let registers internal to the
;; operands, which are out of scope the moment the node completes).
(fn xg_fin
  ((q QName)
   (cea Expr)
   (ceb Expr)
   (ia (List Doc))
   (ib (List Doc))
   (od Doc)
   (t Doc)
   (src Doc)
   (ca Int)
   (cb Int)
   (ra Int))
  XG
  (let ((ce (Call q (Cons cea (Cons ceb Nil)))))
    (if (has_fv ce)
      (XGOk
        (dapp ia (dapp ib (Cons (xi_bin od t src) Nil)))
        (+ ca (+ cb 1))
        (+ ra 1)
        ra
        ce)
      (XGErr "ground arithmetic subtree (constant-fold it in the source)"))))

;; the walk. Atoms MATERIALIZE (an atom reached here is a left operand, a
;; let rhs, or a let body — all need a register); operand-position atoms
;; are peeled by xoper before recursion.
(fn xg_v ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) XG
  (measure (struct e))
  (match e
    ((BVar i)
     (match (xoper n env e)
       ((XOReg r ce)
        (match (xreg_at n nxt)
          (None (XGErr "register pool exhausted (no spills in v1)"))
          ((Some t) (XGOk (Cons (xi_movrr t r) Nil) 1 (+ nxt 1) nxt ce))))
       ((XOBad m) (XGErr m))
       (_ (XGErr "unbound variable"))))
    ((IntLit v)
     (match (xoper n env e)
       ((XOImm v2 ce)
        (match (xreg_at n nxt)
          (None (XGErr "register pool exhausted (no spills in v1)"))
          ((Some t) (XGOk (Cons (xi_movri t v2) Nil) 1 (+ nxt 1) nxt ce))))
       ((XOBad m) (XGErr m))
       (_ (XGErr "unreachable literal shape"))))
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (match (xop_of q)
          (None
            (XGErr
              "call outside the fragment (only + - * band bor bxor allowed)"))
          ((Some od)
           (match (xg_v n env nxt a)
             ((XGErr m) (XGErr m))
             ((XGOk ia ca nxa ra cea)
              (match (xreg_at n ra)
                (None (XGErr "register pool exhausted (no spills in v1)"))
                ((Some t)
                 (match (xoper n env b)
                   ((XOBad m) (XGErr m))
                   ((XOReg rb ceb)
                    (xg_fin q cea ceb ia Nil od t (xs_reg rb) ca 0 ra))
                   ((XOImm v ceb)
                    (xg_fin q cea ceb ia Nil od t (xs_imm v) ca 0 ra))
                   (XONo
                     (match (xg_v n env nxa b)
                       ((XGErr m) (XGErr m))
                       ((XGOk ib cb nxb rb ceb)
                        (match (xreg_at n rb)
                          (None
                            (XGErr "register pool exhausted (no spills in v1)"))
                          ((Some sr)
                           (xg_fin q cea ceb ia ib od t (xs_reg sr) ca cb ra))))))))))))))
       (_
         (match (xop_of q)
           (None
             (XGErr
               "call outside the fragment (only + - * band bor bxor allowed)"))
           ((Some _) (XGErr "arith call must be binary"))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (xg_v n env nxt rhs)
          ((XGErr m) (XGErr m))
          ((XGOk ir cr nxr rr cer)
           (match (xg_v n (Cons (Pair cer rr) env) nxr body)
             ((XGErr m) (XGErr m))
             ((XGOk ib cb nxb rb ceb) (XGOk (dapp ir ib) (+ cr cb) nxb rb ceb))))))
       (_ (XGErr "let must bind exactly one name (split into nested lets)"))))
    (_ (XGErr "body outside the straight-line fragment"))))

;; the root walk: the result must land in rax. A bare-atom body movs it
;; there directly; a compound body already ends in pool slot 0 (= rax)
;; unless live let bindings pushed it up, in which case one final mov.
(type XT (XTOk (List Doc) Int Expr) (XTErr (List Int)))

(fn xg_t ((n Int) (body Expr)) XT
  (match (xoper n Nil body)
    ((XOBad m) (XTErr m))
    ((XOReg r ce) (XTOk (Cons (xi_movrr (DStr "RAX") r) Nil) 1 ce))
    ((XOImm v ce) (XTOk (Cons (xi_movri (DStr "RAX") v) Nil) 1 ce))
    (XONo
      (match (xg_v n Nil 0 body)
        ((XGErr m) (XTErr m))
        ((XGOk is cnt nx res ce)
         (if (int_eq res 0) (XTOk is cnt ce)
         (match (xreg_at n res)
           (None (XTErr "register pool exhausted (no spills in v1)"))
           ((Some r)
            (XTOk (dapp is (Cons (xi_movrr (DStr "RAX") r) Nil)) (+ cnt 1) ce)))))))))

;; ---- premise nodes: meta/shape's nodes_e (the shared wrap-node collector,
;; is_bit_op transparency — graduated with the x86 loop slice) ----------------------

;; ---- premise and proof emission ---------------------------------------------------
;;
;; Premises, helper claims, and proof text all come from meta/proof's
;; fused condition-path walk (pw_region — the §6j machinery, parametric
;; in the wrap key). This is the x86 instantiation: 2^64 / wrap64_id.
;; Straight-line bodies ride the walk with an empty path (bare premise
;; pairs, wrap events at premise indices — byte-identical to the
;; pre-hygiene form); arm-local nodes get condition-wrapped premises
;; stripped inside their case-on arm, and a bound derivable from a path
;; condition alone emits a generated cb_* helper claim and NO premise.

(fn wk64 () WrapK
  (MkWrapK 18446744073709551616 "18446744073709551616" "wrap64_id"))

;; ---- the if fragment (docs/X86.md §12): tail-position ifs ---------------------
;;
;; `if` lives in TAIL position (the body's result spine after lets, and arm
;; tails — nested ifs and arm-local lets allowed). Conditions are
;; int_eq/lt/le fused into an XBrIf Cond (the §5 design): the LEFT operand
;; is register-resident (a param home or a value binding), the RIGHT a
;; register or immediate; both canonical operands must be a param/alias or
;; literal (a COMPUTED binding wraps into machine state and would not match
;; the spec's case-on scrutinee — refused, as in the wasm fragment).
;;
;; The diamond mirrors wasm's structured-control shape (x86 keeps XBlock/
;; XBrIf/XBr): XBlock[ XBlock[ XBrIf COND 0, ELSE.., XBr 1 ], THEN.. ] with
;; both arms depositing at the if's result register rl. No stack value and
;; no separate cond code — the comparison is fused into the branch, so the
;; x86 diamond is SMALLER than wasm's (which computes b2i on the stack).
;;
;; PROOF: the region tree (shape.shard's RT, reused) mirrors the branch
;; structure; the proof case-ons the source condition, and each arm rewrites
;; the ctor-named case hyp into both sides and computes past the branch
;; (the machine's fused XBrIf test IS the source condition after ground
;; wrap collapse, so no b2i intermediate). Wrap nodes discharge in the
;; region where their code runs, deduped against ancestor regions.
;; Premises are CONDITION-RELATIVE (the §6j hygiene, meta/proof's walk):
;; arm-local nodes carry if-wrapped premises stripped inside their arm,
;; and path-derivable bounds discharge silently via generated cb_*
;; helper claims.

;; source comparison -> the fused Cond ctor
(fn xcmp_cond ((q QName)) (Option Doc)
  (if (core_named q (quote int_eq)) (Some (DStr "CEq"))
  (if (core_named q (quote lt)) (Some (DStr "CLtU"))
  (if (core_named q (quote le)) (Some (DStr "CLeU"))
  None))))

;; a condition -> (Cond doc, canonical condition expr) or None (refuse).
;; Left operand must be register-resident AND a param/alias/literal; right
;; a register or immediate, param/alias/literal.
(fn xcond_of ((n Int) (env (List (Pair Expr Int))) (c Expr))
  (Option (Pair Doc Expr))
  (match c
    ((Call q ops)
     (match (xcmp_cond q)
       (None None)
       ((Some cop)
        (match ops
          ((Cons c1 (Cons c2 Nil))
           (match (xoper n env c1)
             ((XOReg lr ce1)
              (if (cond_operand_ok ce1)
                (match (xoper n env c2)
                  ((XOReg rr ce2)
                   (if (cond_operand_ok ce2)
                     (Some
                       (Pair
                         (dconc
                           (list
                             (DStr "(")
                             cop
                             (sp)
                             lr
                             (DStr " (SReg ")
                             rr
                             (DStr "))")))
                         (Call q (Cons ce1 (Cons ce2 Nil)))))
                     None))
                  ((XOImm v ce2)
                   (Some
                     (Pair
                       (dconc
                         (list
                           (DStr "(")
                           cop
                           (sp)
                           lr
                           (DStr " (SImm ")
                           (dint v)
                           (DStr "))")))
                       (Call q (Cons ce1 (Cons ce2 Nil))))))
                  (_ None))
                None))
             (_ None)))
          (_ None)))))
    (_ None)))

;; the diamond: a single XBlock whose body branches on COND, both arms
;; depositing into the result register (their code already ends with the
;; deposit mov).
(fn xdiamond ((cond Doc) (then_code (List Doc)) (else_code (List Doc)))
  (List Doc)
  (Cons
    (dconc
      (list
        (DStr "(XBlock (list (XBlock (list (XBrIf ")
        cond
        (DStr " 0) ")
        (djoin (dapp else_code (Cons (DStr "(XBr 1)") Nil)))
        (DStr ")) ")
        (djoin then_code)
        (DStr "))")))
    Nil))

;; does this body have a tail-position if (so the region path is needed)?
(fn has_tail_if ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((If _ _ _) True)
    ((Let _ body) (has_tail_if body))
    (_ False)))

;; the region walk: emit e depositing its value at reg(rl), scratch from
;; nxt (nxt > rl), returning a region tree (shape.shard RT). Arms of an if
;; deposit at the SAME rl (the result is the function result path, so rl is
;; stable down the whole tail spine); lets bind below the scratch window.
(fn xg_depo ((n Int) (env (List (Pair Expr Int))) (nxt Int) (rl Int) (e Expr))
  TRes
  (measure (struct e))
  (match e
    ((If c a b)
     (match (xcond_of n env c)
       (None
         (TErr
           "if condition outside the fragment (int_eq/lt/le, register-resident param/alias/literal operands)"))
       ((Some (Pair cdoc ce_c))
        (match (xg_depo n env nxt rl a)
          ((TErr m) (TErr m))
          ((TOk rta)
           (match (xg_depo n env nxt rl b)
             ((TErr m) (TErr m))
             ((TOk rtb)
              (TOk
                (RTif
                  (xdiamond cdoc (rt_code rta) (rt_code rtb))
                  (+ (rt_count rta) (+ (rt_count rtb) 4))
                  rl
                  Nil
                  ce_c
                  rta
                  rtb)))))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (xg_v n env nxt rhs)
          ((XGErr m) (TErr m))
          ((XGOk ir cr nxr rr cer)
           (match (nodes_e cer Nil)
             ((NErr m) (TErr m))
             ((NOk rns)
              (match (xg_depo n (Cons (Pair cer rr) env) nxr rl body)
                ((TErr m) (TErr m))
                ((TOk rt) (TOk (rt_prepend ir cr rns rt)))))))))
       (_ (TErr "let must bind exactly one name (split into nested lets)"))))
    (_
      (match (xoper n env e)
        ((XOBad m) (TErr m))
        ((XOReg r ce)
         (match (xreg_at n rl)
           (None (TErr "register pool exhausted (no spills in v1)"))
           ((Some rd) (TOk (RTv (Cons (xi_movrr rd r) Nil) 1 rl Nil)))))
        ((XOImm v ce)
         (match (xreg_at n rl)
           (None (TErr "register pool exhausted (no spills in v1)"))
           ((Some rd) (TOk (RTv (Cons (xi_movri rd v) Nil) 1 rl Nil)))))
        (XONo
          (match (xg_v n env nxt e)
            ((XGErr m) (TErr m))
            ((XGOk code cnt nx res ce)
             (match (nodes_e ce Nil)
               ((NErr m) (TErr m))
               ((NOk ns)
                (match (xreg_at n rl)
                  (None (TErr "register pool exhausted (no spills in v1)"))
                  ((Some rd)
                   (match (xreg_at n res)
                     (None (TErr "register pool exhausted (no spills in v1)"))
                     ((Some rs)
                      (TOk
                        (RTv
                          (dapp code (Cons (xi_movrr rd rs) Nil))
                          (+ cnt 1)
                          rl
                          ns)))))))))))))))

;; ---- claim assembly ---------------------------------------------------------------

(type XCR (XCOk Doc) (XCErr (List Int)))

(fn xerr_at ((q QName) (m (List Int))) XCR
  (XCErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))

;; position-general prefix printers (LIB mode, docs/X86.md §19): pfx
;; quantified (fN XFunc) binders before the claim's own literal, so the
;; cert holds at its PINNED index inside any module extension. pfx=0 is
;; the old single-function form byte-for-byte.
(fn xpr_fbinds ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "")
  (DCat
    (xpr_fbinds (- k 1))
    (dcat3 (DStr "(f") (dint (- k 1)) (DStr " XFunc) ")))))

(fn xpr_fcons ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "")
  (DCat (xpr_fcons (- k 1)) (dcat3 (DStr "(Cons f") (dint (- k 1)) (DStr " ")))))

(fn xpr_rpars ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "") (DCat (xpr_rpars (- k 1)) (DStr ")"))))

;; the shared claim skeleton: goal binders + premises + the module literal
;; (the own function at pinned index pfx, quantified prefix functions
;; before it, restfs after, no memory) + the spec RHS + the proof body,
;; which begins with compute lhs / unfold + ζ-reduce rhs.
(fn xg_emit_claim
  ((q QName)
   (ts (List Type))
   (code (List Doc))
   (prems Doc)
   (fuel Int)
   (proofbody Doc)
   (pfx Int))
  Doc
  (dconc
    (list
      (DStr "(claim lowered_")
      (dsym (qn_name q))
      (DStr " (goal (")
      (pr_binds ts 0)
      (xpr_fbinds pfx)
      (DStr "(c Nat) (restfs (List XFunc)) (mem Mem)) (")
      prems
      (DStr ") (= (xcall_fn_mem (S^ ")
      (dint fuel)
      (DStr " c) (MkXModule ")
      (xpr_fcons pfx)
      (DStr "(Cons (MkXFunc ")
      (dint (count_ts ts))
      (DStr " (list ")
      (djoin code)
      (DStr ")) restfs)")
      (xpr_rpars pfx)
      (DStr " 0 0) ")
      (dint pfx)
      (DStr " (list ")
      (pr_args ts 0)
      (DStr ") mem) (Some (Pair (")
      (dsym (qn_name q))
      (pr_args_lead ts)
      (DStr ") mem)))) (chain (steps ((compute lhs) (unfold ")
      (dsym (qn_name q))
      (DStr " rhs) (reduce rhs))) ")
      proofbody
      (DStr "))")
      (DStr (nl)))))

;; run the condition-path walk over the region tree and assemble: any
;; generated cb_* helper claims land BEFORE the lowered claim
(fn xg_finish ((q QName) (ts (List Type)) (rt RT) (fuel Int) (pfx Int)) XCR
  (match (pw_region rt Nil Nil (dsym (qn_name q)) (wk64) 0 0 0)
    ((MkPWR proof_body prems helpers _ _ _)
     (XCOk
       (DCat
         helpers
         (xg_emit_claim q ts (rt_code rt) prems fuel proof_body pfx))))))

;; the if path: build the region tree (result at rl=0=rax, scratch reserved
;; from index 1) and hand it to the walk. Fuel is generously
;; over-provisioned — additive slack absorbs the excess.
(fn xg_claim_if ((q QName) (ts (List Type)) (body Expr) (pfx Int)) XCR
  (match (xg_depo (count_ts ts) Nil 1 0 body)
    ((TErr m) (xerr_at q m))
    ((TOk rt) (xg_finish q ts rt (+ (* 2 (rt_count rt)) 10) pfx))))

(fn fn_is_mem ((f FnDef)) Bool
  (match f
    ((FnDef _ ts _ _)
     (match ts
       ((Cons t0 _) (is_mem_ty t0))
       (Nil False)))))

(fn xg_claim ((f FnDef) (pfx Int)) XCR
  (if (fn_is_loop f) (xg_claim_loop f (xw_hlo) (xw_hhi))
  (if (fn_is_mem f) (xg_claim_mem f (xw_hlo) (xw_hhi))
  (match f
    ((FnDef q ts rty body)
     (if (all_int ts)
       (if (is_int_ty rty)
         (if (le (count_ts ts) 6)
           (if (has_tail_if body) (xg_claim_if q ts body pfx)
           (match (xg_t (count_ts ts) body)
             ((XTErr m) (xerr_at q m))
             ((XTOk code cnt ce)
              (match (nodes_e ce Nil)
                ((NErr m) (xerr_at q m))
                ((NOk ns) (xg_finish q ts (RTv code cnt 0 ns) (+ cnt 4) pfx))))))
           (xerr_at
             q
             "more than six Int params (SysV register homes only in v1)"))
         (xerr_at q "return type is not Int"))
       (xerr_at q "params are not all Int")))))))

;; ---- the loop fragment (docs/X86.md §14): Nat-counted store loops --------------
;;
;; Source shape (meta/shape's SHARED recognizers — wasm's §6f family):
;;   (fn NAME ((m Mem) (x0 Int) … (xn-1 Int) (k Nat)) Mem
;;     (match k (Z m) ((S k2) (NAME (mem_set m ADDR VAL) U0 … Un-1 k2))))
;; v1 = the probed article (examples/x86_pieces.shard stage 2): ONE store
;; per iteration, strides +1/static, store value an accum or an imm32
;; literal. Refused with named growth: two-store nests (the reverse
;; slice), byte-read values (copy needs a scratch-register closed form),
;; stride != 1 and decrementing accums, calls-in-loops (inter-function
;; layout).
;;
;; Machine shape: params stay in their SysV homes for the WHOLE loop —
;; the counter's home is the loop counter, advancing accums are bumped
;; IN PLACE by two-operand adds (no local shuffle: 4+nadv instructions
;; vs wasm's 8+stlen+4nadv). The claims mirror the hand play verbatim:
;; worker xlgw_* by induction on k against the folded xeval_loop term
;; (register state as concrete MkRegs literals, exit accums via the
;; xlg_adv closed form), theorem lowered_* = the entry spine (+4) plus
;; the worker by citation; the kit facts are models/x86/loopkit's.

;; Regs-field owner: which param slot's SysV home is record field f
;; (field order rax rcx rdx rbx rbp rsi rdi r8 r9 r10..r15; -1 = none)
(fn xslot_of ((f Int)) Int
  (if (int_eq f 6) 0
  (if (int_eq f 5) 1
  (if (int_eq f 2) 2
  (if (int_eq f 1) 3
  (if (int_eq f 7) 4
  (if (int_eq f 8) 5
  (- 0 1))))))))

;; one ENTRY-record field: accums in their homes, the counter home reads
;; (int_of_nat k), every other field 0
(fn xl_entryf ((n Int) (f Int)) Doc
  (let ((s (xslot_of f)))
    (if (lt s 0) (DStr "0")
    (if (int_eq s n) (DStr "(int_of_nat k)")
    (if (lt s n) (DCat (DStr "x") (dint s))
    (DStr "0"))))))

;; one EXIT-record field: advancing accums at the xlg_adv closed form,
;; static accums unchanged, the counter (and everything else) 0
(fn xl_exitf ((n Int) (adv (List LStr)) (f Int)) Doc
  (let ((s (xslot_of f)))
    (if (lt s 0) (DStr "0")
    (if (int_eq s n) (DStr "0")
    (if (lt s n)
      (if (ls_adv (ls_at adv s))
        (dconc (list (DStr "(xlg_adv x") (dint s) (DStr " k)")))
        (DCat (DStr "x") (dint s)))
      (DStr "0"))))))

(fn xl_rf ((n Int) (adv (List LStr)) (exitp Bool) (f Int)) Doc
  (if exitp (xl_exitf n adv f) (xl_entryf n f)))

;; the full 15-field record literal
(fn xl_regs ((n Int) (adv (List LStr)) (exitp Bool)) Doc
  (dconc
    (list
      (DStr "(MkRegs ")
      (xl_rf n adv exitp 0)
      (sp)
      (xl_rf n adv exitp 1)
      (sp)
      (xl_rf n adv exitp 2)
      (sp)
      (xl_rf n adv exitp 3)
      (sp)
      (xl_rf n adv exitp 4)
      (sp)
      (xl_rf n adv exitp 5)
      (sp)
      (xl_rf n adv exitp 6)
      (sp)
      (xl_rf n adv exitp 7)
      (sp)
      (xl_rf n adv exitp 8)
      (sp)
      (xl_rf n adv exitp 9)
      (sp)
      (xl_rf n adv exitp 10)
      (sp)
      (xl_rf n adv exitp 11)
      (sp)
      (xl_rf n adv exitp 12)
      (sp)
      (xl_rf n adv exitp 13)
      (sp)
      (xl_rf n adv exitp 14)
      (DStr ")"))))

;; ---- loop codegen -----------------------------------------------------------------

;; store value operand (v1: accum home or imm32 literal)
(fn xlv_src ((v LVal)) (Option Doc)
  (match v
    ((LVAcc j) (Some (xs_reg (xhome j))))
    ((LVLit l) (if (lt l 2147483648) (Some (xs_imm l)) None))
    ((LVRead _) None)))

(fn xl_advcode ((adv (List LStr)) (i Int)) (List Doc)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t)
     (match h
       ((LSInc)
        (Cons
          (xi_bin (DStr "XAdd") (xhome i) (xs_imm 1))
          (xl_advcode t (+ i 1))))
       (_ (xl_advcode t (+ i 1)))))))

;; guard / the store / advances / counter decrement / re-enter
;; (instrs = 4 + nadv)
(fn xl_code ((n Int) (adv (List LStr)) (ai Int) (vsrc Doc)) (List Doc)
  (dapp
    (list
      (dconc (list (DStr "(XBrIf (CEqz ") (xhome n) (DStr ") 1)")))
      (dconc
        (list (DStr "(XStore8 (AReg ") (xhome ai) (DStr ") ") vsrc (DStr ")"))))
    (dapp
      (xl_advcode adv 0)
      (list (xi_bin (DStr "XSub") (xhome n) (xs_imm 1)) (DStr "(XBr 0)")))))

;; ---- loop claim assembly ------------------------------------------------------------

(fn xl_nadv ((bs (List LStr))) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (+ (if (ls_adv h) 1 0) (xl_nadv t)))))

;; number of advancing accums among the first i (= accum i's group-A
;; premise index)
(fn xl_advpos ((bs (List LStr)) (i Int)) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t)
     (if (int_eq i 0) 0 (+ (if (ls_adv h) 1 0) (xl_advpos t (- i 1)))))))

;; the first INCREMENTING accum — the counter wrap (xlg_kM) rides its
;; premise pair, so every loop needs one (v1 fence)
(fn xl_first_inc ((bs (List LStr)) (i Int)) (Option Int)
  (measure (struct bs))
  (match bs
    (Nil None)
    ((Cons h t)
     (match h
       ((LSInc) (Some i))
       (_ (xl_first_inc t (+ i 1)))))))

(fn xl_strides_ok ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil True)
    ((Cons h t)
     (match h
       ((LSDec) False)
       ((LSIncK _) False)
       (_ (xl_strides_ok t))))))

;; the HARNESS window the fragment claims pin (X86.md §23): the CPU
;; differential harness maps [0, 65536) at DATA_BASE and the §15 range
;; dispensation identifies model addresses with window offsets. The bin
;; route passes its own window instead ([BUF, BUF+4096), the A1 rung).
(fn xw_hlo () Int 0)
(fn xw_hhi () Int 65536)

;; group-A premises, param order: one lower bound per advancing accum
(fn xl_prems_lo ((bs (List LStr)) (wl Int) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (dconc
           (list
             (DStr "(= (le ")
             (dint wl)
             (DStr " x")
             (dint i)
             (DStr ") True) ")))
         (DStr ""))
       (xl_prems_lo t wl (+ i 1))))))

;; group-B premises, param order: one range per advancing accum
(fn xl_prems_rng ((bs (List LStr)) (wh Int) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (dconc
           (list
             (DStr "(= (le (+ x")
             (dint i)
             (DStr " (int_of_nat k)) ")
             (dint wh)
             (DStr ") True) ")))
         (DStr ""))
       (xl_prems_rng t wh (+ i 1))))))

;; the SELF literal as spelled in claims ((inline …) rides the body fn)
(fn xl_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkXFunc ")
      (dint (+ n 1))
      (DStr " (list (XBlock (list (XLoop (inline ")
      nm
      (DStr "_body))))))"))))

;; the store-address stage: premise-rewrite the nonneg guard, cite
;; xlg_a1_ms for the upper guard, compute on
(fn xl_stage ((pa Int) (pb Int)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop xeval_loop xlg_fuel)) (rewrite (premise ")
      (dint pa)
      (DStr
        ") lr lhs true ()) (compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint pb)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; counter collapse + counter wrap (xlg_kM at the first inc accum's pair)
(fn xl_hwk ((fa Int) (pa Int) (pb Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma xlg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 18446744073709551616) (int_of_nat k2)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma xlg_kM) lr lhs ((inst a x")
      (dint fa)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint pb)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise ")
      (dint pa)
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; one advancing accum's advance wrap: (mod (+ xi 1) 2^64) collapses via
;; wrap64_id off xlg_lo1 + xlg_64/xlg_a1_ms at its premise pair
(fn xl_hw1 ((i Int) (j Int) (pa Int) (pb Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint j)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " 1) 18446744073709551616) (+ x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise ")
      (dint pa)
      (DStr
        ") lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_64) lr lhs () ((rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint pb)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint j)
      (DStr ") lr lhs true ()))) "))))

;; advance wraps, param order (ordinal j names hw0, hw1, …)
(fn xl_hws ((adv (List LStr)) (i Int) (j Int) (na Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h) (DCat (xl_hw1 i j j (+ na j)) (xl_hws t (+ i 1) (+ j 1) na))
     (xl_hws t (+ i 1) j na)))))

;; the IH's group-A discharges: xlg_lo1 per advancing accum
(fn xl_lo1s ((adv (List LStr)) (p Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h)
       (DCat
         (dconc
           (list
             (DStr
               "(rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl)) refl) ")))
         (xl_lo1s t (+ p 1)))
       (xl_lo1s t p)))))

;; the IH's group-B discharges: xlg_shift per advancing accum
(fn xl_shifts ((adv (List LStr)) (p Int) (na Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h)
       (DCat
         (dconc
           (list
             (DStr
               "(rewrite-with (lemma xlg_shift) lr lhs () ((steps ((rewrite (premise ")
             (dint (+ na p))
             (DStr
               ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
         (xl_shifts t (+ p 1) na))
       (xl_shifts t p na)))))

;; pass-through premise steps (theorem -> worker), one per premise
(fn xl_pass1 ((bs (List LStr)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h)
       (DCat
         (dconc
           (list
             (DStr "(steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl) ")))
         (xl_pass1 t (+ p 1)))
       (xl_pass1 t p)))))

;; the loop worker: induction on k against the folded xeval_loop term —
;; the hand play (examples/x86_pieces.shard xlgw_fill) parametrized
(fn xl_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ai Int)
   (fa Int)
   (p Int)
   (wl Int)
   (wh Int))
  Doc
  (let ((na (xl_nadv adv)))
    (dconc
      (list
        (DStr "(claim xlgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) (")
        (xl_prems_lo adv wl 0)
        (xl_prems_rng adv wh 0)
        (DStr ") (= (xeval_loop (S^ ")
        (dint p)
        (DStr " (xlg_fuel k c)) (MkXModule (Cons ")
        (xl_self nm n)
        (DStr " restfs) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr ") (inline ")
        nm
        (DStr "_body) ")
        (xl_regs n adv False)
        (DStr " m0) (Some (XBrk 0 ")
        (xl_regs n adv True)
        (DStr " (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold xlg_fuel lhs) (reduce lhs) (unfold xeval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
        (xl_stage (xl_advpos adv ai) (+ na (xl_advpos adv ai)))
        (DStr "(steps ((compute lhs (stop xeval_loop xlg_fuel)))) ")
        (xl_hwk fa (xl_advpos adv fa) (+ na (xl_advpos adv fa)))
        (xl_hws adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr
          " rhs) (unfold xlg_adv rhs) (reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
        (xl_lo1s adv 0)
        (xl_shifts adv 0 na)
        (DStr ")) (steps ((compute both))) refl)))))")
        (DStr (nl))))))

;; the piece theorem: entry spine (outer seq / XBlock / inner seq /
;; XLoop = +4 over the worker), then the worker by citation
(fn xl_thm
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (p4 Int)
   (wl Int)
   (wh Int))
  Doc
  (let ((na (xl_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) (")
        (xl_prems_lo adv wl 0)
        (xl_prems_rng adv wh 0)
        (DStr ") (= (xcall_fn_mem (S^ ")
        (dint p4)
        (DStr " (xlg_fuel k c)) (MkXModule (Cons ")
        (xl_self nm n)
        (DStr " restfs) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr ") 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlgw_")
        nm
        (DStr ") lr lhs () (")
        (xl_pass1 adv 0)
        (xl_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + worker + theorem, one unit per source fn
(fn xl_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ai Int)
   (vsrc Doc)
   (fa Int)
   (p Int)
   (wl Int)
   (wh Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List XInstr) (list ")
      (djoin (xl_code n adv ai vsrc))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () XFunc (MkXFunc ")
      (dint (+ n 1))
      (DStr " (list (XBlock (list (XLoop (")
      nm
      (DStr "_body)))))))")
      (DStr (nl))
      (xl_worker nm mids n adv ai fa p wl wh)
      (xl_thm nm mids n adv (+ p 4) wl wh))))

;; ---- the Int-return SUM loop (bytesum; probe examples/xintloop_probe) ----------
;;
;; (fn NAME ((m Mem) (p Int) (a Int) (k Nat)) Int
;;   (match k (Z a) ((S k2) (NAME m (+ p 1) (+ a (mem_get m p)) k2))))
;; — the LIOk shape of meta/shape's li_recognize (wasm's §6ab twin). v1
;; pins the probe exactly: two accums, the advancing address first, the
;; sum second (reading the address's OLD value — load+add precede the
;; advances). The load target is a REGISTER, so the worker closes rax
;; over models/x86/loopkit's xlg_last and QUANTIFIES the entry rax (ra);
;; the piece's epilogue XMovRR RAX RSI overwrites the residue with the
;; sum. The sum accum rides the k-scaled wrap invariant
;; (le (+ a (* 256 k)) 2^64) — xlg_sum_lo/xlg_sum_64/xlg_sum_shift.

;; the module literal: [the epilogue'd loop func | restfs], self at 0
(fn xli_mod ((nm Doc) (wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr "(MkXModule (Cons (MkXFunc 3 (list (XBlock (list (XLoop (inline ")
      nm
      (DStr "_body)))) (XMovRR RAX RSI))) restfs) ")
      (dint wl)
      (sp)
      (dint wh)
      (DStr ")"))))

;; the shared premise text: window pair on the address, nonneg + the
;; k-scaled wrap invariant on the sum
(fn xli_prems ((wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr "((= (le ")
      (dint wl)
      (DStr " x0) True) (= (le 0 x1) True) (= (le (+ x0 (int_of_nat k)) ")
      (dint wh)
      (DStr
        ") True) (= (le (+ x1 (* 256 (int_of_nat k))) 18446744073709551616) True))"))))

;; body + func + worker induction + lowered theorem (the probe
;; templated; fuel 10/14 probe-validated)
(fn xli_unit ((q QName) (mids (List Type)) (wl Int) (wh Int)) Doc
  (let ((nm (dsym (qn_name q))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr
          "_body () (List XInstr) (list (XBrIf (CEqz RDX) 1) (XLoad8 RAX (AReg RDI)) (XBin XAdd RSI (SReg RAX)) (XBin XAdd RDI (SImm 1)) (XBin XSub RDX (SImm 1)) (XBr 0)))")
        (DStr (nl))
        (DStr "(fn ")
        nm
        (DStr "_func () XFunc (MkXFunc 3 (list (XBlock (list (XLoop (")
        nm
        (DStr "_body)))) (XMovRR RAX RSI))))")
        (DStr (nl))
        (DStr "(claim xliw_")
        nm
        (DStr " (goal ((ra Int) ")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ")
        (xli_prems wl wh)
        (DStr " (= (xeval_loop (S^ 10 (xlg_fuel k c)) ")
        (xli_mod nm wl wh)
        (DStr " (inline ")
        nm
        (DStr
          "_body) (MkRegs ra 0 (int_of_nat k) 0 0 x1 x0 0 0 0 0 0 0 0 0) m0) (Some (XBrk 0 (MkRegs (xlg_last m0 x0 ra k) 0 0 0 0 (")
        nm
        (DStr
          " m0 x0 x1 k) (xlg_adv x0 k) 0 0 0 0 0 0 0 0) m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold xlg_fuel lhs) (reduce lhs) (unfold xeval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop xeval_loop xlg_fuel)) (rewrite (premise 0) lr lhs true ()) (compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma xlg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 18446744073709551616) (int_of_nat k2)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma xlg_kM) lr lhs ((inst a x0) (inst c k2)) ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise 0) lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) (have hw0 (= (mod (+ x0 1) 18446744073709551616) (+ x0 1)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (+ x0 1))) ((rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_64) lr lhs () ((rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw0) lr lhs true ()))) (have hwa (= (mod (+ x1 (mem_get m0 x0)) 18446744073709551616) (+ x1 (mem_get m0 x0))) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (+ x1 (mem_get m0 x0)))) ((rewrite-with (lemma xlg_sum_lo) lr lhs () ((steps ((rewrite (premise 1) lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) (rewrite-with (lemma xlg_sum_64) lr lhs ((inst c k2)) ((steps ((rewrite (premise 3) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) (steps ((rewrite (premise hwa) lr lhs true ()))) (steps ((unfold ")
        nm
        (DStr
          " rhs) (unfold xlg_adv rhs) (unfold xlg_last rhs) (reduce rhs))) (rewrite-with (hyp 0) lr lhs () ((rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_sum_lo) lr lhs () ((steps ((rewrite (premise 1) lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) (rewrite-with (lemma xlg_shift) lr lhs () ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_sum_shift) lr lhs () ((steps ((rewrite (premise 3) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl)) refl))) (steps ((compute both))) refl)))))")
        (DStr (nl))
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ")
        (xli_prems wl wh)
        (DStr " (= (xcall_fn_mem (S^ 14 (xlg_fuel k c)) ")
        (xli_mod nm wl wh)
        (DStr " 0 (list x0 x1 (int_of_nat k)) m0) (Some (Pair (")
        nm
        (DStr
          " m0 x0 x1 k) m0)))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xliw_")
        nm
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (premise 3) lr lhs true ())) refl))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; the loop-fn gate: param slicing + the shared recognizer + v1 fences
(fn xg_claim_loop ((f FnDef) (wl Int) (wh Int)) XCR
  (match f
    ((FnDef q ts rty body)
     (match ts
       ((Cons _ rest)
        (match (ts_lasto rest)
          ((Some lt2)
           (if (is_nat_ty lt2)
             (let ((mids (ts_mids rest)))
               (if (all_int mids)
                 (let ((n (count_ts mids)))
                   (if (lt 0 n)
                     (if (le n 5)
                       (if (is_mem_ty rty)
                         (match (lp_recognize q n body Nil)
                           ((LRErr m) (xerr_at q m))
                           ((LRCall _ _ _)
                            (xerr_at
                              q
                              "internal: LRCall loops route through xg_claim_loop_r"))
                           ((LROk adv sts)
                            (if (xl_strides_ok adv)
                              (match sts
                                ((Cons (Pair ai v) Nil)
                                 (match (xlv_src v)
                                   (None
                                     (xerr_at
                                       q
                                       "store value must be an accum or an imm32 literal (byte-read values follow the copy slice)"))
                                   ((Some vsrc)
                                    (match (xl_first_inc adv 0)
                                      (None
                                        (xerr_at
                                          q
                                          "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                                      ((Some fa)
                                       (XCOk
                                         (xl_unit
                                           (dsym (qn_name q))
                                           mids
                                           n
                                           adv
                                           ai
                                           vsrc
                                           fa
                                           (+ (+ 4 (xl_nadv adv)) 4)
                                           wl
                                           wh)))))))
                                (_
                                  (xerr_at
                                    q
                                    "two-store nests follow the reverse slice (v1: one store per iteration)")))
                              (xerr_at
                                q
                                "v1 strides are +1 or static (decrementing and stride-K accums are named growth)"))))
                       (if (is_int_ty rty)
                         (match (li_recognize q n body)
                           ((LIErr m) (xerr_at q m))
                           ((LIOk adv r j)
                            (if (int_eq n 2)
                              (if (int_eq r 1)
                                (if (int_eq j 0)
                                  (match adv
                                    ((Cons (LSInc) (Cons (LSStat) Nil))
                                     (XCOk (xli_unit q mids wl wh)))
                                    (_
                                      (xerr_at
                                        q
                                        "v1 Int-return loop: the address accumulator advances +1, the sum rides (named growth)")))
                                  (xerr_at
                                    q
                                    "v1 Int-return loop: the summed read's address must be accumulator 0"))
                                (xerr_at
                                  q
                                  "v1 Int-return loop: the sum accumulator must be accumulator 1 (the returned one)"))
                              (xerr_at
                                q
                                "v1 Int-return loop needs exactly two Int accumulators (address, sum)")))
                           (_
                             (xerr_at
                               q
                               "scan/flag Int-return loop shapes are named growth (v1: the sum shape)")))
                         (xerr_at q "loop fn must return Mem or Int")))
                       (xerr_at
                         q
                         "more than five accumulators (SysV register homes only)"))
                     (xerr_at q "loop fn needs at least one Int accumulator")))
                 (xerr_at q "loop accumulators must all be Int")))
             (xerr_at q "loop fn's last param must be the Nat counter")))
          (None (xerr_at q "loop fn needs (m Mem) (accums Int...) (k Nat)"))))
       (Nil (xerr_at q "loop fn needs params"))))))

;; ---- the mem fragment (docs/X86.md §15): reads/stores through std/mem ----------
;;
;; Source fns `(fn NAME ((m Mem) (p0 Int) … (pn-1 Int)) RTY BODY)` whose
;; bodies read/write bytes lower to XCalls against std/mem's x86 artifact
;; functions (mem.x86.shard: get at module index 0, set at 1, the caller
;; at 2). The proofs COMPOSE BY CITATION — each call's run premise is
;; discharged by the callee's clobber-set cert through xcall_bridge, the
;; callee body never computed into (the §10 keystone, xmemcall_probe the
;; design article). v1 (matching the probe): one read or one store; the
;; address is a param, the read wrapped in one arith node against a
;; literal, the stored value a param. Everything else is a loud fence.
;;
;; Params park at the prologue into r10, r11 (caller-saved, preserved by
;; the callees), freeing rdi/rsi as marshalling scratch; ≤2 params in v1
;; (r12+ are callee-saved, a spill-class growth). The emitter re-emits
;; std/mem's two callee literals into the output (same-file inline; the
;; callee certs guarantee the copies match by value or fail gate 3).

;; param index of a body BVar (env-empty, mem outermost): pos = n-1-i;
;; the mem param is BVar n
(fn xm_pidx ((e Expr) (n Int)) (Option Int)
  (match e
    ((BVar i)
     (if (int_eq i n) None (if (le 0 (- (- n 1) i)) (Some (- (- n 1) i)) None)))
    (_ None)))

(fn xm_is_mem ((e Expr) (n Int)) Bool
  (match e
    ((BVar i) (int_eq i n))
    (_ False)))

;; parked register of param k (r10, r11 in v1)
(fn xm_park ((k Int)) (Option Doc)
  (if (int_eq k 0) (Some (DStr "R10"))
  (if (int_eq k 1) (Some (DStr "R11"))
  None)))

;; the prologue: park p0..pn-1 into r10.. (structural over the param types)
(fn xm_prologue ((ts (List Type)) (i Int)) (List Doc)
  (measure (struct ts))
  (match ts
    (Nil Nil)
    ((Cons _ t)
     (match (xm_park i)
       (None Nil)
       ((Some pr) (Cons (xi_movrr pr (xhome i)) (xm_prologue t (+ i 1))))))))

;; the value spelling of param k (the claim's x{k})
(fn xm_xk ((k Int)) Doc (dsym (xsym k)))

;; a parked-register field value for the MkRegs literal: x{k} if k < n,
;; else 0 (r10 = param 0, r11 = param 1)
(fn xm_parkval ((slot Int) (n Int)) Doc
  (if (lt slot n) (xm_xk slot) (DStr "0")))

;; the 15-field register literal at a call site: rax/rsi given, rdi the
;; marshalled address x{a}, r10/r11 the parked params, all else 0
(fn xm_regs ((raxd Doc) (rsid Doc) (a Int) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkRegs ")
      raxd
      (DStr " 0 0 0 0 ")
      rsid
      (sp)
      (xm_xk a)
      (DStr " 0 0 ")
      (xm_parkval 0 n)
      (sp)
      (xm_parkval 1 n)
      (DStr " 0 0 0 0)"))))

;; the two callee literal copies (same-file inline sources)
(fn xm_callee_fns () Doc
  (dconc
    (list
      (DStr
        "(fn xg_mget_f () XFunc (MkXFunc 1 (list (XLoad8 RAX (AReg RDI)))))")
      (DStr (nl))
      (DStr
        "(fn xg_mset_f () XFunc (MkXFunc 2 (list (XStore8 (AReg RDI) (SReg RSI)))))")
      (DStr (nl)))))

;; the shared module-literal prefix: [get, set, caller-body, restfs]
(fn xm_modpfx ((n Int) (body (List Doc)) (wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr
        "(MkXModule (Cons (inline xg_mget_f) (Cons (inline xg_mset_f) (Cons (MkXFunc ")
      (dint n)
      (DStr " (list ")
      (djoin body)
      (DStr ")) restfs))) ")
      (dint wl)
      (sp)
      (dint wh)
      (DStr ")"))))

;; ---- read fragment: (OP (mem_get m p_a) LIT) -----------------------------------

;; recognize the v1 read body; returns (address param, XBin op doc, spec
;; op QName, literal)
(type XMR (XMROk Int Doc QName Int) (XMRNo))

(fn xm_read ((body Expr) (n Int)) XMR
  (match body
    ((Call q as)
     (match (xbop_of q)
       (None XMRNo)
       ((Some od)
        (match as
          ((Cons ge (Cons (IntLit l) Nil))
           (if (le 0 l)
             (if (lt l 2147483648)
               (match ge
                 ((Call gq gas)
                  (if (memq_named gq (quote mem_get))
                    (match gas
                      ((Cons marg (Cons aarg Nil))
                       (if (xm_is_mem marg n)
                         (match (xm_pidx aarg n)
                           ((Some a) (XMROk a od q l))
                           (None XMRNo))
                         XMRNo))
                      (_ XMRNo))
                    XMRNo))
                 (_ XMRNo))
               XMRNo)
             XMRNo))
          (_ XMRNo)))))
    (_ XMRNo)))

;; the source arith op as spec text (+ / - / *)
(fn xm_opsym ((q QName)) Doc
  (if (core_named q (quote +)) (DStr "+")
  (if (core_named q (quote -)) (DStr "-")
  (DStr "*"))))

;; the spec call spelling: (NAME m0 x0 x1 …) — the concl RHS the proof
;; opens by unfold+reduce (the machine residue meets it there)
(fn xm_spec ((nm Doc) (mids (List Type))) Doc
  (dconc (list (DStr "(") nm (DStr " m0") (pr_args_lead mids) (DStr ")"))))

;; the read piece: park, marshal the address, call get, arith on the byte
(fn xm_read_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (a Int)
   (od Doc)
   (q QName)
   (l Int)
   (wl Int)
   (wh Int))
  Doc
  (let ((rd (dcat3 (DStr "(mem_get m0 ") (xm_xk a) (DStr ")"))))
    (let
      ((node
         (dconc
           (list (DStr "(") (xm_opsym q) (sp) rd (DStr " ") (dint l) (DStr ")")))))
      (dconc
        (list
          (DStr "(fn ")
          nm
          (DStr "_body () (List XInstr) (list ")
          (djoin
            (dapp
              (xm_prologue mids 0)
              (dapp
                (match (xm_park a)
                  ((Some pr) (Cons (xi_movrr (DStr "RDI") pr) Nil))
                  (None Nil))
                (list (DStr "(XCall 0)") (xi_bin od (DStr "RAX") (xs_imm l))))))
          (DStr "))")
          (DStr (nl))
          (DStr "(claim lowered_")
          nm
          (DStr " (goal (")
          (pr_binds mids 0)
          (DStr "(m0 Mem) (c Nat) (restfs (List XFunc))) (")
          (DStr "(= (le ")
          (dint wl)
          (DStr " ")
          (xm_xk a)
          (DStr ") True) (= (le (+ ")
          (xm_xk a)
          (DStr " 1) ")
          (dint wh)
          (DStr ") True) (= (le 0 ")
          node
          (DStr ") True) (= (lt ")
          node
          (DStr " 18446744073709551616) True)) (= (xcall_fn_mem (S^ 12 c) ")
          (xm_modpfx
            n
            (dapp
              (xm_prologue mids 0)
              (dapp
                (match (xm_park a)
                  ((Some pr) (Cons (xi_movrr (DStr "RDI") pr) Nil))
                  (None Nil))
                (list (DStr "(XCall 0)") (xi_bin od (DStr "RAX") (xs_imm l)))))
            wl
            wh)
          (DStr " 2 (list ")
          (pr_args mids 0)
          (DStr ") m0) (Some (Pair ")
          (xm_spec nm mids)
          (DStr
            " m0)))) (chain (steps ((compute lhs (stop xeval_call)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline xg_mget_f)) (inst rs2 ")
          (xm_regs rd (DStr "0") a n)
          (DStr
            ") (inst mem2 m0)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xmget_cert) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((compute lhs (stop mem_get)))) (have w0 (= (mod ")
          node
          (DStr " 18446744073709551616) ")
          node
          (DStr ") (rewrite-with (lemma wrap64_id) lr lhs ((inst x ")
          node
          (DStr
            ")) ((steps ((rewrite (premise 2) lr lhs true ())) refl) (steps ((rewrite (premise 3) lr lhs true ())) refl)) refl)) (steps ((rewrite (premise w0) lr lhs true ()))) (steps ((unfold ")
          nm
          (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
          (DStr (nl)))))))

;; ---- store fragment: (mem_set m p_a p_v) ---------------------------------------

(type XMS (XMSOk Int Int) (XMSNo))

(fn xm_store ((body Expr) (n Int)) XMS
  (match body
    ((Call q as)
     (if (memq_named q (quote mem_set))
       (match as
         ((Cons marg (Cons aarg (Cons varg Nil)))
          (if (xm_is_mem marg n)
            (match (xm_pidx aarg n)
              ((Some a)
               (match (xm_pidx varg n)
                 ((Some v) (XMSOk a v))
                 (None XMSNo)))
              (None XMSNo))
            XMSNo))
         (_ XMSNo))
       XMSNo))
    (_ XMSNo)))

;; HOME-ALIGNED fast path (docs/X86.md §18): a store at (param0, param1)
;; finds its args already sitting in mset's marshalling homes — the body
;; is the call alone, no parking, no marshalling, clobber ∅. This is
;; what makes such fns callable from loops with zero state bookkeeping.
(fn xm_aligned ((a Int) (v Int)) Bool (if (int_eq a 0) (int_eq v 1) False))

(fn xm_store_unit
  ((nm Doc) (mids (List Type)) (n Int) (a Int) (v Int) (wl Int) (wh Int))
  Doc
  (let
    ((mvcode
       (if (xm_aligned a v) (list (DStr "(XCall 1)"))
       (dapp
         (xm_prologue mids 0)
         (dapp
           (match (xm_park a)
             ((Some pr) (Cons (xi_movrr (DStr "RDI") pr) Nil))
             (None Nil))
           (dapp
             (match (xm_park v)
               ((Some pr) (Cons (xi_movrr (DStr "RSI") pr) Nil))
               (None Nil))
             (list (DStr "(XCall 1)"))))))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr "_body () (List XInstr) (list ")
        (djoin mvcode)
        (DStr "))")
        (DStr (nl))
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (restfs (List XFunc))) (")
        (DStr "(= (le ")
        (dint wl)
        (DStr " ")
        (xm_xk a)
        (DStr ") True) (= (le (+ ")
        (xm_xk a)
        (DStr " 1) ")
        (dint wh)
        (DStr ") True)) (= (xcall_fn_mem (S^ 12 c) ")
        (xm_modpfx n mvcode wl wh)
        (DStr " 2 (list ")
        (pr_args mids 0)
        (DStr ") m0) (Some (Pair 0 ")
        (xm_spec nm mids)
        (DStr
          ")))) (chain (steps ((compute lhs (stop xeval_call)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline xg_mset_f)) (inst rs2 ")
        (if (xm_aligned a v)
          (dconc
            (list
              (DStr "(MkRegs 0 0 0 0 0 ")
              (xm_xk 1)
              (sp)
              (xm_xk 0)
              (DStr " 0 0 0 0 0 0 0 0)")))
          (xm_regs (DStr "0") (xm_xk v) a n))
        (DStr ") (inst mem2 (mem_set m0 ")
        (xm_xk a)
        (sp)
        (xm_xk v)
        (DStr
          "))) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xmset_cert) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((unfold ")
        nm
        (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; the mem-fn gate: param slicing + shape recognition + v1 fences
(fn xg_claim_mem ((f FnDef) (wl Int) (wh Int)) XCR
  (match f
    ((FnDef q ts rty body)
     (match ts
       ((Cons _ rest)
        (if (all_int rest)
          (let ((n (count_ts rest)))
            (if (lt 0 n)
              (if (le n 2)
                (if (is_int_ty rty)
                  (match (xm_read body n)
                    ((XMROk a od sq l)
                     (XCOk
                       (xm_read_unit (dsym (qn_name q)) rest n a od sq l wl wh)))
                    (XMRNo
                      (xerr_at
                        q
                        "Int-return mem body must be (OP (mem_get m p) LIT) — one read, one arith node (v1)")))
                (if (is_mem_ty rty)
                  (match (xm_store body n)
                    ((XMSOk a v)
                     (XCOk (xm_store_unit (dsym (qn_name q)) rest n a v wl wh)))
                    (XMSNo
                      (xerr_at
                        q
                        "Mem-return mem body must be (mem_set m p v) — one store, param address and value (v1)")))
                  (xerr_at q "mem fn must return Int or Mem")))
                (xerr_at
                  q
                  "more than two Int params (v1 parks into r10/r11 only)"))
              (xerr_at q "mem fn needs at least one Int param")))
          (xerr_at q "mem fn params must all be Int")))
       (Nil (xerr_at q "mem fn needs params"))))))

;; ---- the call fragment (docs/X86.md §16): sibling calls through GENERATED
;; clobber-set certs -----------------------------------------------------------------
;;
;; A source fn whose body calls an EARLIER fn of the same file lowers to
;; marshalling + XCall against that sibling's generated function literal,
;; and the emitter also generates the sibling's §10 CLOBBER-SET cert
;; (xcert_* — all fifteen register fields quantified, the result record
;; literal reading off as the clobber set). The caller's proof composes
;; by citation exactly like the mem fragment: each call's run premise
;; discharges by the generated cert through xcall_bridge, the callee
;; body never computed into (xsibcall_probe.shard = the hand-play).
;;
;; v1 fences (loud, named growth): the callee is arity-1 Int->Int with a
;; LEFT-SPINE body (right operands are params/literals, so the whole body
;; writes only rax — clobber {rax} by construction, no per-register value
;; tracking); the caller body is (F a) or (OP (F a) (F b)) against ONE
;; callee, args params or imm32 literals, <=2 caller params (parked
;; r10/r11, the mem fragment's convention); callers are not themselves
;; callable (no cert is generated for a fn containing calls). A two-call
;; body evaluates the RIGHT call first and parks its result in rcx across
;; the left call — justified purely by the cert (rcx passes through
;; verbatim).

;; find a sibling fn by name among the already-processed defs
(fn xc_find ((seen (List FnDef)) (q QName)) (Option FnDef)
  (measure (struct seen))
  (match seen
    (Nil None)
    ((Cons f t)
     (match f
       ((FnDef q2 _ _ _) (if (qn_eq q2 q) (Some f) (xc_find t q)))))))

;; the head of a call expr, if it names a sibling
(fn xc_sib_of ((e Expr) (seen (List FnDef))) (Option FnDef)
  (match e
    ((Call q _) (xc_find seen q))
    (_ None)))

;; dispatch: Some callee if the body is call-shaped at the top level —
;; a bare sibling call, or a binary arith node with a sibling call as
;; either operand (deeper sibling calls fall to the pure path's refusal)
(fn xc_target ((body Expr) (seen (List FnDef))) (Option FnDef)
  (match (xc_sib_of body seen)
    ((Some f) (Some f))
    (None
      (match body
        ((Call q as)
         (match as
           ((Cons l (Cons r Nil))
            (match (xop_of q)
              (None None)
              ((Some _)
               (match (xc_sib_of l seen)
                 ((Some f) (Some f))
                 (None (xc_sib_of r seen))))))
           (_ None)))
        (_ None)))))

;; the certed registry (docs/X86.md §17): per emitted cert, HOW the
;; callee composes — a LEAF (left-spine body, clobber {rax}) or a MID (a
;; §16 caller shape certed by the chain form, clobber {rax, rcx, r10}).
;; The kind carries what a consumer needs: bodies for spellings and
;; inlining, the mid's combining op and leaf, and the cert's fuel tower.
(type CK
  (CKLeaf Expr Int)
  (CKM1 Symbol Expr Int)
  (CKM2 QName Symbol Expr Int)
  (CKMem))

(fn ck_find ((cs (List (Pair Symbol CK))) (s Symbol)) (Option CK)
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons h t)
     (match h
       ((Pair nm k) (if (sym_eq nm s) (Some k) (ck_find t s)))))))

;; the callee's effective body (BVar 0 = its param), leaf-inlined
(fn ck_eff ((k CK)) Expr
  (match k
    ((CKLeaf b _) b)
    ((CKM1 _ lb _) lb)
    ((CKM2 op _ lb _) (Call op (Cons lb (Cons lb Nil))))))

;; the callee cert's fuel tower
(fn ck_fuel ((k CK)) Int
  (match k
    ((CKLeaf _ cnt) (+ cnt 1))
    ((CKM1 _ _ fk) fk)
    ((CKM2 _ _ _ fk) fk)))

;; ---- the callee walk: left-spine bodies, rax-only ---------------------------------

;; operand source of a callee-body atom (arity n, env empty): a param
;; reads its SysV home, a literal is an immediate
(fn xcb_atom_src ((e Expr) (n Int)) (Option Doc)
  (match e
    ((BVar i)
     (let ((pos (- (- n 1) i)))
       (if (le 0 pos) (if (lt pos n) (Some (xs_reg (xhome pos))) None) None)))
    ((IntLit v)
     (if (le 0 v) (if (lt v 2147483648) (Some (xs_imm v)) None) None))
    (_ None)))

;; materialize the spine head into rax
(fn xcb_head ((e Expr) (n Int)) (Option Doc)
  (match e
    ((BVar i)
     (let ((pos (- (- n 1) i)))
       (if (le 0 pos)
         (if (lt pos n) (Some (xi_movrr (DStr "RAX") (xhome pos))) None)
         None)))
    ((IntLit v)
     (if (le 0 v) (if (lt v 2147483648) (Some (xi_movri (DStr "RAX") v)) None)
     None))
    (_ None)))

;; the left-spine walk: head materializes into rax, every node is a
;; two-operand op on rax with an atom right operand
(type XCB (XCBOk (List Doc) Int) (XCBNo (List Int)))

(fn xcb_code ((e Expr) (n Int)) XCB
  (measure (struct e))
  (match e
    ((Call q as)
     (match as
       ((Cons l (Cons r Nil))
        (match (xop_of q)
          (None
            (XCBNo
              "callee body op outside the fragment (only + - * band bor bxor)"))
          ((Some od)
           (match (xcb_atom_src r n)
             (None
               (XCBNo
                 "callee body must be left-spine: right operands are params or imm32 literals (v1)"))
             ((Some src)
              (match (xcb_code l n)
                ((XCBNo m) (XCBNo m))
                ((XCBOk is cnt)
                 (XCBOk
                   (dapp is (Cons (xi_bin od (DStr "RAX") src) Nil))
                   (+ cnt 1)))))))))
       (_ (XCBNo "callee arith call must be binary"))))
    (_
      (match (xcb_head e n)
        ((Some i) (XCBOk (Cons i Nil) 1))
        (None
          (XCBNo
            "callee body atom outside the fragment (param or imm32 literal)"))))))

;; the callee body with its (single) param substituted — the caller's
;; effective inlined expr and the source of its wrap nodes
(fn xcb_inline ((e Expr) (arg Expr)) Expr
  (measure (struct e))
  (match e
    ((BVar _) arg)
    ((Call q (Cons l (Cons r Nil)))
     (Call q (Cons (xcb_inline l arg) (Cons (xcb_inline r arg) Nil))))
    (_ e)))

;; the source arith op symbol (spec-side spelling)
(fn xc_opsym ((q QName)) Doc
  (if (core_named q (quote +)) (DStr "+")
  (if (core_named q (quote -)) (DStr "-")
  (if (core_named q (quote *)) (DStr "*")
  (if (core_named q (quote band)) (DStr "band")
  (if (core_named q (quote bor)) (DStr "bor")
  (DStr "bxor")))))))

;; the honest postorder wrap spelling of a left-spine body with the param
;; spelled as argd (rdi for the cert, the marshalled value for an rs2).
;; Total: shapes outside the validated fragment spell as 0 — the
;; generator is untrusted, a wrong spelling fails the cert at check time.
(fn xcb_spell ((e Expr) (argd Doc)) Doc
  (measure (struct e))
  (match e
    ((BVar _) argd)
    ((IntLit v) (dint v))
    ((Call q (Cons l (Cons r Nil)))
     (let
       ((nd
          (dconc
            (list
              (DStr "(")
              (xc_opsym q)
              (sp)
              (xcb_spell l argd)
              (sp)
              (xcb_spell r argd)
              (DStr ")")))))
       (match (xbop_of q)
         ((Some _) (dcat3 (DStr "(wrap64 ") nd (DStr ")")))
         (None nd))))
    (_ (DStr "0"))))

;; ---- callee cert emission ---------------------------------------------------------

(fn xc_gfname ((q QName)) Doc (DCat (DStr "xgf_") (dsym (qn_name q))))

(fn xc_certname ((q QName)) Doc (DCat (DStr "xcert_") (dsym (qn_name q))))

(fn xc_gfsym ((s Symbol)) Doc (DCat (DStr "xgf_") (dsym s)))

;; module-literal spine helpers: one (Cons (inline xgf_S) … per element,
;; the matching closers, and the caller's entry index (= spine length)
(fn xc_mpfx ((spine (List Symbol))) Doc
  (measure (struct spine))
  (match spine
    (Nil (DStr ""))
    ((Cons s t)
     (DCat
       (dconc (list (DStr "(Cons (inline ") (xc_gfsym s) (DStr ") ")))
       (xc_mpfx t)))))

(fn xc_mclose ((spine (List Symbol))) Doc
  (measure (struct spine))
  (match spine
    (Nil (DStr ""))
    ((Cons _ t) (DCat (DStr ")") (xc_mclose t)))))

(fn xc_slen ((spine (List Symbol))) Int
  (measure (struct spine))
  (match spine
    (Nil 0)
    ((Cons _ t) (+ 1 (xc_slen t)))))

;; the named function literal + the §10 clobber-set cert: callee at
;; module index 0 (restfs and the window quantified — the cert applies inside
;; any extension), all fifteen fields quantified, result rax = the wrap
;; spelling over the entry home, the other fourteen verbatim
(fn xc_callee_doc ((cq QName) (ccode (List Doc)) (ccnt Int) (cbody Expr)) Doc
  (dconc
    (list
      (DStr "(fn ")
      (xc_gfname cq)
      (DStr " () XFunc (MkXFunc 1 (list ")
      (djoin ccode)
      (DStr ")))")
      (DStr (nl))
      (DStr "(claim ")
      (xc_certname cq)
      (DStr
        " (goal ((c Nat) (restfs (List XFunc)) (mlo Int) (mhi Int) (mem Mem) (rax Int) (rcx Int) (rdx Int) (rbx Int) (rbp Int) (rsi Int) (rdi Int) (r8 Int) (r9 Int) (r10 Int) (r11 Int) (r12 Int) (r13 Int) (r14 Int) (r15 Int)) () (= (xrun_regs (S^ ")
      (dint (+ ccnt 1))
      (DStr " c) (MkXModule (Cons (inline ")
      (xc_gfname cq)
      (DStr
        ") restfs) mlo mhi) 0 (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) mem) (Some (Pair (MkRegs ")
      (xcb_spell cbody (DStr "rdi"))
      (DStr
        " rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) mem)))) (steps ((compute both)) refl))")
      (DStr (nl)))))

;; ---- caller assembly ----------------------------------------------------------------

;; a call argument: canonical expr, value spelling, marshalling instr
(type XCA (XCAOk Expr Doc Doc) (XCANo))

(fn xc_arg ((e Expr) (n Int)) XCA
  (match e
    ((BVar i)
     (let ((pos (- (- n 1) i)))
       (if (le 0 pos)
         (if (lt pos n)
           (match (xm_park pos)
             ((Some pr)
              (XCAOk (FVar (xsym pos)) (xm_xk pos) (xi_movrr (DStr "RDI") pr)))
             (None XCANo))
           XCANo)
         XCANo)))
    ((IntLit v)
     (if (le 0 v)
       (if (lt v 2147483648) (XCAOk e (dint v) (xi_movri (DStr "RDI") v)) XCANo)
       XCANo))
    (_ XCANo)))

;; the 15-field register literal at a call site: rax/rcx/rdi given, rsi
;; the surviving entry value of param 1, r10/r11 the parked params
(fn xc_regs ((raxd Doc) (rcxd Doc) (rdid Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkRegs ")
      raxd
      (sp)
      rcxd
      (DStr " 0 0 0 ")
      (xm_parkval 1 n)
      (sp)
      rdid
      (DStr " 0 0 ")
      (xm_parkval 0 n)
      (sp)
      (xm_parkval 1 n)
      (DStr " 0 0 0 0)"))))

;; one bridge: stop at the fold, rewrite by xcall_bridge, discharge the
;; run premise by the generated cert (no cert premises — pure callee)
(fn xc_bridge ((cq QName) (rs2 Doc)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop xeval_call)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline ")
      (xc_gfname cq)
      (DStr ")) (inst rs2 ")
      rs2
      (DStr
        ") (inst mem2 mem)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma ")
      (xc_certname cq)
      (DStr ") lr lhs () ()) (steps ((compute both))) refl)))"))))

;; the caller claim: multi-fn module literal (the callee SPINE below the
;; caller, caller = the entry at spine length), bridges first, then the
;; standard wrap chain over the INLINED effective body, then the spec
;; RHS opens (the closing compute both also opens the transparent
;; callee spec calls)
(fn xc_unit
  ((q QName)
   (ts (List Type))
   (spine (List Symbol))
   (code (List Doc))
   (fuel Int)
   (prems Doc)
   (pf Doc)
   (bridges Doc))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      (dsym (qn_name q))
      (DStr "_body () (List XInstr) (list ")
      (djoin code)
      (DStr "))")
      (DStr (nl))
      (DStr "(claim lowered_")
      (dsym (qn_name q))
      (DStr " (goal (")
      (pr_binds ts 0)
      (DStr "(c Nat) (restfs (List XFunc)) (mem Mem)) (")
      prems
      (DStr ") (= (xcall_fn_mem (S^ ")
      (dint fuel)
      (DStr " c) (MkXModule ")
      (xc_mpfx spine)
      (DStr "(Cons (MkXFunc ")
      (dint (count_ts ts))
      (DStr " (list ")
      (djoin code)
      (DStr ")) restfs)")
      (xc_mclose spine)
      (DStr " 0 0) ")
      (dint (xc_slen spine))
      (DStr " (list ")
      (pr_args ts 0)
      (DStr ") mem) (Some (Pair (")
      (dsym (qn_name q))
      (pr_args_lead ts)
      (DStr ") mem)))) (chain ")
      bridges
      (DStr " (steps ((compute lhs))) ")
      pf
      (DStr " (steps ((unfold ")
      (dsym (qn_name q))
      (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
      (DStr (nl)))))

;; single call: park, marshal, call — the result is already in rax
(fn xc_single
  ((q QName) (ts (List Type)) (cq QName) (cbody Expr) (ccnt Int) (a Expr))
  XCR
  (let ((n (count_ts ts)))
    (match (xc_arg a n)
      (XCANo
        (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
      ((XCAOk ace avald marshal)
       (match (nodes_e (xcb_inline cbody ace) Nil)
         ((NErr m) (xerr_at q m))
         ((NOk ns)
          (match (pw_items ns Nil Nil (dsym (qn_name q)) (wk64) 0 0 0)
            ((Pair (MkPWR pf prems _ _ _ _) _)
             (let
               ((code
                  (dapp
                    (xm_prologue ts 0)
                    (Cons marshal (Cons (DStr "(XCall 0)") Nil)))))
               (XCOk
                 (xc_unit
                   q
                   ts
                   (Cons (qn_name cq) Nil)
                   code
                   (+ (+ n 2) (+ ccnt 8))
                   prems
                   pf
                   (xc_bridge
                     cq
                     (xc_regs (xcb_spell cbody avald) (DStr "0") avald n)))))))))))))

;; two calls, one callee: evaluate the RIGHT call first, park its result
;; in rcx across the left call, combine on the result home
(fn xc_two
  ((q QName)
   (ts (List Type))
   (cq QName)
   (cbody Expr)
   (ccnt Int)
   (opq QName)
   (od Doc)
   (al Expr)
   (ar Expr))
  XCR
  (let ((n (count_ts ts)))
    (match (xc_arg al n)
      (XCANo
        (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
      ((XCAOk alce alvald marshall)
       (match (xc_arg ar n)
         (XCANo
           (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
         ((XCAOk arce arvald marshalr)
          (match
            (nodes_e
              (Call
                opq
                (Cons
                  (xcb_inline cbody alce)
                  (Cons (xcb_inline cbody arce) Nil)))
              Nil)
            ((NErr m) (xerr_at q m))
            ((NOk ns)
             (match (pw_items ns Nil Nil (dsym (qn_name q)) (wk64) 0 0 0)
               ((Pair (MkPWR pf prems _ _ _ _) _)
                (let
                  ((code
                     (dapp
                       (xm_prologue ts 0)
                       (list
                         marshalr
                         (DStr "(XCall 0)")
                         (xi_movrr (DStr "RCX") (DStr "RAX"))
                         marshall
                         (DStr "(XCall 0)")
                         (xi_bin od (DStr "RAX") (xs_reg (DStr "RCX")))))))
                  (let
                    ((bridges
                       (DCat
                         (xc_bridge
                           cq
                           (xc_regs
                             (xcb_spell cbody arvald)
                             (DStr "0")
                             arvald
                             n))
                         (DCat
                           (sp)
                           (xc_bridge
                             cq
                             (xc_regs
                               (xcb_spell cbody alvald)
                               (xcb_spell cbody arvald)
                               alvald
                               n))))))
                    (XCOk
                      (xc_unit
                        q
                        ts
                        (Cons (qn_name cq) Nil)
                        code
                        (+ (+ n 4) (+ (* 2 (+ ccnt 2)) 6))
                        prems
                        pf
                        bridges))))))))))))))

;; shape dispatch over the caller body (LEAF callee)
(fn xc_shape
  ((q QName) (ts (List Type)) (cq QName) (cbody Expr) (ccnt Int) (body Expr))
  XCR
  (match body
    ((Call q1 as)
     (if (qn_eq q1 cq)
       (match as
         ((Cons a Nil) (xc_single q ts cq cbody ccnt a))
         (_ (xerr_at q "callee call must have exactly one argument (v1)")))
       (match (xop_of q1)
         (None (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)"))
         ((Some od)
          (match as
            ((Cons (Call ql (Cons al Nil)) (Cons (Call qr (Cons ar Nil)) Nil))
             (if (qn_eq ql cq)
               (if (qn_eq qr cq) (xc_two q ts cq cbody ccnt q1 od al ar)
               (xerr_at q "both calls must target the same callee (v1)"))
               (xerr_at q "both calls must target the same callee (v1)")))
            (_ (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)")))))))
    (_ (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)"))))

;; ---- the chain tier (docs/X86.md §17): callers of MIDS ------------------------------
;;
;; A mid clobbers {rax, rcx, r10} (its stash and park), so its callers
;; park in r8/r9 and stash in rdx — the complement of the callee's cert
;; clobber set (the clobber set steering regalloc). Module spines nest:
;; [leaf, mid, caller | restfs], entry 2, XCall 1.

(fn xt_park ((k Int)) (Option Doc)
  (if (int_eq k 0) (Some (DStr "R8")) (if (int_eq k 1) (Some (DStr "R9")) None)))

(fn xt_prologue ((ts (List Type)) (i Int)) (List Doc)
  (measure (struct ts))
  (match ts
    (Nil Nil)
    ((Cons _ t)
     (match (xt_park i)
       (None Nil)
       ((Some pr) (Cons (xi_movrr pr (xhome i)) (xt_prologue t (+ i 1))))))))

;; a call argument vs a MID callee (parks are r8/r9)
(fn xt_arg ((e Expr) (n Int)) XCA
  (match e
    ((BVar i)
     (let ((pos (- (- n 1) i)))
       (if (le 0 pos)
         (if (lt pos n)
           (match (xt_park pos)
             ((Some pr)
              (XCAOk (FVar (xsym pos)) (xm_xk pos) (xi_movrr (DStr "RDI") pr)))
             (None XCANo))
           XCANo)
         XCANo)))
    ((IntLit v)
     (if (le 0 v)
       (if (lt v 2147483648) (XCAOk e (dint v) (xi_movri (DStr "RDI") v)) XCANo)
       XCANo))
    (_ XCANo)))

;; call-site register literal vs a MID callee: rax/rcx carry the mid's
;; result and parked-leaf clobbers, rdx the outer stash, r10 the mid's
;; park clobber (= that call's argument), r8/r9 the outer parks
(fn xt_regs ((raxd Doc) (rcxd Doc) (rdxd Doc) (rdid Doc) (r10d Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkRegs ")
      raxd
      (sp)
      rcxd
      (sp)
      rdxd
      (DStr " 0 0 ")
      (xm_parkval 1 n)
      (sp)
      rdid
      (sp)
      (xm_parkval 0 n)
      (sp)
      (xm_parkval 1 n)
      (sp)
      r10d
      (DStr " 0 0 0 0 0)"))))

;; the mid's rcx clobber spelling at an argument (the parked right-call
;; leaf result), or the entry value for a single-call mid
(fn xt_rcx ((k CK) (argd Doc) (entry Doc)) Doc
  (match k
    ((CKM2 _ _ lb _) (xcb_spell lb argd))
    (_ entry)))

;; the mid's own §16 caller code at arity 1 (park r10, marshal, calls) —
;; the same instruction list its lowered claim spelled
(fn xt_midcode ((k CK)) (List Doc)
  (match k
    ((CKM2 op _ _ _)
     (match (xop_of op)
       ((Some od)
        (list
          (xi_movrr (DStr "R10") (DStr "RDI"))
          (xi_movrr (DStr "RDI") (DStr "R10"))
          (DStr "(XCall 0)")
          (xi_movrr (DStr "RCX") (DStr "RAX"))
          (xi_movrr (DStr "RDI") (DStr "R10"))
          (DStr "(XCall 0)")
          (xi_bin od (DStr "RAX") (xs_reg (DStr "RCX")))))
       (None Nil)))
    (_
      (list
        (xi_movrr (DStr "R10") (DStr "RDI"))
        (xi_movrr (DStr "RDI") (DStr "R10"))
        (DStr "(XCall 0)")))))

;; the symbolic-entry register literal inside a MID's own cert proof:
;; r10 = rdi (post-park), rax/rcx as given, the rest the quantified names
(fn xt_sregs ((raxd Doc) (rcxd Doc)) Doc
  (dconc
    (list
      (DStr "(MkRegs ")
      raxd
      (sp)
      rcxd
      (DStr " rdx rbx rbp rsi rdi r8 r9 rdi r11 r12 r13 r14 r15)"))))

;; one bridge citing a LEAF cert by symbol (inside a mid's cert proof)
(fn xt_bridge_s ((ls Symbol) (rs2 Doc)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop xeval_call)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline ")
      (xc_gfsym ls)
      (DStr ")) (inst rs2 ")
      rs2
      (DStr
        ") (inst mem2 mem)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert_")
      (dsym ls)
      (DStr ") lr lhs () ()) (steps ((compute both))) refl)))"))))

;; the mid's named function literal + its chain cert (the §17 form): mid
;; at module index 1 under its leaf, proof BY BRIDGES at symbolic entry
;; registers, result rax = the leaf-inlined wrap spelling, rcx the
;; parked leaf result (two-call), r10 the entry argument
(fn xt_cert_doc ((cq QName) (k CK)) Doc
  (match k
    ((CKLeaf _ _) (DStr ""))
    ((CKM1 ls lb fk)
     (dconc
       (list
         (DStr "(fn ")
         (xc_gfname cq)
         (DStr " () XFunc (MkXFunc 1 (list ")
         (djoin (xt_midcode k))
         (DStr ")))")
         (DStr (nl))
         (DStr "(claim ")
         (xc_certname cq)
         (DStr
           " (goal ((c Nat) (restfs (List XFunc)) (mlo Int) (mhi Int) (mem Mem) (rax Int) (rcx Int) (rdx Int) (rbx Int) (rbp Int) (rsi Int) (rdi Int) (r8 Int) (r9 Int) (r10 Int) (r11 Int) (r12 Int) (r13 Int) (r14 Int) (r15 Int)) () (= (xrun_regs (S^ ")
         (dint fk)
         (DStr " c) (MkXModule (Cons (inline ")
         (xc_gfsym ls)
         (DStr ") (Cons (inline ")
         (xc_gfname cq)
         (DStr
           ") restfs)) mlo mhi) 1 (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) mem) (Some (Pair (MkRegs ")
         (xcb_spell lb (DStr "rdi"))
         (DStr
           " rcx rdx rbx rbp rsi rdi r8 r9 rdi r11 r12 r13 r14 r15) mem)))) (chain ")
         (xt_bridge_s ls (xt_sregs (xcb_spell lb (DStr "rdi")) (DStr "rcx")))
         (DStr " (steps ((compute both))) refl))")
         (DStr (nl)))))
    ((CKM2 op ls lb fk)
     (dconc
       (list
         (DStr "(fn ")
         (xc_gfname cq)
         (DStr " () XFunc (MkXFunc 1 (list ")
         (djoin (xt_midcode k))
         (DStr ")))")
         (DStr (nl))
         (DStr "(claim ")
         (xc_certname cq)
         (DStr
           " (goal ((c Nat) (restfs (List XFunc)) (mlo Int) (mhi Int) (mem Mem) (rax Int) (rcx Int) (rdx Int) (rbx Int) (rbp Int) (rsi Int) (rdi Int) (r8 Int) (r9 Int) (r10 Int) (r11 Int) (r12 Int) (r13 Int) (r14 Int) (r15 Int)) () (= (xrun_regs (S^ ")
         (dint fk)
         (DStr " c) (MkXModule (Cons (inline ")
         (xc_gfsym ls)
         (DStr ") (Cons (inline ")
         (xc_gfname cq)
         (DStr
           ") restfs)) mlo mhi) 1 (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) mem) (Some (Pair (MkRegs ")
         (xcb_spell (ck_eff k) (DStr "rdi"))
         (sp)
         (xcb_spell lb (DStr "rdi"))
         (DStr
           " rdx rbx rbp rsi rdi r8 r9 rdi r11 r12 r13 r14 r15) mem)))) (chain ")
         (xt_bridge_s ls (xt_sregs (xcb_spell lb (DStr "rdi")) (DStr "rcx")))
         (sp)
         (xt_bridge_s
           ls
           (xt_sregs (xcb_spell lb (DStr "rdi")) (xcb_spell lb (DStr "rdi"))))
         (DStr " (steps ((compute both))) refl))")
         (DStr (nl)))))))

;; single call to a MID: park r8.., marshal, XCall 1
(fn xt_single
  ((q QName) (ts (List Type)) (cq QName) (k CK) (ls Symbol) (a Expr))
  XCR
  (let ((n (count_ts ts)))
    (match (xt_arg a n)
      (XCANo
        (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
      ((XCAOk ace avald marshal)
       (match (nodes_e (xcb_inline (ck_eff k) ace) Nil)
         ((NErr m) (xerr_at q m))
         ((NOk ns)
          (match (pw_items ns Nil Nil (dsym (qn_name q)) (wk64) 0 0 0)
            ((Pair (MkPWR pf prems _ _ _ _) _)
             (let
               ((code
                  (dapp
                    (xt_prologue ts 0)
                    (Cons marshal (Cons (DStr "(XCall 1)") Nil)))))
               (XCOk
                 (xc_unit
                   q
                   ts
                   (Cons ls (Cons (qn_name cq) Nil))
                   code
                   (+ (+ n 2) (+ (ck_fuel k) 8))
                   prems
                   pf
                   (xc_bridge
                     cq
                     (xt_regs
                       (xcb_spell (ck_eff k) avald)
                       (xt_rcx k avald (DStr "0"))
                       (DStr "0")
                       avald
                       avald
                       n)))))))))))))

;; two calls to a MID: right call first, stash rdx, combine
(fn xt_two
  ((q QName)
   (ts (List Type))
   (cq QName)
   (k CK)
   (ls Symbol)
   (opq QName)
   (od Doc)
   (al Expr)
   (ar Expr))
  XCR
  (let ((n (count_ts ts)))
    (match (xt_arg al n)
      (XCANo
        (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
      ((XCAOk alce alvald marshall)
       (match (xt_arg ar n)
         (XCANo
           (xerr_at q "call argument must be a param or an imm32 literal (v1)"))
         ((XCAOk arce arvald marshalr)
          (match
            (nodes_e
              (Call
                opq
                (Cons
                  (xcb_inline (ck_eff k) alce)
                  (Cons (xcb_inline (ck_eff k) arce) Nil)))
              Nil)
            ((NErr m) (xerr_at q m))
            ((NOk ns)
             (match (pw_items ns Nil Nil (dsym (qn_name q)) (wk64) 0 0 0)
               ((Pair (MkPWR pf prems _ _ _ _) _)
                (let
                  ((code
                     (dapp
                       (xt_prologue ts 0)
                       (list
                         marshalr
                         (DStr "(XCall 1)")
                         (xi_movrr (DStr "RDX") (DStr "RAX"))
                         marshall
                         (DStr "(XCall 1)")
                         (xi_bin od (DStr "RAX") (xs_reg (DStr "RDX")))))))
                  (let
                    ((bridges
                       (DCat
                         (xc_bridge
                           cq
                           (xt_regs
                             (xcb_spell (ck_eff k) arvald)
                             (xt_rcx k arvald (DStr "0"))
                             (DStr "0")
                             arvald
                             arvald
                             n))
                         (DCat
                           (sp)
                           (xc_bridge
                             cq
                             (xt_regs
                               (xcb_spell (ck_eff k) alvald)
                               (xt_rcx k alvald (DStr "0"))
                               (xcb_spell (ck_eff k) arvald)
                               alvald
                               alvald
                               n))))))
                    (XCOk
                      (xc_unit
                        q
                        ts
                        (Cons ls (Cons (qn_name cq) Nil))
                        code
                        (+ (+ n 4) (+ (* 2 (+ (ck_fuel k) 2)) 6))
                        prems
                        pf
                        bridges))))))))))))))

;; shape dispatch over the caller body (MID callee)
(fn xt_shape
  ((q QName) (ts (List Type)) (cq QName) (k CK) (ls Symbol) (body Expr))
  XCR
  (match body
    ((Call q1 as)
     (if (qn_eq q1 cq)
       (match as
         ((Cons a Nil) (xt_single q ts cq k ls a))
         (_ (xerr_at q "callee call must have exactly one argument (v1)")))
       (match (xop_of q1)
         (None (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)"))
         ((Some od)
          (match as
            ((Cons (Call ql (Cons al Nil)) (Cons (Call qr (Cons ar Nil)) Nil))
             (if (qn_eq ql cq)
               (if (qn_eq qr cq) (xt_two q ts cq k ls q1 od al ar)
               (xerr_at q "both calls must target the same callee (v1)"))
               (xerr_at q "both calls must target the same callee (v1)")))
            (_ (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)")))))))
    (_ (xerr_at q "call body must be (F a) or (OP (F a) (F b)) (v1)"))))

;; caller dispatch on the callee's kind
(fn xc_go ((q QName) (ts (List Type)) (cq QName) (k CK) (body Expr)) XCR
  (match k
    ((CKLeaf cbody ccnt) (xc_shape q ts cq cbody ccnt body))
    ((CKM1 ls _ _) (xt_shape q ts cq k ls body))
    ((CKM2 _ ls _ _) (xt_shape q ts cq k ls body))
    ((CKMem) (xerr_at q "a mem callee is callable only from loops (v1)"))))

;; classify an unregistered callee: a LEAF (left-spine) or a v1 MID (a
;; §16 caller shape over an already-certed LEAF — depth 2)
(fn xt_classify ((cbody Expr) (certed (List (Pair Symbol CK)))) (Option CK)
  (match cbody
    ((Call q1 as)
     (match as
       ((Cons (BVar _) Nil)
        (match (ck_find certed (qn_name q1))
          ((Some (CKLeaf lb lcnt))
           (Some (CKM1 (qn_name q1) lb (+ (+ lcnt 1) 11))))
          (_ None)))
       ((Cons
          (Call ql (Cons (BVar _) Nil))
          (Cons (Call qr (Cons (BVar _) Nil)) Nil))
        (match (xop_of q1)
          (None None)
          ((Some _)
           (if (qn_eq ql qr)
             (match (ck_find certed (qn_name ql))
               ((Some (CKLeaf lb lcnt))
                (Some (CKM2 q1 (qn_name ql) lb (+ (* 2 (+ lcnt 4)) 13))))
               (_ None))
             None))))
       (_ None)))
    (_ None)))

;; classify + build the new callee's cert doc
(type XTN (XTNOk CK Doc) (XTNErr (List Int)))

(fn xt_new ((q QName) (cq QName) (cbody Expr) (certed (List (Pair Symbol CK))))
  XTN
  (match (xcb_code cbody 1)
    ((XCBOk ccode ccnt)
     (XTNOk (CKLeaf cbody ccnt) (xc_callee_doc cq ccode ccnt cbody)))
    ((XCBNo lm)
     (match (xt_classify cbody certed)
       ((Some k) (XTNOk k (xt_cert_doc cq k)))
       (None
         (XTNErr
           (append_int
             lm
             "; nor a v1 mid shape ((L x) / (OP (L x) (L x)) over a certed leaf, depth 2)")))))))

;; the call-fn gate: caller fences, callee fences, registry lookup or a
;; new cert, then the shape. Returns the doc AND the updated registry.
(type XCC (XCCOk Doc (List (Pair Symbol CK))) (XCCErr (List Int)))

(fn xcc_of ((r XCR) (certed (List (Pair Symbol CK)))) XCC
  (match r
    ((XCErr m) (XCCErr m))
    ((XCOk d) (XCCOk d certed))))

(fn xg_claim_call ((f FnDef) (cf FnDef) (certed (List (Pair Symbol CK)))) XCC
  (match f
    ((FnDef q ts rty body)
     (if (all_int ts)
       (if (is_int_ty rty)
         (if (le (count_ts ts) 2)
           (match cf
             ((FnDef cq cts crty cbody)
              (if (int_eq (count_ts cts) 1)
                (if (all_int cts)
                  (if (is_int_ty crty)
                    (match (ck_find certed (qn_name cq))
                      ((Some k) (xcc_of (xc_go q ts cq k body) certed))
                      (None
                        (match (xt_new q cq cbody certed)
                          ((XTNErr m) (xcc_of (xerr_at q m) certed))
                          ((XTNOk k cdoc)
                           (match (xc_go q ts cq k body)
                             ((XCErr m) (XCCErr m))
                             ((XCOk d)
                              (XCCOk
                                (DCat cdoc d)
                                (Cons (Pair (qn_name cq) k) certed))))))))
                    (xcc_of (xerr_at q "callee must return Int (v1)") certed))
                  (xcc_of (xerr_at q "callee params must be Int") certed))
                (xcc_of (xerr_at q "callee arity must be 1 (v1)") certed))))
           (xcc_of
             (xerr_at
               q
               "more than two Int params (call fragment parks r10/r11 only in v1)")
             certed))
         (xcc_of (xerr_at q "return type is not Int") certed))
       (xcc_of (xerr_at q "params are not all Int") certed)))))

;; ---- the call-loop fragment (docs/X86.md par.18): calls inside loops ------------
;;
;; A Nat-counted loop whose per-iteration WORK is a call to an EARLIER
;; same-file HOME-ALIGNED store fn (probe: xloopcall_probe.shard):
;;   (fn NAME ((m Mem) (x0 Int) (x1 Int) (k Nat)) Mem
;;     (match k (Z m) ((S k2) (NAME (CS m x0 x1) (+ x0 1) x1 k2))))
;; The callee's body is (XCall 1) alone (the par.18 fast path), so it
;; clobbers NOTHING: the loop's state (rdi/rsi/rdx) passes through the
;; call verbatim by the callee's cert, and the worker's register
;; literals are byte-for-byte fill's. The worker's S case stops at the
;; folded call and fires xcall_bridge with the callee's PREMISED cert,
;; the bounds discharging from the loop's range premise via the
;; existing xlg_* kit (stride 1). The cert returns the FOLDED spec
;; term, so the IH re-applies with no collapse at the boundary.
;;
;; v1 fences (loud, named growth): exactly two accumulators (the
;; advancing address in rdi, the static value in rsi), stride +1, call
;; args = accums 0 and 1 in order, the callee a home-aligned single
;; store.

;; the callee's named literal + premised clobber-set cert (result mem =
;; the folded spec call; clobber emptyset)
(fn xcl_cert_doc ((cs Symbol)) Doc
  (dconc
    (list
      (DStr "(fn ")
      (xc_gfsym cs)
      (DStr " () XFunc (MkXFunc 2 (list (XCall 1))))")
      (DStr (nl))
      (DStr "(claim xcert_")
      (dsym cs)
      (DStr
        " (goal ((c Nat) (restfs (List XFunc)) (mlo Int) (mhi Int) (mem Mem) (rax Int) (rcx Int) (rdx Int) (rbx Int) (rbp Int) (rsi Int) (rdi Int) (r8 Int) (r9 Int) (r10 Int) (r11 Int) (r12 Int) (r13 Int) (r14 Int) (r15 Int)) ((= (le mlo rdi) True) (= (le (+ rdi 1) mhi) True)) (= (xrun_regs (S^ 6 c) (MkXModule (Cons (inline xg_mget_f) (Cons (inline xg_mset_f) (Cons (inline ")
      (xc_gfsym cs)
      (DStr
        ") restfs))) mlo mhi) 2 (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) mem) (Some (Pair (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15) (")
      (dsym cs)
      (DStr
        " mem rdi rsi))))) (chain (steps ((compute lhs (stop xeval_call)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline xg_mset_f)) (inst rs2 (MkRegs rax rcx rdx rbx rbp rsi rdi r8 r9 r10 r11 r12 r13 r14 r15)) (inst mem2 (mem_set mem rdi rsi))) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xmset_cert) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((unfold ")
      (dsym cs)
      (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
      (DStr (nl)))))

;; the loop's module literal: [get, set, callee, loop | restfs], loop at 3
(fn xcl_mod ((cs Symbol) (nm Doc) (wl Int) (wh Int)) Doc
  (dconc
    (list
      (DStr
        "(MkXModule (Cons (inline xg_mget_f) (Cons (inline xg_mset_f) (Cons (inline ")
      (xc_gfsym cs)
      (DStr ") (Cons (MkXFunc 3 (list (XBlock (list (XLoop (inline ")
      nm
      (DStr "_body)))))) restfs)))) ")
      (dint wl)
      (sp)
      (dint wh)
      (DStr ")"))))

;; the loop body fn + worker induction + lowered theorem (the probe
;; templated; fuel 20/24 probe-validated)
(fn xcl_unit ((q QName) (cs Symbol) (wl Int) (wh Int)) Doc
  (let ((nm (dsym (qn_name q))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr
          "_body () (List XInstr) (list (XBrIf (CEqz RDX) 1) (XCall 2) (XBin XAdd RDI (SImm 1)) (XBin XSub RDX (SImm 1)) (XBr 0)))")
        (DStr (nl))
        (DStr "(claim xclw_")
        nm
        (DStr
          " (goal ((x0 Int) (x1 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr ") True)) (= (xeval_loop (S^ 20 (xlg_fuel k c)) ")
        (xcl_mod cs nm wl wh)
        (DStr " (inline ")
        nm
        (DStr
          "_body) (MkRegs 0 0 (int_of_nat k) 0 0 x1 x0 0 0 0 0 0 0 0 0) m0) (Some (XBrk 0 (MkRegs 0 0 0 0 0 x1 (xlg_adv x0 k) 0 0 0 0 0 0 0 0) (")
        nm
        (DStr
          " m0 x0 x1 k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold xlg_fuel lhs) (reduce lhs) (unfold xeval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (rewrite-with (lemma xlg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (have ha1 (= (le (+ x0 1) ")
        (dint wh)
        (DStr
          ") True) (rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f (inline ")
        (xc_gfsym cs)
        (DStr
          ")) (inst rs2 (MkRegs 0 0 (+ 1 (int_of_nat k2)) 0 0 x1 x0 0 0 0 0 0 0 0 0)) (inst mem2 (")
        (dsym cs)
        (DStr
          " m0 x0 x1))) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert_")
        (dsym cs)
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise ha1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma xlg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 18446744073709551616) (int_of_nat k2)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma xlg_kM) lr lhs ((inst a x0) (inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise 0) lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) (have hw0 (= (mod (+ x0 1) 18446744073709551616) (+ x0 1)) (rewrite-with (lemma wrap64_id) lr lhs ((inst x (+ x0 1))) ((rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_64) lr lhs () ((rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw0) lr lhs true ()))) (steps ((unfold ")
        nm
        (DStr
          " rhs) (unfold xlg_adv rhs) (reduce rhs))) (rewrite-with (hyp 0) lr lhs () ((rewrite-with (lemma xlg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma xlg_shift) lr lhs () ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl))) (steps ((compute both))) refl)))))")
        (DStr (nl))
        (DStr "(claim lowered_")
        nm
        (DStr
          " (goal ((x0 Int) (x1 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr ") True)) (= (xcall_fn_mem (S^ 24 (xlg_fuel k c)) ")
        (xcl_mod cs nm wl wh)
        (DStr " 3 (list x0 x1 (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr
          " m0 x0 x1 k))))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xclw_")
        nm
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; the call-loop gate: shape fences, callee validation, cert emission
(fn xcl_claim
  ((q QName)
   (mids (List Type))
   (adv (List LStr))
   (cs Symbol)
   (ks (List LKArg))
   (reg (List CInfo))
   (certed (List (Pair Symbol CK)))
   (wl Int)
   (wh Int))
  XCC
  (if (int_eq (count_ts mids) 2)
    (match adv
      ((Cons (LSInc) (Cons (LSStat) Nil))
       (match ks
         ((Cons (LKAcc ka) (Cons (LKAcc kb) Nil))
          (if (if (int_eq ka 0) (int_eq kb 1) False)
            (match (reg_find reg cs)
              (None
                (xcc_of
                  (xerr_at q "loop callee is not a registered same-file mem fn")
                  certed))
              ((Some ci)
               (match ci
                 ((MkCInfo _ _ _ _ _ cbody)
                  (match (xm_store cbody 2)
                    ((XMSOk a2 v2)
                     (if (xm_aligned a2 v2)
                       (let ((unit (xcl_unit q cs wl wh)))
                         (match (ck_find certed cs)
                           ((Some (CKMem)) (XCCOk unit certed))
                           ((Some _)
                            (xcc_of
                              (xerr_at
                                q
                                "loop callee name collides with a non-mem cert")
                              certed))
                           (None
                             (XCCOk
                               (DCat (xcl_cert_doc cs) unit)
                               (Cons (Pair cs (CKMem)) certed)))))
                       (xcc_of
                         (xerr_at
                           q
                           "loop callee must be a HOME-ALIGNED single store (mem_set m p v) at (param0, param1) (v1)")
                         certed)))
                    (XMSNo
                      (xcc_of
                        (xerr_at
                          q
                          "loop callee must be a HOME-ALIGNED single store (mem_set m p v) at (param0, param1) (v1)")
                        certed)))))))
            (xcc_of
              (xerr_at
                q
                "call-site args must be the accumulators (addr, value) in order (v1)")
              certed)))
         (_
           (xcc_of
             (xerr_at
               q
               "call-site args must be the accumulators (addr, value) in order (v1)")
             certed))))
      (_
        (xcc_of
          (xerr_at
            q
            "call-loop accumulators must be one advancing (+1) address and one static value (v1)")
          certed)))
    (xcc_of
      (xerr_at q "call-loop needs exactly two Int accumulators (v1)")
      certed)))

;; the loop route: LRCall bodies dispatch to the call-loop fragment,
;; everything else delegates to the store-loop path unchanged
(fn xg_claim_loop_r
  ((f FnDef)
   (reg (List CInfo))
   (certed (List (Pair Symbol CK)))
   (wl Int)
   (wh Int))
  XCC
  (match f
    ((FnDef q ts rty body)
     (match ts
       ((Cons _ rest)
        (match (ts_lasto rest)
          ((Some lt2)
           (if (is_nat_ty lt2)
             (let ((mids (ts_mids rest)))
               (if (all_int mids)
                 (match (lp_recognize q (count_ts mids) body reg)
                   ((LRCall adv cs ks)
                    (xcl_claim q mids adv cs ks reg certed wl wh))
                   (_ (xcc_of (xg_claim_loop f wl wh) certed)))
                 (xcc_of (xg_claim_loop f wl wh) certed)))
             (xcc_of (xg_claim_loop f wl wh) certed)))
          (None (xcc_of (xg_claim_loop f wl wh) certed))))
       (Nil (xcc_of (xg_claim_loop f wl wh) certed))))))

;; ---- module walk ------------------------------------------------------------------

(type XER (XEOk Doc Bool Bool) (XEErr (List Int)))

;; register a Mem-returning mem-fragment fn as a potential loop callee
;; (only the name, arity, and body matter to the x86 side)
(fn xg_reg ((f FnDef) (reg (List CInfo))) (List CInfo)
  (match f
    ((FnDef q ts rty body)
     (if (is_mem_ty rty)
       (match ts
         ((Cons _ rest)
          (reg_add
            reg
            (MkCInfo (qn_name q) (DStr "") 0 (count_ts rest) Nil body)))
         (Nil reg))
       reg))))

(fn xg_fns
  ((fns (List FnDef))
   (modpath (List Symbol))
   (seen (List FnDef))
   (certed (List (Pair Symbol CK)))
   (reg (List CInfo))
   (acc Doc)
   (lf Bool)
   (mf Bool))
  XER
  (measure (struct fns))
  (match fns
    (Nil (XEOk acc lf mf))
    ((Cons f rest)
     (match f
       ((FnDef q _ _ body)
        (match q
          ((QName mp _)
           (if (sym_list_eq mp modpath)
             (if (fn_is_loop f)
               (match (xg_claim_loop_r f reg certed (xw_hlo) (xw_hhi))
                 ((XCCErr m) (XEErr m))
                 ((XCCOk d certed2)
                  (xg_fns
                    rest
                    modpath
                    (Cons f seen)
                    certed2
                    reg
                    (DCat acc (DCat (DStr (nl)) d))
                    True
                    mf)))
             (if (fn_is_mem f)
               (match (xg_claim f 0)
                 ((XCErr m) (XEErr m))
                 ((XCOk d)
                  (xg_fns
                    rest
                    modpath
                    (Cons f seen)
                    certed
                    (xg_reg f reg)
                    (DCat acc (DCat (DStr (nl)) d))
                    lf
                    True)))
               (match (xc_target body seen)
                 ((Some cf)
                  (match (xg_claim_call f cf certed)
                    ((XCCErr m) (XEErr m))
                    ((XCCOk d certed2)
                     (xg_fns
                       rest
                       modpath
                       (Cons f seen)
                       certed2
                       reg
                       (DCat acc (DCat (DStr (nl)) d))
                       lf
                       mf))))
                 (None
                   (match (xg_claim f 0)
                     ((XCErr m) (XEErr m))
                     ((XCOk d)
                      (xg_fns
                        rest
                        modpath
                        (Cons f seen)
                        certed
                        reg
                        (DCat acc (DCat (DStr (nl)) d))
                        lf
                        mf)))))))
             (xg_fns rest modpath seen certed reg acc lf mf)))))))))

(fn xg_header ((target (List Int)) (loopf Bool) (memf Bool)) Doc
  (dconc
    (list
      (DStr ";;; GENERATED by tools/x86gen (the certifying x86_64 emitter) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (dimport (append_int (updots target) "models/x86/x86.shard"))
      (if loopf
        (DCat
          (dimport (append_int (updots target) "models/x86/loopkit.shard"))
          (dimport (append_int (updots target) "std/nat.shard")))
        (DStr ""))
      (if memf (dimport (append_int (updots target) "std/mem/mem.x86.shard"))
      (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models x86 x86 *))" (nl)))
      (if loopf
        (DStr
          (append_int
            "(use (:: models x86 loopkit *))"
            (append_int (nl) (append_int "(use (:: std nat *))" (nl)))))
        (DStr ""))
      (if memf (DStr (append_int "(use (:: std mem mem.x86 *))" (nl)))
      (DStr ""))
      (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl)))
      (if memf (DCat (DStr (nl)) (xm_callee_fns)) (DStr "")))))

;; ---- LIB mode (docs/X86.md §19): one image, named exports --------------------------
;;
;; A (lib …) declaration in the TARGET source lays the whole file into ONE
;; x86 image: every fn at its source-order index, certs position-general
;; (the xpr_* prefix binders; each claim's own literal at its PINNED
;; index), the declared exports baked BY NAME. The OUT file additionally
;; ships the image function list (LNAME_xfuncs), the named-export table
;; (LNAME_exports), and the per-entry encoding (LNAME_entry_bytes k =
;; enc_image with export k laid FIRST — the existing harness calls the
;; blob's start; the ELF rung owns the single-container bytes). v1
;; fragment: pure Int fns (straight-line/let/tail-if); mem, loop and call
;; fns refuse loudly.

;; an XFunc literal, spelled exactly as the claim spells it (same
;; generator, same inputs — the byte tie holds both to the shipped bytes)
(fn xflit_doc ((np Int) (code (List Doc))) Doc
  (dconc
    (list
      (DStr "(MkXFunc ")
      (dint np)
      (DStr " (list ")
      (djoin code)
      (DStr "))"))))

(fn xlib_flit ((f FnDef)) (Option Doc)
  (match f
    ((FnDef q ts rty body)
     (if (has_tail_if body)
       (match (xg_depo (count_ts ts) Nil 1 0 body)
         ((TErr _) None)
         ((TOk rt) (Some (xflit_doc (count_ts ts) (rt_code rt)))))
       (match (xg_t (count_ts ts) body)
         ((XTErr _) None)
         ((XTOk code _ _) (Some (xflit_doc (count_ts ts) code))))))))

;; ---- the bin-entry WRAPPER (probe examples/xbinsum_probe) -----------------------
;;
;; (fn NAME ((m Mem) (p Int) (k Nat)) Int (band (CS m p 0 k) 255))
;; — bytesum's ENTRY: marshal the glue's (rdi = buf, rsi = len) into the
;; index-0 sum loop's homes (mov rdx, rsi; mov rsi, 0 — seeding the
;; accumulator IS program logic), call, mask to an exit code (XAnd is
;; exact in the model). The bridge takes the callee in xrun_regs FORM at
;; the exact call-site register literal (xcert_CS), whose premises are
;; ONLY the wrapper-facing window pair — the loop's accumulator
;; invariants discharge internally ((le 0 0) by compute; the seeded sum
;; invariant by the farkas fact xsumk_CS, whose multipliers are
;; window-literal-blind). Fuel 19/14 probe-validated (five pre-call
;; peels over the callee cert's 14).

;; the loop callee's literal, spelled as the loop's own claims spell it
(fn xbw_ll ((cs Symbol)) Doc
  (dconc
    (list
      (DStr "(MkXFunc 3 (list (XBlock (list (XLoop (inline ")
      (dsym cs)
      (DStr "_body)))) (XMovRR RAX RSI)))"))))

;; the v1 shape gate: params ((m Mem) (p Int) (k Nat)), Int return, body
;; exactly (band (CS m p 0 k) 255) against the registered index-0 loop
(fn xbw_shape ((ts (List Type)) (rty Type) (body Expr) (cs Symbol)) Bool
  (match ts
    ((Cons t0 (Cons t1 (Cons t2 Nil)))
     (if (is_mem_ty t0)
       (if (is_int_ty t1)
         (if (is_nat_ty t2)
           (if (is_int_ty rty)
             (match body
               ((Call bq (Cons inner (Cons (IntLit mask) Nil)))
                (if (core_named bq (quote band))
                  (if (int_eq mask 255)
                    (match inner
                      ((Call
                         cq
                         (Cons
                           (BVar mv)
                           (Cons
                             (BVar pv)
                             (Cons (IntLit z) (Cons (BVar kv) Nil)))))
                       (if (sym_eq (qn_name cq) cs)
                         (if (int_eq mv 2)
                           (if (int_eq pv 1)
                             (if (int_eq z 0) (int_eq kv 0) False)
                             False)
                           False)
                         False))
                      (_ False))
                    False)
                  False))
               (_ False))
             False)
           False)
         False)
       False))
    (_ False)))

;; body + func + the seeded-sum farkas fact + the callee's xrun_regs-form
;; cert + the wrapper's lowered theorem (the probe templated)
(fn xbw_unit ((q QName) (cs Symbol) (wl Int) (wh Int)) Doc
  (let ((nm (dsym (qn_name q))))
    (dconc
      (list
        (DStr "(fn ")
        nm
        (DStr
          "_body () (List XInstr) (list (XMovRR RDX RSI) (XMovRI RSI 0) (XCall 0) (XBin XAnd RAX (SImm 255))))")
        (DStr (nl))
        (DStr "(fn ")
        nm
        (DStr "_func () XFunc (MkXFunc 2 (")
        nm
        (DStr "_body)))")
        (DStr (nl))
        (DStr "(claim xsumk_")
        (dsym cs)
        (DStr " (goal ((x Int) (k Nat)) ((= (le ")
        (dint wl)
        (DStr " x) True) (= (le (+ x (int_of_nat k)) ")
        (dint wh)
        (DStr
          ") True)) (= (le (+ 0 (* 256 (int_of_nat k))) 18446744073709551616) True)) (by arith (list 1 256 256)))")
        (DStr (nl))
        (DStr "(claim xcert_")
        (dsym cs)
        (DStr
          " (goal ((x0 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr ") True)) (= (xrun_regs (S^ 14 (xlg_fuel k c)) (MkXModule (Cons ")
        (xbw_ll cs)
        (DStr " restfs) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr
          ") 0 (MkRegs 0 0 (int_of_nat k) 0 0 0 x0 0 0 0 0 0 0 0 0) m0) (Some (Pair (MkRegs (")
        (dsym cs)
        (DStr " m0 x0 0 k) 0 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x0 0 k) (xlg_adv x0 k) 0 0 0 0 0 0 0 0) m0)))) (chain (steps ((compute lhs (stop xeval_loop xlg_fuel)))) (rewrite-with (lemma xliw_")
        (dsym cs)
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((compute both)) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl) (rewrite-with (lemma xsumk_")
        (dsym cs)
        (DStr
          ") lr lhs ((inst x x0)) ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl)) refl))) (steps ((compute both))) refl))")
        (DStr (nl))
        (DStr "(claim lowered_")
        nm
        (DStr
          " (goal ((x0 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))) ((= (le ")
        (dint wl)
        (DStr " x0) True) (= (le (+ x0 (int_of_nat k)) ")
        (dint wh)
        (DStr
          ") True)) (= (xcall_fn_mem (S^ 19 (xlg_fuel k c)) (MkXModule (Cons ")
        (xbw_ll cs)
        (DStr " (Cons (MkXFunc 2 (inline ")
        nm
        (DStr "_body)) restfs)) ")
        (dint wl)
        (sp)
        (dint wh)
        (DStr ") 1 (list x0 (int_of_nat k)) m0) (Some (Pair (")
        nm
        (DStr
          " m0 x0 k) m0)))) (chain (steps ((compute lhs (stop xeval_call xeval_loop xlg_fuel)))) (rewrite-with (lemma xcall_bridge) lr lhs ((inst f ")
        (xbw_ll cs)
        (DStr ") (inst rs2 (MkRegs (")
        (dsym cs)
        (DStr " m0 x0 0 k) 0 0 0 0 (")
        (dsym cs)
        (DStr
          " m0 x0 0 k) (xlg_adv x0 k) 0 0 0 0 0 0 0 0)) (inst mem2 m0)) ((steps ((compute both)) refl) (chain (rewrite-with (lemma xcert_")
        (dsym cs)
        (DStr
          ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))) (steps ((unfold ")
        nm
        (DStr " rhs) (reduce rhs))) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; claims, the xfuncs cons spine (open), name -> index, count
(type XLE (XLEOk Doc Doc (List (Pair Symbol Int)) Int) (XLEErr (List Int)))

(fn xemit_fns_lib
  ((fns (List FnDef))
   (modpath (List Symbol))
   (seen (List FnDef))
   (k Int)
   (accp Doc)
   (accf Doc)
   (accn (List (Pair Symbol Int)))
   (lloop (Option Symbol))
   (wl Int)
   (wh Int))
  XLE
  (measure (struct fns))
  (match fns
    (Nil (XLEOk accp accf accn k))
    ((Cons f rest)
     (match f
       ((FnDef q ts rty body)
        (match q
          ((QName mp nm)
           (if (sym_list_eq mp modpath)
             (if (fn_is_loop f)
               (if (is_int_ty rty)
                 (if (int_eq k 0)
                   (match (xg_claim_loop f wl wh)
                     ((XCErr m) (XLEErr m))
                     ((XCOk d)
                      (xemit_fns_lib
                        rest
                        modpath
                        (Cons f seen)
                        1
                        (DCat accp (DCat (DStr (nl)) d))
                        (DCat
                          accf
                          (dconc
                            (list (DStr "(Cons (") (dsym nm) (DStr "_func) "))))
                        (Cons (Pair nm 0) accn)
                        (Some nm)
                        wl
                        wh)))
                   (XLEErr
                     "an Int-return loop must be fn 0 of the lib file (v1)"))
                 (XLEErr "Mem-return loops are not in the x86 lib fragment yet"))
             (if (fn_is_mem f)
               (match lloop
                 ((Some cs)
                  (if (xbw_shape ts rty body cs)
                    (if (int_eq k 1)
                      (xemit_fns_lib
                        rest
                        modpath
                        (Cons f seen)
                        2
                        (DCat accp (DCat (DStr (nl)) (xbw_unit q cs wl wh)))
                        (DCat
                          accf
                          (dconc
                            (list (DStr "(Cons (") (dsym nm) (DStr "_func) "))))
                        (Cons (Pair nm 1) accn)
                        lloop
                        wl
                        wh)
                      (XLEErr
                        "the entry wrapper must immediately follow its loop (v1)"))
                    (XLEErr
                      "mem fns are not in the x86 lib fragment yet (v1 lib mem shape: the band-masked seeded sum call against fn 0)")))
                 (None (XLEErr "mem fns are not in the x86 lib fragment yet")))
               (match (xc_target body seen)
                 ((Some _)
                  (XLEErr "call fns are not in the x86 lib fragment yet"))
                 (None
                   (match (xg_claim f k)
                     ((XCErr m) (XLEErr m))
                     ((XCOk d)
                      (match (xlib_flit f)
                        (None (XLEErr "lib literal generation failed"))
                        ((Some flit)
                         (xemit_fns_lib
                           rest
                           modpath
                           (Cons f seen)
                           (+ k 1)
                           (DCat accp (DCat (DStr (nl)) d))
                           (DCat accf (dcat3 (DStr "(Cons ") flit (sp)))
                           (Cons (Pair nm k) accn)
                           lloop
                           wl
                           wh)))))))))
             (xemit_fns_lib rest modpath seen k accp accf accn lloop wl wh)))))))))

(fn xlib_funcs_doc ((lname Symbol) (accf Doc) (k Int)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr ";; the lib image: every fn of the file at its source-order index")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_xfuncs () (List XFunc) ")
      accf
      (DStr "Nil")
      (xpr_rpars k)
      (DStr ")")
      (DStr (nl)))))

(fn xlib_exp_at ((x Symbol) (ns (List (Pair Symbol Int)))) (Option Int)
  (measure (struct ns))
  (match ns
    (Nil None)
    ((Cons (Pair n i) rest) (if (sym_eq x n) (Some i) (xlib_exp_at x rest)))))

(fn xlib_exp_entries ((exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (measure (struct exps))
  (match exps
    (Nil (Some (DStr "")))
    ((Cons x rest)
     (match (xlib_exp_at x ns)
       (None None)
       ((Some i)
        (match (xlib_exp_entries rest ns)
          (None None)
          ((Some d)
           (Some
             (DCat
               (dconc
                 (list
                   (DStr " (XX ")
                   (DStr (list 34))
                   (dsym x)
                   (DStr (list 34))
                   (sp)
                   (dint i)
                   (DStr ")")))
               d)))))))))

(fn xlib_exports_doc
  ((lname Symbol) (exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (match (xlib_exp_entries exps ns)
    (None None)
    ((Some entries)
     (Some
       (dconc
         (list
           (DStr (nl))
           (DStr
             ";; the export table: the (lib …) declaration's names, by index")
           (DStr (nl))
           (DStr "(fn ")
           (dsym lname)
           (DStr "_exports () (List XExport) (list")
           entries
           (DStr "))")
           (DStr (nl))))))))

;; the per-entry encoding, spec-side: the plan driver evaluates this
;; instead of importing target encoders — export k is laid FIRST (the
;; harness calls the blob's start); indices inside the image never move
(fn xlib_bytes_doc ((lname Symbol)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr
        ";; the encoded image, one layout per export: enc_image with entry k")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_entry_bytes ((k Int)) (List Int) (enc_image (")
      (dsym lname)
      (DStr "_xfuncs) k))")
      (DStr (nl))
      (DStr (nl))
      (DStr
        ";; the ELF harness inputs (docs/X86.md §20): the index-order image")
      (DStr (nl))
      (DStr ";; (entry = the stub, not a lib fn) and its per-index offsets")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_elf_image () (List Int) (enc_image_ord (")
      (dsym lname)
      (DStr "_xfuncs)))")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_elf_offsets () (List Int) (img_offs_ord (")
      (dsym lname)
      (DStr "_xfuncs) 0))")
      (DStr (nl)))))

;; the (lib …) declaration of the TARGET source, if any. A (bin …)
;; declaration is admitted AS a one-export lib (docs/X86.md §22): the
;; image machinery is identical — one image, the entry at its
;; source-order index — and the differences (the argv glue, the
;; glue-contract surface law) live in the ELF builder and the accepts
;; gate's bin arm, never in the emitter.
(fn xlib_scan_forms ((forms (List SExpr))) (Option Lib)
  (measure (struct forms))
  (match forms
    (Nil None)
    ((Cons f rest)
     (if (is_lib_form f)
       (match (lib_of_form f)
         (None (xlib_scan_forms rest))
         ((Some l) (Some l)))
     (if (is_bin_form f)
       (match (bin_of_form f)
         (None (xlib_scan_forms rest))
         ((Some b)
          (match b
            ((Bin bname entry _x _t _r) (Some (Lib bname (Cons entry Nil) Nil))))))
       (xlib_scan_forms rest))))))

(fn xlib_scan ((srcs (List SrcEntry)) (target (List Int))) (Option Lib)
  (measure (struct srcs))
  (match srcs
    (Nil None)
    ((Cons (SrcEntry path _ src) rest)
     (if (int_list_eq path target)
       (match (read_all src)
         (None None)
         ((Some forms) (xlib_scan_forms forms)))
       (xlib_scan rest target)))))

;; the LIB file's header: the model, the encoder (XExport/XX for the
;; export table, enc_image for the per-entry bytes), and the source
(fn xany_loop ((fns (List FnDef))) Bool
  (measure (struct fns))
  (match fns
    (Nil False)
    ((Cons f rest) (if (fn_is_loop f) True (xany_loop rest)))))

(fn xlib_header ((target (List Int)) (lf Bool)) Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/x86gen (LIB mode: one image, named exports) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (dimport (append_int (updots target) "models/x86/x86.shard"))
      (dimport (append_int (updots target) "models/x86/encode.shard"))
      (if lf (dimport (append_int (updots target) "models/x86/loopkit.shard"))
      (DStr ""))
      (if lf (dimport (append_int (updots target) "std/nat.shard")) (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models x86 x86 *))" (nl)))
      (if lf (DStr (append_int "(use (:: models x86 loopkit *))" (nl)))
      (DStr ""))
      (if lf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
      (DStr (append_int "(use (:: models x86 encode XExport))" (nl)))
      (DStr (append_int "(use (:: models x86 encode XX))" (nl)))
      (DStr (append_int "(use (:: models x86 encode enc_image))" (nl)))
      (DStr (append_int "(use (:: models x86 encode enc_image_ord))" (nl)))
      (DStr (append_int "(use (:: models x86 encode img_offs_ord))" (nl)))
      (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl))))))

;; lib mode: emit the position-general claims + the image function list +
;; the export table + the per-entry encoding.
(fn xlib_run
  ((l Lib) (fns (List FnDef)) (target (List Int)) (out (List Int)) (w World))
  World
  (match l
    ((Lib lname exps _acc)
     (match
       (xemit_fns_lib
         fns
         (split_slash (until_dot target) Nil)
         Nil
         0
         (DStr "")
         (DStr "")
         Nil
         None
         (xw_hlo)
         (xw_hhi))
       ((XLEErr msg)
        (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))
       ((XLEOk bodyp accf ns k)
        (match (xlib_exports_doc lname exps ns)
          (None
            (exit
              1
              (write
                "refused: a (lib exports) name is not an emitted fn of this file\n"
                w)))
          ((Some expdoc)
           (match
             (write_file
               out
               (doc_flat
                 (dconc
                   (list
                     (xlib_header target (xany_loop fns))
                     bodyp
                     (xlib_funcs_doc lname accf k)
                     expdoc
                     (xlib_bytes_doc lname)))
                 Nil)
               w)
             ((Pair ok w2)
              (if ok
                (exit 0 (write (append_int "wrote " (append_int out (nl))) w2))
                (xfail (append_int "cannot write " out) w2)))))))))))

;; ---- driver -----------------------------------------------------------------------

(fn prelude_ctors_l () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn xfail ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn xgen_run ((target (List Int)) (out (List Int)) (w World)) World
  (match (resolve_closure target True w)
    ((Pair Nil w1) (xfail (append_int "cannot read closure of " target) w1))
    ((Pair srcs w1)
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors_l)
         1)
       ((BMFail diag) (xfail diag w1))
       ((BMOk m)
        (match m
          ((Module _ fns _ _ _)
           (match (xlib_scan srcs target)
             ((Some l) (xlib_run l fns target out w1))
             (None
               (match
                 (xg_fns
                   fns
                   (split_slash (until_dot target) Nil)
                   Nil
                   Nil
                   Nil
                   (DStr "")
                   False
                   False)
                 ((XEErr msg)
                  (exit
                    1
                    (write (append_int "refused: " (append_int msg (nl))) w1)))
                 ((XEOk body loopf memf)
                  (match
                    (write_file
                      out
                      (doc_flat (DCat (xg_header target loopf memf) body) Nil)
                      w1)
                    ((Pair ok w2)
                     (if ok
                       (exit
                         0
                         (write (append_int "wrote " (append_int out (nl))) w2))
                       (xfail (append_int "cannot write " out) w2)))))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target (Cons out Nil)) (xgen_run target out w1))
       (_ (xfail "usage: x86gen SRC OUT" w1))))))
