;;; structgen.shard — the offline structural-measure MIGRATION AID (issue #1).
;;;
;;; Per docs/TOTALITY.md §4 the descent RECOGNIZER stays OUT of the trust path:
;;; admit DISCOVERS which parameter descends; the author commits an explicit
;;; `(measure (struct ARG))` clause; the small check-time verifier
;;; (driver mc_check_struct) REPLAYS it. This tool is the "admit can generate
;;; the declarations" step: it runs admit's classifier over a file's closure and
;;; inserts a `(measure (struct ARG))` clause into every self-/mutually-
;;; structural fn DEFINED IN THAT FILE that doesn't already carry a measure.
;;;
;;; NOT trusted: a wrong arg only yields a clause the verifier FAILs (loud,
;;; never silently admitted), and a wrong INSERTION offset yields unparseable
;;; text that the follow-up shardfmt pass REFUSES (exit 3).
;;;
;;; Insertion is BYTE-LEVEL (every original byte, incl. comments, preserved;
;;; only the clause is spliced after the return-type form), so the output may be
;;; non-canonical spacing — pipe through shardfmt to canonicalize:
;;;
;;;   eval run tools/structgen/structgen.shard FILE.shard > T \
;;;     && eval run tools/shardfmt/shardfmt.shard T > FILE.shard
;;;
;;; `... FILE dbg` instead dumps the (name -> arg) map it would apply.

(import "../../kernel/loader.shard")  ; resolve_closure, int_list_eq, World I/O
(import "../../kernel/admit.shard")  ; ad_sccs, ad_scc_verdict, AdVerdict
(use (:: kernel loader *))
(use (:: kernel admit *))
(use (:: kernel reader *))  ; read_all, SExpr, build_module_d, module_path_of
(use (:: kernel term *))  ; chars_of_sym, qn_name
(use (:: kernel module *))  ; Module, FnTrie, QName

(fn sg_ctors () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn sg_cat ((a (List Int)) (b (List Int))) (List Int)
  (match a
    (Nil b)
    ((Cons h t) (Cons h (sg_cat t b)))))

;; ===========================================================================
;; CLASSIFY — admit verdicts -> (fn-name-bytes -> descending index). NO modpath
;; filter (directory modules re-home impl fns at the interface modpath via the
;; sig->def rebind); we key by name and apply only to fns DEFINED in the target
;; file (its parsed forms). A cross-file homonym at worst yields a wrong clause
;; the verifier FAILs — never a silent admission (docs/TOTALITY.md §3.1).
;; ===========================================================================

(fn sg_des_map ((des (List (Pair QName Int)))) (List (Pair (List Int) Int))
  (match des
    (Nil Nil)
    ((Cons (Pair q j) rest)
     (Cons (Pair (chars_of_sym (qn_name q)) j) (sg_des_map rest)))))

(fn sg_scc_map ((scc (List QName)) (v AdVerdict)) (List (Pair (List Int) Int))
  (match v
    ((AdStruct j)
     (match scc
       ((Cons q _) (Cons (Pair (chars_of_sym (qn_name q)) j) Nil))
       (_ Nil)))
    ((AdMutual des) (sg_des_map des))
    ((AdNonRec) Nil)
    ((AdFlag _) Nil)
    ((AdUnresolved _ _) Nil)))

(fn sg_amap_go ((sccs (List (List QName))) (tr FnTrie))
  (List (Pair (List Int) Int))
  (match sccs
    (Nil Nil)
    ((Cons scc rest)
     (sg_cat (sg_scc_map scc (ad_scc_verdict tr scc)) (sg_amap_go rest tr)))))

(fn sg_amap ((m Module)) (List (Pair (List Int) Int))
  (match m
    ((Module _ _ _ tr _) (sg_amap_go (ad_sccs m) tr))))

(fn sg_lookup_idx ((nm (List Int)) (amap (List (Pair (List Int) Int))))
  (Option Int)
  (match amap
    (Nil None)
    ((Cons (Pair k j) rest)
     (if (int_list_eq k nm) (Some j) (sg_lookup_idx nm rest)))))

;; ===========================================================================
;; RESOLVE — descending INDEX -> parameter NAME, from the file's own parsed
;; forms (FnDef carries no param names; the source does). Result: the final
;; (fn-name-bytes -> arg-name-bytes) map applied by the scanner.
;; ===========================================================================

(fn sg_form_fn ((f SExpr)) (Option (Pair Symbol (List SExpr)))
  (match f
    ((SList (Cons (SSym h) (Cons (SSym nm) (Cons (SList ps) _))))
     (if (sym_eq h (quote fn)) (Some (Pair nm ps)) None))
    (_ None)))  ; type-parametric name or non-fn -> skip

(fn sg_nth ((xs (List SExpr)) (i Int)) (Option SExpr)
  (match xs
    (Nil None)
    ((Cons h t) (if (lt i 1) (Some h) (sg_nth t (- i 1))))))

;; already-measured fn: clause slot (index 4 of a 6-element fn form) is a
;; (measure …). Skip these — never double-insert (keeps the tool idempotent and
;; leaves existing numeric/struct clauses untouched).
(fn sg_is_measured ((f SExpr)) Bool
  (match f
    ((SList items)
     (match (sg_nth items 4)
       ((Some (SList (Cons (SSym h) _))) (sym_eq h (quote measure)))
       (_ False)))
    (_ False)))

(fn sg_paramname_at ((ps (List SExpr)) (j Int)) (Option (List Int))
  (match ps
    (Nil None)
    ((Cons p t)
     (if (lt j 1)
       (match p
         ((SList (Cons (SSym pn) _)) (Some (chars_of_sym pn)))
         (_ None))
       (sg_paramname_at t (- j 1))))))

(fn sg_argmap ((forms (List SExpr)) (amap (List (Pair (List Int) Int))))
  (List (Pair (List Int) (List Int)))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (if (sg_is_measured f) (sg_argmap rest amap)
     (match (sg_form_fn f)
       (None (sg_argmap rest amap))
       ((Some (Pair nm ps))
        (match (sg_lookup_idx (chars_of_sym nm) amap)
          (None (sg_argmap rest amap))
          ((Some j)
           (match (sg_paramname_at ps j)
             (None (sg_argmap rest amap))
             ((Some arg)
              (Cons (Pair (chars_of_sym nm) arg) (sg_argmap rest amap))))))))))))

(fn sg_arg_lookup ((nm (List Int)) (am (List (Pair (List Int) (List Int)))))
  (Option (List Int))
  (match am
    (Nil None)
    ((Cons (Pair k v) rest)
     (if (int_list_eq k nm) (Some v) (sg_arg_lookup nm rest)))))

;; ===========================================================================
;; BYTE SCAN — forward build: each copier returns (consumed-bytes, rest).
;; String- and comment-aware paren tracking; the source is reproduced verbatim
;; except for the spliced clause.
;; bytes:  ( 40  ) 41  ' 39  " 34  ; 59  \ 92  sp 32  tab 9  nl 10  cr 13
;; ===========================================================================

(fn sg_isws ((c Int)) Bool
  (if (int_eq c 32) True
  (if (int_eq c 9) True
  (if (int_eq c 10) True
  (int_eq c 13)))))

(fn sg_delim ((c Int)) Bool
  (if (sg_isws c) True
  (if (int_eq c 40) True
  (if (int_eq c 41) True
  (if (int_eq c 39) True
  (if (int_eq c 34) True
  (int_eq c 59)))))))

;; cs is AFTER a '"'; returns (string-body-incl-closing-quote, rest).
(fn sg_copy_string ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (int_eq c 92)
       (match rest
         (Nil (Pair (Cons 92 Nil) Nil))
         ((Cons d r2)
          (match (sg_copy_string r2)
            ((Pair s r3) (Pair (Cons 92 (Cons d s)) r3)))))
     (if (int_eq c 34) (Pair (Cons 34 Nil) rest)
     (match (sg_copy_string rest)
       ((Pair s r2) (Pair (Cons c s) r2))))))))

;; cs is AFTER a ';'; returns (comment-incl-newline, rest).
(fn sg_copy_comment ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (int_eq c 10) (Pair (Cons 10 Nil) rest)
     (match (sg_copy_comment rest)
       ((Pair cm r2) (Pair (Cons c cm) r2)))))))

;; cs is AFTER a '('; returns (content-incl-matching-')', rest).
(fn sg_copy_paren ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (int_eq c 41) (Pair (Cons 41 Nil) rest)
     (if (int_eq c 40)
       (match (sg_copy_paren rest)
         ((Pair inner r2)
          (match (sg_copy_paren r2)
            ((Pair more r3) (Pair (Cons 40 (sg_cat inner more)) r3)))))
     (if (int_eq c 34)
       (match (sg_copy_string rest)
         ((Pair s r2)
          (match (sg_copy_paren r2)
            ((Pair more r3) (Pair (Cons 34 (sg_cat s more)) r3)))))
     (if (int_eq c 59)
       (match (sg_copy_comment rest)
         ((Pair cm r2)
          (match (sg_copy_paren r2)
            ((Pair more r3) (Pair (Cons 59 (sg_cat cm more)) r3)))))
       (match (sg_copy_paren rest)
         ((Pair more r2) (Pair (Cons c more) r2))))))))))

;; an atom token; stop (without consuming) at the first delimiter.
(fn sg_copy_atom ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (sg_delim c) (Pair Nil cs)
     (match (sg_copy_atom rest)
       ((Pair a r) (Pair (Cons c a) r)))))))

;; one whole form (atom / "string" / 'quote / (...)).
(fn sg_copy_form ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (int_eq c 40)
       (match (sg_copy_paren rest)
         ((Pair inner r) (Pair (Cons 40 inner) r)))
     (if (int_eq c 39)
       (match (sg_copy_form rest)
         ((Pair f r) (Pair (Cons 39 f) r)))
     (if (int_eq c 34)
       (match (sg_copy_string rest)
         ((Pair s r) (Pair (Cons 34 s) r)))
       (sg_copy_atom cs)))))))

;; leading whitespace + comments, up to the first significant byte.
(fn sg_copy_ws ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (sg_isws c)
       (match (sg_copy_ws rest)
         ((Pair w r) (Pair (Cons c w) r)))
     (if (int_eq c 59)
       (match (sg_copy_comment rest)
         ((Pair cm r2)
          (match (sg_copy_ws r2)
            ((Pair w r3) (Pair (Cons 59 (sg_cat cm w)) r3)))))
       (Pair Nil cs))))))

;; an atom token's bytes (pure), returning (atom, rest).
(fn sg_read_atom ((cs (List Int))) (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons c rest)
     (if (sg_delim c) (Pair Nil cs)
     (match (sg_read_atom rest)
       ((Pair a r) (Pair (Cons c a) r)))))))

(fn sg_clause ((arg (List Int))) (List Int)
  (sg_cat " (measure (struct " (sg_cat arg "))")))

;; cs is at the fn's BODY (after fn/name/params/ret). Splice if nm is a target;
;; copy the rest of the fn paren (body + closing ')').
(fn sg_after_ret
  ((cs (List Int)) (am (List (Pair (List Int) (List Int)))) (nm (List Int)))
  (Pair (List Int) (List Int))
  (match (sg_copy_paren cs)
    ((Pair rest2 r)
     (match (sg_arg_lookup nm am)
       (None (Pair rest2 r))
       ((Some arg) (Pair (sg_cat (sg_clause arg) rest2) r))))))

;; cs is AFTER the "fn" head atom. Returns (name…ret…clause?…body…')', rest).
(fn sg_fn_body ((cs (List Int)) (am (List (Pair (List Int) (List Int)))))
  (Pair (List Int) (List Int))
  (match (sg_copy_ws cs)
    ((Pair w1 c1)
     (match (sg_read_atom c1)
       ((Pair nm c2)
        (match (sg_copy_ws c2)
          ((Pair w2 c3)
           (match (sg_copy_form c3)
             ((Pair params c4)
              (match (sg_copy_ws c4)
                ((Pair w3 c5)
                 (match (sg_copy_form c5)
                   ((Pair ret c6)
                    (match (sg_after_ret c6 am nm)
                      ((Pair body r)
                       (Pair
                         (sg_cat
                           w1
                           (sg_cat
                             nm
                             (sg_cat
                               w2
                               (sg_cat params (sg_cat w3 (sg_cat ret body))))))
                         r))))))))))))))))

;; cs is at a top-level '('. Splice if it is `(fn …)`, else copy verbatim.
(fn sg_top_form ((cs (List Int)) (am (List (Pair (List Int) (List Int)))))
  (Pair (List Int) (List Int))
  (match cs
    (Nil (Pair Nil Nil))
    ((Cons _ after_lp)
     (match (sg_copy_ws after_lp)
       ((Pair ws c1)
        (match (sg_read_atom c1)
          ((Pair head c2)
           (if (int_list_eq head "fn")
             (match (sg_fn_body c2 am)
               ((Pair body r) (Pair (Cons 40 (sg_cat ws (sg_cat head body))) r)))
             (match (sg_copy_paren c2)
               ((Pair rest2 r)
                (Pair (Cons 40 (sg_cat ws (sg_cat head rest2))) r)))))))))))

(fn sg_scan ((cs (List Int)) (am (List (Pair (List Int) (List Int)))))
  (List Int)
  (match (sg_copy_ws cs)
    ((Pair ws c1)
     (match c1
       (Nil ws)
       ((Cons c _)
        (if (int_eq c 40)
          (match (sg_top_form c1 am)
            ((Pair out c2) (sg_cat ws (sg_cat out (sg_scan c2 am)))))
          (match (sg_copy_form c1)
            ((Pair out c2) (sg_cat ws (sg_cat out (sg_scan c2 am)))))))))))

;; ===========================================================================
;; DEBUG + MAIN
;; ===========================================================================

(fn sg_dbg_argmap ((am (List (Pair (List Int) (List Int))))) (List Int)
  (match am
    (Nil Nil)
    ((Cons (Pair k v) rest)
     (sg_cat k (sg_cat " -> " (sg_cat v (sg_cat "
" (sg_dbg_argmap rest))))))))

(fn sg_last ((srcs (List SrcEntry))) (Option SrcEntry)
  (match srcs
    (Nil None)
    ((Cons e Nil) (Some e))
    ((Cons _ t) (sg_last t))))

(fn sg_go ((srcs (List SrcEntry)) (dbg Bool) (w World)) World
  (match (sg_last srcs)
    (None (exit 2 (write "structgen: empty closure\n" w)))
    ((Some (SrcEntry _ _ src))
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (sg_ctors)
         1)
       ((BMFail diag)
        (exit 2 (write (append_int "structgen: load failed\n" diag) w)))
       ((BMOk m)
        (match (read_all src)
          (None (exit 2 (write "structgen: cannot parse target\n" w)))
          ((Some forms)
           (let ((am (sg_argmap forms (sg_amap m))))
             (if dbg (exit 0 (write (sg_dbg_argmap am) w))
             (exit 0 (write (sg_scan src am) w)))))))))))

(fn sg_has_dbg ((rest (List (List Int)))) Bool
  (match rest
    (Nil False)
    ((Cons a _) (int_list_eq a "dbg"))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       (Nil (exit 2 (write "usage: structgen <file.shard> [dbg]\n" w1)))
       ((Cons target rest)
        (match (resolve_closure target False w1)
          ((Pair srcs w2)
           (match srcs
             (Nil
               (exit 2 (write (append_int "structgen: cannot read " target) w2)))
             (_ (sg_go srcs (sg_has_dbg rest) w2))))))))))
