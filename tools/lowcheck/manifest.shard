;;; tools/lowcheck/manifest.shard — the MANIFEST binding gate (docs/
;;; LOWERING.md §6ad): validates that a rendered plan's ARTIFACT lines
;;; actually BIND to the gated cert files. tools/bytetie ties module
;;; name <-> claim <-> bytes; before this gate every OTHER manifest
;;; field was decoration — a PA line could name the wrong cert or the
;;; wrong export index and all five gates stayed green. Checked per
;;; ARTIFACT line (positional word order, the lowbuild renderer's):
;;;   1. cert=<c>     — c is lowered_<name> or linked_<name> (the naming
;;;                     convention the byte tie already rides)
;;;   2. certfile=<f> — f is one of the CERTFILE arguments (the files
;;;                     the calling build script actually gates)
;;;   3. model=<m>    — m is the MODEL argument (the semantics the
;;;                     kernel gate checked)
;;;   4. export=f<N>  — N equals the pinned function-index literal in
;;;                     the named claim's conclusion, read from the cert
;;;                     file RAW (certnav's PCC stance — never trust the
;;;                     plan's producer)
;;; A plan with ZERO artifact lines is refused — a garbled plan must not
;;; pass by vacuity.
;;;
;;; RUN IT:
;;;   bin/shard_eval run tools/lowcheck/manifest.shard PLANTXT MODEL CERTFILE...
;;;   exit 0 = every artifact line bound; 1 = unbound lines (or none at
;;;   all); 2 = unreadable/unparseable inputs

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/reader.shard")
(import "../../kernel/term.shard")
(import "../../meta/forms")
(import "../low/certnav.shard")

(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader read_file))
(use (:: kernel loader write))
(use (:: kernel loader exit))
(use (:: kernel reader SExpr))
(use (:: kernel reader SInt))
(use (:: kernel reader SSym))
(use (:: kernel reader SList))
(use (:: kernel term append_int))
(use (:: kernel term show_int))
(use (:: meta forms *))
(use (:: tools low certnav *))

(fn nl () (List Int) (Cons 10 Nil))

;; ---- small text utilities --------------------------------------------------------

(fn rev_ch ((xs (List Int)) (acc (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_ch t (Cons h acc)))))

(fn chars_eq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        ((Cons _ _) False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (chars_eq xs ys) False))))))

(fn split_on ((sep Int) (cs (List Int)) (cur (List Int))) (List (List Int))
  (measure (struct cs))
  (match cs
    (Nil (Cons (rev_ch cur Nil) Nil))
    ((Cons c t)
     (if (int_eq c sep) (Cons (rev_ch cur Nil) (split_on sep t Nil))
     (split_on sep t (Cons c cur))))))

(fn drop_empty ((ws (List (List Int)))) (List (List Int))
  (measure (struct ws))
  (match ws
    (Nil Nil)
    ((Cons w rest)
     (match w
       (Nil (drop_empty rest))
       ((Cons _ _) (Cons w (drop_empty rest)))))))

(fn words ((cs (List Int))) (List (List Int)) (drop_empty (split_on 32 cs Nil)))

;; prefix strip: (Some REST) iff cs starts with pre
(fn strip_pre ((pre (List Int)) (cs (List Int))) (Option (List Int))
  (measure (struct pre))
  (match pre
    (Nil (Some cs))
    ((Cons a as)
     (match cs
       (Nil None)
       ((Cons b bs) (if (int_eq a b) (strip_pre as bs) None))))))

(fn pd_go ((cs (List Int)) (acc Int)) (Option Int)
  (measure (struct cs))
  (match cs
    (Nil (Some acc))
    ((Cons c t)
     (if (if (le 48 c) (le c 57) False) (pd_go t (+ (* acc 10) (- c 48))) None))))

;; nonempty all-digit parse
(fn parse_dec ((cs (List Int))) (Option Int)
  (match cs
    (Nil None)
    ((Cons _ _) (pd_go cs 0))))

;; ---- the claim-index table per cert file ------------------------------------------
;; claim name -> the pinned function-index literal in its conclusion's
;; call_fn / call_fn_mem / xcall_fn / xcall_fn_mem application (every
;; cert form carries a literal index; claims without one are simply not
;; manifest-bindable)

(fn items_idx ((items (List SExpr))) (Option Int)
  (match items
    ((Cons _ (Cons _fuel (Cons _wm (Cons idx _))))
     (match idx
       ((SInt k) (Some k))
       (_ None)))
    (_ None)))

(fn claim_idx ((gf SExpr)) (Option Int)
  (match gf
    ((SList (Cons g (Cons _bs (Cons _prems (Cons concl Nil)))))
     (if (is_sym g (quote goal))
       (match (find_call concl)
         (None
           (match (find_xcall concl)
             (None
               (match (find_xrun_w concl)
                 (None None)
                 ((Some items) (items_idx items))))
             ((Some items) (items_idx items))))
         ((Some items) (items_idx items)))
       None))
    (_ None)))

(fn cidx ((forms (List SExpr))) (List (Pair Symbol Int))
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((SList (Cons h (Cons nm (Cons gf _))))
        (if (is_sym h (quote claim))
          (match nm
            ((SSym cn)
             (match (claim_idx gf)
               ((Some k) (Cons (Pair cn k) (cidx rest)))
               (None (cidx rest))))
            (_ (cidx rest)))
          (cidx rest)))
       (_ (cidx rest))))))

(fn cid_find ((tbl (List (Pair Symbol Int))) (want (List Int))) (Option Int)
  (measure (struct tbl))
  (match tbl
    (Nil None)
    ((Cons e rest)
     (match e
       ((Pair n k)
        (if (chars_eq (chars_of_sym n) want) (Some k) (cid_find rest want)))))))

(type CFile (CFile (List Int) (List (Pair Symbol Int))))

(fn cf_find ((cfs (List CFile)) (p (List Int)))
  (Option (List (Pair Symbol Int)))
  (measure (struct cfs))
  (match cfs
    (Nil None)
    ((Cons c rest)
     (match c
       ((CFile q tbl) (if (chars_eq q p) (Some tbl) (cf_find rest p)))))))

;; ---- per-ARTIFACT verdict ----------------------------------------------------------

(type AV (AVOk (List Int) (List Int) Int) (AVBad (List Int)))

;; the semantic checks, fields already stripped
(fn art_sem
  ((cfs (List CFile))
   (model (List Int))
   (name (List Int))
   (cert (List Int))
   (cf (List Int))
   (md (List Int))
   (n Int))
  AV
  (if (chars_eq md model)
    (if
      (if (chars_eq cert (append_int "lowered_" name)) True
      (if (chars_eq cert (append_int "lowered_w_" name)) True
      (chars_eq cert (append_int "linked_" name))))
      (match (cf_find cfs cf)
        (None
          (AVBad
            (append_int
              name
              (append_int
                ": certfile "
                (append_int cf " is not one of the gated cert files")))))
        ((Some tbl)
         (match (cid_find tbl cert)
           (None
             (AVBad
               (append_int
                 name
                 (append_int
                   ": no claim "
                   (append_int cert (append_int " with a pinned index in " cf))))))
           ((Some k)
            (if (int_eq k n) (AVOk name cert n)
            (AVBad
              (append_int
                name
                (append_int
                  ": export=f"
                  (append_int
                    (show_int n)
                    (append_int
                      " but "
                      (append_int cert (append_int " pins index " (show_int k)))))))))))))
      (AVBad
        (append_int
          name
          (append_int
            ": cert "
            (append_int cert " is not lowered_<name> / linked_<name>")))))
    (AVBad
      (append_int
        name
        (append_int ": model " (append_int md " is not the gated model"))))))

;; positional field parse of the words AFTER the ARTIFACT keyword
(fn art_verdict ((cfs (List CFile)) (model (List Int)) (ws (List (List Int))))
  AV
  (match ws
    ((Cons name (Cons w2 (Cons w3 (Cons w4 (Cons w5 _)))))
     (match (strip_pre "cert=" w2)
       (None (AVBad (append_int name ": word 2 is not cert=...")))
       ((Some cert)
        (match (strip_pre "certfile=" w3)
          (None (AVBad (append_int name ": word 3 is not certfile=...")))
          ((Some cf)
           (match (strip_pre "model=" w4)
             (None (AVBad (append_int name ": word 4 is not model=...")))
             ((Some md)
              (match (strip_pre "export=f" w5)
                (None (AVBad (append_int name ": word 5 is not export=fN")))
                ((Some ns)
                 (match (parse_dec ns)
                   (None
                     (AVBad (append_int name ": export index is not a number")))
                   ((Some n) (art_sem cfs model name cert cf md n))))))))))))
    (_ (AVBad "malformed ARTIFACT line (fewer than 6 words)"))))

;; ---- the walk ----------------------------------------------------------------------

(type MRes (MRes Int Int (List Int)))

(fn scan_arts
  ((cfs (List CFile))
   (model (List Int))
   (ls (List (List Int)))
   (ok Int)
   (bad Int)
   (out (List Int)))
  MRes
  (measure (struct ls))
  (match ls
    (Nil (MRes ok bad out))
    ((Cons l rest)
     (if (prefix_eq "ARTIFACT " l)
       (match (words l)
         ((Cons _art ws)
          (match (art_verdict cfs model ws)
            ((AVOk name cert n)
             (scan_arts
               cfs
               model
               rest
               (+ ok 1)
               bad
               (append_int
                 out
                 (append_int
                   "BOUND         "
                   (append_int
                     name
                     (append_int
                       " -> "
                       (append_int
                         cert
                         (append_int " @f" (append_int (show_int n) (nl))))))))))
            ((AVBad msg)
             (scan_arts
               cfs
               model
               rest
               ok
               (+ bad 1)
               (append_int
                 out
                 (append_int "UNBOUND       " (append_int msg (nl))))))))
         (Nil (scan_arts cfs model rest ok bad out)))
       (scan_arts cfs model rest ok bad out)))))

;; ---- IO plumbing -------------------------------------------------------------------

(fn fail2 ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn load_cfs ((paths (List (List Int))) (acc (List CFile)) (w World))
  (Pair (Option (List CFile)) World)
  (measure (struct paths))
  (match paths
    (Nil (Pair (Some acc) w))
    ((Cons p rest)
     (match (read_file p w)
       ((Pair None w1)
        (Pair
          None
          (write (append_int "error: cannot read " (append_int p (nl))) w1)))
       ((Pair (Some src) w1)
        (match (forms_go src Nil 1000000)
          (None
            (Pair
              None
              (write (append_int "error: cannot parse " (append_int p (nl))) w1)))
          ((Some forms) (load_cfs rest (Cons (CFile p (cidx forms)) acc) w1))))))))

(fn verdict_line ((ok Int) (bad Int)) (List Int)
  (if (int_eq ok 0)
    (if (int_eq bad 0)
      (append_int "MANIFEST REFUSED: no ARTIFACT lines in the plan" (nl))
      (append_int
        "MANIFEST: 0 bound, "
        (append_int (show_int bad) (append_int " unbound" (nl)))))
    (append_int
      "MANIFEST: "
      (append_int
        (show_int ok)
        (append_int
          " bound, "
          (append_int (show_int bad) (append_int " unbound" (nl))))))))

(fn run4
  ((plan (List Int)) (model (List Int)) (certs (List (List Int))) (w World))
  World
  (match (read_file plan w)
    ((Pair None w1) (fail2 (append_int "cannot read " plan) w1))
    ((Pair (Some ptxt) w1)
     (match (load_cfs certs Nil w1)
       ((Pair None w2) (exit 2 w2))
       ((Pair (Some cfs) w2)
        (match (scan_arts cfs model (split_on 10 ptxt Nil) 0 0 "")
          ((MRes ok bad report)
           (match (write (append_int report (verdict_line ok bad)) w2)
             (w3 (exit (if (int_eq bad 0) (if (int_eq ok 0) 1 0) 1) w3))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons plan (Cons model certs))
        (match certs
          (Nil (fail2 "usage: manifest PLANTXT MODEL CERTFILE..." w1))
          ((Cons _ _) (run4 plan model certs w1))))
       (_ (fail2 "usage: manifest PLANTXT MODEL CERTFILE..." w1))))))
