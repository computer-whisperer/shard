;;; The MIXED-TIER impgen source pin (V2-5e-4): the sqmc probe body
;;; (segments + two counting loops) as a generated-leg fixture -- the
;;; compositional emitter's corpus anchor. The generated wasm out
;;; mirrors tools/impgen/blueprints/sqmc_probe.shard piece for piece.

(import "../../../kernel/stdlib.shard")
(import "../../../models/imp/imp.shard")

(use (:: models imp imp *))

(fn it_imx_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
      (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))
      (ISet 0 (IConst 1))
      (IWhile
        (ILoc 0)
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
          (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
      (ISet 0 (IConst 1))
      (IWhile
        (ILoc 0)
        (list
          (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
          (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
      (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3))))
    (ILoc 0)
    U32))

;; the CHUNK-GRAIN fixture (V2-8): two straight-line spans that cross
;; the translator's 24-statement seal points, so the generated x86
;; chain cuts mid-flat. Span A = 24 stmts ending in a store (chunk 1,
;; sealed) + 2 more with a store (chunk 2, unsealed, its RAX band tree
;; rides the dirt-free loop into the next boundary -- the pass-through
;; witness at a chunk cut); span B = 24 stmts with a store (chunk 1,
;; sealed: the next boundary enters at scratch zero) + a 2-stmt final
;; chunk walked to ground through the terminal seal.
(fn it_imxl_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
