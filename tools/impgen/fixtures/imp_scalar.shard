;;; tools/impgen/fixtures/imp_scalar.shard — imp twins of the STRAIGHT-LINE fragment
;;; (docs/IMP.md rung I0; re-landed on the v2 typed machine, §2a):
;;; representative members of the scalar fragment class
;;; (examples/wasmgen_src.shard) re-spelled as well-kinded imp
;;; functions, with spec ⊑ imp certs. THE V2 WIDTH STORY LIVES HERE,
;;; ONCE: the specs are exact unbounded-Int fns and the machine wraps
;;; to its kinds, so each cert carries FIT PREMISES (args and exact
;;; intermediates in band) discharged through the per-kind
;;; wrap-identity lemmas below — and the imp ⊑ ISA bridges downstream
;;; are UNPREMISED, because by type the two machines compute the same
;;; values (the premises that v1 restated per target live here, once).
;;;
;;; Pure-expression twins run in ONE fuel unit ((S c) — icall's
;;; statement list is empty); branching twins carry a small constant
;;; reservoir. PROOF GATES ONLY (the DI2 resolution): these certs are
;;; the whole gate; there is no engine leg at imp.

(import "../../../kernel/stdlib.shard")
(import "../../../examples/wasmgen_src.shard")
(use (:: examples wasmgen_src *))
(import "../../../models/imp/imp.shard")
(use (:: models imp imp *))
(import "../../../std/bits")
(use (:: std bits *))

;; a one-function program; the scalar twins own no memory
(fn it_prog ((f IFn)) IProg (MkIProg (list f) 0))

;; --- the wrap-identity lemmas (one per kind) ------------------------------------
;; In-band wrap is the identity — the discharge vocabulary for every
;; fit premise (the wrap32_id statement, restated over each kind's
;; modulus; machine-independent, so it lives with the twins, not with
;; any target).

(claim iwrap8_id
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 256) True)) (= (mod x 256) x))
  (div-facts
    x
    256
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 256 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 256 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim iwrap32_id
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 4294967296 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim iwrap64_id
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 18446744073709551616) True))
    (= (mod x 18446744073709551616) x))
  (div-facts
    x
    18446744073709551616
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 18446744073709551616 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 18446744073709551616 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

;; --- the twins -------------------------------------------------------------------

(fn it_add1_fn () IFn
  (MkIFn (list U32) Nil Nil (IBin U32 IAdd (ILoc 0) (IConst 1)) U32))

(fn it_add_fn () IFn
  (MkIFn (list U32 U32) Nil Nil (IBin U32 IAdd (ILoc 0) (ILoc 1)) U32))

(fn it_mix_fn () IFn
  (MkIFn
    (list U32 U32)
    Nil
    Nil
    (IBin
      U32
      IAdd
      (IBin U32 IMul (ILoc 0) (IConst 2))
      (IBin U32 ISub (ILoc 1) (ILoc 0)))
    U32))

(fn it_sel_fn () IFn
  (MkIFn
    (list U32 U32)
    (list U32)
    (list
      (IIf
        (IBin U32 IEq (ILoc 0) (IConst 0))
        (list (ISet 2 (IBin U32 IAdd (ILoc 1) (IConst 1))))
        (list (ISet 2 (IBin U32 IMul (ILoc 1) (IConst 2))))))
    (ILoc 2)
    U32))

(fn it_clamp2_fn () IFn
  (MkIFn
    (list U32)
    (list U32)
    (list
      (IIf
        (IBin U32 ILt (ILoc 0) (IConst 10))
        (list (ISet 1 (IConst 0)))
        (list
          (IIf
            (IBin U32 ILt (ILoc 0) (IConst 100))
            (list (ISet 1 (IConst 1)))
            (list (ISet 1 (IConst 2)))))))
    (ILoc 1)
    U32))

(fn it_divq_fn () IFn
  (MkIFn (list U32 U32) Nil Nil (IBin U32 IDiv (ILoc 0) (ILoc 1)) U32))

(fn it_shr3_fn () IFn
  (MkIFn (list U32) Nil Nil (IBin U32 IShr (ILoc 0) (IConst 3)) U32))

(fn it_shl4_fn () IFn
  (MkIFn (list U32) Nil Nil (IBin U32 IShl (ILoc 0) (IConst 4)) U32))

(fn it_rotr7_fn () IFn
  (MkIFn (list U32) Nil Nil (IRotr U32 (ILoc 0) (IConst 7)) U32))

(fn it_chset_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    (list U32)
    (list
      (ISet
        3
        (IBin
          U32
          IXor
          (IBin U32 IAnd (ILoc 0) (ILoc 1))
          (IBin U32 IAnd (IBin U32 IXor (ILoc 0) (IConst 4294967295)) (ILoc 2)))))
    (ILoc 3)
    U32))

;; the conversion twins — the crystallization points made programs
(fn it_tob_fn () IFn (MkIFn (list U32) Nil Nil (ITrunc U32 U8 (ILoc 0)) U8))

(fn it_ext_fn () IFn (MkIFn (list U8) Nil Nil (IExt U8 U32 (ILoc 0)) U32))

;; the U64 twin — same vocabulary, different crystallized kind; native
;; on both targets since the wasm i64 tier landed (V2-2c)
(fn it_addq_fn () IFn
  (MkIFn (list U64 U64) Nil Nil (IBin U64 IAdd (ILoc 0) (ILoc 1)) U64))

;; the downward conversion out of U64 — the zero-extending 32-bit mov
;; on x86, the band-spelled i32.wrap_i64 on wasm
(fn it_tow_fn () IFn (MkIFn (list U64) Nil Nil (ITrunc U64 U32 (ILoc 0)) U32))

;; the upward conversion into U64 — on wasm the one conversion that
;; emits a real instruction (i64.extend_i32_u); on x86 a no-op
(fn it_extq_fn () IFn (MkIFn (list U32) Nil Nil (IExt U32 U64 (ILoc 0)) U64))

;; the direct U64→U8 narrowing — x86's And-255 serves any source
;; width; wasm refuses it (no single band-spelled emission there —
;; named growth): the conversion asymmetry
(fn it_tobq_fn () IFn (MkIFn (list U64) Nil Nil (ITrunc U64 U8 (ILoc 0)) U8))

;; the U64 rotation — native on wasm (i64.rotr, band-spelled both
;; sides); x86 refuses it (the 32-bit composition does not scale to
;; the width that IS the register): the rotate asymmetry
(fn it_rotrq_fn () IFn
  (MkIFn (list U64) Nil Nil (IRotr U64 (ILoc 0) (IConst 7)) U64))

;; the U64 gate: the branching twin at the wide kind — pins fused
;; U64 conditions on both targets
(fn it_selq_fn () IFn
  (MkIFn
    (list U64 U64)
    (list U64)
    (list
      (IIf
        (IBin U64 IEq (ILoc 0) (IConst 0))
        (list (ISet 2 (IBin U64 IAdd (ILoc 1) (IConst 1))))
        (list (ISet 2 (IBin U64 IMul (ILoc 1) (IConst 2))))))
    (ILoc 2)
    U64))

;; the wide twin: seven locals — the first consumer of the x86 home
;; file past the six SysV argument registers (body local 6 lives in a
;; callee-saved home)
(fn it_wide_fn () IFn
  (MkIFn
    (list U32 U32)
    (list U32 U32 U32 U32 U32)
    (list (ISet 6 (IBin U32 IAdd (ILoc 0) (ILoc 1))))
    (ILoc 6)
    U32))

;; --- the certs: spec ⊑ imp, fit premises once ------------------------------------

(claim imp_lg_add1
  (goal ((x Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 (+ x 1)) True)
     (= (lt (+ x 1) 4294967296) True))
    (= (icall (S c) (it_prog (it_add1_fn)) 0 (list x)) (Some (lg_add1 x))))
  (chain
    (steps ((compute lhs) (unfold lg_add1 rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hr (= (mod (+ x 1) 4294967296) (+ x 1))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (+ x 1)))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hr) lr lhs true ())))
    refl))

(claim imp_lg_add
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 y) True)
     (= (lt y 4294967296) True)
     (= (le 0 (+ x y)) True)
     (= (lt (+ x y) 4294967296) True))
    (= (icall (S c) (it_prog (it_add_fn)) 0 (list x y)) (Some (lg_add x y))))
  (chain
    (steps ((compute lhs) (unfold lg_add rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hy (= (mod y 4294967296) y)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr lhs true ())))
    (have hr (= (mod (+ x y) 4294967296) (+ x y))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (+ x y)))
        ((steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hr) lr lhs true ())))
    refl))

(claim imp_lg_mix
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 y) True)
     (= (lt y 4294967296) True)
     (= (le 0 (* x 2)) True)
     (= (lt (* x 2) 4294967296) True)
     (= (le 0 (- y x)) True)
     (= (lt (- y x) 4294967296) True)
     (= (le 0 (+ (* x 2) (- y x))) True)
     (= (lt (+ (* x 2) (- y x)) 4294967296) True))
    (= (icall (S c) (it_prog (it_mix_fn)) 0 (list x y)) (Some (lg_mix x y))))
  (chain
    (steps ((compute lhs) (unfold lg_mix rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hy (= (mod y 4294967296) y)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr lhs true ())))
    (have h1 (= (mod (* x 2) 4294967296) (* x 2))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (* x 2)))
        ((steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise h1) lr lhs true ())))
    (have h2 (= (mod (- y x) 4294967296) (- y x))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (- y x)))
        ((steps ((rewrite (premise 6) lr lhs true ())) refl)
         (steps ((rewrite (premise 7) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise h2) lr lhs true ())))
    (have h3 (= (mod (+ (* x 2) (- y x)) 4294967296) (+ (* x 2) (- y x)))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (+ (* x 2) (- y x))))
        ((steps ((rewrite (premise 8) lr lhs true ())) refl)
         (steps ((rewrite (premise 9) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise h3) lr lhs true ())))
    refl))

;; the gate: branch-conditional fit premises (each branch's wrap
;; residues are priced only when that branch runs — the §6j premise
;; discipline, unchanged from the v1 era, just relocated here)
(claim imp_lg_sel
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 y) True)
     (= (lt y 4294967296) True)
     (= (if (int_eq x 0) (le 0 (+ y 1)) True) True)
     (= (if (int_eq x 0) (lt (+ y 1) 4294967296) True) True)
     (= (if (int_eq x 0) True (le 0 (* y 2))) True)
     (= (if (int_eq x 0) True (lt (* y 2) 4294967296)) True))
    (= (icall (S^ 8 c) (it_prog (it_sel_fn)) 0 (list x y)) (Some (lg_sel x y))))
  (chain
    (steps ((compute lhs) (unfold lg_sel rhs) (reduce rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr both true ())))
    (have hy (= (mod y 4294967296) y)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr both true ())))
    (case-on (int_eq x 0) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           (have p0 (= (le 0 (+ y 1)) True)
             (chain
               (steps
                 ((rewrite (premise 4) rl rhs true ())
                  (rewrite (hyp True) lr rhs true ())
                  (compute rhs)))
               refl))
           (have p1 (= (lt (+ y 1) 4294967296) True)
             (chain
               (steps
                 ((rewrite (premise 5) rl rhs true ())
                  (rewrite (hyp True) lr rhs true ())
                  (compute rhs)))
               refl))
           (have w2 (= (mod (+ y 1) 4294967296) (+ y 1))
             (rewrite-with
               (lemma iwrap32_id)
               lr
               lhs
               ((inst x (+ y 1)))
               ((steps ((rewrite (premise p0) lr lhs true ())) refl)
                (steps ((rewrite (premise p1) lr lhs true ())) refl))
               refl))
           (steps ((rewrite (premise w2) lr lhs true ())))
           refl))
       (case False
         (chain
           (steps ((rewrite (hyp False) lr both true ()) (compute both)))
           (have p3 (= (le 0 (* y 2)) True)
             (chain
               (steps
                 ((rewrite (premise 6) rl rhs true ())
                  (rewrite (hyp False) lr rhs true ())
                  (compute rhs)))
               refl))
           (have p4 (= (lt (* y 2) 4294967296) True)
             (chain
               (steps
                 ((rewrite (premise 7) rl rhs true ())
                  (rewrite (hyp False) lr rhs true ())
                  (compute rhs)))
               refl))
           (have w5 (= (mod (* y 2) 4294967296) (* y 2))
             (rewrite-with
               (lemma iwrap32_id)
               lr
               lhs
               ((inst x (* y 2)))
               ((steps ((rewrite (premise p3) lr lhs true ())) refl)
                (steps ((rewrite (premise p4) lr lhs true ())) refl))
               refl))
           (steps ((rewrite (premise w5) lr lhs true ())))
           refl))))))

;; every branch assigns a literal — after the arg banding collapses,
;; no wrap residue exists anywhere
(claim imp_lg_clamp2
  (goal ((x Int) (c Nat)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (=
      (icall (S^ 10 c) (it_prog (it_clamp2_fn)) 0 (list x))
      (Some (lg_clamp2 x))))
  (chain
    (steps ((compute lhs) (unfold lg_clamp2 rhs) (reduce rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr both true ())))
    (case-on (lt x 10) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           refl))
       (case False
         (chain
           (steps ((rewrite (hyp False) lr both true ()) (compute both)))
           (case-on (lt x 100) Bool
             ((case True
                (chain
                  (steps ((rewrite (hyp True) lr both true ()) (compute both)))
                  refl))
              (case False
                (chain
                  (steps ((rewrite (hyp False) lr both true ()) (compute both)))
                  refl))))))))))

;; the honest corner: division carries its divisor premise (and the
;; quotient of in-band operands is in band — no result premise)
(claim imp_lg_divq
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 y) True)
     (= (lt y 4294967296) True)
     (= (le 1 y) True))
    (= (icall (S c) (it_prog (it_divq_fn)) 0 (list x y)) (Some (lg_divq x y))))
  (chain
    (steps ((compute lhs) (unfold lg_divq rhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hy (= (mod y 4294967296) y)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr lhs true ())))
    (steps ((rewrite (premise 4) lr lhs true ()) (compute lhs)))
    refl))

;; ---- the shift/rotate twins ------------------------------------------------------
;; Ground counts (the wk fence). shr cannot leave the band; shl wraps,
;; so it carries the one result premise; the rotation cert states the
;; band-spelled containment the machine computes — the same spelling
;; the sha-class specs use.

(claim imp_lg_shr3
  (goal ((x Int) (c Nat)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (icall (S c) (it_prog (it_shr3_fn)) 0 (list x)) (Some (bshr x 3))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    refl))

(claim imp_lg_shl4
  (goal ((x Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 (bshl x 4)) True)
     (= (lt (bshl x 4) 4294967296) True))
    (= (icall (S c) (it_prog (it_shl4_fn)) 0 (list x)) (Some (bshl x 4))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hr (= (mod (bshl x 4) 4294967296) (bshl x 4))
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x (bshl x 4)))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hr) lr lhs true ())))
    refl))

(claim imp_lg_rotr7
  (goal ((x Int) (c Nat)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (=
      (icall (S c) (it_prog (it_rotr7_fn)) 0 (list x))
      (Some (band (bor (bshr x 7) (bshl x 25)) 4294967295))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hb (= (band x 4294967295) (mod x 4294967296))
      (rewrite-with
        (lemma mask_word32)
        lr
        lhs
        ()
        ((steps ((rewrite (premise 0) lr lhs true ())) refl))
        refl))
    (steps
      ((rewrite (premise hb) lr lhs true ())
       (rewrite (premise hx) lr lhs true ())))
    refl))

;; ---- the statement-position expression twin --------------------------------------
;; A ch-shaped tree assigned to an extra local; every op is
;; band-closed, so after the arg banding collapses no wrap remains.

(claim imp_lg_chset
  (goal ((x Int) (y Int) (z Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 4294967296) True)
     (= (le 0 y) True)
     (= (lt y 4294967296) True)
     (= (le 0 z) True)
     (= (lt z 4294967296) True))
    (=
      (icall (S^ 8 c) (it_prog (it_chset_fn)) 0 (list x y z))
      (Some (bxor (band x y) (band (bxor x 4294967295) z)))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 4294967296) x)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hy (= (mod y 4294967296) y)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr lhs true ())))
    (have hz (= (mod z 4294967296) z)
      (rewrite-with
        (lemma iwrap32_id)
        lr
        lhs
        ((inst x z))
        ((steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hz) lr lhs true ())))
    refl))

;; ---- the conversion twins ---------------------------------------------------------

