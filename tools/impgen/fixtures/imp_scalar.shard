(claim imp_lg_tob
  (goal ((x Int) (c Nat)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (icall (S c) (it_prog (it_tob_fn)) 0 (list x)) (Some (band x 255))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 4294967296) x)
