        (lemma iwrap32_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    refl))

;; zero-extension: the value identity
(claim imp_lg_ext
  (goal ((x Int) (c Nat)) ((= (le 0 x) True) (= (lt x 256) True))
    (= (icall (S c) (it_prog (it_ext_fn)) 0 (list x)) (Some x)))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 256) x)
      (rewrite-with
        (lemma iwrap8_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    refl))

;; the U64 leg: the same add shape at the wider kind, fit premises in
;; ITS modulus — one twin vocabulary, two crystallized kinds
(claim imp_lg_addq
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 18446744073709551616) True)
     (= (le 0 y) True)
     (= (lt y 18446744073709551616) True)
     (= (le 0 (+ x y)) True)
     (= (lt (+ x y) 18446744073709551616) True))
    (= (icall (S c) (it_prog (it_addq_fn)) 0 (list x y)) (Some (+ x y))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 18446744073709551616) x)
      (rewrite-with
        (lemma iwrap64_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr lhs true ())))
    (have hy (= (mod y 18446744073709551616) y)
      (rewrite-with
        (lemma iwrap64_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr lhs true ())))
    (have hr (= (mod (+ x y) 18446744073709551616) (+ x y))
      (rewrite-with
        (lemma iwrap64_id)
        lr
        lhs
        ((inst x (+ x y)))
        ((steps ((rewrite (premise 4) lr lhs true ())) refl)
         (steps ((rewrite (premise 5) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hr) lr lhs true ())))
    refl))

