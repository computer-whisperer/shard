;; the U64 rotation: the band-spelled containment at the wide width
(claim imp_lg_rotrq
  (goal ((x Int) (c Nat))
    ((= (le 0 x) True) (= (lt x 18446744073709551616) True))
    (=
      (icall (S c) (it_prog (it_rotrq_fn)) 0 (list x))
      (Some (band (bor (bshr x 7) (bshl x 57)) 18446744073709551615))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 18446744073709551616) x)
      (rewrite-with
        (lemma iwrap64_id)
