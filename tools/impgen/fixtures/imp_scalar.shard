;; the U64 gate: branch-conditional fit premises at the wide kind —
;; the §6j discipline, kind-substituted
(claim imp_lg_selq
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 x) True)
     (= (lt x 18446744073709551616) True)
     (= (le 0 y) True)
     (= (lt y 18446744073709551616) True)
     (= (if (int_eq x 0) (le 0 (+ y 1)) True) True)
     (= (if (int_eq x 0) (lt (+ y 1) 18446744073709551616) True) True)
     (= (if (int_eq x 0) True (le 0 (* y 2))) True)
     (= (if (int_eq x 0) True (lt (* y 2) 18446744073709551616)) True))
    (=
      (icall (S^ 8 c) (it_prog (it_selq_fn)) 0 (list x y))
      (Some (if (int_eq x 0) (+ y 1) (* y 2)))))
  (chain
    (steps ((compute lhs)))
    (have hx (= (mod x 18446744073709551616) x)
      (rewrite-with
        (lemma iwrap64_id)
        lr
        lhs
        ((inst x x))
        ((steps ((rewrite (premise 0) lr lhs true ())) refl)
         (steps ((rewrite (premise 1) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hx) lr both true ())))
    (have hy (= (mod y 18446744073709551616) y)
      (rewrite-with
        (lemma iwrap64_id)
        lr
        lhs
        ((inst x y))
        ((steps ((rewrite (premise 2) lr lhs true ())) refl)
         (steps ((rewrite (premise 3) lr lhs true ())) refl))
        refl))
    (steps ((rewrite (premise hy) lr both true ())))
    (case-on (int_eq x 0) Bool
      ((case True
         (chain
           (steps ((rewrite (hyp True) lr both true ()) (compute both)))
           (have p0 (= (le 0 (+ y 1)) True)
             (chain
               (steps
                 ((rewrite (premise 4) rl rhs true ())
                  (rewrite (hyp True) lr rhs true ())
                  (compute rhs)))
               refl))
           (have p1 (= (lt (+ y 1) 18446744073709551616) True)
             (chain
               (steps
                 ((rewrite (premise 5) rl rhs true ())
                  (rewrite (hyp True) lr rhs true ())
                  (compute rhs)))
               refl))
           (have w2 (= (mod (+ y 1) 18446744073709551616) (+ y 1))
             (rewrite-with
               (lemma iwrap64_id)
               lr
               lhs
               ((inst x (+ y 1)))
               ((steps ((rewrite (premise p0) lr lhs true ())) refl)
                (steps ((rewrite (premise p1) lr lhs true ())) refl))
               refl))
           (steps ((rewrite (premise w2) lr lhs true ())))
           refl))
       (case False
         (chain
           (steps ((rewrite (hyp False) lr both true ()) (compute both)))
           (have p3 (= (le 0 (* y 2)) True)
             (chain
               (steps
                 ((rewrite (premise 6) rl rhs true ())
                  (rewrite (hyp False) lr rhs true ())
                  (compute rhs)))
               refl))
           (have p4 (= (lt (* y 2) 18446744073709551616) True)
             (chain
               (steps
                 ((rewrite (premise 7) rl rhs true ())
                  (rewrite (hyp False) lr rhs true ())
                  (compute rhs)))
               refl))
           (have w5 (= (mod (* y 2) 18446744073709551616) (* y 2))
             (rewrite-with
               (lemma iwrap64_id)
               lr
               lhs
               ((inst x (* y 2)))
               ((steps ((rewrite (premise p3) lr lhs true ())) refl)
                (steps ((rewrite (premise p4) lr lhs true ())) refl))
               refl))
           (steps ((rewrite (premise w5) lr lhs true ())))
           refl))))))

