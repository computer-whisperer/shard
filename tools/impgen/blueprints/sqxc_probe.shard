;;; DEV PROBE (the x86 compositional leg): the mixed tier at the
;;; register machine. The wasm design (sqmc_probe) factors segments
;;; into standalone lemmas joined by ist_seam/es_scont; that factoring
;;; cannot cross to x86 without the generator learning machine
;;; semantics (a segment lemma's continuation must RECONSTRUCT the
;;; register file, and the three scratch registers carry concrete
;;; trees between pieces that only the checker should compute). The
;;; x86 leg instead cuts the chain at LOOP EXITS ONLY: each boundary
;;; lemma walks its flat segment INLINE by the statement-tier split
;;; spine (scratch states stay concrete all the way), cites the
;;; counter-tied worker at its loop head, exposes the exit locals by
;;; il_wlen, and hands the exposed state to the next boundary lemma.
;;;
;;; Scratch discipline: a loop's ix_zs seals zero exactly what its
;;; body dirties, so scratch the body never touches PASSES THROUGH a
;;; loop -- the worker quantifies those slots and ix_mout (to_x86's
;;; mixed-grain exit adapter) restores them; body-dirtied slots are
;;; literal 0. Boundary lemmas quantify the seal-set slots (the
;;; terminal ix_zs zeroes them before the final XNorm) and spell 0 in
;;; registers the body never writes. All bindings happen by matching
;;; -- no emission-side knowledge of the scratch trees.
;;;
;;; The program is tools/impgen/fixtures/imp_mixed.shard's it_imx_fn verbatim
;;; (sqxc_srctie pins it): loop 1 has a scratch-clean body (RAX
;;; carries s2's store band THROUGH it -- the pass-through witness),
;;; loop 2 dirties RAX (sealed at entry and back-edge) and stores
;;; through a symbolic address (the per-iteration guard-split
;;; witness).

(import "../../../kernel/stdlib.shard")
(import "../../../models/imp/imp.shard")
(import "../../../models/x86/x86.shard")
(import "../../../models/imp/to_x86.shard")
(import "../../../models/wasm/loopkit.shard")
(import "../../../std/nat.shard")
(import "../../../std/mem")
(import "../fixtures/imp_mixed.shard")

(use (:: models imp imp *))
(use (:: models x86 x86 *))
(use (:: models imp to_x86 *))
(use (:: models wasm loopkit *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: tools impgen fixtures imp_mixed *))

;; --- the program (local copies; (inline F) resolves file-locally) ----

(fn sqxc_bi () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqxc_bx () (List XInstr)
  (list
    (XBin32 XAdd RSI (SImm 5))
    (XMovRR RAX RSI)
    (XBin XAnd RAX (SImm 255))
    (XStore8 (AReg RDX) (SReg RAX))
    (XMovRI RDI 1)
    (XBlock
      (list
        (XLoop
          (list
            (XBrIf (CEqz RDI) 1)
            (XBin32 XAdd RSI (SImm 1))
            (XBin32 XSub RDI (SImm 1))
            (XBr 0)))))
    (XBin32 XAdd RSI (SImm 7))
    (XMovRI RDI 1)
    (XMovRI RAX 0)
    (XBlock
      (list
        (XLoop
          (list
            (XBrIf (CEqz RDI) 1)
            (XMovRR RAX RDX)
            (XBin XAnd RAX (SImm 255))
            (XStore8 (AReg RSI) (SReg RAX))
            (XBin32 XSub RDI (SImm 1))
            (XMovRI RAX 0)
            (XBr 0)))))
    (XBin32 XAdd RDX (SImm 3))
    (XMovRI RAX 0)))

;; loop bodies (worker subjects)
(fn sqxc_l1i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
    (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))

(fn sqxc_l1x () (List XInstr)
  (list
    (XBrIf (CEqz RDI) 1)
    (XBin32 XAdd RSI (SImm 1))
    (XBin32 XSub RDI (SImm 1))
    (XBr 0)))

(fn sqxc_l2i () (List IStmt)
  (list
    (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
    (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))

(fn sqxc_l2x () (List XInstr)
  (list
    (XBrIf (CEqz RDI) 1)
    (XMovRR RAX RDX)
    (XBin XAnd RAX (SImm 255))
    (XStore8 (AReg RSI) (SReg RAX))
    (XBin32 XSub RDI (SImm 1))
    (XMovRI RAX 0)
    (XBr 0)))

;; boundary tails (rest fns; spelled literally -- inline never nests)
(fn sqxc_r1i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 0 (IConst 1))
    (IWhile
      (ILoc 0)
      (list
        (IStore (ILoc 1) (ITrunc U32 U8 (ILoc 2)))
        (ISet 0 (IBin U32 ISub (ILoc 0) (IConst 1)))))
    (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqxc_r1x () (List XInstr)
  (list
    (XBin32 XAdd RSI (SImm 7))
    (XMovRI RDI 1)
    (XMovRI RAX 0)
    (XBlock
      (list
        (XLoop
          (list
            (XBrIf (CEqz RDI) 1)
            (XMovRR RAX RDX)
            (XBin XAnd RAX (SImm 255))
            (XStore8 (AReg RSI) (SReg RAX))
            (XBin32 XSub RDI (SImm 1))
            (XMovRI RAX 0)
            (XBr 0)))))
    (XBin32 XAdd RDX (SImm 3))
    (XMovRI RAX 0)))

(fn sqxc_r2i () (List IStmt)
  (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 3)))))

(fn sqxc_r2x () (List XInstr) (list (XBin32 XAdd RDX (SImm 3)) (XMovRI RAX 0)))

;; --- ties: the local copies ARE the program and its translation ------

(claim sqxc_srctie
  (goal () () (= (ibody_of (it_imx_fn)) (inline sqxc_bi)))
  (steps ((compute both)) refl))

(claim sqxc_tie
  (goal () () (= (ix_sstmts (inline sqxc_bi)) (Some (inline sqxc_bx))))
  (steps ((compute both)) refl))

;; --- the per-file width twin (the generated-file shape) --------------

(claim sqxc_wid
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 4294967296 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

;; --- the counter-tied workers ----------------------------------------

;; loop 1: scratch-clean body -- all three scratch slots pass through
;; (za zb zc quantified on both sides; ix_mout restores them at exit)
(claim sqxc_wk1
  (goal
    ((x1 Int)
     (x2 Int)
     (za Int)
     (zb Int)
     (zc Int)
     (k Nat)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (xeval_loop
        (S^ 8 (lg_fuel k c))
        (MkXModule restfs 0 65536)
        (inline sqxc_l1x)
        (MkRegs za 0 x2 0 0 x1 (int_of_nat k) 0 0 zb zc 0 0 0 0)
        m)
      (ix_mout
        za
        zb
        zc
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 0)
          (inline sqxc_l1i)
          (list (int_of_nat k) x1 x2)
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold xeval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
           (rewrite-with (lemma lg_sub) lr lhs () () refl))
         (steps ((rewrite (premise hsub) lr both true ())))
         (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
           (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl))
         (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
           (steps
             ((rewrite (premise hs1) rl lhs true ())
              (rewrite (premise 0) lr lhs true ()))
             refl))
         (have hcap (= (lt (int_of_nat k2) 4294967296) True)
           (steps () (by arith (rows (goal 1) (hks 1)))))
         (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
           (rewrite-with
             (lemma sqxc_wid)
             lr
             lhs
             ((inst x (int_of_nat k2)))
             ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)
              (steps ((rewrite (premise hcap) lr lhs true ())) refl))
             refl))
         (steps ((rewrite (premise hwk) lr both true ())))
         (rewrite-with
           (hyp 0)
           lr
           lhs
           ((inst c2 c2))
           ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
         refl)))))

;; --- boundary 2: the final segment (za dies at the terminal seal) ----

(claim sqxc_b2
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (za Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 6 c)
        (MkXModule restfs 0 65536)
        (inline sqxc_r2x)
        (MkRegs za 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 5 c2) 65536 (inline sqxc_r2i) (list x0 x1 x2) m))))
  (steps ((compute both)) refl))

;; loop 2: the body dirties RAX (sealed at entry + back-edge, so the
;; rax slot is literal 0 in the induction); r10/r11 pass through; the
;; per-iteration store splits on the symbolic address exactly as the
;; statement tier does (shared low guard, le-pair bridge at the arm's
;; polarity)
(claim sqxc_wk2
  (goal
    ((x1 Int)
     (x2 Int)
     (zb Int)
     (zc Int)
     (k Nat)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ((= (lt (int_of_nat k) 4294967296) True))
    (=
      (xeval_loop
        (S^ 11 (lg_fuel k c))
        (MkXModule restfs 0 65536)
        (inline sqxc_l2x)
        (MkRegs 0 0 x2 0 0 x1 (int_of_nat k) 0 0 zb zc 0 0 0 0)
        m)
      (ix_mout
        0
        zb
        zc
        (iwhile
          (S^ 9 (lg_fuel k c2))
          65536
          (ILoc 0)
          (inline sqxc_l2i)
          (list (int_of_nat k) x1 x2)
          m))))
  (induct k
    ((case Z
       (steps
         ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both))
         refl))
     (case S
       (k2)
       (chain
         (steps
           ((unfold lg_fuel lhs)
            (reduce lhs)
            (unfold lg_fuel rhs)
            (reduce rhs)
            (unfold xeval_loop lhs)
            (unfold iwhile rhs)
            (rewrite (lemma int_of_nat_succ) lr both true ())
            (compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (rewrite-with
           (lemma lg_ne)
           lr
           lhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (rewrite-with
           (lemma lg_ne)
           lr
           rhs
           ()
           ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)))
         (steps ((compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
         (case-on (le 0 x1) Bool
           ((case True
              (chain
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop xeval_loop iwhile lg_fuel ix_mout))))
                (case-on (lt x1 65536) Bool
                  ((case True
                     (chain
                       (have hlt2 (= (lt x1 65536) True)
                         (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                       (have hle2 (= (le (+ x1 1) 65536) True)
                         (steps () (by arith (rows (goal 1) (hlt2 1)))))
                       (steps
                         ((rewrite (hyp 0) lr rhs true ())
                          (rewrite (premise hle2) lr lhs true ())
                          (compute
                            both
                            (stop xeval_loop iwhile lg_fuel ix_mout))))
                       (have hsub
                         (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2))
                         (rewrite-with (lemma lg_sub) lr lhs () () refl))
                       (steps ((rewrite (premise hsub) lr both true ())))
                       (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2)))
                         (steps
                           ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                           refl))
                       (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True)
                         (steps
                           ((rewrite (premise hs1) rl lhs true ())
                            (rewrite (premise 0) lr lhs true ()))
                           refl))
                       (have hcap (= (lt (int_of_nat k2) 4294967296) True)
                         (steps () (by arith (rows (goal 1) (hks 1)))))
                       (have hwk
                         (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2))
                         (rewrite-with
                           (lemma sqxc_wid)
                           lr
                           lhs
                           ((inst x (int_of_nat k2)))
                           ((rewrite-with
                              (lemma int_of_nat_nonneg)
                              lr
                              lhs
                              ()
                              ()
                              refl)
                            (steps
                              ((rewrite (premise hcap) lr lhs true ()))
                              refl))
                           refl))
                       (steps ((rewrite (premise hwk) lr both true ())))
                       (rewrite-with
                         (hyp 2)
                         lr
                         lhs
                         ((inst c2 c2))
                         ((steps ((rewrite (premise hcap) lr lhs true ())) refl)))
                       refl))
                   (case False
                     (chain
                       (have hlt2 (= (lt x1 65536) False)
                         (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                       (have hle2 (= (le (+ x1 1) 65536) False)
                         (steps () (by arith (rows (goal 1) (hlt2 1)))))
                       (steps
                         ((rewrite (hyp 0) lr rhs true ())
                          (rewrite (premise hle2) lr lhs true ())
                          (compute both (stop lg_fuel))))
                       refl))))))
            (case False
              (chain
                (steps
                  ((rewrite (hyp 0) lr both true ())
                   (compute both (stop lg_fuel))))
                refl)))))))))

;; --- boundary 1: segment [s4 s5] walked inline, loop 2 by worker,
;; --- il_wlen exposure at the exit, boundary 2 cited at the leaf ------

(claim sqxc_b1
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (za Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 21 c)
        (MkXModule restfs 0 65536)
        (inline sqxc_r1x)
        (MkRegs za 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 16 c2) 65536 (inline sqxc_r1i) (list x0 x1 x2) m))))
  (chain
    (steps ((compute both (stop xeval_loop iwhile lg_fuel int_of_nat))))
    (have hi1 (= (int_of_nat 1) 1)
      (chain
        (have ha1 (= (int_of_nat 1) (int_of_nat (S^ 1 Z)))
          (steps ((compute both)) refl))
        (steps
          ((rewrite (premise ha1) lr lhs true ())
           (rewrite (lemma int_of_nat_succ) lr lhs true ())
           (rewrite (lemma int_of_nat_zero) lr lhs true ())
           (compute lhs)))
        refl))
    (have hrg
      (=
        (MkRegs
          0
          0
          x2
          0
          0
          (mod (+ x1 7) 4294967296)
          (int_of_nat 1)
          0
          0
          0
          0
          0
          0
          0
          0)
        (MkRegs 0 0 x2 0 0 (mod (+ x1 7) 4294967296) 1 0 0 0 0 0 0 0 0))
      (steps ((rewrite (premise hi1) lr lhs true ())) refl))
    (have hlc
      (=
        (list (int_of_nat 1) (mod (+ x1 7) 4294967296) x2)
        (list 1 (mod (+ x1 7) 4294967296) x2))
      (steps ((rewrite (premise hi1) lr lhs true ())) refl))
    (steps
      ((rewrite (premise hrg) rl lhs true ())
       (rewrite (premise hlc) rl rhs true ())))
    (have hfm (= (S^ 14 c) (S^ 11 (lg_fuel 1 (S^ 2 c))))
      (steps ((compute both)) refl))
    (have hfi (= (S^ 12 c2) (S^ 9 (lg_fuel 1 (S^ 2 c2))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hfm) lr lhs true ())
       (rewrite (premise hfi) lr rhs true ())))
    (rewrite-with
      (lemma sqxc_wk2)
      lr
      lhs
      ((inst c2 (S^ 2 c2)))
      ((steps ((rewrite (premise hi1) lr lhs true ()) (compute lhs)) refl)))
    (case-on
      (iwhile
        (S^ 9 (lg_fuel 1 (S^ 2 c2)))
        65536
        (ILoc 0)
        (inline sqxc_l2i)
        (list (int_of_nat 1) (mod (+ x1 7) 4294967296) x2)
        m)
      Option
      ((case None
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute both (stop lg_fuel int_of_nat))))
           refl))
       (case Some
         (o2)
         (chain
           (steps ((rewrite (hyp 0) lr both true ())))
           (case-on o2 IOut
             ((case INorm
                (lc2 mm2)
                (chain
                  (steps ((rewrite (hyp 0) lr both true ())))
                  (have hc2i (= (lg_fuel 1 (S^ 2 c2)) (S^ 3 c2))
                    (steps ((compute both)) refl))
                  (have hc2m (= (lg_fuel 1 (S^ 2 c)) (S^ 3 c))
                    (steps ((compute both)) refl))
                  (steps
                    ((rewrite (premise hc2i) lr both true ())
                     (rewrite (premise hc2m) lr both true ())
                     (compute
                       both
                       (stop xeval_seq istmts xeval_loop iwhile lg_fuel
                         int_of_nat))))
                  (case-on lc2 List
                    ((case Nil
                       (chain
                         (have hbad
                           (=
                             (iolen
                               (ilen
                                 (list
                                   (int_of_nat 1)
                                   (mod (+ x1 7) 4294967296)
                                   x2))
                               (Some (INorm lc2 mm2)))
                             3)
                           (chain
                             (steps
                               ((rewrite (hyp 1) rl lhs true ())
                                (rewrite (hyp 2) rl lhs true ())))
                             (rewrite-with (lemma il_wlen) lr lhs () ())
                             (steps ((compute lhs)))
                             refl))
                         (have hlen
                           (=
                             (iolen
                               (ilen
                                 (list
                                   (int_of_nat 1)
                                   (mod (+ x1 7) 4294967296)
                                   x2))
                               (Some (INorm lc2 mm2)))
                             (ilen lc2))
                           (steps ((compute both)) refl))
                         (have hg (= (ilen lc2) 3)
                           (steps
                             ((rewrite (premise hlen) rl lhs true ())
                              (rewrite (premise hbad) lr lhs true ()))
                             refl))
                         (have hs (= (ilen lc2) 0)
                           (steps
                             ((rewrite (hyp 0) lr lhs true ()) (compute lhs))
                             refl))
                         (have hff (= (le 0 0) False)
                           (steps () (by arith (rows (goal 1) (hg 1) (hs -1)))))
                         (absurd (premise hff))))
                     (case Cons
                       (e0 r0)
                       (chain
                         (steps
                           ((rewrite (hyp 0) lr both true ())
                            (compute
                              both
                              (stop xeval_seq istmts xeval_loop iwhile lg_fuel
                                int_of_nat))))
                         (case-on r0 List
                           ((case Nil
                              (chain
                                (have hbad
                                  (=
                                    (iolen
                                      (ilen
                                        (list
                                          (int_of_nat 1)
                                          (mod (+ x1 7) 4294967296)
                                          x2))
                                      (Some (INorm lc2 mm2)))
                                    3)
                                  (chain
                                    (steps
                                      ((rewrite (hyp 2) rl lhs true ())
                                       (rewrite (hyp 3) rl lhs true ())))
                                    (rewrite-with (lemma il_wlen) lr lhs () ())
                                    (steps ((compute lhs)))
                                    refl))
                                (have hlen
                                  (=
                                    (iolen
                                      (ilen
                                        (list
                                          (int_of_nat 1)
                                          (mod (+ x1 7) 4294967296)
                                          x2))
                                      (Some (INorm lc2 mm2)))
                                    (ilen lc2))
                                  (steps ((compute both)) refl))
                                (have hg (= (ilen lc2) 3)
                                  (steps
                                    ((rewrite (premise hlen) rl lhs true ())
                                     (rewrite (premise hbad) lr lhs true ()))
                                    refl))
                                (have hs (= (ilen lc2) 1)
                                  (steps
                                    ((rewrite (hyp 1) lr lhs true ())
                                     (rewrite (hyp 0) lr lhs true ())
                                     (compute lhs))
                                    refl))
                                (have hff (= (le 0 0) False)
                                  (steps
                                    ()
                                    (by arith (rows (goal 1) (hg 1) (hs -1)))))
                                (absurd (premise hff))))
                            (case Cons
                              (e1 r1)
                              (chain
                                (steps
                                  ((rewrite (hyp 0) lr both true ())
                                   (compute
                                     both
                                     (stop xeval_seq istmts xeval_loop iwhile
                                       lg_fuel int_of_nat))))
                                (case-on r1 List
                                  ((case Nil
                                     (chain
