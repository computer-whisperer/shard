;; --- V2-8: the seal-point segment sub-lemma + composition ------------
;; A 26-statement straight-line body chunks at the translator's
;; seal-point grid (24 + 2, one store in chunk 1 so the seal is
;; nonempty): the OPEN-TAIL sub-lemma walks chunk 1 THROUGH ITS SEAL
;; to the scratch-clean boundary and hands the tail to xs_scont (the
;; es_scont mirror -- honest exactly because the seal re-zeroed the
;; chunk's dirt); the composition splits the imp side by ist_seam
;; (now models/imp-resident), cites the sub-lemma, case-ons the
;; SHARED standalone chunk run, exposes by il_slen, and walks chunk 2
;; inline to ground.

(fn sqxc_lsi () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 8)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 9)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 10)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 11)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 12)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 13)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 14)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 15)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 16)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 17)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 18)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 19)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 20)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 21)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 22)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 23)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 24)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 25)))))

(fn sqxc_c1i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 1)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 2)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 4)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 5)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 7)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 8)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 9)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 10)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 11)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 12)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 13)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 14)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 15)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 16)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 17)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 18)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 19)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 20)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 21)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 22)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 23)))
    (IStore (ILoc 2) (ITrunc U32 U8 (ILoc 1)))))

(fn sqxc_c2i () (List IStmt)
  (list
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 24)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 25)))))

(fn sqxc_lsx () (List XInstr)
  (list
    (XBin32 XAdd RSI (SImm 1))
    (XBin32 XAdd RSI (SImm 2))
    (XBin32 XAdd RSI (SImm 3))
    (XBin32 XAdd RSI (SImm 4))
    (XBin32 XAdd RSI (SImm 5))
    (XBin32 XAdd RSI (SImm 6))
    (XBin32 XAdd RSI (SImm 7))
    (XBin32 XAdd RSI (SImm 8))
    (XBin32 XAdd RSI (SImm 9))
    (XBin32 XAdd RSI (SImm 10))
    (XBin32 XAdd RSI (SImm 11))
    (XBin32 XAdd RSI (SImm 12))
    (XBin32 XAdd RSI (SImm 13))
    (XBin32 XAdd RSI (SImm 14))
    (XBin32 XAdd RSI (SImm 15))
    (XBin32 XAdd RSI (SImm 16))
    (XBin32 XAdd RSI (SImm 17))
    (XBin32 XAdd RSI (SImm 18))
    (XBin32 XAdd RSI (SImm 19))
    (XBin32 XAdd RSI (SImm 20))
    (XBin32 XAdd RSI (SImm 21))
    (XBin32 XAdd RSI (SImm 22))
    (XBin32 XAdd RSI (SImm 23))
    (XMovRR RAX RSI)
    (XBin XAnd RAX (SImm 255))
    (XStore8 (AReg RDX) (SReg RAX))
    (XMovRI RAX 0)
    (XBin32 XAdd RSI (SImm 24))
    (XBin32 XAdd RSI (SImm 25))
    (XMovRI RAX 0)))

(claim sqxc_lstie
  (goal () () (= (ix_sstmts (inline sqxc_lsi)) (Some (inline sqxc_lsx))))
  (steps ((compute both)) refl))

;; chunk 1's open-tail sub-lemma: 26 instrs + the seal, any tail rw
(claim sqxc_sl1
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (rw (List XInstr))
     (m Mem)
     (f Nat)
     (g Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 27 (S f))
        (MkXModule restfs 0 65536)
        (Cons
          (XBin32 XAdd RSI (SImm 1))
          (Cons
            (XBin32 XAdd RSI (SImm 2))
            (Cons
              (XBin32 XAdd RSI (SImm 3))
              (Cons
                (XBin32 XAdd RSI (SImm 4))
                (Cons
                  (XBin32 XAdd RSI (SImm 5))
                  (Cons
                    (XBin32 XAdd RSI (SImm 6))
                    (Cons
                      (XBin32 XAdd RSI (SImm 7))
                      (Cons
                        (XBin32 XAdd RSI (SImm 8))
                        (Cons
                          (XBin32 XAdd RSI (SImm 9))
                          (Cons
                            (XBin32 XAdd RSI (SImm 10))
                            (Cons
                              (XBin32 XAdd RSI (SImm 11))
                              (Cons
                                (XBin32 XAdd RSI (SImm 12))
                                (Cons
                                  (XBin32 XAdd RSI (SImm 13))
                                  (Cons
                                    (XBin32 XAdd RSI (SImm 14))
                                    (Cons
                                      (XBin32 XAdd RSI (SImm 15))
                                      (Cons
                                        (XBin32 XAdd RSI (SImm 16))
                                        (Cons
                                          (XBin32 XAdd RSI (SImm 17))
                                          (Cons
                                            (XBin32 XAdd RSI (SImm 18))
                                            (Cons
                                              (XBin32 XAdd RSI (SImm 19))
                                              (Cons
                                                (XBin32 XAdd RSI (SImm 20))
                                                (Cons
                                                  (XBin32 XAdd RSI (SImm 21))
                                                  (Cons
                                                    (XBin32 XAdd RSI (SImm 22))
                                                    (Cons
                                                      (XBin32
                                                        XAdd
                                                        RSI
                                                        (SImm 23))
                                                      (Cons
                                                        (XMovRR RAX RSI)
                                                        (Cons
                                                          (XBin
                                                            XAnd
                                                            RAX
                                                            (SImm 255))
                                                          (Cons
                                                            (XStore8
                                                              (AReg RDX)
                                                              (SReg RAX))
                                                            (Cons
                                                              (XMovRI RAX 0)
                                                              rw)))))))))))))))))))))))))))
        (MkRegs 0 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (xs_scont
        (S f)
        (MkXModule restfs 0 65536)
        rw
        (istmts (S^ 24 (S g)) 65536 (inline sqxc_c1i) (list x0 x1 x2) m))))
  (chain
    (steps ((compute both (stop xs_scont))))
    (case-on (le 0 x2) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ()) (compute both (stop xs_scont))))
           (case-on (lt x2 65536) Bool
             ((case True
                (chain
                  (have hlt1 (= (lt x2 65536) True)
                    (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                  (have hle1 (= (le (+ x2 1) 65536) True)
                    (steps () (by arith (rows (goal 1) (hlt1 1)))))
                  (steps
                    ((rewrite (hyp 0) lr rhs true ())
                     (rewrite (premise hle1) lr lhs true ())
                     (compute both)))
                  refl))
              (case False
                (chain
                  (have hlt1 (= (lt x2 65536) False)
                    (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                  (have hle1 (= (le (+ x2 1) 65536) False)
                    (steps () (by arith (rows (goal 1) (hlt1 1)))))
                  (steps
                    ((rewrite (hyp 0) lr rhs true ())
                     (rewrite (premise hle1) lr lhs true ())
                     (compute both)))
                  refl))))))
       (case False
         (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl))))))

;; the composition: ist_seam splits the imp side at the seal point,
;; the sub-lemma carries chunk 1, one case-on of the SHARED standalone
;; run absorbs every outcome, il_slen exposes the segment exit, and
;; chunk 2 walks inline to ground
(claim sqxc_lscomp
  (goal
    ((x0 Int) (x1 Int) (x2 Int) (m Mem) (c Nat) (c2 Nat) (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 34 c)
        (MkXModule restfs 0 65536)
        (inline sqxc_lsx)
        (MkRegs 0 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 30 c2) 65536 (inline sqxc_lsi) (list x0 x1 x2) m))))
  (chain
    (have hsp1 (= (inline sqxc_lsi) (isapp (inline sqxc_c1i) (inline sqxc_c2i)))
      (steps ((compute both)) refl))
    (have hfg1 (= (S^ 30 c2) (lg_fuel (istn (inline sqxc_c1i)) (S (S^ 5 c2))))
      (steps ((compute both)) refl))
    (steps
      ((rewrite (premise hsp1) lr rhs true ())
       (rewrite (premise hfg1) lr rhs true ())))
    (rewrite-with
      (lemma ist_seam)
      lr
      rhs
      ((inst g c2))
      ((steps ((compute lhs)) refl)))
    (have hfg1b (= (lg_fuel (istn (inline sqxc_c1i)) (S c2)) (S^ 24 (S c2)))
      (steps ((compute both)) refl))
    (steps ((rewrite (premise hfg1b) lr rhs true ())))
    (rewrite-with (lemma sqxc_sl1) lr lhs ((inst g c2)) ())
    (case-on (istmts (S^ 24 (S c2)) 65536 (inline sqxc_c1i) (list x0 x1 x2) m)
      Option
      ((case None
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute both (stop lg_fuel int_of_nat))))
           refl))
       (case Some
         (o0)
         (chain
           (steps ((rewrite (hyp 0) lr both true ())))
           (case-on o0 IOut
             ((case INorm
                (e0 mm0)
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute both (stop xeval_seq istmts lg_fuel int_of_nat))))
                  (case-on e0 List
                    ((case Nil
                       (chain
                         (have hbad
                           (=
                             (iolen
                               (ilen (list x0 x1 x2))
                               (Some (INorm e0 mm0)))
                             3)
                           (chain
                             (steps
                               ((rewrite (hyp 1) rl lhs true ())
                                (rewrite (hyp 2) rl lhs true ())))
                             (rewrite-with (lemma il_slen) lr lhs () ())
                             (steps ((compute lhs)))
                             refl))
                         (have hlen
                           (=
                             (iolen
                               (ilen (list x0 x1 x2))
                               (Some (INorm e0 mm0)))
                             (ilen e0))
                           (steps ((compute both)) refl))
                         (have hg (= (ilen e0) 3)
                           (steps
                             ((rewrite (premise hlen) rl lhs true ())
                              (rewrite (premise hbad) lr lhs true ()))
                             refl))
                         (have hs (= (ilen e0) 0)
                           (steps
                             ((rewrite (hyp 0) lr lhs true ()) (compute lhs))
                             refl))
                         (have hff (= (le 0 0) False)
                           (steps () (by arith (rows (goal 1) (hg 1) (hs -1)))))
                         (absurd (premise hff))))
                     (case Cons
                       (e0_0 r0_0)
                       (chain
                         (steps
                           ((rewrite (hyp 0) lr both true ())
                            (compute
                              both
                              (stop xeval_seq istmts lg_fuel int_of_nat))))
                         (case-on r0_0 List
                           ((case Nil
                              (chain
                                (have hbad
                                  (=
                                    (iolen
                                      (ilen (list x0 x1 x2))
                                      (Some (INorm e0 mm0)))
                                    3)
                                  (chain
                                    (steps
                                      ((rewrite (hyp 2) rl lhs true ())
                                       (rewrite (hyp 3) rl lhs true ())))
                                    (rewrite-with (lemma il_slen) lr lhs () ())
                                    (steps ((compute lhs)))
                                    refl))
                                (have hlen
                                  (=
                                    (iolen
                                      (ilen (list x0 x1 x2))
                                      (Some (INorm e0 mm0)))
                                    (ilen e0))
                                  (steps ((compute both)) refl))
                                (have hg (= (ilen e0) 3)
                                  (steps
                                    ((rewrite (premise hlen) rl lhs true ())
                                     (rewrite (premise hbad) lr lhs true ()))
                                    refl))
                                (have hs (= (ilen e0) 1)
                                  (steps
                                    ((rewrite (hyp 1) lr lhs true ())
                                     (rewrite (hyp 0) lr lhs true ())
                                     (compute lhs))
                                    refl))
                                (have hff (= (le 0 0) False)
                                  (steps
                                    ()
                                    (by arith (rows (goal 1) (hg 1) (hs -1)))))
                                (absurd (premise hff))))
                            (case Cons
                              (e0_1 r0_1)
                              (chain
                                (steps
                                  ((rewrite (hyp 0) lr both true ())
                                   (compute
                                     both
                                     (stop xeval_seq istmts lg_fuel int_of_nat))))
                                (case-on r0_1 List
                                  ((case Nil
                                     (chain
                                       (have hbad
                                         (=
                                           (iolen
                                             (ilen (list x0 x1 x2))
                                             (Some (INorm e0 mm0)))
                                           3)
                                         (chain
                                           (steps
                                             ((rewrite (hyp 3) rl lhs true ())
                                              (rewrite (hyp 4) rl lhs true ())))
                                           (rewrite-with
                                             (lemma il_slen)
                                             lr
                                             lhs
                                             ()
                                             ())
                                           (steps ((compute lhs)))
                                           refl))
                                       (have hlen
                                         (=
                                           (iolen
                                             (ilen (list x0 x1 x2))
                                             (Some (INorm e0 mm0)))
                                           (ilen e0))
                                         (steps ((compute both)) refl))
                                       (have hg (= (ilen e0) 3)
                                         (steps
                                           ((rewrite
                                              (premise hlen)
                                              rl
                                              lhs
                                              true
                                              ())
                                            (rewrite
                                              (premise hbad)
                                              lr
                                              lhs
                                              true
                                              ()))
                                           refl))
                                       (have hs (= (ilen e0) 2)
                                         (steps
                                           ((rewrite (hyp 2) lr lhs true ())
                                            (rewrite (hyp 1) lr lhs true ())
                                            (rewrite (hyp 0) lr lhs true ())
                                            (compute lhs))
                                           refl))
                                       (have hff (= (le 0 0) False)
                                         (steps
                                           ()
                                           (by
                                             arith
                                             (rows (goal 1) (hg 1) (hs -1)))))
                                       (absurd (premise hff))))
                                   (case Cons
                                     (e0_2 r0_2)
                                     (chain
                                       (steps
                                         ((rewrite (hyp 0) lr both true ())
                                          (compute
                                            both
                                            (stop xeval_seq istmts lg_fuel
                                              int_of_nat))))
                                       (case-on r0_2 List
                                         ((case Nil
                                            (chain
                                              (steps
                                                ((rewrite
                                                   (hyp 0)
                                                   lr
                                                   both
                                                   true
                                                   ())
                                                 (compute
                                                   both
                                                   (stop lg_fuel int_of_nat))))
                                              refl))
                                          (case Cons
                                            (e0_3 r0_3)
                                            (chain
                                              (have hbad
                                                (=
                                                  (iolen
                                                    (ilen (list x0 x1 x2))
                                                    (Some (INorm e0 mm0)))
                                                  3)
                                                (chain
                                                  (steps
                                                    ((rewrite
                                                       (hyp 4)
                                                       rl
                                                       lhs
                                                       true
                                                       ())
                                                     (rewrite
                                                       (hyp 5)
                                                       rl
                                                       lhs
                                                       true
                                                       ())))
                                                  (rewrite-with
                                                    (lemma il_slen)
                                                    lr
                                                    lhs
                                                    ()
                                                    ())
                                                  (steps ((compute lhs)))
                                                  refl))
                                              (have hlen
                                                (=
                                                  (iolen
                                                    (ilen (list x0 x1 x2))
                                                    (Some (INorm e0 mm0)))
                                                  (ilen e0))
                                                (steps ((compute both)) refl))
                                              (have hg (= (ilen e0) 3)
                                                (steps
                                                  ((rewrite
                                                     (premise hlen)
                                                     rl
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (premise hbad)
                                                     lr
                                                     lhs
                                                     true
                                                     ()))
                                                  refl))
                                              (have hs
                                                (=
                                                  (ilen e0)
                                                  (+
                                                    1
                                                    (+
                                                      1
                                                      (+ 1 (+ 1 (ilen r0_3))))))
                                                (steps
                                                  ((rewrite
                                                     (hyp 3)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (hyp 2)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (hyp 1)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (rewrite
                                                     (hyp 0)
                                                     lr
                                                     lhs
                                                     true
                                                     ())
                                                   (unfold ilen lhs)
                                                   (reduce lhs)
                                                   (unfold ilen lhs)
                                                   (reduce lhs)
                                                   (unfold ilen lhs)
                                                   (reduce lhs)
                                                   (unfold ilen lhs)
                                                   (reduce lhs))
                                                  refl))
                                              (have hnn
                                                (= (le 0 (ilen r0_3)) True)
                                                (chain
                                                  (rewrite-with
                                                    (lemma ilen_nonneg)
                                                    lr
                                                    lhs
                                                    ()
                                                    ())
                                                  refl))
                                              (have hff (= (le 0 0) False)
                                                (steps
                                                  ()
                                                  (by
                                                    arith
                                                    (rows
                                                      (goal 1)
                                                      (hg -1)
                                                      (hs 1)
                                                      (hnn 1)))))
                                              (absurd (premise hff))))))))))))))))))))
              (case ITrap
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute both (stop lg_fuel int_of_nat))))
                  refl))))))))))
