;;; tools/impgen/blueprints/iwg_probe.shard — DEV PROBE (unregistered, the facts_probe
;;; idiom): the GENERIC Some-conditional loop worker — the rebuilt
;;; impgen's loop-tier statement form. The hand iww_* workers carry
;;; per-program premises (pointer window, counter cap) synthesized by
;;; shape recognition; the generic form replaces them with ONE
;;; program-independent premise — the imp loop run LANDS (= Some o) at
;;; ghost-count fuel (S^B (lg_fuel k 0)), tail Z so exhaustion is
;;; contradictory — and closes every leaf by:
;;;   exit    guard dies      -> both machines exit, premise pins o
;;;   trap    a bound test fails -> both machines trap (shared banded
;;;           scrutinee; the machine's le-(+1) spelling bridged by an
;;;           integer-tight arith have)
;;;   absurd  fuel dies under the premise -> (absurd …)
;;;   step    body completes -> premise transports one iteration, the
;;;           IH fires at the new state with (inst o o)
;;; If iwg_fill checks, the walk+guards+fuel form of IMP.md §2a is
;;; validated and the generator stamps it structurally.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(use (:: std mem *))
(import "../../../models/imp/imp.shard")
(use (:: models imp imp *))
(import "../../../models/wasm/wasm.shard")
(use (:: models wasm wasm *))
(import "../../../models/imp/to_wasm.shard")
(use (:: models imp to_wasm *))
(import "../../../models/wasm/loopkit.shard")
(use (:: models wasm loopkit *))

;; local body copies for the (inline …) sugar (the bridge-file pattern)

(fn pr_fill_w () (List Instr)
  (list
    (LocalGet 2)
    (I32Eqz)
    (BrIf 1)
    (LocalGet 0)
    (LocalGet 1)
    (I32Store8)
    (LocalGet 0)
    (I32Const 1)
    (I32Bin BAdd)
    (LocalSet 0)
    (LocalGet 2)
    (I32Const 1)
    (I32Bin BSub)
    (LocalSet 2)
    (Br 0)))

(fn pr_fill_i () (List IStmt)
  (list
    (IStore (ILoc 0) (ILoc 1))
    (ISet 0 (IBin U32 IAdd (ILoc 0) (IConst 1)))
    (ISet 2 (IBin U32 ISub (ILoc 2) (IConst 1)))))

;; the generic worker: NO pointer window, NO counter cap — the locals
;; are fully symbolic (no int_of_nat), the iteration count is a GHOST
;; in the fuel shape, and the imp run's landing is the one premise.
(claim iwg_fill
  (goal
    ((a Int)
     (b Int)
     (w Int)
     (st (List Int))
     (m Mem)
     (o IOut)
     (k Nat)
     (c Nat)
     (restfs (List Func)))
    ((=
       (iwhile
         (S^ 4 (lg_fuel k 0))
         65536
         (ILoc 2)
         (inline pr_fill_i)
         (list a b w)
         m)
       (Some o)))
    (=
      (eval_loop
        (S^ 19 (lg_fuel k c))
        (MkWModule
          (Cons
            (MkFunc
              3
              0
              (list (Block (list (Loop (inline pr_fill_w)))) (I32Const 0)))
            restfs)
          65536)
        (inline pr_fill_w)
        (list a b w)
        st
        m)
      (iw_out st (Some o))))
  (induct k
    ((case Z
       (case-on (int_eq w 0) Bool
         ((case True
            (chain
              (have hro (= (Some (INorm (list a b w) m)) (Some o))
                (steps
                  ((rewrite (premise 0) rl rhs true ())
                   (compute rhs (stop lg_fuel))
                   (rewrite (hyp True) lr rhs true ())
                   (compute rhs (stop lg_fuel)))
                  refl))
              (steps
                ((rewrite (premise hro) rl rhs true ())
                 (compute rhs)
                 (compute lhs)
                 (rewrite (hyp True) lr lhs true ())
                 (compute lhs))
                refl)))
          (case False
            (case-on (le 0 a) Bool
              ((case False
                 (chain
                   (have hro (= (Some ITrap) (Some o))
                     (steps
                       ((rewrite (premise 0) rl rhs true ())
                        (compute rhs (stop lg_fuel))
                        (rewrite (hyp 1) lr rhs true ())
                        (compute rhs (stop lg_fuel))
                        (rewrite (hyp 0) lr rhs true ())
                        (compute rhs (stop lg_fuel)))
                       refl))
                   (steps
                     ((rewrite (premise hro) rl rhs true ())
                      (compute rhs)
                      (compute lhs)
                      (rewrite (hyp 1) lr lhs true ())
                      (compute lhs)
                      (rewrite (hyp 0) lr lhs true ())
                      (compute lhs))
                     refl)))
               (case True
                 (case-on (lt a 65536) Bool
                   ((case False
                      (chain
                        (have hlt0 (= (lt a 65536) False)
                          (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                        (have hle0 (= (le (+ a 1) 65536) False)
                          (steps () (by arith (rows (goal 1) (hlt0 1)))))
                        (have hro (= (Some ITrap) (Some o))
                          (steps
                            ((rewrite (premise 0) rl rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 2) lr rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 1) lr rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 0) lr rhs true ())
                             (compute rhs (stop lg_fuel)))
                            refl))
                        (steps
                          ((rewrite (premise hro) rl rhs true ())
                           (compute rhs)
                           (compute lhs)
                           (rewrite (hyp 2) lr lhs true ())
                           (compute lhs)
                           (rewrite (hyp 1) lr lhs true ())
                           (compute lhs)
                           (rewrite (premise hle0) lr lhs true ())
                           (compute lhs))
                          refl)))
                    (case True
                      (chain
                        (have hn (= None (Some o))
                          (steps
                            ((rewrite (premise 0) rl rhs true ())
                             (compute rhs)
                             (rewrite (hyp 2) lr rhs true ())
                             (compute rhs)
                             (rewrite (hyp 1) lr rhs true ())
                             (compute rhs)
                             (rewrite (hyp 0) lr rhs true ())
                             (compute rhs))
                            refl))
                        (absurd (premise hn)))))))))))))
     (case S
       (k2)
       (case-on (int_eq w 0) Bool
         ((case True
            (chain
              (have hro (= (Some (INorm (list a b w) m)) (Some o))
                (steps
                  ((rewrite (premise 0) rl rhs true ())
                   (compute rhs (stop lg_fuel))
                   (rewrite (hyp True) lr rhs true ())
                   (compute rhs (stop lg_fuel)))
                  refl))
              (steps
                ((rewrite (premise hro) rl rhs true ())
                 (compute rhs)
                 (compute lhs (stop lg_fuel))
                 (rewrite (hyp True) lr lhs true ())
                 (compute lhs (stop lg_fuel)))
                refl)))
          (case False
            (case-on (le 0 a) Bool
              ((case False
                 (chain
                   (have hro (= (Some ITrap) (Some o))
                     (steps
                       ((rewrite (premise 0) rl rhs true ())
                        (compute rhs (stop lg_fuel))
                        (rewrite (hyp 1) lr rhs true ())
                        (compute rhs (stop lg_fuel))
                        (rewrite (hyp 0) lr rhs true ())
                        (compute rhs (stop lg_fuel)))
                       refl))
                   (steps
                     ((rewrite (premise hro) rl rhs true ())
                      (compute rhs)
                      (compute lhs (stop lg_fuel))
                      (rewrite (hyp 1) lr lhs true ())
                      (compute lhs (stop lg_fuel))
                      (rewrite (hyp 0) lr lhs true ())
                      (compute lhs (stop lg_fuel)))
                     refl)))
               (case True
                 (case-on (lt a 65536) Bool
                   ((case False
                      (chain
                        (have hlt0 (= (lt a 65536) False)
                          (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                        (have hle0 (= (le (+ a 1) 65536) False)
                          (steps () (by arith (rows (goal 1) (hlt0 1)))))
                        (have hro (= (Some ITrap) (Some o))
                          (steps
                            ((rewrite (premise 0) rl rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 2) lr rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 1) lr rhs true ())
                             (compute rhs (stop lg_fuel))
                             (rewrite (hyp 0) lr rhs true ())
                             (compute rhs (stop lg_fuel)))
                            refl))
                        (steps
                          ((rewrite (premise hro) rl rhs true ())
                           (compute rhs)
                           (compute lhs (stop lg_fuel))
                           (rewrite (hyp 2) lr lhs true ())
                           (compute lhs (stop lg_fuel))
                           (rewrite (hyp 1) lr lhs true ())
                           (compute lhs (stop lg_fuel))
                           (rewrite (premise hle0) lr lhs true ())
                           (compute lhs (stop lg_fuel)))
                          refl)))
                    (case True
                      (chain
                        (have hlt (= (lt a 65536) True)
                          (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                        (have hle1 (= (le (+ a 1) 65536) True)
                          (steps () (by arith (rows (goal 1) (hlt 1)))))
                        (have hnext
                          (=
                            (iwhile
                              (S^ 4 (lg_fuel k2 0))
                              65536
                              (ILoc 2)
                              (inline pr_fill_i)
                              (list
                                (mod (+ a 1) 4294967296)
                                b
                                (mod (- w 1) 4294967296))
                              (mem_set m a b))
                            (Some o))
                          (steps
                            ((rewrite (premise 0) rl rhs true ())
                             (unfold lg_fuel rhs)
                             (reduce rhs)
                             (unfold iwhile rhs)
                             (compute rhs (stop iwhile lg_fuel))
                             (rewrite (hyp 2) lr rhs true ())
                             (compute rhs (stop iwhile lg_fuel))
                             (rewrite (hyp 1) lr rhs true ())
                             (compute rhs (stop iwhile lg_fuel))
                             (rewrite (hyp 0) lr rhs true ())
                             (compute rhs (stop iwhile lg_fuel)))
                            refl))
                        (steps
                          ((unfold lg_fuel lhs)
                           (reduce lhs)
                           (unfold eval_loop lhs)
                           (compute lhs (stop eval_loop lg_fuel))
                           (rewrite (hyp 2) lr lhs true ())
                           (compute lhs (stop eval_loop lg_fuel))
                           (rewrite (hyp 1) lr lhs true ())
                           (compute lhs (stop eval_loop lg_fuel))
                           (rewrite (premise hle1) lr lhs true ())
                           (compute lhs (stop eval_loop lg_fuel))))
                        (rewrite-with
                          (hyp 3)
                          lr
                          lhs
                          ((inst o o))
                          ((steps
                             ((rewrite (premise hnext) lr lhs true ()))
                             refl)))
                        refl))))))))))))))
