;;; tools/impgen/blueprints/sqbsx_probe.shard — the SEALED-BRANCH-CHUNK x86 blueprint
;;; (rung IF-3a): adjacent top-level branches on x86, resolved by the
;;; translator's seal rules (to_x86 ix_brla/ix_cjoin). The program
;;; it_bsx = store / br1 (store in the then arm -> real seal) / br2 /
;;; store+set tail. Chunk-grain legs: [store]+seal, [br1]+seal,
;;; [br2, store, set] (the IF-1c terminal branch leg).
;;;
;;; HISTORY: the IF-3a-a hand blueprint proved the mechanism at the
;;; seal-after-branch-only translation (two-layer composition in one
;;; lemma; the flat entry chunk's exit scratch SPELLED -- (band x1
;;; 255) -- riding into the branch sub-lemma's za by matching). The
;;; IF-3a-b chunk-grain rule (a flat chunk seals before a sealing
;;; branch) re-grounded the file at the emitter's leg grammar: every
;;; chunk of a branch-sealing span exits sealed, the entry chunk is a
;;; stock V2-8 zero-exit sub-lemma, and this file's claims are the
;;; EMITTER'S OUTPUT VERBATIM (blueprint == generated, the IF-2
;;; parity discipline).
;;;
;;; THE MECHANISM (sqbr_x_bsx_c1): ONE case-on of the shared raw
;;; scrutinee inside the sub-lemma; each polarity arm walks its own
;;; guards (per-REGION dedup, the IF-1c law) THROUGH the seal, and
;;; the seal is THE JOIN: RAX continues at literal 0 on both arms, so
;;; the continuation register file is arm-independent and the
;;; conclusion is ONE xm_scont form. Fuel: blocks are depth budgets
;;; -- a branch chunk consumes 1 at the top level (+ its seal)
;;; regardless of arm, so towers stay arm-independent; the machine
;;; total is tcost (pricing the arm nesting) + the seal width, and
;;; the continuation tower is tcost-1. The chain composes by
;;; ist_seam1 at the branch singleton (tied fuel, no reshapes), the
;;; sub-lemma cite, the shared-run case-on, il_slen exposure, and the
;;; next boundary cited at the parked leaf.

(import "../../../kernel/stdlib.shard")
(import "../../../models/imp/imp.shard")
(import "../../../models/x86/x86.shard")
(import "../../../models/imp/to_x86.shard")
(import "../../../std/nat.shard")
(import "../../../std/mem")
(import "../../../models/wasm/loopkit.shard")
(import "../../../models/x86/loopkit.shard")

(use (:: models imp imp *))
(use (:: models x86 x86 *))
(use (:: models imp to_x86 *))
(use (:: std nat *))
(use (:: std mem *))
(use (:: models wasm loopkit *))
(use (:: models x86 loopkit *))

(fn it_bsx_fn () IFn
  (MkIFn
    (list U32 U32 U32)
    Nil
    (list
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1)))
      (IIf
        (IBin U32 ILt (ILoc 1) (IConst 9))
        (list
          (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
          (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
        (list (ISet 1 (IConst 11))))
      (IIf
        (IBin U32 IEq (ILoc 2) (IConst 5))
        (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
        (list (ISet 2 (IConst 7))))
      (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))
      (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3))))
    (ILoc 1)
    U32))

(claim tie_x_bsx
  (goal () () (= (ix_sstmts (ibody_of (it_bsx_fn))) (Some (inline gb_bsx_x))))
  (steps ((compute both)) refl))

(fn gb_bsx_i () (List IStmt)
  (Cons (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))) (gb_bsx_r1_i)))

(fn gb_bsx_x () (List XInstr)
  (Cons
    (XMovRR RAX RSI)
    (Cons
      (XBin XAnd RAX (SImm 255))
      (Cons (XStore8 (AReg RDI) (SReg RAX)) (Cons (XMovRI RAX 0) (gb_bsx_r1_x))))))

(fn gb_bsx_r1_i () (List IStmt)
  (Cons
    (IIf
      (IBin U32 ILt (ILoc 1) (IConst 9))
      (list
        (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 6)))
        (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 1))))
      (list (ISet 1 (IConst 11))))
    (gb_bsx_r2_i)))

(fn gb_bsx_r1_x () (List XInstr)
  (Cons
    (XBlock
      (list
        (XBlock (list (XBrIf (CLtU RSI (SImm 9)) 0) (XMovRI RSI 11) (XBr 1)))
        (XBin32 XAdd RSI (SImm 6))
        (XMovRR RAX RSI)
        (XBin XAnd RAX (SImm 255))
        (XStore8 (AReg RDI) (SReg RAX))))
    (Cons (XMovRI RAX 0) (gb_bsx_r2_x))))

(fn gb_bsx_r2_i () (List IStmt)
  (list
    (IIf
      (IBin U32 IEq (ILoc 2) (IConst 5))
      (list (ISet 2 (IBin U32 IAdd (ILoc 2) (IConst 2))))
      (list (ISet 2 (IConst 7))))
    (IStore (ILoc 0) (ITrunc U32 U8 (ILoc 2)))
    (ISet 1 (IBin U32 IAdd (ILoc 1) (IConst 3)))))

(fn gb_bsx_r2_x () (List XInstr)
  (list
    (XBlock
      (list
        (XBlock (list (XBrIf (CEq RDX (SImm 5)) 0) (XMovRI RDX 7) (XBr 1)))
        (XBin32 XAdd RDX (SImm 2))))
    (XMovRR RAX RDX)
    (XBin XAnd RAX (SImm 255))
    (XStore8 (AReg RDI) (SReg RAX))
    (XBin32 XAdd RSI (SImm 3))
    (XMovRI RAX 0)))

(claim sqm_wid_bsx
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True))
    (= (mod x 4294967296) x))
  (div-facts
    x
    4294967296
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 4294967296 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 4294967296 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim sqm_wid64_bsx
  (goal ((x Int)) ((= (le 0 x) True) (= (lt x 18446744073709551616) True))
    (= (mod x 18446744073709551616) x))
  (div-facts
    x
    18446744073709551616
    q
    (have qlo (= (le -1 q) True)
      (by arith (list 18446744073709551616 1 0 -1 0 1 0))
      (have qhi (= (le q 1) True)
        (by arith (list 18446744073709551616 0 1 1 1 0 0))
        (fin-split
          q
          (premise qlo)
          (premise qhi)
          ((case -1
             (by
               arith
               (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0))))
           (case 0
             (by
               arith
               (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0))))
           (case 1
             (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))

(claim cmp_x_bsx_b2
  (goal
    ((x0 Int)
     (x1 Int)
     (x2 Int)
     (za Int)
     (m Mem)
     (c Nat)
     (c2 Nat)
     (restfs (List XFunc)))
    ()
    (=
      (xeval_seq
        (S^ 67 c)
        (MkXModule restfs 0 65536)
        (gb_bsx_r2_x)
        (MkRegs za 0 x2 0 0 x1 x0 0 0 0 0 0 0 0 0)
        m)
      (ix_sout (istmts (S^ 65 c2) 65536 (gb_bsx_r2_i) (list x0 x1 x2) m))))
  (chain
    (steps
      ((unfold gb_bsx_r2_x lhs)
       (reduce lhs)
       (unfold gb_bsx_r2_i rhs)
       (reduce rhs)))
    (steps
      ((compute
         both
         (stop iwhile xeval_loop lg_fuel int_of_nat gb_bsx_r1_x gb_bsx_r1_i
           gb_bsx_r2_x gb_bsx_r2_i))))
    (case-on (int_eq x2 5) Bool
      ((case True
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute
                both
                (stop iwhile xeval_loop lg_fuel int_of_nat gb_bsx_r1_x
                  gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
           (case-on (le 0 x0) Bool
             ((case True
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute
                       both
                       (stop iwhile xeval_loop lg_fuel int_of_nat gb_bsx_r1_x
                         gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
                  (case-on (lt x0 65536) Bool
                    ((case True
                       (chain
                         (have hlt2 (= (lt x0 65536) True)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle2 (= (le (+ x0 1) 65536) True)
                           (steps () (by arith (rows (goal 1) (hlt2 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle2) lr lhs true ())
                            (compute
                              both
                              (stop iwhile xeval_loop lg_fuel int_of_nat
                                gb_bsx_r1_x gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
                         (steps ((compute both (stop lg_fuel int_of_nat))))
                         refl))
                     (case False
                       (chain
                         (have hlt2 (= (lt x0 65536) False)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle2 (= (le (+ x0 1) 65536) False)
                           (steps () (by arith (rows (goal 1) (hlt2 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle2) lr lhs true ())
                            (compute
                              both
                              (stop lg_fuel int_of_nat gb_bsx_r1_x gb_bsx_r1_i
                                gb_bsx_r2_x gb_bsx_r2_i))))
                         refl))))))
              (case False
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute
                       both
                       (stop lg_fuel int_of_nat gb_bsx_r1_x gb_bsx_r1_i
                         gb_bsx_r2_x gb_bsx_r2_i))))
                  refl))))))
       (case False
         (chain
           (steps
             ((rewrite (hyp 0) lr both true ())
              (compute
                both
                (stop iwhile xeval_loop lg_fuel int_of_nat gb_bsx_r1_x
                  gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
           (case-on (le 0 x0) Bool
             ((case True
                (chain
                  (steps
                    ((rewrite (hyp 0) lr both true ())
                     (compute
                       both
                       (stop iwhile xeval_loop lg_fuel int_of_nat gb_bsx_r1_x
                         gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
                  (case-on (lt x0 65536) Bool
                    ((case True
                       (chain
                         (have hlt2 (= (lt x0 65536) True)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle2 (= (le (+ x0 1) 65536) True)
                           (steps () (by arith (rows (goal 1) (hlt2 1)))))
                         (steps
                           ((rewrite (hyp 0) lr rhs true ())
                            (rewrite (premise hle2) lr lhs true ())
                            (compute
                              both
                              (stop iwhile xeval_loop lg_fuel int_of_nat
                                gb_bsx_r1_x gb_bsx_r1_i gb_bsx_r2_x gb_bsx_r2_i))))
                         (steps ((compute both (stop lg_fuel int_of_nat))))
                         refl))
                     (case False
                       (chain
                         (have hlt2 (= (lt x0 65536) False)
                           (steps ((rewrite (hyp 0) lr lhs true ())) refl))
                         (have hle2 (= (le (+ x0 1) 65536) False)
                           (steps () (by arith (rows (goal 1) (hlt2 1)))))
