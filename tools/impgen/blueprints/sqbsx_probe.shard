                         gb_bsx_r2_i))))
                  (case-on ec1 List
                    ((case Nil
                       (chain
                         (have hbad
                           (=
                             (iolen
                               (ilen (list x0 x1 x2))
                               (Some (INorm ec1 mc1)))
                             3)
                           (chain
                             (steps
                               ((rewrite (hyp 1) rl lhs true ())
                                (rewrite (hyp 2) rl lhs true ())))
                             (rewrite-with (lemma il_slen) lr lhs () ())
                             (steps ((compute lhs)))
                             refl))
                         (have hlen
                           (=
                             (iolen
                               (ilen (list x0 x1 x2))
                               (Some (INorm ec1 mc1)))
                             (ilen ec1))
                           (steps ((compute both)) refl))
                         (have hg (= (ilen ec1) 3)
                           (steps
                             ((rewrite (premise hlen) rl lhs true ())
                              (rewrite (premise hbad) lr lhs true ()))
                             refl))
                         (have hs (= (ilen ec1) 0)
                           (steps
                             ((rewrite (hyp 0) lr lhs true ()) (compute lhs))
                             refl))
                         (have hff (= (le 0 0) False)
                           (steps () (by arith (rows (goal 1) (hg 1) (hs -1)))))
                         (absurd (premise hff))))
                     (case Cons
                       (ec1_0 rc1_0)
                       (chain
                         (steps
                           ((rewrite (hyp 0) lr both true ())
                            (compute
                              both
                              (stop iwhile xeval_loop lg_fuel int_of_nat istmts
                                xeval_seq gb_bsx_r1_x gb_bsx_r1_i gb_bsx_r2_x
                                gb_bsx_r2_i))))
                         (case-on rc1_0 List
                           ((case Nil
                              (chain
                                (have hbad
                                  (=
                                    (iolen
                                      (ilen (list x0 x1 x2))
                                      (Some (INorm ec1 mc1)))
                                    3)
                                  (chain
                                    (steps
                                      ((rewrite (hyp 2) rl lhs true ())
                                       (rewrite (hyp 3) rl lhs true ())))
                                    (rewrite-with (lemma il_slen) lr lhs () ())
                                    (steps ((compute lhs)))
                                    refl))
                                (have hlen
                                  (=
                                    (iolen
                                      (ilen (list x0 x1 x2))
                                      (Some (INorm ec1 mc1)))
