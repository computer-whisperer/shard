                                   (compute
                                     both
                                     (stop iwhile xeval_loop lg_fuel int_of_nat
                                       istmts xeval_seq gb_bsx_r1_x gb_bsx_r1_i
                                       gb_bsx_r2_x gb_bsx_r2_i))))
                                (case-on rc1_1 List
