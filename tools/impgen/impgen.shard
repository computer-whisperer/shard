;;; tools/impgen/impgen.shard -- the imp -> ISA LEG GENERATOR, v2: the
;;; STRUCTURAL WALK over well-kinded imp (docs/IMP.md 2a; rung V2-5).
;;; For every imp pin in the target file, emit the per-target TIE and
;;; BRIDGE certs. The v1 recognizer/premise machinery is GONE: v2's
;;; crystallized kinds make the alignment relation program-independent
;;; by type, so a bridge is the walk's case-on tree over the shared
;;; banded scrutinees (branch conditions, div guards) with compute-both
;;; leaves -- no premises, no wrap events, no invariant synthesis.
;;;
;;; THE FACTORING (unchanged from I2d): the translators are the single
;;; source of translation truth -- this tool LOADS models/imp/to_wasm /
;;; to_x86 through the kernel (meta/invoke) and RUNS them on the pin
;;; values; the tie literal is the spelled result (meta/spell's sp_e
;;; over a qname table harvested from the value itself). Nothing about
;;; translation is re-derived here.
;;;
;;; PIN CONVENTION: a pin is a NULLARY fn returning IFn, defined in the
;;; target file (it_<nm>_fn naming gives claims tie_<nm> / imp_w_<nm>;
;;; other names pass through whole). Bridges additionally need the
;;; IFn -> IProg wrapper (found by SIGNATURE); the wrapper's declared
;;; memsize is discovered by running it (never assumed). A pin the
;;; translator REFUSES gets a comment line, not an error. Loop pins
;;; (any IWhile in the body) note-and-tie in this tier; the generic
;;; Some-conditional loop tier is the next rung of V2-5.
;;;
;;; V2 BRIDGE STATEMENT: unpremised --
;;;   call_fn (S^ff c) (module of the translated pin) 0
;;;     (iband_args KINDS args)  =  icall (S^gg c2) (WRAP (PIN)) 0 args
;;; and the proof is (compute both) plus the walk's case-on tree, each
;;; arm (rewrite (hyp _)) + (compute both), every leaf refl. Guard
;;; splits put the trap on the False arm -- both machines trap by type,
;;; and the denotations conflate trap to None on both sides.
;;;
;;; RUN IT:  bin/shard_eval run tools/impgen/impgen.shard SRC TARGET OUT.raw
;;;          (TARGET = wasm | x86; OUT must be a sibling of SRC), then
;;;          shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../meta/doc")
(import "../../meta/spell")
(import "../../meta/invoke")
(import "../../models/imp/imp.shard")

(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader read_file))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term Ctor))
(use (:: kernel term Call))
(use (:: kernel term IntLit))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term qn_mod))
(use (:: kernel term qname_eq))
(use (:: kernel term sym_path_eq))
(use (:: kernel term expr_eq))
(use (:: kernel term append_int))
(use (:: kernel term show_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module TCon))
(use (:: meta doc *))
(use (:: meta spell *))
(use (:: meta invoke *))
(use (:: models imp imp *))

;; --- small utils ----------------------------------------------------------------

(fn ceq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        ((Cons _ _) False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (ceq xs ys) False))))))

(fn imax ((a Int) (b Int)) Int (if (lt a b) b a))

(fn starts_with ((pre (List Int)) (s (List Int))) Bool
  (measure (struct pre))
  (match pre
    (Nil True)
    ((Cons p pt)
     (match s
       (Nil False)
       ((Cons c ct) (if (int_eq p c) (starts_with pt ct) False))))))

(fn drop_len ((pre (List Int)) (s (List Int))) (List Int)
  (measure (struct pre))
  (match pre
    (Nil s)
    ((Cons _ pt)
     (match s
       (Nil Nil)
       ((Cons _ ct) (drop_len pt ct))))))

(fn strip_pre ((pre (List Int)) (s (List Int))) (List Int)
  (if (starts_with pre s) (drop_len pre s) s))

(fn rev_int_go ((s (List Int)) (acc (List Int))) (List Int)
  (measure (struct s))
  (match s
    (Nil acc)
    ((Cons h t) (rev_int_go t (Cons h acc)))))

(fn rev_int ((s (List Int))) (List Int) (rev_int_go s Nil))

(fn strip_suf ((suf (List Int)) (s (List Int))) (List Int)
  (rev_int (strip_pre (rev_int suf) (rev_int s))))

;; pin fn name -> claim stem: it_<nm>_fn -> <nm> (either half optional)
(fn pin_nm ((s Symbol)) (List Int)
  (strip_suf "_fn" (strip_pre "it_" (chars_of_sym s))))

;; --- ground-value views (evm results are Ctor/IntLit trees) ---------------------

;; a ctor node with this LOCAL name (basename match: the values come
;; from the loaded models, whose paths are canonical — within the imp /
;; wasm / x86 / prelude vocabulary basenames are unambiguous)
(fn ec_is ((e Expr) (s Symbol)) (Option (List Expr))
  (match e
    ((Ctor q args) (if (sym_eq (qn_name q) s) (Some args) None))
    (_ None)))

(fn e_int ((e Expr)) (Option Int)
  (match e
    ((IntLit n) (Some n))
    (_ None)))

;; --- the spell table: harvest ctor qnames from the value itself -----------------
;; Every ctor spells as its basename; the generated file's glob uses
;; make each basename resolvable. Harvesting from the value (instead of
;; hand-spelled paths) keeps the table honest by construction. One
;; structural walk (ctor args descend inline — subterms of the head).

(fn tbl_has ((t (List (Pair QName Symbol))) (q QName)) Bool
  (measure (struct t))
  (match t
    (Nil False)
    ((Cons (Pair k _) rest) (if (qname_eq k q) True (tbl_has rest q)))))

(fn harvest_l ((es (List Expr)) (t (List (Pair QName Symbol))))
  (List (Pair QName Symbol))
  (measure (struct es))
  (match es
    (Nil t)
    ((Cons h rest)
     (match h
       ((Ctor q args)
        (harvest_l
          rest
          (harvest_l args (if (tbl_has t q) t (Cons (Pair q (qn_name q)) t)))))
       (_ (harvest_l rest t))))))

(fn harvest ((e Expr)) (List (Pair QName Symbol)) (harvest_l (Cons e Nil) Nil))

;; --- reify: ground imp value Exprs -> native models/imp values ------------------
;; Loud None on anything outside the imp grammar (an internal error:
;; the pin evaluated to a non-IFn or the grammar grew without this
;; tool growing with it).

(fn rf_op ((e Expr)) (Option IOp)
  (match e
    ((Ctor q _)
     (if (sym_eq (qn_name q) (quote IAdd)) (Some IAdd)
     (if (sym_eq (qn_name q) (quote ISub)) (Some ISub)
     (if (sym_eq (qn_name q) (quote IMul)) (Some IMul)
     (if (sym_eq (qn_name q) (quote IDiv)) (Some IDiv)
     (if (sym_eq (qn_name q) (quote IRem)) (Some IRem)
     (if (sym_eq (qn_name q) (quote IAnd)) (Some IAnd)
     (if (sym_eq (qn_name q) (quote IOr)) (Some IOr)
     (if (sym_eq (qn_name q) (quote IXor)) (Some IXor)
     (if (sym_eq (qn_name q) (quote IShl)) (Some IShl)
     (if (sym_eq (qn_name q) (quote IShr)) (Some IShr)
     (if (sym_eq (qn_name q) (quote IEq)) (Some IEq)
     (if (sym_eq (qn_name q) (quote ILt)) (Some ILt)
     (if (sym_eq (qn_name q) (quote ILe)) (Some ILe)
     None))))))))))))))
    (_ None)))

(fn rf_kind ((e Expr)) (Option IKind)
  (match e
    ((Ctor q _)
     (if (sym_eq (qn_name q) (quote U8)) (Some U8)
     (if (sym_eq (qn_name q) (quote U32)) (Some U32)
     (if (sym_eq (qn_name q) (quote U64)) (Some U64)
     None))))
    (_ None)))

(fn rf_kinds ((e Expr)) (Option (List IKind))
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) (Some Nil)
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match (rf_kind h)
            (None None)
            ((Some k)
             (match (rf_kinds t)
               (None None)
               ((Some ks) (Some (Cons k ks)))))))
         (_ None))
       None)))
    (_ None)))

(fn rf_exp ((e Expr)) (Option IExp)
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote IConst))
       (match args
         ((Cons a Nil)
          (match (e_int a)
            (None None)
            ((Some n) (Some (IConst n)))))
         (_ None))
     (if (sym_eq (qn_name q) (quote ILoc))
       (match args
         ((Cons a Nil)
          (match (e_int a)
            (None None)
            ((Some n) (Some (ILoc n)))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IBin))
       (match args
         ((Cons kk (Cons o (Cons a (Cons b Nil))))
          (match (rf_kind kk)
            (None None)
            ((Some ik)
             (match (rf_op o)
               (None None)
               ((Some io)
                (match (rf_exp a)
                  (None None)
                  ((Some ia)
                   (match (rf_exp b)
                     (None None)
                     ((Some ib) (Some (IBin ik io ia ib)))))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IRotr))
       (match args
         ((Cons kk (Cons a (Cons k Nil)))
          (match (rf_kind kk)
            (None None)
            ((Some ik)
             (match (rf_exp a)
               (None None)
               ((Some ia)
                (match (rf_exp k)
                  (None None)
                  ((Some ic) (Some (IRotr ik ia ic)))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IExt))
       (match args
         ((Cons kf (Cons kt (Cons a Nil)))
          (match (rf_kind kf)
            (None None)
            ((Some ikf)
             (match (rf_kind kt)
               (None None)
               ((Some ikt)
                (match (rf_exp a)
                  (None None)
                  ((Some ia) (Some (IExt ikf ikt ia)))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote ITrunc))
       (match args
         ((Cons kf (Cons kt (Cons a Nil)))
          (match (rf_kind kf)
            (None None)
            ((Some ikf)
             (match (rf_kind kt)
               (None None)
               ((Some ikt)
                (match (rf_exp a)
                  (None None)
                  ((Some ia) (Some (ITrunc ikf ikt ia)))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote ILoad))
       (match args
         ((Cons a Nil)
          (match (rf_exp a)
            (None None)
            ((Some ia) (Some (ILoad ia)))))
         (_ None))
       None))))))))
    (_ None)))

;; one structural walk (the ix_stmts shape: statement dispatch inlined
;; at the Cons head, so the recursion is a single (struct e) descent)
(fn rf_stmts ((e Expr)) (Option (List IStmt))
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) (Some Nil)
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match (rf_stmts t)
            (None None)
            ((Some rest)
             (match h
               ((Ctor hq hargs)
                (if (sym_eq (qn_name hq) (quote ISet))
                  (match hargs
                    ((Cons i (Cons ex Nil))
                     (match (e_int i)
                       (None None)
                       ((Some n)
                        (match (rf_exp ex)
                          (None None)
                          ((Some ie) (Some (Cons (ISet n ie) rest)))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IStore))
                  (match hargs
                    ((Cons a (Cons v Nil))
                     (match (rf_exp a)
                       (None None)
                       ((Some ia)
                        (match (rf_exp v)
                          (None None)
                          ((Some iv) (Some (Cons (IStore ia iv) rest)))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IIf))
                  (match hargs
                    ((Cons c (Cons tb (Cons eb Nil)))
                     (match (rf_exp c)
                       (None None)
                       ((Some ic)
                        (match (rf_stmts tb)
                          (None None)
                          ((Some itb)
                           (match (rf_stmts eb)
                             (None None)
                             ((Some ieb) (Some (Cons (IIf ic itb ieb) rest)))))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IWhile))
                  (match hargs
                    ((Cons c (Cons b Nil))
                     (match (rf_exp c)
                       (None None)
                       ((Some ic)
                        (match (rf_stmts b)
                          (None None)
                          ((Some ib) (Some (Cons (IWhile ic ib) rest)))))))
                    (_ None))
                  None)))))
               (_ None)))))
         (_ None))
       None)))
    (_ None)))

(fn rf_fn ((e Expr)) (Option IFn)
  (match (ec_is e (quote MkIFn))
    (None None)
    ((Some args)
     (match args
       ((Cons p (Cons x (Cons b (Cons r (Cons rk Nil)))))
        (match (rf_kinds p)
          (None None)
          ((Some pks)
           (match (rf_kinds x)
             (None None)
             ((Some xks)
              (match (rf_stmts b)
                (None None)
                ((Some bs)
                 (match (rf_exp r)
                   (None None)
                   ((Some re)
                    (match (rf_kind rk)
                      (None None)
                      ((Some rkk) (Some (MkIFn pks xks bs re rkk)))))))))))))
       (_ None)))))

;; --- fuel: depth bounds, computed structurally, + slack -------------------------

;; imp side: istmts/istmt/iwhile burn one per ENTRY and hand the same
;; reservoir to head and tail — fuel bounds depth, so cost is a max
;; (upper bounds, validated by the kernel check of the emitted certs)
(fn gcost ((ss (List IStmt))) Int
  (measure (struct ss))
  (match ss
    (Nil 1)
    ((Cons s t)
     (match s
       ((ISet _ _) (+ 1 (imax 2 (gcost t))))
       ((IStore _ _) (+ 1 (imax 2 (gcost t))))
       ((IIf _ tb eb) (+ 1 (imax (+ 2 (imax (gcost tb) (gcost eb))) (gcost t))))
       ((IWhile _ _) (+ 1 (imax 2 (gcost t))))))))

;; machine side: the same depth discipline over the TRANSLATED ground
;; value (a Cons spine; Block/Loop/XBlock/XLoop nest) — one generic
;; walk, nesting recognized by basename
(fn tc_nest ((s Symbol)) Bool
  (if (sym_eq s (quote Block)) True
  (if (sym_eq s (quote Loop)) True
  (if (sym_eq s (quote XBlock)) True
  (sym_eq s (quote XLoop))))))

(fn tcost ((e Expr)) Int
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) 1
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match h
            ((Ctor hq hargs)
             (if (tc_nest (qn_name hq))
               (match hargs
                 ((Cons b Nil) (+ 1 (imax (+ 2 (tcost b)) (tcost t))))
                 (_ (+ 1 (imax 2 (tcost t)))))
               (+ 1 (imax 2 (tcost t)))))
            (_ (+ 1 (imax 2 (tcost t))))))
         (_ 1))
       1)))
    (_ 1)))

;; --- the symbolic walk: events in evaluation order -------------------------------
;; The bridge's premise discipline: walk the pin's statements and result
;; with a SYMBOLIC local state (params = x0…, extras = 0), emitting one
;; event per machine-width residue in evaluation order — a wrap pair per
;; exact-op node whose value survives symbolically (ground subtrees
;; compute away, so they carry no residue), a divisor guard per
;; symbolic divisor. Branches fork the walk (continuation folded into
;; both arms); an event's PATH prefixes its premises condition-relative
;; (the §6j hygiene, meta/spell's cond_wrap).

(fn pq ((s Symbol)) QName (QName Nil s))

;; the ground-fold table: the walk's spelling contract (emitted terms
;; are the stuck terms compute leaves) demands ground arith fold at
;; spelling time -- a ground op is never stuck, so an unfolded spelling
;; drifts from every goal the checker produces AND accumulates (a
;; value chained through k steps spells O(k) deep, quadratic over a
;; segment). Every op here is the same total primitive the checker
;; computes, so the fold is identity by construction. Comparisons stay
;; out (Bool-valued; se_cond grounds them to CFollow instead).
(fn sc2_op ((s Symbol) (a Int) (b Int)) (Option Int)
  (if (sym_eq s (quote +)) (Some (+ a b))
  (if (sym_eq s (quote -)) (Some (- a b))
  (if (sym_eq s (quote *)) (Some (* a b))
  (if (sym_eq s (quote ediv)) (Some (ediv a b))
  (if (sym_eq s (quote mod)) (Some (mod a b))
  (if (sym_eq s (quote band)) (Some (band a b))
  (if (sym_eq s (quote bor)) (Some (bor a b))
  (if (sym_eq s (quote bxor)) (Some (bxor a b))
  (if (sym_eq s (quote bshl)) (Some (bshl a b))
  (if (sym_eq s (quote bshr)) (Some (bshr a b))
  None)))))))))))

(fn sc2 ((s Symbol) (a Expr) (b Expr)) Expr
  (match a
    ((IntLit na)
     (match b
       ((IntLit nb)
        (match (sc2_op s na nb)
          ((Some r) (IntLit r))
          (None (Call (pq s) (Cons a (Cons b Nil))))))
       (_ (Call (pq s) (Cons a (Cons b Nil))))))
    (_ (Call (pq s) (Cons a (Cons b Nil))))))

;; value-position spelling of an exact op (comparisons refuse upstream)
(fn op_sym ((o IOp)) Symbol
  (match o
    (IAdd (quote +))
    (ISub (quote -))
    (IMul (quote *))
    (IDiv (quote ediv))
    (IRem (quote mod))
    (IAnd (quote band))
    (IOr (quote bor))
    (IXor (quote bxor))
    (IShl (quote bshl))
    (IShr (quote bshr))
    (IEq (quote int_eq))
    (ILt (quote lt))
    (ILe (quote le))))

(fn is_cmp ((o IOp)) Bool
  (match o
    (IEq True)
    (ILt True)
    (ILe True)
    (_ False)))

(fn is_wrapop ((o IOp)) Bool
  (match o
    (IAdd True)
    (ISub True)
    (IMul True)
    (_ False)))

(fn has_fv ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((FVar _) True)
    ((Call _ args) (has_fv_l args))
    ((Ctor _ args) (has_fv_l args))
    (_ False)))

(fn has_fv_l ((es (List Expr))) Bool
  (measure (struct es))
  (match es
    (Nil False)
    ((Cons h t) (if (has_fv h) True (has_fv_l t)))))

;; symbolic locals: params x0…, extras literal 0 (count down, prepend —
;; the last prepended binder is x0, so the order comes out ascending)
(fn st_params_go ((p Int) (acc (List Expr))) (List Expr)
  (measure p (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt p 1) acc (st_params_go (- p 1) (Cons (FVar (xsym (- p 1))) acc))))

(fn st_params ((p Int)) (List Expr) (st_params_go p Nil))

(fn st_zeros ((x Int)) (List Expr)
  (measure x (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt x 1) Nil (Cons (IntLit 0) (st_zeros (- x 1)))))

(fn st_app ((a (List Expr)) (b (List Expr))) (List Expr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (st_app t b)))))

(fn st_init ((p Int) (x Int)) (List Expr) (st_app (st_params p) (st_zeros x)))

(fn st_get ((st (List Expr)) (i Int)) (Option Expr)
  (measure (struct st))
  (match st
    (Nil None)
    ((Cons h t) (if (int_eq i 0) (Some h) (st_get t (- i 1))))))

(fn st_set ((st (List Expr)) (i Int) (v Expr)) (Option (List Expr))
  (measure (struct st))
  (match st
    (Nil None)
    ((Cons h t)
     (if (int_eq i 0) (Some (Cons v t))
     (match (st_set t (- i 1) v)
       (None None)
       ((Some t2) (Some (Cons h t2))))))))

;; v2 symbolic entry state: params BANDED to their kinds (the walk's
;; leaves are the banded trees the statement's iband_args produces),
;; extras literal 0
(fn st_binit_go ((ks (List IKind)) (i Int)) (List Expr)
  (measure (struct ks))
  (match ks
    (Nil Nil)
    ((Cons k kt)
     (Cons
       (sc2 (quote mod) (FVar (xsym i)) (IntLit (ikmod k)))
       (st_binit_go kt (+ i 1))))))

(fn st_binit ((pks (List IKind)) (xks (List IKind))) (List Expr)
  (st_app (st_binit_go pks 0) (st_zeros (ikn xks))))

;; --- the v2 symbolic walk: banded values + split points --------------------------
;; The walk mirrors iexp/iop_val EXACTLY (the emitted scrutinees must
;; be the stuck terms compute leaves): params enter BANDED (the
;; statement feeds iband_args), op results wrap to their node's kind,
;; bit ops are band-closed, conversions band-narrow. What v1 collected
;; as premise events is now a list of GUARD SCRUTINEES -- each becomes
;; a case-on whose False arm is a trap leaf.

;; walk result: symbolic value + guard scrutinees in evaluation order
(type XR (XOk Expr (List Expr)) (XRf (List Int)))

(fn ga_app ((a (List Expr)) (b (List Expr))) (List Expr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (ga_app t b)))))

;; the collapsed band-spelled rotation tree: the model's double-modded
;; complement ground-collapses under compute at ground counts, so the
;; walk emits the collapsed spelling directly. The OPERAND is banded
;; (the native-rotate amendment — mirrors imp's IRotr exactly; a
;; drifted mirror here emits scrutinee trees the checker's computes
;; never produce)
(fn rot_val ((va Expr) (w Int) (md Int) (kc Int)) Expr
  (let ((vb (sc2 (quote band) va (IntLit (- md 1)))))
    (sc2
      (quote band)
      (sc2
        (quote bor)
        (sc2 (quote bshr) vb (IntLit (mod kc w)))
        (sc2 (quote bshl) vb (IntLit (mod (- w (mod kc w)) w))))
      (IntLit (- md 1)))))

(fn se_exp ((x86 Bool) (e IExp) (st (List Expr))) XR
  (measure (struct e))
  (match e
    ((IConst n) (XOk (IntLit n) Nil))
    ((ILoc i)
     (match (st_get st i)
       (None (XRf "local index out of range"))
       ((Some v) (XOk v Nil))))
    ((IBin k o a b)
     (if (is_cmp o) (XRf "comparison in value position (no pin consumer)")
     (match (se_exp x86 a st)
       ((XRf m) (XRf m))
       ((XOk va ga)
        (match (se_exp x86 b st)
          ((XRf m) (XRf m))
          ((XOk vb gb)
           (match o
             (IDiv
               (if x86 (XRf "division (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (XOk (sc2 (quote ediv) va vb) (ga_app ga gb)))
                 (_
                   (XOk
                     (sc2 (quote ediv) va vb)
                     (ga_app
                       ga
                       (ga_app gb (Cons (sc2 (quote le) (IntLit 1) vb) Nil))))))))
             (IRem
               (if x86 (XRf "remainder (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (XOk (sc2 (quote mod) va vb) (ga_app ga gb)))
                 (_
                   (XOk
                     (sc2 (quote mod) va vb)
                     (ga_app
                       ga
                       (ga_app gb (Cons (sc2 (quote le) (IntLit 1) vb) Nil))))))))
             (IShl
               (match vb
                 ((IntLit kc)
                  (XOk
                    (sc2
                      (quote mod)
                      (sc2 (quote bshl) va (IntLit kc))
                      (IntLit (ikmod k)))
                    (ga_app ga gb)))
                 (_ (XRf "symbolic shift count (wk refuses; unreachable)"))))
             (IShr
               (match vb
                 ((IntLit kc)
                  (XOk (sc2 (quote bshr) va (IntLit kc)) (ga_app ga gb)))
                 (_ (XRf "symbolic shift count (wk refuses; unreachable)"))))
             (IAnd (XOk (sc2 (quote band) va vb) (ga_app ga gb)))
             (IOr (XOk (sc2 (quote bor) va vb) (ga_app ga gb)))
             (IXor (XOk (sc2 (quote bxor) va vb) (ga_app ga gb)))
             (_
               (XOk
                 (sc2 (quote mod) (sc2 (op_sym o) va vb) (IntLit (ikmod k)))
                 (ga_app ga gb))))))))))
    ;; rotation walks identically on BOTH targets since V2-6 (native
    ;; XRorI32 = imp's exact tree; the V2-2b x86 fence retired) —
    ;; kinds a target's translator refuses never reach this walk (the
    ;; tie refuses first and the pin lands as tie+note)
    ((IRotr k a c)
     (match c
       ((IConst kc)
        (match (se_exp x86 a st)
          ((XRf m) (XRf m))
          ((XOk va ga) (XOk (rot_val va (ikw k) (ikmod k) kc) ga))))
       (_ (XRf "symbolic rotation count (wk refuses; unreachable)"))))
    ((IExt _ _ a) (se_exp x86 a st))
    ((ITrunc _ kt a)
     (match (se_exp x86 a st)
       ((XRf m) (XRf m))
       ((XOk va ga) (XOk (sc2 (quote band) va (IntLit (- (ikmod kt) 1))) ga))))
    ((ILoad _)
     (XRf
       "memory in a straight-line pin (the loop tier's denotations carry mem)"))))

;; the branch tree the proof mirrors
(type BT (BTLeaf) (BTBr Expr BT BT))

;; statements walk result: the case-on tree the proof mirrors
(type SR (SROk BT) (SRf (List Int)))

;; wrap a statement's guard splits around the continuation tree: the
;; False arm of every guard is a trap leaf (both machines trap by
;; type; the denotations conflate trap to None on both sides)
(fn bt_guards ((gs (List Expr)) (bt BT)) BT
  (measure (struct gs))
  (match gs
    (Nil bt)
    ((Cons g t) (BTBr g (bt_guards t bt) BTLeaf))))

;; a condition's split spec: CSplit scrut guards flipped (flipped =
;; the True arm selects the ELSE branch -- imp's istmt tests the
;; condition VALUE against zero, so a non-comparison condition splits
;; on (int_eq cv 0)); CFollow z = ground condition, walk the known arm
(type CSpec (CSplit Expr (List Expr) Bool) (CFollow Bool) (CBad (List Int)))

(fn se_cond_val ((x86 Bool) (c IExp) (st (List Expr))) CSpec
  (match (se_exp x86 c st)
    ((XRf m) (CBad m))
    ((XOk cv gs)
     (match cv
       ((IntLit n) (CFollow (int_eq n 0)))
       (_ (CSplit (sc2 (quote int_eq) cv (IntLit 0)) gs True))))))

;; a ground comparison's value (the known arm the walk follows)
(fn cmp_gd ((o IOp) (a Int) (b Int)) Bool
  (match o
    (IEq (int_eq a b))
    (ILt (lt a b))
    (ILe (le a b))
    (_ False)))

;; comparison condition: both operands ground and guard-free follows
;; the known arm (a spelled scrutinee would never stick -- the checker
;; computes the comparison through); z flips (True selects ELSE)
(fn se_cond_cmp ((o IOp) (va Expr) (ga (List Expr)) (vb Expr) (gb (List Expr)))
  CSpec
  (match va
    ((IntLit na)
     (match vb
       ((IntLit nb)
        (match ga
          (Nil
            (match gb
              (Nil (CFollow (if (cmp_gd o na nb) False True)))
              ((Cons _ _) (CSplit (sc2 (op_sym o) va vb) (ga_app ga gb) False))))
          ((Cons _ _) (CSplit (sc2 (op_sym o) va vb) (ga_app ga gb) False))))
       (_ (CSplit (sc2 (op_sym o) va vb) (ga_app ga gb) False))))
    (_ (CSplit (sc2 (op_sym o) va vb) (ga_app ga gb) False))))

(fn se_cond ((x86 Bool) (c IExp) (st (List Expr))) CSpec
  (match c
    ((IBin _ o a b)
     (if (is_cmp o)
       (match (se_exp x86 a st)
         ((XRf m) (CBad m))
         ((XOk va ga)
          (match (se_exp x86 b st)
            ((XRf m) (CBad m))
            ((XOk vb gb) (se_cond_cmp o va ga vb gb)))))
       (se_cond_val x86 c st)))
    (_ (se_cond_val x86 c st))))

;; total statement count (branch bodies included) — the walk's fuel
;; bound: continuation folding consumes each original statement at most
;; once along any one chain
(fn isz_stmts ((ss (List IStmt))) Int
  (measure (struct ss))
  (match ss
    (Nil 0)
    ((Cons s t)
     (match s
       ((ISet _ _) (+ 1 (isz_stmts t)))
       ((IStore _ _) (+ 1 (isz_stmts t)))
       ((IIf _ tb eb) (+ 1 (+ (isz_stmts tb) (+ (isz_stmts eb) (isz_stmts t)))))
       ((IWhile _ b) (+ 1 (+ (isz_stmts b) (isz_stmts t))))))))

;; statements + result, continuation folded into branch arms so every
;; leaf is a complete run; conditions must be comparison-headed and
;; event-free (the no-arith-in-conditions fence). Fueled: folding is
;; not structural, and the size bound above makes underflow unreachable
(fn se_stmts
  ((fuel Int) (x86 Bool) (ss (List IStmt)) (res IExp) (st (List Expr)))
  SR
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) (SRf "walk fuel underflow (internal)")
  (match ss
    (Nil
      (match (se_exp x86 res st)
        ((XRf m) (SRf m))
        ((XOk _ gs) (SROk (bt_guards gs BTLeaf)))))
    ((Cons s t)
     (match s
       ((ISet i e)
        (match (se_exp x86 e st)
          ((XRf m) (SRf m))
          ((XOk v gs)
           (match (st_set st i v)
             (None (SRf "local index out of range"))
             ((Some st2)
              (match (se_stmts (- fuel 1) x86 t res st2)
                ((SRf m) (SRf m))
                ((SROk bt) (SROk (bt_guards gs bt)))))))))
       ((IStore _ _)
        (SRf
          "memory in a straight-line pin (the loop tier's denotations carry mem)"))
       ((IWhile _ _) (SRf "loop pin (the generic loop tier)"))
       ((IIf c tb eb)
        (match (se_cond x86 c st)
          ((CBad m) (SRf m))
          ((CFollow z)
           (se_stmts (- fuel 1) x86 (stmt_app (if z eb tb) t) res st))
          ((CSplit scrut gs flip)
           (match (se_stmts (- fuel 1) x86 (stmt_app tb t) res st)
             ((SRf m) (SRf m))
             ((SROk btt)
              (match (se_stmts (- fuel 1) x86 (stmt_app eb t) res st)
                ((SRf m) (SRf m))
                ((SROk btf)
                 (SROk
                   (bt_guards
                     gs
                     (if flip (BTBr scrut btf btt) (BTBr scrut btt btf))))))))))))))))

(fn stmt_app ((a (List IStmt)) (b (List IStmt))) (List IStmt)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (stmt_app t b)))))

;; --- the tie claim ---------------------------------------------------------------

(fn d_tie
  ((tiepre (List Int)) (nm (List Int)) (trans (List Int)) (pin Symbol) (v Doc))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr tiepre)
      (DStr nm)
      (DStr " (goal () () (= (")
      (DStr trans)
      (DStr " (")
      (dsym pin)
      (DStr ")) ")
      v
      (DStr ")) (steps ((compute both)) refl))")
      (DStr (nl))
      (DStr (nl)))))

;; goal binders: (x0 Int) … then the two fuel tails
(fn d_binds_go ((n Int) (acc Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) acc
  (d_binds_go
    (- n 1)
    (DCat (dcat3 (DStr "(x") (dint (- n 1)) (DStr " Int) ")) acc))))

(fn d_binds ((n Int)) Doc (d_binds_go n (DStr "(c Nat) (c2 Nat)")))

;; call args: (list x0 x1 …), Nil when the pin takes no params
(fn d_args_go ((n Int) (acc Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) acc (d_args_go (- n 1) (dcat3 (DStr " x") (dint (- n 1)) acc))))

(fn d_args ((n Int)) Doc
  (if (lt n 1) (DStr "Nil")
  (dcat3 (DStr "(list") (d_args_go n (DStr "")) (DStr ")"))))

;; --- the v2 goal equation ---------------------------------------------------------

;; the pin's parameter kinds, spelled
(fn d_kind1 ((k IKind)) Doc
  (match k
    (U8 (DStr "U8"))
    (U32 (DStr "U32"))
    (U64 (DStr "U64"))))

(fn d_kinds_go ((ks (List IKind))) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr ""))
    ((Cons k t) (dcat3 (sp) (d_kind1 k) (d_kinds_go t)))))

(fn d_kinds ((ks (List IKind))) Doc
  (match ks
    (Nil (DStr "Nil"))
    ((Cons _ _) (dcat3 (DStr "(list") (d_kinds_go ks) (DStr ")")))))

;; machine side: the banded entry (iband_args -- the v2 alignment
;; relation made syntax); the module's memsize is the wrapper's
;; declared size, discovered by running the wrapper
(fn d_lhs
  ((x86 Bool)
   (trans (List Int))
   (pin Symbol)
   (ff Int)
   (msz Int)
   (ks Doc)
   (args Doc))
  Doc
  (dconc
    (list
      (DStr (if x86 "(xcall_fn (S^ " "(call_fn (S^ "))
      (dint ff)
      (DStr " c) (")
      (DStr (if x86 "MkXModule (list (x_of (" "MkWModule (list (w_of ("))
      (DStr trans)
      (DStr " (")
      (dsym pin)
      (DStr (if x86 ")))) 0 " ")))) "))
      (dint msz)
      (DStr ") 0 (iband_args ")
      ks
      (DStr " ")
      args
      (DStr "))"))))

(fn d_rhs ((wrapnm (List Int)) (pin Symbol) (gg Int) (args Doc)) Doc
  (dconc
    (list
      (DStr "(icall (S^ ")
      (dint gg)
      (DStr " c2) (")
      (DStr wrapnm)
      (DStr " (")
      (dsym pin)
      (DStr ")) 0 ")
      args
      (DStr ")"))))

;; the case-on tree: every arm rewrites its own hypothesis and
;; recomputes; leaves are refl (trap leaves included -- both
;; denotations are None there)
(fn emit_tree ((bt BT)) Doc
  (measure (struct bt))
  (match bt
    (BTLeaf (DStr "refl"))
    ((BTBr c tb fb)
     (dconc
       (list
         (DStr "(case-on ")
         (pr_e c)
         (DStr
           " Bool ((case True (chain (steps ((rewrite (hyp True) lr both true ()) (compute both))) ")
         (emit_tree tb)
         (DStr
           ")) (case False (chain (steps ((rewrite (hyp False) lr both true ()) (compute both))) ")
         (emit_tree fb)
         (DStr "))))"))))))

;; the whole bridge claim: UNPREMISED (the v2 thesis)
(fn d_bridge
  ((brpre (List Int))
   (nm (List Int))
   (pin Symbol)
   (x86 Bool)
   (trans (List Int))
   (wrapnm (List Int))
   (nparams Int)
   (ff Int)
   (gg Int)
   (msz Int)
   (ks Doc)
   (bt BT))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr brpre)
      (DStr nm)
      (DStr " (goal (")
      (d_binds nparams)
      (DStr ") () (= ")
      (d_lhs x86 trans pin ff msz ks (d_args nparams))
      (DStr " ")
      (d_rhs wrapnm pin gg (d_args nparams))
      (DStr ")) ")
      (match bt
        (BTLeaf (DStr "(steps ((compute both)) refl)"))
        ((BTBr _ _ _)
         (dcat3
           (DStr "(chain (steps ((compute both))) ")
           (emit_tree bt)
           (DStr ")"))))
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

;; a bridge the v1 walk declines: the tie stands alone, honestly noted
(fn d_note ((pin Symbol) (why (List Int))) Doc
  (dconc
    (list
      (DStr ";; ")
      (dsym pin)
      (DStr ": tie only (bridge scope: ")
      (DStr why)
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

;; --- bridge-joint discovery ---------------------------------------------------

(fn is_ty1 ((t Type) (s Symbol)) Bool
  (match t
    ((TCon q as)
     (match as
       (Nil (sym_eq (qn_name q) s))
       ((Cons _ _) False)))
    (_ False)))

;; the IFn -> IProg wrapper defined in the source module, by signature
(fn find_wrap ((fns (List FnDef)) (mp (List Symbol))) (Option Symbol)
  (measure (struct fns))
  (match fns
    (Nil None)
    ((Cons f rest)
     (match f
       ((FnDef q ts rt _)
        (match ts
          ((Cons t1 tr)
           (match tr
             (Nil
               (if (is_ty1 t1 (quote IFn))
                 (if (is_ty1 rt (quote IProg))
                   (if (sym_path_eq (qn_mod q) mp) (Some (qn_name q))
                   (find_wrap rest mp))
                   (find_wrap rest mp))
                 (find_wrap rest mp)))
             ((Cons _ _) (find_wrap rest mp))))
          (Nil (find_wrap rest mp))))))))

;; drop through the first underscore (the whole tail if none)
;; --- the loop tier: the generic Some-conditional worker (V2-5) --------------------
;; One IWhile as the WHOLE body, bare-local guard, straight-line loop
;; body, IConst/ILoc result -- the probe-validated form
;; (examples/iwg_probe.shard): the worker carries NO per-program
;; premises; the imp run's landing (= Some o) at ghost-count fuel
;; (S^B (lg_fuel k 0)) is the one premise, B = gcost(loop body) EXACT
;; so base-case fuel death is contradictory. Everything else declines
;; to note-and-tie (branches/nested loops in a body, comparison
;; guards, expression results: named growth).

;; a split the loop walk emits: shared scrutinee (both machines stick
;; on the same term) or the mem-hi bound (imp spells (lt a MSZ), the
;; machine (le (+ a 1) MSZ) -- bridged by a keyed-rows arith have)
(type GSplit (GShared Expr) (GMemHi Expr))

(fn gs_app ((a (List GSplit)) (b (List GSplit))) (List GSplit)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (gs_app t b)))))

;; loop-walk expression result: value + splits (evaluation order)
(type LXR (LXOk Expr (List GSplit)) (LXRf (List Int)))

;; memory-address guards: a symbolic address emits the low bound + the
;; mem-hi pair; a ground in-bounds address emits NONE (both checks
;; compute through -- a spelled scrutinee would never stick); a ground
;; out-of-bounds address refuses (the program traps unconditionally,
;; so no refinement claim exists to state)
(type LWA (LWAGuards (List GSplit)) (LWABad (List Int)))

(fn lws_addr ((va Expr) (msz Int)) LWA
  (match va
    ((IntLit n)
     (if (if (le 0 n) (lt n msz) False) (LWAGuards Nil)
     (LWABad "ground memory address out of bounds (the program traps)")))
    (_
      (LWAGuards
        (Cons (GShared (sc2 (quote le) (IntLit 0) va)) (Cons (GMemHi va) Nil))))))

;; the loop-body walk runs at RAW binders (the worker quantifies
;; arbitrary Int locals) with a symbolic memory
(fn lw_exp ((x86 Bool) (msz Int) (e IExp) (st (List Expr)) (mem Expr)) LXR
  (measure (struct e))
  (match e
    ((IConst n) (LXOk (IntLit n) Nil))
    ((ILoc i)
     (match (st_get st i)
       (None (LXRf "local index out of range"))
       ((Some v) (LXOk v Nil))))
    ((IBin k o a b)
     (if (is_cmp o) (LXRf "comparison in value position (no pin consumer)")
     (match (lw_exp x86 msz a st mem)
       ((LXRf m) (LXRf m))
       ((LXOk va ga)
        (match (lw_exp x86 msz b st mem)
          ((LXRf m) (LXRf m))
          ((LXOk vb gb)
           (match o
             (IDiv
               (if x86 (LXRf "division (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (LXOk (sc2 (quote ediv) va vb) (gs_app ga gb)))
                 (_
                   (LXOk
                     (sc2 (quote ediv) va vb)
                     (gs_app
                       ga
                       (gs_app
                         gb
                         (Cons (GShared (sc2 (quote le) (IntLit 1) vb)) Nil))))))))
             (IRem
               (if x86 (LXRf "remainder (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (LXOk (sc2 (quote mod) va vb) (gs_app ga gb)))
                 (_
                   (LXOk
                     (sc2 (quote mod) va vb)
                     (gs_app
                       ga
                       (gs_app
                         gb
                         (Cons (GShared (sc2 (quote le) (IntLit 1) vb)) Nil))))))))
             (IShl
               (match vb
                 ((IntLit kc)
                  (LXOk
                    (sc2
                      (quote mod)
                      (sc2 (quote bshl) va (IntLit kc))
                      (IntLit (ikmod k)))
                    (gs_app ga gb)))
                 (_ (LXRf "symbolic shift count (wk refuses; unreachable)"))))
             (IShr
               (match vb
                 ((IntLit kc)
                  (LXOk (sc2 (quote bshr) va (IntLit kc)) (gs_app ga gb)))
                 (_ (LXRf "symbolic shift count (wk refuses; unreachable)"))))
             (IAnd (LXOk (sc2 (quote band) va vb) (gs_app ga gb)))
             (IOr (LXOk (sc2 (quote bor) va vb) (gs_app ga gb)))
             (IXor (LXOk (sc2 (quote bxor) va vb) (gs_app ga gb)))
             (_
               (LXOk
                 (sc2 (quote mod) (sc2 (op_sym o) va vb) (IntLit (ikmod k)))
                 (gs_app ga gb))))))))))
    ;; rotation walks identically on BOTH targets since V2-6 (the
    ;; se_exp arm's note applies here verbatim)
    ((IRotr k a c)
     (match c
       ((IConst kc)
        (match (lw_exp x86 msz a st mem)
          ((LXRf m) (LXRf m))
          ((LXOk va ga) (LXOk (rot_val va (ikw k) (ikmod k) kc) ga))))
       (_ (LXRf "symbolic rotation count (wk refuses; unreachable)"))))
    ((IExt _ _ a) (lw_exp x86 msz a st mem))
    ((ITrunc _ kt a)
     (match (lw_exp x86 msz a st mem)
       ((LXRf m) (LXRf m))
       ((LXOk va ga) (LXOk (sc2 (quote band) va (IntLit (- (ikmod kt) 1))) ga))))
    ((ILoad a)
     (match (lw_exp x86 msz a st mem)
       ((LXRf m) (LXRf m))
       ((LXOk va ga)
        (match (lws_addr va msz)
          ((LWABad m) (LXRf m))
          ((LWAGuards gp)
           (match va
             ;; ground load: the spelling contract holds only against a
             ;; pristine symbolic memory (over a store chain the lookup
             ;; itself computes through -- a chain-lookup mirror is
             ;; named growth)
             ((IntLit _)
              (match mem
                ((FVar _) (LXOk (sc2 (quote mem_get) mem va) (gs_app ga gp)))
                (_
                  (LXRf
                    "ground load through a store chain (the lookup computes through; named growth)"))))
             (_ (LXOk (sc2 (quote mem_get) mem va) (gs_app ga gp)))))))))))

;; loop-body statements walk: splits (evaluation order) + post state
(type LSR (LSOk (List GSplit) (List Expr) Expr) (LSRf (List Int)))

(fn lw_stmts
  ((fuel Int)
   (x86 Bool)
   (msz Int)
   (ss (List IStmt))
   (st (List Expr))
   (mem Expr))
  LSR
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) (LSRf "walk fuel underflow (internal)")
  (match ss
    (Nil (LSOk Nil st mem))
    ((Cons s t)
     (match s
       ((ISet i e)
        (match (lw_exp x86 msz e st mem)
          ((LXRf m) (LSRf m))
          ((LXOk v gs)
           (match (st_set st i v)
             (None (LSRf "local index out of range"))
             ((Some st2)
              (match (lw_stmts (- fuel 1) x86 msz t st2 mem)
                ((LSRf m) (LSRf m))
                ((LSOk gt st3 mem3) (LSOk (gs_app gs gt) st3 mem3))))))))
       ((IStore ae ve)
        (match (lw_exp x86 msz ae st mem)
          ((LXRf m) (LSRf m))
          ((LXOk va ga)
           (match (lws_addr va msz)
             ((LWABad m) (LSRf m))
             ((LWAGuards gp)
              (match (lw_exp x86 msz ve st mem)
                ((LXRf m) (LSRf m))
                ((LXOk vv gv)
                 (match
                   (lw_stmts
                     (- fuel 1)
                     x86
                     msz
                     t
                     st
                     (Call
                       (pq (quote mem_set))
                       (Cons mem (Cons va (Cons vv Nil)))))
                   ((LSRf m) (LSRf m))
                   ((LSOk gt st3 mem3)
                    (LSOk (gs_app ga (gs_app gp (gs_app gv gt))) st3 mem3))))))))))
       ((IIf _ _ _)
        (LSRf
          "nested or repeated branch (straight-line arms; one branch per loop body; named growth)"))
       ((IWhile _ _) (LSRf "nested loop (named growth)")))))))

;; drop the last statement (the base case's fuel death point: at
;; B = gcost exactly, iteration one dies at the LAST statement's
;; istmt entry, so only the earlier statements' splits fire)
(fn lw_butlast ((ss (List IStmt))) (List IStmt)
  (measure (struct ss))
  (match ss
    (Nil Nil)
    ((Cons s t)
     (match t
       (Nil Nil)
       ((Cons _ _) (Cons s (lw_butlast t)))))))

;; --- loop-tier emission: the generic worker + the conditional denotation ---------
;; All hyp citations are POSITIONAL (innermost 0). At a leaf under
;; case-ons [guard, s1 .. sj] the indices are s_j = 0 .. s_1 = j-1,
;; guard = j, and the step case's IH sits at j+1. Cut haves join the
;; PREMISES (named), never the hyps.

;; one in-scope split with its case order (0 = the guard, then 1..)
(fn gsp_scrut ((g GSplit) (msz Int)) Doc
  (match g
    ((GShared e) (pr_e e))
    ((GMemHi a)
     (dconc (list (DStr "(lt ") (pr_e a) (DStr " ") (dint msz) (DStr ")"))))))

;; the machine's mem-hi have name for split position i
(fn dl_hle ((i Int)) Doc (dcat3 (DStr "hle") (dint i) (DStr "")))

(fn dl_hlt ((i Int)) Doc (dcat3 (DStr "hlt") (dint i) (DStr "")))

;; haves for the mem-hi splits in scope, at the stated polarity: the
;; lt fact lifted from its hyp (case hyps never join farkas rows),
;; then the machine spelling by an integer-tight keyed-rows cert
(fn dl_memhaves ((gs (List (Pair GSplit Int))) (nhyps Int) (msz Int) (pol Bool))
  Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons (Pair g i) t)
     (match g
       ((GShared _) (dl_memhaves t nhyps msz pol))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(have ")
            (dl_hlt i)
            (DStr "l (= ")
            (gsp_scrut (GMemHi a) msz)
            (DStr (if pol " True) " " False) "))
            (DStr "(steps ((rewrite (hyp ")
            (dint (- nhyps (+ i 1)))
            (DStr ") lr lhs true ())) refl)) ")
            (DStr "(have ")
            (dl_hle i)
            (DStr " (= (le (+ ")
            (pr_e a)
            (DStr " 1) ")
            (dint msz)
            (DStr (if pol ") True) " ") False) "))
            (DStr "(steps () (by arith (rows (goal 1) (")
            (dl_hlt i)
            (DStr "l 1)))) ) ")
            (dl_memhaves t nhyps msz pol))))))))

;; the imp-side resolution chain: guard then each split, hyp rewrites
;; with computes between; side + stop set per caller
(fn dl_impchain ((gs (List (Pair GSplit Int))) (nhyps Int) (stops Doc)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons (Pair _ i) t)
     (dconc
       (list
         (DStr "(rewrite (hyp ")
         (dint (- nhyps (+ i 1)))
         (DStr ") lr rhs true ()) (compute rhs ")
         stops
         (DStr ") ")
         (dl_impchain t nhyps stops))))))

;; the machine-side chain: shared splits rewrite their hyps, mem-hi
;; splits rewrite their machine-spelled haves
(fn dl_machchain ((gs (List (Pair GSplit Int))) (nhyps Int) (stops Doc)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons (Pair g i) t)
     (dconc
       (list
         (match g
           ((GShared _)
            (dcat3
              (DStr "(rewrite (hyp ")
              (dint (- nhyps (+ i 1)))
              (DStr ") lr lhs true ()) ")))
           ((GMemHi _)
            (dcat3
              (DStr "(rewrite (premise ")
              (dl_hle i)
              (DStr ") lr lhs true ()) "))))
         (DStr "(compute lhs ")
         stops
         (DStr ") ")
         (dl_machchain t nhyps stops))))))

;; index the splits 1.. (0 is the guard) and pair each with its order
(fn gs_index ((gs (List GSplit)) (i Int)) (List (Pair GSplit Int))
  (measure (struct gs))
  (match gs
    (Nil Nil)
    ((Cons g t) (Cons (Pair g i) (gs_index t (+ i 1))))))

;; --- the worker leaves ------------------------------------------------------------

;; guard-dead exit: both machines exit with the entry state; the
;; premise pins o. mout = the target's out adapter application around
;; (Some (INorm LOCALS m)) is not needed textually -- the goal rewrite
;; carries it -- so the leaf is target-independent except the machine
;; fuel stop.
(fn wk_exit ((locals Doc) (mstop Doc)) Doc
  (dconc
    (list
      (DStr "(chain (have hro (= (Some (INorm ")
      locals
      (DStr
        " m)) (Some o)) (steps ((rewrite (premise 0) rl rhs true ()) (compute rhs (stop lg_fuel)) (rewrite (hyp 0) lr rhs true ()) (compute rhs (stop lg_fuel))) refl)) (steps ((rewrite (premise hro) rl rhs true ()) (compute rhs) (compute lhs ")
      mstop
      (DStr ") (rewrite (hyp 0) lr lhs true ()) (compute lhs ")
      mstop
      (DStr ")) refl))"))))

;; a bound test failed: both machines trap. scope = guard + every
;; split up to AND INCLUDING the failed one (its polarity False, the
;; others True); mem-hi haves at their stated polarities.
(fn wk_trap
  ((scope (List (Pair GSplit Int)))
   (failed (Pair GSplit Int))
   (msz Int)
   (mstop Doc))
  Doc
  (let ((nh (ilen_gs scope)))
    (dconc
      (list
        (DStr "(chain ")
        (dl_memhaves (gs_butlastp scope) nh msz True)
        (match failed
          ((Pair g i)
           (match g
             ((GShared _) (DStr ""))
             ((GMemHi a)
              (dconc
                (list
                  (DStr "(have ")
                  (dl_hlt i)
                  (DStr "l (= ")
                  (gsp_scrut (GMemHi a) msz)
                  (DStr
                    " False) (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (have ")
                  (dl_hle i)
                  (DStr " (= (le (+ ")
                  (pr_e a)
                  (DStr " 1) ")
                  (dint msz)
                  (DStr ") False) (steps () (by arith (rows (goal 1) (")
                  (dl_hlt i)
                  (DStr "l 1)))) ) ")))))))
        (DStr
          "(have hro (= (Some ITrap) (Some o)) (steps ((rewrite (premise 0) rl rhs true ()) (compute rhs (stop lg_fuel)) ")
        (dl_impchain scope nh (DStr "(stop lg_fuel)"))
        (DStr
          ") refl)) (steps ((rewrite (premise hro) rl rhs true ()) (compute rhs) (compute lhs ")
        mstop
        (DStr ") ")
        (dl_machchain scope nh mstop)
        (DStr ") refl))")))))

;; base-case fuel death under the premise: contradictory, absurd
(fn wk_absurd ((scope (List (Pair GSplit Int)))) Doc
  (let ((nh (ilen_gs scope)))
    (dconc
      (list
        (DStr
          "(chain (have hn (= None (Some o)) (steps ((rewrite (premise 0) rl rhs true ()) (compute rhs) ")
        (dl_impchain_plain scope nh)
        (DStr ") refl)) (absurd (premise hn)))")))))

;; the step arm: the premise transports one iteration, the IH fires
(fn wk_step
  ((scope (List (Pair GSplit Int)))
   (msz Int)
   (bfuel Int)
   (conddoc Doc)
   (ibody Doc)
   (postlocals Doc)
   (postmem Doc)
   (mstop Doc)
   (mfuel Doc)
   (mloop Doc))
  Doc
  (let ((nh (ilen_gs scope)))
    (dconc
      (list
        (DStr "(chain ")
        (dl_memhaves scope nh msz True)
        (DStr "(have hnext (= (iwhile (S^ ")
        (dint bfuel)
        (DStr " (lg_fuel k2 0)) ")
        (dint msz)
        (DStr " ")
        conddoc
        (DStr " (inline ")
        ibody
        (DStr ") ")
        postlocals
        (DStr " ")
        postmem
        (DStr
          ") (Some o)) (steps ((rewrite (premise 0) rl rhs true ()) (unfold lg_fuel rhs) (reduce rhs) (unfold iwhile rhs) (compute rhs (stop iwhile lg_fuel)) ")
        (dl_impchain scope nh (DStr "(stop iwhile lg_fuel)"))
        (DStr ") refl)) (steps ((unfold ")
        mfuel
        (DStr " lhs) (reduce lhs) (unfold ")
        mloop
        (DStr " lhs) (compute lhs (stop ")
        mloop
        (DStr " ")
        mfuel
        (DStr ")) ")
        (dl_machchain
          scope
          nh
          (dconc (list (DStr "(stop ") mloop (DStr " ") mfuel (DStr ")"))))
        (DStr ")) (rewrite-with (hyp ")
        (dint nh)
        (DStr
          ") lr lhs ((inst o o)) ((steps ((rewrite (premise hnext) lr lhs true ())) refl))) refl)")))))

;; scope length + all-but-last (small local helpers)
(fn ilen_gs ((l (List (Pair GSplit Int)))) Int
  (measure (struct l))
  (match l
    (Nil 0)
    ((Cons _ t) (+ 1 (ilen_gs t)))))

(fn gs_butlastp ((l (List (Pair GSplit Int)))) (List (Pair GSplit Int))
  (measure (struct l))
  (match l
    (Nil Nil)
    ((Cons h t)
     (match t
       (Nil Nil)
       ((Cons _ _) (Cons h (gs_butlastp t)))))))

;; the plain-compute imp chain (the base absurd leaf: lg_fuel must
;; compute so the fuel dies)
(fn dl_impchain_plain ((gs (List (Pair GSplit Int))) (nhyps Int)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons (Pair _ i) t)
     (dconc
       (list
         (DStr "(rewrite (hyp ")
         (dint (- nhyps (+ i 1)))
         (DStr ") lr rhs true ()) (compute rhs) ")
         (dl_impchain_plain t nhyps))))))

;; the split tree: nested case-ons, every False arm a trap leaf, the
;; spine ending at the final leaf (absurd in base, the step arm in
;; step). scope carries the guard at order 0.
(fn wk_tree
  ((remaining (List (Pair GSplit Int)))
   (scope (List (Pair GSplit Int)))
   (msz Int)
   (mstop Doc)
   (final Doc))
  Doc
  (measure (struct remaining))
  (match remaining
    (Nil final)
    ((Cons (Pair g i) rest)
     (dconc
       (list
         (DStr "(case-on ")
         (gsp_scrut g msz)
         (DStr " Bool ((case True ")
         (wk_tree rest (gsp_snoc scope (Pair g i)) msz mstop final)
         (DStr ") (case False ")
         (wk_trap (gsp_snoc scope (Pair g i)) (Pair g i) msz mstop)
         (DStr ")))"))))))

(fn gsp_snoc ((l (List (Pair GSplit Int))) (x (Pair GSplit Int)))
  (List (Pair GSplit Int))
  (measure (struct l))
  (match l
    (Nil (Cons x Nil))
    ((Cons h t) (Cons h (gsp_snoc t x)))))

;; --- loop-pin extraction ----------------------------------------------------------

;; reified side: body must be exactly one IWhile over a bare local
(fn lp_pieces ((ifn IFn)) (Option (Pair Int (List IStmt)))
  (match (ibody_of ifn)
    (Nil None)
    ((Cons st1 t)
     (match t
       ((Cons _ _) None)
       (Nil
         (match st1
           ((IWhile c b)
            (match c
              ((ILoc gi) (Some (Pair gi b)))
              (_ None)))
           (_ None)))))))

;; Expr side: a Cons spine to element list
(fn lpe_spine ((e Expr)) (Option (List Expr))
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) (Some Nil)
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match (lpe_spine t)
            (None None)
            ((Some rest) (Some (Cons h rest)))))
         (_ None))
       None)))
    (_ None)))

;; the pin's imp cond + loop-body Exprs (for spelling)
(fn lpe_ibody ((gv Expr)) (Option (Pair Expr Expr))
  (match (ec_is gv (quote MkIFn))
    (None None)
    ((Some args)
     (match args
       ((Cons _ (Cons _ (Cons b (Cons _ (Cons _ Nil)))))
        (match (lpe_spine b)
          ((Some (Cons w Nil))
           (match w
             ((Ctor q wargs)
              (if (sym_eq (qn_name q) (quote IWhile))
                (match wargs
                  ((Cons c (Cons lb Nil)) (Some (Pair c lb)))
                  (_ None))
                None))
             (_ None)))
          (_ None)))
       (_ None)))))

;; split the translated body's element list at the Block/XBlock that
;; carries the loop: (pre, loop body Expr, post)
(fn lpe_wsplit ((els (List Expr)))
  (Option (Pair (List Expr) (Pair Expr (List Expr))))
  (measure (struct els))
  (match els
    (Nil None)
    ((Cons h t)
     (match h
       ((Ctor q hargs)
        (if
          (if (sym_eq (qn_name q) (quote Block)) True
          (sym_eq (qn_name q) (quote XBlock)))
          (match hargs
            ((Cons inner Nil)
             (match (lpe_spine inner)
               ((Some (Cons lp Nil))
                (match lp
                  ((Ctor lq largs)
                   (if
                     (if (sym_eq (qn_name lq) (quote Loop)) True
                     (sym_eq (qn_name lq) (quote XLoop)))
                     (match largs
                       ((Cons w Nil) (Some (Pair Nil (Pair w t))))
                       (_ None))
                     None))
                  (_ None)))
               (_ None)))
            (_ None))
          (match (lpe_wsplit t)
            (None None)
            ((Some (Pair pre (Pair w post)))
             (Some (Pair (Cons h pre) (Pair w post)))))))
       (_ None)))))

;; spell a list of instr elements, space-separated
(fn lpe_spell ((tbl (List (Pair QName Symbol))) (els (List Expr))) SpR
  (measure (struct els))
  (match els
    (Nil (SpROk (DStr "")))
    ((Cons h t)
     (match (sp_e tbl 0 h)
       ((SpRErr m) (SpRErr m))
       ((SpROk d)
        (match (lpe_spell tbl t)
          ((SpRErr m) (SpRErr m))
          ((SpROk ds) (SpROk (dcat3 d (sp) ds)))))))))

;; --- x86 register-file doc --------------------------------------------------------

;; local index -> MkRegs field (rax rcx rdx rbx rbp rsi rdi r8 r9 r10
;; r11 r12 r13 r14 r15): the SysV homes then the callee-saved file
(fn lp_homefield ((i Int)) Int
  (if (int_eq i 0) 6
  (if (int_eq i 1) 5
  (if (int_eq i 2) 2
  (if (int_eq i 3) 1
  (if (int_eq i 4) 7
  (if (int_eq i 5) 8
  (if (int_eq i 6) 3
  (if (int_eq i 7) 4
  (if (int_eq i 8) 11
  (if (int_eq i 9) 12
  (if (int_eq i 10) 13
  (if (int_eq i 11) 14
  -1)))))))))))))

(fn lp_fieldlocal ((j Int) (n Int)) (Option Int)
  (if (lt j 0) None
  (if (int_eq (lp_homefield 0) j) (if (lt 0 n) (Some 0) None)
  (if (int_eq (lp_homefield 1) j) (if (lt 1 n) (Some 1) None)
  (if (int_eq (lp_homefield 2) j) (if (lt 2 n) (Some 2) None)
  (if (int_eq (lp_homefield 3) j) (if (lt 3 n) (Some 3) None)
  (if (int_eq (lp_homefield 4) j) (if (lt 4 n) (Some 4) None)
  (if (int_eq (lp_homefield 5) j) (if (lt 5 n) (Some 5) None)
  (if (int_eq (lp_homefield 6) j) (if (lt 6 n) (Some 6) None)
  (if (int_eq (lp_homefield 7) j) (if (lt 7 n) (Some 7) None)
  (if (int_eq (lp_homefield 8) j) (if (lt 8 n) (Some 8) None)
  (if (int_eq (lp_homefield 9) j) (if (lt 9 n) (Some 9) None)
  (if (int_eq (lp_homefield 10) j) (if (lt 10 n) (Some 10) None)
  (if (int_eq (lp_homefield 11) j) (if (lt 11 n) (Some 11) None)
  None))))))))))))))

(fn lp_regs_go ((j Int) (n Int)) Doc
  (measure (- 15 j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 15)
    (dcat3
      (match (lp_fieldlocal j n)
        ((Some i) (dcat3 (DStr " x") (dint i) (DStr "")))
        (None (DStr " 0")))
      (DStr "")
      (lp_regs_go (+ j 1) n))
    (DStr "")))

(fn lp_regsdoc ((n Int)) Doc
  (dcat3 (DStr "(MkRegs") (lp_regs_go 0 n) (DStr ")")))

;; --- loop-pin claim assembly ------------------------------------------------------

;; the denotation's INorm arm: expose the exit-locals spine to the
;; result local's depth (lget/ilget/xargs then compute); Nil arms are
;; wrong-length states where both machines trap
(fn lp_spine ((d Int) (v Int)) Doc
  (measure d (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt d 1) (DStr "refl")
  (dconc
    (list
      (DStr "(case-on ")
      (if (int_eq v 0) (DStr "lc2") (dcat3 (DStr "r") (dint (- v 1)) (DStr "")))
      (DStr
        " List ((case Nil (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl)) (case Cons (e")
      (dint v)
      (DStr " r")
      (dint v)
      (DStr ") (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
      (DStr "))) ")
      (lp_spine (- d 1) (+ v 1))
      (DStr "))))")))))

;; banded entry locals at the denotation boundary: params (mod xI MI),
;; extras literal 0
(fn lp_banded_go ((ks (List IKind)) (i Int)) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr ""))
    ((Cons k t)
     (dconc
       (list
         (DStr " (mod x")
         (dint i)
         (DStr " ")
         (dint (ikmod k))
         (DStr ")")
         (lp_banded_go t (+ i 1)))))))

(fn lp_zeros_go ((n Int)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (DStr "") (dcat3 (DStr " 0") (DStr "") (lp_zeros_go (- n 1)))))

(fn lp_banded ((pks (List IKind)) (nx Int)) Doc
  (match pks
    (Nil
      (if (lt nx 1) (DStr "Nil")
      (dcat3 (DStr "(list") (lp_zeros_go nx) (DStr ")"))))
    ((Cons _ _)
     (dconc
       (list (DStr "(list") (lp_banded_go pks 0) (lp_zeros_go nx) (DStr ")"))))))

;; --- the x86 exit-spine walker (the il_wlen consumer) -----------------------------

;; ix_out rebuilds the exit register file via xargs, whose computation
;; needs the exit-locals SPINE to the twin's FULL arity — so the x86
;; INorm arm case-ons all nl2+1 levels (wasm's iw_out carries locals
;; opaquely and stops at the result local's depth). Arms:
;;   Nil below the result local  -> the imp result extraction traps,
;;                                  contradicting the Some premise
;;   Nil at/above it             -> refl (xargs zero-fills the missing
;;                                  homes; the result home is filled)
;;   Nil at depth nl2            -> the true exit (xargs grounds)
;;   Cons at depth nl2           -> overlong tail, refuted via il_wlen
;;                                  + ilen_nonneg farkas (cert constant:
;;                                  NL2 - nl2 - 1 = -1 at every arity)

;; the case-on scrutinee at depth v
(fn lpx_scrut ((v Int)) Doc
  (if (int_eq v 0) (DStr "lc2") (dcat3 (DStr "r") (dint (- v 1)) (DStr ""))))

;; spine rewrites (hyp j) down to (hyp 0), on the given side
(fn lpx_sprw ((j Int) (side (List Int))) Doc
  (measure (+ j 1) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 0) (DStr "")
  (dconc
    (list
      (DStr " (rewrite (hyp ")
      (dint j)
      (DStr ") lr ")
      (DStr side)
      (DStr " true ())")
      (lpx_sprw (- j 1) side)))))

;; right-nested (+ 1 (+ 1 ... (ilen rN))) with n +1-levels
(fn lpx_sum ((n Int) (rn Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (dcat3 (DStr "(ilen ") rn (DStr ")"))
  (dcat3 (DStr "(+ 1 ") (lpx_sum (- n 1) rn) (DStr ")"))))

;; n unfold/reduce pairs peeling ilen down a concrete spine
(fn lpx_unf ((n Int)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (DStr "")
  (dcat3 (DStr " (unfold ilen lhs) (reduce lhs)") (DStr "") (lpx_unf (- n 1)))))

;; the absurd-flavor Nil arm at depth v: rebuild the premise's imp run
;; through the case-on hyps until the result extraction computes None
(fn lpx_nilabs ((v Int) (dstops Doc) (stops2 Doc)) Doc
  (dconc
    (list
      (DStr
        "(chain (have hn (= None (Some r)) (steps ((rewrite (premise 0) rl rhs true ()) (compute rhs ")
      dstops
      (DStr ") (rewrite (hyp ")
      (dint (+ v 2))
      (DStr ") lr rhs true ()) (compute rhs ")
      stops2
      (DStr ") (rewrite (hyp ")
      (dint (+ v 1))
      (DStr ") lr rhs true ()) (compute rhs ")
      stops2
      (DStr ")")
      (lpx_sprw v "rhs")
      (DStr " (compute rhs)) refl)) (absurd (premise hn)))"))))

;; the refl-flavor Nil arm (and the depth-nl2 true exit)
(fn lpx_nilref () Doc
  (DStr
    "(chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl)"))

;; the overlong-tail refutation arm at depth nl2 (binders e<nl2> r<nl2>)
(fn lpx_ref ((nl2 Int) (entry Doc)) Doc
  (let ((rn (dcat3 (DStr "r") (dint nl2) (DStr ""))))
    (dconc
      (list
        (DStr "(chain (have hbad (= (iolen (ilen ")
        entry
        (DStr ") (Some (INorm lc2 m2))) ")
        (dint nl2)
        (DStr ") (chain (steps ((rewrite (hyp ")
        (dint (+ nl2 1))
        (DStr ") rl lhs true ()) (rewrite (hyp ")
        (dint (+ nl2 2))
        (DStr
          ") rl lhs true ()))) (rewrite-with (lemma il_wlen) lr lhs () ()) (steps ((compute lhs))) refl)) (have hlen (= (iolen (ilen ")
        entry
        (DStr
          ") (Some (INorm lc2 m2))) (ilen lc2)) (steps ((compute both)) refl)) (have hg (= (ilen lc2) ")
        (dint nl2)
        (DStr
          ") (steps ((rewrite (premise hlen) rl lhs true ()) (rewrite (premise hbad) lr lhs true ())) refl)) (have hs (= (ilen lc2) ")
        (lpx_sum (+ nl2 1) rn)
        (DStr ") (steps (")
        (lpx_sprw nl2 "lhs")
        (lpx_unf (+ nl2 1))
        (DStr ") refl)) (have hnn (= (le 0 (ilen ")
        rn
        (DStr
          ")) True) (chain (rewrite-with (lemma ilen_nonneg) lr lhs () ()) refl)) (have hff (= (le 0 0) False) (steps () (by arith (rows (goal 1) (hg -1) (hs 1) (hnn 1))))) (absurd (premise hff)))")))))

;; the walker: case-on levels 0..nl2
(fn lpx_spine
  ((v Int) (nl2 Int) (rdepth Int) (dstops Doc) (stops2 Doc) (entry Doc))
  Doc
  (measure (- (+ nl2 1) v) (by arith (list 1 0)) (by arith (list 1 1)))
  (dconc
    (list
      (DStr "(case-on ")
      (lpx_scrut v)
      (DStr " List ((case Nil ")
      (if (lt v rdepth) (lpx_nilabs v dstops stops2) (lpx_nilref))
      (DStr ") (case Cons (e")
      (dint v)
      (DStr " r")
      (dint v)
      (DStr ") ")
      (if (lt v nl2)
        (dconc
          (list
            (DStr
              "(chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) ")
            (lpx_spine (+ v 1) nl2 rdepth dstops stops2 entry)
            (DStr ")")))
        (lpx_ref nl2 entry))
      (DStr ")))"))))

;; --- the loop-pin generator -------------------------------------------------------

(fn lp_gen
  ((brpre (List Int))
   (trans (List Int))
   (x86 Bool)
   (wrapnm (List Int))
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (gv Expr)
   (tv Expr))
  ERes
  (match (lp_pieces ifn)
    (None
      (EOk
        (d_note
          pin
          "loop shape (one IWhile over a bare local as the whole body; named growth)")))
    ((Some (Pair gi lbody))
     (if (has_brtop lbody)
       (EOk
         (d_note
           pin
           "branch in a symbolic-count loop body (the pure loop tier; named growth)"))
       (match (lpe_ibody gv)
         (None (EErr "loop pin body shape (internal)"))
         ((Some (Pair condE lbodyE))
          (match (ec_is tv (quote Some))
            (None (EErr "translated value is not Some (internal)"))
            ((Some sargs)
             (match sargs
               ((Cons fexp Nil)
                (match fexp
                  ((Ctor _ margs)
                   (match (last_e margs)
                     (None (EErr "translated func has no body (internal)"))
                     ((Some instrs)
                      (match (lpe_spine instrs)
                        (None (EErr "translated body spine (internal)"))
                        ((Some els)
                         (match (lpe_wsplit els)
                           (None
                             (EOk
                               (d_note pin "translated loop shape (internal)")))
                           ((Some (Pair pre (Pair wbodyE post)))
                            (match (rescheck (iresult_of ifn))
                              (None
                                (EOk
                                  (d_note
                                    pin
                                    "loop result (IConst/ILoc only; named growth)")))
                              ((Some rdepth)
                               (match
                                 (lw_stmts
                                   (+ (isz_stmts lbody) 2)
                                   x86
                                   msz
                                   lbody
                                   (st_params
                                     (+
                                       (ikn (ikparams_of ifn))
                                       (ikn (ikextra_of ifn))))
                                   (FVar (quote m)))
                                 ((LSRf why) (EOk (d_note pin why)))
                                 ((LSOk fsplits postlc postmem)
                                  (match
                                    (lw_stmts
                                      (+ (isz_stmts lbody) 2)
                                      x86
                                      msz
                                      (lw_butlast lbody)
                                      (st_params
                                        (+
                                          (ikn (ikparams_of ifn))
                                          (ikn (ikextra_of ifn))))
                                      (FVar (quote m)))
                                    ((LSRf why) (EOk (d_note pin why)))
                                    ((LSOk bsplits _ _)
                                     (lp_emit brpre trans x86 wrapnm msz pin ifn
                                       gi lbody condE lbodyE wbodyE pre post
                                       margs rdepth fsplits postlc postmem
                                       bsplits))))))))))))))
                  (_ (EErr "translated value shape (internal)"))))
               (_ (EErr "translated value shape (internal)")))))))))))

;; result must be IConst (depth 0) or ILoc i (spine depth i+1)
(fn rescheck ((e IExp)) (Option Int)
  (match e
    ((IConst _) (Some 0))
    ((ILoc i) (Some (+ i 1)))
    (_ None)))

(fn lp_emit
  ((brpre (List Int))
   (trans (List Int))
   (x86 Bool)
   (wrapnm (List Int))
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (gi Int)
   (lbody (List IStmt))
   (condE Expr)
   (lbodyE Expr)
   (wbodyE Expr)
   (pre (List Expr))
   (post (List Expr))
   (margs (List Expr))
   (rdepth Int)
   (fsplits (List GSplit))
   (postlc (List Expr))
   (postmem Expr)
   (bsplits (List GSplit)))
  ERes
  (match (sp_e (harvest lbodyE) 0 lbodyE)
    ((SpRErr m) (EErr m))
    ((SpROk ibodydoc)
     (match (sp_e (harvest wbodyE) 0 wbodyE)
       ((SpRErr m) (EErr m))
       ((SpROk wbodydoc)
        (match (sp_e (harvest condE) 0 condE)
          ((SpRErr m) (EErr m))
          ((SpROk conddoc)
           (match (lpe_spell (harvest (Ctor (pq (quote X)) pre)) pre)
             ((SpRErr m) (EErr m))
             ((SpROk predoc)
              (match (lpe_spell (harvest (Ctor (pq (quote X)) post)) post)
                ((SpRErr m) (EErr m))
                ((SpROk postdoc)
                 (let
                   ((nl2 (+ (ikn (ikparams_of ifn)) (ikn (ikextra_of ifn))))
                    (np (ikn (ikparams_of ifn)))
                    (nm (pin_nm pin))
                    (bfl (- (gcost lbody) 1))
                    (afl (+ (tcost wbodyE) 4))
                    (guard
                      (Pair
                        (GShared
                          (sc2 (quote int_eq) (FVar (xsym gi)) (IntLit 0)))
                        0))
                    (mstop (DStr (if x86 "(stop xlg_fuel)" "(stop lg_fuel)")))
                    (stops2
                      (DStr (if x86 "(stop lg_fuel xlg_fuel)" "(stop lg_fuel)")))
                    (mfuel (DStr (if x86 "xlg_fuel" "lg_fuel")))
                    (mloop (DStr (if x86 "xeval_loop" "eval_loop"))))
                   (let
                     ((gbi
                        (dconc
                          (list
                            (DStr "(fn gb_")
                            (DStr nm)
                            (DStr "_i () (List IStmt) ")
                            ibodydoc
                            (DStr ")")
                            (DStr (nl))
                            (DStr (nl)))))
                      (gbw
                        (dconc
                          (list
                            (DStr "(fn gb_")
                            (DStr nm)
                            (DStr
                              (if x86 "_x () (List XInstr) "
                              "_w () (List Instr) "))
                            wbodydoc
                            (DStr ")")
                            (DStr (nl))
                            (DStr (nl)))))
                      (iwprem
                        (dconc
                          (list
                            (DStr "(= (iwhile (S^ ")
                            (dint bfl)
                            (DStr " (lg_fuel k 0)) ")
                            (dint msz)
                            (DStr " ")
                            conddoc
                            (DStr " (inline gb_")
                            (DStr nm)
                            (DStr "_i) ")
                            (d_args nl2)
                            (DStr " m) (Some o))"))))
                      (moddoc
                        (if x86
                          (dconc
                            (list
                              (DStr "(MkXModule (Cons (MkXFunc ")
                              (dint np)
                              (DStr " (list ")
                              predoc
                              (DStr "(XBlock (list (XLoop (inline gb_")
                              (DStr nm)
                              (DStr "_x)))) ")
                              postdoc
                              (DStr ")) restfs) 0 ")
                              (dint msz)
                              (DStr ")")))
                          (dconc
                            (list
                              (DStr "(MkWModule (Cons (MkFunc ")
                              (dint np)
                              (DStr " ")
                              (dint (- nl2 np))
                              (DStr " (list ")
                              predoc
                              (DStr "(Block (list (Loop (inline gb_")
                              (DStr nm)
                              (DStr "_w)))) ")
                              postdoc
                              (DStr ")) restfs) ")
                              (dint msz)
                              (DStr ")")))))
                      (fscope (gsp_snoc_all guard (gs_index fsplits 1)))
                      (bscope (gsp_snoc_all guard (gs_index bsplits 1)))
                      (entry (lp_banded (ikparams_of ifn) (- nl2 np))))
                     (let
                       ((worker
                          (dconc
                            (list
                              (DStr "(claim ")
                              (DStr (if x86 "ixwg_" "iwg_"))
                              (DStr nm)
                              (DStr " (goal (")
                              (d_binds_go
                                nl2
                                (DStr
                                  (if x86
                                    "(m Mem) (o IOut) (k Nat) (c Nat) (restfs (List XFunc))"
                                    "(st (List Int)) (m Mem) (o IOut) (k Nat) (c Nat) (restfs (List Func))")))
                              (DStr ") (")
                              iwprem
                              (DStr ") (= (")
                              (DStr (if x86 "xeval_loop (S^ " "eval_loop (S^ "))
                              (dint afl)
                              (DStr
                                (if x86 " (xlg_fuel k c)) " " (lg_fuel k c)) "))
                              moddoc
                              (DStr " (inline gb_")
                              (DStr nm)
                              (DStr (if x86 "_x) " "_w) "))
                              (if x86 (lp_regsdoc nl2)
                              (dcat3 (d_args nl2) (DStr " st") (DStr "")))
                              (DStr " m) (")
                              (DStr (if x86 "ix_out 0" "iw_out st"))
                              (DStr
                                " (Some o)))) (induct k ((case Z (case-on (int_eq x")
                              (dint gi)
                              (DStr " 0) Bool ((case True ")
                              (wk_exit (d_args nl2) mstop)
                              (DStr ") (case False ")
                              (wk_tree
                                (gs_index bsplits 1)
                                (Cons guard Nil)
                                msz
                                mstop
                                (wk_absurd bscope))
                              (DStr ")))) (case S (k2) (case-on (int_eq x")
                              (dint gi)
                              (DStr " 0) Bool ((case True ")
                              (wk_exit (d_args nl2) mstop)
                              (DStr ") (case False ")
                              (wk_tree
                                (gs_index fsplits 1)
                                (Cons guard Nil)
                                msz
                                mstop
                                (wk_step
                                  fscope
                                  msz
                                  bfl
                                  conddoc
                                  (dcat3 (DStr "gb_") (DStr nm) (DStr "_i"))
                                  (d_exprlist postlc)
                                  (pr_e postmem)
                                  mstop
                                  mfuel
                                  mloop))
                              (DStr "))))))")
                              (DStr ")")
                              (DStr (nl))
                              (DStr (nl)))))
                        (icallt
                          (dconc
                            (list
                              (DStr "(icall_mem (S^ ")
                              (dint (+ bfl 2))
                              (DStr " (lg_fuel k 0)) (")
                              (DStr wrapnm)
                              (DStr " (")
                              (dsym pin)
                              (DStr ")) 0 ")
                              (d_args np)
                              (DStr " m0)"))))
                        (iwstuck
                          (dconc
                            (list
                              (DStr "(iwhile (S^ ")
                              (dint bfl)
                              (DStr " (lg_fuel k 0)) ")
                              (dint msz)
                              (DStr " ")
                              conddoc
                              (DStr " (inline gb_")
                              (DStr nm)
                              (DStr "_i) ")
                              entry
                              (DStr " m0)"))))
                        (dstops
                          (DStr
                            (if x86 "(stop iwhile xeval_loop xlg_fuel lg_fuel)"
                            "(stop iwhile eval_loop lg_fuel)"))))
                       (let
                         ((denot0
                            (dconc
                              (list
                                (DStr "(claim ")
                                (DStr brpre)
                                (DStr nm)
                                (DStr " (goal (")
                                (d_binds_go
                                  np
                                  (DStr
                                    "(m0 Mem) (r (Pair Int Mem)) (k Nat) (c Nat)"))
                                (DStr ") ((= ")
                                icallt
                                (DStr " (Some r))) (= (")
                                (DStr
                                  (if x86 "xcall_fn_mem (S^ "
                                  "call_fn_mem (S^ "))
                                (dint (+ (+ afl 4) (ilen_e pre)))
                                (DStr
                                  (if x86
                                    " (xlg_fuel k c)) (MkXModule (list (x_of ("
                                    " (lg_fuel k c)) (MkWModule (list (w_of ("))
                                (DStr trans)
                                (DStr " (")
                                (dsym pin)
                                (DStr (if x86 ")))) 0 " ")))) "))
                                (dint msz)
                                (DStr ") 0 (iband_args ")
                                (d_kinds (ikparams_of ifn))
                                (DStr " ")
                                (d_args np)
                                (DStr ") m0) ")
                                icallt
                                (DStr ")) (chain (steps ((compute both ")
                                dstops
                                (DStr "))) (case-on ")
                                iwstuck
                                (DStr
                                  " Option ((case None (chain (have hn (= None (Some r)) (steps ((rewrite (premise 0) rl rhs true ()) (compute rhs ")
                                dstops
                                (DStr
                                  ") (rewrite (hyp 0) lr rhs true ()) (compute rhs)) refl)) (absurd (premise hn)))) (case Some (o) (chain (rewrite-with (lemma ")
                                (DStr (if x86 "ixwg_" "iwg_"))
                                (DStr nm)
                                (DStr
                                  ") lr lhs ((inst o o)) ((steps ((rewrite (hyp 0) lr lhs true ())) refl))) (steps ((rewrite (hyp 0) lr rhs true ()) (compute both ")
                                stops2
                                (DStr
                                  "))) (case-on o IOut ((case INorm (lc2 m2) (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) ")
                                (if x86
                                  (lpx_spine 0 nl2 rdepth dstops stops2 entry)
                                  (lp_spine rdepth 0))
                                (DStr
                                  ")) (case ITrap (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl)))))))))")
                                (DStr ")")
                                (DStr (nl))
                                (DStr (nl))))))
                         (EOk
                           (dconc
                             (list
                               gbi
                               gbw
                               worker
                               denot0
                               (DStr (nl))
                               (DStr (nl))))))))))))))))))))

;; prepend one element (the guard) to an indexed split list
(fn gsp_snoc_all ((g (Pair GSplit Int)) (l (List (Pair GSplit Int))))
  (List (Pair GSplit Int))
  (Cons g l))

(fn ilen_e ((l (List Expr))) Int
  (measure (struct l))
  (match l
    (Nil 0)
    ((Cons _ t) (+ 1 (ilen_e t)))))

;; spelled post-state locals list
(fn d_exprlist_go ((es (List Expr))) Doc
  (measure (struct es))
  (match es
    (Nil (DStr ""))
    ((Cons h t) (dcat3 (sp) (pr_e h) (d_exprlist_go t)))))

(fn d_exprlist ((es (List Expr))) Doc
  (match es
    (Nil (DStr "Nil"))
    ((Cons _ _) (dcat3 (DStr "(list") (d_exprlist_go es) (DStr ")")))))

;; --- the statement tier: seq-grain legs for memful straight-line pins --------------
;; A pin whose body is straight-line but touches memory (the sha
;; bodies) bridges at STATEMENT grain: machine seq run = seq adapter
;; of the imp statement run, UNPREMISED (probe-validated form,
;; examples/sqw_probe/sqx_probe). The walk is the loop tier's lw_stmts
;; verbatim (raw symbolic locals + symbolic memory); the proof is the
;; split spine with compute-both leaves -- shared low-bound guards
;; case-on directly, mem-hi guards case-on the imp spelling (lt a MSZ)
;; and bridge to the machine spelling (le (+ a 1) MSZ) by a keyed-rows
;; have-pair at the arm's polarity. Trap arms close by computation on
;; both sides (both machines trap; the adapters conflate). The x86 leg
;; states the SEALED translation (ix_sstmts): the chunk exits at
;; scratch zero, so the exit register file is exactly (xargs locals)
;; through ix_sout.

;; any memory op in a straight-line body (the dispatch key)
(fn hm_exp ((e IExp)) Bool
  (measure (struct e))
  (match e
    ((IConst _) False)
    ((ILoc _) False)
    ((IBin _ _ a b) (if (hm_exp a) True (hm_exp b)))
    ((IRotr _ a c) (if (hm_exp a) True (hm_exp c)))
    ((IExt _ _ a) (hm_exp a))
    ((ITrunc _ _ a) (hm_exp a))
    ((ILoad _) True)))

(fn has_mem ((ss (List IStmt))) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons s t)
     (match s
       ((ISet _ e) (if (hm_exp e) True (has_mem t)))
       ((IStore _ _) True)
       ((IIf _ tb eb) (if (has_mem tb) True (if (has_mem eb) True (has_mem t))))
       ((IWhile _ b) (if (has_mem b) True (has_mem t)))))))

;; append two ground Cons-spine Exprs (the kind env for the iw_stmts
;; invoke: params ++ extras, reusing the value's own canonical qnames)
(fn e_app_spine ((a Expr) (b Expr)) Expr
  (measure (struct a))
  (match a
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) b
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil)) (Ctor q (Cons h (Cons (e_app_spine t b) Nil))))
         (_ a))
       a)))
    (_ a)))

;; split identity (dedup key): same variant, same scrutinee tree. An
;; all-occurrence rewrite resolves every duplicate of a scrutinee at
;; its first split, so later duplicates are dropped, not re-split.
(fn gs_eq ((a GSplit) (b GSplit)) Bool
  (match a
    ((GShared e1)
     (match b
       ((GShared e2) (expr_eq e1 e2))
       ((GMemHi _) False)))
    ((GMemHi e1)
     (match b
       ((GShared _) False)
       ((GMemHi e2) (expr_eq e1 e2))))))

(fn gs_seen ((seen (List GSplit)) (g GSplit)) Bool
  (measure (struct seen))
  (match seen
    (Nil False)
    ((Cons h t) (if (gs_eq h g) True (gs_seen t g)))))

(fn gs_dedup ((seen (List GSplit)) (gs (List GSplit))) (List GSplit)
  (measure (struct gs))
  (match gs
    (Nil Nil)
    ((Cons g t)
     (if (gs_seen seen g) (gs_dedup seen t) (Cons g (gs_dedup (Cons g seen) t))))))

;; the mem-hi bridge at one polarity: lift the case hyp into a have
;; (case hyps never join farkas rows), derive the machine spelling by
;; the integer-tight cert, then resolve the imp side by the hyp and
;; the machine side by the have
(fn sq_mh ((i Int) (a Expr) (msz Int) (pol (List Int))) Doc
  (dconc
    (list
      (DStr "(have hlt")
      (dint i)
      (DStr " (= (lt ")
      (pr_e a)
      (DStr " ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (have hle")
      (dint i)
      (DStr " (= (le (+ ")
      (pr_e a)
      (DStr " 1) ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps () (by arith (rows (goal 1) (hlt")
      (dint i)
      (DStr
        " 1))))) (steps ((rewrite (hyp 0) lr rhs true ()) (rewrite (premise hle")
      (dint i)
      (DStr ") lr lhs true ()) (compute both)))"))))

;; the split spine: every False arm is a compute-closed trap leaf, the
;; final True leaf is refl (both sides fully ground under the resolved
;; guards)
(fn sq_spine ((gs (List GSplit)) (i Int) (msz Int)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr "refl"))
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (DStr
              " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) ")
            (sq_spine t (+ i 1) msz)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (sq_mh i a msz "True")
            (DStr " ")
            (sq_spine t (+ i 1) msz)
            (DStr ")) (case False (chain ")
            (sq_mh i a msz "False")
            (DStr " refl))))"))))))))

;; the statement-tier tie: the seq translation product itself
;; (iw_stmts at the pin's kind env / the SEALED ix_sstmts)
(fn d_sqtie
  ((tiepre (List Int)) (nm (List Int)) (x86 Bool) (pin Symbol) (ks Doc) (v Doc))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr tiepre)
      (DStr nm)
      (DStr " (goal () () (= ")
      (if x86 (dcat3 (DStr "(ix_sstmts (ibody_of (") (dsym pin) (DStr ")))"))
      (dconc
        (list
          (DStr "(iw_stmts ")
          ks
          (DStr " (ibody_of (")
          (dsym pin)
          (DStr ")))"))))
      (DStr " ")
      v
      (DStr ")) (steps ((compute both)) refl))")
      (DStr (nl))
      (DStr (nl)))))

;; the seq-grain bridge claim. Bodies spell FLAT ((list e …), via
;; spl_e) exactly as the mixed tier's sqm_emit does: a Nil-terminated
;; Cons spine indents at growing depth under shardfmt, so a long
;; straight-line body (the sha round/ext legs, the K/H init's ~577
;; stmts) costs quadratically to format as a Cons spine; the flat
;; form indents at constant depth and stays linear. The desugared
;; term is identical, so every bridge/tie is byte-unchanged in
;; meaning (the byte-tie gate re-verifies over canon).
(fn sq_emit
  ((brpre (List Int))
   (x86 Bool)
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (bodyE Expr)
   (instrsE Expr)
   (splits (List GSplit)))
  ERes
  (match (spl_e bodyE)
    ((SpRErr m) (EErr m))
    ((SpROk ibodydoc)
     (match (spl_e instrsE)
       ((SpRErr m) (EErr m))
       ((SpROk wbodydoc)
        (let
          ((nm (pin_nm pin))
           (nl (+ (ikn (ikparams_of ifn)) (ikn (ikextra_of ifn))))
           (gg (+ (gcost (ibody_of ifn)) 4))
           (aa (+ (tcost instrsE) 4))
           (ds (gs_dedup Nil splits)))
          (let
            ((gbi
               (dconc
                 (list
                   (DStr "(fn gb_")
                   (DStr nm)
                   (DStr "_i () (List IStmt) ")
                   ibodydoc
                   (DStr ")")
                   (DStr (nl))
                   (DStr (nl)))))
             (gbw
               (dconc
                 (list
                   (DStr "(fn gb_")
                   (DStr nm)
                   (DStr (if x86 "_x () (List XInstr) " "_w () (List Instr) "))
                   wbodydoc
                   (DStr ")")
                   (DStr (nl))
                   (DStr (nl))))))
            (EOk
              (dconc
                (list
                  gbi
                  gbw
                  (DStr "(claim ")
                  (DStr brpre)
                  (DStr nm)
                  (DStr " (goal (")
                  (d_binds_go
                    nl
                    (DStr
                      (if x86 "(m Mem) (c Nat) (c2 Nat) (restfs (List XFunc))"
                      "(st (List Int)) (m Mem) (c Nat) (c2 Nat) (restfs (List Func))")))
                  (DStr ") () (= (")
                  (DStr (if x86 "xeval_seq (S^ " "eval_seq (S^ "))
                  (dint aa)
                  (DStr
                    (if x86 " c) (MkXModule restfs 0 " " c) (MkWModule restfs "))
                  (dint msz)
                  (DStr ") (inline gb_")
                  (DStr nm)
                  (DStr (if x86 "_x) " "_w) "))
                  (if x86 (lp_regsdoc nl)
                  (dcat3 (d_args nl) (DStr " st") (DStr "")))
                  (DStr " m) (")
                  (DStr (if x86 "ix_sout " "iw_sout st "))
                  (DStr "(istmts (S^ ")
                  (dint gg)
                  (DStr " c2) ")
                  (dint msz)
                  (DStr " (inline gb_")
                  (DStr nm)
                  (DStr "_i) ")
                  (d_args nl)
                  (DStr " m)))) (chain (steps ((compute both))) ")
                  (sq_spine ds 1 msz)
                  (DStr "))")
                  (DStr (nl))
                  (DStr (nl))))))))))))

;; one statement pin, one target: run the SEQ translator on the pin's
;; body value, spell the tie, then the bridge (wrapper-gated: the
;; declared memsize comes from the IProg wrapper). Walk refusals
;; (rotation on x86, branches) leave the tie standing with the honest
;; note.
(fn sq_pin
  ((msrc Module)
   (mtr Module)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (wrap (Option Symbol))
   (pin Symbol)
   (gv Expr)
   (ifn IFn))
  ERes
  (match (ec_is gv (quote MkIFn))
    (None (EErr "pin value shape (internal)"))
    ((Some margs)
     (match margs
       ((Cons pksE (Cons xksE (Cons bodyE _)))
        (match
          (if x86 (invoke mtr (quote ix_sstmts) (Cons bodyE Nil))
          (invoke
            mtr
            (quote iw_stmts)
            (Cons (e_app_spine pksE xksE) (Cons bodyE Nil))))
          (None
            (EErr
              (append_int
                "statement translator invoke failed on "
                (chars_of_sym pin))))
          ((Some tv)
           (match (ec_is tv (quote None))
             ((Some _) (EOk (d_refused pin tname)))
             (None
               (match (ec_is tv (quote Some))
                 (None (EErr "translated value is not Some (internal)"))
                 ((Some sargs)
                  (match sargs
                    ((Cons instrsE Nil)
                     (match (spl_e tv)
                       ((SpRErr m) (EErr m))
                       ((SpROk vdoc)
                        (let
                          ((tie
                             (d_sqtie
                               tiepre
                               (pin_nm pin)
                               x86
                               pin
                               (d_kinds
                                 (ikapp (ikparams_of ifn) (ikextra_of ifn)))
                               vdoc)))
                          (match wrap
                            (None
                              (EOk
                                (DCat
                                  tie
                                  (d_note
                                    pin
                                    "statement pin without an IProg wrapper"))))
                            ((Some wnm)
                             (match (wrap_msz msrc wnm gv)
                               (None
                                 (EErr
                                   "wrapper does not yield an IProg (internal)"))
                               ((Some msz)
                                (match
                                  (lw_stmts
                                    (+ (isz_stmts (ibody_of ifn)) 2)
                                    x86
                                    msz
                                    (ibody_of ifn)
                                    (st_params
                                      (+
                                        (ikn (ikparams_of ifn))
                                        (ikn (ikextra_of ifn))))
                                    (FVar (quote m)))
                                  ((LSRf why) (EOk (DCat tie (d_note pin why))))
                                  ((LSOk splits _ _)
                                   (match
                                     (sq_emit brpre x86 msz pin ifn bodyE
                                       instrsE splits)
                                     ((EErr msg) (EErr msg))
                                     ((EOk bdoc) (EOk (DCat tie bdoc))))))))))))))
                    (_ (EErr "translated value shape (internal)"))))))))))
       (_ (EErr "pin value shape (internal)"))))))

;; --- the mixed tier: seq-grain legs for bodies with embedded counting loops --------
;; (docs/IMP.md V2-5e-4). A body whose top-level shape is straight-line
;; segments around bare-local counting IWhiles bridges at statement
;; grain like the statement tier, with each loop resolved by a
;; COUNTER-TIED generic worker (probe-validated: examples/sqmw_probe
;; single loop, examples/sqm2_probe two loops + the exit-arity
;; refutations). The worker aligns eval_loop with iwhile by induction
;; on the counter (int_of_nat k in the guard slot), UNPREMISED except
;; the counter cap; locals ride an OPEN Cons-spine (tail binder rr), so
;; the worker fires at the Nil-terminated entry AND at later loop
;; heads' case-var spines. The spine stays UNPREMISED: at each loop
;; head the residual towers reshape to the worker's
;; (S^ B (lg_fuel K slack)) shape at the GROUND count (the counter was
;; set by a segment constant), the worker rewrite plants the SHARED
;; iwhile term on both sides, and one Option/IOut case-on absorbs every
;; outcome through the adapters. Exit locals are exposed by nl+1
;; case-ons; wrong-arity arms refute by il_wlen (the lpx precedent,
;; wasm flavor); the depth-nl Nil arm continues with a Nil-terminated
;; spine, so entry spellings stay ground-length at every loop. v1
;; fences (decline to tie+note): non-bare-local guards, non-ground or
;; non-U32 counters, missing trailing decrement, top-level branches,
;; x86 emission (named growth; rotating bodies refuse in the walk with
;; the honest V2-2b note).

;; the loop-body branch payload (IF-2): the shared raw comparison
;; scrutinee at the walked post-prefix state + the per-REGION deduped
;; splits (then / else; the prefix region rides the wsplits field).
;; Regions never dedup across the polarity case-on — arm guard
;; occurrences materialize only after the polarity resolves (the
;; IF-1c law, blueprint-validated inside the worker by sqblw/sqblx).
(type LBr (MkLBr Expr (List GSplit) (List GSplit)))

(type MxLp
  (MkMxLp
    Int  ;; gi — the counter slot
    Int  ;; kg — the ground count at the loop head
    Expr  ;; lbodyE — the loop body sublist (ground Expr)
    (List IStmt)  ;; lbody — the loop body, reified
    (List Expr)  ;; hlocals — walked locals at the loop head
    Expr  ;; hmem — walked memory at the loop head
    (List GSplit)  ;; wsplits — the worker's per-iteration splits (the prefix region when a branch is present)
    (Option LBr)  ;; lbr — the loop-body branch payload (IF-2)
    Int))  ;; pi — imp spine position

(type MxEv (MxSp GSplit) (MxL MxLp))
(type MxR (MxOk (List MxEv)) (MxRf (List Int)))

;; --- the compositional piece grammar (V2-5e-4, option A) --------------------
;; A mixed body slices into alternating FLAT SEGMENTS (ISet/IStore
;; runs) and LOOP PIECES (the counter-set statement RIDES WITH its
;; IWhile: the ground counter is restored by a concrete set over the
;; previous piece's exposed case-vars). Segments carry their stmts +
;; ground Exprs; loop pieces carry the worker inventory (gi, kg,
;; body, body Expr, per-iteration splits).
(type MxPc
  (MxPS (List IStmt) (List Expr))
  (MxPL
    Int
    Int
    (List IStmt)
    Expr
    (List GSplit)
    (Option LBr)
    (List (Pair Int Int)))
  (MxPB IStmt Expr Expr Bool (List GSplit) (List GSplit) Int))
(type MxPR (MxPOk (List MxPc)) (MxPRf (List Int)))

;; conservative node count over a reified tree (Ctor/Call nodes +
;; leaves); 2x + 4 bounds any walk path's fuel need (each seq element
;; costs one seq peel + one instr peel; block nesting is covered by
;; the Block node's own count) -- oversupply is safe on both sides of
;; a branch sub-lemma (the parked continuation is claim-minus-one
;; regardless of arm, and completed standalone runs are
;; fuel-independent above need)
(fn mxb_count ((e Expr)) Int
  (measure (struct e))
  (match e
    ((Ctor _ args) (+ 1 (mxb_countl args)))
    ((Call _ args) (+ 1 (mxb_countl args)))
    (_ 1)))

(fn mxb_countl ((es (List Expr))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons h t) (+ (mxb_count h) (mxb_countl t)))))

(fn mxb_k ((sl (List Expr))) Int
  (match sl
    (Nil 8)
    ((Cons h _) (+ (* 2 (mxb_count h)) 4))))

;; --- the loop-body region walk (IF-2) ----------------------------------
;; A loop body holding at most ONE top-level IIf: the prefix walks at
;; the loop-head state, the shared raw comparison scrutinee is taken
;; at the post-prefix state (mxc_br's constraints: comparison-headed,
;; guard-free operands), and EACH ARM walks arm-stmts ++ post-tail
;; from the post-prefix state — per-region deduped splits and a
;; per-arm post-state, the counter's trailing band-decrement checked
;; on BOTH. A second IIf lands in the post-tail walk and bubbles
;; lw_stmts's own named refusal.

(fn lwb_split ((ss (List IStmt)))
  (Option (Pair (List IStmt) (Pair IStmt (List IStmt))))
  (measure (struct ss))
  (match ss
    (Nil None)
    ((Cons s t)
     (match s
       ((IIf _ _ _) (Some (Pair Nil (Pair s t))))
       (_
         (match (lwb_split t)
           (None None)
           ((Some (Pair pre (Pair br post)))
            (Some (Pair (Cons s pre) (Pair br post))))))))))

(type LWBR
  (LWBOk (List GSplit) (Option LBr) (List Expr) (List Expr))
  (LWBRf (List Int)))

;; the trailing band-decrement shape at the counter slot
(fn lwb_dec ((gi Int) (lc (List Expr))) Bool
  (match (st_get lc gi)
    (None False)
    ((Some pv)
     (expr_eq
       pv
       (sc2
         (quote mod)
         (sc2
           (quote -)
           (sc2
             (quote +)
             (IntLit 1)
             (Call (pq (quote int_of_nat)) (Cons (FVar (quote k2)) Nil)))
           (IntLit 1))
         (IntLit 4294967296))))))

(fn lwb_walk
  ((x86 Bool) (msz Int) (gi Int) (lbody (List IStmt)) (wst (List Expr)))
  LWBR
  (match (lwb_split lbody)
    (None
      (match
        (lw_stmts (+ (isz_stmts lbody) 2) x86 msz lbody wst (FVar (quote m)))
        ((LSRf why) (LWBRf why))
        ((LSOk wsplits postlc _)
         (if (lwb_dec gi postlc)
           (LWBOk (gs_dedup Nil wsplits) None postlc postlc)
           (LWBRf
             "loop counter is not a trailing band-decrement (named growth)")))))
    ((Some (Pair pre (Pair br post)))
     (match br
       ((IIf cnd tb eb)
        (match (lw_stmts (+ (isz_stmts pre) 2) x86 msz pre wst (FVar (quote m)))
          ((LSRf why) (LWBRf why))
          ((LSOk gspre sta mema)
           (match cnd
             ((IBin _ o ca cb)
              (if (is_cmp o)
                (match (lw_exp x86 msz ca sta mema)
                  ((LXRf m2) (LWBRf m2))
                  ((LXOk va ga)
                   (match (lw_exp x86 msz cb sta mema)
                     ((LXRf m2) (LWBRf m2))
                     ((LXOk vb gb)
                      (match (gs_app ga gb)
                        ((Cons _ _)
                         (LWBRf
                           "loop-body branch condition carries guards (named growth)"))
                        (Nil
                          (match
                            (lw_stmts (+ (isz_stmts tb) 2) x86 msz tb sta mema)
                            ((LSRf m2) (LWBRf m2))
                            ((LSOk gst stt memt)
                             (match
                               (lw_stmts
                                 (+ (isz_stmts post) 2)
                                 x86
                                 msz
                                 post
                                 stt
                                 memt)
                               ((LSRf m2) (LWBRf m2))
                               ((LSOk gstp sttp _)
                                (match
                                  (lw_stmts
                                    (+ (isz_stmts eb) 2)
                                    x86
                                    msz
                                    eb
                                    sta
                                    mema)
                                  ((LSRf m2) (LWBRf m2))
                                  ((LSOk gse ste meme)
                                   (match
                                     (lw_stmts
                                       (+ (isz_stmts post) 2)
                                       x86
                                       msz
                                       post
                                       ste
                                       meme)
                                     ((LSRf m2) (LWBRf m2))
                                     ((LSOk gsep step2 _)
                                      (if (lwb_dec gi sttp)
                                        (if (lwb_dec gi step2)
                                          (LWBOk
                                            (gs_dedup Nil gspre)
                                            (Some
                                              (MkLBr
                                                (sc2 (op_sym o) va vb)
                                                (gs_dedup Nil (gs_app gst gstp))
                                                (gs_dedup Nil (gs_app gse gsep))))
                                            sttp
                                            step2)
                                          (LWBRf
                                            "loop counter is not a trailing band-decrement (named growth)"))
                                        (LWBRf
                                          "loop counter is not a trailing band-decrement (named growth)"))))))))))))))))
                (LWBRf
                  "non-comparison loop-body branch condition (named growth)")))
             (_
               (LWBRf
                 "non-comparison loop-body branch condition (named growth)"))))))
       (_ (LWBRf "loop-body walk shape (internal)"))))))

;; validate one top-level branch and build its piece: comparison-headed
;; condition only (both machines stick on the SAME raw-operand
;; comparison tree -- iop_val compares unwrapped, iw_cond emits the
;; fused comparison; the shared scrutinee IS the inner cmp term),
;; guard-free condition operands, straight-line arms (lw_stmts's own
;; fences refuse nested control). The arm walks run at fresh symbolic
;; locals -- exactly the sub-lemma's binders.
(fn mxc_br
  ((x86 Bool)
   (msz Int)
   (cnd IExp)
   (tb (List IStmt))
   (eb (List IStmt))
   (sE Expr)
   (nl Int))
  MxPR
  (match cnd
    ((IBin k o a b)
     (if (is_cmp o)
       (match (lw_exp x86 msz a (st_params nl) (FVar (quote m)))
         ((LXRf m2) (MxPRf m2))
         ((LXOk va ga)
          (match (lw_exp x86 msz b (st_params nl) (FVar (quote m)))
            ((LXRf m2) (MxPRf m2))
            ((LXOk vb gb)
             (match (gs_app ga gb)
               ((Cons _ _)
                (MxPRf "branch condition carries guards (named growth)"))
               (Nil
                 (match
                   (lw_stmts
                     (+ (isz_stmts tb) 2)
                     x86
                     msz
                     tb
                     (st_params nl)
                     (FVar (quote m)))
                   ((LSRf m2) (MxPRf m2))
                   ((LSOk tgs _ _)
                    (match
                      (lw_stmts
                        (+ (isz_stmts eb) 2)
                        x86
                        msz
                        eb
                        (st_params nl)
                        (FVar (quote m)))
                      ((LSRf m2) (MxPRf m2))
                      ((LSOk egs _ _)
                       (MxPOk
                         (Cons
                           (MxPB
                             (IIf cnd tb eb)
                             sE
                             (sc2 (op_sym o) va vb)
                             True
                             tgs
                             egs
                             (+ (* 2 (mxb_count sE)) 4))
                           Nil))))))))))))
       (MxPRf "non-comparison branch condition (named growth)")))
    (_ (MxPRf "non-comparison branch condition (named growth)"))))

;; validate one loop head (guard/kind/count/decrement) and build its
;; worker inventory -- the mx_walk IWhile block, state-free: the
;; worker walk runs at fresh symbolic locals with the counter tied.
(fn mxc_loop
  ((x86 Bool)
   (msz Int)
   (gi Int)
   (kg Int)
   (lbody (List IStmt))
   (sE Expr)
   (nl Int)
   (ks (List IKind)))
  MxPR
  (match (ikat ks gi)
    (None (MxPRf "counter slot outside the kind env (internal)"))
    ((Some gk)
     (match gk
       (U32
         (if (lt kg 0) (MxPRf "negative counter at a loop head (named growth)")
         (match (ec_is sE (quote IWhile))
           (None (MxPRf "loop Expr shape (internal)"))
           ((Some wargs)
            (match wargs
              ((Cons _ (Cons lbE Nil))
               (match
                 (st_set
                   (st_params nl)
                   gi
                   (sc2
                     (quote +)
                     (IntLit 1)
                     (Call (pq (quote int_of_nat)) (Cons (FVar (quote k2)) Nil))))
                 (None (MxPRf "counter slot out of range (internal)"))
                 ((Some wst)
                  (match (lwb_walk x86 msz gi lbody wst)
                    ((LWBRf why) (MxPRf why))
                    ((LWBOk wsplits lbr _ _)
                     (MxPOk (Cons (MxPL gi kg lbody lbE wsplits lbr Nil) Nil)))))))
              (_ (MxPRf "loop Expr shape (internal)")))))))
       (_ (MxPRf "non-U32 loop counter (named growth)"))))))

;; cap check: flush the accumulated segment when it is full (24
;; stmts) and the incoming stmt is NOT a const-set (const-runs must
;; never straddle a flush -- the loop pop needs them intact)
(fn mxc_capq ((s IStmt) (rs (List IStmt))) Bool
  (match s
    ((ISet _ sv)
     (match sv
       ((IConst _) False)
       (_ (if (lt (isz_top rs) 24) False True))))
    (_ (if (lt (isz_top rs) 24) False True))))

;; the piece slicer: accumulate flat statements; a counter-set
;; IMMEDIATELY BEFORE a matching IWhile flushes the segment and opens
;; a loop piece. rs/rsE = the reversed segment accumulators.
(fn mxc_slice
  ((fuel Int)
   (x86 Bool)
   (msz Int)
   (ss (List IStmt))
   (ssE (List Expr))
   (rs (List IStmt))
   (rsE (List Expr))
   (nl Int)
   (ks (List IKind)))
  MxPR
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) (MxPRf "piece slicer fuel underflow (internal)")
  (match ss
    (Nil
      (match rs
        (Nil (MxPOk Nil))
        (_ (MxPOk (Cons (MxPS (rev_stmts rs) (rev_exprs rsE)) Nil)))))
    ((Cons s t)
     (match ssE
       (Nil (MxPRf "statement/Expr spine mismatch (internal)"))
       ((Cons sE tE)
        (match s
          ((IWhile cnd lbody)
           (match cnd
             ((ILoc gi)
              (match (mxc_crun rs rsE Nil)
                ((Pair csets (Pair rp rpE))
                 (match (mxc_cfind csets gi)
                   (None
                     (MxPRf
                       "loop counter is not a trailing const-set before its loop (named growth)"))
                   ((Some kg)
                    (match (mxc_loop x86 msz gi kg lbody sE nl ks)
                      ((MxPRf m2) (MxPRf m2))
                      ((MxPOk lps)
                       (match lps
                         ((Cons lp0 _)
                          (match lp0
                            ((MxPL g2 k2 lb2 le2 ws2 br2 _)
                             (match
                               (mxc_slice (- fuel 1) x86 msz t tE Nil Nil nl ks)
                               ((MxPRf m2) (MxPRf m2))
                               ((MxPOk more)
                                (let
                                  ((tail
                                     (Cons
                                       (MxPL g2 k2 lb2 le2 ws2 br2 csets)
                                       more)))
                                  (match rp
                                    (Nil (MxPOk tail))
                                    (_
                                      (MxPOk
                                        (Cons
                                          (MxPS (rev_stmts rp) (rev_exprs rpE))
                                          tail))))))))
                            (_ (MxPRf "loop record shape (internal)"))))
                         (Nil (MxPRf "loop record shape (internal)"))))))))))
             (_ (MxPRf "while guard is not a bare local (named growth)"))))
          ((IIf cnd tb eb)
           (match (mxc_br x86 msz cnd tb eb sE nl)
             ((MxPRf m2) (MxPRf m2))
             ((MxPOk bps)
              (match bps
                (Nil (MxPRf "branch record shape (internal)"))
                ((Cons bp _)
                 (match (mxc_slice (- fuel 1) x86 msz t tE Nil Nil nl ks)
                   ((MxPRf m2) (MxPRf m2))
                   ((MxPOk more)
                    (let ((btail (Cons bp more)))
                      (match rs
                        (Nil (MxPOk btail))
                        (_
                          (MxPOk
                            (Cons (MxPS (rev_stmts rs) (rev_exprs rsE)) btail))))))))))))
          (_
            (if (mxc_capq s rs)
              (match
                (mxc_slice
                  (- fuel 1)
                  x86
                  msz
                  t
                  tE
                  (Cons s Nil)
                  (Cons sE Nil)
                  nl
                  ks)
                ((MxPRf m2) (MxPRf m2))
                ((MxPOk more)
                 (MxPOk (Cons (MxPS (rev_stmts rs) (rev_exprs rsE)) more))))
              (mxc_slice
                (- fuel 1)
                x86
                msz
                t
                tE
                (Cons s rs)
                (Cons sE rsE)
                nl
                ks))))))))))

(fn rev_stmts ((a (List IStmt))) (List IStmt) (rev_stmts_go a Nil))
(fn rev_stmts_go ((a (List IStmt)) (acc (List IStmt))) (List IStmt)
  (measure (struct a))
  (match a
    (Nil acc)
    ((Cons h t) (rev_stmts_go t (Cons h acc)))))
(fn rev_exprs ((a (List Expr))) (List Expr) (rev_exprs_go a Nil))
(fn rev_exprs_go ((a (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct a))
  (match a
    (Nil acc)
    ((Cons h t) (rev_exprs_go t (Cons h acc)))))
(fn pcapp ((a (List MxPc)) (b (List MxPc))) (List MxPc)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (pcapp t b)))))

;; pop the maximal trailing const-set run off the reversed segment
;; accumulators; returns (program-order const alist, remaining rs, rsE)
(fn mxc_crun ((rs (List IStmt)) (rsE (List Expr)) (acc (List (Pair Int Int))))
  (Pair (List (Pair Int Int)) (Pair (List IStmt) (List Expr)))
  (measure (struct rs))
  (match rs
    (Nil (Pair acc (Pair rs rsE)))
    ((Cons sp rp)
     (match sp
       ((ISet si sv)
        (match sv
          ((IConst v)
           (match rsE
             (Nil (Pair acc (Pair rs rsE)))
             ((Cons _ rpE) (mxc_crun rp rpE (Cons (Pair si v) acc)))))
          (_ (Pair acc (Pair rs rsE)))))
       (_ (Pair acc (Pair rs rsE)))))))

;; the LAST write to slot gi in the program-order run (acc is already
;; program order; later writes shadow earlier ones)
(fn mxc_cfind ((cs (List (Pair Int Int))) (gi Int)) (Option Int)
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons (Pair si v) t)
     (match (mxc_cfind t gi)
       ((Some w) (Some w))
       (None (if (int_eq si gi) (Some v) None))))))

(fn mxc_clen ((cs (List (Pair Int Int)))) Int
  (measure (struct cs))
  (match cs
    (Nil 0)
    ((Cons _ t) (+ 1 (mxc_clen t)))))

(fn mxc_cval ((cs (List (Pair Int Int))) (si Int)) (Option Int)
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons (Pair s1 v) t)
     (match (mxc_cval t si)
       ((Some w) (Some w))
       (None (if (int_eq s1 si) (Some v) None))))))

;; slice k elements off an Expr list (the machine spine cutter)
(fn mxc_take ((els (List Expr)) (k Int)) (List Expr)
  (measure (struct els))
  (if (lt k 1) Nil
  (match els
    (Nil Nil)
    ((Cons h t) (Cons h (mxc_take t (- k 1)))))))

(fn mxc_drop ((els (List Expr)) (k Int)) (List Expr)
  (measure (struct els))
  (if (lt k 1) els
  (match els
    (Nil Nil)
    ((Cons _ t) (mxc_drop t (- k 1))))))

;; per-SEGMENT machine chunks by invoking the translator on each
;; segment's stmt list (no spine-position arithmetic -- the translator
;; itself cuts the chunks; loop pieces own [2q const instrs + Block])
(fn mxc_chunks ((pcs (List MxPc)) (mtr Module) (ksE Expr))
  (Option (List (List Expr)))
  (measure (struct pcs))
  (match pcs
    (Nil (Some Nil))
    ((Cons pc rest)
     (match pc
       ((MxPS _ segE)
        (match
          (invoke mtr (quote iw_stmts) (Cons ksE (Cons (list_expr segE) Nil)))
          (None None)
          ((Some tv)
           (match (ec_is tv (quote Some))
             (None None)
             ((Some sargs)
              (match sargs
                ((Cons chE Nil)
                 (match (lpe_spine chE)
                   (None None)
                   ((Some ch)
                    (match (mxc_chunks rest mtr ksE)
                      (None None)
                      ((Some more) (Some (Cons ch more)))))))
                (_ None)))))))
       ((MxPB _ sE _ _ _ _ _)
        (match
          (invoke
            mtr
            (quote iw_stmts)
            (Cons ksE (Cons (list_expr (Cons sE Nil)) Nil)))
          (None None)
          ((Some tv)
           (match (ec_is tv (quote Some))
             (None None)
             ((Some sargs)
              (match sargs
                ((Cons chE Nil)
                 (match (lpe_spine chE)
                   (None None)
                   ((Some ch)
                    (match (mxc_chunks rest mtr ksE)
                      (None None)
                      ((Some more) (Some (Cons ch more)))))))
                (_ None)))))))
       ((MxPL _ _ _ _ _ _ _) (mxc_chunks rest mtr ksE))))))

;; the whole-claim fuels: continuation positions are depth-flavored
;; (segments consume their instr/stmt counts; loop pieces consume 3
;; machine / 2 imp peels), and each loop's stuck-walker tower must
;; reach its worker spelling plus the ground count -- a MAX constraint
;; per loop, not a sum.
(fn mxc_ag
  ((pcs (List MxPc))
   (msls (List (List Expr)))
   (machs (List (Pair Int (Pair Int Expr))))
   (cm Int)
   (ci Int)
   (am Int)
   (ai Int))
  (Pair Int Int)
  (measure (struct pcs))
  (match pcs
    (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
    ((Cons pc rest)
     (match pc
       ((MxPS segst _)
        (match msls
          (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
          ((Cons sl mrest)
           (mxc_ag
             rest
             mrest
             machs
             (+ cm (ilen_e sl))
             (+ ci (isz_top segst))
             am
             ai))))
       ((MxPB _ _ _ _ _ _ gsub)
        (match msls
          (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
          ((Cons sl mrest)
           (mxc_ag
             rest
             mrest
             machs
             (+ cm 1)
             (+ ci 1)
             (imax am (+ cm (+ (mxb_k sl) 2)))
             (imax ai (+ ci (+ gsub 2)))))))
       ((MxPL _ kg lbody _ _ _ csets)
        (match machs
          (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
          ((Cons (Pair _ (Pair _ wcode)) hrest)
           (let ((q (mxc_clen csets)))
             (mxc_ag
               rest
               msls
               hrest
               (+ cm (+ (* 2 q) 1))
               (+ ci (+ q 1))
               (imax
                 am
                 (+ (+ (+ cm (+ (* 2 q) 4)) (+ (tcost wcode) 2)) (+ kg 1)))
               (imax ai (+ (+ (+ ci (+ q 2)) (+ (gcost lbody) 5)) (+ kg 1))))))))))))

;; print an Expr list as a ground (Cons ... Nil) spine, or with an
;; open tail doc (the segment lemmas' machine spelling); sp_e per
;; element (pr_e is the guard-arithmetic printer -- stmt/instr ctors
;; need the general speller)
(fn mxc_spn ((els (List Expr)) (tail Doc)) Doc
  (measure (struct els))
  (match els
    (Nil tail)
    ((Cons h t)
     (match (sp_e (harvest h) 0 h)
       ((SpRErr _) (DStr "?SPN?"))
       ((SpROk hd)
        (dconc (list (DStr "(Cons ") hd (DStr " ") (mxc_spn t tail) (DStr ")"))))))))

;; the flat list spelling: Nil-terminated Cons chains spell as
;; (list e1 ... ek) -- the same term after desugar, but a flat form
;; indents at constant depth, so a long code list stays LINEAR under
;; shardfmt where a Cons spine's growing indentation is quadratic in
;; its length. Open spines (variable tails) keep mxc_spn.
(fn spl_chainp ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil))
       (match args
         (Nil True)
         ((Cons _ _) False))
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons _ (Cons t Nil)) (spl_chainp t))
         (_ False))
       False)))
    (_ False)))

(fn spl_e ((e Expr)) SpR
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (spl_chainp e)
       (match args
         (Nil (SpROk (dsym (qn_name q))))
         ((Cons h (Cons t Nil))
          (match (spl_e h)
            ((SpRErr m) (SpRErr m))
            ((SpROk hd)
             (match (spl_items t)
               ((SpRErr m) (SpRErr m))
               ((SpROk td)
                (SpROk (dconc (list (DStr "(list ") hd td (DStr ")")))))))))
         (_ (SpRErr "chain arity (internal)")))
       (match args
         (Nil (SpROk (dsym (qn_name q))))
         ((Cons _ _)
          (match (spl_args args)
            ((SpRErr m) (SpRErr m))
            ((SpROk ad)
             (SpROk (dconc (list (DStr "(") (dsym (qn_name q)) ad (DStr ")"))))))))))
    (_ (sp_e (harvest e) 0 e))))

(fn spl_items ((e Expr)) SpR
  (measure (struct e))
  (match e
    ((Ctor _ args)
     (match args
       (Nil (SpROk (DStr "")))
       ((Cons h (Cons t Nil))
        (match (spl_e h)
          ((SpRErr m) (SpRErr m))
          ((SpROk hd)
           (match (spl_items t)
             ((SpRErr m) (SpRErr m))
             ((SpROk td) (SpROk (dcat3 (DStr " ") hd td)))))))
       (_ (SpRErr "chain arity (internal)"))))
    (_ (SpRErr "chain shape (internal)"))))

(fn spl_args ((es (List Expr))) SpR
  (measure (struct es))
  (match es
    (Nil (SpROk (DStr "")))
    ((Cons h t)
     (match (spl_e h)
       ((SpRErr m) (SpRErr m))
       ((SpROk hd)
        (match (spl_args t)
          ((SpRErr m) (SpRErr m))
          ((SpROk td) (SpROk (dcat3 (DStr " ") hd td)))))))))

;; a closed code list: the flat spelling, elements via spl_e
(fn mxc_lst1 ((els (List Expr))) Doc
  (measure (struct els))
  (match els
    (Nil (DStr ""))
    ((Cons h t)
     (match (spl_e h)
       ((SpRErr _) (dcat3 (DStr " ?SPN?") (DStr "") (mxc_lst1 t)))
       ((SpROk hd) (dcat3 (DStr " ") hd (mxc_lst1 t)))))))

(fn mxc_lst ((els (List Expr))) Doc
  (match els
    (Nil (DStr "Nil"))
    ((Cons _ _) (dcat3 (DStr "(list") (mxc_lst1 els) (DStr ")")))))

;; fn emitters: the per-segment imp body fns and the per-boundary rest
;; fns (both sides). Bodies are LITERAL spines -- (inline X) inside a
;; body poisons citations of the enclosing fn (il_sx never recurses
;; into replacements).
(fn mxc_fn1 ((name Doc) (ty Doc) (body Doc)) Doc
  (dconc
    (list
      (DStr "(fn ")
      name
      (DStr " () ")
      ty
      (DStr " ")
      body
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

(fn mxc_snm ((nm (List Int)) (j Int) (side (List Int))) Doc
  (dconc (list (DStr "gb_") (DStr nm) (DStr "_s") (dint j) (DStr side))))

(fn mxc_rnm ((nm (List Int)) (j Int) (side (List Int))) Doc
  (dconc (list (DStr "gb_") (DStr nm) (DStr "_r") (dint j) (DStr side))))

;; the stop-set doc for composition computes: mstop + every rest fn
(fn mxc_rstops ((nm (List Int)) (j Int) (nr Int)) Doc
  (measure (- (+ nr 1) j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt nr j) (DStr "")
  (dcat3
    (dcat3 (DStr " ") (mxc_rnm nm j "_w") (DStr " "))
    (mxc_rnm nm j "_i")
    (mxc_rstops nm (+ j 1) nr))))

(fn mxc_cstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list
      (DStr "(stop iwhile eval_loop lg_fuel int_of_nat istmts eval_seq")
      (mxc_rstops nm 1 nr)
      (DStr ")"))))

;; the loop-piece PEEL stop: walkers open (the counter-set peels
;; concretely), loop machinery + rest fns stopped
(fn mxc_pstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list
      (DStr "(stop iwhile eval_loop lg_fuel int_of_nat")
      (mxc_rstops nm 1 nr)
      (DStr ")"))))

;; the leaf stop (adapters open, walkers open): rest fns only
(fn mxc_lstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list (DStr "(stop lg_fuel int_of_nat") (mxc_rstops nm 1 nr) (DStr ")"))))

;; the segment-lemma split spine: sq_spine with the es_scont stop on
;; mid-path computes (trap leaves compute open so the adapter
;; dispatches)
(fn mxc_mh ((i Int) (a Expr) (msz Int) (pol (List Int)) (mid Bool)) Doc
  (dconc
    (list
      (DStr "(have hlt")
      (dint i)
      (DStr " (= (lt ")
      (pr_e a)
      (DStr " ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (have hle")
      (dint i)
      (DStr " (= (le (+ ")
      (pr_e a)
      (DStr " 1) ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps () (by arith (rows (goal 1) (hlt")
      (dint i)
      (DStr
        " 1))))) (steps ((rewrite (hyp 0) lr rhs true ()) (rewrite (premise hle")
      (dint i)
      (if mid (DStr ") lr lhs true ()) (compute both (stop es_scont))))")
      (DStr ") lr lhs true ()) (compute both)))")))))

(fn mxc_spine ((gs (List GSplit)) (i Int) (msz Int)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr "refl"))
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (match t
              (Nil
                (DStr
                  " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) "))
              ((Cons _ _)
               (DStr
                 " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both (stop es_scont)))) ")))
            (mxc_spine t (+ i 1) msz)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (mxc_mh
              i
              a
              msz
              "True"
              (match t
                (Nil False)
                ((Cons _ _) True)))
            (DStr " ")
            (mxc_spine t (+ i 1) msz)
            (DStr ")) (case False (chain ")
            (mxc_mh i a msz "False" False)
            (DStr " refl))))"))))))))

;; one open-spine segment lemma: machine walk of the segment's kW
;; instrs over ANY tail rw = es_scont of the standalone imp run.
;; UNPREMISED; splits from the walk at fresh symbolic locals.
(fn mxc_seglemma
  ((nm (List Int))
   (j Int)
   (nl Int)
   (msz Int)
   (kista Int)
   (msl (List Expr))
   (gs (List GSplit)))
  Doc
  (dconc
    (list
      (DStr "(claim sqs_")
      (DStr nm)
      (DStr "_s")
      (dint j)
      (DStr " (goal (")
      (d_binds_go nl (DStr ""))
      (DStr
        "(rw (List Instr)) (st (List Int)) (m Mem) (f Nat) (g Nat) (restfs (List Func))) () (= (eval_seq (S^ ")
      (dint (ilen_e msl))
      (DStr " (S f)) (MkWModule restfs ")
      (dint msz)
      (DStr ") ")
      (mxc_spn msl (DStr "rw"))
      (DStr " ")
      (d_argspine nl)
      (DStr " st m) (es_scont (S f) (MkWModule restfs ")
      (dint msz)
      (DStr ") rw st (istmts (S^ ")
      (dint kista)
      (DStr " (S g)) ")
      (dint msz)
      (DStr " (inline ")
      (mxc_snm nm j "_i")
      (DStr ") ")
      (d_argspine nl)
      (match gs
        (Nil (DStr " m)))) (chain (steps ((compute both))) "))
        ((Cons _ _)
         (DStr " m)))) (chain (steps ((compute both (stop es_scont)))) ")))
      (mxc_spine gs 1 msz)
      (DStr "))")
      (DStr (nl))
      (DStr (nl)))))

;; the entry locals as an explicit Cons spine (segment lemmas fire at
;; exposed case-var lists, so the claim quantifies a CLOSED nl-spine)
(fn d_argspine_go ((i Int) (nl Int)) Doc
  (measure (- nl i) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt i nl)
    (dconc
      (list
        (DStr "(Cons x")
        (dint i)
        (DStr " ")
        (d_argspine_go (+ i 1) nl)
        (DStr ")")))
    (DStr "Nil")))

(fn d_argspine ((nl Int)) Doc (d_argspine_go 0 nl))

;; --- the parametrized exposure ladder (compositional boundaries) -------------
;; mxl_hbg/mxl_ref/mxl_over/mxl_exit generalized: the length lemma
;; (il_slen at segment exits, il_wlen at loop exits), the subject/mem
;; names, the binder prefixes, and the mid-compute stop set are all
;; parameters; refutation hyp indices stay depth-relative (newest
;; first), so the blocks are context-independent.
(fn mxc_hbg ((entry Doc) (subj Doc) (mm Doc) (nlq Int) (somei Int) (lm Doc)) Doc
  (dconc
    (list
      (DStr "(have hbad (= (iolen (ilen ")
      entry
      (DStr ") (Some (INorm ")
      subj
      (DStr " ")
      mm
      (DStr "))) ")
      (dint nlq)
      (DStr ") (chain (steps ((rewrite (hyp ")
      (dint (- somei 1))
      (DStr ") rl lhs true ()) (rewrite (hyp ")
      (dint somei)
      (DStr ") rl lhs true ()))) (rewrite-with (lemma ")
      lm
      (DStr
        ") lr lhs () ()) (steps ((compute lhs))) refl)) (have hlen (= (iolen (ilen ")
      entry
      (DStr ") (Some (INorm ")
      subj
      (DStr " ")
      mm
      (DStr "))) (ilen ")
      subj
      (DStr ")) (steps ((compute both)) refl)) (have hg (= (ilen ")
      subj
      (DStr ") ")
      (dint nlq)
      (DStr
        ") (steps ((rewrite (premise hlen) rl lhs true ()) (rewrite (premise hbad) lr lhs true ())) refl)) "))))

(fn mxc_ref ((entry Doc) (subj Doc) (mm Doc) (nlq Int) (j Int) (lm Doc)) Doc
  (dconc
    (list
      (DStr "(chain ")
      (mxc_hbg entry subj mm nlq (+ j 2) lm)
      (DStr "(have hs (= (ilen ")
      subj
      (DStr ") ")
      (dint j)
      (DStr ") (steps (")
      (mxl_sprw j)
      (DStr
        " (compute lhs)) refl)) (have hff (= (le 0 0) False) (steps () (by arith (rows (goal 1) (hg 1) (hs -1))))) (absurd (premise hff)))"))))

(fn mxc_over ((entry Doc) (subj Doc) (mm Doc) (nlq Int) (lm Doc) (rp Doc)) Doc
  (let ((rn (dconc (list rp (dint nlq)))))
    (dconc
      (list
        (DStr "(chain ")
        (mxc_hbg entry subj mm nlq (+ nlq 2) lm)
        (DStr "(have hs (= (ilen ")
        subj
        (DStr ") ")
        (mxl_sum (+ nlq 1) rn)
        (DStr ") (steps (")
        (mxl_sprw nlq)
        (mxl_unf (+ nlq 1))
        (DStr ") refl)) (have hnn (= (le 0 (ilen ")
        rn
        (DStr
          ")) True) (chain (rewrite-with (lemma ilen_nonneg) lr lhs () ()) refl)) (have hff (= (le 0 0) False) (steps () (by arith (rows (goal 1) (hg -1) (hs 1) (hnn 1))))) (absurd (premise hff)))")))))

(fn mxc_exit
  ((entry Doc)
   (subj Doc)
   (mm Doc)
   (j Int)
   (nlq Int)
   (vdoc Doc)
   (cont Doc)
   (lm Doc)
   (stp Doc)
   (ep Doc)
   (rp Doc))
  Doc
  (measure (- (+ nlq 1) j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j nlq)
    (dconc
      (list
        (DStr "(case-on ")
        vdoc
        (DStr " List ((case Nil ")
        (mxc_ref entry subj mm nlq j lm)
        (DStr ") (case Cons (")
        ep
        (dint j)
        (DStr " ")
        rp
        (dint j)
        (DStr
          ") (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
        stp
        (DStr "))) ")
        (mxc_exit
          entry
          subj
          mm
          (+ j 1)
          nlq
          (dconc (list rp (dint j)))
          cont
          lm
          stp
          ep
          rp)
        (DStr "))))")))
    (dconc
      (list
        (DStr "(case-on ")
        vdoc
        (DStr
          " List ((case Nil (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
        stp
        (DStr "))) ")
        cont
        (DStr ")) (case Cons (")
        ep
        (dint nlq)
        (DStr " ")
        rp
        (dint nlq)
        (DStr ") ")
        (mxc_over entry subj mm nlq lm rp)
        (DStr ")))")))))

;; the counter-respell have: the concrete K at slot gi respelled as
;; (int_of_nat K) across the exposed locals spine
(fn mxc_lspine
  ((i Int) (nl Int) (gi Int) (kd Doc) (ep Doc) (cs (List (Pair Int Int))))
  Doc
  (measure (- nl i) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt i nl)
    (dconc
      (list
        (DStr "(Cons ")
        (if (int_eq i gi) kd
        (match (mxc_cval cs i)
          ((Some v) (dint v))
          (None (dcat3 ep (dint i) (DStr "")))))
        (DStr " ")
        (mxc_lspine (+ i 1) nl gi kd ep cs)
        (DStr ")")))
    (DStr "Nil")))

;; spell the const-set pairs as machine instr Cons-prefix and their closers
(fn mxc_cspell ((cs (List (Pair Int Int)))) Doc
  (measure (struct cs))
  (match cs
    (Nil (DStr ""))
    ((Cons (Pair si v) t)
     (dconc
       (list
         (DStr "(Cons (I32Const ")
         (dint v)
         (DStr ") (Cons (LocalSet ")
         (dint si)
         (DStr ") ")
         (mxc_cspell t))))))

(fn mxc_ccls ((cs (List (Pair Int Int)))) Doc
  (measure (struct cs))
  (match cs
    (Nil (DStr ""))
    ((Cons _ t) (dcat3 (DStr "))") (mxc_ccls t) (DStr "")))))

;; one loop piece: the rest-fn unfold have, the peel compute, the
;; packed ladder (deduped), the counter respell, the per-side reshape
;; haves, the worker citation, and the shared-iwhile case-on shell.
;; cont = the INorm arm's continuation (restores + exposure emitted by
;; the caller); fm/gm are the arriving fuel positions.
(fn mxc_lhead
  ((nm (List Int))
   (nl Int)
   (msz Int)
   (gi Int)
   (kg Int)
   (d Int)
   (b Int)
   (fm Int)
   (gm Int)
   (wlen Int)
   (bw Int)
   (lcode Expr)
   (csets (List (Pair Int Int)))
   (mmv Doc)
   (ep Doc)
   (cstop Doc)
   (pstop Doc)
   (needladder Bool)
   (bzero Bool)
   (cont Doc))
  Doc
  (let
    ((aw (+ (tcost lcode) 2))
     (q (mxc_clen csets))
     (kd (dcat3 (DStr "(int_of_nat ") (dint kg) (DStr ")"))))
    (let
      ((sm (- (- (- fm (+ (* 2 q) 4)) aw) kg))
       (si (- (- (- gm (+ q 2)) bw) kg))
       (rlocs (mxc_lspine 0 nl gi kd ep csets)))
      (dconc
        (list
          (DStr "(steps ((compute both ")
          pstop
          (DStr "))) ")
          (if needladder (mx_ladder kg) (DStr ""))
          (DStr "(have hlc")
          (dint d)
          (DStr " (= ")
          rlocs
          (DStr " ")
          (mxc_lspine 0 nl gi (dint kg) ep csets)
          (DStr ") (steps ((rewrite (premise hi")
          (dint kg)
          (DStr ") lr lhs true ())) refl)) (steps ((rewrite (premise hlc")
          (dint d)
          (DStr ") rl both true ()))) (have hf")
          (dint d)
          (DStr "i (= (S^ ")
          (dint (- gm (+ q 2)))
          (DStr " c2) (S^ ")
          (dint bw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " (S^ ")
          (dint si)
          (DStr " c2)))) (steps ((compute both)) refl)) (have hf")
          (dint d)
          (DStr "m (= (S^ ")
          (dint (- fm (+ (* 2 q) 4)))
          (DStr " c) (S^ ")
          (dint aw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " (S^ ")
          (dint sm)
          (DStr
            " c)))) (steps ((compute both)) refl)) (steps ((rewrite (premise hf")
          (dint d)
          (DStr "i) lr rhs true ()) (rewrite (premise hf")
          (dint d)
          (DStr "m) lr lhs true ()))) (rewrite-with (lemma sqmw_")
          (DStr nm)
          (DStr "_l")
          (dint d)
          (DStr ") lr lhs ((inst c2 (S^ ")
          (dint si)
          (DStr " c2))) ((steps ((rewrite (premise hi")
          (dint kg)
          (DStr
            ") lr lhs true ()) (compute lhs)) refl))) (case-on (iwhile (S^ ")
          (dint bw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " (S^ ")
          (dint si)
          (DStr " c2))) ")
          (dint msz)
          (DStr " (ILoc ")
          (dint gi)
          (DStr ") (inline gb_")
          (DStr nm)
          (DStr "_l")
          (dint d)
          (DStr "_i) ")
          rlocs
          (DStr " ")
          mmv
          (DStr
            ") Option ((case None (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
          cstop
          (DStr "))) refl)) (case Some (o")
          (dint d)
          (DStr
            ") (chain (steps ((rewrite (hyp 0) lr both true ()))) (case-on o")
          (dint d)
          (DStr " IOut ((case INorm (lc")
          (dint d)
          (DStr " mm")
          (dint d)
          (DStr ") (chain (steps ((rewrite (hyp 0) lr both true ()))) (have hc")
          (dint d)
          (DStr "i (= (lg_fuel ")
          (dint kg)
          (DStr " (S^ ")
          (dint si)
          (DStr " c2)) (S^ ")
          (dint (+ si kg))
          (DStr " c2)) (steps ((compute both)) refl)) (have hc")
          (dint d)
          (DStr "m (= (lg_fuel ")
          (dint kg)
          (DStr " (S^ ")
          (dint sm)
          (DStr " c)) (S^ ")
          (dint (+ sm kg))
          (DStr
            " c)) (steps ((compute both)) refl)) (steps ((rewrite (premise hc")
          (dint d)
          (DStr "i) lr both true ()) (rewrite (premise hc")
          (dint d)
          (DStr "m) lr both true ()) (compute both ")
          cstop
          (DStr "))) ")
          cont
          (DStr
            ")) (case ITrap (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
          cstop
          (DStr "))) refl))))))))"))))))

;; the composition driver: fold the pieces, emitting per-piece chain
;; elements; opaque case-var states between pieces, il_slen exposure
;; at segment exits, il_wlen at loop exits, machine tails folded
;; behind rest fns (empty rests spell Nil -- no empty rest fn).
(fn mxc_piece
  ((pc MxPc)
   (msl (List Expr))
   (mach (Pair Int (Pair Int Expr)))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (fm Int)
   (gm Int)
   (b Int)
   (d Int)
   (nr Int)
   (mmv Doc)
   (cont Doc))
  Doc
  (let
    ((cstop (mxc_cstop nm nr))
     (lstop (mxc_lstop nm nr))
     (lastp (int_eq b (- nr 0)))
     (locsp (mxc_lspine 0 nl (- 0 1) (DStr "") (DStr "x") Nil)))
    (match pc
      ((MxPS segst _)
       (let
         ((ki (isz_top segst))
          (subj (DStr "es0"))
          (mmn (DStr "mms0"))
          (ep2 (DStr "es0_"))
          (rp2 (DStr "rs0_")))
         (dconc
           (list
             (DStr "(have hsp0 (= (inline ")
             (if (int_eq b 0) (dcat3 (DStr "gb_") (DStr nm) (DStr "_i"))
             (mxc_rnm nm b "_i"))
             (DStr ") (isapp (inline ")
             (mxc_snm nm b "_i")
             (DStr ") ")
             (if lastp (DStr "Nil")
             (dcat3 (DStr "(inline ") (mxc_rnm nm (+ b 1) "_i") (DStr ")")))
             (DStr ")) (steps ((compute both)) refl)) (have hfg0 (= (S^ ")
             (dint gm)
             (DStr " c2) (lg_fuel (istn (inline ")
             (mxc_snm nm b "_i")
             (DStr ")) (S (S^ ")
             (dint (- (- gm ki) 1))
             (DStr
               " c2)))) (steps ((compute both)) refl)) (steps ((rewrite (premise hsp0) lr rhs true ()) (rewrite (premise hfg0) lr rhs true ()))) (rewrite-with (lemma ist_seam) lr rhs ((inst g c2)) ((steps ((compute lhs)) refl))) (have hfg0b (= (lg_fuel (istn (inline ")
             (mxc_snm nm b "_i")
             (DStr ")) (S c2)) (S^ ")
             (dint ki)
             (DStr
               " (S c2))) (steps ((compute both)) refl)) (steps ((rewrite (premise hfg0b) lr rhs true ()))) ")
             (DStr "(rewrite-with (lemma sqs_")
             (DStr nm)
             (DStr "_s")
             (dint b)
             (DStr ") lr lhs ((inst g c2)) ()) ")
             (DStr "(case-on (istmts (S^ ")
             (dint ki)
             (DStr " (S c2)) ")
             (dint msz)
             (DStr " (inline ")
             (mxc_snm nm b "_i")
             (DStr ") ")
             locsp
             (DStr " ")
             mmv
             (DStr
               ") Option ((case None (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
             lstop
             (DStr
               ")) refl)) (case Some (os0) (chain (steps ((rewrite (hyp 0) lr both true ()))) (case-on os0 IOut ((case INorm (es0 mms0) (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
             cstop
             (DStr "))) ")
             (mxc_exit
               locsp
               subj
               mmn
               0
               nl
               subj
               cont
               (DStr "il_slen")
               cstop
               ep2
               rp2)
             (DStr
               ")) (case ITrap (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
             lstop
             (DStr ")) refl))))))))")))))
      ;; THE BRANCH PIECE (the sqbw_probe blueprint's cmp_sqb_b1): no
      ;; isapp/fuel haves -- the singleton seam matches the pasted
      ;; (Cons IIf rest) and the S-tower directly; the sub-lemma cite
      ;; instantiates its dangling g so both cites present the SAME
      ;; standalone term; ONE case-on of that shared run; il_slen
      ;; exposure (branch exits are SEGMENT-flavored)
      ((MxPB _ _ _ _ _ _ gsub)
       (dconc
         (list
           (DStr
             "(rewrite-with (lemma ist_seam1) lr rhs () ()) (rewrite-with (lemma sqbr_")
           (DStr nm)
           (DStr "_s")
           (dint b)
           (DStr ") lr lhs ((inst g ")
           (mxx_tw (- (- gm gsub) 1) (DStr "c2"))
           (DStr ")) ()) (case-on (istmts (S^ ")
           (dint gm)
           (DStr " c2) ")
           (dint msz)
           (DStr " (inline ")
           (mxc_snm nm b "_i")
           (DStr ") ")
           locsp
           (DStr " ")
           mmv
           (DStr
             ") Option ((case None (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
           lstop
           (DStr
             ")) refl)) (case Some (os0) (chain (steps ((rewrite (hyp 0) lr both true ()))) (case-on os0 IOut ((case INorm (es0 mms0) (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
           cstop
           (DStr "))) ")
           (mxc_exit
             locsp
             (DStr "es0")
             (DStr "mms0")
             0
             nl
             (DStr "es0")
             cont
             (DStr "il_slen")
             cstop
             (DStr "es0_")
             (DStr "rs0_"))
           (DStr
             ")) (case ITrap (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
           lstop
           (DStr ")) refl))))))))"))))
      ((MxPL gi kg lbody lbE wsplits _ csets)
       (match mach
         ((Pair _ (Pair wlen lcodeE))
          (let
            ((bw (+ (gcost lbody) 5))
             (q (mxc_clen csets))
             (kd (dcat3 (DStr "(int_of_nat ") (dint kg) (DStr ")")))
             (subj (dcat3 (DStr "lc") (dint d) (DStr "")))
             (mmn (dcat3 (DStr "mm") (dint d) (DStr "")))
             (ep2 (dcat3 (DStr "e") (dint d) (DStr "_")))
             (rp2 (dcat3 (DStr "r") (dint d) (DStr "_"))))
            (mxc_lhead
              nm
              nl
              msz
              gi
              kg
              d
              b
              fm
              gm
              wlen
              bw
              lcodeE
              csets
              mmv
              (DStr "x")
              cstop
              (mxc_pstop nm nr)
              True
              (int_eq b 0)
              (mxc_exit
                (mxc_lspine 0 nl gi kd (DStr "x") csets)
                subj
                mmn
                0
                nl
                subj
                cont
                (DStr "il_wlen")
                cstop
                ep2
                rp2)))))))))

;; the boundary-lemma chain: one claim per piece boundary, emitted
;; deepest-first so each cites the next; boundary 0 = the public
;; claim. Every lemma is the statement-tier form over fresh locals --
;; nesting stays piece-deep and the fmt'd file stays sane.
(fn mxc_lems
  ((pcs (List MxPc))
   (msls (List (List Expr)))
   (machs (List (Pair Int (Pair Int Expr))))
   (brpre (List Int))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (fm Int)
   (gm Int)
   (b Int)
   (d Int)
   (nr Int))
  Doc
  (measure (struct pcs))
  (match pcs
    (Nil (DStr ""))
    ((Cons pc rest)
     (let
       ((lastp
          (match rest
            (Nil True)
            ((Cons _ _) False)))
        (nmdoc
          (if (int_eq b 0) (dcat3 (DStr brpre) (DStr nm) (DStr ""))
          (dconc (list (DStr "cmp_") (DStr nm) (DStr "_b") (dint b)))))
        (codew
          (if (int_eq b 0)
            (dconc (list (DStr "(inline gb_") (DStr nm) (DStr "_w)")))
            (dconc (list (DStr "(inline ") (mxc_rnm nm b "_w") (DStr ")")))))
        (codei
          (if (int_eq b 0)
            (dconc (list (DStr "(inline gb_") (DStr nm) (DStr "_i)")))
            (dconc (list (DStr "(inline ") (mxc_rnm nm b "_i") (DStr ")"))))))
       (match (mxc_step pc msls fm gm)
         ((Pair (Pair fm2 gm2) (Pair msls2 machs2q))
          (let
            ((machs2 (if (lt machs2q 0) (mxc_mtail machs) machs))
             (msl1
               (match msls
                 (Nil Nil)
                 ((Cons h _) h)))
             (mach1
               (match machs
                 (Nil (Pair 0 (Pair 0 (IntLit 0))))
                 ((Cons h _) h))))
            (dconc
              (list
                (mxc_lems
                  rest
                  msls2
                  machs2
                  brpre
                  nm
                  nl
                  msz
                  fm2
                  gm2
                  (+ b 1)
                  (match pc
                    ((MxPS _ _) d)
                    ((MxPB _ _ _ _ _ _ _) d)
                    ((MxPL _ _ _ _ _ _ _) (+ d 1)))
                  nr)
                (DStr "(claim ")
                nmdoc
                (DStr " (goal (")
                (d_binds_go
                  nl
                  (DStr
                    "(st (List Int)) (m Mem) (c Nat) (c2 Nat) (restfs (List Func))"))
                (DStr ") () (= (eval_seq (S^ ")
                (dint fm)
                (DStr " c) (MkWModule restfs ")
                (dint msz)
                (DStr ") ")
                codew
                (DStr " ")
                (d_args nl)
                (DStr " st m) (iw_sout st (istmts (S^ ")
                (dint gm)
                (DStr " c2) ")
                (dint msz)
                (DStr " ")
                codei
                (DStr " ")
                (d_args nl)
                (DStr " m)))) (chain ")
                (mxc_piece
                  pc
                  msl1
                  mach1
                  nm
                  nl
                  msz
                  fm
                  gm
                  b
                  d
                  nr
                  (DStr "m")
                  (if lastp (DStr "(steps ((compute both))) refl")
                  (dconc
                    (list
                      (DStr "(rewrite-with (lemma cmp_")
                      (DStr nm)
                      (DStr "_b")
                      (dint (+ b 1))
                      (DStr
                        ") lr lhs ((inst c2 c2)) ()) (steps ((compute both ")
                      (mxc_cstop nm nr)
                      (DStr "))) refl")))))
                (DStr "))")
                (DStr (nl))
                (DStr (nl)))))))))))

;; per-piece fuel/stream stepping: returns ((fm2 gm2) (msls2 machflag))
;; -- machflag < 0 means the machs list advances (loop piece)
(fn mxc_step ((pc MxPc) (msls (List (List Expr))) (fm Int) (gm Int))
  (Pair (Pair Int Int) (Pair (List (List Expr)) Int))
  (match pc
    ((MxPS segst _)
     (match msls
       (Nil (Pair (Pair fm gm) (Pair Nil 0)))
       ((Cons sl mrest)
        (Pair (Pair (- fm (ilen_e sl)) (- gm (isz_top segst))) (Pair mrest 0)))))
    ((MxPB _ _ _ _ _ _ _)
     (match msls
       (Nil (Pair (Pair fm gm) (Pair Nil 0)))
       ((Cons _ mrest) (Pair (Pair (- fm 1) (- gm 1)) (Pair mrest 0)))))
    ((MxPL _ _ _ _ _ _ csets)
     (let ((q (mxc_clen csets)))
       (Pair (Pair (- fm (+ (* 2 q) 1)) (- gm (+ q 1))) (Pair msls (- 0 1)))))))

(fn mxc_mtail ((machs (List (Pair Int (Pair Int Expr)))))
  (List (Pair Int (Pair Int Expr)))
  (match machs
    (Nil Nil)
    ((Cons _ t) t)))
(fn mxsym ((pre (List Int)) (d Int) (j Int)) Symbol
  (sym_of_chars
    (append_int pre (append_int (show_int d) (append_int "_" (show_int j))))))

(fn mxs1 ((pre (List Int)) (d Int)) Symbol
  (sym_of_chars (append_int pre (show_int d))))

(fn mx_fresh ((d Int) (j Int) (nl Int)) (List Expr)
  (measure (- nl j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j nl) (Cons (FVar (mxsym "e" d j)) (mx_fresh d (+ j 1) nl)) Nil))

;; the machine loop entries: (flat index, loop-code length, inner list
;; Expr) per Block([Loop inner]) element of the translated spine
(fn mx_mach ((els (List Expr)) (j Int))
  (Option (List (Pair Int (Pair Int Expr))))
  (measure (struct els))
  (match els
    (Nil (Some Nil))
    ((Cons h t)
     (match (mx_mach t (+ j 1))
       (None None)
       ((Some rest)
        (match h
          ((Ctor q hargs)
           (if (sym_eq (qn_name q) (quote Block))
             (match hargs
               ((Cons inner Nil)
                (match (lpe_spine inner)
                  ((Some (Cons lp Nil))
                   (match lp
                     ((Ctor lq largs)
                      (if (sym_eq (qn_name lq) (quote Loop))
                        (match largs
                          ((Cons w Nil)
                           (match (lpe_spine w)
                             (None None)
                             ((Some wels)
                              (Some (Cons (Pair j (Pair (ilen_e wels) w)) rest)))))
                          (_ None))
                        (Some rest)))
                     (_ (Some rest))))
                  (_ (Some rest))))
               (_ (Some rest)))
             (Some rest)))
          (_ (Some rest))))))))

(fn mx_nth ((l (List (Pair Int (Pair Int Expr)))) (i Int))
  (Option (Pair Int (Pair Int Expr)))
  (measure (struct l))
  (match l
    (Nil None)
    ((Cons h t) (if (lt i 1) (Some h) (mx_nth t (- i 1))))))

;; the segmented walk: straight-line statements ride lw_stmts one at a
;; time; each top-level IWhile is validated (bare-local U32 counter,
;; ground at the head, trailing band-decrement) and recorded, and the
;; continuation walks over fresh case-var locals and memory
(fn mx_walk
  ((fuel Int)
   (x86 Bool)
   (msz Int)
   (ss (List IStmt))
   (ssE (List Expr))
   (st (List Expr))
   (mem Expr)
   (p Int)
   (d Int)
   (nl Int)
   (ks (List IKind)))
  MxR
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) (MxRf "mixed walk fuel underflow (internal)")
  (match ss
    (Nil (MxOk Nil))
    ((Cons s t)
     (match ssE
       (Nil (MxRf "statement/Expr spine mismatch (internal)"))
       ((Cons sE tE)
        (match s
          ((IWhile cnd lbody)
           (match cnd
             ((ILoc gi)
              (match (ikat ks gi)
                (None (MxRf "counter slot outside the kind env (internal)"))
                ((Some gk)
                 (match gk
                   (U32
                     (match (st_get st gi)
                       (None (MxRf "counter slot out of range (internal)"))
                       ((Some cv)
                        (match cv
                          ((IntLit kg)
                           (if (lt kg 0)
                             (MxRf
                               "negative counter at a loop head (named growth)")
                             (match (ec_is sE (quote IWhile))
                               (None (MxRf "loop Expr shape (internal)"))
                               ((Some wargs)
                                (match wargs
                                  ((Cons _ (Cons lbE Nil))
                                   (match
                                     (st_set
                                       (st_params nl)
                                       gi
                                       (sc2
                                         (quote +)
                                         (IntLit 1)
                                         (Call
                                           (pq (quote int_of_nat))
                                           (Cons (FVar (quote k2)) Nil))))
                                     (None
                                       (MxRf
                                         "counter slot out of range (internal)"))
                                     ((Some wst)
                                      (match (lwb_walk x86 msz gi lbody wst)
                                        ((LWBRf why) (MxRf why))
                                        ((LWBOk wsplits lbr _ _)
                                         (match
                                           (mx_walk
                                             (- fuel 1)
                                             x86
                                             msz
                                             t
                                             tE
                                             (mx_fresh d 0 nl)
                                             (FVar (mxs1 "mm" d))
                                             (+ p 1)
                                             (+ d 1)
                                             nl
                                             ks)
                                           ((MxRf m2) (MxRf m2))
                                           ((MxOk evs)
                                            (MxOk
                                              (Cons
                                                (MxL
                                                  (MkMxLp gi kg lbE lbody st mem
                                                    wsplits lbr p))
                                                evs)))))))))
                                  (_ (MxRf "loop Expr shape (internal)")))))))
                          (_
                            (MxRf
                              "loop counter is not ground at the loop head (named growth)"))))))
                   (_ (MxRf "non-U32 loop counter (named growth)"))))))
             (_ (MxRf "while guard is not a bare local (named growth)"))))
          ;; a top-level branch contributes no worker event; the walk
          ;; continues at FRESH state (the per-arm walked states are
          ;; the chain emitters' business: the wasm legs take them from
          ;; the piece slicer at fresh locals, the x86 legs re-walk at
          ;; the leg's in-flight state)
          ((IIf _ _ _)
           (mx_walk
             (- fuel 1)
             x86
             msz
             t
             tE
             (mx_fresh d 0 nl)
             (FVar (mxs1 "mm" d))
             (+ p 1)
             (+ d 1)
             nl
             ks))
          (_
            (match (lw_stmts 3 x86 msz (Cons s Nil) st mem)
              ((LSRf m2) (MxRf m2))
              ((LSOk gs st2 mem2)
               (match (mx_walk (- fuel 1) x86 msz t tE st2 mem2 (+ p 1) d nl ks)
                 ((MxRf m2) (MxRf m2))
                 ((MxOk evs) (MxOk (mx_evapp gs evs))))))))))))))

(fn mx_evapp ((gs (List GSplit)) (evs (List MxEv))) (List MxEv)
  (measure (struct gs))
  (match gs
    (Nil evs)
    ((Cons g t) (Cons (MxSp g) (mx_evapp t evs)))))

;; loop count of an event list
(fn mx_nloops ((evs (List MxEv))) Int
  (measure (struct evs))
  (match evs
    (Nil 0)
    ((Cons e t)
     (match e
       ((MxSp _) (mx_nloops t))
       ((MxL _) (+ 1 (mx_nloops t)))))))

;; --- mixed-tier emission: docs ------------------------------------------------------

(fn mx_wstop () Doc (DStr "(stop eval_loop iwhile lg_fuel iw_out)"))
(fn mx_mstop () Doc (DStr "(stop iwhile eval_loop lg_fuel int_of_nat)"))

;; worker binders: every non-counter slot, then the tail/kit binders
(fn mxw_binds_go ((n Int) (gi Int) (acc Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) acc
  (mxw_binds_go
    (- n 1)
    gi
    (if (int_eq (- n 1) gi) acc
    (DCat (dcat3 (DStr "(x") (dint (- n 1)) (DStr " Int) ")) acc)))))

;; the worker's open-spine locals at counter term kd
(fn mxw_locs_go ((j Int) (nl Int) (gi Int) (kd Doc)) Doc
  (measure (- nl j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j nl)
    (dconc
      (list
        (DStr "(Cons ")
        (if (int_eq j gi) kd (dcat3 (DStr "x") (dint j) (DStr "")))
        (sp)
        (mxw_locs_go (+ j 1) nl gi kd)
        (DStr ")")))
    (DStr "rr")))

;; the packed int_of_nat ladder have for ground count K
(fn mx_succs ((n Int)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (DStr "")
  (dcat3
    (DStr " (rewrite (lemma int_of_nat_succ) lr lhs true ())")
    (DStr "")
    (mx_succs (- n 1)))))

(fn mx_ladder ((kg Int)) Doc
  (dconc
    (list
      (DStr "(have hi")
      (dint kg)
      (DStr " (= (int_of_nat ")
      (dint kg)
      (DStr ") ")
      (dint kg)
      (DStr ") (chain (have ha")
      (dint kg)
      (DStr " (= (int_of_nat ")
      (dint kg)
      (DStr ") (int_of_nat (S^ ")
      (dint kg)
      (DStr " Z))) (steps ((compute both)) refl)) (steps ((rewrite (premise ha")
      (dint kg)
      (DStr ") lr lhs true ())")
      (mx_succs kg)
      (DStr
        " (rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute lhs))) refl)) "))))

(fn mx_kseen ((seen (List Int)) (k Int)) Bool
  (measure (struct seen))
  (match seen
    (Nil False)
    ((Cons h t) (if (int_eq h k) True (mx_kseen t k)))))

;; the worker mem-hi have-pair at one polarity, worker stops
(fn mxw_mh ((i Int) (a Expr) (msz Int) (pol (List Int)) (cs Doc)) Doc
  (dconc
    (list
      (DStr "(have hlt")
      (dint i)
      (DStr " (= (lt ")
      (pr_e a)
      (DStr " ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps ((rewrite (hyp 0) lr lhs true ())) refl)) (have hle")
      (dint i)
      (DStr " (= (le (+ ")
      (pr_e a)
      (DStr " 1) ")
      (dint msz)
      (DStr ") ")
      (DStr pol)
      (DStr ") (steps () (by arith (rows (goal 1) (hlt")
      (dint i)
      (DStr
        " 1))))) (steps ((rewrite (hyp 0) lr rhs true ()) (rewrite (premise hle")
      (dint i)
      (DStr ") lr lhs true ()) (compute both ")
      cs
      (DStr ")))"))))

;; the worker split spine: True arms continue at worker stops, False
;; arms close at (stop lg_fuel); the all-true tail follows
(fn mxw_spine ((gs (List GSplit)) (i Int) (msz Int) (tail Doc)) Doc
  (measure (struct gs))
  (match gs
    (Nil tail)
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (DStr
              " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
            (mx_wstop)
            (DStr "))) ")
            (mxw_spine t (+ i 1) msz tail)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both (stop lg_fuel)))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (mxw_mh i a msz "True" (mx_wstop))
            (DStr " ")
            (mxw_spine t (+ i 1) msz tail)
            (DStr ")) (case False (chain ")
            (mxw_mh i a msz "False" (DStr "(stop lg_fuel)"))
            (DStr " refl))))"))))))))

;; the worker step case's all-true tail: decrement collapse, cap
;; step-down, wrap collapse, the IH at the split depth
(fn mxw_tail ((widnm Doc) (ihidx Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr both true ()))) (have hs1 (= (int_of_nat (S k2)) (+ 1 (int_of_nat k2))) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) (have hks (= (lt (+ 1 (int_of_nat k2)) 4294967296) True) (steps ((rewrite (premise hs1) rl lhs true ()) (rewrite (premise 0) lr lhs true ())) refl)) (have hcap (= (lt (int_of_nat k2) 4294967296) True) (steps () (by arith (rows (goal 1) (hks 1))))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma ")
      widnm
      (DStr
        ") lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (steps ((rewrite (premise hcap) lr lhs true ())) refl)) refl)) (steps ((rewrite (premise hwk) lr both true ()))) (rewrite-with (hyp ")
      (dint ihidx)
      (DStr
        ") lr lhs ((inst c2 c2)) ((steps ((rewrite (premise hcap) lr lhs true ())) refl))) refl"))))

;; the loop-body branch case-on (IF-2): ONE case-on of the shared raw
;; comparison scrutinee inside the induct step; both arms LIVE (no
;; trap closer) -- each rewrites the polarity into both sides, walks
;; its own region's splits (indices offset past the prefix so hlt/hle
;; names stay distinct; the arms are separate scopes and may reuse
;; each other's), and cites the IH at its own hyp depth
;; (1 + prefix + region). p = the prefix split count.
(fn mxw_brcase
  ((scrut Expr)
   (tgs (List GSplit))
   (egs (List GSplit))
   (p Int)
   (msz Int)
   (widnm Doc))
  Doc
  (dconc
    (list
      (DStr "(case-on ")
      (pr_e scrut)
      (DStr
        " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
      (mx_wstop)
      (DStr "))) ")
      (mxw_spine
        tgs
        (+ p 1)
        msz
        (mxw_tail widnm (+ (+ p 1) (ilen_gs (gs_index tgs 0)))))
      (DStr
        ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
      (mx_wstop)
      (DStr "))) ")
      (mxw_spine
        egs
        (+ p 1)
        msz
        (mxw_tail widnm (+ (+ p 1) (ilen_gs (gs_index egs 0)))))
      (DStr "))))"))))

;; one counter-tied worker claim + its body-copy fns
(fn mxw_emit
  ((nm (List Int))
   (d Int)
   (nl Int)
   (msz Int)
   (lp MxLp)
   (wlen Int)
   (wcodeE Expr))
  ERes
  (match lp
    ((MkMxLp gi _ lbodyE lbody _ _ wsplits lbr _)
     (match (spl_e lbodyE)
       ((SpRErr m) (EErr m))
       ((SpROk lbdoc)
        (match (spl_e wcodeE)
          ((SpRErr m) (EErr m))
          ((SpROk wcdoc)
           (let
             ((bw (+ (gcost lbody) 5))
              (aw (+ (tcost wcodeE) 2))
              (ds (gs_dedup Nil wsplits))
              (locs (mxw_locs_go 0 nl gi (DStr "(int_of_nat k)"))))
             (EOk
               (dconc
                 (list
                   (DStr "(fn gb_")
                   (DStr nm)
                   (DStr "_l")
                   (dint d)
                   (DStr "_i () (List IStmt) ")
                   lbdoc
                   (DStr ")")
                   (DStr (nl))
                   (DStr (nl))
                   (DStr "(fn gb_")
                   (DStr nm)
                   (DStr "_l")
                   (dint d)
                   (DStr "_w () (List Instr) ")
                   wcdoc
                   (DStr ")")
                   (DStr (nl))
                   (DStr (nl))
                   (DStr "(claim sqmw_")
                   (DStr nm)
                   (DStr "_l")
                   (dint d)
                   (DStr " (goal (")
                   (mxw_binds_go
                     nl
                     gi
                     (DStr
                       "(rr (List Int)) (k Nat) (st (List Int)) (m Mem) (c Nat) (c2 Nat) (restfs (List Func))"))
                   (DStr
                     ") ((= (lt (int_of_nat k) 4294967296) True)) (= (eval_loop (S^ ")
                   (dint aw)
                   (DStr " (lg_fuel k c)) (MkWModule restfs ")
                   (dint msz)
                   (DStr ") (inline gb_")
                   (DStr nm)
                   (DStr "_l")
                   (dint d)
                   (DStr "_w) ")
                   locs
                   (DStr " st m) (iw_out st (iwhile (S^ ")
                   (dint bw)
                   (DStr " (lg_fuel k c2)) ")
                   (dint msz)
                   (DStr " (ILoc ")
                   (dint gi)
                   (DStr ") (inline gb_")
                   (DStr nm)
                   (DStr "_l")
                   (dint d)
                   (DStr "_i) ")
                   locs
                   (DStr
                     " m)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold lg_fuel rhs) (reduce rhs) (unfold eval_loop lhs) (unfold iwhile rhs) (rewrite (lemma int_of_nat_succ) lr both true ()) (compute both ")
                   (mx_wstop)
                   (DStr
                     "))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (rewrite-with (lemma lg_ne) lr rhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute both ")
                   (mx_wstop)
                   (DStr "))) ")
                   (mxw_spine
                     ds
                     1
                     msz
                     (match lbr
                       (None
                         (mxw_tail
                           (dcat3 (DStr "sqm_wid_") (DStr nm) (DStr ""))
                           (ilen_gs (gs_index ds 0))))
                       ((Some (MkLBr scrut tgs egs))
                        (mxw_brcase
                          scrut
                          tgs
                          egs
                          (ilen_gs (gs_index ds 0))
                          msz
                          (dcat3 (DStr "sqm_wid_") (DStr nm) (DStr ""))))))
                   (DStr ")))))")
                   (DStr (nl))
                   (DStr (nl)))))))))))))

;; the self-contained wrap collapse twin (iwrap32_id verbatim; the
;; generated file cannot import examples/)
(fn mx_wid64 ((nm (List Int))) Doc
  (dconc
    (list
      (DStr "(claim sqm_wid64_")
      (DStr nm)
      (DStr
        " (goal ((x Int)) ((= (le 0 x) True) (= (lt x 18446744073709551616) True)) (= (mod x 18446744073709551616) x)) (div-facts x 18446744073709551616 q (have qlo (= (le -1 q) True) (by arith (list 18446744073709551616 1 0 -1 0 1 0)) (have qhi (= (le q 1) True) (by arith (list 18446744073709551616 0 1 1 1 0 0)) (fin-split q (premise qlo) (premise qhi) ((case -1 (by arith (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0)))) (case 0 (by arith (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0)))) (case 1 (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))")
      (DStr (nl))
      (DStr (nl)))))

(fn mx_wid ((nm (List Int))) Doc
  (dconc
    (list
      (DStr "(claim sqm_wid_")
      (DStr nm)
      (DStr
        " (goal ((x Int)) ((= (le 0 x) True) (= (lt x 4294967296) True)) (= (mod x 4294967296) x)) (div-facts x 4294967296 q (have qlo (= (le -1 q) True) (by arith (list 4294967296 1 0 -1 0 1 0)) (have qhi (= (le q 1) True) (by arith (list 4294967296 0 1 1 1 0 0)) (fin-split q (premise qlo) (premise qhi) ((case -1 (by arith (list (list 0 1 0 -1 0 1 0 0 0) (list 0 1 0 -1 0 1 0 0 0)))) (case 0 (by arith (list (list 1 0 0 1 0 0 0 0 0) (list 1 0 0 -1 0 0 0 0 0)))) (case 1 (by arith (list (list 0 0 1 1 1 0 0 0 0) (list 0 0 1 1 1 0 0 0 0))))))))))")
      (DStr (nl))
      (DStr (nl)))))

;; --- the leg's exit-spine machinery ------------------------------------------------

;; hyp rewrites walking the exit list forward through the arm's spine
;; hyps (j down to 0), lhs side
(fn mxl_sprw ((j Int)) Doc
  (measure (+ j 1) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 0) (DStr "")
  (dconc
    (list
      (DStr " (rewrite (hyp ")
      (dint j)
      (DStr ") lr lhs true ())")
      (mxl_sprw (- j 1))))))

;; the ilen unfold ladder (n levels) and the nested sum spelling
(fn mxl_unf ((n Int)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (DStr "")
  (dcat3 (DStr " (unfold ilen lhs) (reduce lhs)") (DStr "") (mxl_unf (- n 1)))))

(fn mxl_sum ((n Int) (rn Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) (dcat3 (DStr "(ilen ") rn (DStr ")"))
  (dcat3 (DStr "(+ 1 ") (mxl_sum (- n 1) rn) (DStr ")"))))

(fn mxlp_body ((lp MxLp)) (List IStmt)
  (match lp
    ((MkMxLp _ _ _ lbody _ _ _ _ _) lbody)))

(fn mxlp_kg ((lp MxLp)) Int
  (match lp
    ((MkMxLp _ kg _ _ _ _ _ _ _) kg)))

;; all workers, in loop order
(fn mxw_all
  ((evs (List MxEv))
   (machs (List (Pair Int (Pair Int Expr))))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (d Int))
  ERes
  (measure (struct evs))
  (match evs
    (Nil (EOk (DStr "")))
    ((Cons e t)
     (match e
       ((MxSp _) (mxw_all t machs nm nl msz d))
       ((MxL lp)
        (match (mx_nth machs (- d 1))
          (None (EErr "machine loop entry missing (internal)"))
          ((Some (Pair _ (Pair wlen wcodeE)))
           (match (mxw_emit nm d nl msz lp wlen wcodeE)
             ((EErr m) (EErr m))
             ((EOk wd)
              (match (mxw_all t machs nm nl msz (+ d 1))
                ((EErr m) (EErr m))
                ((EOk rest) (EOk (DCat wd rest)))))))))))))

;; the mixed-tier emission: wid twin, per-loop workers, the leg
(fn sqm_emit
  ((brpre (List Int))
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (bodyE Expr)
   (instrsE Expr)
   (evs (List MxEv))
   (mtr Module)
   (ksE Expr))
  ERes
  (match (spl_e bodyE)
    ((SpRErr m) (EErr m))
    ((SpROk ibodydoc)
     (match (spl_e instrsE)
       ((SpRErr m) (EErr m))
       ((SpROk wbodydoc)
        (match (lpe_spine instrsE)
          (None (EErr "translated spine shape (internal)"))
          ((Some els)
           (match (lpe_spine bodyE)
             (None (EErr "imp spine shape (internal)"))
             ((Some ssE)
              (match (mx_mach els 0)
                (None (EErr "machine loop scan (internal)"))
                ((Some machs)
                 (let
                   ((nm (pin_nm pin))
                    (nl (+ (ikn (ikparams_of ifn)) (ikn (ikextra_of ifn))))
                    (ss (ibody_of ifn)))
                   (match
                     (mxc_slice
                       (+ (isz_top ss) 2)
                       False
                       msz
                       ss
                       ssE
                       Nil
                       Nil
                       nl
                       (ikapp (ikparams_of ifn) (ikextra_of ifn)))
                     ((MxPRf m) (EErr m))
                     ((MxPOk pcs)
                      (match (mxc_chunks pcs mtr ksE)
                        (None
                          (EErr "per-segment translation invoke (internal)"))
                        ((Some msls)
                         (match (mxc_ag pcs msls machs 0 0 0 0)
                           ((Pair aa gg)
                            (match (mxw_all evs machs nm nl msz 1)
                              ((EErr m) (EErr m))
                              ((EOk workers)
                               (match (mxc_sfl pcs msls nm nl msz 0)
                                 ((EErr m) (EErr m))
                                 ((EOk segdocs)
                                  (EOk
                                    (dconc
                                      (list
                                        (mxc_fn1
                                          (dcat3
                                            (DStr "gb_")
                                            (DStr nm)
                                            (DStr "_i"))
                                          (DStr "(List IStmt)")
                                          ibodydoc)
                                        (mxc_fn1
                                          (dcat3
                                            (DStr "gb_")
                                            (DStr nm)
                                            (DStr "_w"))
                                          (DStr "(List Instr)")
                                          wbodydoc)
                                        (mxc_rests pcs msls ss ssE els nm 1)
                                        (mx_wid nm)
                                        workers
                                        segdocs
                                        (mxc_lems
                                          pcs
                                          msls
                                          machs
                                          brpre
                                          nm
                                          nl
                                          msz
                                          aa
                                          gg
                                          0
                                          1
                                          (mxc_nrst pcs)))))))))))))))))))))))))))

;; rest-fn count: one per boundary 1..n-1 (empty rests are not emitted
;; but numbering stays boundary-aligned; nrst = pieces - 1)
(fn mxc_nrst ((pcs (List MxPc))) Int (- (isz_pcs pcs) 1))

(fn isz_pcs ((l (List MxPc))) Int
  (measure (struct l))
  (match l
    (Nil 0)
    ((Cons _ t) (+ 1 (isz_pcs t)))))

;; per-segment fns + lemmas: walk pieces with the boundary counter,
;; running the statement walk at fresh symbolic locals for the splits
(fn mxc_sfl
  ((pcs (List MxPc))
   (msls (List (List Expr)))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (b Int))
  ERes
  (measure (struct pcs))
  (match pcs
    (Nil (EOk (DStr "")))
    ((Cons pc rest)
     (match pc
       ((MxPS segst segE)
        (match msls
          (Nil (EErr "segment/machine slice mismatch (internal)"))
          ((Cons sl mrest)
           (match
             (lw_stmts
               (+ (isz_top segst) 2)
               False
               msz
               segst
               (st_params nl)
               (FVar (quote m)))
             ((LSRf why) (EErr why))
             ((LSOk gs _ _)
              (match (mxc_sfl rest mrest nm nl msz (+ b 1))
                ((EErr m) (EErr m))
                ((EOk more)
                 (EOk
                   (dconc
                     (list
                       (mxc_fn1
                         (mxc_snm nm b "_i")
                         (DStr "(List IStmt)")
                         (mxc_lst segE))
                       (mxc_seglemma nm b nl msz (isz_top segst) sl gs)
                       more))))))))))
       ((MxPB _ sE scrutE flip tgs egs gsub)
        (match msls
          (Nil (EErr "branch/machine slice mismatch (internal)"))
          ((Cons sl mrest)
           (match (mxc_sfl rest mrest nm nl msz (+ b 1))
             ((EErr m) (EErr m))
             ((EOk more)
              (EOk
                (dconc
                  (list
                    (mxc_fn1
                      (mxc_snm nm b "_i")
                      (DStr "(List IStmt)")
                      (mxc_lst (Cons sE Nil)))
                    (mxc_brlemma nm b nl msz gsub sl scrutE flip tgs egs)
                    more))))))))
       ((MxPL _ _ _ _ _ _ _) (mxc_sfl rest msls nm nl msz (+ b 1)))))))

;; one open-tail BRANCH sub-lemma (the sqbw_probe blueprint): machine
;; walk of the branch chunk over ANY tail rw = es_scont of the
;; standalone imp run of the branch SINGLETON. ONE case-on of the
;; shared comparison scrutinee (both machines stick on the raw-operand
;; cmp tree); each arm walks concretely by the statement-tier split
;; spine; the parked continuation is claim-minus-one regardless of
;; which arm ran, so the fuel spelling is arm-independent.
(fn mxc_brarm ((gs (List GSplit)) (msz Int)) Doc
  (dconc
    (list
      (DStr "(chain (steps ((rewrite (hyp 0) lr both true ()) (compute both")
      (match gs
        (Nil (DStr ""))
        ((Cons _ _) (DStr " (stop es_scont)")))
      (DStr "))) ")
      (mxc_spine gs 1 msz)
      (DStr ")"))))

(fn mxc_brlemma
  ((nm (List Int))
   (j Int)
   (nl Int)
   (msz Int)
   (gsub Int)
   (msl (List Expr))
   (scrutE Expr)
   (flip Bool)
   (tgs (List GSplit))
   (egs (List GSplit)))
  Doc
  (let ((kk (mxb_k msl)) (armT (if flip tgs egs)) (armF (if flip egs tgs)))
    (dconc
      (list
        (DStr "(claim sqbr_")
        (DStr nm)
        (DStr "_s")
        (dint j)
        (DStr " (goal (")
        (d_binds_go nl (DStr ""))
        (DStr
          "(rw (List Instr)) (st (List Int)) (m Mem) (f Nat) (g Nat) (restfs (List Func))) () (= (eval_seq (S^ ")
        (dint kk)
        (DStr " (S f)) (MkWModule restfs ")
        (dint msz)
        (DStr ") ")
        (mxc_spn msl (DStr "rw"))
        (DStr " ")
        (d_argspine nl)
        (DStr " st m) (es_scont (S^ ")
        (dint (- kk 1))
        (DStr " (S f)) (MkWModule restfs ")
        (dint msz)
        (DStr ") rw st (istmts (S^ ")
        (dint gsub)
        (DStr " (S g)) ")
        (dint msz)
        (DStr " (inline ")
        (mxc_snm nm j "_i")
        (DStr ") ")
        (d_argspine nl)
        (DStr
          " m)))) (chain (steps ((compute both (stop es_scont)))) (case-on ")
        (pr_e scrutE)
        (DStr " Bool ((case True ")
        (mxc_brarm armT msz)
        (DStr ") (case False ")
        (mxc_brarm armF msz)
        (DStr ")))))")
        (DStr (nl))
        (DStr (nl))))))

;; the rest fns (boundaries 1..n-1): literal suffix slices, both sides
(fn mxc_rests
  ((pcs (List MxPc))
   (msls (List (List Expr)))
   (ss (List IStmt))
   (ssE (List Expr))
   (els (List Expr))
   (nm (List Int))
   (b Int))
  Doc
  (measure (struct pcs))
  (match pcs
    (Nil (DStr ""))
    ((Cons pc rest)
     (match rest
       (Nil (DStr ""))
       ((Cons _ _)
        (match pc
          ((MxPS segst _)
           (match msls
             (Nil (DStr ""))
             ((Cons sl mrest)
              (let ((ki (isz_top segst)) (kw (ilen_e sl)))
                (dconc
                  (list
                    (mxc_fn1
                      (mxc_rnm nm b "_i")
                      (DStr "(List IStmt)")
                      (mxc_lst (edrop ssE ki)))
                    (mxc_fn1
                      (mxc_rnm nm b "_w")
                      (DStr "(List Instr)")
                      (mxc_lst (mxc_drop els kw)))
                    (mxc_rests
                      rest
                      mrest
                      (sdrop ss ki)
                      (edrop ssE ki)
                      (mxc_drop els kw)
                      nm
                      (+ b 1))))))))
          ((MxPB _ _ _ _ _ _ _)
           (match msls
             (Nil (DStr ""))
             ((Cons _ mrest)
              (dconc
                (list
                  (mxc_fn1
                    (mxc_rnm nm b "_i")
                    (DStr "(List IStmt)")
                    (mxc_lst (edrop ssE 1)))
                  (mxc_fn1
                    (mxc_rnm nm b "_w")
                    (DStr "(List Instr)")
                    (mxc_lst (mxc_drop els 1)))
                  (mxc_rests
                    rest
                    mrest
                    (sdrop ss 1)
                    (edrop ssE 1)
                    (mxc_drop els 1)
                    nm
                    (+ b 1)))))))
          ((MxPL _ _ _ _ _ _ csets)
           (let ((q (mxc_clen csets)))
             (dconc
               (list
                 (mxc_fn1
                   (mxc_rnm nm b "_i")
                   (DStr "(List IStmt)")
                   (mxc_lst (edrop ssE (+ q 1))))
                 (mxc_fn1
                   (mxc_rnm nm b "_w")
                   (DStr "(List Instr)")
                   (mxc_lst (mxc_drop els (+ (* 2 q) 1))))
                 (mxc_rests
                   rest
                   msls
                   (sdrop ss (+ q 1))
                   (edrop ssE (+ q 1))
                   (mxc_drop els (+ (* 2 q) 1))
                   nm
                   (+ b 1))))))))))))

(fn sdrop ((l (List IStmt)) (k Int)) (List IStmt)
  (measure (struct l))
  (if (lt k 1) l
  (match l
    (Nil Nil)
    ((Cons _ t) (sdrop t (- k 1))))))

(fn edrop ((l (List Expr)) (k Int)) (List Expr)
  (measure (struct l))
  (if (lt k 1) l
  (match l
    (Nil Nil)
    ((Cons _ t) (edrop t (- k 1))))))
;; count of top-level statements
(fn isz_top ((ss (List IStmt))) Int
  (measure (struct ss))
  (match ss
    (Nil 0)
    ((Cons _ t) (+ 1 (isz_top t)))))

(fn ilen_p ((l (List (Pair Int (Pair Int Expr))))) Int
  (measure (struct l))
  (match l
    (Nil 0)
    ((Cons _ t) (+ 1 (ilen_p t)))))

;; one mixed pin, one target: tie always; the wasm leg via the
;; segmented walk; x86 declines with the walk's honest reason (or the
;; named-growth note when the walk succeeds)
(fn sqm_pin
  ((msrc Module)
   (mtr Module)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (wrap (Option Symbol))
   (pin Symbol)
   (gv Expr)
   (ifn IFn))
  ERes
  (match (ec_is gv (quote MkIFn))
    (None (EErr "pin value shape (internal)"))
    ((Some margs)
     (match margs
       ((Cons pksE (Cons xksE (Cons bodyE _)))
        (match
          (if x86 (invoke mtr (quote ix_sstmts) (Cons bodyE Nil))
          (invoke
            mtr
            (quote iw_stmts)
            (Cons (e_app_spine pksE xksE) (Cons bodyE Nil))))
          (None
            (EErr
              (append_int
                "statement translator invoke failed on "
                (chars_of_sym pin))))
          ((Some tv)
           (match (ec_is tv (quote None))
             ((Some _) (EOk (d_refused pin tname)))
             (None
               (match (ec_is tv (quote Some))
                 (None (EErr "translated value is not Some (internal)"))
                 ((Some sargs)
                  (match sargs
                    ((Cons instrsE Nil)
                     (match (spl_e tv)
                       ((SpRErr m) (EErr m))
                       ((SpROk vdoc)
                        (let
                          ((tie
                             (d_sqtie
                               tiepre
                               (pin_nm pin)
                               x86
                               pin
                               (d_kinds
                                 (ikapp (ikparams_of ifn) (ikextra_of ifn)))
                               vdoc))
                           (nl
                             (+ (ikn (ikparams_of ifn)) (ikn (ikextra_of ifn)))))
                          (match wrap
                            (None
                              (EOk
                                (DCat
                                  tie
                                  (d_note
                                    pin
                                    "mixed pin without an IProg wrapper"))))
                            ((Some wnm)
                             (match (wrap_msz msrc wnm gv)
                               (None
                                 (EErr
                                   "wrapper does not yield an IProg (internal)"))
                               ((Some msz)
                                (match (lpe_spine bodyE)
                                  (None (EErr "body spine shape (internal)"))
                                  ((Some bels)
                                   (match
                                     (mx_walk
                                       (+ (isz_top (ibody_of ifn)) 2)
                                       x86
                                       msz
                                       (ibody_of ifn)
                                       bels
                                       (st_params nl)
                                       (FVar (quote m))
                                       0
                                       1
                                       nl
                                       (ikapp
                                         (ikparams_of ifn)
                                         (ikextra_of ifn)))
                                     ((MxRf why)
                                      (EOk (DCat tie (d_note pin why))))
                                     ((MxOk evs)
                                      (if x86
                                        (match
                                          (sqx_emit brpre msz pin ifn bodyE
                                            instrsE evs mtr)
                                          ((SqxErr msg) (EErr msg))
                                          ((SqxNote why)
                                           (EOk (DCat tie (d_note pin why))))
                                          ((SqxOk bdoc)
                                           (EOk
                                             (DCat
                                               (d_sqtie
                                                 tiepre
                                                 (pin_nm pin)
                                                 True
                                                 pin
                                                 (d_kinds
                                                   (ikapp
                                                     (ikparams_of ifn)
                                                     (ikextra_of ifn)))
                                                 (dconc
                                                   (list
                                                     (DStr "(Some (inline gb_")
                                                     (DStr (pin_nm pin))
                                                     (DStr "_x))"))))
                                               bdoc))))
                                        (match
                                          (sqm_emit
                                            brpre
                                            msz
                                            pin
                                            ifn
                                            bodyE
                                            instrsE
                                            evs
                                            mtr
                                            (e_app_spine pksE xksE))
                                          ((EErr msg) (EErr msg))
                                          ((EOk bdoc) (EOk (DCat tie bdoc)))))))))))))))))
                    (_ (EErr "translated value shape (internal)"))))))))))
       (_ (EErr "pin value shape (internal)"))))))

;; --- the x86 mixed tier (V2-7, seal-point cuts V2-8): ---------------------
;; The wasm composition factors segments into standalone lemmas joined
;; by ist_seam/es_scont; V2-7 measured that an x86 chain lemma cannot
;; reset its walked state mid-span (goal size x steps, the capacity
;; wall) and that a segment lemma's continuation must RECONSTRUCT the
;; register file. The V2-8 translator seal points resolve both: the
;; chain cuts at every chunk seal AND every loop, and the mid-flat
;; legs carry open-tail sub-lemmas (sqs_x_*) whose xm_scont adapter
;; rebuilds the register file FROM THE SEAL -- 0 where the chunk's
;; seal re-zeroes, a pass-through residue where it never writes; the
;; scratch trees that ride between pieces bind by matching, never by
;; spelling. Loop legs walk their final chunk inline exactly as V2-7
;; (the chunk's dirt rides into the loop construct, ix_mout restores
;; it) and expose by il_wlen. Scratch discipline
;; (probe: examples/sqxc_probe.shard): boundary lemmas quantify
;; exactly the FULL body's seal-set registers (the terminal ix_zs
;; zeroes them before the final XNorm) and spell 0 elsewhere; workers
;; quantify the slots their body never touches (pass-through, restored
;; by ix_mout) and spell 0 in body-dirtied slots (the ix_zs seals);
;; every unknown tree binds by MATCHING at cite sites -- the emitter
;; never spells a scratch value it did not put there. Rest fns spell
;; as Cons spines ENDING IN THE NEXT REST FN'S CALL, so an open-walker
;; compute brakes at the (stopped) call instead of overshooting the
;; boundary; one unfold re-literalizes the tail for the cite.

(fn mxx_rstops ((nm (List Int)) (j Int) (nr Int)) Doc
  (measure (- (+ nr 1) j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt nr j) (DStr "")
  (dcat3
    (dcat3 (DStr " ") (mxc_rnm nm j "_x") (DStr " "))
    (mxc_rnm nm j "_i")
    (mxx_rstops nm (+ j 1) nr))))

(fn mxx_pstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list
      (DStr "(stop iwhile xeval_loop lg_fuel int_of_nat")
      (mxx_rstops nm 1 nr)
      (DStr ")"))))

(fn mxx_cstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list
      (DStr "(stop iwhile xeval_loop lg_fuel int_of_nat istmts xeval_seq")
      (mxx_rstops nm 1 nr)
      (DStr ")"))))

(fn mxx_lstop ((nm (List Int)) (nr Int)) Doc
  (dconc
    (list (DStr "(stop lg_fuel int_of_nat") (mxx_rstops nm 1 nr) (DStr ")"))))

(fn mxx_wstop () Doc (DStr "(stop xeval_loop iwhile lg_fuel ix_mout)"))

;; a fuel tower doc that degrades to the bare tail at count 0
(fn mxx_tw ((n Int) (v Doc)) Doc
  (if (lt n 1) v (dconc (list (DStr "(S^ ") (dint n) (DStr " ") v (DStr ")")))))

;; ask the MODEL which scratch register a code list dirties (ix_dwl
;; through the translator module -- never a generator-side scan)
(fn mxx_dirty ((mtr Module) (codeE Expr) (t Int)) (Option Bool)
  (match (invoke mtr (quote ix_dwl) (Cons codeE (Cons (IntLit t) Nil)))
    (None None)
    ((Some r)
     (match (ec_is r (quote True))
       ((Some _) (Some True))
       (None (Some False))))))

;; per-loop scratch info: zs length + pass-through flags (True = the
;; body never touches the register; its slot quantifies in the worker)
(type MxXLi (MkMxXLi Int Int Expr Bool Bool Bool))

(fn mxx_li1 ((mtr Module) (wlen Int) (wcodeE Expr)) (Option MxXLi)
  (match (mxx_dirty mtr wcodeE 0)
    (None None)
    ((Some d0)
     (match (mxx_dirty mtr wcodeE 10)
       (None None)
       ((Some d10)
        (match (mxx_dirty mtr wcodeE 11)
          (None None)
          ((Some d11)
           (Some
             (MkMxXLi
               (+ (if d0 1 0) (+ (if d10 1 0) (if d11 1 0)))
               wlen
               wcodeE
               (if d0 False True)
               (if d10 False True)
               (if d11 False True))))))))))

(fn mxx_lis ((machs (List (Pair Int (Pair Int Expr)))) (mtr Module))
  (Option (List MxXLi))
  (measure (struct machs))
  (match machs
    (Nil (Some Nil))
    ((Cons (Pair _ (Pair wlen wcodeE)) t)
     (match (mxx_li1 mtr wlen wcodeE)
       (None None)
       ((Some li)
        (match (mxx_lis t mtr)
          (None None)
          ((Some more) (Some (Cons li more)))))))))

;; the machine loop entries for the x86 spine: XBlock([XLoop inner])
(fn mxx_mach ((els (List Expr)) (j Int))
  (Option (List (Pair Int (Pair Int Expr))))
  (measure (struct els))
  (match els
    (Nil (Some Nil))
    ((Cons h t)
     (match (mxx_mach t (+ j 1))
       (None None)
       ((Some rest)
        (match h
          ((Ctor q hargs)
           (if (sym_eq (qn_name q) (quote XBlock))
             (match hargs
               ((Cons inner Nil)
                (match (lpe_spine inner)
                  ((Some (Cons lp Nil))
                   (match lp
                     ((Ctor lq largs)
                      (if (sym_eq (qn_name lq) (quote XLoop))
                        (match largs
                          ((Cons w Nil)
                           (match (lpe_spine w)
                             (None None)
                             ((Some wels)
                              (Some (Cons (Pair j (Pair (ilen_e wels) w)) rest)))))
                          (_ None))
                        (Some rest)))
                     (_ (Some rest))))
                  (_ (Some rest))))
               (_ (Some rest)))
             (Some rest)))
          (_ (Some rest))))))))

;; per-CHUNK machine translation + seal, both by INVOKE (the model
;; answers: ix_stmts for the chunk's instrs, ix_zs for the seal the
;; translator inserts after it -- V2-8's interior seal points; the
;; slicer's segments ARE the translator's chunk grid, mxc_capq and
;; ix_capq deliberately spell the same cap discipline)
(fn mxx_chunks ((pcs (List MxPc)) (mtr Module))
  (Option (List (Pair (List Expr) (List Expr))))
  (measure (struct pcs))
  (match pcs
    (Nil (Some Nil))
    ((Cons pc rest)
     (match pc
       ((MxPS _ segE)
        (match (invoke mtr (quote ix_stmts) (Cons (list_expr segE) Nil))
          (None None)
          ((Some tv)
           (match (ec_is tv (quote Some))
             (None None)
             ((Some sargs)
              (match sargs
                ((Cons chE Nil)
                 (match (lpe_spine chE)
                   (None None)
                   ((Some ch)
                    (match (invoke mtr (quote ix_zs) (Cons chE Nil))
                      (None None)
                      ((Some zv)
                       (match (lpe_spine zv)
                         (None None)
                         ((Some zl)
                          (match (mxx_chunks rest mtr)
                            (None None)
                            ((Some more) (Some (Cons (Pair ch zl) more)))))))))))
                (_ None)))))))
       ;; a branch is a singleton chunk with NO seal on either side
       ;; (ix_cjoin seals flat-flat neighbors only) -- its msls entry
       ;; carries the encoding element and an empty seal
       ((MxPB _ sE _ _ _ _ _)
        (match
          (invoke mtr (quote ix_stmts) (Cons (list_expr (Cons sE Nil)) Nil))
          (None None)
          ((Some tv)
           (match (ec_is tv (quote Some))
             (None None)
             ((Some sargs)
              (match sargs
                ((Cons chE Nil)
                 (match (lpe_spine chE)
                   (None None)
                   ((Some ch)
                    (match (mxx_chunks rest mtr)
                      (None None)
                      ((Some more) (Some (Cons (Pair ch Nil) more)))))))
                (_ None)))))))
       ((MxPL _ _ _ _ _ _ _) (mxx_chunks rest mtr))))))

;; the register-file doc: scratch fields take the given docs; home
;; fields take kd at the counter, the const-run's ground value at a
;; cset slot, the ep-prefixed binder otherwise; non-home fields are 0
(fn mxx_regs_go
  ((j Int)
   (nl Int)
   (gi Int)
   (kd Doc)
   (ep Doc)
   (cs (List (Pair Int Int)))
   (sa Doc)
   (sb Doc)
   (sc Doc))
  Doc
  (measure (- 15 j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 15)
    (dcat3
      (if (int_eq j 0) (dcat3 (DStr " ") sa (DStr ""))
      (if (int_eq j 9) (dcat3 (DStr " ") sb (DStr ""))
      (if (int_eq j 10) (dcat3 (DStr " ") sc (DStr ""))
      (match (lp_fieldlocal j nl)
        ((Some i)
         (if (int_eq i gi) (dcat3 (DStr " ") kd (DStr ""))
         (match (mxc_cval cs i)
           ((Some v) (dcat3 (DStr " ") (dint v) (DStr "")))
           (None (dconc (list (DStr " ") ep (dint i)))))))
        (None (DStr " 0"))))))
      (DStr "")
      (mxx_regs_go (+ j 1) nl gi kd ep cs sa sb sc))
    (DStr "")))

(fn mxx_regs
  ((nl Int)
   (gi Int)
   (kd Doc)
   (ep Doc)
   (cs (List (Pair Int Int)))
   (sa Doc)
   (sb Doc)
   (sc Doc))
  Doc
  (dcat3 (DStr "(MkRegs") (mxx_regs_go 0 nl gi kd ep cs sa sb sc) (DStr ")")))

;; the worker's CLOSED locals spine (xargs walks the whole list at the
;; exit adapter, so no open tail is possible on this target)
(fn mxx_locs_go ((j Int) (nl Int) (gi Int) (kd Doc)) Doc
  (measure (- nl j) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j nl)
    (dconc
      (list
        (DStr "(Cons ")
        (if (int_eq j gi) kd (dcat3 (DStr "x") (dint j) (DStr "")))
        (sp)
        (mxx_locs_go (+ j 1) nl gi kd)
        (DStr ")")))
    (DStr "Nil")))

;; a code spine with an arbitrary tail doc, elements at the flat-list
;; spelling (nested Block bodies stay linear under shardfmt)
(fn mxx_spn ((els (List Expr)) (tail Doc)) Doc
  (measure (struct els))
  (match els
    (Nil tail)
    ((Cons h t)
     (match (spl_e h)
       ((SpRErr _) (DStr "?SPN?"))
       ((SpROk hd)
        (dconc (list (DStr "(Cons ") hd (DStr " ") (mxx_spn t tail) (DStr ")"))))))))

;; the worker split spine at x86 stops
(fn mxxw_spine ((gs (List GSplit)) (i Int) (msz Int) (tail Doc)) Doc
  (measure (struct gs))
  (match gs
    (Nil tail)
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (DStr
              " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
            (mxx_wstop)
            (DStr "))) ")
            (mxxw_spine t (+ i 1) msz tail)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both (stop lg_fuel)))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (mxw_mh i a msz "True" (mxx_wstop))
            (DStr " ")
            (mxxw_spine t (+ i 1) msz tail)
            (DStr ")) (case False (chain ")
            (mxw_mh i a msz "False" (DStr "(stop lg_fuel)"))
            (DStr " refl))))"))))))))

;; one counter-tied x86 worker: body-copy fns + the claim (probe shape)
;; the x86 twin of mxw_brcase (identical structure, x86 stops); the
;; loop's own ix_zs seal re-zeroes the arm dirt before the back-edge,
;; so the header register state is arm-independent and the per-arm IH
;; cites bind by matching -- the seal IS the join.
(fn mxxw_brcase
  ((scrut Expr)
   (tgs (List GSplit))
   (egs (List GSplit))
   (p Int)
   (msz Int)
   (widnm Doc))
  Doc
  (dconc
    (list
      (DStr "(case-on ")
      (pr_e scrut)
      (DStr
        " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
      (mxx_wstop)
      (DStr "))) ")
      (mxxw_spine
        tgs
        (+ p 1)
        msz
        (mxw_tail widnm (+ (+ p 1) (ilen_gs (gs_index tgs 0)))))
      (DStr
        ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
      (mxx_wstop)
      (DStr "))) ")
      (mxxw_spine
        egs
        (+ p 1)
        msz
        (mxw_tail widnm (+ (+ p 1) (ilen_gs (gs_index egs 0)))))
      (DStr "))))"))))

(fn mxxw_emit ((nm (List Int)) (d Int) (nl Int) (msz Int) (lp MxLp) (li MxXLi))
  ERes
  (match lp
    ((MkMxLp gi _ lbodyE lbody _ _ wsplits lbr _)
     (match li
       ((MkMxXLi _ wlen wcodeE sa sb sc)
        (match (spl_e lbodyE)
          ((SpRErr m) (EErr m))
          ((SpROk lbdoc)
           (match (spl_e wcodeE)
             ((SpRErr m) (EErr m))
             ((SpROk wcdoc)
              (let
                ((bw (+ (gcost lbody) 5))
                 (aw (+ (tcost wcodeE) 2))
                 (ds (gs_dedup Nil wsplits))
                 (sad (if sa (DStr "za") (DStr "0")))
                 (sbd (if sb (DStr "zb") (DStr "0")))
                 (scd (if sc (DStr "zc") (DStr "0"))))
                (let
                  ((locs (mxx_locs_go 0 nl gi (DStr "(int_of_nat k)")))
                   (regs
                     (mxx_regs
                       nl
                       gi
                       (DStr "(int_of_nat k)")
                       (DStr "x")
                       Nil
                       sad
                       sbd
                       scd))
                   (zbinds
                     (dconc
                       (list
                         (if sa (DStr "(za Int) ") (DStr ""))
                         (if sb (DStr "(zb Int) ") (DStr ""))
                         (if sc (DStr "(zc Int) ") (DStr ""))))))
                  (EOk
                    (dconc
                      (list
                        (DStr "(fn gb_")
                        (DStr nm)
                        (DStr "_l")
                        (dint d)
                        (DStr "_i () (List IStmt) ")
                        lbdoc
                        (DStr ")")
                        (DStr (nl))
                        (DStr (nl))
                        (DStr "(fn gb_")
                        (DStr nm)
                        (DStr "_l")
                        (dint d)
                        (DStr "_x () (List XInstr) ")
                        wcdoc
                        (DStr ")")
                        (DStr (nl))
                        (DStr (nl))
                        (DStr "(claim sqxw_")
                        (DStr nm)
                        (DStr "_l")
                        (dint d)
                        (DStr " (goal (")
                        (mxw_binds_go
                          nl
                          gi
                          (dcat3
                            zbinds
                            (DStr
                              "(k Nat) (m Mem) (c Nat) (c2 Nat) (restfs (List XFunc))")
                            (DStr "")))
                        (DStr
                          ") ((= (lt (int_of_nat k) 4294967296) True)) (= (xeval_loop (S^ ")
                        (dint aw)
                        (DStr " (lg_fuel k c)) (MkXModule restfs 0 ")
                        (dint msz)
                        (DStr ") (inline gb_")
                        (DStr nm)
                        (DStr "_l")
                        (dint d)
                        (DStr "_x) ")
                        regs
                        (DStr " m) (ix_mout ")
                        sad
                        (DStr " ")
                        sbd
                        (DStr " ")
                        scd
                        (DStr " (iwhile (S^ ")
                        (dint bw)
                        (DStr " (lg_fuel k c2)) ")
                        (dint msz)
                        (DStr " (ILoc ")
                        (dint gi)
                        (DStr ") (inline gb_")
                        (DStr nm)
                        (DStr "_l")
                        (dint d)
                        (DStr "_i) ")
                        locs
                        (DStr
                          " m)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold lg_fuel rhs) (reduce rhs) (unfold xeval_loop lhs) (unfold iwhile rhs) (rewrite (lemma int_of_nat_succ) lr both true ()) (compute both ")
                        (mxx_wstop)
                        (DStr
                          "))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (rewrite-with (lemma lg_ne) lr rhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute both ")
                        (mxx_wstop)
                        (DStr "))) ")
                        (mxxw_spine
                          ds
                          1
                          msz
                          (match lbr
                            (None
                              (mxw_tail
                                (dcat3 (DStr "sqm_wid_") (DStr nm) (DStr ""))
                                (ilen_gs (gs_index ds 0))))
                            ((Some (MkLBr scrut tgs egs))
                             (mxxw_brcase
                               scrut
                               tgs
                               egs
                               (ilen_gs (gs_index ds 0))
                               msz
                               (dcat3 (DStr "sqm_wid_") (DStr nm) (DStr ""))))))
                        (DStr ")))))")
                        (DStr (nl))
                        (DStr (nl))))))))))))))))

;; all x86 workers, in loop order
(fn mxxw_all
  ((evs (List MxEv))
   (lis (List MxXLi))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (d Int))
  ERes
  (measure (struct evs))
  (match evs
    (Nil (EOk (DStr "")))
    ((Cons e t)
     (match e
       ((MxSp _) (mxxw_all t lis nm nl msz d))
       ((MxL lp)
        (match lis
          (Nil (EErr "machine loop info missing (internal)"))
          ((Cons li lrest)
           (match (mxxw_emit nm d nl msz lp li)
             ((EErr m) (EErr m))
             ((EOk wd)
              (match (mxxw_all t lrest nm nl msz (+ d 1))
                ((EErr m) (EErr m))
                ((EOk rest) (EOk (DCat wd rest)))))))))))))

;; --- leg grammar: chunk-grain cuts (V2-8). A boundary lemma sits
;; after EVERY translator chunk seal AND after every loop, so each
;; lemma's state is bounded by one capped chunk and RESETS at every
;; cut to fresh binders (the reset the V2-7 capacity wall demanded;
;; the wasm capped factoring gets it the same way). A chunk followed
;; by a loop stays IN the loop's lemma (no seal separates them -- its
;; scratch dirt rides into the loop construct and ix_mout restores
;; it), so loop legs keep the V2-7 shape verbatim: walk the chunk +
;; const-run inline, cite the counter-tied worker, expose by il_wlen,
;; cite the next boundary at the leaf. A MID-FLAT leg never walks its
;; machine side at all: the walk lives in the leg's open-tail
;; sub-lemma (sqs_x_*, braked by the opaque tail), and the chain
;; lemma composes -- ist_seam splits the imp side at the seal point,
;; the sub-lemma cite rewrites the machine side, il_slen exposes the
;; shared standalone run, and the next boundary is cited at the
;; parked leaf, where the machine side sits at the FOLDED rest-fn
;; call under the xeval_seq stop (an inline walk would overshoot the
;; brake into match residue -- the V2-7 finding, re-measured here).
;; The counter respell happens at INSTRUCTION grain BEFORE the loop
;; walk ((XMovRI reg K) / (ISet gi (IConst K)) respelled to the
;; (int_of_nat K) payload at first occurrence -- single in the subject
;; because deeper legs are folded behind their rest fns), so the walk
;; itself carries the worker's counter spelling into the stuck loop
;; term and the cite binds everything by matching. Scrutinees and the
;; exposure entry spell from the leg's own lw_stmts walk state.

(fn mxx_legs ((pcs (List MxPc))) (List (Pair (List MxPc) (Option MxPc)))
  (measure (struct pcs))
  (match pcs
    (Nil Nil)
    ((Cons pc t)
     (match pc
       ((MxPL _ _ _ _ _ _ _) (Cons (Pair Nil (Some pc)) (mxx_legs t)))
       ;; a branch has no seal on either side: it GLUES into the leg
       ;; that follows it (through the next loop / flat run / end)
       ((MxPB _ _ _ _ _ _ _)
        (match (mxx_legs t)
          (Nil (Cons (Pair (Cons pc Nil) None) Nil))
          ((Cons (Pair segs2 olp2) rest2)
           (Cons (Pair (Cons pc segs2) olp2) rest2))))
       ((MxPS a e)
        (match t
          (Nil (Cons (Pair (Cons (MxPS a e) Nil) None) Nil))
          ((Cons pc2 t2)
           (match pc2
             ((MxPL _ _ _ _ _ _ _)
              (Cons (Pair (Cons (MxPS a e) Nil) (Some pc2)) (mxx_legs t2)))
             ((MxPS _ _) (Cons (Pair (Cons (MxPS a e) Nil) None) (mxx_legs t)))
             ;; flat followed by a branch: no seal between them either
             ((MxPB _ _ _ _ _ _ _)
              (match (mxx_legs t)
                (Nil (Cons (Pair (Cons (MxPS a e) Nil) None) Nil))
                ((Cons (Pair segs2 olp2) rest2)
                 (Cons (Pair (Cons (MxPS a e) segs2) olp2) rest2))))))))))))

(fn mxx_nlg ((l (List (Pair (List MxPc) (Option MxPc))))) Int
  (measure (struct l))
  (match l
    (Nil 0)
    ((Cons _ t) (+ 1 (mxx_nlg t)))))

;; the leg's chunk metrics from the invoked stream: (machine width,
;; (seal width, stmt count)); a chunkless leg passes msls through
(fn mxx_segm ((segs (List MxPc)) (msls (List (Pair (List Expr) (List Expr)))))
  (Pair (Pair Int (Pair Int Int)) (List (Pair (List Expr) (List Expr))))
  (measure (struct segs))
  (match segs
    (Nil (Pair (Pair 0 (Pair 0 0)) msls))
    ((Cons pc rest)
     (match pc
       ((MxPS segst _)
        (match msls
          (Nil (Pair (Pair 0 (Pair 0 0)) Nil))
          ((Cons (Pair sl zl) mrest)
           (match (mxx_segm rest mrest)
             ((Pair (Pair w2 (Pair z2 t2)) mout)
              ;; z = the TRAILING flat chunk's seal (a mid leg ends at
              ;; it); seals between glued pieces are never emitted
              (Pair
                (Pair
                  (+ (ilen_e sl) w2)
                  (Pair
                    (match rest
                      (Nil (ilen_e zl))
                      (_ z2))
                    (+ (isz_top segst) t2)))
                mout))))))
       ;; a branch = ONE machine element (the outer XBlock), ONE imp
       ;; statement; no seal
       ((MxPB _ _ _ _ _ _ _)
        (match msls
          (Nil (Pair (Pair 0 (Pair 0 0)) Nil))
          ((Cons _ mrest)
           (match (mxx_segm rest mrest)
             ((Pair (Pair w2 (Pair z2 t2)) mout)
              (Pair (Pair (+ 1 w2) (Pair z2 (+ 1 t2))) mout))))))
       ((MxPL _ _ _ _ _ _ _) (Pair (Pair 0 (Pair 0 0)) msls))))))

;; the leg's own statement list: segment stmts then the const-run
(fn mxx_segstmts ((segs (List MxPc))) (List IStmt)
  (measure (struct segs))
  (match segs
    (Nil Nil)
    ((Cons pc t)
     (match pc
       ((MxPS segst _) (isapp2 segst (mxx_segstmts t)))
       ((MxPB _ _ _ _ _ _ _) (mxx_segstmts t))
       ((MxPL _ _ _ _ _ _ _) (mxx_segstmts t))))))

(fn isapp2 ((a (List IStmt)) (b (List IStmt))) (List IStmt)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (isapp2 t b)))))

(fn mxx_csetstmts ((cs (List (Pair Int Int)))) (List IStmt)
  (measure (struct cs))
  (match cs
    (Nil Nil)
    ((Cons (Pair si v) t) (Cons (ISet si (IConst v)) (mxx_csetstmts t)))))

;; conservative nested-walk headroom for a leg's branches (the arm
;; walks run BELOW the top-level countdown; oversupply is safe --
;; machine surplus binds by matching, imp towers derive by
;; subtraction)
(fn mxx_sgpad ((segs (List MxPc))) Int
  (measure (struct segs))
  (match segs
    (Nil 0)
    ((Cons pc t)
     (match pc
       ((MxPB _ sE _ _ _ _ _) (+ (+ (* 2 (mxb_count sE)) 4) (mxx_sgpad t)))
       (_ (mxx_sgpad t))))))

;; whole-claim fuels at leg grain (MAX constraint per loop); mid-flat
;; legs consume their chunk + its seal exactly (the cite alignment
;; needs the chain arithmetic exact at every boundary); branch legs
;; add conservative headroom for the nested arm walks
(fn mxx_ag
  ((legs (List (Pair (List MxPc) (Option MxPc))))
   (lis (List MxXLi))
   (msls (List (Pair (List Expr) (List Expr))))
   (cm Int)
   (ci Int)
   (am Int)
   (ai Int))
  (Pair Int Int)
  (measure (struct legs))
  (match legs
    (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
    ((Cons (Pair segs olp) rest)
     (match (mxx_segm segs msls)
       ((Pair (Pair w (Pair z tn)) msls2)
        (match olp
          (None
            (match rest
              (Nil
                (Pair
                  (imax am (+ (+ (+ cm w) (mxx_sgpad segs)) 8))
                  (imax ai (+ (+ (+ ci tn) (mxx_sgpad segs)) 8))))
              ((Cons _ _)
               (mxx_ag rest lis msls2 (+ cm (+ w z)) (+ ci tn) am ai))))
          ((Some pc)
           (match pc
             ((MxPL _ kg lbody _ _ _ csets)
              (match lis
                (Nil (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))
                ((Cons (MkMxXLi zlen _ wcode _ _ _) lrest)
                 (let ((q (mxc_clen csets)))
                   (mxx_ag
                     rest
                     lrest
                     msls2
                     (+ (+ cm w) (+ (+ q zlen) 1))
                     (+ (+ ci tn) (+ q 1))
                     (imax
                       am
                       (+
                         (+
                           (+ (+ (+ cm w) (mxx_sgpad segs)) (+ (+ q zlen) 4))
                           (+ (tcost wcode) 2))
                         (+ kg 1)))
                     (imax
                       ai
                       (+
                         (+
                           (+ (+ (+ ci tn) (mxx_sgpad segs)) (+ q 2))
                           (+ (gcost lbody) 5))
                         (+ kg 1))))))))
             (_ (Pair (imax am (+ cm 8)) (imax ai (+ ci 8))))))))))))

;; --- rest fns: cuts AFTER each loop; spines brake at the next call --------

(fn mxx_slice ((els (List Expr)) (from Int) (count Int)) (List Expr)
  (mxc_take (mxc_drop els from) count))

(fn mxx_rest1
  ((nm (List Int))
   (b Int)
   (ssE (List Expr))
   (els (List Expr))
   (ip Int)
   (mp Int)
   (ki Int)
   (kw Int)
   (lastp Bool))
  Doc
  (dconc
    (list
      (mxc_fn1
        (if (int_eq b 0) (dcat3 (DStr "gb_") (DStr nm) (DStr "_i"))
        (mxc_rnm nm b "_i"))
        (DStr "(List IStmt)")
        (if lastp (mxc_lst (mxc_drop ssE ip))
        (mxx_spn
          (mxx_slice ssE ip ki)
          (dcat3 (DStr "(") (mxc_rnm nm (+ b 1) "_i") (DStr ")")))))
      (mxc_fn1
        (if (int_eq b 0) (dcat3 (DStr "gb_") (DStr nm) (DStr "_x"))
        (mxc_rnm nm b "_x"))
        (DStr "(List XInstr)")
        (if lastp (mxc_lst (mxc_drop els mp))
        (mxx_spn
          (mxx_slice els mp kw)
          (dcat3 (DStr "(") (mxc_rnm nm (+ b 1) "_x") (DStr ")"))))))))

(fn mxx_rests
  ((legs (List (Pair (List MxPc) (Option MxPc))))
   (lis (List MxXLi))
   (msls (List (Pair (List Expr) (List Expr))))
   (nm (List Int))
   (ssE (List Expr))
   (els (List Expr))
   (ip Int)
   (mp Int)
   (b Int))
  Doc
  (measure (struct legs))
  (match legs
    (Nil (DStr ""))
    ((Cons (Pair segs olp) rest)
     (match (mxx_segm segs msls)
       ((Pair (Pair w (Pair z tn)) msls2)
        (let
          ((lastp
             (match rest
               (Nil True)
               ((Cons _ _) False))))
          (match olp
            (None
              (if lastp (mxx_rest1 nm b ssE els ip mp tn w True)
              (DCat
                (mxx_rest1 nm b ssE els ip mp tn (+ w z) False)
                (mxx_rests
                  rest
                  lis
                  msls2
                  nm
                  ssE
                  els
                  (+ ip tn)
                  (+ mp (+ w z))
                  (+ b 1)))))
            ((Some pc)
             (match pc
               ((MxPL _ _ _ _ _ _ csets)
                (match lis
                  (Nil (DStr ""))
                  ((Cons (MkMxXLi zlen _ _ _ _ _) lrest)
                   (let ((q (mxc_clen csets)))
                     (let ((ki (+ tn (+ q 1))) (kw (+ w (+ (+ q zlen) 1))))
                       (DCat
                         (mxx_rest1 nm b ssE els ip mp ki kw lastp)
                         (mxx_rests
                           rest
                           lrest
                           msls2
                           nm
                           ssE
                           els
                           (+ ip ki)
                           (+ mp kw)
                           (+ b 1))))))))
               (_ (DStr "")))))))))))

;; the chain split spine: True arms continue at pst, False arms
;; conflate traps at lst
(fn mxx_spine
  ((gs (List GSplit)) (i Int) (msz Int) (pst Doc) (lst Doc) (tail Doc))
  Doc
  (measure (struct gs))
  (match gs
    (Nil tail)
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (DStr
              " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
            pst
            (DStr "))) ")
            (mxx_spine t (+ i 1) msz pst lst tail)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
            lst
            (DStr "))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (mxw_mh i a msz "True" pst)
            (DStr " ")
            (mxx_spine t (+ i 1) msz pst lst tail)
            (DStr ")) (case False (chain ")
            (mxw_mh i a msz "False" lst)
            (DStr " refl))))"))))))))

;; cite the next boundary lemma at the exposure leaf: the goal holds
;; the FOLDED continuation (walkers stopped), which is the cited
;; lemma's exact subject form; the trailing compute unfolds the
;; adapter to the goal's match form
(fn mxx_cite ((nm (List Int)) (b Int) (cst Doc)) Doc
  (dconc
    (list
      (DStr "(rewrite-with (lemma cmp_x_")
      (DStr nm)
      (DStr "_b")
      (dint b)
      (DStr ") lr lhs ((inst c2 c2)) ()) (steps ((compute both ")
      cst
      (DStr "))) refl"))))

;; the counter home's register ctor name
(fn mxx_regnm ((i Int)) Doc
  (if (int_eq i 0) (DStr "RDI")
  (if (int_eq i 1) (DStr "RSI")
  (if (int_eq i 2) (DStr "RDX")
  (if (int_eq i 3) (DStr "RCX")
  (if (int_eq i 4) (DStr "R8")
  (if (int_eq i 5) (DStr "R9")
  (if (int_eq i 6) (DStr "RBX")
  (if (int_eq i 7) (DStr "RBP")
  (if (int_eq i 8) (DStr "R12")
  (if (int_eq i 9) (DStr "R13")
  (if (int_eq i 10) (DStr "R14")
  (if (int_eq i 11) (DStr "R15")
  (DStr "?REG?"))))))))))))))

;; walked locals as a (list ...) doc, kd at the counter slot
(fn mxx_locdoc_go ((lc (List Expr)) (j Int) (gi Int) (kd Doc)) Doc
  (measure (struct lc))
  (match lc
    (Nil (DStr ""))
    ((Cons e t)
     (dcat3
       (if (int_eq j gi) (dcat3 (DStr " ") kd (DStr ""))
       (dcat3 (DStr " ") (pr_e e) (DStr "")))
       (DStr "")
       (mxx_locdoc_go t (+ j 1) gi kd)))))

(fn mxx_locdoc ((lc (List Expr)) (gi Int) (kd Doc)) Doc
  (dconc (list (DStr "(list") (mxx_locdoc_go lc 0 gi kd) (DStr ")"))))

;; --- seal-point segment sub-lemmas (V2-8) --------------------------------
;; A mid-flat leg's machine walk lives in an OPEN-TAIL sub-lemma (the
;; opaque tail rw brakes the walker at the boundary; an inline chain
;; walk would overshoot the folded rest-fn call into match residue --
;; the V2-7 finding, re-measured here). The sub-lemma states: the
;; chunk's instrs THROUGH ITS SEAL over ANY tail = xm_scont of the
;; standalone imp run, with scratch residues read off the seal (0
;; where the seal re-zeroes, the entry binder where the chunk never
;; writes -- the model's ix_zs answer IS the dirt set).

(fn mxx_zmov ((e Expr) (rn Symbol)) Bool
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote XMovRI))
       (match args
         ((Cons r _)
          (match r
            ((Ctor rq _) (sym_eq (qn_name rq) rn))
            (_ False)))
         (_ False))
       False))
    (_ False)))

(fn mxx_zhas ((zl (List Expr)) (rn Symbol)) Bool
  (measure (struct zl))
  (match zl
    (Nil False)
    ((Cons h t) (if (mxx_zmov h rn) True (mxx_zhas t rn)))))

(fn mxx_zflags ((zl (List Expr))) (Pair Bool (Pair Bool Bool))
  (Pair
    (mxx_zhas zl (quote RAX))
    (Pair (mxx_zhas zl (quote R10)) (mxx_zhas zl (quote R11)))))

;; the sub-lemma split spine: mid computes brake at (stop xm_scont);
;; the final arm and the trap arms compute open, so both sides
;; converge on the braked-tail residue / the trap
(fn mxxs_spine ((gs (List GSplit)) (i Int) (msz Int)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr "refl"))
    ((Cons g t)
     (match g
       ((GShared e)
        (dconc
          (list
            (DStr "(case-on ")
            (pr_e e)
            (match t
              (Nil
                (DStr
                  " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) "))
              ((Cons _ _)
               (DStr
                 " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both (stop xm_scont)))) ")))
            (mxxs_spine t (+ i 1) msz)
            (DStr
              ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both))) refl))))"))))
       ((GMemHi a)
        (dconc
          (list
            (DStr "(case-on (lt ")
            (pr_e a)
            (DStr " ")
            (dint msz)
            (DStr ") Bool ((case True (chain ")
            (mxw_mh
              i
              a
              msz
              "True"
              (match t
                (Nil (DStr ""))
                ((Cons _ _) (DStr "(stop xm_scont)"))))
            (DStr " ")
            (mxxs_spine t (+ i 1) msz)
            (DStr ")) (case False (chain ")
            (mxw_mh i a msz "False" (DStr ""))
            (DStr " refl))))"))))))))

;; one seal-point sub-lemma: the chunk fn + the open-tail claim.
;; UNPREMISED; splits from the chunk's own walk at fresh locals.
(fn mxx_seg1
  ((nm (List Int))
   (b Int)
   (nl Int)
   (msz Int)
   (tn Int)
   (segs (List MxPc))
   (msls (List (Pair (List Expr) (List Expr))))
   (gs (List GSplit)))
  Doc
  (match segs
    (Nil (DStr ""))
    ((Cons pc _)
     (match pc
       ((MxPL _ _ _ _ _ _ _) (DStr ""))
       ((MxPS _ segE)
        (match msls
          (Nil (DStr ""))
          ((Cons (Pair sl zl) _)
           (match (mxx_zflags zl)
             ((Pair da (Pair db dc))
              (let
                ((cnm
                   (dconc
                     (list
                       (DStr "gb_")
                       (DStr nm)
                       (DStr "_c")
                       (dint b)
                       (DStr "_i")))))
                (dconc
                  (list
                    (DStr "(fn ")
                    cnm
                    (DStr " () (List IStmt) ")
                    (mxc_lst segE)
                    (DStr ")")
                    (DStr (nl))
                    (DStr (nl))
                    (DStr "(claim sqs_x_")
                    (DStr nm)
                    (DStr "_c")
                    (dint b)
                    (DStr " (goal (")
                    (d_binds_go
                      nl
                      (DStr
                        "(za Int) (zb Int) (zc Int) (rw (List XInstr)) (m Mem) (f Nat) (g Nat) (restfs (List XFunc))"))
                    (DStr ") () (= (xeval_seq (S^ ")
                    (dint (+ (ilen_e sl) (ilen_e zl)))
                    (DStr " (S f)) (MkXModule restfs 0 ")
                    (dint msz)
                    (DStr ") ")
                    (mxx_spn (st_app sl zl) (DStr "rw"))
                    (DStr " ")
                    (mxx_regs
                      nl
                      (- 0 1)
                      (DStr "")
                      (DStr "x")
                      Nil
                      (DStr "za")
                      (DStr "zb")
                      (DStr "zc"))
                    (DStr " m) (xm_scont ")
                    (if da (DStr "0") (DStr "za"))
                    (DStr " ")
                    (if db (DStr "0") (DStr "zb"))
                    (DStr " ")
                    (if dc (DStr "0") (DStr "zc"))
                    (DStr " (S f) (MkXModule restfs 0 ")
                    (dint msz)
                    (DStr ") rw (istmts (S^ ")
                    (dint tn)
                    (DStr " (S g)) ")
                    (dint msz)
                    (DStr " (inline ")
                    cnm
                    (DStr ") ")
                    (d_args nl)
                    (match gs
                      (Nil (DStr " m)))) (chain (steps ((compute both))) "))
                      ((Cons _ _)
                       (DStr
                         " m)))) (chain (steps ((compute both (stop xm_scont)))) ")))
                    (mxxs_spine gs 1 msz)
                    (DStr "))")
                    (DStr (nl))
                    (DStr (nl))))))))))))))

;; the seal-point composition (one mid-flat leg's chain-lemma body):
;; ist_seam splits the imp side at the seal point, the sub-lemma cite
;; rewrites the machine side, ONE case-on of the shared standalone
;; run absorbs every outcome, il_slen exposes the segment exit, and
;; cont fires at the exposed leaf -- where the machine side sits
;; parked at the folded rest-fn call (the xeval_seq stop keeps it at
;; call grain; nothing here ever walks the machine side)
(fn mxx_cstep
  ((nm (List Int))
   (b Int)
   (nl Int)
   (msz Int)
   (tn Int)
   (gm Int)
   (cst Doc)
   (lst Doc)
   (cont Doc))
  Doc
  (let
    ((cnm
       (dconc (list (DStr "gb_") (DStr nm) (DStr "_c") (dint b) (DStr "_i"))))
     (subj
       (if (int_eq b 0)
         (dconc (list (DStr "(inline gb_") (DStr nm) (DStr "_i)")))
         (dconc (list (DStr "(") (mxc_rnm nm b "_i") (DStr ")")))))
     (tail (dconc (list (DStr "(") (mxc_rnm nm (+ b 1) "_i") (DStr ")")))))
    (dconc
      (list
        (DStr "(have hsp")
        (dint b)
        (DStr " (= ")
        subj
        (DStr " (isapp (inline ")
        cnm
        (DStr ") ")
        tail
        (DStr ")) (steps ((compute both)) refl)) (steps ((rewrite (premise hsp")
        (dint b)
        (DStr ") lr rhs true ()))) (have hfg")
        (dint b)
        (DStr " (= (S^ ")
        (dint gm)
        (DStr " c2) (lg_fuel (istn (inline ")
        cnm
        (DStr ")) (S (S^ ")
        (dint (- (- gm tn) 1))
        (DStr
          " c2)))) (steps ((compute both)) refl)) (steps ((rewrite (premise hfg")
        (dint b)
        (DStr
          ") lr rhs true ()))) (rewrite-with (lemma ist_seam) lr rhs ((inst g c2)) ((steps ((compute lhs)) refl))) (have hfb")
        (dint b)
        (DStr " (= (lg_fuel (istn (inline ")
        cnm
        (DStr ")) (S c2)) (S^ ")
        (dint tn)
        (DStr
          " (S c2))) (steps ((compute both)) refl)) (steps ((rewrite (premise hfb")
        (dint b)
        (DStr ") lr rhs true ()))) (rewrite-with (lemma sqs_x_")
        (DStr nm)
        (DStr "_c")
        (dint b)
        (DStr ") lr lhs ((inst g c2)) ()) (case-on (istmts (S^ ")
        (dint tn)
        (DStr " (S c2)) ")
        (dint msz)
        (DStr " (inline ")
        cnm
        (DStr ") ")
        (d_args nl)
        (DStr
          " m) Option ((case None (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
        lst
        (DStr "))) refl)) (case Some (oc")
        (dint b)
        (DStr
          ") (chain (steps ((rewrite (hyp 0) lr both true ()))) (case-on oc")
        (dint b)
        (DStr " IOut ((case INorm (ec")
        (dint b)
        (DStr " mc")
        (dint b)
        (DStr
          ") (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
        cst
        (DStr "))) ")
        (mxc_exit
          (d_args nl)
          (dcat3 (DStr "ec") (dint b) (DStr ""))
          (dcat3 (DStr "mc") (dint b) (DStr ""))
          0
          nl
          (dcat3 (DStr "ec") (dint b) (DStr ""))
          cont
          (DStr "il_slen")
          cst
          (dcat3 (DStr "ec") (dint b) (DStr "_"))
          (dcat3 (DStr "rc") (dint b) (DStr "_")))
        (DStr
          ")) (case ITrap (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
        lst
        (DStr "))) refl))))))))")))))

;; one loop-leg block after the pre-walk respells: the walk compute,
;; the fuel reshapes, the worker citation, the shared-iwhile case-on
;; shell, and the exposure with the leaf continuation
(fn mxx_lhead
  ((nm (List Int))
   (nl Int)
   (msz Int)
   (gi Int)
   (kg Int)
   (d Int)
   (xm Int)
   (yi Int)
   (q Int)
   (zlen Int)
   (aw Int)
   (bw Int)
   (locdoc Doc)
   (memdoc Doc)
   (pst Doc)
   (cst Doc)
   (cont Doc))
  Doc
  (let ((kd (dcat3 (DStr "(int_of_nat ") (dint kg) (DStr ")"))))
    (let ((sm (- (- xm aw) kg)) (si (- (- yi bw) kg)))
      (dconc
        (list
          (DStr "(have hkw")
          (dint d)
          (DStr " (= (mod ")
          kd
          (DStr " 18446744073709551616) ")
          kd
          (DStr ") (rewrite-with (lemma sqm_wid64_")
          (DStr nm)
          (DStr ") lr lhs ((inst x ")
          kd
          (DStr
            ")) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (steps ((rewrite (premise hi")
          (dint kg)
          (DStr
            ") lr lhs true ()) (compute lhs)) refl)) refl)) (steps ((rewrite (premise hkw")
          (dint d)
          (DStr ") lr lhs true ()))) (have hf")
          (dint d)
          (DStr "i (= ")
          (mxx_tw yi (DStr "c2"))
          (DStr " (S^ ")
          (dint bw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " ")
          (mxx_tw si (DStr "c2"))
          (DStr "))) (steps ((compute both)) refl)) (have hf")
          (dint d)
          (DStr "m (= ")
          (mxx_tw xm (DStr "c"))
          (DStr " (S^ ")
          (dint aw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " ")
          (mxx_tw sm (DStr "c"))
          (DStr
            "))) (steps ((compute both)) refl)) (steps ((rewrite (premise hf")
          (dint d)
          (DStr "i) lr rhs true ()) (rewrite (premise hf")
          (dint d)
          (DStr "m) lr lhs true ()))) (rewrite-with (lemma sqxw_")
          (DStr nm)
          (DStr "_l")
          (dint d)
          (DStr ") lr lhs ((inst c2 ")
          (mxx_tw si (DStr "c2"))
          (DStr ")) ((steps ((rewrite (premise hi")
          (dint kg)
          (DStr
            ") lr lhs true ()) (compute lhs)) refl))) (case-on (iwhile (S^ ")
          (dint bw)
          (DStr " (lg_fuel ")
          (dint kg)
          (DStr " ")
          (mxx_tw si (DStr "c2"))
          (DStr ")) ")
          (dint msz)
          (DStr " (ILoc ")
          (dint gi)
          (DStr ") (inline gb_")
          (DStr nm)
          (DStr "_l")
          (dint d)
          (DStr "_i) ")
          locdoc
          (DStr " ")
          memdoc
          (DStr
            ") Option ((case None (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
          cst
          (DStr "))) refl)) (case Some (o")
          (dint d)
          (DStr
            ") (chain (steps ((rewrite (hyp 0) lr both true ()))) (case-on o")
          (dint d)
          (DStr " IOut ((case INorm (lc")
          (dint d)
          (DStr " mm")
          (dint d)
          (DStr ") (chain (steps ((rewrite (hyp 0) lr both true ()))) (have hc")
          (dint d)
          (DStr "i (= (lg_fuel ")
          (dint kg)
          (DStr " ")
          (mxx_tw si (DStr "c2"))
          (DStr ") ")
          (mxx_tw (+ si kg) (DStr "c2"))
          (DStr ") (steps ((compute both)) refl)) (have hc")
          (dint d)
          (DStr "m (= (lg_fuel ")
          (dint kg)
          (DStr " ")
          (mxx_tw sm (DStr "c"))
          (DStr ") ")
          (mxx_tw (+ sm kg) (DStr "c"))
          (DStr ") (steps ((compute both)) refl)) (steps ((rewrite (premise hc")
          (dint d)
          (DStr "i) lr both true ()) (rewrite (premise hc")
          (dint d)
          (DStr "m) lr both true ()) (compute both ")
          cst
          (DStr "))) ")
          cont
          (DStr
            ")) (case ITrap (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
          cst
          (DStr "))) refl))))))))"))))))

;; --- branch legs (IF-1c) ---------------------------------------------------
;; A branch has NO seal on either side (ix_cjoin seals flat-flat
;; neighbors only), so its arm dirt rides out unspellable and no
;; sub-lemma factoring exists on this target (the V2-7 finding): the
;; branch walks INLINE in its chain lemma, the loop-leg precedent.
;; ONE case-on of the shared raw-operand comparison scrutinee -- both
;; machines stick on the same inner cmp term, walked at the LEG'S
;; IN-FLIGHT state -- and each polarity arm carries its own tail text
;; (arm guards, worker cite, exposure) to the SAME cite targets.
;; Towers are ARM-INDEPENDENT on both sides (both machines hand
;; continuations the same reservoir -- depth budgets, not step
;; counts), so the chain arithmetic carries over with the branch
;; counted as 1 machine element / 1 imp statement, and joins bind by
;; MATCHING: the next boundary's za binder absorbs the arms'
;; different RAX trees, its fuel binder any machine surplus.
;; Blueprint: examples/sqbx_probe.shard.

(fn gsl_len ((gs (List GSplit))) Int
  (measure (struct gs))
  (match gs
    (Nil 0)
    ((Cons _ t) (+ 1 (gsl_len t)))))

(fn mxx_hasbr ((segs (List MxPc))) Bool
  (measure (struct segs))
  (match segs
    (Nil False)
    ((Cons pc t)
     (match pc
       ((MxPB _ _ _ _ _ _ _) True)
       (_ (mxx_hasbr t))))))

(fn mxx_nbr ((segs (List MxPc))) Int
  (measure (struct segs))
  (match segs
    (Nil 0)
    ((Cons pc t)
     (match pc
       ((MxPB _ _ _ _ _ _ _) (+ 1 (mxx_nbr t)))
       (_ (mxx_nbr t))))))

;; decompose a branch leg's pieces: ([A?] branch [B?])
(fn mxx_brtail ((segs (List MxPc))) (Option (List IStmt))
  (match segs
    (Nil (Some Nil))
    ((Cons pc t)
     (match pc
       ((MxPS b2 _)
        (match t
          (Nil (Some b2))
          (_ None)))
       (_ None)))))

(fn mxx_brparts2 ((segs (List MxPc))) (Option (Pair IStmt (List IStmt)))
  (match segs
    (Nil None)
    ((Cons pc t)
     (match pc
       ((MxPB bs _ _ _ _ _ _)
        (match (mxx_brtail t)
          (None None)
          ((Some b2) (Some (Pair bs b2)))))
       (_ None)))))

(fn mxx_brparts ((segs (List MxPc)))
  (Option (Pair (List IStmt) (Pair IStmt (List IStmt))))
  (match segs
    (Nil None)
    ((Cons pc t)
     (match pc
       ((MxPS a _)
        (match (mxx_brparts2 t)
          (None None)
          ((Some (Pair bs b2)) (Some (Pair a (Pair bs b2))))))
       ((MxPB bs _ _ _ _ _ _)
        (match (mxx_brtail t)
          (None None)
          ((Some b2) (Some (Pair Nil (Pair bs b2))))))
       (_ None)))))

;; the leg-grammar fences (v1 scope, note-grade): one branch per
;; unsealed span; a branch leg ends at a loop or the terminal seal,
;; never at a mid-flat seal point
(fn mxx_legck ((legs (List (Pair (List MxPc) (Option MxPc)))))
  (Option (List Int))
  (measure (struct legs))
  (match legs
    (Nil None)
    ((Cons (Pair segs olp) rest)
     (if (lt 1 (mxx_nbr segs))
       (Some "adjacent branches share an unsealed span (named growth)")
     (if (mxx_hasbr segs)
       (match olp
         ((Some _) (mxx_legck rest))
         (None
           (match rest
             (Nil (mxx_legck rest))
             (_
               (Some
                 "branch leg ending at a mid-flat seal point (named growth)")))))
       (mxx_legck rest))))))

;; one branch leg's chain-lemma body: walk the entry segment, case-on
;; the shared scrutinee, then per polarity arm walk the arm + tail
;; inline to the leg's target (worker cite + exposure + next-boundary
;; cite for loop legs; ground for the terminal leg). The arm tails
;; are the SAME text except for the walked locals/memory.
(fn mxx_bleg
  ((nm (List Int))
   (nl Int)
   (msz Int)
   (parts (Pair (List IStmt) (Pair IStmt (List IStmt))))
   (olp (Option MxPc))
   (li (Option MxXLi))
   (headdoc Doc)
   (opener Doc)
   (fm Int)
   (gm Int)
   (w Int)
   (tn Int)
   (b Int)
   (d Int)
   (pst Doc)
   (cst Doc)
   (lst Doc)
   (lastp Bool))
  Doc
  (match parts
    ((Pair aSt (Pair bs bSt))
     (match bs
       ((IIf cnd tb eb)
        (match cnd
          ((IBin _ o ca cb)
           (match
             (lw_stmts
               (+ (isz_stmts aSt) 2)
               True
               msz
               aSt
               (st_params nl)
               (FVar (quote m)))
             ((LSRf _) (DStr ""))
             ((LSOk gsA stA memA)
              (match (lw_exp True msz ca stA memA)
                ((LXRf _) (DStr ""))
                ((LXOk va _)
                 (match (lw_exp True msz cb stA memA)
                   ((LXRf _) (DStr ""))
                   ((LXOk vb _)
                    (match (lw_stmts (+ (isz_stmts tb) 2) True msz tb stA memA)
                      ((LSRf _) (DStr ""))
                      ((LSOk gsT stT memT)
                       (match
                         (lw_stmts (+ (isz_stmts eb) 2) True msz eb stA memA)
                         ((LSRf _) (DStr ""))
                         ((LSOk gsE stE memE)
                          (match olp
                            (None
                              ;; terminal branch leg: both arms walk to
                              ;; ground through the terminal seal
                              (match
                                (lw_stmts
                                  (+ (isz_stmts bSt) 2)
                                  True
                                  msz
                                  bSt
                                  stT
                                  memT)
                                ((LSRf _) (DStr ""))
                                ((LSOk gsBT _ _)
                                 (match
                                   (lw_stmts
                                     (+ (isz_stmts bSt) 2)
                                     True
                                     msz
                                     bSt
                                     stE
                                     memE)
                                   ((LSRf _) (DStr ""))
                                   ((LSOk gsBE _ _)
                                    (let
                                      ((prefix (gs_dedup Nil gsA))
                                       (sufT (gs_dedup Nil (gs_app gsT gsBT)))
                                       (sufE (gs_dedup Nil (gs_app gsE gsBE)))
                                       (ground
                                         (DStr
                                           "(steps ((compute both (stop lg_fuel int_of_nat)))) refl")))
                                      (dconc
                                        (list
                                          headdoc
                                          opener
                                          (DStr "(steps ((compute both ")
                                          pst
                                          (DStr "))) ")
                                          (mxx_spine
                                            prefix
                                            1
                                            msz
                                            pst
                                            lst
                                            (dconc
                                              (list
                                                (DStr "(case-on ")
                                                (pr_e (sc2 (op_sym o) va vb))
                                                (DStr
                                                  " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
                                                pst
                                                (DStr "))) ")
                                                (mxx_spine
                                                  sufT
                                                  (+ 1 (gsl_len prefix))
                                                  msz
                                                  pst
                                                  lst
                                                  ground)
                                                (DStr
                                                  ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
                                                pst
                                                (DStr "))) ")
                                                (mxx_spine
                                                  sufE
                                                  (+ 1 (gsl_len prefix))
                                                  msz
                                                  pst
                                                  lst
                                                  ground)
                                                (DStr "))))"))))
                                          (DStr "))")
                                          (DStr (nl))
                                          (DStr (nl))))))))))
                            ((Some pc)
                             (match pc
                               ((MxPL gi kg lbody _ _ _ csets)
                                (match li
                                  (None (DStr ""))
                                  ((Some (MkMxXLi zlen _ wcode _ _ _))
                                   (let
                                     ((q (mxc_clen csets))
                                      (bw (+ (gcost lbody) 5))
                                      (tailSt
                                        (isapp2 bSt (mxx_csetstmts csets))))
                                     (match
                                       (lw_stmts
                                         (+ (isz_stmts tailSt) 2)
                                         True
                                         msz
                                         tailSt
                                         stT
                                         memT)
                                       ((LSRf _) (DStr ""))
                                       ((LSOk gsBT lcT memBT)
                                        (match
                                          (lw_stmts
                                            (+ (isz_stmts tailSt) 2)
                                            True
                                            msz
                                            tailSt
                                            stE
                                            memE)
                                          ((LSRf _) (DStr ""))
                                          ((LSOk gsBE lcE memBE)
                                           (let
                                             ((xm (- (- fm (+ w (+ q zlen))) 4))
                                              (yi (- (- gm (+ tn q)) 2))
                                              (kd
                                                (dcat3
                                                  (DStr "(int_of_nat ")
                                                  (dint kg)
                                                  (DStr ")"))))
                                             (let
                                               ((locdocT (mxx_locdoc lcT gi kd))
                                                (locdocE (mxx_locdoc lcE gi kd))
                                                (memdocT (pr_e memBT))
                                                (memdocE (pr_e memBE))
                                                (cont
                                                  (if lastp
                                                    (DStr
                                                      "(steps ((compute both (stop lg_fuel int_of_nat)))) refl")
                                                    (mxx_cite nm (+ b 1) cst)))
                                                (respell
                                                  (dconc
                                                    (list
                                                      (mx_ladder kg)
                                                      (DStr "(have hxk")
                                                      (dint d)
                                                      (DStr " (= (XMovRI ")
                                                      (mxx_regnm gi)
                                                      (DStr " ")
                                                      kd
                                                      (DStr ") (XMovRI ")
                                                      (mxx_regnm gi)
                                                      (DStr " ")
                                                      (dint kg)
                                                      (DStr
                                                        ")) (steps ((rewrite (premise hi")
                                                      (dint kg)
                                                      (DStr
                                                        ") lr lhs true ())) refl)) (steps ((rewrite (premise hxk")
                                                      (dint d)
                                                      (DStr
                                                        ") rl lhs false ()))) (have hik")
                                                      (dint d)
                                                      (DStr " (= (ISet ")
                                                      (dint gi)
                                                      (DStr " (IConst ")
                                                      kd
                                                      (DStr ")) (ISet ")
                                                      (dint gi)
                                                      (DStr " (IConst ")
                                                      (dint kg)
                                                      (DStr
                                                        "))) (steps ((rewrite (premise hi")
                                                      (dint kg)
                                                      (DStr
                                                        ") lr lhs true ())) refl)) (steps ((rewrite (premise hik")
                                                      (dint d)
                                                      (DStr
                                                        ") rl rhs false ()))) ")))))
                                               (let
                                                 ((prefix (gs_dedup Nil gsA))
                                                  (sufT
                                                    (gs_dedup
                                                      Nil
                                                      (gs_app gsT gsBT)))
                                                  (sufE
                                                    (gs_dedup
                                                      Nil
                                                      (gs_app gsE gsBE)))
                                                  (lheadT
                                                    (mxx_lhead
                                                      nm
                                                      nl
                                                      msz
                                                      gi
                                                      kg
                                                      (+ d 1)
                                                      xm
                                                      yi
                                                      q
                                                      zlen
                                                      (+ (tcost wcode) 2)
                                                      bw
                                                      locdocT
                                                      memdocT
                                                      pst
                                                      cst
                                                      (mxc_exit
                                                        locdocT
                                                        (dcat3
                                                          (DStr "lc")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        (dcat3
                                                          (DStr "mm")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        0
                                                        nl
                                                        (dcat3
                                                          (DStr "lc")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        cont
                                                        (DStr "il_wlen")
                                                        cst
                                                        (dcat3
                                                          (DStr "e")
                                                          (dint (+ d 1))
                                                          (DStr "_"))
                                                        (dcat3
                                                          (DStr "r")
                                                          (dint (+ d 1))
                                                          (DStr "_")))))
                                                  (lheadE
                                                    (mxx_lhead
                                                      nm
                                                      nl
                                                      msz
                                                      gi
                                                      kg
                                                      (+ d 1)
                                                      xm
                                                      yi
                                                      q
                                                      zlen
                                                      (+ (tcost wcode) 2)
                                                      bw
                                                      locdocE
                                                      memdocE
                                                      pst
                                                      cst
                                                      (mxc_exit
                                                        locdocE
                                                        (dcat3
                                                          (DStr "lc")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        (dcat3
                                                          (DStr "mm")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        0
                                                        nl
                                                        (dcat3
                                                          (DStr "lc")
                                                          (dint (+ d 1))
                                                          (DStr ""))
                                                        cont
                                                        (DStr "il_wlen")
                                                        cst
                                                        (dcat3
                                                          (DStr "e")
                                                          (dint (+ d 1))
                                                          (DStr "_"))
                                                        (dcat3
                                                          (DStr "r")
                                                          (dint (+ d 1))
                                                          (DStr "_"))))))
                                                 (dconc
                                                   (list
                                                     headdoc
                                                     opener
                                                     respell
                                                     (DStr
                                                       "(steps ((compute both ")
                                                     pst
                                                     (DStr "))) ")
                                                     (mxx_spine
                                                       prefix
                                                       1
                                                       msz
                                                       pst
                                                       lst
                                                       (dconc
                                                         (list
                                                           (DStr "(case-on ")
                                                           (pr_e
                                                             (sc2
                                                               (op_sym o)
                                                               va
                                                               vb))
                                                           (DStr
                                                             " Bool ((case True (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
                                                           pst
                                                           (DStr "))) ")
                                                           (mxx_spine
                                                             sufT
                                                             (+
                                                               1
                                                               (gsl_len prefix))
                                                             msz
                                                             pst
                                                             lst
                                                             lheadT)
                                                           (DStr
                                                             ")) (case False (chain (steps ((rewrite (hyp 0) lr both true ()) (compute both ")
                                                           pst
                                                           (DStr "))) ")
                                                           (mxx_spine
                                                             sufE
                                                             (+
                                                               1
                                                               (gsl_len prefix))
                                                             msz
                                                             pst
                                                             lst
                                                             lheadE)
                                                           (DStr "))))"))))
                                                     (DStr "))")
                                                     (DStr (nl))
                                                     (DStr (nl)))))))))))))))
                               (_ (DStr ""))))))))))))))))
          (_ (DStr ""))))
       (_ (DStr ""))))))

;; the chain driver over legs, deepest-first
(fn mxx_lems
  ((legs (List (Pair (List MxPc) (Option MxPc))))
   (lis (List MxXLi))
   (msls (List (Pair (List Expr) (List Expr))))
   (brpre (List Int))
   (nm (List Int))
   (nl Int)
   (msz Int)
   (fm Int)
   (gm Int)
   (b Int)
   (d Int)
   (nr Int)
   (fsa Bool)
   (fsb Bool)
   (fsc Bool))
  Doc
  (measure (struct legs))
  (match legs
    (Nil (DStr ""))
    ((Cons (Pair segs olp) rest)
     (let
       ((pst (mxx_pstop nm nr))
        (cst (mxx_cstop nm nr))
        (lst (mxx_lstop nm nr))
        (nmdoc
          (if (int_eq b 0) (dcat3 (DStr brpre) (DStr nm) (DStr ""))
          (dconc (list (DStr "cmp_x_") (DStr nm) (DStr "_b") (dint b)))))
        (codex
          (if (int_eq b 0)
            (dconc (list (DStr "(inline gb_") (DStr nm) (DStr "_x)")))
            (dconc (list (DStr "(") (mxc_rnm nm b "_x") (DStr ")")))))
        (codei
          (if (int_eq b 0)
            (dconc (list (DStr "(inline gb_") (DStr nm) (DStr "_i)")))
            (dconc (list (DStr "(") (mxc_rnm nm b "_i") (DStr ")")))))
        (opener
          (if (int_eq b 0) (DStr "")
          (dconc
            (list
              (DStr "(steps ((unfold ")
              (mxc_rnm nm b "_x")
              (DStr " lhs) (reduce lhs) (unfold ")
              (mxc_rnm nm b "_i")
              (DStr " rhs) (reduce rhs))) ")))))
        (mopener
          (if (int_eq b 0) (DStr "")
          (dconc
            (list
              (DStr "(steps ((unfold ")
              (mxc_rnm nm b "_x")
              (DStr " lhs) (reduce lhs))) ")))))
        (zad (if fsa (DStr "za") (DStr "0")))
        (zbd (if fsb (DStr "zb") (DStr "0")))
        (zcd (if fsc (DStr "zc") (DStr "0"))))
       (let
         ((headregs
            (if (int_eq b 0)
              (mxx_regs
                nl
                (- 0 1)
                (DStr "")
                (DStr "x")
                Nil
                (DStr "0")
                (DStr "0")
                (DStr "0"))
              (mxx_regs nl (- 0 1) (DStr "") (DStr "x") Nil zad zbd zcd))))
         (let
           ((headdoc
              (dconc
                (list
                  (DStr "(claim ")
                  nmdoc
                  (DStr " (goal (")
                  (d_binds_go
                    nl
                    (dcat3
                      (if (int_eq b 0) (DStr "")
                      (dconc
                        (list
                          (if fsa (DStr "(za Int) ") (DStr ""))
                          (if fsb (DStr "(zb Int) ") (DStr ""))
                          (if fsc (DStr "(zc Int) ") (DStr "")))))
                      (DStr "(m Mem) (c Nat) (c2 Nat) (restfs (List XFunc))")
                      (DStr "")))
                  (DStr ") () (= (xeval_seq (S^ ")
                  (dint fm)
                  (DStr " c) (MkXModule restfs 0 ")
                  (dint msz)
                  (DStr ") ")
                  codex
                  (DStr " ")
                  headregs
                  (DStr " m) (ix_sout (istmts (S^ ")
                  (dint gm)
                  (DStr " c2) ")
                  (dint msz)
                  (DStr " ")
                  codei
                  (DStr " ")
                  (d_args nl)
                  (DStr " m)))) (chain ")))))
           (match (mxx_segm segs msls)
             ((Pair (Pair w (Pair z tn)) msls2)
              (if (mxx_hasbr segs)
                ;; --- a branch leg (IF-1c): the branch walks inline;
                ;; loop-tailed legs keep the loop path's arithmetic
                ;; verbatim (the branch = 1 element / 1 statement),
                ;; terminal legs walk to ground per arm. Mid legs are
                ;; fenced upstream (mxx_legck).
                (match (mxx_brparts segs)
                  (None (DStr ""))
                  ((Some parts)
                   (match olp
                     (None
                       (match rest
                         (Nil
                           (mxx_bleg nm nl msz parts None None headdoc opener fm
                             gm w tn b d pst cst lst True))
                         (_ (DStr ""))))
                     ((Some pc)
                      (match pc
                        ((MxPL _ _ _ _ _ _ csets)
                         (match lis
                           (Nil (DStr ""))
                           ((Cons li lrest)
                            (match li
                              ((MkMxXLi zlen _ _ _ _ _)
                               (let
                                 ((q (mxc_clen csets))
                                  (lastp
                                    (match rest
                                      (Nil True)
                                      ((Cons _ _) False))))
                                 (let
                                   ((fm2 (- (- fm (+ w (+ (+ q zlen) 1))) 0))
                                    (gm2 (- gm (+ tn (+ q 1)))))
                                   (DCat
                                     (mxx_lems
                                       rest
                                       lrest
                                       msls2
                                       brpre
                                       nm
                                       nl
                                       msz
                                       fm2
                                       gm2
                                       (+ b 1)
                                       (+ d 1)
                                       nr
                                       fsa
                                       fsb
                                       fsc)
                                     (mxx_bleg
                                       nm
                                       nl
                                       msz
                                       parts
                                       (Some pc)
                                       (Some li)
                                       headdoc
                                       opener
                                       fm
                                       gm
                                       w
                                       tn
                                       b
                                       d
                                       pst
                                       cst
                                       lst
                                       lastp)))))))))
                        (_ (DStr "")))))))
                (match olp
                  (None
                    ;; a flat leg. Last: walk the chunk (+ the terminal
                    ;; seal) to ground. Mid (V2-8): the chunk ends at its
                    ;; seal point -- emit the open-tail sub-lemma (the
                    ;; machine walk lives THERE) and compose by ist_seam +
                    ;; il_slen; the machine side of the chain lemma is
                    ;; never walked, so it parks at the folded rest-fn
                    ;; call for the next boundary's cite.
                    (let
                      ((lastp
                         (match rest
                           (Nil True)
                           ((Cons _ _) False))))
                      (match
                        (lw_stmts
                          (+ (isz_stmts (mxx_segstmts segs)) 2)
                          True
                          msz
                          (mxx_segstmts segs)
                          (st_params nl)
                          (FVar (quote m)))
                        ((LSRf _) (DStr ""))
                        ((LSOk gs _ _)
                         (if lastp
                           (dconc
                             (list
                               headdoc
                               opener
                               (DStr "(steps ((compute both ")
                               pst
                               (DStr "))) ")
                               (mxx_spine
                                 (gs_dedup Nil gs)
                                 1
                                 msz
                                 pst
                                 lst
                                 (DStr
                                   "(steps ((compute both (stop lg_fuel int_of_nat)))) refl"))
                               (DStr "))")
                               (DStr (nl))
                               (DStr (nl))))
                           (dconc
                             (list
                               (mxx_lems
                                 rest
                                 lis
                                 msls2
                                 brpre
                                 nm
                                 nl
                                 msz
                                 (- fm (+ w z))
                                 (- gm tn)
                                 (+ b 1)
                                 d
                                 nr
                                 fsa
                                 fsb
                                 fsc)
                               (mxx_seg1
                                 nm
                                 b
                                 nl
                                 msz
                                 tn
                                 segs
                                 msls
                                 (gs_dedup Nil gs))
                               headdoc
                               mopener
                               (mxx_cstep
                                 nm
                                 b
                                 nl
                                 msz
                                 tn
                                 gm
                                 cst
                                 lst
                                 (mxx_cite nm (+ b 1) cst))
                               (DStr "))")
                               (DStr (nl))
                               (DStr (nl)))))))))
                  ((Some pc)
                   (match pc
                     ((MxPL gi kg lbody _ _ _ csets)
                      (match lis
                        (Nil (DStr ""))
                        ((Cons (MkMxXLi zlen _ wcode _ _ _) lrest)
                         (let
                           ((q (mxc_clen csets))
                            (bw (+ (gcost lbody) 5))
                            (wstmts
                              (isapp2 (mxx_segstmts segs) (mxx_csetstmts csets))))
                           (match
                             (lw_stmts
                               (+ (isz_stmts wstmts) 2)
                               True
                               msz
                               wstmts
                               (st_params nl)
                               (FVar (quote m)))
                             ((LSRf _) (DStr ""))
                             ((LSOk gs postlc postmem)
                              (let
                                ((fm2 (- (- fm (+ w (+ (+ q zlen) 1))) 0))
                                 (gm2 (- gm (+ tn (+ q 1))))
                                 (xm (- (- fm (+ w (+ q zlen))) 4))
                                 (yi (- (- gm (+ tn q)) 2))
                                 (kd
                                   (dcat3
                                     (DStr "(int_of_nat ")
                                     (dint kg)
                                     (DStr ")"))))
                                (let
                                  ((locdoc (mxx_locdoc postlc gi kd))
                                   (memdoc (pr_e postmem))
                                   (lastp
                                     (match rest
                                       (Nil True)
                                       ((Cons _ _) False))))
                                  (let
                                    ((cont
                                       (if lastp
                                         (DStr
                                           "(steps ((compute both (stop lg_fuel int_of_nat)))) refl")
                                         (mxx_cite nm (+ b 1) cst)))
                                     (respell
                                       (dconc
                                         (list
                                           (mx_ladder kg)
                                           (DStr "(have hxk")
                                           (dint d)
                                           (DStr " (= (XMovRI ")
                                           (mxx_regnm gi)
                                           (DStr " ")
                                           kd
                                           (DStr ") (XMovRI ")
                                           (mxx_regnm gi)
                                           (DStr " ")
                                           (dint kg)
                                           (DStr
                                             ")) (steps ((rewrite (premise hi")
                                           (dint kg)
                                           (DStr
                                             ") lr lhs true ())) refl)) (steps ((rewrite (premise hxk")
                                           (dint d)
                                           (DStr
                                             ") rl lhs false ()))) (have hik")
                                           (dint d)
                                           (DStr " (= (ISet ")
                                           (dint gi)
                                           (DStr " (IConst ")
                                           kd
                                           (DStr ")) (ISet ")
                                           (dint gi)
                                           (DStr " (IConst ")
                                           (dint kg)
                                           (DStr
                                             "))) (steps ((rewrite (premise hi")
                                           (dint kg)
                                           (DStr
                                             ") lr lhs true ())) refl)) (steps ((rewrite (premise hik")
                                           (dint d)
                                           (DStr ") rl rhs false ()))) ")))))
                                    (dconc
                                      (list
                                        (mxx_lems
                                          rest
                                          lrest
                                          msls2
                                          brpre
                                          nm
                                          nl
                                          msz
                                          (- fm2 0)
                                          gm2
                                          (+ b 1)
                                          (+ d 1)
                                          nr
                                          fsa
                                          fsb
                                          fsc)
                                        headdoc
                                        opener
                                        respell
                                        (DStr "(steps ((compute both ")
                                        pst
                                        (DStr "))) ")
                                        (mxx_spine
                                          (gs_dedup Nil gs)
                                          1
                                          msz
                                          pst
                                          lst
                                          (mxx_lhead
                                            nm
                                            nl
                                            msz
                                            gi
                                            kg
                                            (+ d 1)
                                            xm
                                            yi
                                            q
                                            zlen
                                            (+ (tcost wcode) 2)
                                            bw
                                            locdoc
                                            memdoc
                                            pst
                                            cst
                                            (mxc_exit
                                              locdoc
                                              (dcat3
                                                (DStr "lc")
                                                (dint (+ d 1))
                                                (DStr ""))
                                              (dcat3
                                                (DStr "mm")
                                                (dint (+ d 1))
                                                (DStr ""))
                                              0
                                              nl
                                              (dcat3
                                                (DStr "lc")
                                                (dint (+ d 1))
                                                (DStr ""))
                                              cont
                                              (DStr "il_wlen")
                                              cst
                                              (dcat3
                                                (DStr "e")
                                                (dint (+ d 1))
                                                (DStr "_"))
                                              (dcat3
                                                (DStr "r")
                                                (dint (+ d 1))
                                                (DStr "_")))))
                                        (DStr "))")
                                        (DStr (nl))
                                        (DStr (nl)))))))))))))
                     (_ (DStr ""))))))))))))))


(type SqxR (SqxOk Doc) (SqxNote (List Int)) (SqxErr (List Int)))

;; the x86 mixed-tier emission: wid twins, per-loop workers, rest fns
;; cut at chunk seals and loop exits, the boundary chain
(fn sqx_emit
  ((brpre (List Int))
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (bodyE Expr)
   (instrsE Expr)
   (evs (List MxEv))
   (mtr Module))
  SqxR
  (match (lpe_spine instrsE)
    (None (SqxErr "translated spine shape (internal)"))
    ((Some els)
     (match (lpe_spine bodyE)
       (None (SqxErr "imp spine shape (internal)"))
       ((Some ssE)
        (match (mxx_mach els 0)
          (None (SqxErr "machine loop scan (internal)"))
          ((Some machs)
           (match (mxx_lis machs mtr)
             (None (SqxErr "machine loop info (internal)"))
             ((Some lis)
              (match (mxx_dirty mtr instrsE 0)
                (None (SqxErr "seal scan (internal)"))
                ((Some fsa)
                 (match (mxx_dirty mtr instrsE 10)
                   (None (SqxErr "seal scan (internal)"))
                   ((Some fsb)
                    (match (mxx_dirty mtr instrsE 11)
                      (None (SqxErr "seal scan (internal)"))
                      ((Some fsc)
                       (let
                         ((nm (pin_nm pin))
                          (nl
                            (+ (ikn (ikparams_of ifn)) (ikn (ikextra_of ifn))))
                          (ss (ibody_of ifn)))
                         (match
                           (mxc_slice
                             (+ (isz_top ss) 2)
                             True
                             msz
                             ss
                             ssE
                             Nil
                             Nil
                             nl
                             (ikapp (ikparams_of ifn) (ikextra_of ifn)))
                           ((MxPRf m) (SqxErr m))
                           ((MxPOk pcs)
                            (match (mxx_chunks pcs mtr)
                              (None
                                (SqxErr
                                  "per-segment translation invoke (internal)"))
                              ((Some msls)
                               (let ((legs (mxx_legs pcs)))
                                 (match (mxx_legck legs)
                                   ((Some why) (SqxNote why))
                                   (None
                                     (match (mxx_ag legs lis msls 0 0 0 0)
                                       ((Pair aa gg)
                                        (match (mxxw_all evs lis nm nl msz 1)
                                          ((EErr m) (SqxErr m))
                                          ((EOk workers)
                                           (SqxOk
                                             (dconc
                                               (list
                                                 (mxx_rests legs lis msls nm ssE
                                                   els 0 0 0)
                                                 (mx_wid nm)
                                                 (mx_wid64 nm)
                                                 workers
                                                 (mxx_lems
                                                   legs
                                                   lis
                                                   msls
                                                   brpre
                                                   nm
                                                   nl
                                                   msz
                                                   aa
                                                   gg
                                                   0
                                                   0
                                                   (- (mxx_nlg legs) 1)
                                                   fsa
                                                   fsb
                                                   fsc)))))))))))))))))))))))))))))))

;; --- per-pin emission ------------------------------------------------------------

;; a refused pin's honest record in the output
(fn d_refused ((pin Symbol) (tname (List Int))) Doc
  (dconc
    (list
      (DStr ";; ")
      (dsym pin)
      (DStr ": no ")
      (DStr tname)
      (DStr " leg (the translator refused this pin)")
      (DStr (nl))
      (DStr (nl)))))

(type ERes (EOk Doc) (EErr (List Int)))

(fn last_e ((es (List Expr))) (Option Expr)
  (measure (struct es))
  (match es
    (Nil None)
    ((Cons h Nil) (Some h))
    ((Cons _ t) (last_e t))))

;; the pin's bridge: fuel from the two cost walks, premises and proof
;; from the symbolic walk; a v1-scope decline leaves the tie standing
;; with an honest note
;; any IWhile anywhere in a body (nested branches included)
(fn has_while ((ss (List IStmt))) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons s t)
     (match s
       ((IWhile _ _) True)
       ((IIf _ tb eb)
        (if (has_while tb) True (if (has_while eb) True (has_while t))))
       (_ (has_while t))))))

;; the wrapper's declared memsize, discovered by RUNNING the wrapper
;; on the pin value (never assumed)
(fn wrap_msz ((msrc Module) (wrap Symbol) (gv Expr)) (Option Int)
  (match (invoke msrc wrap (Cons gv Nil))
    (None None)
    ((Some pv)
     (match (ec_is pv (quote MkIProg))
       (None None)
       ((Some pargs)
        (match pargs
          ((Cons _ (Cons ms Nil)) (e_int ms))
          (_ None)))))))

(fn gen_bridge
  ((brpre (List Int))
   (trans (List Int))
   (x86 Bool)
   (wrapnm (List Int))
   (msz Int)
   (pin Symbol)
   (ifn IFn)
   (tv Expr))
  ERes
  (match (ec_is tv (quote Some))
    (None (EErr "translated value is not Some (internal)"))
    ((Some sargs)
     (match sargs
       ((Cons fexp Nil)
        (match fexp
          ((Ctor _ margs)
           (match (last_e margs)
             (None (EErr "translated func has no body (internal)"))
             ((Some instrs)
              (match
                (se_stmts
                  (+ (isz_stmts (ibody_of ifn)) 2)
                  x86
                  (ibody_of ifn)
                  (iresult_of ifn)
                  (st_binit (ikparams_of ifn) (ikextra_of ifn)))
                ((SRf why) (EOk (d_note pin why)))
                ((SROk bt)
                 (EOk
                   (d_bridge
                     brpre
                     (pin_nm pin)
                     pin
                     x86
                     trans
                     wrapnm
                     (ikn (ikparams_of ifn))
                     (+ (tcost instrs) 4)
                     (+ (gcost (ibody_of ifn)) 4)
                     msz
                     (d_kinds (ikparams_of ifn))
                     bt)))))))
          (_ (EErr "translated value shape (internal)"))))
       (_ (EErr "translated value shape (internal)"))))))

;; one pin, one target: evaluate the pin in the SOURCE module, reify,
;; and dispatch by tier -- loops to the loop tier, memful straight-line
;; bodies to the statement tier, memless straight-line to the scalar
;; (fn-grain) tier
(fn gen_pin
  ((msrc Module)
   (mtr Module)
   (trans Symbol)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (wrap (Option Symbol))
   (pin Symbol))
  ERes
  (match (invoke msrc pin Nil)
    (None (EErr (append_int "pin does not evaluate: " (chars_of_sym pin))))
    ((Some gv)
     (match (rf_fn gv)
       (None (EErr (append_int "pin does not reify: " (chars_of_sym pin))))
       ((Some ifn)
        (if (has_while (ibody_of ifn))
          (match (lp_pieces ifn)
            ((Some _)
             (gen_fn_pin msrc mtr trans tiepre brpre tname x86 wrap pin gv ifn))
            (None (sqm_pin msrc mtr tiepre brpre tname x86 wrap pin gv ifn)))
        (if (has_mem (ibody_of ifn))
          (if (has_brtop (ibody_of ifn))
            (sqm_pin msrc mtr tiepre brpre tname x86 wrap pin gv ifn)
            (sq_pin msrc mtr tiepre brpre tname x86 wrap pin gv ifn))
          (gen_fn_pin msrc mtr trans tiepre brpre tname x86 wrap pin gv ifn))))))))

;; a TOP-LEVEL branch (statement position, outside any loop): routes a
;; memful body to the mixed tier, whose piece grammar owns branches --
;; the statement tier's walk stays straight-line-only
(fn has_brtop ((ss (List IStmt))) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons s t)
     (match s
       ((IIf _ _ _) True)
       (_ (has_brtop t))))))

;; the fn-grain flow (loop + scalar tiers): run the FUNCTION translator
;; on the pin value, spell the tie, then the per-tier bridge
(fn gen_fn_pin
  ((msrc Module)
   (mtr Module)
   (trans Symbol)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (wrap (Option Symbol))
   (pin Symbol)
   (gv Expr)
   (ifn IFn))
  ERes
  (match (invoke mtr trans (Cons gv Nil))
    (None (EErr (append_int "translator invoke failed on " (chars_of_sym pin))))
    ((Some tv)
     (match (ec_is tv (quote None))
       ((Some _) (EOk (d_refused pin tname)))
       (None
         (match (spl_e tv)
           ((SpRErr msg) (EErr msg))
           ((SpROk vdoc)
            (if (has_while (ibody_of ifn))
              (match wrap
                (None
                  (EOk
                    (DCat
                      (d_tie tiepre (pin_nm pin) (chars_of_sym trans) pin vdoc)
                      (d_note pin "loop pin without an IProg wrapper"))))
                ((Some wnm)
                 (match (wrap_msz msrc wnm gv)
                   (None (EErr "wrapper does not yield an IProg (internal)"))
                   ((Some msz)
                    (match
                      (lp_gen
                        brpre
                        (chars_of_sym trans)
                        x86
                        (chars_of_sym wnm)
                        msz
                        pin
                        ifn
                        gv
                        tv)
                      ((EErr msg) (EErr msg))
                      ((EOk ldoc)
                       (EOk
                         (DCat
                           (d_tie
                             tiepre
                             (pin_nm pin)
                             (chars_of_sym trans)
                             pin
                             vdoc)
                           ldoc))))))))
              (match wrap
                (None
                  (EOk
                    (d_tie tiepre (pin_nm pin) (chars_of_sym trans) pin vdoc)))
                ((Some wnm)
                 (match (wrap_msz msrc wnm gv)
                   (None (EErr "wrapper does not yield an IProg (internal)"))
                   ((Some msz)
                    (match
                      (gen_bridge
                        brpre
                        (chars_of_sym trans)
                        x86
                        (chars_of_sym wnm)
                        msz
                        pin
                        ifn
                        tv)
                      ((EErr msg) (EErr msg))
                      ((EOk bdoc)
                       (EOk
                         (DCat
                           (d_tie
                             tiepre
                             (pin_nm pin)
                             (chars_of_sym trans)
                             pin
                             vdoc)
                           bdoc))))))))))))))))

(fn gen_pins
  ((msrc Module)
   (mtr Module)
   (trans Symbol)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (wrap (Option Symbol))
   (pins (List Symbol)))
  ERes
  (measure (struct pins))
  (match pins
    (Nil (EOk (DStr "")))
    ((Cons p rest)
     (match (gen_pin msrc mtr trans tiepre brpre tname x86 wrap p)
       ((EErr msg) (EErr msg))
       ((EOk d)
        (match (gen_pins msrc mtr trans tiepre brpre tname x86 wrap rest)
          ((EErr msg) (EErr msg))
          ((EOk ds) (EOk (DCat d ds)))))))))

;; does any pin carry a loop? (the header's loop-tier import gate)
(fn any_loop ((msrc Module) (pins (List Symbol))) Bool
  (measure (struct pins))
  (match pins
    (Nil False)
    ((Cons p rest)
     (match (invoke msrc p Nil)
       (None (any_loop msrc rest))
       ((Some gv)
        (match (rf_fn gv)
          (None (any_loop msrc rest))
          ((Some ifn) (if (has_while (ibody_of ifn)) True (any_loop msrc rest)))))))))

;; does any pin touch memory? (the header's std/mem import gate — the
;; statement tier's Mem binders need the type in scope)
(fn any_mem ((msrc Module) (pins (List Symbol))) Bool
  (measure (struct pins))
  (match pins
    (Nil False)
    ((Cons p rest)
     (match (invoke msrc p Nil)
       (None (any_mem msrc rest))
       ((Some gv)
        (match (rf_fn gv)
          (None (any_mem msrc rest))
          ((Some ifn) (if (has_mem (ibody_of ifn)) True (any_mem msrc rest)))))))))

;; --- pin enumeration --------------------------------------------------------------

;; nullary fns returning IFn, defined in the target file's own module
(fn is_ifn_ty ((t Type)) Bool
  (match t
    ((TCon q args)
     (match args
       (Nil (sym_eq (qn_name q) (quote IFn)))
       ((Cons _ _) False)))
    (_ False)))

(fn pins_of ((fns (List FnDef)) (mp (List Symbol))) (List Symbol)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((FnDef q ts rt _)
        (match ts
          ((Cons _ _) (pins_of rest mp))
          (Nil
            (if (is_ifn_ty rt)
              (if (sym_path_eq (qn_mod q) mp)
                (Cons (qn_name q) (pins_of rest mp))
                (pins_of rest mp))
              (pins_of rest mp)))))))))

;; --- the generated file header -----------------------------------------------------

;; imports: kernel stdlib + the pin SOURCE (sibling by basename) + the
;; imp model + the target model + the translator, repo-root relative
;; through the OUT path's updots climb
(fn ig_header
  ((src (List Int))
   (tname (List Int))
   (out (List Int))
   (modelpath (List Int))
   (transpath (List Int))
   (loopful Bool)
   (memful Bool)
   (x86 Bool))
  Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/impgen (the imp -> ISA leg generator, docs/IMP.md V2-5) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate:")
      (DStr (nl))
      (DStr ";;;   bin/shard_eval run tools/impgen/impgen.shard ")
      (DStr src)
      (DStr " ")
      (DStr tname)
      (DStr " ")
      (DStr out)
      (DStr ", then shardfmt.")
      (DStr (nl))
      (dimport (append_int (updots out) "kernel/stdlib.shard"))
      (dimport (basename_go src Nil))
      (dimport (append_int (updots out) "models/imp/imp.shard"))
      (dimport (append_int (updots out) modelpath))
      (dimport (append_int (updots out) transpath))
      (if loopful
        (dconc
          (list
            (dimport (append_int (updots out) "std/nat.shard"))
            (dimport (append_int (updots out) "std/mem"))
            (dimport (append_int (updots out) "models/wasm/loopkit.shard"))
            (if x86
              (dimport (append_int (updots out) "models/x86/loopkit.shard"))
              (DStr ""))))
      (if memful (dimport (append_int (updots out) "std/mem"))
      (DStr "")))
      (use_of src)
      (use_of "models/imp/imp.shard")
      (use_of modelpath)
      (use_of transpath)
      (if loopful
        (dconc
          (list
            (use_of "std/nat.shard")
            (use_of "std/mem")
            (use_of "models/wasm/loopkit.shard")
            (if x86 (use_of "models/x86/loopkit.shard") (DStr ""))))
      (if memful (use_of "std/mem")
      (DStr "")))
      (DStr (nl)))))

(fn ig_fail ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn ig_refuse ((msg (List Int)) (w World)) World
  (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))

(fn ig_emit
  ((src (List Int))
   (tname (List Int))
   (out (List Int))
   (trans Symbol)
   (modelpath (List Int))
   (transpath (List Int))
   (tiepre (List Int))
   (brpre (List Int))
   (x86 Bool)
   (w World))
  World
  (match (load_run_module src w)
    ((Pair None w1) (ig_fail (append_int "cannot load " src) w1))
    ((Pair (Some msrc) w1)
     (match (load_run_module transpath w1)
       ((Pair None w2) (ig_fail (append_int "cannot load " transpath) w2))
       ((Pair (Some mtr) w2)
        (match msrc
          ((Module _ fns _ _ _)
           (match (pins_of fns (split_slash (until_dot src) Nil))
             (Nil (ig_refuse (append_int "no imp pins in " src) w2))
             ((Cons p prest)
              (match
                (gen_pins
                  msrc
                  mtr
                  trans
                  tiepre
                  brpre
                  tname
                  x86
                  (find_wrap fns (split_slash (until_dot src) Nil))
                  (Cons p prest))
                ((EErr msg) (ig_refuse msg w2))
                ((EOk body)
                 (match
                   (write_file
                     out
                     (doc_flat
                       (DCat
                         (ig_header
                           src
                           tname
                           out
                           modelpath
                           transpath
                           (any_loop msrc (Cons p prest))
                           (any_mem msrc (Cons p prest))
                           x86)
                         body)
                       Nil)
                     w2)
                   ((Pair ok w3)
                    (if ok
                      (exit
                        0
                        (write (append_int "wrote " (append_int out (nl))) w3))
                      (ig_fail (append_int "cannot write " out) w3)))))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons src (Cons tname (Cons out Nil)))
        (if (ceq tname "wasm")
          (ig_emit
            src
            tname
            out
            (quote imp2w_fn)
            "models/wasm/wasm.shard"
            "models/imp/to_wasm.shard"
            "tie_"
            "imp_w_"
            False
            w1)
        (if (ceq tname "x86")
          (ig_emit
            src
            tname
            out
            (quote imp2x_fn)
            "models/x86/x86.shard"
            "models/imp/to_x86.shard"
            "tie_x_"
            "imp_x_"
            True
            w1)
          (ig_refuse (append_int "unknown target " tname) w1))))
       (_ (ig_refuse "usage: impgen SRC TARGET OUT" w1))))))
