;;; tools/impgen/impgen.shard — the imp ⊑ ISA LEG GENERATOR (docs/IMP.md
;;; rung I2d): for every imp pin in the target file, emit the per-target
;;; tie and bridge certs that the I1 hand era priced — the translator's
;;; output as a ground literal (TIE), and the machine ⊑ imp alignment
;;; with the width story priced in that machine's modulus (BRIDGE).
;;;
;;; THE FACTORING: the translators (models/imp/to_wasm, to_x86) are
;;; ordinary in-language values — this tool LOADS them through the
;;; kernel (meta/invoke) and RUNS them on the pin values; nothing about
;;; translation is re-derived here. What the generator owns is the
;;; CERT TEXT: the premise discipline (wrap pairs per exact-op node in
;;; evaluation order, divisor guards, condition-relative premises per
;;; branch — the §6j hygiene), the fuel towers (depth bounds computed
;;; structurally, + slack), and the proof skeletons (compute both;
;;; wrap-event haves citing wrap32_id/wrap64_id; case-on trees
;;; mirroring the pin's branch structure — the shapes stabilized by
;;; examples/imp_wasm_bridge.shard and examples/imp_x86_bridge.shard).
;;;
;;; PIN CONVENTION: a pin is a NULLARY fn returning IFn, defined in the
;;; target file (it_<nm>_fn naming gives claims tie_<nm> / imp_w_<nm>;
;;; other names pass through whole). Bridges additionally need the
;;; one-fn program wrapper `it_prog` in the target file; without it the
;;; tool emits ties only. A pin the target's translator REFUSES (width
;;; mismatch, off-pattern shape) gets a comment line, not an error —
;;; refusal-by-None is the translator's contract and the leg simply
;;; does not exist on that target.
;;;
;;; V1 SCOPE (the scalar/branch tier): straight-line expressions and
;;; IIf trees with comparison-headed conditions. Premise-carrying ops
;;; under one condition level (the imp_w_sel shape); deeper nesting is
;;; supported only premise-free (the imp_w_clamp2 shape). Conditional
;;; divisor guards and straight-line IStore/ILoad REFUSE loudly.
;;;
;;; LOOP TIER (docs/IMP.md I2d-2): a pin whose body is exactly one
;;; counting IWhile over (ILoc c) in the two hand-validated shapes
;;;   fill: [ (IStore (ILoc p) (ILoc v)) ; p += 1 ; c -= 1 ]
;;;   sum:  [ (ISet a (a + ILoad (ILoc p))) ; p += 1 ; c -= 1 ]
;;; (distinct param locals, no extras, params <= 6, result IConst/ILoc)
;;; gets a WORKER — the machine loop aligned with iwhile by induction
;;; on the counter, the iww_*/ixw_* shapes, discharging against the
;;; target loopkit — and, when the source file provides the joints, a
;;; DENOTATION BRIDGE (call_fn_mem = icall_mem). The bridge's joints,
;;; all discovered, none re-derived: the IFn -> IProg wrapper (by
;;; signature), the imp-side meeting lemma imw_<stem> (by a textual scan
;;; of the source — the claim roster is check-only; <stem> tries the
;;; pin stem, then the stem past its first underscore), and the guard lemma im_lt visible from the
;;; source. CONTRACT with the meeting lemma: it is stated at
;;; (S^ (gcost body + 5) (lg_fuel k c)) with premises
;;; [le 0 ptr; le (+ ptr (int_of_nat k)) 65536] in that order, and the
;;; wrapper's memsize is the loopkit's 65536 (checked; a different
;;; size declines the bridge). Loops outside the family decline to
;;; tie-plus-note, the scalar tier's honest-fence discipline.
;;;
;;; RUN IT:  bin/shard_eval run tools/impgen/impgen.shard SRC TARGET OUT.raw
;;;          (TARGET = wasm | x86; OUT must be a sibling of SRC), then
;;;          shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../meta/doc")
(import "../../meta/spell")
(import "../../meta/invoke")
(import "../../models/imp/imp.shard")

(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader read_file))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term Ctor))
(use (:: kernel term Call))
(use (:: kernel term IntLit))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term qn_mod))
(use (:: kernel term qname_eq))
(use (:: kernel term sym_path_eq))
(use (:: kernel term expr_eq))
(use (:: kernel term append_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module TCon))
(use (:: meta doc *))
(use (:: meta spell *))
(use (:: meta invoke *))
(use (:: models imp imp *))

;; --- small utils ----------------------------------------------------------------

(fn ceq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        ((Cons _ _) False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (ceq xs ys) False))))))

(fn imax ((a Int) (b Int)) Int (if (lt a b) b a))

(fn starts_with ((pre (List Int)) (s (List Int))) Bool
  (measure (struct pre))
  (match pre
    (Nil True)
    ((Cons p pt)
     (match s
       (Nil False)
       ((Cons c ct) (if (int_eq p c) (starts_with pt ct) False))))))

(fn drop_len ((pre (List Int)) (s (List Int))) (List Int)
  (measure (struct pre))
  (match pre
    (Nil s)
    ((Cons _ pt)
     (match s
       (Nil Nil)
       ((Cons _ ct) (drop_len pt ct))))))

(fn strip_pre ((pre (List Int)) (s (List Int))) (List Int)
  (if (starts_with pre s) (drop_len pre s) s))

(fn rev_int_go ((s (List Int)) (acc (List Int))) (List Int)
  (measure (struct s))
  (match s
    (Nil acc)
    ((Cons h t) (rev_int_go t (Cons h acc)))))

(fn rev_int ((s (List Int))) (List Int) (rev_int_go s Nil))

(fn strip_suf ((suf (List Int)) (s (List Int))) (List Int)
  (rev_int (strip_pre (rev_int suf) (rev_int s))))

;; pin fn name -> claim stem: it_<nm>_fn -> <nm> (either half optional)
(fn pin_nm ((s Symbol)) (List Int)
  (strip_suf "_fn" (strip_pre "it_" (chars_of_sym s))))

;; --- ground-value views (evm results are Ctor/IntLit trees) ---------------------

;; a ctor node with this LOCAL name (basename match: the values come
;; from the loaded models, whose paths are canonical — within the imp /
;; wasm / x86 / prelude vocabulary basenames are unambiguous)
(fn ec_is ((e Expr) (s Symbol)) (Option (List Expr))
  (match e
    ((Ctor q args) (if (sym_eq (qn_name q) s) (Some args) None))
    (_ None)))

(fn e_int ((e Expr)) (Option Int)
  (match e
    ((IntLit n) (Some n))
    (_ None)))

;; --- the spell table: harvest ctor qnames from the value itself -----------------
;; Every ctor spells as its basename; the generated file's glob uses
;; make each basename resolvable. Harvesting from the value (instead of
;; hand-spelled paths) keeps the table honest by construction. One
;; structural walk (ctor args descend inline — subterms of the head).

(fn tbl_has ((t (List (Pair QName Symbol))) (q QName)) Bool
  (measure (struct t))
  (match t
    (Nil False)
    ((Cons (Pair k _) rest) (if (qname_eq k q) True (tbl_has rest q)))))

(fn harvest_l ((es (List Expr)) (t (List (Pair QName Symbol))))
  (List (Pair QName Symbol))
  (measure (struct es))
  (match es
    (Nil t)
    ((Cons h rest)
     (match h
       ((Ctor q args)
        (harvest_l
          rest
          (harvest_l args (if (tbl_has t q) t (Cons (Pair q (qn_name q)) t)))))
       (_ (harvest_l rest t))))))

(fn harvest ((e Expr)) (List (Pair QName Symbol)) (harvest_l (Cons e Nil) Nil))

;; --- reify: ground imp value Exprs -> native models/imp values ------------------
;; Loud None on anything outside the imp grammar (an internal error:
;; the pin evaluated to a non-IFn or the grammar grew without this
;; tool growing with it).

(fn rf_op ((e Expr)) (Option IOp)
  (match e
    ((Ctor q _)
     (if (sym_eq (qn_name q) (quote IAdd)) (Some IAdd)
     (if (sym_eq (qn_name q) (quote ISub)) (Some ISub)
     (if (sym_eq (qn_name q) (quote IMul)) (Some IMul)
     (if (sym_eq (qn_name q) (quote IDiv)) (Some IDiv)
     (if (sym_eq (qn_name q) (quote IRem)) (Some IRem)
     (if (sym_eq (qn_name q) (quote IAnd)) (Some IAnd)
     (if (sym_eq (qn_name q) (quote IOr)) (Some IOr)
     (if (sym_eq (qn_name q) (quote IXor)) (Some IXor)
     (if (sym_eq (qn_name q) (quote IShl)) (Some IShl)
     (if (sym_eq (qn_name q) (quote IShr)) (Some IShr)
     (if (sym_eq (qn_name q) (quote IEq)) (Some IEq)
     (if (sym_eq (qn_name q) (quote ILt)) (Some ILt)
     (if (sym_eq (qn_name q) (quote ILe)) (Some ILe)
     None))))))))))))))
    (_ None)))

(fn rf_exp ((e Expr)) (Option IExp)
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote IConst))
       (match args
         ((Cons a Nil)
          (match (e_int a)
            (None None)
            ((Some n) (Some (IConst n)))))
         (_ None))
     (if (sym_eq (qn_name q) (quote ILoc))
       (match args
         ((Cons a Nil)
          (match (e_int a)
            (None None)
            ((Some n) (Some (ILoc n)))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IBin))
       (match args
         ((Cons o (Cons a (Cons b Nil)))
          (match (rf_op o)
            (None None)
            ((Some io)
             (match (rf_exp a)
               (None None)
               ((Some ia)
                (match (rf_exp b)
                  (None None)
                  ((Some ib) (Some (IBin io ia ib)))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IWrap))
       (match args
         ((Cons w (Cons a Nil))
          (match (e_int w)
            (None None)
            ((Some wn)
             (match (rf_exp a)
               (None None)
               ((Some ia) (Some (IWrap wn ia)))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote IRotr))
       (match args
         ((Cons w (Cons a (Cons k Nil)))
          (match (e_int w)
            (None None)
            ((Some wn)
             (match (rf_exp a)
               (None None)
               ((Some ia)
                (match (rf_exp k)
                  (None None)
                  ((Some ik) (Some (IRotr wn ia ik)))))))))
         (_ None))
     (if (sym_eq (qn_name q) (quote ILoad))
       (match args
         ((Cons a Nil)
          (match (rf_exp a)
            (None None)
            ((Some ia) (Some (ILoad ia)))))
         (_ None))
       None)))))))
    (_ None)))

;; one structural walk (the ix_stmts shape: statement dispatch inlined
;; at the Cons head, so the recursion is a single (struct e) descent)
(fn rf_stmts ((e Expr)) (Option (List IStmt))
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) (Some Nil)
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match (rf_stmts t)
            (None None)
            ((Some rest)
             (match h
               ((Ctor hq hargs)
                (if (sym_eq (qn_name hq) (quote ISet))
                  (match hargs
                    ((Cons i (Cons ex Nil))
                     (match (e_int i)
                       (None None)
                       ((Some n)
                        (match (rf_exp ex)
                          (None None)
                          ((Some ie) (Some (Cons (ISet n ie) rest)))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IStore))
                  (match hargs
                    ((Cons a (Cons v Nil))
                     (match (rf_exp a)
                       (None None)
                       ((Some ia)
                        (match (rf_exp v)
                          (None None)
                          ((Some iv) (Some (Cons (IStore ia iv) rest)))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IIf))
                  (match hargs
                    ((Cons c (Cons tb (Cons eb Nil)))
                     (match (rf_exp c)
                       (None None)
                       ((Some ic)
                        (match (rf_stmts tb)
                          (None None)
                          ((Some itb)
                           (match (rf_stmts eb)
                             (None None)
                             ((Some ieb)
                              (Some (Cons (IIf ic itb ieb) rest)))))))))
                    (_ None))
                (if (sym_eq (qn_name hq) (quote IWhile))
                  (match hargs
                    ((Cons c (Cons b Nil))
                     (match (rf_exp c)
                       (None None)
                       ((Some ic)
                        (match (rf_stmts b)
                          (None None)
                          ((Some ib) (Some (Cons (IWhile ic ib) rest)))))))
                    (_ None))
                  None)))))
               (_ None)))))
         (_ None))
       None)))
    (_ None)))

(fn rf_fn ((e Expr)) (Option IFn)
  (match (ec_is e (quote MkIFn))
    (None None)
    ((Some args)
     (match args
       ((Cons p (Cons x (Cons b (Cons r Nil))))
        (match (e_int p)
          (None None)
          ((Some pn)
           (match (e_int x)
             (None None)
             ((Some xn)
              (match (rf_stmts b)
                (None None)
                ((Some bs)
                 (match (rf_exp r)
                   (None None)
                   ((Some re) (Some (MkIFn pn xn bs re)))))))))))
       (_ None)))))

;; --- fuel: depth bounds, computed structurally, + slack -------------------------

;; imp side: istmts/istmt/iwhile burn one per ENTRY and hand the same
;; reservoir to head and tail — fuel bounds depth, so cost is a max
;; (upper bounds, validated by the kernel check of the emitted certs)
(fn gcost ((ss (List IStmt))) Int
  (measure (struct ss))
  (match ss
    (Nil 1)
    ((Cons s t)
     (match s
       ((ISet _ _) (+ 1 (imax 2 (gcost t))))
       ((IStore _ _) (+ 1 (imax 2 (gcost t))))
       ((IIf _ tb eb)
        (+ 1 (imax (+ 2 (imax (gcost tb) (gcost eb))) (gcost t))))
       ((IWhile _ _) (+ 1 (imax 2 (gcost t))))))))

;; machine side: the same depth discipline over the TRANSLATED ground
;; value (a Cons spine; Block/Loop/XBlock/XLoop nest) — one generic
;; walk, nesting recognized by basename
(fn tc_nest ((s Symbol)) Bool
  (if (sym_eq s (quote Block)) True
  (if (sym_eq s (quote Loop)) True
  (if (sym_eq s (quote XBlock)) True
  (sym_eq s (quote XLoop))))))

(fn tcost ((e Expr)) Int
  (measure (struct e))
  (match e
    ((Ctor q args)
     (if (sym_eq (qn_name q) (quote Nil)) 1
     (if (sym_eq (qn_name q) (quote Cons))
       (match args
         ((Cons h (Cons t Nil))
          (match h
            ((Ctor hq hargs)
             (if (tc_nest (qn_name hq))
               (match hargs
                 ((Cons b Nil) (+ 1 (imax (+ 2 (tcost b)) (tcost t))))
                 (_ (+ 1 (imax 2 (tcost t)))))
               (+ 1 (imax 2 (tcost t)))))
            (_ (+ 1 (imax 2 (tcost t))))))
         (_ 1))
       1)))
    (_ 1)))

;; --- the symbolic walk: events in evaluation order -------------------------------
;; The bridge's premise discipline: walk the pin's statements and result
;; with a SYMBOLIC local state (params = x0…, extras = 0), emitting one
;; event per machine-width residue in evaluation order — a wrap pair per
;; exact-op node whose value survives symbolically (ground subtrees
;; compute away, so they carry no residue), a divisor guard per
;; symbolic divisor. Branches fork the walk (continuation folded into
;; both arms); an event's PATH prefixes its premises condition-relative
;; (the §6j hygiene, meta/spell's cond_wrap).

(fn pq ((s Symbol)) QName (QName Nil s))

(fn sc2 ((s Symbol) (a Expr) (b Expr)) Expr (Call (pq s) (Cons a (Cons b Nil))))

;; value-position spelling of an exact op (comparisons refuse upstream)
(fn op_sym ((o IOp)) Symbol
  (match o
    (IAdd (quote +))
    (ISub (quote -))
    (IMul (quote *))
    (IDiv (quote ediv))
    (IRem (quote mod))
    (IAnd (quote band))
    (IOr (quote bor))
    (IXor (quote bxor))
    (IShl (quote bshl))
    (IShr (quote bshr))
    (IEq (quote int_eq))
    (ILt (quote lt))
    (ILe (quote le))))

(fn is_cmp ((o IOp)) Bool
  (match o
    (IEq True)
    (ILt True)
    (ILe True)
    (_ False)))

(fn is_wrapop ((o IOp)) Bool
  (match o
    (IAdd True)
    (ISub True)
    (IMul True)
    (_ False)))

(fn has_fv ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((FVar _) True)
    ((Call _ args) (has_fv_l args))
    ((Ctor _ args) (has_fv_l args))
    (_ False)))

(fn has_fv_l ((es (List Expr))) Bool
  (measure (struct es))
  (match es
    (Nil False)
    ((Cons h t) (if (has_fv h) True (has_fv_l t)))))

;; symbolic locals: params x0…, extras literal 0 (count down, prepend —
;; the last prepended binder is x0, so the order comes out ascending)
(fn st_params_go ((p Int) (acc (List Expr))) (List Expr)
  (measure p (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt p 1) acc (st_params_go (- p 1) (Cons (FVar (xsym (- p 1))) acc))))

(fn st_params ((p Int)) (List Expr) (st_params_go p Nil))

(fn st_zeros ((x Int)) (List Expr)
  (measure x (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt x 1) Nil (Cons (IntLit 0) (st_zeros (- x 1)))))

(fn st_app ((a (List Expr)) (b (List Expr))) (List Expr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (st_app t b)))))

(fn st_init ((p Int) (x Int)) (List Expr) (st_app (st_params p) (st_zeros x)))

(fn st_get ((st (List Expr)) (i Int)) (Option Expr)
  (measure (struct st))
  (match st
    (Nil None)
    ((Cons h t) (if (int_eq i 0) (Some h) (st_get t (- i 1))))))

(fn st_set ((st (List Expr)) (i Int) (v Expr)) (Option (List Expr))
  (measure (struct st))
  (match st
    (Nil None)
    ((Cons h t)
     (if (int_eq i 0) (Some (Cons v t))
     (match (st_set t (- i 1) v)
       (None None)
       ((Some t2) (Some (Cons h t2))))))))

;; events: a wrap pair or a divisor guard, condition-relative via path
(type EvK (KWrap) (KGuard))

(record Ev (evk EvK) (evp (List (Pair Expr Bool))) (evx Expr))

;; expression walk result: symbolic value + events (eval order), or the
;; v1-scope refusal reason
(type XR (XOk Expr (List Ev)) (XRf (List Int)))

(fn ev_app ((a (List Ev)) (b (List Ev))) (List Ev)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (ev_app t b)))))

;; the walk: md = the target modulus; x86 flags the rotation premise
;; and div refusal mirror; absorb suppresses the ROOT op's wrap event
;; (an IWrap of native width directly above it prices the containment)
(fn se_exp
  ((x86 Bool)
   (md Int)
   (e IExp)
   (st (List Expr))
   (pth (List (Pair Expr Bool)))
   (absorb Bool))
  XR
  (measure (struct e))
  (match e
    ((IConst n)
     (if (le 0 n)
       (if (lt n md) (XOk (IntLit n) Nil)
       (XRf "constant outside the machine width"))
       (XRf "negative constant (the machine wraps it)")))
    ((ILoc i)
     (match (st_get st i)
       (None (XRf "local index out of range"))
       ((Some v) (XOk v Nil))))
    ((IBin o a b)
     (if (is_cmp o) (XRf "comparison in value position (v1)")
     (match (se_exp x86 md a st pth False)
       ((XRf m) (XRf m))
       ((XOk va evs_a)
        (match (se_exp x86 md b st pth False)
          ((XRf m) (XRf m))
          ((XOk vb evs_b)
           (match o
             (IDiv
               (if x86 (XRf "division (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (XOk (sc2 (quote ediv) va vb) (ev_app evs_a evs_b)))
                 (_
                   (XOk
                     (sc2 (quote ediv) va vb)
                     (ev_app
                       evs_a
                       (ev_app evs_b (Cons (MkEv KGuard pth vb) Nil))))))))
             (IRem
               (if x86 (XRf "remainder (to_x86 refuses; unreachable)")
               (match vb
                 ((IntLit _) (XOk (sc2 (quote mod) va vb) (ev_app evs_a evs_b)))
                 (_
                   (XOk
                     (sc2 (quote mod) va vb)
                     (ev_app
                       evs_a
                       (ev_app evs_b (Cons (MkEv KGuard pth vb) Nil))))))))
             (IShl
               (match vb
                 ((IntLit k)
                  (if (le 0 k)
                    (if (lt k (if x86 64 32))
                      (if absorb (XOk (sc2 (quote bshl) va (IntLit k)) evs_a)
                      (if (has_fv va)
                        (XOk
                          (sc2 (quote bshl) va (IntLit k))
                          (ev_app
                            evs_a
                            (Cons
                              (MkEv
                                KWrap
                                pth
                                (sc2 (quote bshl) va (IntLit k)))
                              Nil)))
                      (XOk (sc2 (quote bshl) va (IntLit k)) evs_a)))
                      (XRf "shift count at or past the machine count mask (v1)"))
                    (XRf "negative shift count")))
                 (_ (XRf "symbolic shift count (v1)"))))
             (IShr
               (match vb
                 ((IntLit k)
                  (if (le 0 k)
                    (if (lt k (if x86 64 32))
                      (XOk (sc2 (quote bshr) va (IntLit k)) evs_a)
                      (XRf "shift count at or past the machine count mask (v1)"))
                    (XRf "negative shift count")))
                 (_ (XRf "symbolic shift count (v1)"))))
             (_
               (if (is_wrapop o)
                 (if absorb (XOk (sc2 (op_sym o) va vb) (ev_app evs_a evs_b))
                 (if (has_fv (sc2 (op_sym o) va vb))
                   (XOk
                     (sc2 (op_sym o) va vb)
                     (ev_app
                       evs_a
                       (ev_app
                         evs_b
                         (Cons (MkEv KWrap pth (sc2 (op_sym o) va vb)) Nil))))
                 (XOk (sc2 (op_sym o) va vb) (ev_app evs_a evs_b))))
                 (XOk (sc2 (op_sym o) va vb) (ev_app evs_a evs_b)))))))))))
    ((IWrap w a)
     (if (int_eq w (if x86 64 32))
       (match (se_exp x86 md a st pth True)
         ((XRf m) (XRf m))
         ((XOk va evs) (XOk (sc2 (quote mod) va (IntLit md)) evs)))
       (XRf "off-width wrap (the translator refuses; unreachable)")))
    ((IRotr w a k)
     (if (int_eq w 32)
       (match k
         ((IConst kc)
          (match (se_exp x86 md a st pth False)
            ((XRf m) (XRf m))
            ((XOk va evs)
             (if x86
               (if (has_fv va)
                 (XOk
                   (rot_val va kc)
                   (ev_app
                     evs
                     (Cons
                       (MkEv
                         KWrap
                         pth
                         (sc2 (quote bshl) va (IntLit (- 32 (mod kc 32)))))
                       Nil)))
                 (XOk (rot_val va kc) evs))
               (XOk (rot_val va kc) evs)))))
         (_ (XRf "symbolic rotation count (v1)")))
       (XRf "off-width rotation (the translator refuses; unreachable)")))
    ((ILoad _) (XRf "memory (the loop/mem tier)"))))

;; the band-spelled rotation value (the machine residue's exact tree)
(fn rot_val ((va Expr) (kc Int)) Expr
  (sc2
    (quote band)
    (sc2
      (quote bor)
      (sc2 (quote bshr) va (IntLit (mod kc 32)))
      (sc2 (quote bshl) va (IntLit (- 32 (mod kc 32)))))
    (IntLit 4294967295)))

;; the branch tree the proof mirrors
(type BT (BTLeaf) (BTBr Expr BT BT))

;; statements walk result
(type SR (SROk BT (List Ev)) (SRf (List Int)))

;; total statement count (branch bodies included) — the walk's fuel
;; bound: continuation folding consumes each original statement at most
;; once along any one chain
(fn isz_stmts ((ss (List IStmt))) Int
  (measure (struct ss))
  (match ss
    (Nil 0)
    ((Cons s t)
     (match s
       ((ISet _ _) (+ 1 (isz_stmts t)))
       ((IStore _ _) (+ 1 (isz_stmts t)))
       ((IIf _ tb eb) (+ 1 (+ (isz_stmts tb) (+ (isz_stmts eb) (isz_stmts t)))))
       ((IWhile _ b) (+ 1 (+ (isz_stmts b) (isz_stmts t))))))))

;; statements + result, continuation folded into branch arms so every
;; leaf is a complete run; conditions must be comparison-headed and
;; event-free (the no-arith-in-conditions fence). Fueled: folding is
;; not structural, and the size bound above makes underflow unreachable
(fn se_stmts
  ((fuel Int)
   (x86 Bool)
   (md Int)
   (ss (List IStmt))
   (res IExp)
   (st (List Expr))
   (pth (List (Pair Expr Bool))))
  SR
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) (SRf "walk fuel underflow (internal)")
  (match ss
    (Nil
      (match (se_exp x86 md res st pth False)
        ((XRf m) (SRf m))
        ((XOk _ evs) (SROk BTLeaf evs))))
    ((Cons s t)
     (match s
       ((ISet i e)
        (match (se_exp x86 md e st pth False)
          ((XRf m) (SRf m))
          ((XOk v evs)
           (match (st_set st i v)
             (None (SRf "local index out of range"))
             ((Some st2)
              (match (se_stmts (- fuel 1) x86 md t res st2 pth)
                ((SRf m) (SRf m))
                ((SROk bt evs_t) (SROk bt (ev_app evs evs_t)))))))))
       ((IStore _ _) (SRf "memory (the loop/mem tier)"))
       ((IWhile _ _) (SRf "loop shape outside the counting-loop family (v1)"))
       ((IIf c tb eb)
        (match c
          ((IBin o a b)
           (if (is_cmp o)
             (match (se_exp x86 md a st pth False)
               ((XRf m) (SRf m))
               ((XOk va evs_a)
                (match evs_a
                  ((Cons _ _) (SRf "arith residue in a condition (v1)"))
                  (Nil
                    (match (se_exp x86 md b st pth False)
                      ((XRf m) (SRf m))
                      ((XOk vb evs_b)
                       (match evs_b
                         ((Cons _ _) (SRf "arith residue in a condition (v1)"))
                         (Nil
                           (match
                             (se_stmts
                               (- fuel 1)
                               x86
                               md
                               (stmt_app tb t)
                               res
                               st
                               (path_snoc pth (sc2 (op_sym o) va vb) True))
                             ((SRf m) (SRf m))
                             ((SROk btt evs_t)
                              (match
                                (se_stmts
                                  (- fuel 1)
                                  x86
                                  md
                                  (stmt_app eb t)
                                  res
                                  st
                                  (path_snoc pth (sc2 (op_sym o) va vb) False))
                                ((SRf m) (SRf m))
                                ((SROk btf evs_f)
                                 (SROk
                                   (BTBr (sc2 (op_sym o) va vb) btt btf)
                                   (ev_app evs_t evs_f))))))))))))))
             (SRf "non-comparison branch condition (v1)")))
          (_ (SRf "non-comparison branch condition (v1)")))))))))

(fn stmt_app ((a (List IStmt)) (b (List IStmt))) (List IStmt)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (stmt_app t b)))))

(fn path_snoc
  ((p (List (Pair Expr Bool))) (c Expr) (pol Bool))
  (List (Pair Expr Bool))
  (measure (struct p))
  (match p
    (Nil (Cons (Pair c pol) Nil))
    ((Cons h t) (Cons h (path_snoc t c pol)))))

;; --- event dedup and premise indexing ---------------------------------------------

(fn path_eq ((a (List (Pair Expr Bool))) (b (List (Pair Expr Bool)))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        ((Cons _ _) False)))
    ((Cons (Pair ca pa) ta)
     (match b
       (Nil False)
       ((Cons (Pair cb pb) tb)
        (if (expr_eq ca cb)
          (if (match pa
                (True (match pb (True True) (False False)))
                (False (match pb (True False) (False True))))
            (path_eq ta tb)
            False)
          False))))))

(fn evk_eq ((a EvK) (b EvK)) Bool
  (match a
    (KWrap (match b (KWrap True) (KGuard False)))
    (KGuard (match b (KWrap False) (KGuard True)))))

(fn ev_seen ((l (List Ev)) (e Ev)) Bool
  (measure (struct l))
  (match l
    (Nil False)
    ((Cons h t)
     (if (evk_eq (evk_of h) (evk_of e))
       (if (expr_eq (evx_of h) (evx_of e))
         (if (path_eq (evp_of h) (evp_of e)) True (ev_seen t e))
         (ev_seen t e))
       (ev_seen t e)))))

(fn ev_dedup_go ((l (List Ev)) (seen (List Ev))) (List Ev)
  (measure (struct l))
  (match l
    (Nil Nil)
    ((Cons h t)
     (if (ev_seen seen h) (ev_dedup_go t seen)
     (Cons h (ev_dedup_go t (Cons h seen)))))))

(fn ev_dedup ((l (List Ev))) (List Ev) (ev_dedup_go l Nil))

;; each event with its FIRST premise slot (wraps take two, guards one)
(fn ev_index ((l (List Ev)) (i Int)) (List (Pair Ev Int))
  (measure (struct l))
  (match l
    (Nil Nil)
    ((Cons h t)
     (Cons
       (Pair h i)
       (ev_index
         t
         (match (evk_of h)
           (KWrap (+ i 2))
           (KGuard (+ i 1))))))))

;; events whose path is exactly p
(fn evs_at
  ((l (List (Pair Ev Int))) (p (List (Pair Expr Bool))))
  (List (Pair Ev Int))
  (measure (struct l))
  (match l
    (Nil Nil)
    ((Cons (Pair e i) t)
     (if (path_eq (evp_of e) p)
       (Cons (Pair e i) (evs_at t p))
       (evs_at t p)))))

;; --- the tie claim ---------------------------------------------------------------

(fn d_tie
  ((tiepre (List Int)) (nm (List Int)) (trans (List Int)) (pin Symbol) (v Doc))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr tiepre)
      (DStr nm)
      (DStr " (goal () () (= (")
      (DStr trans)
      (DStr " (")
      (dsym pin)
      (DStr ")) ")
      v
      (DStr ")) (steps ((compute both)) refl))")
      (DStr (nl))
      (DStr (nl)))))

;; --- bridge emission ---------------------------------------------------------------

;; goal binders: (x0 Int) … then the two fuel tails
(fn d_binds_go ((n Int) (acc Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) acc
  (d_binds_go
    (- n 1)
    (DCat (dcat3 (DStr "(x") (dint (- n 1)) (DStr " Int) ")) acc))))

(fn d_binds ((n Int)) Doc (d_binds_go n (DStr "(c Nat) (c2 Nat)")))

;; call args: (list x0 x1 …), Nil when the pin takes no params
(fn d_args_go ((n Int) (acc Doc)) Doc
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) acc (d_args_go (- n 1) (dcat3 (DStr " x") (dint (- n 1)) acc))))

(fn d_args ((n Int)) Doc
  (if (lt n 1) (DStr "Nil")
  (dcat3 (DStr "(list") (d_args_go n (DStr "")) (DStr ")"))))

(fn d_lt_bound ((x Expr) (md Int)) Doc
  (dcat3 (dcat3 (DStr "(lt ") (pr_e x) (sp)) (dint md) (DStr ")")))

;; one premise: the bound condition-wrapped along the event's path
(fn d_prem_one ((p (List (Pair Expr Bool))) (bound Doc)) Doc
  (dcat3 (DStr "(= ") (cond_wrap p bound) (DStr " True)")))

(fn d_prems ((l (List (Pair Ev Int))) (md Int)) Doc
  (measure (struct l))
  (match l
    (Nil (DStr ""))
    ((Cons (Pair e _) t)
     (match (evk_of e)
       (KWrap
         (dcat3
           (dcat3
             (d_prem_one (evp_of e) (bnd_le0 (pr_e (evx_of e))))
             (sp)
             (d_prem_one (evp_of e) (d_lt_bound (evx_of e) md)))
           (sp)
           (d_prems t md)))
       (KGuard
         (dcat3
           (d_prem_one (evp_of e) (bnd_ge1 (pr_e (evx_of e))))
           (sp)
           (d_prems t md)))))))

;; the goal equation, per target
(fn d_lhs
  ((x86 Bool) (trans (List Int)) (pin Symbol) (ff Int) (args Doc))
  Doc
  (dconc
    (list
      (DStr (if x86 "(xcall_fn (S^ " "(call_fn (S^ "))
      (dint ff)
      (DStr " c) (")
      (DStr (if x86 "MkXModule (list (x_of (" "MkWModule (list (w_of ("))
      (DStr trans)
      (DStr " (")
      (dsym pin)
      (DStr (if x86 ")))) 0 0) 0 " ")))) 0) 0 "))
      args
      (DStr ")"))))

(fn d_rhs ((wrapnm (List Int)) (pin Symbol) (gg Int) (args Doc)) Doc
  (dconc
    (list
      (DStr "(icall (S^ ")
      (dint gg)
      (DStr " c2) (")
      (DStr wrapnm)
      (DStr " (")
      (dsym pin)
      (DStr ")) 0 ")
      args
      (DStr ")"))))

;; v1 discharge-scope fence: guards must be unconditional, wraps at
;; most one condition deep (the imp_w_sel shape)
(fn plen ((p (List (Pair Expr Bool)))) Int
  (measure (struct p))
  (match p
    (Nil 0)
    ((Cons _ t) (+ 1 (plen t)))))

(fn evs_ok ((l (List Ev))) (Option (List Int))
  (measure (struct l))
  (match l
    (Nil None)
    ((Cons h t)
     (match (evk_of h)
       (KGuard
         (match (evp_of h)
           (Nil (evs_ok t))
           ((Cons _ _) (Some "conditional divisor guard (v1)"))))
       (KWrap
         (if (lt 1 (plen (evp_of h)))
           (Some "width residue under nested branches (v1)")
           (evs_ok t)))))))

;; the polarity's hyp spelling
(fn d_pol ((pol Bool)) Doc (DStr (if pol "True" "False")))

;; discharge items for the events at one path; the have counter is
;; global across the claim (the hand files' p0/p1/w2 naming)
(fn emit_evs
  ((l (List (Pair Ev Int))) (md Int) (wlem (List Int)) (ctr Int))
  (Pair Doc Int)
  (measure (struct l))
  (match l
    (Nil (Pair (DStr "") ctr))
    ((Cons (Pair e i) t)
     (match (evk_of e)
       (KGuard
         (match (emit_evs t md wlem ctr)
           ((Pair rest c2)
            (Pair
              (dcat3
                (dcat3
                  (DStr "(steps ((rewrite (premise ")
                  (dint i)
                  (DStr ") lr both true ()) (compute both))) "))
                rest
                (DStr ""))
              c2))))
       (KWrap
         (match (evp_of e)
           (Nil
             (match (emit_evs t md wlem (+ ctr 1))
               ((Pair rest c2)
                (Pair
                  (DCat
                    (dconc
                      (list
                        (DStr "(have w")
                        (dint ctr)
                        (DStr " (= (mod ")
                        (pr_e (evx_of e))
                        (DStr " ")
                        (dint md)
                        (DStr ") ")
                        (pr_e (evx_of e))
                        (DStr ") (rewrite-with (lemma ")
                        (DStr wlem)
                        (DStr ") lr lhs ((inst x ")
                        (pr_e (evx_of e))
                        (DStr ")) ((steps ((rewrite (premise ")
                        (dint i)
                        (DStr ") lr lhs true ())) refl) (steps ((rewrite (premise ")
                        (dint (+ i 1))
                        (DStr ") lr lhs true ())) refl)) refl)) (steps ((rewrite (premise w")
                        (dint ctr)
                        (DStr ") lr lhs true ()))) ")))
                    rest)
                  c2))))
           ((Cons (Pair _ pol) _)
            (match (emit_evs t md wlem (+ ctr 3))
              ((Pair rest c2)
               (Pair
                 (DCat
                   (dconc
                     (list
                       (DStr "(have p")
                       (dint ctr)
                       (DStr " (= ")
                       (bnd_le0 (pr_e (evx_of e)))
                       (DStr " True) (chain (steps ((rewrite (premise ")
                       (dint i)
                       (DStr ") rl rhs true ()) (rewrite (hyp ")
                       (d_pol pol)
                       (DStr ") lr rhs true ()) (compute rhs))) refl)) ")
                       (DStr "(have p")
                       (dint (+ ctr 1))
                       (DStr " (= ")
                       (d_lt_bound (evx_of e) md)
                       (DStr " True) (chain (steps ((rewrite (premise ")
                       (dint (+ i 1))
                       (DStr ") rl rhs true ()) (rewrite (hyp ")
                       (d_pol pol)
                       (DStr ") lr rhs true ()) (compute rhs))) refl)) ")
                       (DStr "(have w")
                       (dint (+ ctr 2))
                       (DStr " (= (mod ")
                       (pr_e (evx_of e))
                       (DStr " ")
                       (dint md)
                       (DStr ") ")
                       (pr_e (evx_of e))
                       (DStr ") (rewrite-with (lemma ")
                       (DStr wlem)
                       (DStr ") lr lhs ((inst x ")
                       (pr_e (evx_of e))
                       (DStr ")) ((steps ((rewrite (premise p")
                       (dint ctr)
                       (DStr ") lr lhs true ())) refl) (steps ((rewrite (premise p")
                       (dint (+ ctr 1))
                       (DStr ") lr lhs true ())) refl)) refl)) ")
                       (DStr "(steps ((rewrite (premise w")
                       (dint (+ ctr 2))
                       (DStr ") lr lhs true ()))) ")))
                   rest)
                 c2))))))))))

;; the proof tree: per node, discharge this path's events, then either
;; close the leaf or case-on the branch condition (arms re-enter with
;; the hyp rewrite + compute, the hand files' arm template)
(fn emit_tree
  ((bt BT)
   (evl (List (Pair Ev Int)))
   (md Int)
   (wlem (List Int))
   (p (List (Pair Expr Bool)))
   (ctr Int))
  (Pair Doc Int)
  (measure (struct bt))
  (match (emit_evs (evs_at evl p) md wlem ctr)
    ((Pair items c1)
     (match bt
       (BTLeaf (Pair (DCat items (DStr "refl")) c1))
       ((BTBr c tb fb)
        (match (emit_tree tb evl md wlem (path_snoc p c True) c1)
          ((Pair tdoc c2)
           (match (emit_tree fb evl md wlem (path_snoc p c False) c2)
             ((Pair fdoc c3)
              (Pair
                (DCat
                  items
                  (dconc
                    (list
                      (DStr "(case-on ")
                      (pr_e c)
                      (DStr " Bool ((case True (chain (steps ((rewrite (hyp True) lr both true ()) (compute both))) ")
                      tdoc
                      (DStr ")) (case False (chain (steps ((rewrite (hyp False) lr both true ()) (compute both))) ")
                      fdoc
                      (DStr "))))"))))
                c3))))))))))

;; the whole bridge claim
(fn d_bridge
  ((brpre (List Int))
   (nm (List Int))
   (pin Symbol)
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (trans (List Int))
   (wrapnm (List Int))
   (nparams Int)
   (ff Int)
   (gg Int)
   (bt BT)
   (evl (List (Pair Ev Int))))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr brpre)
      (DStr nm)
      (DStr " (goal (")
      (d_binds nparams)
      (DStr ") (")
      (d_prems evl md)
      (DStr ") (= ")
      (d_lhs x86 trans pin ff (d_args nparams))
      (DStr " ")
      (d_rhs wrapnm pin gg (d_args nparams))
      (DStr ")) ")
      (match evl
        (Nil
          (match bt
            (BTLeaf (DStr "(steps ((compute both)) refl)"))
            ((BTBr _ _ _)
             (match (emit_tree bt evl md wlem Nil 0)
               ((Pair pdoc _)
                (dcat3 (DStr "(chain (steps ((compute both))) ") pdoc (DStr ")")))))))
        ((Cons _ _)
         (match (emit_tree bt evl md wlem Nil 0)
           ((Pair pdoc _)
            (dcat3 (DStr "(chain (steps ((compute both))) ") pdoc (DStr ")"))))))
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

;; a bridge the v1 walk declines: the tie stands alone, honestly noted
(fn d_note ((pin Symbol) (why (List Int))) Doc
  (dconc
    (list
      (DStr ";; ")
      (dsym pin)
      (DStr ": tie only (v1 bridge scope: ")
      (DStr why)
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

;; --- the loop tier (docs/IMP.md I2d-2) ---------------------------------------------
;; The counting-loop worker + denotation bridge, mechanizing the hand
;; iww_*/ixw_* induction template. Recognition is EXACT (the two
;; hand-validated statement sequences); everything else declines.

(type LRole (LRFill Int) (LRSum Int))

(record LShape (lsp Int) (lsc Int) (lsn Int) (lsrole LRole) (lsbs (List IStmt)))

(fn is_sum ((sh LShape)) Bool
  (match (lsrole_of sh)
    ((LRFill _) False)
    ((LRSum _) True)))

;; premise slots: lo(ptr) = 0 always; hi(ptr) = 1 (fill) / 2 (sum);
;; sum adds lo(acc) = 1 and hi(acc) = 3
(fn lp_hp ((sh LShape)) Int
  (match (lsrole_of sh)
    ((LRFill _) 1)
    ((LRSum _) 2)))

;; ISet i (IBin IAdd (ILoc i) (IConst 1)) -> i
(fn lp_inc ((s IStmt)) (Option Int)
  (match s
    ((ISet i e)
     (match e
       ((IBin o a b)
        (match o
          (IAdd
            (match a
              ((ILoc j)
               (match b
                 ((IConst n)
                  (if (int_eq n 1) (if (int_eq i j) (Some i) None) None))
                 (_ None)))
              (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

;; ISet i (IBin ISub (ILoc i) (IConst 1)) -> i
(fn lp_dec ((s IStmt)) (Option Int)
  (match s
    ((ISet i e)
     (match e
       ((IBin o a b)
        (match o
          (ISub
            (match a
              ((ILoc j)
               (match b
                 ((IConst n)
                  (if (int_eq n 1) (if (int_eq i j) (Some i) None) None))
                 (_ None)))
              (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

;; result expressions the final computes close over
(fn lp_res_ok ((e IExp) (n Int)) Bool
  (match e
    ((IConst _) True)
    ((ILoc i) (if (le 0 i) (lt i n) False))
    (_ False)))

(fn lp_distinct3 ((a Int) (b Int) (c Int)) Bool
  (if (int_eq a b) False (if (int_eq a c) False (if (int_eq b c) False True))))

(fn lp_all_lt ((n Int) (xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil True)
    ((Cons h t) (if (le 0 h) (if (lt h n) (lp_all_lt n t) False) False))))

;; the first body statement classifies the shape
(fn lp_s1 ((s1 IStmt) (p Int) (c Int) (n Int) (bs (List IStmt)))
  (Option LShape)
  (match s1
    ((IStore ae ve)
     (match ae
       ((ILoc p2)
        (match ve
          ((ILoc v)
           (if (int_eq p p2)
             (if (lp_distinct3 p c v)
               (if (lp_all_lt n (Cons p (Cons c (Cons v Nil))))
                 (Some (MkLShape p c n (LRFill v) bs))
                 None)
               None)
             None))
          (_ None)))
       (_ None)))
    ((ISet a e1)
     (match e1
       ((IBin o aa bb)
        (match o
          (IAdd
            (match aa
              ((ILoc a2)
               (match bb
                 ((ILoad pe)
                  (match pe
                    ((ILoc p2)
                     (if (int_eq a a2)
                       (if (int_eq p p2)
                         (if (lp_distinct3 p c a)
                           (if (lp_all_lt n (Cons p (Cons c (Cons a Nil))))
                             (Some (MkLShape p c n (LRSum a) bs))
                             None)
                           None)
                         None)
                       None))
                    (_ None)))
                 (_ None)))
              (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

(fn lp_rec ((f IFn)) (Option LShape)
  (if (int_eq (iextra_of f) 0)
    (if (le (iparams_of f) 6)
      (if (lp_res_ok (iresult_of f) (iparams_of f))
        (match (ibody_of f)
          ((Cons w wr)
           (match wr
             (Nil
               (match w
                 ((IWhile ce bs)
                  (match ce
                    ((ILoc c)
                     (match bs
                       ((Cons s1 (Cons s2 (Cons s3 Nil)))
                        (match (lp_inc s2)
                          (None None)
                          ((Some p)
                           (match (lp_dec s3)
                             (None None)
                             ((Some c2)
                              (if (int_eq c c2)
                                (lp_s1 s1 p c (iparams_of f) bs)
                                None))))))
                       (_ None)))
                    (_ None)))
                 (_ None)))
             (_ None)))
          (_ None))
        None)
      None)
    None))

;; the IWhile's body list, as the VALUE Expr subterm (for spelling)
(fn gv_wbody ((gv Expr)) (Option Expr)
  (match (ec_is gv (quote MkIFn))
    (None None)
    ((Some args)
     (match args
       ((Cons _ (Cons _ (Cons b (Cons _ Nil))))
        (match b
          ((Ctor q1 bargs)
           (if (sym_eq (qn_name q1) (quote Cons))
             (match bargs
               ((Cons wh (Cons _ Nil))
                (match wh
                  ((Ctor q2 wargs)
                   (if (sym_eq (qn_name q2) (quote IWhile))
                     (match wargs
                       ((Cons _ (Cons bs Nil)) (Some bs))
                       (_ None))
                     None))
                  (_ None)))
               (_ None))
             None))
          (_ None)))
       (_ None)))))

;; the translated loop's instruction list:
;; func body = Cons (Block (list (Loop L))) epilogue -> L
(fn ex_loop_body ((x86 Bool) (fexp Expr)) (Option Expr)
  (match fexp
    ((Ctor _ margs)
     (match (last_e margs)
       (None None)
       ((Some body)
        (match body
          ((Ctor qc cargs)
           (if (sym_eq (qn_name qc) (quote Cons))
             (match cargs
               ((Cons blk (Cons _ Nil))
                (match blk
                  ((Ctor qb bargs)
                   (if (sym_eq (qn_name qb) (if x86 (quote XBlock) (quote Block)))
                     (match bargs
                       ((Cons inner Nil)
                        (match inner
                          ((Ctor qi iargs)
                           (if (sym_eq (qn_name qi) (quote Cons))
                             (match iargs
                               ((Cons lp (Cons _ Nil))
                                (match lp
                                  ((Ctor ql largs)
                                   (if
                                     (sym_eq
                                       (qn_name ql)
                                       (if x86 (quote XLoop) (quote Loop)))
                                     (match largs
                                       ((Cons l Nil) (Some l))
                                       (_ None))
                                     None))
                                  (_ None)))
                               (_ None))
                             None))
                          (_ None)))
                       (_ None))
                     None))
                  (_ None)))
               (_ None))
             None))
          (_ None)))))
    (_ None)))

;; --- bridge-joint discovery ---------------------------------------------------

(fn is_ty1 ((t Type) (s Symbol)) Bool
  (match t
    ((TCon q as)
     (match as
       (Nil (sym_eq (qn_name q) s))
       ((Cons _ _) False)))
    (_ False)))

;; the IFn -> IProg wrapper defined in the source module, by signature
(fn find_wrap ((fns (List FnDef)) (mp (List Symbol))) (Option Symbol)
  (measure (struct fns))
  (match fns
    (Nil None)
    ((Cons f rest)
     (match f
       ((FnDef q ts rt _)
        (match ts
          ((Cons t1 tr)
           (match tr
             (Nil
               (if (is_ty1 t1 (quote IFn))
                 (if (is_ty1 rt (quote IProg))
                   (if (sym_path_eq (qn_mod q) mp)
                     (Some (qn_name q))
                     (find_wrap rest mp))
                   (find_wrap rest mp))
                 (find_wrap rest mp)))
             ((Cons _ _) (find_wrap rest mp))))
          (Nil (find_wrap rest mp))))))))

;; drop through the first underscore (the whole tail if none)
(fn after_us ((s (List Int))) (List Int)
  (measure (struct s))
  (match s
    (Nil Nil)
    ((Cons h t) (if (int_eq h 95) t (after_us t)))))

;; The claim roster is CHECK-ONLY (run-mode parse skips claims), so the
;; meeting lemma is discovered by a textual scan of the source file: the
;; form head "(claim imw_<stem>" at a whitespace boundary. A false
;; positive fails loudly when the generated file is kernel-checked; a
;; false negative just leaves the worker standing alone.
(fn txt_ws ((c Int)) Bool
  (if (int_eq c 32) True (if (int_eq c 10) True (int_eq c 9))))

(fn txt_at ((needle (List Int)) (hay (List Int))) Bool
  (measure (struct needle))
  (match needle
    (Nil
      (match hay
        (Nil True)
        ((Cons h _) (txt_ws h))))
    ((Cons nc nt)
     (match hay
       (Nil False)
       ((Cons hc ht) (if (int_eq nc hc) (txt_at nt ht) False))))))

(fn txt_has ((needle (List Int)) (hay (List Int))) Bool
  (measure (struct hay))
  (if (txt_at needle hay) True
  (match hay
    (Nil False)
    ((Cons _ t) (txt_has needle t)))))

;; the imp-side meeting lemma's name, if the source text declares it
(fn find_mw ((srctxt (List Int)) (stem (List Int))) (Option (List Int))
  (if (txt_has (append_int "(claim imw_" stem) srctxt)
    (Some (append_int "imw_" stem))
    (if (txt_has (append_int "(claim imw_" (after_us stem)) srctxt)
      (Some (append_int "imw_" (after_us stem)))
      None)))

;; the wrapper's memsize (the MkIProg literal's second field)
(fn lp_msz ((msrc Module) (wrap Symbol) (gv Expr)) (Option Int)
  (match (invoke msrc wrap (Cons gv Nil))
    (None None)
    ((Some pv)
     (match (ec_is pv (quote MkIProg))
       (None None)
       ((Some pargs)
        (match pargs
          ((Cons _ (Cons msz Nil)) (e_int msz))
          (_ None)))))))

;; --- loop-tier doc pieces -------------------------------------------------------

(fn d_xi ((i Int)) Doc (DCat (DStr "x") (dint i)))

;; the locals list (list x0 x1 (int_of_nat k)) — counter spelled through k
(fn d_lgo ((j Int) (cidx Int) (acc Doc)) Doc
  (measure j (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 1) acc
  (d_lgo
    (- j 1)
    cidx
    (DCat
      (DCat
        (DStr " ")
        (if (int_eq (- j 1) cidx) (DStr "(int_of_nat k)") (d_xi (- j 1))))
      acc))))

(fn d_largs ((n Int) (cidx Int)) Doc
  (dcat3 (DStr "(list") (d_lgo n cidx (DStr "")) (DStr ")")))

;; worker binders: (x<i> Int) for every param except the counter
(fn d_wbx_go ((j Int) (cidx Int) (acc Doc)) Doc
  (measure j (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt j 1) acc
  (d_wbx_go
    (- j 1)
    cidx
    (if (int_eq (- j 1) cidx) acc
    (DCat (dcat3 (DStr "(x") (dint (- j 1)) (DStr " Int) ")) acc)))))

;; SysV homes in Regs field order: field index -> local (or -1)
(fn d_reg_loc ((pos Int)) Int
  (if (int_eq pos 1) 3
  (if (int_eq pos 2) 2
  (if (int_eq pos 5) 1
  (if (int_eq pos 6) 0
  (if (int_eq pos 7) 4
  (if (int_eq pos 8) 5
  (- 0 1))))))))

(fn d_reg_item ((pos Int) (n Int) (cidx Int) (ra Doc)) Doc
  (if (int_eq pos 0) ra
  (if (lt (d_reg_loc pos) 0) (DStr "0")
  (if (lt (d_reg_loc pos) n)
    (if (int_eq (d_reg_loc pos) cidx)
      (DStr "(int_of_nat k)")
      (d_xi (d_reg_loc pos)))
    (DStr "0")))))

(fn d_regs_go ((cnt Int) (n Int) (cidx Int) (ra Doc)) Doc
  (measure cnt (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt cnt 1) (DStr "")
  (DCat
    (DCat (DStr " ") (d_reg_item (- 15 cnt) n cidx ra))
    (d_regs_go (- cnt 1) n cidx ra))))

(fn d_mkregs ((n Int) (cidx Int) (ra Doc)) Doc
  (dcat3 (DStr "(MkRegs") (d_regs_go 15 n cidx ra) (DStr ")")))

(fn d_lprem_lo ((i Int)) Doc
  (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True)"))))

(fn d_lprem_hi ((i Int)) Doc
  (dconc
    (list (DStr "(= (le (+ x") (dint i) (DStr " (int_of_nat k)) 65536) True)"))))

(fn d_lprem_acc ((i Int) (md Int)) Doc
  (dconc
    (list
      (DStr "(= (le (+ x")
      (dint i)
      (DStr " (* 256 (int_of_nat k))) ")
      (dint md)
      (DStr ") True)"))))

(fn d_lprems ((sh LShape) (md Int)) Doc
  (match (lsrole_of sh)
    ((LRFill _)
     (dcat3 (d_lprem_lo (lsp_of sh)) (sp) (d_lprem_hi (lsp_of sh))))
    ((LRSum a)
     (dconc
       (list
         (d_lprem_lo (lsp_of sh))
         (sp)
         (d_lprem_lo a)
         (sp)
         (d_lprem_hi (lsp_of sh))
         (sp)
         (d_lprem_acc a md))))))

;; discharge atoms (the hand files' exact spellings)
(fn d_dprem ((i Int)) Doc
  (dconc
    (list
      (DStr "(steps ((rewrite (premise ")
      (dint i)
      (DStr ") lr lhs true ())) refl)"))))

(fn d_dsucc () Doc
  (DStr "(steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)"))

(fn d_dnn () Doc
  (DStr "(rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)"))

(fn d_dcompb () Doc (DStr "(steps ((compute both)) refl)"))

(fn d_dgetlo () Doc (DStr "(rewrite-with (lemma get_lo) lr lhs () () refl)"))

(fn d_dgethi () Doc (DStr "(rewrite-with (lemma get_hi) lr lhs () () refl)"))

(fn d_d3 ((i Int)) Doc
  (dconc (list (d_dprem i) (sp) (d_dsucc) (sp) (d_dnn))))

(fn d_stops ((x86 Bool)) Doc
  (DStr
    (if x86
      "(stop xeval_loop iwhile xlg_fuel lg_fuel ix_out xlg_last)"
      "(stop eval_loop iwhile lg_fuel iw_out)")))

(fn d_km_inst ((x86 Bool) (p Int)) Doc
  (dconc
    (list
      (DStr "((inst a x")
      (dint p)
      (DStr ") (inst c k2)")
      (DStr (if x86 " (inst w 65536) (inst l 0)" ""))
      (DStr ")"))))

(fn d_km_dis ((x86 Bool) (hp Int)) Doc
  (if x86
    (dconc
      (list
        (d_dprem hp)
        (sp)
        (d_dsucc)
        (sp)
        (d_dprem 0)
        (sp)
        (d_dcompb)
        (sp)
        (d_dcompb)))
    (dconc (list (d_dprem hp) (sp) (d_dsucc) (sp) (d_dprem 0)))))

;; wrap bounds for the pointer increment
(fn d_hw0_dis ((x86 Bool) (hp Int)) Doc
  (if x86
    (dconc
      (list
        (DStr "(rewrite-with (lemma xlg_lo0) lr lhs ((inst l 0)) (")
        (d_dprem 0)
        (sp)
        (d_dcompb)
        (DStr ") refl) (rewrite-with (lemma xlg_64) lr lhs ((inst w 65536)) ((rewrite-with (lemma xlg_a1_ms) lr lhs ((inst c k2)) (")
        (d_d3 hp)
        (DStr ") refl) ")
        (d_dcompb)
        (DStr ") refl)")))
    (dconc
      (list
        (DStr "(rewrite-with (lemma lg_lo1) lr lhs () (")
        (d_dprem 0)
        (DStr ") refl) (rewrite-with (lemma lg_32) lr lhs () ((rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) (")
        (d_d3 hp)
        (DStr ") refl)) refl)")))))

;; the accumulator's wrap identity (sum shape only)
(fn d_hwa ((x86 Bool) (p Int) (a Int) (md Int) (wlem (List Int))) Doc
  (dconc
    (list
      (DStr "(have hwa (= (mod (+ x")
      (dint a)
      (DStr " (mem_get m0 x")
      (dint p)
      (DStr ")) ")
      (dint md)
      (DStr ") (+ x")
      (dint a)
      (DStr " (mem_get m0 x")
      (dint p)
      (DStr "))) (rewrite-with (lemma ")
      (DStr wlem)
      (DStr ") lr lhs ((inst x (+ x")
      (dint a)
      (DStr " (mem_get m0 x")
      (dint p)
      (DStr ")))) ((rewrite-with (lemma ")
      (DStr (if x86 "xlg_sum_lo" "lg_sum_lo"))
      (DStr ") lr lhs () (")
      (d_dprem 1)
      (sp)
      (d_dgetlo)
      (DStr ") refl) (rewrite-with (lemma ")
      (DStr (if x86 "xlg_sum_64" "lg_sum_32"))
      (DStr ") lr lhs ((inst c k2)) (")
      (d_dprem 3)
      (sp)
      (d_dsucc)
      (sp)
      (d_dgethi)
      (sp)
      (d_dnn)
      (DStr ") refl)) refl)) (steps ((rewrite (premise hwa) lr lhs true ()))) "))))

;; the induction hypothesis, premises re-established at the stepped state
(fn d_ih ((x86 Bool) (sh LShape)) Doc
  (match (lsrole_of sh)
    ((LRFill _)
     (dconc
       (list
         (DStr "(rewrite-with (hyp 0) lr lhs () ((rewrite-with (lemma ")
         (DStr (if x86 "xlg_lo1" "lg_lo1"))
         (DStr ") lr lhs () (")
         (d_dprem 0)
         (DStr ") refl) (rewrite-with (lemma ")
         (DStr (if x86 "xlg_shift" "lg_shift"))
         (DStr ") lr lhs () (")
         (d_dprem 1)
         (sp)
         (d_dsucc)
         (DStr ") refl))) "))))
    ((LRSum _)
     (dconc
       (list
         (DStr "(rewrite-with (hyp 0) lr lhs () ((rewrite-with (lemma ")
         (DStr (if x86 "xlg_lo1" "lg_lo1"))
         (DStr ") lr lhs () (")
         (d_dprem 0)
         (DStr ") refl) (rewrite-with (lemma ")
         (DStr (if x86 "xlg_sum_lo" "lg_sum_lo"))
         (DStr ") lr lhs () (")
         (d_dprem 1)
         (sp)
         (d_dgetlo)
         (DStr ") refl) (rewrite-with (lemma ")
         (DStr (if x86 "xlg_shift" "lg_shift"))
         (DStr ") lr lhs () (")
         (d_dprem 2)
         (sp)
         (d_dsucc)
         (DStr ") refl) (rewrite-with (lemma ")
         (DStr (if x86 "xlg_sum_shift" "lg_sum_shift"))
         (DStr ") lr lhs () (")
         (d_dprem 3)
         (sp)
         (d_dsucc)
         (sp)
         (d_dgethi)
         (DStr ") refl))) "))))))

;; the S case: the hand template, indices spliced
(fn d_schain ((x86 Bool) (sh LShape) (md Int) (wlem (List Int))) Doc
  (dconc
    (list
      (DStr "(steps ((unfold ")
      (DStr (if x86 "xlg_fuel" "lg_fuel"))
      (DStr " lhs) (reduce lhs) (unfold lg_fuel rhs) (reduce rhs) (unfold ")
      (DStr (if x86 "xeval_loop" "eval_loop"))
      (DStr " lhs) (unfold iwhile rhs) (rewrite (lemma int_of_nat_succ) lr both true ()) (compute both ")
      (d_stops x86)
      (DStr "))) (rewrite-with (lemma ")
      (DStr (if x86 "xlg_ne" "lg_ne"))
      (DStr ") lr lhs () (")
      (d_dnn)
      (DStr ")) (rewrite-with (lemma lg_ne) lr rhs () (")
      (d_dnn)
      (DStr ")) (steps ((compute both ")
      (d_stops x86)
      (DStr ") (rewrite (premise 0) lr both true ()) (compute both ")
      (d_stops x86)
      (DStr "))) (rewrite-with (lemma ")
      (DStr (if x86 "xlg_a1_ms" "lg_a1_ms"))
      (DStr ") lr lhs ((inst c k2)) (")
      (d_d3 (lp_hp sh))
      (DStr ")) (rewrite-with (lemma im_lt) lr rhs ((inst c k2)) (")
      (d_d3 (lp_hp sh))
      (DStr ")) (steps ((compute both ")
      (d_stops x86)
      (DStr "))) (have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma ")
      (DStr (if x86 "xlg_sub" "lg_sub"))
      (DStr ") lr lhs () () refl)) (steps ((rewrite (premise hsub) lr both true ()) (compute both ")
      (d_stops x86)
      (DStr "))) (have hwk (= (mod (int_of_nat k2) ")
      (dint md)
      (DStr ") (int_of_nat k2)) (rewrite-with (lemma ")
      (DStr wlem)
      (DStr ") lr lhs ((inst x (int_of_nat k2))) (")
      (d_dnn)
      (DStr " (rewrite-with (lemma ")
      (DStr (if x86 "xlg_kM" "lg_kM"))
      (DStr ") lr lhs ")
      (d_km_inst x86 (lsp_of sh))
      (DStr " (")
      (d_km_dis x86 (lp_hp sh))
      (DStr ") refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) (have hw0 (= (mod (+ x")
      (dint (lsp_of sh))
      (DStr " 1) ")
      (dint md)
      (DStr ") (+ x")
      (dint (lsp_of sh))
      (DStr " 1)) (rewrite-with (lemma ")
      (DStr wlem)
      (DStr ") lr lhs ((inst x (+ x")
      (dint (lsp_of sh))
      (DStr " 1))) (")
      (d_hw0_dis x86 (lp_hp sh))
      (DStr ") refl)) (steps ((rewrite (premise hw0) lr lhs true ()))) ")
      (match (lsrole_of sh)
        ((LRFill _) (DStr ""))
        ((LRSum a) (d_hwa x86 (lsp_of sh) a md wlem)))
      (if x86
        (if (is_sum sh)
          (DStr "(steps ((unfold xlg_last rhs) (reduce rhs))) ")
          (DStr ""))
        (DStr ""))
      (d_ih x86 sh)
      (DStr "refl"))))

;; the worker claim: machine loop = adapter of iwhile, induction on k
(fn d_worker
  ((x86 Bool)
   (sh LShape)
   (md Int)
   (wlem (List Int))
   (stem (List Int))
   (fw Int)
   (fi Int)
   (fdoc Doc)
   (lbdoc Doc)
   (ibdoc Doc))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr (if x86 "ixw_" "iww_"))
      (DStr stem)
      (DStr " (goal (")
      (if x86 (if (is_sum sh) (DStr "(ra Int) ") (DStr "")) (DStr ""))
      (d_wbx_go
        (lsn_of sh)
        (lsc_of sh)
        (if x86
          (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List XFunc))")
          (DStr "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))")))
      (DStr ") (")
      (d_lprems sh md)
      (DStr ") (= ")
      (if x86
        (dconc
          (list
            (DStr "(xeval_loop (S^ ")
            (dint fw)
            (DStr " (xlg_fuel k c)) (MkXModule (Cons ")
            fdoc
            (DStr " restfs) 0 65536) ")
            lbdoc
            (DStr " ")
            (d_mkregs
              (lsn_of sh)
              (lsc_of sh)
              (if (is_sum sh) (DStr "ra") (DStr "0")))
            (DStr " m0)")))
        (dconc
          (list
            (DStr "(eval_loop (S^ ")
            (dint fw)
            (DStr " (lg_fuel k c)) (MkWModule (Cons ")
            fdoc
            (DStr " restfs) 65536) ")
            lbdoc
            (DStr " ")
            (d_largs (lsn_of sh) (lsc_of sh))
            (DStr " st m0)"))))
      (DStr " ")
      (if x86
        (dcat3
          (DStr "(ix_out ")
          (if (is_sum sh)
            (dconc
              (list (DStr "(xlg_last m0 x") (dint (lsp_of sh)) (DStr " ra k)")))
            (DStr "0"))
          (DStr " "))
        (DStr "(iw_out st "))
      (dconc
        (list
          (DStr "(iwhile (S^ ")
          (dint fi)
          (DStr " (lg_fuel k c)) 65536 (ILoc ")
          (dint (lsc_of sh))
          (DStr ") ")
          ibdoc
          (DStr " ")
          (d_largs (lsn_of sh) (lsc_of sh))
          (DStr " m0)")))
      (DStr "))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr both true ()) (compute both)) refl)) (case S (k2) (chain ")
      (d_schain x86 sh md wlem)
      (DStr ")))))")
      (DStr (nl))
      (DStr (nl)))))

;; the worker's premises, discharged one for one in the bridge
(fn d_lbr_dis ((sh LShape)) Doc
  (match (lsrole_of sh)
    ((LRFill _) (dcat3 (d_dprem 0) (sp) (d_dprem 1)))
    ((LRSum _)
     (dconc
       (list
         (d_dprem 0)
         (sp)
         (d_dprem 1)
         (sp)
         (d_dprem 2)
         (sp)
         (d_dprem 3))))))

;; the denotation bridge: call boundary = call boundary, through the
;; worker and the imp-side meeting lemma (both sides, fuel-independent)
(fn d_lbridge
  ((x86 Bool)
   (sh LShape)
   (md Int)
   (stem (List Int))
   (brpre (List Int))
   (trans (List Int))
   (pin Symbol)
   (wrapnm (List Int))
   (mw (List Int))
   (fwb Int)
   (fib Int))
  Doc
  (dconc
    (list
      (DStr "(claim ")
      (DStr brpre)
      (DStr stem)
      (DStr " (goal (")
      (d_wbx_go
        (lsn_of sh)
        (lsc_of sh)
        (DStr "(m0 Mem) (c Nat) (c2 Nat) (k Nat)"))
      (DStr ") (")
      (d_lprems sh md)
      (DStr ") (= ")
      (if x86
        (dconc
          (list
            (DStr "(xcall_fn_mem (S^ ")
            (dint fwb)
            (DStr " (xlg_fuel k c)) (MkXModule (list (x_of (")
            (DStr trans)
            (DStr " (")
            (dsym pin)
            (DStr ")))) 0 65536) 0 ")
            (d_largs (lsn_of sh) (lsc_of sh))
            (DStr " m0)")))
        (dconc
          (list
            (DStr "(call_fn_mem (S^ ")
            (dint fwb)
            (DStr " (lg_fuel k c)) (MkWModule (list (w_of (")
            (DStr trans)
            (DStr " (")
            (dsym pin)
            (DStr ")))) 65536) 0 ")
            (d_largs (lsn_of sh) (lsc_of sh))
            (DStr " m0)"))))
      (DStr " (icall_mem (S^ ")
      (dint fib)
      (DStr " (lg_fuel k c2)) (")
      (DStr wrapnm)
      (DStr " (")
      (dsym pin)
      (DStr ")) 0 ")
      (d_largs (lsn_of sh) (lsc_of sh))
      (DStr " m0))) (chain (steps ((compute both ")
      (d_stops x86)
      (DStr "))) (rewrite-with (lemma ")
      (DStr (if x86 "ixw_" "iww_"))
      (DStr stem)
      (DStr ") lr lhs () (")
      (d_lbr_dis sh)
      (DStr ")) (rewrite-with (lemma ")
      (DStr mw)
      (DStr ") lr lhs () (")
      (d_dprem 0)
      (sp)
      (d_dprem (lp_hp sh))
      (DStr ")) (rewrite-with (lemma ")
      (DStr mw)
      (DStr ") lr rhs () (")
      (d_dprem 0)
      (sp)
      (d_dprem (lp_hp sh))
      (DStr ")) (steps ((compute both))) refl))")
      (DStr (nl))
      (DStr (nl)))))

;; a recognized loop whose bridge joints are missing: the worker stands
(fn d_lwnote ((pin Symbol) (why (List Int))) Doc
  (dconc
    (list
      (DStr ";; ")
      (dsym pin)
      (DStr ": worker only (")
      (DStr why)
      (DStr ")")
      (DStr (nl))
      (DStr (nl)))))

;; the loop pin's cert set: worker always; bridge when the joints exist
(fn gen_loop
  ((brpre (List Int))
   (trans (List Int))
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (pin Symbol)
   (gv Expr)
   (tv Expr)
   (sh LShape)
   (msrc Module)
   (srctxt (List Int))
   (wrap (Option Symbol)))
  ERes
  (match (ec_is tv (quote Some))
    (None (EErr "translated value is not Some (internal)"))
    ((Some sargs)
     (match sargs
       ((Cons fexp Nil)
        (match (ex_loop_body x86 fexp)
          (None (EErr "translated loop shape (internal)"))
          ((Some lb)
           (match (gv_wbody gv)
             (None (EErr "pin loop body shape (internal)"))
             ((Some ib)
              (match (sp_e (harvest tv) 0 fexp)
                ((SpRErr m) (EErr m))
                ((SpROk fdoc)
                 (match (sp_e (harvest tv) 0 lb)
                   ((SpRErr m) (EErr m))
                   ((SpROk lbdoc)
                    (match (sp_e (harvest gv) 0 ib)
                      ((SpRErr m) (EErr m))
                      ((SpROk ibdoc)
                       (EOk
                         (DCat
                           (d_worker
                             x86
                             sh
                             md
                             wlem
                             (pin_nm pin)
                             (+ (tcost lb) 4)
                             (+ (gcost (lsbs_of sh)) 5)
                             fdoc
                             lbdoc
                             ibdoc)
                           (match wrap
                             (None
                               (d_lwnote
                                 pin
                                 "no IFn -> IProg wrapper in the source: no bridge"))
                             ((Some wnm)
                              (match (find_mw srctxt (pin_nm pin))
                                (None
                                  (d_lwnote
                                    pin
                                    "no imw_ meeting lemma in the source: no bridge"))
                                ((Some mw)
                                 (match (lp_msz msrc wnm gv)
                                   (None
                                     (d_lwnote
                                       pin
                                       "wrapper does not evaluate to MkIProg (internal)"))
                                   ((Some msz)
                                    (if (int_eq msz 65536)
                                      (d_lbridge
                                        x86
                                        sh
                                        md
                                        (pin_nm pin)
                                        brpre
                                        trans
                                        pin
                                        (chars_of_sym wnm)
                                        mw
                                        (+ (+ (tcost lb) 4) 4)
                                        (+ (+ (gcost (lsbs_of sh)) 5) 2))
                                      (d_lwnote
                                        pin
                                        "wrapper memsize is not 65536 (the loopkit constants): no bridge")))))))))))))))))))))
       (_ (EErr "translated value shape (internal)"))))))

;; does any pin in the file carry a recognized loop? (header imports)
(fn any_loop ((msrc Module) (pins (List Symbol))) Bool
  (measure (struct pins))
  (match pins
    (Nil False)
    ((Cons p rest)
     (match (invoke msrc p Nil)
       (None (any_loop msrc rest))
       ((Some gv)
        (match (rf_fn gv)
          (None (any_loop msrc rest))
          ((Some ifn)
           (match (lp_rec ifn)
             ((Some _) True)
             (None (any_loop msrc rest))))))))))

;; --- per-pin emission ------------------------------------------------------------

;; a refused pin's honest record in the output
(fn d_refused ((pin Symbol) (tname (List Int))) Doc
  (dconc
    (list
      (DStr ";; ")
      (dsym pin)
      (DStr ": no ")
      (DStr tname)
      (DStr " leg (the translator refused this pin)")
      (DStr (nl))
      (DStr (nl)))))

(type ERes (EOk Doc) (EErr (List Int)))

(fn last_e ((es (List Expr))) (Option Expr)
  (measure (struct es))
  (match es
    (Nil None)
    ((Cons h Nil) (Some h))
    ((Cons _ t) (last_e t))))

;; the pin's bridge: fuel from the two cost walks, premises and proof
;; from the symbolic walk; a v1-scope decline leaves the tie standing
;; with an honest note
(fn gen_bridge
  ((brpre (List Int))
   (trans (List Int))
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (wrapnm (List Int))
   (pin Symbol)
   (gv Expr)
   (tv Expr))
  ERes
  (match (rf_fn gv)
    (None (EErr (append_int "pin does not reify: " (chars_of_sym pin))))
    ((Some ifn)
     (match (ec_is tv (quote Some))
       (None (EErr "translated value is not Some (internal)"))
       ((Some sargs)
        (match sargs
          ((Cons fexp Nil)
           (match fexp
             ((Ctor _ margs)
              (match (last_e margs)
                (None (EErr "translated func has no body (internal)"))
                ((Some instrs)
                 (match
                   (se_stmts
                     (+ (isz_stmts (ibody_of ifn)) 2)
                     x86
                     md
                     (ibody_of ifn)
                     (iresult_of ifn)
                     (st_init (iparams_of ifn) (iextra_of ifn))
                     Nil)
                   ((SRf why) (EOk (d_note pin why)))
                   ((SROk bt evs)
                    (match (evs_ok (ev_dedup evs))
                      ((Some why) (EOk (d_note pin why)))
                      (None
                        (EOk
                          (d_bridge
                            brpre
                            (pin_nm pin)
                            pin
                            x86
                            md
                            wlem
                            trans
                            wrapnm
                            (iparams_of ifn)
                            (+ (tcost instrs) 4)
                            (+ (gcost (ibody_of ifn)) 4)
                            bt
                            (ev_index (ev_dedup evs) 0))))))))))
             (_ (EErr "translated value shape (internal)"))))
          (_ (EErr "translated value shape (internal)"))))))))

;; one pin, one target: evaluate the pin in the SOURCE module, run the
;; translator on the value in the TRANSLATOR module, spell the tie,
;; then the loop tier (recognized shapes) or the scalar bridge (when
;; the wrapper exists and the walk accepts)
(fn gen_pin
  ((msrc Module)
   (mtr Module)
   (trans Symbol)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (srctxt (List Int))
   (wrap (Option Symbol))
   (pin Symbol))
  ERes
  (match (invoke msrc pin Nil)
    (None (EErr (append_int "pin does not evaluate: " (chars_of_sym pin))))
    ((Some gv)
     (match (invoke mtr trans (Cons gv Nil))
       (None
         (EErr (append_int "translator invoke failed on " (chars_of_sym pin))))
       ((Some tv)
        (match (ec_is tv (quote None))
          ((Some _) (EOk (d_refused pin tname)))
          (None
            (match (sp_e (harvest tv) 0 tv)
              ((SpRErr msg) (EErr msg))
              ((SpROk vdoc)
               (match (rf_fn gv)
                 (None
                   (EErr (append_int "pin does not reify: " (chars_of_sym pin))))
                 ((Some ifn)
                  (match (lp_rec ifn)
                    ((Some sh)
                     (match
                       (gen_loop
                         brpre
                         (chars_of_sym trans)
                         x86
                         md
                         wlem
                         pin
                         gv
                         tv
                         sh
                         msrc
                         srctxt
                         wrap)
                       ((EErr msg) (EErr msg))
                       ((EOk ldoc)
                        (EOk
                          (DCat
                            (d_tie
                              tiepre
                              (pin_nm pin)
                              (chars_of_sym trans)
                              pin
                              vdoc)
                            ldoc)))))
                    (None
                      (match wrap
                        (None
                          (EOk
                            (d_tie
                              tiepre
                              (pin_nm pin)
                              (chars_of_sym trans)
                              pin
                              vdoc)))
                        ((Some wnm)
                         (match
                           (gen_bridge
                             brpre
                             (chars_of_sym trans)
                             x86
                             md
                             wlem
                             (chars_of_sym wnm)
                             pin
                             gv
                             tv)
                           ((EErr msg) (EErr msg))
                           ((EOk bdoc)
                            (EOk
                              (DCat
                                (d_tie
                                  tiepre
                                  (pin_nm pin)
                                  (chars_of_sym trans)
                                  pin
                                  vdoc)
                                bdoc)))))))))))))))))))

(fn gen_pins
  ((msrc Module)
   (mtr Module)
   (trans Symbol)
   (tiepre (List Int))
   (brpre (List Int))
   (tname (List Int))
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (srctxt (List Int))
   (wrap (Option Symbol))
   (pins (List Symbol)))
  ERes
  (measure (struct pins))
  (match pins
    (Nil (EOk (DStr "")))
    ((Cons p rest)
     (match (gen_pin msrc mtr trans tiepre brpre tname x86 md wlem srctxt wrap p)
       ((EErr msg) (EErr msg))
       ((EOk d)
        (match
          (gen_pins msrc mtr trans tiepre brpre tname x86 md wlem srctxt wrap rest)
          ((EErr msg) (EErr msg))
          ((EOk ds) (EOk (DCat d ds)))))))))

;; --- pin enumeration --------------------------------------------------------------

;; nullary fns returning IFn, defined in the target file's own module
(fn is_ifn_ty ((t Type)) Bool
  (match t
    ((TCon q args)
     (match args
       (Nil (sym_eq (qn_name q) (quote IFn)))
       ((Cons _ _) False)))
    (_ False)))

(fn pins_of ((fns (List FnDef)) (mp (List Symbol))) (List Symbol)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((FnDef q ts rt _)
        (match ts
          ((Cons _ _) (pins_of rest mp))
          (Nil
            (if (is_ifn_ty rt)
              (if (sym_path_eq (qn_mod q) mp)
                (Cons (qn_name q) (pins_of rest mp))
                (pins_of rest mp))
              (pins_of rest mp)))))))))

;; --- the generated file header -----------------------------------------------------

;; imports: kernel stdlib + the pin SOURCE (sibling by basename) + the
;; imp model + the target model + the translator, repo-root relative
;; through the OUT path's updots climb
(fn ig_header
  ((src (List Int))
   (tname (List Int))
   (out (List Int))
   (modelpath (List Int))
   (transpath (List Int))
   (loopful Bool)
   (x86 Bool))
  Doc
  (dconc
    (list
      (DStr ";;; GENERATED by tools/impgen (the imp -> ISA leg generator, docs/IMP.md I2d) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate:")
      (DStr (nl))
      (DStr ";;;   bin/shard_eval run tools/impgen/impgen.shard ")
      (DStr src)
      (DStr " ")
      (DStr tname)
      (DStr " ")
      (DStr out)
      (DStr ", then shardfmt.")
      (DStr (nl))
      (dimport (append_int (updots out) "kernel/stdlib.shard"))
      (dimport (basename_go src Nil))
      (dimport (append_int (updots out) "models/imp/imp.shard"))
      (dimport (append_int (updots out) modelpath))
      (dimport (append_int (updots out) transpath))
      (if loopful
        (dconc
          (list
            (dimport (append_int (updots out) "std/nat.shard"))
            (dimport (append_int (updots out) "std/mem"))
            (dimport (append_int (updots out) "models/wasm/loopkit.shard"))
            (if x86
              (dimport (append_int (updots out) "models/x86/loopkit.shard"))
              (DStr ""))))
        (DStr ""))
      (use_of src)
      (use_of "models/imp/imp.shard")
      (use_of modelpath)
      (use_of transpath)
      (if loopful
        (dconc
          (list
            (use_of "std/nat.shard")
            (use_of "std/mem")
            (use_of "models/wasm/loopkit.shard")
            (if x86 (use_of "models/x86/loopkit.shard") (DStr ""))))
        (DStr ""))
      (DStr (nl)))))

;; --- driver -----------------------------------------------------------------------

(fn ig_fail ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn ig_refuse ((msg (List Int)) (w World)) World
  (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))

(fn ig_emit
  ((src (List Int))
   (tname (List Int))
   (out (List Int))
   (trans Symbol)
   (modelpath (List Int))
   (transpath (List Int))
   (tiepre (List Int))
   (brpre (List Int))
   (x86 Bool)
   (md Int)
   (wlem (List Int))
   (w World))
  World
  (match (load_run_module src w)
    ((Pair None w1) (ig_fail (append_int "cannot load " src) w1))
    ((Pair (Some msrc) w1)
     (match (load_run_module transpath w1)
       ((Pair None w2) (ig_fail (append_int "cannot load " transpath) w2))
       ((Pair (Some mtr) w2)
        (match (read_file src w2)
          ((Pair osrc w3)
           (match msrc
             ((Module _ fns _ _ _)
              (match (pins_of fns (split_slash (until_dot src) Nil))
                (Nil (ig_refuse (append_int "no imp pins in " src) w3))
                ((Cons p prest)
                 (match
                   (gen_pins
                     msrc
                     mtr
                     trans
                     tiepre
                     brpre
                     tname
                     x86
                     md
                     wlem
                     (match osrc
                       (None Nil)
                       ((Some txt) txt))
                     (find_wrap fns (split_slash (until_dot src) Nil))
                     (Cons p prest))
                   ((EErr msg) (ig_refuse msg w3))
                   ((EOk body)
                    (match
                      (write_file
                        out
                        (doc_flat
                          (DCat
                            (ig_header
                              src
                              tname
                              out
                              modelpath
                              transpath
                              (any_loop msrc (Cons p prest))
                              x86)
                            body)
                          Nil)
                        w3)
                      ((Pair ok w4)
                       (if ok
                         (exit
                           0
                           (write (append_int "wrote " (append_int out (nl))) w4))
                         (ig_fail (append_int "cannot write " out) w4)))))))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons src (Cons tname (Cons out Nil)))
        (if (ceq tname "wasm")
          (ig_emit
            src
            tname
            out
            (quote imp2w_fn)
            "models/wasm/wasm.shard"
            "models/imp/to_wasm.shard"
            "tie_"
            "imp_w_"
            False
            4294967296
            "wrap32_id"
            w1)
        (if (ceq tname "x86")
          (ig_emit
            src
            tname
            out
            (quote imp2x_fn)
            "models/x86/x86.shard"
            "models/imp/to_x86.shard"
            "tie_x_"
            "imp_x_"
            True
            18446744073709551616
            "wrap64_id"
            w1)
        (ig_refuse (append_int "unknown target " tname) w1))))
       (_ (ig_refuse "usage: impgen SRC TARGET OUT" w1))))))
