;;; tools/build/build_products.shard — the repo's driver-era PRODUCT LIST
;;; (docs/BUILD.md rung 1, slice 1): BuildProfile values consumed by
;;; tools/build via the standard symbol
;;;
;;;     (fn build_products () (List BuildProfile))
;;;
;;; Carries the lib products across all three targets, the x86 bins,
;;; and the pinned wasm fragment sets (the builds the retired
;;; lowbuild*.sh scripts used to drive). Two-file cert sets ride the
;;; aux field: regen's aux = the second generator output; pinlib's
;;; aux = the portable companion of the linked primary.
;;;
;;; RUN IT:  tools/build/build.sh tools/build/build_products.shard

(import "../../kernel/stdlib.shard")
(import "../../meta/build")
(use (:: meta build *))

(fn build_products () (List BuildProfile)
  (list
    (MkBuildProfile
      (quote lib)
      (quote wasm)
      "tools/lowbuild/fixtures/purelib_src.shard"
      "tools/lowbuild/fixtures/purelib_out.shard"
      "")
