;;; test_app — tiny pipeline smoke target for tools/lower (v0 subset only:
;;; flat patterns, no if/match in named position at the SOURCE level — the
;;; lowerer is allowed to introduce what ANF needs).

(import "../../kernel/stdlib.shard")

(extern write ((s (List Int)) (w World)) World)
(extern exit ((code Int) (w World)) World)

(fn len_i ((xs (List Int))) Int
  (match xs
    (Nil 0)
    ((Cons h t) (+ 1 (len_i t)))))

(fn sum_i ((xs (List Int))) Int
  (match xs
    (Nil 0)
    ((Cons h t) (+ h (sum_i t)))))

(fn digit ((n Int)) Int (+ 48 n))

(fn show2 ((n Int)) (List Int)
  (if (lt n 10)
    (Cons (digit n) Nil)
    (Cons (digit (/ n 10)) (Cons (digit (mod n 10)) Nil))))

;; nested + literal patterns, arms sharing the Cons outer ctor (fallthrough)
(fn classify ((xs (List Int))) Int
  (match xs
    (Nil 0)
    ((Cons 7 (Cons x t)) (+ 70 x))
    ((Cons h Nil) h)
    ((Cons h (Cons x t)) (+ h x))))

;; if in NAMED (argument) position
(fn pick ((a Int) (b Int)) Int
  (+ 1 (if (lt a b) b a)))

(fn main ((w World)) World
  (exit 0
    (write
      (Cons 108 (Cons 61 (show2 (len_i (list 3 1 4 1 5)))))
      (write
        (Cons 32 (Cons 115 (Cons 61 (show2 (sum_i (list 3 1 4 1 5))))))
        (write
          (Cons 32 (Cons 99 (Cons 61 (show2 (+ (classify (list 7 2 9)) (+ (classify (list 5)) (classify (list 2 3))))))))
          (write
            (Cons 32 (Cons 112 (Cons 61 (show2 (pick 3 8)))))
            w))))))
