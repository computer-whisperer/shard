;;; tools/lowbuild/fixtures/purelib_src.shard — the LIB-BUILD PILOT (the boring library):
;;; plain shard functions + a (lib …) declaration, compiled by LIB mode
;;; (tools/wasmgen, tools/x86gen) into ONE module per target — every fn at
;;; its source-order index, position-general certs, the declared exports
;;; baked BY NAME (bl_dbl stays internal: in the module, off the export
;;; surface). The SAME declaration serves every target: the fn set is the
;;; two-target intersection fragment (x86 div is the first
;;; example-demanded growth).

(import "../../../kernel/stdlib.shard")

(fn bl_inc ((a Int)) Int (+ a 1))

(fn bl_add3 ((a Int) (b Int) (c Int)) Int (+ a (+ b c)))

;; internal: a helper the lib does not export
(fn bl_dbl ((a Int)) Int (* a 2))

(fn bl_mask ((a Int)) Int (band a 255))

;; accepts: the premise-percolation declaration — bl_inc/bl_add3's
;; guarantees are conditional on wrap ranges, SIGNED here at the NARROWEST
;; width across intended targets (the width-ordered coverage law: wrap32
;; declared covers a wasm wrap32 surface exactly and an x86 wrap64 surface
;; by subsumption); bl_mask (transparent bitwise) is premise-free and
;; needs no entry.
(lib
  purelib
  (exports bl_inc bl_add3 bl_mask)
  (accepts (bl_inc wrap32) (bl_add3 wrap32)))
