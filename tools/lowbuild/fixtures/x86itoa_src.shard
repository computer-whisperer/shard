;;; tools/lowbuild/fixtures/x86itoa_src.shard — source fns for the x86_64 DO-WHILE
;;; fragment (docs/X86.md §38-§41; probe examples/xitoa_probe.shard):
;;; the value-condition loop family, itoa's render pair. Two shapes,
;;; both looping WHILE THE QUOTIENT IS NONZERO on a ghost-Nat bound
;;; the machine never sees (machine args are the Ints only):
;;;
;;;   STORE (digits high-to-low ending at p, predecrement):
;;;   (fn NAME ((m Mem) (n Int) (p Int) (k Nat)) Mem
;;;     (match k (Z m) ((S k2)
;;;       (let ((m2 (mem_set m (- p 1) (mod (+ (mod n D) C) W))))
;;;         (if (int_eq (ediv n D) 0) m2 (NAME m2 (ediv n D) (- p 1) k2))))))
;;;
;;;   POINTER (the start-pointer twin — the same walk minus the store;
;;;   the caller recovers the count as (- p start) in pure arithmetic):
;;;   (fn NAME ((n Int) (p Int) (k Nat)) Int
;;;     (match k (Z p) ((S k2)
;;;       (if (int_eq (ediv n D) 0) (- p 1) (NAME (ediv n D) (- p 1) k2)))))
;;;
;;; The stored byte spells the machine's XAdd wrap VERBATIM (§30's law;
;;; mem_set is opaque). D and C are imm32 literals, spliced; the ghost
;;; premise rides an EMITTED per-fn power companion. This lib is
;;; x86-ONLY (div is the compound rdx:rax instruction, §31's growth).

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(use (:: std mem *))

;; itoa's writer: decimal digits, ASCII offset 48
(fn xw_digits ((m Mem) (n Int) (p Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2)
     (let
       ((m2 (mem_set m (- p 1) (mod (+ (mod n 10) 48) 18446744073709551616))))
       (if (int_eq (ediv n 10) 0) m2 (xw_digits m2 (ediv n 10) (- p 1) k2))))))

;; itoa's start pointer: where the digits begin
(fn xw_start ((n Int) (p Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z p)
    ((S k2)
     (if (int_eq (ediv n 10) 0) (- p 1) (xw_start (ediv n 10) (- p 1) k2)))))

;; a non-decimal divisor/offset pins the spliced guards and byte
(fn xw_oct ((m Mem) (n Int) (p Int) (k Nat)) Mem
  (measure (struct k))
  (match k
    (Z m)
    ((S k2)
     (let
       ((m2 (mem_set m (- p 1) (mod (+ (mod n 8) 48) 18446744073709551616))))
       (if (int_eq (ediv n 8) 0) m2 (xw_oct m2 (ediv n 8) (- p 1) k2))))))

(fn xw_start7 ((n Int) (p Int) (k Nat)) Int
  (measure (struct k))
  (match k
    (Z p)
    ((S k2)
     (if (int_eq (ediv n 7) 0) (- p 1) (xw_start7 (ediv n 7) (- p 1) k2)))))
