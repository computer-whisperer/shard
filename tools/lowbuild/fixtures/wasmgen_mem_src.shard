;;; wasmgen_mem_src.shard — source articles for wasmgen's MEM fragment
;;; (bodies that CALL std/mem's shipped wasm artifacts; docs/LOWERING.md).
;;; First param Mem, rest Int; Int return = read-only body, Mem return = a
;;; single trailing mem_set (lets allowed above it). Run lowbuild_mem.sh
;;; for the gated artifact set; the emitted certs are
;;; examples/wasmgen_mem_out.shard.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(use (:: std mem *))

;; literal address, no Int params
(fn mg_first ((m Mem)) Int (mem_get m 0))

;; the byte read itself (the trivial wrapper)
(fn mg_at ((m Mem) (x Int)) Int (mem_get m x))

;; two reads + add — the callcomp probe's sum2, machine-generated
(fn mg_sum2 ((m Mem) (x Int) (y Int)) Int (+ (mem_get m x) (mem_get m y)))

;; a read shared through a let (one call, the local read twice)
(fn mg_dbl ((m Mem) (x Int)) Int (let ((g (mem_get m x))) (+ g g)))

;; indirection: a read as another read's address
(fn mg_ind ((m Mem) (p Int)) Int (mem_get m (mem_get m p)))

;; arith address + the SAME arith recomputed after the call — the wrap
;; event re-fires for the post-call materialization (the stage law)
(fn mg_sq ((m Mem) (x Int)) Int (+ (mem_get m (* x x)) (* x x)))

;; plain byte store
(fn mg_store ((m Mem) (a Int) (v Int)) Mem (mem_set m a v))

;; byte copy by calls (read feeds the write's value)
(fn mg_copy ((m Mem) (s Int) (d Int)) Mem (mem_set m d (mem_get m s)))

;; read-modify-write — the msetcomp probe's bump, machine-generated
(fn mg_bump ((m Mem) (x Int)) Mem (mem_set m x (+ (mem_get m x) 1)))

;; a product of two reads — NONLINEAR in the reads, so its wrap bounds
;; stay premises (the §6j auto-discharge refuses what Farkas cannot
;; certify); the negative control for PRE hygiene
(fn mg_prod ((m Mem) (x Int) (y Int)) Int (* (mem_get m x) (mem_get m y)))

;; store then read THROUGH the store (write-then-read; the Mem let is
;; the linear sequencing form — probe: models/wasm/probes/wtrmem_probe.shard)
(fn mg_putget ((m Mem) (x Int) (y Int)) Mem
  (let ((m2 (mem_set m x 7))) (mem_set m2 y (mem_get m2 x))))

;; byte swap: both reads pre-write (scalar lets), then two stores
;; through a Mem let
(fn mg_swap ((m Mem) (x Int) (y Int)) Mem
  (let ((a (mem_get m x)))
    (let ((b (mem_get m y))) (let ((m2 (mem_set m x b))) (mem_set m2 y a)))))
