                   (unfold xlg_adv rhs)
                   (reduce rhs)))
                (have hxa (= (xlg_xf (mem_get m0 x0) 97 122 32) (mem_get m0 x0))
                  (steps
                    ((unfold xlg_xf lhs)
                     (rewrite (hyp 0) lr lhs true ())
                     (reduce lhs))
                    refl))
                (steps ((rewrite (premise hxa) lr rhs true ())))
                (have hxb
                  (=
                    (if (le 97 (mem_get m0 x0))
                      (if (le (mem_get m0 x0) 122) (- (mem_get m0 x0) 32)
                      (mem_get m0 x0))
                      (mem_get m0 x0))
                    (mem_get m0 x0))
                  (steps ((rewrite (hyp 0) lr lhs true ()) (reduce lhs)) refl))
                (steps ((rewrite (premise hxb) lr rhs true ())))
                (rewrite-with
                  (hyp 1)
                  lr
                  lhs
                  ()
                  ((rewrite-with
                     (lemma xlg_lo1)
                     lr
                     lhs
                     ()
                     ((steps ((rewrite (premise 0) lr lhs true ())) refl))
                     refl)
                   (rewrite-with
                     (lemma xlg_shift)
                     lr
                     lhs
                     ()
                     ((steps ((rewrite (premise 1) lr lhs true ())) refl)
                      (steps
                        ((rewrite (lemma int_of_nat_succ) lr lhs true ()))
                        refl))
                     refl)))
                refl)))))))))
(claim lowered_xl_upcase
  (goal ((x0 Int) (m0 Mem) (c Nat) (k Nat) (restfs (List XFunc)))
    ((= (le 0 x0) True) (= (le (+ x0 (int_of_nat k)) 65536) True))
    (=
      (xcall_fn_mem
        (S^ 17 (xlg_fuel k c))
        (MkXModule
          (Cons
            (MkXFunc
              2
              (list
                (XBlock (list (XLoop (inline xl_upcase_body))))
                (XMovRI RAX 0)))
            restfs)
          0
          65536)
        0
        (list x0 (int_of_nat k))
        m0)
      (Some (Pair 0 (xl_upcase m0 x0 k)))))
  (chain
    (steps ((compute lhs (stop xeval_loop xlg_fuel))))
    (rewrite-with
      (lemma xlxw_xl_upcase)
      lr
      lhs
      ((inst ra 0) (inst rc 0))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (steps ((compute both)))
    refl))
