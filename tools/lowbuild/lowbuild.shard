;;; tools/lowbuild/lowbuild.shard — the GENERIC BUILD DRIVER (docs/LOWERING.md
;;; §6): runs any module's build entry and renders its Plan.
;;;
;;;     bin/shard_eval run tools/lowbuild/lowbuild.shard <mod.build path>
;;;
;;; ONE driver for every gated module — no per-module stubs. It loads the
;;; mod.build's import closure AT RUNTIME (meta/invoke: kernel-as-a-module),
;;; constructs the Target compile-context, calls `build : Target -> Plan`
;;; across the meta-level boundary, decodes the returned Plan value, and
;;; renders the wire formats at the boundary:
;;;   ARTIFACT/MOD/CASE/MEMCASE lines on stdout — the V8 differ's grammar
;;;   (examples/wasm_diff.mjs), byte-compatible with the retired
;;;   main()-rendering mod.build form.
;;; The Target ctor's QName comes from the LOADED closure's own typedefs
;;; (ctor_qn) — the driver never spells vocabulary paths by hand. Decode is
;;; whole-or-nothing: a stuck term or shape mismatch anywhere fails LOUDLY
;;; (exit 1), never renders a truncated plan.
;;;
;;; v1 Target is fixed here: wasm, 65536, 32 — the values every current
;;; build hardcoded. Argv-selectable targets arrive when a second ISA does.

(import "../../kernel/stdlib.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/loader.shard")
(import "../../meta/invoke")
(import "../../meta/plan")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel loader *))
(use (:: meta invoke *))
(use (:: meta plan *))

;; ---------------------------------------------------------------------------
;; decoding — Plan value (Expr) -> native plan structures, whole-or-nothing
;; ---------------------------------------------------------------------------

;; a Ctor node with this local name yields its args
(fn dc_ctor ((name Symbol) (e Expr)) (Option (List Expr))
  (match e
    ((Ctor q args) (if (sym_eq (qn_name q) name) (Some args) None))
    (_ None)))

(fn dc_vec ((e Expr)) (Option PVec)
  (match (dc_ctor (quote PV) e)
    ((Some (Cons k (Cons args (Cons mem (Cons want (Cons memout Nil))))))
     (match (expr_int k)
       ((Some kv)
        (match (expr_ints args)
          ((Some av)
           (match (expr_ints mem)
             ((Some mv)
              (match (expr_int want)
                ((Some wv)
                 (match (expr_ints memout)
                   ((Some ov) (Some (PV kv av mv wv ov)))
                   (_ None)))
                (_ None)))
             (_ None)))
          (_ None)))
       (_ None)))
    (_ (dc_xvec e))))

;; the x86 memory-readback vector (PXV — the XMEMCASE wire form)
(fn dc_xvec ((e Expr)) (Option PVec)
  (match (dc_ctor (quote PXV) e)
    ((Some (Cons k (Cons args (Cons addr (Cons want (Cons outb Nil))))))
     (match (expr_int k)
       ((Some kv)
        (match (expr_ints args)
          ((Some av)
           (match (expr_int addr)
             ((Some pv)
              (match (expr_int want)
                ((Some wv)
                 (match (expr_ints outb)
                   ((Some ov) (Some (PXV kv av pv wv ov)))
                   (_ None)))
                (_ None)))
             (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

(fn dc_vecs ((es (List Expr))) (Option (List PVec))
  (measure (struct es))
  (match es
    (Nil (Some Nil))
    ((Cons e rest)
     (match (dc_vec e)
       (None None)
       ((Some v)
        (match (dc_vecs rest)
          (None None)
          ((Some vs) (Some (Cons v vs)))))))))

(fn dc_art ((e Expr)) (Option PArt)
  (match (dc_ctor (quote PA) e)
    ((Some
       (Cons
         nm
         (Cons cert (Cons cf (Cons model (Cons k (Cons cal (Cons ext Nil))))))))
     (match (expr_ints nm)
       ((Some nv)
        (match (expr_ints cert)
          ((Some certv)
           (match (expr_ints cf)
             ((Some cfv)
              (match (expr_ints model)
                ((Some modelv)
                 (match (expr_int k)
                   ((Some kv)
                    (match (expr_ints cal)
                      ((Some calv)
                       (match (expr_ints ext)
                         ((Some extv)
                          (Some (PA nv certv cfv modelv kv calv extv)))
                         (_ None)))
                      (_ None)))
                   (_ None)))
                (_ None)))
             (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

(fn dc_arts ((es (List Expr))) (Option (List PArt))
  (measure (struct es))
  (match es
    (Nil (Some Nil))
    ((Cons e rest)
     (match (dc_art e)
       (None None)
       ((Some a)
        (match (dc_arts rest)
          (None None)
          ((Some as_) (Some (Cons a as_)))))))))

(fn dc_mod_lib ((e Expr)) (Option PMod)
  (match (dc_ctor (quote PLib) e)
    ((Some (Cons nm (Cons bytes (Cons arts (Cons vecs Nil)))))
     (match (expr_ints nm)
       ((Some nv)
        (match (expr_ints bytes)
          ((Some bv)
           (match (expr_list arts)
             ((Some aes)
              (match (dc_arts aes)
                ((Some av)
                 (match (expr_list vecs)
                   ((Some ves)
                    (match (dc_vecs ves)
                      ((Some vv) (Some (PLib nv bv av vv)))
                      (_ None)))
                   (_ None)))
                (_ None)))
             (_ None)))
          (_ None)))
       (_ None)))
    (_ None)))

(fn dc_mod ((e Expr)) (Option PMod)
  (match (dc_ctor (quote PM) e)
    ((Some (Cons nm (Cons bytes (Cons arts (Cons vecs Nil)))))
     (match (expr_ints nm)
       ((Some nv)
        (match (expr_ints bytes)
          ((Some bv)
           (match (expr_list arts)
             ((Some aes)
              (match (dc_arts aes)
                ((Some av)
                 (match (expr_list vecs)
                   ((Some ves)
                    (match (dc_vecs ves)
                      ((Some vv) (Some (PM nv bv av vv)))
                      (_ None)))
                   (_ None)))
                (_ None)))
             (_ None)))
          (_ None)))
       (_ None)))
    (_ (dc_mod_lib e))))

(fn dc_mods ((es (List Expr))) (Option (List PMod))
  (measure (struct es))
  (match es
    (Nil (Some Nil))
    ((Cons e rest)
     (match (dc_mod e)
       (None None)
       ((Some m)
        (match (dc_mods rest)
          (None None)
          ((Some ms) (Some (Cons m ms)))))))))

(fn dc_plan ((e Expr)) (Option (List PMod))
  (match (dc_ctor (quote MkPlan) e)
    ((Some (Cons mods Nil))
     (match (expr_list mods)
       ((Some mes) (dc_mods mes))
       (_ None)))
    (_ None)))

;; ---------------------------------------------------------------------------
;; rendering — native plan structures -> the wire lines
;; ---------------------------------------------------------------------------

(fn cat ((xs (List (List Int)))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons h t) (append_int h (cat t)))))

(fn hexd ((d Int)) Int (if (lt d 10) (+ 48 d) (+ 87 d)))

(fn hexs ((bs (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons b t) (Cons (hexd (ediv b 16)) (Cons (hexd (mod b 16)) (hexs t))))))

(fn showargs ((xs (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons h t) (append_int " " (append_int (show_int h) (showargs t))))))

(fn art_line ((a PArt)) (List Int)
  (match a
    ((PA nm cert cf model k cal ext)
     (cat
       (list
         "ARTIFACT "
         nm
         " cert="
         cert
         " certfile="
         cf
         " model="
         model
         " export=f"
         (show_int k)
         (match cal
           (Nil "")
           (_ (append_int " callees=" cal)))
         " externs="
         ext
         "\n")))))

;; PXV has no wasm grammar — a plan carrying it under the wasm ISA is a
;; loud refusal (None threads to the driver)
(fn vec_line ((nm (List Int)) (v PVec)) (Option (List Int))
  (match v
    ((PXV _ _ _ _ _) None)
    ((PV k args mem want memout)
     (match mem
       (Nil
         (Some
           (cat
             (list
               "CASE "
               nm
               " f"
               (show_int k)
               (showargs args)
               " -> "
               (show_int want)
               "\n"))))
       (_
         (Some
           (cat
             (list
               "MEMCASE "
               nm
               " f"
               (show_int k)
               (showargs args)
               " MEM "
               (hexs mem)
               " -> "
               (show_int want)
               " "
               (hexs memout)
               "\n"))))))))

(fn vec_lines ((nm (List Int)) (vs (List PVec))) (Option (List Int))
  (measure (struct vs))
  (match vs
    (Nil (Some ""))
    ((Cons v rest)
     (match (vec_line nm v)
       (None None)
       ((Some l)
        (match (vec_lines nm rest)
          (None None)
          ((Some ls) (Some (append_int l ls)))))))))

(fn art_lines ((as_ (List PArt))) (List Int)
  (measure (struct as_))
  (match as_
    (Nil "")
    ((Cons a rest) (append_int (art_line a) (art_lines rest)))))

;; the export name covering index k in the art table (lib rendering)
(fn art_name_at ((as_ (List PArt)) (k Int)) (Option (List Int))
  (measure (struct as_))
  (match as_
    (Nil None)
    ((Cons (PA nm _ _ _ i _ _) rest)
     (if (int_eq i k) (Some nm) (art_name_at rest k)))))

;; a lib vector: the fn field is the export NAME (the named-export wire);
;; a vector whose index no art covers refuses
(fn vec_line_lib ((nm (List Int)) (arts (List PArt)) (v PVec))
  (Option (List Int))
  (match v
    ((PXV _ _ _ _ _) None)
    ((PV k args mem want memout)
     (match (art_name_at arts k)
       (None None)
       ((Some en)
        (match mem
          (Nil
            (Some
              (cat
                (list
                  "CASE "
                  nm
                  " "
                  en
                  (showargs args)
                  " -> "
                  (show_int want)
                  "\n"))))
          (_
            (Some
              (cat
                (list
                  "MEMCASE "
                  nm
                  " "
                  en
                  (showargs args)
                  " MEM "
                  (hexs mem)
                  " -> "
                  (show_int want)
                  " "
                  (hexs memout)
                  "\n"))))))))))

(fn vec_lines_lib ((nm (List Int)) (arts (List PArt)) (vs (List PVec)))
  (Option (List Int))
  (measure (struct vs))
  (match vs
    (Nil (Some ""))
    ((Cons v rest)
     (match (vec_line_lib nm arts v)
       (None None)
       ((Some l)
        (match (vec_lines_lib nm arts rest)
          (None None)
          ((Some ls) (Some (append_int l ls)))))))))

(fn mod_lines ((pm PMod)) (Option (List Int))
  (match pm
    ((PM nm bytes arts vecs)
     (match (vec_lines nm vecs)
       (None None)
       ((Some vls)
        (Some (cat (list (art_lines arts) "MOD " nm " " (hexs bytes) "\n" vls))))))
    ((PLib nm bytes arts vecs)
     (match (vec_lines_lib nm arts vecs)
       (None None)
       ((Some vls)
        (Some (cat (list (art_lines arts) "MOD " nm " " (hexs bytes) "\n" vls))))))))

(fn plan_lines ((ms (List PMod))) (Option (List Int))
  (measure (struct ms))
  (match ms
    (Nil (Some ""))
    ((Cons m rest)
     (match (mod_lines m)
       (None None)
       ((Some l)
        (match (plan_lines rest)
          (None None)
          ((Some ls) (Some (append_int l ls)))))))))

;; ---------------------------------------------------------------------------
;; rendering — the x86 wire grammar (examples/x86_diff.c's plan reader)
;; ---------------------------------------------------------------------------
;; XMOD <name> <hex>
;; XCASE <name> <argc> <a0> <a1> <a2> -> <exp>
;; XMEMCASE <name> <argc> <a0> <a1> <a2> READ <addr> <len> -> <exp> <outhex>
;; Integers are 16-char little-endian hex, exactly three padded arg slots.
;; ARTIFACT lines render the same as wasm's (the manifest gate reads them;
;; the build script filters them out of the CPU replayer's copy). Memory
;; readback vectors ride PXV (an absolute-address window, no init image —
;; the harness's data page starts zeroed); wasm-style init-image vectors
;; (PV with a mem field) and exports beyond f0 stay refusals.

;; low 8 bytes of (n mod 2^64), little-endian
(fn le8b ((n Int)) (List Int)
  (let ((u (mod n 18446744073709551616)))
    (list
      (mod u 256)
      (mod (ediv u 256) 256)
      (mod (ediv u 65536) 256)
      (mod (ediv u 16777216) 256)
      (mod (ediv u 4294967296) 256)
      (mod (ediv u 1099511627776) 256)
      (mod (ediv u 281474976710656) 256)
      (mod (ediv u 72057594037927936) 256))))

(fn hx ((v Int)) (List Int) (hexs (le8b v)))

(fn xargc ((xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ t) (+ 1 (xargc t)))))

;; three padded arg slots, each preceded by one space
(fn xslots ((args (List Int))) (List Int)
  (match args
    (Nil (cat (list " " (hx 0) " " (hx 0) " " (hx 0))))
    ((Cons a0 t0)
     (match t0
       (Nil (cat (list " " (hx a0) " " (hx 0) " " (hx 0))))
       ((Cons a1 t1)
        (match t1
          (Nil (cat (list " " (hx a0) " " (hx a1) " " (hx 0))))
          ((Cons a2 t2) (cat (list " " (hx a0) " " (hx a1) " " (hx a2))))))))))

(fn xvec_line ((nm (List Int)) (v PVec)) (Option (List Int))
  (match v
    ((PV k args mem want memout)
     (match mem
       (Nil
         (if (int_eq k 0)
           (if (le (xargc args) 3)
             (Some
               (cat
                 (list
                   "XCASE "
                   nm
                   " "
                   (show_int (xargc args))
                   (xslots args)
                   " -> "
                   (hx want)
                   "\n")))
             None)
           None))
       (_ None)))
    ((PXV k args addr want outb)
     (if (int_eq k 0)
       (if (le (xargc args) 3)
         (Some
           (cat
             (list
               "XMEMCASE "
               nm
               " "
               (show_int (xargc args))
               (xslots args)
               " READ "
               (hx addr)
               " "
               (hx (xargc outb))
               " -> "
               (hx want)
               " "
               (hexs outb)
               "\n")))
         None)
       None))))

(fn xvec_lines ((nm (List Int)) (vs (List PVec))) (Option (List Int))
  (measure (struct vs))
  (match vs
    (Nil (Some ""))
    ((Cons v rest)
     (match (xvec_line nm v)
       (None None)
       ((Some l)
        (match (xvec_lines nm rest)
          (None None)
          ((Some ls) (Some (append_int l ls)))))))))

(fn xmod_lines ((pm PMod)) (Option (List Int))
  (match pm
    ((PM nm bytes arts vecs)
     (match (xvec_lines nm vecs)
       (None None)
       ((Some vls)
        (Some
          (cat (list (art_lines arts) "XMOD " nm " " (hexs bytes) "\n" vls))))))
    ;; no lib grammar for the x86 wire yet — a PLib under x86 refuses
    ((PLib _ _ _ _) None)))

(fn xplan_lines ((ms (List PMod))) (Option (List Int))
  (measure (struct ms))
  (match ms
    (Nil (Some ""))
    ((Cons m rest)
     (match (xmod_lines m)
       (None None)
       ((Some ls)
        (match (xplan_lines rest)
          (None None)
          ((Some rls) (Some (append_int ls rls)))))))))

;; ---------------------------------------------------------------------------
;; the driver
;; ---------------------------------------------------------------------------

(fn fail ((msg (List Int)) (w World)) World
  (exit 1 (write (append_int "lowbuild: " (append_int msg "\n")) w)))

(fn ceq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        (_ False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (ceq xs ys) False))))))

;; the compile-context per ISA: wasm = the v1 defaults every build
;; hardcoded; x86 = 64-bit values, same declared memory limit
(fn target_val ((tq QName) (xisa Bool)) Expr
  (if xisa
    (Ctor
      tq
      (Cons (SymLit (quote x86)) (Cons (IntLit 65536) (Cons (IntLit 64) Nil))))
    (Ctor
      tq
      (Cons (SymLit (quote wasm)) (Cons (IntLit 65536) (Cons (IntLit 32) Nil))))))

(fn drive ((m Module) (xisa Bool) (w World)) World
  (match (ctor_qn m (quote MkTarget))
    (None
      (fail
        "loaded closure has no Target vocabulary (meta/plan not imported?)"
        w))
    ((Some tq)
     (match (invoke m (quote build) (Cons (target_val tq xisa) Nil))
       (None (fail "no unique `build` fn in the loaded closure" w))
       ((Some pv)
        (match (dc_plan pv)
          (None
            (fail
              "build's result does not decode as a Plan (stuck term or shape mismatch)"
              w))
          ((Some mods)
           (if xisa
             (match (xplan_lines mods)
               (None
                 (fail
                   "x86 plan outside the XCASE/XMEMCASE grammar (wasm memory image, >3 args, or nonzero export)"
                   w))
               ((Some ls) (exit 0 (write ls w))))
             (match (plan_lines mods)
               (None
                 (fail
                   "wasm plan carries an x86 memory vector (PXV) -- build it with ISA x86"
                   w))
               ((Some ls) (exit 0 (write ls w))))))))))))

(fn run_isa ((bpath (List Int)) (xisa Bool) (w World)) World
  (match (load_run_module bpath w)
    ((Pair om w2)
     (match om
       (None (fail "could not load/parse the mod.build closure" w2))
       ((Some m) (drive m xisa w2))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons bpath Nil) (run_isa bpath False w1))
       ((Cons bpath (Cons isa Nil))
        (if (ceq isa "wasm") (run_isa bpath False w1)
        (if (ceq isa "x86") (run_isa bpath True w1)
        (fail "unknown ISA (wasm | x86)" w1))))
       (_ (fail "usage: lowbuild <mod.build path> [wasm | x86]" w1))))))
