;;; tools/invoke/invoke_probe.shard — the DYNAMIC-INVOCATION probe: exercises
;;; meta/invoke end to end. Loads tools/invoke/invoke_fixture.shard's
;;; closure AT RUNTIME (never imports it), then:
;;;   1. calls double with a marshalled IntLit         (scalar in/out)
;;;   2. builds a MkCfg value from the LOADED module's own typedef via
;;;      ctor_qn and calls area with it                (record marshalling)
;;;   3. calls countdown and decodes the object-level list result element
;;;      by element, order included                    (list decoding)
;;;   4. asks for a missing name                       (clean None, no stuck)
;;; Self-checking: prints one OK/FAIL line per case; exit 0 iff all OK.
;;;
;;; RUN IT:  bin/shard_eval run tools/invoke/invoke_probe.shard

(import "../../kernel/stdlib.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/loader.shard")
(import "../../meta/invoke")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel loader *))
(use (:: meta invoke *))

(fn chk ((label (List Int)) (ok Bool)) (List Int)
  (append_int label (if ok " OK\n" " FAIL\n")))

;; decoded-Int equality against an invocation result
(fn ret_int_eq ((r (Option Expr)) (want Int)) Bool
  (match r
    (None False)
    ((Some e)
     (match (expr_int e)
       (None False)
       ((Some n) (int_eq n want))))))

;; decode an invocation result as a (List Int), whole-or-nothing
(fn ret_ints ((r (Option Expr))) (Option (List Int))
  (match r
    (None None)
    ((Some e) (expr_ints e))))

(fn c_double ((m Module)) Bool
  (ret_int_eq (invoke m (quote double) (Cons (IntLit 21) Nil)) 42))

(fn c_area ((m Module)) Bool
  (match (ctor_qn m (quote MkCfg))
    (None False)
    ((Some q)
     (ret_int_eq
       (invoke
         m
         (quote area)
         (Cons (Ctor q (Cons (IntLit 6) (Cons (IntLit 7) Nil))) Nil))
       42))))

(fn c_countdown ((m Module)) Bool
  (match (ret_ints (invoke m (quote countdown) (Cons (IntLit 3) Nil)))
    (None False)
    ((Some ns) (int_list_eq ns (Cons 3 (Cons 2 (Cons 1 Nil)))))))

(fn c_missing ((m Module)) Bool
  (match (find_fn (quote no_such_fn) m)
    (None True)
    (_ False)))

(fn report ((m Module)) (Pair Bool (List Int))
  (let ((b1 (c_double m)))
    (let ((b2 (c_area m)))
      (let ((b3 (c_countdown m)))
        (let ((b4 (c_missing m)))
          (Pair
            (if b1 (if b2 (if b3 b4 False) False) False)
            (append_int
              (chk "invoke double" b1)
              (append_int
                (chk "invoke area(MkCfg)" b2)
                (append_int
                  (chk "invoke countdown decode" b3)
                  (chk "invoke missing-name" b4))))))))))

(fn main ((w World)) World
  (match (load_run_module "tools/invoke/invoke_fixture.shard" w)
    ((Pair om w1)
     (match om
       (None (exit 1 (write "invoke_probe: load failed\n" w1)))
       ((Some m)
        (match (report m)
          ((Pair allok txt) (exit (if allok 0 1) (write txt w1)))))))))
