;;; prove — the proof solver: offline candidate search, persisted as sidecars.
;;;
;;; The first consumer of the kernel-as-library surface: it imports the
;;; checker toolchain as ordinary modules and drives it IN-PROCESS — no
;;; subprocess, no re-parse per attempt (the target module is built ONCE;
;;; each attempt is a focused driver run against it). For every `auto`
;;; claim/fulfills in the target file it searches for a proof and persists
;;; the winners into the file's `<file>.auto.shard` via write_file.
;;;
;;; THE SEARCH: every decl tries the flat ladder first — closed-form
;;; candidates, cheapest closer first (refl / compute / simp / eqdec / ord /
;;; lia). If that fails, structural induction: on the hinted variable for
;;; (auto (induct VAR)), else on each goal parameter in turn (a hint is an
;;; accelerator, not a requirement). Induction synthesis builds each
;;; constructor case's SUBGOAL via the checker's own build_induct_subgoal
;;; and solves each case independently with a case ladder: per-side
;;; unfold/reduce chains over that side's own fn heads (a file may only
;;; unfold fns it owns, which is exactly what a goal's heads are), optional
;;; IH-rewrite tails ((hyp 0)/(hyp 1), lhs or rhs), closed by refl or a
;;; theory backend. The assembled (induct …) proof is verified WHOLE
;;; through the standard driver pass before persisting.
;;;
;;; THE CONTRACT: search happens HERE, offline; `check` only ever REPLAYS
;;; the persisted entries. A solver bug can cost coverage, never soundness —
;;; the sidecar goes through the full untrusted-proof path at check time.
;;;
;;; The sidecar file is MACHINE-OWNED: a rewrite re-renders kept entries
;;; from their parsed form (comments in it are not preserved). An existing
;;; sidecar that does not lex is refused, never clobbered.
;;;
;;; RUN IT:   ./rust_bootstrap/target/release/eval run tools/prove/prove.shard FILE [CLAIM]
;;;           (or `eval direct` — the closure is flat-file imports)
;;;   FILE alone   solve every auto decl that LACKS a sidecar entry
;;;   FILE CLAIM   (re-)solve exactly CLAIM (must be an auto decl in FILE)
;;; exit 0 = nothing left unsolved   1 = some claim resisted the search
;;;      2 = bad usage / unreadable target / unlexable sidecar / module error

(import "../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../kernel/loader.shard")  ; World + I/O externs + resolve_closure
(import "../../kernel/driver.shard")  ; check_production + auto helpers + ClaimOutcome
(import "../../kernel/module.shard")  ; Module / TypeDef / type helpers
(import "../../kernel/term.shard")  ; Expr / QName / chars_of_sym
(import "../../kernel/proof.shard")  ; Goal / Equation / Param
(import "../../kernel/checker.shard")  ; check_sequent / build_induct_subgoal
(import "../../kernel/reader.shard")  ; read_all / SExpr / RCtx / build_module_d

;; the explicit library surface this app consumes (STRICT-mode scoping).
(use (:: kernel loader resolve_closure))
(use (:: kernel loader auto_path_of))
(use (:: kernel loader append_int))
(use (:: kernel loader int_list_eq))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader read_file))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel reader SrcEntry))
(use (:: kernel reader SExpr))
(use (:: kernel reader SInt))
(use (:: kernel reader SSym))
(use (:: kernel reader SStr))
(use (:: kernel reader SList))
(use (:: kernel reader RCtx))
(use (:: kernel reader read_all))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: kernel reader typedef_ctors))
(use (:: kernel reader module_typedefs))
(use (:: kernel driver check_production))
(use (:: kernel driver prelude_ctors))
(use (:: kernel driver is_auto_proof))
(use (:: kernel driver autos_of_forms))
(use (:: kernel driver auto_lookup))
(use (:: kernel driver file_rctx))
(use (:: kernel driver parse_goal_r))
(use (:: kernel driver parse_proof_r))
(use (:: kernel driver lift_sequent))
(use (:: kernel driver ClaimOutcome))
(use (:: kernel driver COPass))
(use (:: kernel driver COFail))
(use (:: kernel driver COTypeFail))
(use (:: kernel checker Sequent))
(use (:: kernel checker check_sequent))
(use (:: kernel checker build_induct_subgoal))
(use (:: kernel checker find_param))
(use (:: kernel checker seq_params))
(use (:: kernel checker TheoryEmpty))
(use (:: kernel module Module))
(use (:: kernel module FnTrie))
(use (:: kernel module TypeDef))
(use (:: kernel module CtorDef))
(use (:: kernel module Type))
(use (:: kernel module type_head))
(use (:: kernel module lookup_typedef))
(use (:: kernel module type_subst_list))
(use (:: kernel module zip_pairs))
(use (:: kernel module trie_lookup))
(use (:: kernel proof Goal))
(use (:: kernel proof Equation))
(use (:: kernel proof Param))
(use (:: kernel proof Proof))
(use (:: kernel term Expr))
(use (:: kernel term QName))
(use (:: kernel term qname_eq))
(use (:: kernel term qn_name))
(use (:: kernel term chars_of_sym))

(fn nl () (List Int) (Cons 10 Nil))  ; "\n"

;; ---- the flat candidate ladder ---------------------------------------------
;; Closed-form candidates only (no goal-specific payload), cheapest first.
;; farkas is deliberately absent: it needs coefficient witnesses — that is
;; search with structure, like the induction synthesis below but unbuilt.
(fn ladder () (List (List Int))
  (list
    "refl"
    "(steps ((compute both)) refl)"
    "(steps ((simp both)) refl)"
    "(by eqdec (list))"
    "(by ord (list))"
    "(by lia (list))"))

;; one (proof-for NAME PROOF) entry, as bytes.
(fn sidecar_for ((claim (List Int)) (cand (List Int))) (List Int)
  (append_int
    "(proof-for "
    (append_int claim (append_int " " (append_int cand ")")))))

;; ---- s-expression printer (re-render KEPT sidecar entries on merge) --------
(fn show_nat_p ((n Int)) (List Int)  ; n >= 0
  (if (lt n 10)
    (Cons (+ 48 n) Nil)
    (append_int (show_nat_p (/ n 10)) (Cons (+ 48 (mod n 10)) Nil))))

(fn show_int_p ((n Int)) (List Int)
  (if (lt n 0) (Cons 45 (show_nat_p (- 0 n))) (show_nat_p n)))

;; escape exactly what the reader's lexer unescapes: \" \\ \n \t \r.
(fn esc_str ((bs (List Int))) (List Int)
  (match bs
    (Nil Nil)
    ((Cons c rest)
     (if (int_eq c 34) (Cons 92 (Cons 34 (esc_str rest)))
     (if (int_eq c 92) (Cons 92 (Cons 92 (esc_str rest)))
     (if (int_eq c 10) (Cons 92 (Cons 110 (esc_str rest)))
     (if (int_eq c 9) (Cons 92 (Cons 116 (esc_str rest)))
     (if (int_eq c 13) (Cons 92 (Cons 114 (esc_str rest)))
     (Cons c (esc_str rest))))))))))

(fn sx_print ((s SExpr)) (List Int)
  (match s
    ((SInt n) (show_int_p n))
    ((SSym y) (chars_of_sym y))
    ((SStr bs) (Cons 34 (append_int (esc_str bs) (Cons 34 Nil))))
    ((SList items) (Cons 40 (append_int (sx_items items) (Cons 41 Nil))))))

(fn sx_items ((xs (List SExpr))) (List Int)
  (match xs
    (Nil Nil)
    ((Cons x Nil) (sx_print x))
    ((Cons x rest) (append_int (sx_print x) (Cons 32 (sx_items rest))))))

;; ---- target scan: the auto decls, with hint + goal --------------------------
;; (auto HINT…): the tail is solver-directed. Recognized today:
;;   (induct VAR) — synthesize a structural induction on VAR.
(type Hint (HNone) (HInduct Symbol))

;; name, hint, and the goal s-expr when recoverable (a claim carries its own;
;; a fulfills' goal is looked up from a same-file (requirement NAME GOAL)).
(type AutoDecl (AutoDecl Symbol Hint (Option SExpr)))

(fn hint_of ((proofS SExpr)) Hint
  (match proofS
    ((SList (Cons _ hints))
     (match hints
       ((Cons (SList (Cons (SSym hh) (Cons (SSym v) Nil))) _)
        (if (sym_eq hh (quote induct)) (HInduct v) (HNone)))
       (_ (HNone))))
    (_ (HNone))))

(fn req_goal_of ((name Symbol) (forms (List SExpr))) (Option SExpr)
  (match forms
    (Nil None)
    ((Cons f rest)
     (match f
       ((SList (Cons (SSym h) (Cons (SSym n) (Cons goalS Nil))))
        (if (sym_eq h (quote requirement))
          (if (sym_eq n name) (Some goalS) (req_goal_of name rest))
          (req_goal_of name rest)))
       (_ (req_goal_of name rest))))))

(fn auto_decl_of ((f SExpr) (forms (List SExpr))) (Option AutoDecl)
  (match f
    ((SList (Cons (SSym h) (Cons (SSym name) (Cons goalS (Cons proofS Nil)))))
     (if (sym_eq h (quote claim))
       (if (is_auto_proof proofS)
         (Some (AutoDecl name (hint_of proofS) (Some goalS)))
         None)
       None))
    ((SList (Cons (SSym h) (Cons (SSym name) (Cons proofS Nil))))
     (if (sym_eq h (quote fulfills))
       (if (is_auto_proof proofS)
         (Some (AutoDecl name (hint_of proofS) (req_goal_of name forms)))
         None)
       None))
    (_ None)))

(fn auto_decls ((fs (List SExpr)) (forms (List SExpr))) (List AutoDecl)
  (match fs
    (Nil Nil)
    ((Cons f rest)
     (match (auto_decl_of f forms)
       (None (auto_decls rest forms))
       ((Some d) (Cons d (auto_decls rest forms)))))))

(fn decl_name ((d AutoDecl)) Symbol
  (match d
    ((AutoDecl n _ _) n)))

(fn find_decl ((n Symbol) (ds (List AutoDecl))) (Option AutoDecl)
  (match ds
    (Nil None)
    ((Cons d rest) (if (sym_eq (decl_name d) n) (Some d) (find_decl n rest)))))

;; the target's own source bytes within the resolved closure.
(fn src_of ((path (List Int)) (srcs (List SrcEntry))) (Option (List Int))
  (match srcs
    (Nil None)
    ((Cons (SrcEntry p _ s) rest)
     (if (int_list_eq path p) (Some s) (src_of path rest)))))

;; ---- one focused in-process attempt (whole-file driver pass) ---------------
(fn outcome_of ((cn Symbol) (os (List ClaimOutcome))) (Option Bool)
  (match os
    (Nil None)
    ((Cons o rest)
     (match o
       ((COPass n _) (if (sym_eq n cn) (Some True) (outcome_of cn rest)))
       ((COFail n _ _) (if (sym_eq n cn) (Some False) (outcome_of cn rest)))
       ((COTypeFail n _) (if (sym_eq n cn) (Some False) (outcome_of cn rest)))
       (_ (outcome_of cn rest))))))

;; solver context: everything one attempt needs, bundled once per run.
(type Slv
  (Slv
    Module  ; the target's module, built once
    (List SrcEntry)  ; the resolved closure
    (List Symbol)  ; its ctor set
    Symbol  ; pathkey — the target's sidecar key
    RCtx))  ; the target file's resolution context

(fn slv_m ((s Slv)) Module
  (match s
    ((Slv m _ _ _ _) m)))
(fn slv_rctx ((s Slv)) RCtx
  (match s
    ((Slv _ _ _ _ r) r)))

;; does CANDIDATE close NAME? One focus-mode driver pass with the candidate
;; spliced in as a synthetic sidecar entry — the full real pipeline (theory,
;; desugar, tc), so a True here is exactly "check would accept it".
(fn attempt ((s Slv) (name Symbol) (cand (List Int))) Bool
  (match s
    ((Slv m srcs ctors pathkey _)
     (match
       (outcome_of
         name
         (check_production
           m
           srcs
           ctors
           (Cons (Pair pathkey (sidecar_for (chars_of_sym name) cand)) Nil)
           (quote __no_trace__)
           name))
       ((Some True) True)
       (_ False)))))

(fn try_ladder ((s Slv) (name Symbol) (cands (List (List Int))))
  (Option (List Int))
  (match cands
    (Nil None)
    ((Cons c rest) (if (attempt s name c) (Some c) (try_ladder s name rest)))))

;; ---- induction synthesis (the (induct VAR) hint) ----------------------------
;; Per-case solving goes through the checker's OWN subgoal builder, so what we
;; solve is exactly what the checker will re-derive at replay time. Cases are
;; checked against the EMPTY theory: the case ladder cites no lemmas, and the
;; assembled whole proof is verified through the real driver pass afterward.

;; fn heads reachable in a goal expr that resolve in the module's fn trie —
;; the unfold candidates (a goal's own heads are exactly the fns this file
;; may unfold under the surface discipline).
(fn qn_member ((q QName) (qs (List QName))) Bool
  (match qs
    (Nil False)
    ((Cons x rest) (if (qname_eq x q) True (qn_member q rest)))))

(fn heads_of ((e Expr) (trie FnTrie) (acc (List QName))) (List QName)
  (match e
    ((Call q args)
     (match (trie_lookup q trie)
       (None (heads_of_list args trie acc))
       ((Some _)
        (heads_of_list args trie (if (qn_member q acc) acc (Cons q acc))))))
    ((Ctor _ args) (heads_of_list args trie acc))
    ((If c t e2) (heads_of c trie (heads_of t trie (heads_of e2 trie acc))))
    ((Let bs body) (heads_of body trie (heads_of_list bs trie acc)))
    (_ acc)))

(fn heads_of_list ((es (List Expr)) (trie FnTrie) (acc (List QName)))
  (List QName)
  (match es
    (Nil acc)
    ((Cons e rest) (heads_of_list rest trie (heads_of e trie acc)))))

(fn fn_trie_of ((m Module)) FnTrie
  (match m
    ((Module _ _ _ t) t)))

;; per-side heads, as fn-name bytes: each side's own heads are its unfold
;; vocabulary (Unfold replaces ONE occurrence, so chains with repeats reach
;; nested calls of the same fn).
(fn head_names ((qs (List QName))) (List (List Int))
  (match qs
    (Nil Nil)
    ((Cons q rest) (Cons (chars_of_sym (qn_name q)) (head_names rest)))))

(fn side_heads ((g Goal) (m Module))
  (Pair (List (List Int)) (List (List Int)))
  (match g
    ((Goal _ _ (Equation l r))
     (Pair
       (head_names (heads_of l (fn_trie_of m) Nil))
       (head_names (heads_of r (fn_trie_of m) Nil))))))

(fn append_cands ((a (List (List Int))) (b (List (List Int))))
  (List (List Int))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (append_cands t b)))))

;; ---- case-candidate generation ----------------------------------------------
;; A case candidate is (steps PREFIX TERMINAL). PREFIX = an unfold/reduce
;; chain per side (length <= 2, over that side's own heads) plus an optional
;; IH-rewrite tail; TERMINAL = refl or a theory closer. A candidate whose
;; first step doesn't apply fails immediately, so the breadth stays cheap.

(fn st_unfold ((f (List Int)) (side (List Int))) (List Int)
  (append_int "(unfold " (append_int f (append_int " " (append_int side ")")))))

(fn st_reduce ((side (List Int))) (List Int)
  (append_int "(reduce " (append_int side ")")))

;; (rewrite (hyp I) lr SIDE true ()) — the IH-consumption step. The IHs are
;; (hyp 0)/(hyp 1): a top-level goal lifts with NO hypotheses, so appended
;; IHs land at 0 upward ((hyp 1) exists only for two-recursive-field ctors;
;; elsewhere the candidate just fails).
(fn st_rw_hyp ((i Int) (side (List Int))) (List Int)
  (append_int
    "(rewrite (hyp "
    (append_int
      (show_int_p i)
      (append_int ") lr " (append_int side " true ())")))))

(fn join_sp ((xs (List (List Int)))) (List Int)
  (match xs
    (Nil Nil)
    ((Cons x Nil) x)
    ((Cons x rest) (append_int x (Cons 32 (join_sp rest))))))

(fn steps_cand ((stps (List (List Int))) (terminal (List Int))) (List Int)
  (append_int
    "(steps ("
    (append_int (join_sp stps) (append_int ") " (append_int terminal ")")))))

;; ordered unfold chains over one side's heads: empty, every single, every
;; ordered pair (repeats allowed — nested recursion unfolds one fn twice).
(fn append_chains
  ((a (List (List (List Int)))) (b (List (List (List Int)))))
  (List (List (List Int)))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (append_chains t b)))))

(fn chain_singles ((hs (List (List Int)))) (List (List (List Int)))
  (match hs
    (Nil Nil)
    ((Cons f rest) (Cons (Cons f Nil) (chain_singles rest)))))

(fn chain_pairs_with ((f (List Int)) (hs (List (List Int))))
  (List (List (List Int)))
  (match hs
    (Nil Nil)
    ((Cons g rest) (Cons (Cons f (Cons g Nil)) (chain_pairs_with f rest)))))

(fn chain_pairs ((hs (List (List Int))) (all (List (List Int))))
  (List (List (List Int)))
  (match hs
    (Nil Nil)
    ((Cons f rest)
     (append_chains (chain_pairs_with f all) (chain_pairs rest all)))))

(fn chains2 ((hs (List (List Int)))) (List (List (List Int)))
  (Cons Nil (append_chains (chain_singles hs) (chain_pairs hs hs))))

;; one side's chain as steps: (unfold F side) (reduce side) per link.
(fn chain_steps ((names (List (List Int))) (side (List Int)))
  (List (List Int))
  (match names
    (Nil Nil)
    ((Cons f rest)
     (Cons (st_unfold f side) (Cons (st_reduce side) (chain_steps rest side))))))

;; IH-rewrite tails on a base prefix: none / (hyp 0) into lhs / into rhs /
;; (hyp 0)+(hyp 1) into lhs. An empty base keeps only the rewrite variants
;; (the plain closers already cover it).
(fn ih_variants ((base (List (List Int)))) (List (List (List Int)))
  (append_chains
    (match base
      (Nil Nil)
      (_ (Cons base Nil)))
    (list
      (append_cands base (list (st_rw_hyp 0 "lhs")))
      (append_cands base (list (st_rw_hyp 0 "rhs")))
      (append_cands base (list (st_rw_hyp 0 "lhs") (st_rw_hyp 1 "lhs"))))))

(fn prefixes_loop_r
  ((lc (List (List Int))) (rcs (List (List (List Int)))))
  (List (List (List Int)))
  (match rcs
    (Nil Nil)
    ((Cons rc rest)
     (append_chains
       (ih_variants
         (append_cands (chain_steps lc "lhs") (chain_steps rc "rhs")))
       (prefixes_loop_r lc rest)))))

(fn prefixes_loop
  ((lcs (List (List (List Int)))) (rcs (List (List (List Int)))))
  (List (List (List Int)))
  (match lcs
    (Nil Nil)
    ((Cons lc rest)
     (append_chains (prefixes_loop_r lc rcs) (prefixes_loop rest rcs)))))

;; every prefix: the chain cross-product plus simp-based bases (simp is the
;; gated full normalizer — sometimes it exposes the IH redex in one step).
(fn all_prefixes ((lheads (List (List Int))) (rheads (List (List Int))))
  (List (List (List Int)))
  (append_chains
    (prefixes_loop (chains2 lheads) (chains2 rheads))
    (ih_variants (list "(simp both)"))))

(fn with_terminal ((pfxs (List (List (List Int)))) (terminal (List Int)))
  (List (List Int))
  (match pfxs
    (Nil Nil)
    ((Cons p rest) (Cons (steps_cand p terminal) (with_terminal rest terminal)))))

;; the per-case ladder: cheap closers, then every prefix closed by refl, then
;; the bare theory backends, then every prefix closed by lia (an unfolded /
;; IH-rewritten residual is often linear arithmetic).
(fn case_ladder ((lheads (List (List Int))) (rheads (List (List Int))))
  (List (List Int))
  (let ((pfxs (all_prefixes lheads rheads)))
    (append_cands
      (list
        "refl"
        "(steps ((compute both)) refl)"
        "(steps ((simp both)) refl)")
      (append_cands
        (with_terminal pfxs "refl")
        (append_cands
          (list "(by eqdec (list))" "(by ord (list))" "(by lia (list))")
          (with_terminal pfxs "(by lia (list))"))))))

;; parse one candidate's bytes to a native Proof (against the file's scope).
(fn parse_cand ((m Module) (rctx RCtx) (bytes (List Int))) (Option Proof)
  (match (read_all bytes)
    ((Some (Cons f Nil)) (parse_proof_r m rctx f))
    (_ None)))

;; close one case subgoal with the first candidate that checks.
(fn solve_case
  ((s Slv) (subgoal Sequent) (cands (List (List Int))))
  (Option (List Int))
  (match cands
    (Nil None)
    ((Cons c rest)
     (match (parse_cand (slv_m s) (slv_rctx s) c)
       (None (solve_case s subgoal rest))
       ((Some p)
        (if (check_sequent (slv_m s) TheoryEmpty subgoal p)
          (Some c)
          (solve_case s subgoal rest)))))))

;; one (ctor-name, case-proof) per constructor — names = Nil makes
;; build_induct_subgoal gen-fresh the field params, exactly what the checker
;; does for a surface (case CTOR PROOF) at replay.
(fn solve_cases
  ((s Slv)
   (seq Sequent)
   (v Symbol)
   (vt Type)
   (tenv (List (Pair Symbol Type)))
   (ctors (List CtorDef))
   (cands (List (List Int))))
  (Option (List (Pair (List Int) (List Int))))
  (match ctors
    (Nil (Some Nil))
    ((Cons (CtorDef cname ftypes) rest)
     (match
       (solve_case
         s
         (build_induct_subgoal seq v vt cname Nil (type_subst_list tenv ftypes))
         cands)
       (None None)
       ((Some c)
        (match (solve_cases s seq v vt tenv rest cands)
          (None None)
          ((Some more)
           (Some (Cons (Pair (chars_of_sym (qn_name cname)) c) more)))))))))

(fn render_cases ((cs (List (Pair (List Int) (List Int))))) (List Int)
  (match cs
    (Nil Nil)
    ((Cons (Pair cn pf) rest)
     (append_int
       "(case "
       (append_int
         cn
         (append_int
           " "
           (append_int
             pf
             (append_int
               ")"
               (match rest
                 (Nil Nil)
                 (_ (Cons 32 (render_cases rest))))))))))))

(fn assemble_induct ((v Symbol) (cs (List (Pair (List Int) (List Int)))))
  (List Int)
  (append_int
    "(induct "
    (append_int
      (chars_of_sym v)
      (append_int " (" (append_int (render_cases cs) "))")))))

;; the hinted search: goal → per-ctor subgoals → case ladder each → assemble →
;; verify the WHOLE proof through the real driver pass.
(fn try_induct ((s Slv) (name Symbol) (v Symbol) (goalS SExpr))
  (Option (List Int))
  (match (parse_goal_r (slv_m s) (slv_rctx s) goalS)
    (None None)
    ((Some g)
     (match (lift_sequent g)
       (seq
         (match (find_param v (seq_params seq))
           (None None)
           ((Some (Param _ vt))
            (match (type_head vt)
              (None None)  ; TVar — can't induct
              ((Some (Pair tname targs))
               (match (lookup_typedef tname (slv_m s))
                 (None None)
                 ((Some (TypeDef _ tparams tctors))
                  (match (side_heads g (slv_m s))
                    ((Pair lh rh)
                     (match
                       (solve_cases
                         s
                         seq
                         v
                         vt
                         (zip_pairs tparams targs)
                         tctors
                         (case_ladder lh rh))
                       (None None)
                       ((Some cs)
                        (let ((cand (assemble_induct v cs)))
                          (if (attempt s name cand) (Some cand) None)))))))))))))))))

;; ---- solve loop --------------------------------------------------------------
(type Solved
  (SolvedY Symbol (List Int))  ; claim closed by this candidate
  (SolvedN Symbol))  ; search exhausted

;; unhinted induction: try each goal parameter in turn (try_induct skips
;; non-datatype params on its own).
(fn param_syms ((ps (List Param))) (List Symbol)
  (match ps
    (Nil Nil)
    ((Cons (Param n _) rest) (Cons n (param_syms rest)))))

(fn goal_param_names ((g Goal)) (List Symbol)
  (match g
    ((Goal ps _ _) (param_syms ps))))

(fn try_induct_vars
  ((s Slv) (name Symbol) (vs (List Symbol)) (goalS SExpr))
  (Option (List Int))
  (match vs
    (Nil None)
    ((Cons v rest)
     (match (try_induct s name v goalS)
       ((Some c) (Some c))
       (None (try_induct_vars s name rest goalS))))))

;; the unhinted strategy: flat ladder first (cheap, catches the theory-closable
;; goals), then a structural induction on each goal parameter — a hint is an
;; accelerator, not a requirement.
(fn solve_unhinted ((s Slv) (name Symbol) (mgoal (Option SExpr))) Solved
  (match (try_ladder s name (ladder))
    ((Some c) (SolvedY name c))
    (None
      (match mgoal
        (None (SolvedN name))
        ((Some goalS)
         (match (parse_goal_r (slv_m s) (slv_rctx s) goalS)
           (None (SolvedN name))
           ((Some g)
            (match (try_induct_vars s name (goal_param_names g) goalS)
              ((Some c) (SolvedY name c))
              (None (SolvedN name))))))))))

;; hinted decls run their structural search first; on failure they fall back
;; to the full unhinted strategy (the hinted var is retried there — harmless).
(fn solve_one ((s Slv) (d AutoDecl)) Solved
  (match d
    ((AutoDecl name hint mgoal)
     (match hint
       ((HInduct v)
        (match
          (match mgoal
            ((Some goalS) (try_induct s name v goalS))
            (None None))
          ((Some cand) (SolvedY name cand))
          (None (solve_unhinted s name mgoal))))
       ((HNone) (solve_unhinted s name mgoal))))))

(fn solve_all ((s Slv) (ds (List AutoDecl))) (List Solved)
  (match ds
    (Nil Nil)
    ((Cons d rest) (Cons (solve_one s d) (solve_all s rest)))))

(fn won_names ((rs (List Solved))) (List Symbol)
  (match rs
    (Nil Nil)
    ((Cons r rest)
     (match r
       ((SolvedY n _) (Cons n (won_names rest)))
       ((SolvedN _) (won_names rest))))))

(fn any_unsolved ((rs (List Solved))) Bool
  (match rs
    (Nil False)
    ((Cons r rest)
     (match r
       ((SolvedN _) True)
       (_ (any_unsolved rest))))))

(fn sym_member ((n Symbol) (ns (List Symbol))) Bool
  (match ns
    (Nil False)
    ((Cons x rest) (if (sym_eq x n) True (sym_member n rest)))))

;; ---- sidecar merge + render ---------------------------------------------------
;; kept = existing entries whose claim was NOT re-solved this run.
(fn keep_entries
  ((es (List (Pair Symbol SExpr))) (solved (List Symbol)))
  (List (Pair Symbol SExpr))
  (match es
    (Nil Nil)
    ((Cons (Pair n p) rest)
     (if (sym_member n solved)
       (keep_entries rest solved)
       (Cons (Pair n p) (keep_entries rest solved))))))

(fn render_kept ((es (List (Pair Symbol SExpr)))) (List Int)
  (match es
    (Nil Nil)
    ((Cons (Pair n p) rest)
     (append_int
       (append_int
         "(proof-for "
         (append_int
           (chars_of_sym n)
           (append_int " " (append_int (sx_print p) ")"))))
       (append_int (nl) (render_kept rest))))))

(fn render_wins ((rs (List Solved))) (List Int)
  (match rs
    (Nil Nil)
    ((Cons r rest)
     (match r
       ((SolvedY n c)
        (append_int
          (sidecar_for (chars_of_sym n) c)
          (append_int (nl) (render_wins rest))))
       ((SolvedN _) (render_wins rest))))))

(fn sidecar_header () (List Int)
  (append_int
    ";;; proof sidecar — MACHINE-OWNED, written by tools/prove (comments are"
    (append_int
      (nl)
      (append_int
        ";;; not preserved). check REPLAYS these entries; it never searches."
        (append_int (nl) (nl))))))

(fn render_sidecar
  ((kept (List (Pair Symbol SExpr))) (rs (List Solved)))
  (List Int)
  (append_int (sidecar_header) (append_int (render_kept kept) (render_wins rs))))

;; ---- report -------------------------------------------------------------------
(fn report_lines ((rs (List Solved))) (List Int)
  (match rs
    (Nil Nil)
    ((Cons r rest)
     (append_int
       (match r
         ((SolvedY n c)
          (append_int
            "PROVED   "
            (append_int
              (chars_of_sym n)
              (append_int "  " (append_int c (nl))))))
         ((SolvedN n)
          (append_int
            "UNSOLVED "
            (append_int (chars_of_sym n) (append_int "  (search exhausted)" (nl))))))
       (report_lines rest)))))

(fn fail2 ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

;; ---- the run -------------------------------------------------------------------
;; Solve `todo`, persist winners (merged over the kept existing entries),
;; report, exit. No write when nothing was solved.
(fn solve_run
  ((target (List Int))
   (tsrc (List Int))
   (todo (List AutoDecl))
   (existing (List (Pair Symbol SExpr)))
   (srcs (List SrcEntry))
   (w World))
  World
  (match (build_module_d srcs (Module Nil Nil Nil (FnTrie None Nil)) (prelude_ctors) 1)
    ((BMFail diag) (fail2 diag w))
    ((BMOk m)
     (match
       (solve_all
         (Slv
           m
           srcs
           (typedef_ctors (module_typedefs m))
           (sym_of_chars target)
           (file_rctx m target tsrc))
         todo)
       (rs
         (match (won_names rs)
           (Nil
             (exit
               (if (any_unsolved rs) 1 0)
               (write (report_lines rs) w)))
           (solved
             (match
               (write_file
                 (auto_path_of target)
                 (render_sidecar (keep_entries existing solved) rs)
                 w)
               ((Pair ok w1)
                (if ok
                  (exit
                    (if (any_unsolved rs) 1 0)
                    (write
                      (append_int
                        (report_lines rs)
                        (append_int
                          "wrote "
                          (append_int (auto_path_of target) (nl))))
                      w1))
                  (fail2
                    (append_int "cannot write " (auto_path_of target))
                    w1)))))))))))

;; decls to solve for a whole-file run: auto decls LACKING a sidecar entry.
(fn missing_decls
  ((ds (List AutoDecl)) (existing (List (Pair Symbol SExpr))))
  (List AutoDecl)
  (match ds
    (Nil Nil)
    ((Cons d rest)
     (match (auto_lookup (decl_name d) existing)
       ((Some _) (missing_decls rest existing))
       (None (Cons d (missing_decls rest existing)))))))

;; dispatch once args / closure / sidecar / target-forms are in hand.
(fn run_with
  ((target (List Int))
   (tsrc (List Int))
   (mclaim (Option (List Int)))
   (existing (List (Pair Symbol SExpr)))
   (srcs (List SrcEntry))
   (forms (List SExpr))
   (w World))
  World
  (match (auto_decls forms forms)
    (ds
      (match mclaim
        ((Some cb)
         (match (find_decl (sym_of_chars cb) ds)
           ((Some d) (solve_run target tsrc (Cons d Nil) existing srcs w))
           (None
             (fail2
               (append_int
                 "claim "
                 (append_int cb " is not an `auto` decl in the target"))
               w))))
        (None
          (match (missing_decls ds existing)
            (Nil
              (exit
                0
                (write
                  "nothing to solve (every auto decl has a sidecar entry)\n"
                  w)))
            (todo (solve_run target tsrc todo existing srcs w))))))))

;; ---- the World wrapper: arg0 = target file, arg1 (optional) = claim --------
(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target rest)
        (match
          (match rest
            (Nil (Some None))
            ((Cons cb Nil) (Some (Some cb)))
            (_ None))
          (None (exit 2 (write "usage: prove <file.shard> [claim]\n" w1)))
          ((Some mclaim)
           (match (resolve_closure target False w1)  ; False = CHECK-mode closure
             ((Pair srcs w2)
              (match (src_of target srcs)
                (None (fail2 (append_int "cannot read " target) w2))
                ((Some tsrc)
                 (match (read_all tsrc)
                   (None (fail2 "target does not lex" w2))
                   ((Some forms)
                    (match (read_file (auto_path_of target) w2)
                      ((Pair msc w3)
                       (match msc
                         (None (run_with target tsrc mclaim Nil srcs forms w3))
                         ((Some sbytes)
                          (match (read_all sbytes)
                            (None
                              (fail2
                                (append_int
                                  (auto_path_of target)
                                  " exists but does not lex — refusing to rewrite it")
                                w3))
                            ((Some sforms)
                             (run_with
                               target
                               tsrc
                               mclaim
                               (autos_of_forms sforms)
                               srcs
                               forms
                               w3))))))))))))))))
       (_ (exit 2 (write "usage: prove <file.shard> [claim]\n" w1)))))))
