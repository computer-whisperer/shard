;;; tools/search/rev_obj.shard — the rev task's OBJECT module: the import
;;; closure ground candidates are injected into and evaluated against
;;; (std/list append is the task vocabulary's only fn). Loaded at tool
;;; runtime via meta/invoke's load_run_module; candidates become FnDefs
;;; appended to this closure's Module and run under evm_call_pure.

(import "../../kernel/stdlib.shard")
(import "../../std/list")

;; Candidate execution and theorem canon are configured through the same root
;; scope.  The laws driver explicitly selects this ordered subset; visibility
;; alone never promotes a requirement into its rewrite profile.
(use (:: std list append))
(use (:: std list append_nil_left))
(use (:: std list append_cons))
(use (:: std list append_assoc))
(use (:: std list append_nil_right))
