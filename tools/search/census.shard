;;; tools/search/census.shard — the G1/G2 CANONICALITY CENSUS for the
;;; rev grammars (docs/SEARCH.md S9), against the REAL rule ledger:
;;; kernel/canon's cn_e (consumed, never modified) is the judge.
;;;
;;; Per depth, censused term-by-term:
;;;   PASS A (dialect sweep) — every dialect candidate i:
;;;     - rank(unrank(i)) = i (the addressing round-trip / injectivity);
;;;     - cn_e = Nil (G1: the generator image is recognizer-clean);
;;;     - ranks into the FULL grammar and unranks back expr_eq
;;;       (dialect is a SUBSET of the full space);
;;;     - the I/O battery (the dialect solution census).
;;;   PASS B (full sweep) — every full candidate j:
;;;     - classify by cn_e; every CLEAN candidate must rank into the
;;;       dialect grammar and unrank back expr_eq (the quotient misses
;;;       NOTHING the recognizer admits).
;;; Together: dialect set == { cn_e-clean full candidates }, exactly
;;; (G2 quotient exactness), with the counts printed and pinned.
;;;
;;; RUN IT: bin/shard_eval run tools/search/census.shard            (d1 + d2)
;;;         bin/shard_eval run tools/search/census.shard rev N      (depth N)
;;; Pinned lines: FULL/DIALECT/CLEAN, G1 OK, G2 OK, SOLUTIONS dialect.

(import "../../kernel/stdlib.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/canon.shard")
(import "../../meta/sketch")
(import "../../meta/invoke")
(import "rev.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader exit))
(use (:: kernel canon cn_e))
(use (:: kernel canon CViol))
(use (:: meta sketch *))
(use (:: meta invoke *))
(use (:: tools search rev *))

;; ---- pass A: the dialect sweep --------------------------------------------------

(type CzA (CzAErr (List Int)) (CzAOk Int))

(fn cz_dial
  ((k Int)
   (total Int)
   (root Expr)
   (gd Grammar)
   (gf Grammar)
   (m Module)
   (ts (List (Pair (List Int) (List Int))))
   (sols Int))
  CzA
  (measure k)
  (if (le k 0) (CzAOk sols)
  (let ((i (- total k)))
    (match (sk_unrank root gd i)
      ((SkEErr msg) (CzAErr (cz_at "dialect unrank" i msg)))
      ((SkEOk c)
       (match (sk_rank root gd c)
         ((SkCErr msg) (CzAErr (cz_at "dialect roundtrip" i msg)))
         ((SkCOk i2)
          (if (int_eq i2 i)
            (match (cn_e c m)
              (Nil
                (match (sk_rank root gf c)
                  ((SkCErr msg) (CzAErr (cz_at "full membership" i msg)))
                  ((SkCOk jf)
                   (match (sk_unrank root gf jf)
                     ((SkEErr msg) (CzAErr (cz_at "full unrank" i msg)))
                     ((SkEOk c2)
                      (if (expr_eq c2 c)
                        (let ((fd (cand_fd c)))
                          (cz_dial
                            (- k 1)
                            total
                            root
                            gd
                            gf
                            m
                            ts
                            (if (run_tests (inject m fd) fd ts) (+ sols 1) sols)))
                        (CzAErr
                          (cz_at
                            "full roundtrip"
                            i
                            "full unrank disagrees with the candidate"))))))))
              ((Cons _ _)
               (CzAErr (cz_at "G1" i "recognizer flagged a dialect candidate"))))
            (CzAErr
              (cz_at "dialect roundtrip" i "rank disagrees with the index"))))))))))

;; ---- pass B: the full sweep -----------------------------------------------------

(type CzB (CzBErr (List Int)) (CzBOk Int))

(fn cz_full
  ((k Int)
   (total Int)
   (root Expr)
   (gf Grammar)
   (gd Grammar)
   (m Module)
   (clean Int))
  CzB
  (measure k)
  (if (le k 0) (CzBOk clean)
  (let ((j (- total k)))
    (match (sk_unrank root gf j)
      ((SkEErr msg) (CzBErr (cz_at "full unrank" j msg)))
      ((SkEOk c)
       (match (cn_e c m)
         (Nil
           (match (sk_rank root gd c)
             ((SkCErr msg)
              (CzBErr (cz_at "G2 clean candidate outside the dialect" j msg)))
             ((SkCOk id)
              (match (sk_unrank root gd id)
                ((SkEErr msg) (CzBErr (cz_at "dialect unrank" j msg)))
                ((SkEOk c2)
                 (if (expr_eq c2 c)
                   (cz_full (- k 1) total root gf gd m (+ clean 1))
                   (CzBErr
                     (cz_at
                       "dialect roundtrip"
                       j
                       "dialect unrank disagrees with the candidate"))))))))
         ((Cons _ _) (cz_full (- k 1) total root gf gd m clean))))))))

;; ---- driver --------------------------------------------------------------------

(fn run_census ((m Module) (apq QName) (d Int) (w World)) World
  (let ((root (rev_sketch)) (gf (rev_grammar d apq)) (gd (dial_grammar d apq)))
    (match (sk_count root gf)
      ((SkCErr msg)
       (exit
         1
         (write (append_int "CENSUS FAIL full count: " (append_int msg "\n")) w)))
      ((SkCOk nf)
       (match (sk_count root gd)
         ((SkCErr msg)
          (exit
            1
            (write
              (append_int "CENSUS FAIL dialect count: " (append_int msg "\n"))
              w)))
         ((SkCOk nd)
          (match (cz_full nf nf root gf gd m 0)
            ((CzBErr msg) (exit 1 (write (append_int "CENSUS FAIL " msg) w)))
            ((CzBOk clean)
             (match (cz_dial nd nd root gd gf m (rev_tests) 0)
               ((CzAErr msg) (exit 1 (write (append_int "CENSUS FAIL " msg) w)))
               ((CzAOk sols)
                (if (int_eq clean nd)
                  (write
                    (append_int
                      "CENSUS rev DEPTH "
                      (append_int
                        (show_int d)
                        (append_int
                          "\nFULL "
                          (append_int
                            (show_int nf)
                            (append_int
                              " DIALECT "
                              (append_int
                                (show_int nd)
                                (append_int
                                  " CLEAN "
                                  (append_int
                                    (show_int clean)
                                    (append_int
                                      "\nG1 OK\nG2 OK\nSOLUTIONS dialect "
                                      (append_int (show_int sols) "\n"))))))))))
                    w)
                  (exit
                    1
                    (write "CENSUS FAIL: clean count != dialect count\n" w)))))))))))))

;; args: none -> the pinned suite (d1 then d2); "rev N" -> depth N
(fn cz_args ((as (List (List Int))) (m Module) (apq QName) (w World)) World
  (match as
    (Nil (run_census m apq 2 (run_census m apq 1 w)))
    ((Cons a rest)
     (if (int_list_eq a "rev")
       (match rest
         ((Cons ds Nil)
          (match (parse_nat ds)
            (None (exit 2 (write "usage: census [rev N]\n" w)))
            ((Some d) (run_census m apq d w))))
         (_ (exit 2 (write "usage: census [rev N]\n" w))))
       (exit 2 (write "usage: census [rev N]\n" w))))))

(fn main ((w World)) World
  (match (load_run_module "tools/search/rev_obj.shard" w)
    ((Pair om w2)
     (match om
       (None (exit 1 (write "CENSUS FAIL: object module load\n" w2)))
       ((Some m)
        (match (find_fn (quote append) m)
          (None (exit 1 (write "CENSUS FAIL: no append in closure\n" w2)))
          ((Some apfd)
           (match apfd
             ((FnDef apq _ _ _)
              (match (get_args w2)
                ((Pair as w3) (cz_args as m apq w3))))))))))))
