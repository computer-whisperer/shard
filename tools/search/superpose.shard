;;; tools/search/superpose.shard — S4b: the SUPERPOSED CANDIDATE
;;; EXECUTOR
;;; (docs/SEARCH.md S4b, built AS RATIFIED — post-exit ruling
;;; 2026-07-11; named SUPERPOSE, the ledger's own word — "narrow" is
;;; the bootstrap/inner-kernel shard DIALECT's name and stays free). One evaluation runs ALL candidates at once: the
;;; sketch evaluates under a PARTIAL choices assignment; reaching an
;;; unassigned hole BLOCKS, and the region forks once per alternative
;;; — so a test failure prunes an entire subspace (everything
;;; consistent with the partial assignment) in one evaluation, and a
;;; passing region's unconsulted holes are DON'T-CARES covering many
;;; candidates. Settlement is EXACT: found coverage + killed = the
;;; grammar's total, term for term.
;;;
;;; The machine, pure-functionally:
;;;   - a THUNK ARENA (binary trie keyed by node id) with
;;;     CALL-BY-NEED update: forcing a thunk overwrites it with an
;;;     indirection to its value, so shared subterms are paid once
;;;     per region;
;;;   - LAZY evaluation (args allocate as thunks, matches force only
;;;     the scrutinee spine) — that is what makes don't-cares real:
;;;     a hole never demanded is never forked on. For the TOTAL,
;;;     grammar-typed fragments searched here, call-by-need agrees
;;;     with the kernel's call-by-value on every result (totality),
;;;     and the AGREE gate cross-checks every found region's
;;;     representative against kernel/evm anyway;
;;;   - holes are meta/sketch's own reserved-head calls; the grammar
;;;     IS the hole table (D10 ruling: correlation lives HERE, in the
;;;     choices map — the grammar vocabulary stays exact-counting);
;;;   - jobs are meta/sketch `SkRegion`s over the unchanged Grammar: fixed
;;;     choices feed evaluation, forbidden choices stay out of evaluator memo
;;;     keys, forks visit only allowed alternatives, and exact settlement uses
;;;     `sk_region_count` (including restrictions below nested alternatives).
;;;
;;; The consulted-choice-set memo and shared arena carry forcing results
;;; across regions.  Exact persistent indexes keep node and thunk lookup from
;;; degenerating into graph-sized association-list scans.
;;;
;;; RUN IT: bin/shard_eval run tools/search/superpose.shard        (d1 + d2 pins)
;;;         bin/shard_eval run tools/search/superpose.shard rev N  (depth N)

(import "../../kernel/stdlib.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reduce.shard")
(import "../../meta/sketch")
(import "../../meta/invoke")
(import "../../meta/search/mod.req.shard")
(import "rev.shard")
(import "search.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel reduce try_step_prim))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader exit))
(use (:: meta sketch *))
(use (:: meta invoke *))
(use (:: meta search *))
(use (:: tools search rev *))
(use (:: tools search search *))

;; ---- the node arena: a binary trie keyed by node id -------------------------

(type Node
  (SuThunk Expr (List Int))  ; unevaluated: expr + env of node ids
  (SuInd Int)  ; forced: indirection to the value node
  (SuInt Int)
  (SuQuote Symbol)
  (SuCtor QName (List Int)))  ; fields are LAZY node ids

(type SuBr (SuBLeaf) (SuBNode (Option Node) SuBr SuBr))

;; ids address the trie by the bits of (id+1), LSB first, stopping at 1
(fn sb_get ((t SuBr) (j Int) (fuel Int)) (Option Node)
  (measure fuel)
  (if (lt fuel 1) None
  (match t
    ((SuBLeaf) None)
    ((SuBNode v l r)
     (if (le j 1) v
     (if (int_eq (mod j 2) 0) (sb_get l (ediv j 2) (- fuel 1))
     (sb_get r (ediv j 2) (- fuel 1))))))))

(fn sb_set ((t SuBr) (j Int) (n Node) (fuel Int)) SuBr
  (measure fuel)
  (if (lt fuel 1) t
  (match t
    ((SuBLeaf)
     (if (le j 1) (SuBNode (Some n) (SuBLeaf) (SuBLeaf))
     (if (int_eq (mod j 2) 0)
       (SuBNode None (sb_set (SuBLeaf) (ediv j 2) n (- fuel 1)) (SuBLeaf))
       (SuBNode None (SuBLeaf) (sb_set (SuBLeaf) (ediv j 2) n (- fuel 1))))))
    ((SuBNode v l r)
     (if (le j 1) (SuBNode (Some n) l r)
     (if (int_eq (mod j 2) 0) (SuBNode v (sb_set l (ediv j 2) n (- fuel 1)) r)
     (SuBNode v l (sb_set r (ediv j 2) n (- fuel 1)))))))))

;; arena: next id + trie
;; THE CONSULTED-CHOICE-SET MEMO (S4b's ratified second half): the
;; arena is shared across every region of a drive; thunks are INTERNED
;; by (expr, env), so distinct regions reach the same nodes; a
;; completed forcing records WHICH holes it consulted at WHICH
;; choices, and any later region agreeing on exactly that set replays
;; the result without evaluating. A forcing that consulted NOTHING is
;; region-independent — it updates to a plain indirection instead
;; (paid once for the whole drive). Blocked forcings record nothing.
(type SuMR (SuMFail) (SuMVal Int))

(type SuRow (SuRow (List Int) (List (Pair Int Int)) SuMR))

(type SuRowBr (SuRowLeaf) (SuRowNode (Option (List SuRow)) SuRowBr SuRowBr))

(type SuMe (SuMe (List Int) SuRowBr))

;; Exact persistent indexes for the two arena tables that grow with the
;; narrowing graph.  The original association lists made each memo/thunk
;; lookup linear in the number of graph nodes, which dominates deeper search
;; even when theorem pressure has already made the semantic frontier small.
(type SuMmBr (SuMmLeaf) (SuMmNode (Option (List SuMe)) SuMmBr SuMmBr))

(type SuTcRow (SuTcRow Int (List Int) Int))  ; expr id, exact env, node id

(type SuTcBr (SuTcLeaf) (SuTcNode (Option (List SuTcRow)) SuTcBr SuTcBr))

;; next id, node trie, eval steps, memo (node -> entries),
;; expr-intern table, thunk cache (expr id -> env -> node),
;; the CURRENT forcing's consulted (hole, choice) set
(type SuA
  (SuA Int SuBr Int SuMmBr (List (Pair Expr Int)) SuTcBr (List (Pair Int Int))))

(fn sa_new () SuA (SuA 0 (SuBLeaf) 0 (SuMmLeaf) Nil (SuTcLeaf) Nil))

(fn sa_alloc ((a SuA) (n Node)) (Pair Int SuA)
  (match a
    ((SuA sz t k mm te tc cs)
     (Pair sz (SuA (+ sz 1) (sb_set t (+ sz 1) n 64) k mm te tc cs)))))

(fn sa_get ((a SuA) (i Int)) (Option Node)
  (match a
    ((SuA _ t _ _ _ _ _) (sb_get t (+ i 1) 64))))

(fn sa_put ((a SuA) (i Int) (n Node)) SuA
  (match a
    ((SuA sz t k mm te tc cs) (SuA sz (sb_set t (+ i 1) n 64) k mm te tc cs))))

(fn sa_step ((a SuA)) SuA
  (match a
    ((SuA sz t k mm te tc cs) (SuA sz t (+ k 1) mm te tc cs))))

(fn sa_steps ((a SuA)) Int
  (match a
    ((SuA _ _ k _ _ _ _) k)))

(fn sa_nodes ((a SuA)) Int
  (match a
    ((SuA sz _ _ _ _ _ _) sz)))

(fn sa_exprs ((a SuA)) Int
  (match a
    ((SuA _ _ _ _ te _ _) (te_len te))))

;; record a hole consultation (dedup by hole id)
(fn cs_add ((cs (List (Pair Int Int))) (h Int) (c Int)) (List (Pair Int Int))
  (measure (struct cs))
  (match cs
    (Nil (Cons (Pair h c) Nil))
    ((Cons (Pair k v) rest)
     (if (int_eq k h) (Cons (Pair k v) rest)
     (Cons (Pair k v) (cs_add rest h c))))))

(fn cs_merge ((from (List (Pair Int Int))) (into (List (Pair Int Int))))
  (List (Pair Int Int))
  (measure (struct from))
  (match from
    (Nil into)
    ((Cons (Pair h c) rest) (cs_merge rest (cs_add into h c)))))

(fn sa_consult ((a SuA) (h Int) (c Int)) SuA
  (match a
    ((SuA sz t k mm te tc cs) (SuA sz t k mm te tc (cs_add cs h c)))))

;; swap out the current consulted set (fresh forcing begins)
(fn sa_take_cs ((a SuA)) (Pair (List (Pair Int Int)) SuA)
  (match a
    ((SuA sz t k mm te tc cs) (Pair cs (SuA sz t k mm te tc Nil)))))

;; merge a saved consulted set back in
(fn sa_give_cs ((a SuA) (saved (List (Pair Int Int)))) SuA
  (match a
    ((SuA sz t k mm te tc cs) (SuA sz t k mm te tc (cs_merge saved cs)))))

(fn sa_cs ((a SuA)) (List (Pair Int Int))
  (match a
    ((SuA _ _ _ _ _ _ cs) cs)))

(fn sa_mm ((a SuA)) SuMmBr
  (match a
    ((SuA _ _ _ mm _ _ _) mm)))

;; ---- expr interning + the thunk cache ---------------------------------------

(fn te_find ((te (List (Pair Expr Int))) (e Expr)) (Option Int)
  (measure (struct te))
  (match te
    (Nil None)
    ((Cons (Pair k v) rest) (if (expr_eq k e) (Some v) (te_find rest e)))))

(fn te_len ((te (List (Pair Expr Int)))) Int
  (measure (struct te))
  (match te
    (Nil 0)
    ((Cons _ t) (+ 1 (te_len t)))))

(fn tc_hash_go ((env (List Int)) (acc Int)) Int
  (measure (struct env))
  (match env
    (Nil acc)
    ((Cons h rest) (tc_hash_go rest (mod (+ (* acc 65599) (+ h 1)) 2147483647)))))

(fn tc_key ((eid Int) (env (List Int))) Int
  (mod (+ (* (+ eid 1) 1000003) (tc_hash_go env 17)) 2147483647))

(fn tcb_get ((t SuTcBr) (j Int) (fuel Int)) (Option (List SuTcRow))
  (measure fuel)
  (if (lt fuel 1) None
  (match t
    ((SuTcLeaf) None)
    ((SuTcNode v l r)
     (if (le j 1) v
     (if (int_eq (mod j 2) 0) (tcb_get l (ediv j 2) (- fuel 1))
     (tcb_get r (ediv j 2) (- fuel 1))))))))

(fn tcb_set ((t SuTcBr) (j Int) (rows (List SuTcRow)) (fuel Int)) SuTcBr
  (measure fuel)
  (if (lt fuel 1) t
  (match t
    ((SuTcLeaf)
     (if (le j 1) (SuTcNode (Some rows) (SuTcLeaf) (SuTcLeaf))
     (if (int_eq (mod j 2) 0)
       (SuTcNode
         None
         (tcb_set (SuTcLeaf) (ediv j 2) rows (- fuel 1))
         (SuTcLeaf))
       (SuTcNode
         None
         (SuTcLeaf)
         (tcb_set (SuTcLeaf) (ediv j 2) rows (- fuel 1))))))
    ((SuTcNode v l r)
     (if (le j 1) (SuTcNode (Some rows) l r)
     (if (int_eq (mod j 2) 0)
       (SuTcNode v (tcb_set l (ediv j 2) rows (- fuel 1)) r)
       (SuTcNode v l (tcb_set r (ediv j 2) rows (- fuel 1)))))))))

(fn tc_rows ((rows (List SuTcRow)) (eid Int) (env (List Int))) (Option Int)
  (measure (struct rows))
  (match rows
    (Nil None)
    ((Cons (SuTcRow e k r) rest)
     (if (int_eq e eid) (if (ilist_eq k env) (Some r) (tc_rows rest eid env))
     (tc_rows rest eid env)))))

(fn tc_rows_put ((rows (List SuTcRow)) (eid Int) (env (List Int)) (r Int))
  (List SuTcRow)
  (measure (struct rows))
  (match rows
    (Nil (Cons (SuTcRow eid env r) Nil))
    ((Cons (SuTcRow e k old) rest)
     (if (int_eq e eid)
       (if (ilist_eq k env) (Cons (SuTcRow e k r) rest)
       (Cons (SuTcRow e k old) (tc_rows_put rest eid env r)))
       (Cons (SuTcRow e k old) (tc_rows_put rest eid env r))))))

(fn tc_find ((tc SuTcBr) (eid Int) (env (List Int))) (Option Int)
  (match (tcb_get tc (+ (tc_key eid env) 1) 64)
    (None None)
    ((Some rows) (tc_rows rows eid env))))

(fn tc_put ((tc SuTcBr) (eid Int) (env (List Int)) (r Int)) SuTcBr
  (let ((key (tc_key eid env)))
    (match (tcb_get tc (+ key 1) 64)
      (None (tcb_set tc (+ key 1) (Cons (SuTcRow eid env r) Nil) 64))
      ((Some rows) (tcb_set tc (+ key 1) (tc_rows_put rows eid env r) 64)))))

(fn ilist_eq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        ((Cons _ _) False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (ilist_eq xs ys) False))))))

;; an interning thunk allocator: the SAME (expr, env) is ONE node for
;; the whole drive — that is what lets the memo see regions again
(fn su_thunk1 ((a SuA) (e Expr) (env (List Int))) (Pair Int SuA)
  (match a
    ((SuA sz t k mm te tc cs)
     (match (te_find te e)
       (None
         (match
           (sa_alloc
             (SuA sz t k mm (Cons (Pair e (te_len te)) te) tc cs)
             (SuThunk e env))
           ((Pair r a2)
            (match a2
              ((SuA sz2 t2 k2 mm2 te2 tc2 cs2)
               (Pair
                 r
                 (SuA sz2 t2 k2 mm2 te2 (tc_put tc2 (te_len te) env r) cs2)))))))
       ((Some eid)
        (match (tc_find tc eid env)
          ((Some r) (Pair r a))
          (None
            (match (sa_alloc a (SuThunk e env))
              ((Pair r a2)
               (match a2
                 ((SuA sz2 t2 k2 mm2 te2 tc2 cs2)
                  (Pair r (SuA sz2 t2 k2 mm2 te2 (tc_put tc2 eid env r) cs2)))))))))))))

;; ---- the memo ----------------------------------------------------------------

(fn mmb_get ((t SuMmBr) (j Int) (fuel Int)) (Option (List SuMe))
  (measure fuel)
  (if (lt fuel 1) None
  (match t
    ((SuMmLeaf) None)
    ((SuMmNode v l r)
     (if (le j 1) v
     (if (int_eq (mod j 2) 0) (mmb_get l (ediv j 2) (- fuel 1))
     (mmb_get r (ediv j 2) (- fuel 1))))))))

(fn mmb_set ((t SuMmBr) (j Int) (es (List SuMe)) (fuel Int)) SuMmBr
  (measure fuel)
  (if (lt fuel 1) t
  (match t
    ((SuMmLeaf)
     (if (le j 1) (SuMmNode (Some es) (SuMmLeaf) (SuMmLeaf))
     (if (int_eq (mod j 2) 0)
       (SuMmNode None (mmb_set (SuMmLeaf) (ediv j 2) es (- fuel 1)) (SuMmLeaf))
       (SuMmNode None (SuMmLeaf) (mmb_set (SuMmLeaf) (ediv j 2) es (- fuel 1))))))
    ((SuMmNode v l r)
     (if (le j 1) (SuMmNode (Some es) l r)
     (if (int_eq (mod j 2) 0)
       (SuMmNode v (mmb_set l (ediv j 2) es (- fuel 1)) r)
       (SuMmNode v l (mmb_set r (ediv j 2) es (- fuel 1)))))))))

(fn mm_find ((mm SuMmBr) (r Int)) (List SuMe)
  (match (mmb_get mm (+ r 1) 64)
    (None Nil)
    ((Some es) es)))

(fn mm_put ((mm SuMmBr) (r Int) (es (List SuMe))) SuMmBr
  (mmb_set mm (+ r 1) es 64))

;; the choices the current assignment gives a hole set (None: one is
;; unassigned, so no entry over that set can apply)
(fn mp_key ((asg (List (Pair Int Int))) (hs (List Int))) (Option (List Int))
  (measure (struct hs))
  (match hs
    (Nil (Some Nil))
    ((Cons h rest)
     (let ((c (ch_get asg h)))
       (if (lt c 0) None
       (match (mp_key asg rest)
         (None None)
         ((Some ks) (Some (Cons c ks)))))))))

(type MpR (MpMiss) (MpHit SuMR (List (Pair Int Int))))

(fn mp_probe ((es (List SuMe)) (asg (List (Pair Int Int)))) MpR
  (measure (struct es))
  (match es
    (Nil (MpMiss))
    ((Cons (SuMe hs rows) rest)
     (match (mp_key asg hs)
       (None (mp_probe rest asg))
       ((Some key)
        (match (mp_rows rows key)
          (None (mp_probe rest asg))
          ((Some (SuRow _ cons res)) (MpHit res cons))))))))

(fn mr_hash_go ((key (List Int)) (acc Int)) Int
  (measure (struct key))
  (match key
    (Nil acc)
    ((Cons h rest) (mr_hash_go rest (mod (+ (* acc 65599) (+ h 1)) 2147483647)))))

(fn srb_get ((t SuRowBr) (j Int) (fuel Int)) (Option (List SuRow))
  (measure fuel)
  (if (lt fuel 1) None
  (match t
    ((SuRowLeaf) None)
    ((SuRowNode v l r)
     (if (le j 1) v
     (if (int_eq (mod j 2) 0) (srb_get l (ediv j 2) (- fuel 1))
     (srb_get r (ediv j 2) (- fuel 1))))))))

(fn srb_set ((t SuRowBr) (j Int) (rows (List SuRow)) (fuel Int)) SuRowBr
  (measure fuel)
  (if (lt fuel 1) t
  (match t
    ((SuRowLeaf)
     (if (le j 1) (SuRowNode (Some rows) (SuRowLeaf) (SuRowLeaf))
     (if (int_eq (mod j 2) 0)
       (SuRowNode
         None
         (srb_set (SuRowLeaf) (ediv j 2) rows (- fuel 1))
         (SuRowLeaf))
       (SuRowNode
         None
         (SuRowLeaf)
         (srb_set (SuRowLeaf) (ediv j 2) rows (- fuel 1))))))
    ((SuRowNode v l r)
     (if (le j 1) (SuRowNode (Some rows) l r)
     (if (int_eq (mod j 2) 0)
       (SuRowNode v (srb_set l (ediv j 2) rows (- fuel 1)) r)
       (SuRowNode v l (srb_set r (ediv j 2) rows (- fuel 1)))))))))

(fn mp_rows_bucket ((rows (List SuRow)) (key (List Int))) (Option SuRow)
  (measure (struct rows))
  (match rows
    (Nil None)
    ((Cons row rest)
     (match row
       ((SuRow k _ _)
        (if (ilist_eq k key) (Some row) (mp_rows_bucket rest key)))))))

(fn mp_rows ((rows SuRowBr) (key (List Int))) (Option SuRow)
  (match (srb_get rows (+ (mr_hash_go key 17) 1) 64)
    (None None)
    ((Some bucket) (mp_rows_bucket bucket key))))

(fn srb_put ((rows SuRowBr) (key (List Int)) (row SuRow)) SuRowBr
  (let ((j (+ (mr_hash_go key 17) 1)))
    (match (srb_get rows j 64)
      (None (srb_set rows j (Cons row Nil) 64))
      ((Some bucket) (srb_set rows j (Cons row bucket) 64)))))

(fn me_record
  ((es (List SuMe))
   (hs (List Int))
   (key (List Int))
   (cons (List (Pair Int Int)))
   (res SuMR))
  (List SuMe)
  (measure (struct es))
  (match es
    (Nil (Cons (SuMe hs (srb_put (SuRowLeaf) key (SuRow key cons res))) Nil))
    ((Cons (SuMe old_hs rows) rest)
     (if (ilist_eq hs old_hs)
       (Cons (SuMe old_hs (srb_put rows key (SuRow key cons res))) rest)
       (Cons (SuMe old_hs rows) (me_record rest hs key cons res))))))

;; record a completed forcing under its consulted set
(fn mm_record ((a SuA) (r Int) (cons (List (Pair Int Int))) (res SuMR)) SuA
  (match a
    ((SuA sz t k mm te tc cs)
     (let ((hs (cs_holes cons)) (key (cs_choices cons)) (es (mm_find mm r)))
       (SuA sz t k (mm_put mm r (me_record es hs key cons res)) te tc cs)))))

(fn cs_holes ((cons (List (Pair Int Int)))) (List Int)
  (measure (struct cons))
  (match cons
    (Nil Nil)
    ((Cons (Pair h _) rest) (Cons h (cs_holes rest)))))

(fn cs_choices ((cons (List (Pair Int Int)))) (List Int)
  (measure (struct cons))
  (match cons
    (Nil Nil)
    ((Cons (Pair _ c) rest) (Cons c (cs_choices rest)))))

;; ---- choices: hole id -> chosen alternative (assoc; -1 = absent) ------------

(fn ch_get ((asg (List (Pair Int Int))) (h Int)) Int
  (measure (struct asg))
  (match asg
    (Nil -1)
    ((Cons (Pair k v) rest) (if (int_eq k h) v (ch_get rest h)))))

(fn ch_set ((asg (List (Pair Int Int))) (h Int) (v Int)) (List (Pair Int Int))
  (Cons (Pair h v) asg))

;; ---- grammar access ----------------------------------------------------------

(fn su_alts ((g Grammar) (h Int)) (Option (List Expr))
  (match g
    ((Grammar es) (su_alts_go es h))))

(fn su_alts_go ((es (List GEnt)) (h Int)) (Option (List Expr))
  (measure (struct es))
  (match es
    (Nil None)
    ((Cons (GEnt id alts) rest)
     (if (int_eq id h) (Some alts) (su_alts_go rest h)))))

;; The proof/counting vocabulary deliberately keeps Grammar as a transparent
;; ascending list.  Evaluation asks for alternatives on every demanded hole,
;; though, so compile that stable scope once per drive into a persistent trie.
;; The original Grammar remains alongside it for exact counting and checked
;; constraint APIs; this is only an operational view of the same entries.
(type SuGBr (SuGLeaf) (SuGNode (Option (List Expr)) SuGBr SuGBr))

(fn sgb_get ((t SuGBr) (j Int) (fuel Int)) (Option (List Expr))
  (measure fuel)
  (if (lt fuel 1) None
  (match t
    ((SuGLeaf) None)
    ((SuGNode v l r)
     (if (le j 1) v
     (if (int_eq (mod j 2) 0) (sgb_get l (ediv j 2) (- fuel 1))
     (sgb_get r (ediv j 2) (- fuel 1))))))))

(fn sgb_set ((t SuGBr) (j Int) (alts (List Expr)) (fuel Int)) SuGBr
  (measure fuel)
  (if (lt fuel 1) t
  (match t
    ((SuGLeaf)
     (if (le j 1) (SuGNode (Some alts) (SuGLeaf) (SuGLeaf))
     (if (int_eq (mod j 2) 0)
       (SuGNode None (sgb_set (SuGLeaf) (ediv j 2) alts (- fuel 1)) (SuGLeaf))
       (SuGNode None (SuGLeaf) (sgb_set (SuGLeaf) (ediv j 2) alts (- fuel 1))))))
    ((SuGNode v l r)
     (if (le j 1) (SuGNode (Some alts) l r)
     (if (int_eq (mod j 2) 0)
       (SuGNode v (sgb_set l (ediv j 2) alts (- fuel 1)) r)
       (SuGNode v l (sgb_set r (ediv j 2) alts (- fuel 1)))))))))

(fn sug_index ((es (List GEnt)) (t SuGBr)) SuGBr
  (measure (struct es))
  (match es
    (Nil t)
    ((Cons (GEnt id alts) rest) (sug_index rest (sgb_set t (+ id 1) alts 64)))))

(type SuSBr
  (SuSLeaf)
  (SuSNode (Option (List SkSchemaAlt)) SuSBr SuSBr))

(fn ssb_get
  ((tree SuSBr) (key Int) (fuel Int)) (Option (List SkSchemaAlt))
  (measure fuel)
  (if (lt fuel 1) None
  (match tree
    ((SuSLeaf) None)
    ((SuSNode value left right)
     (if (le key 1) value
     (if (int_eq (mod key 2) 0)
       (ssb_get left (ediv key 2) (- fuel 1))
       (ssb_get right (ediv key 2) (- fuel 1))))))))

(fn ssb_set
  ((tree SuSBr) (key Int) (alts (List SkSchemaAlt)) (fuel Int)) SuSBr
  (measure fuel)
  (if (lt fuel 1) tree
  (match tree
    ((SuSLeaf)
     (if (le key 1)
       (SuSNode (Some alts) (SuSLeaf) (SuSLeaf))
     (if (int_eq (mod key 2) 0)
       (SuSNode None
         (ssb_set (SuSLeaf) (ediv key 2) alts (- fuel 1)) (SuSLeaf))
       (SuSNode None
         (SuSLeaf) (ssb_set (SuSLeaf) (ediv key 2) alts (- fuel 1))))))
    ((SuSNode value left right)
     (if (le key 1) (SuSNode (Some alts) left right)
     (if (int_eq (mod key 2) 0)
       (SuSNode value (ssb_set left (ediv key 2) alts (- fuel 1)) right)
       (SuSNode value left
         (ssb_set right (ediv key 2) alts (- fuel 1)))))))))

(fn ssb_index ((entries (List SkSchemaEnt)) (tree SuSBr)) SuSBr
  (measure (struct entries))
  (match entries
    (Nil tree)
    ((Cons (SkSchemaEnt schema_id alts) rest)
     (ssb_index rest (ssb_set tree (+ schema_id 1) alts 64)))))

(type SuPBr
  (SuPLeaf)
  (SuPNode (Option (List Bool)) SuPBr SuPBr))

(fn spb_get
  ((tree SuPBr) (key Int) (fuel Int)) (Option (List Bool))
  (measure fuel)
  (if (lt fuel 1) None
  (match tree
    ((SuPLeaf) None)
    ((SuPNode value left right)
     (if (le key 1) value
     (if (int_eq (mod key 2) 0)
       (spb_get left (ediv key 2) (- fuel 1))
       (spb_get right (ediv key 2) (- fuel 1))))))))

(fn spb_set
  ((tree SuPBr) (key Int) (bits (List Bool)) (fuel Int)) SuPBr
  (measure fuel)
  (if (lt fuel 1) tree
  (match tree
    ((SuPLeaf)
     (if (le key 1)
       (SuPNode (Some bits) (SuPLeaf) (SuPLeaf))
     (if (int_eq (mod key 2) 0)
       (SuPNode None
         (spb_set (SuPLeaf) (ediv key 2) bits (- fuel 1)) (SuPLeaf))
       (SuPNode None
         (SuPLeaf) (spb_set (SuPLeaf) (ediv key 2) bits (- fuel 1))))))
    ((SuPNode value left right)
     (if (le key 1) (SuPNode (Some bits) left right)
     (if (int_eq (mod key 2) 0)
       (SuPNode value (spb_set left (ediv key 2) bits (- fuel 1)) right)
       (SuPNode value left
         (spb_set right (ediv key 2) bits (- fuel 1)))))))))

(fn spb_index
  ((facts (List (Pair Int (List Bool)))) (tree SuPBr)) SuPBr
  (measure (struct facts))
  (match facts
    (Nil tree)
    ((Cons (Pair schema_id bits) rest)
     (spb_index rest (spb_set tree (+ schema_id 1) bits 64)))))

(fn sus_schema_id_at
  ((root_schema Int)
   (index SuSBr)
   (occurrence Int)
   (fuel Int))
  (Option Int)
  (measure fuel)
  (if (lt fuel 1) None
  (if (int_eq occurrence 0) (Some root_schema)
  (if (lt occurrence 0) None
  (match (sk_occ_split occurrence)
    ((SkOccSplitErr _) None)
    ((SkOccSplitOk parent edge)
     (match (sus_schema_id_at root_schema index parent (- fuel 1))
       (None None)
       ((Some parent_schema)
        (match (ssb_get index (+ parent_schema 1) 64)
          (None None)
          ((Some alts)
           (match (sks_ref_edge_find edge alts)
             (None None)
             ((Some (SkSchemaRef _ _ child_schema))
              (Some child_schema)))))))))))))

;; Productivity itself belongs to meta/sketch; the executor merely retains the
;; compiled analysis beside its operational view.  Materialized grammars use
;; an alternatives trie.  Regular schema grammars instantiate alternatives
;; from structural occurrence addresses, so no occurrence trie is required.
(type SuG
  (SuGMaterialized Grammar SuGBr SkProductivity)
  (SuGSchema SkSchemaGrammar Int SuSBr SuPBr))

(fn sug_compile ((g Grammar)) SuG
  (match g
    ((Grammar es)
     (SuGMaterialized
       g
       (sug_index es (SuGLeaf))
       (sk_productivity g)))))

(fn sug_compile_schema ((grammar SkSchemaGrammar)) SuG
  (match grammar
    ((SkSchemaGrammar root entries)
     (match (sk_schema_productivity grammar)
       ((SkSchemaProductivity facts)
        (SuGSchema
          grammar
          root
          (ssb_index entries (SuSLeaf))
          (spb_index facts (SuPLeaf))))))))

(fn sug_raw ((g SuG)) Grammar
  (match g
    ((SuGMaterialized raw _ _) raw)
    ;; Counted/census callers never receive a schema language.  Returning the
    ;; empty materialized grammar here keeps that boundary explicit without
    ;; burdening the evaluator's read-only language interface with an Option.
    ((SuGSchema _ _ _ _) (Grammar Nil))))

(fn sug_alts ((g SuG) (h Int)) (Option (List Expr))
  (match g
    ((SuGMaterialized _ index _) (sgb_get index (+ h 1) 64))
    ((SuGSchema _ root index _)
     (match (sus_schema_id_at root index h 1000000)
       (None None)
       ((Some schema_id)
        (match (ssb_get index (+ schema_id 1) 64)
          (None None)
          ((Some alts)
           (match (sks_instantiate_alts h alts)
             ((SkSchemaAltsErr _) None)
             ((SkSchemaAltsOk instantiated) (Some instantiated))))))))))

(fn sug_productive ((g SuG) (h Int) (k Int)) Bool
  (match g
    ((SuGMaterialized _ _ productivity)
     (sk_alt_productive productivity h k))
    ((SuGSchema _ root index productivity)
     (match (sus_schema_id_at root index h 1000000)
       (None False)
       ((Some schema_id)
        (match (spb_get productivity (+ schema_id 1) 64)
          (None False)
          ((Some bits) (sks_nth_bool bits k))))))))

(fn alt_nth ((alts (List Expr)) (k Int)) (Option Expr)
  (measure (struct alts))
  (match alts
    (Nil None)
    ((Cons a rest) (if (le k 0) (Some a) (alt_nth rest (- k 1))))))

(fn alts_len ((alts (List Expr))) Int
  (measure (struct alts))
  (match alts
    (Nil 0)
    ((Cons _ t) (+ 1 (alts_len t)))))

;; ---- counting: consistent candidates under a partial assignment -------------
;; product over an expr's holes: assigned -> the chosen alternative's
;; own count; unassigned -> the entry's total subspace (the sk_count
;; memo, computed once per grammar)

(type CcR (CcRErr (List Int)) (CcROk Int))

(fn cc_expr
  ((g Grammar)
   (memo (List (Pair Int Int)))
   (asg (List (Pair Int Int)))
   (e Expr)
   (fuel Int))
  CcR
  (measure fuel)
  (if (lt fuel 1) (CcRErr "consistent: fuel")
  (match (holes_e e Nil)
    ((SkIdsErr msg) (CcRErr msg))
    ((SkIdsOk hs) (cc_holes g memo asg hs (- fuel 1))))))

(fn cc_holes
  ((g Grammar)
   (memo (List (Pair Int Int)))
   (asg (List (Pair Int Int)))
   (hs (List Int))
   (fuel Int))
  CcR
  (measure fuel)
  (if (lt fuel 1) (CcRErr "consistent: fuel")
  (match hs
    (Nil (CcROk 1))
    ((Cons h rest)
     (match (cc_hole g memo asg h (- fuel 1))
       ((CcRErr msg) (CcRErr msg))
       ((CcROk n)
        (match (cc_holes g memo asg rest (- fuel 1))
          ((CcRErr msg) (CcRErr msg))
          ((CcROk n2) (CcROk (* n n2))))))))))

(fn cc_hole
  ((g Grammar)
   (memo (List (Pair Int Int)))
   (asg (List (Pair Int Int)))
   (h Int)
   (fuel Int))
  CcR
  (measure fuel)
  (if (lt fuel 1) (CcRErr "consistent: fuel")
  (let ((a (ch_get asg h)))
    (if (lt a 0)
      ;; A singleton entry is not a choice boundary.  Descendant holes may
      ;; already be assigned even though this parent was entered
      ;; transparently, so recurse and retain those constraints.
      (match (su_alts g h)
        (None (CcRErr "consistent: unknown hole"))
        ((Some alts)
         (match alts
           ((Cons ae Nil) (cc_expr g memo asg ae (- fuel 1)))
           (_
             (match (memo_find h memo)
               (None (CcRErr "consistent: hole missing from the count memo"))
               ((Some n) (CcROk n)))))))
      (match (su_alts g h)
        (None (CcRErr "consistent: unknown hole"))
        ((Some alts)
         (match (alt_nth alts a)
           (None (CcRErr "consistent: alternative out of range"))
           ((Some ae) (cc_expr g memo asg ae (- fuel 1))))))))))

;; ---- the lazy evaluator (one fueled SCC) -------------------------------------
;; Results thread the arena. Blocked carries the demanded hole.

(type SuR
  (SuRErr (List Int))
  (SuROut)
  (SuRBlocked Int SuA)
  (SuRFail SuA)
  (SuRVal Int SuA))

(type SuL
  (SuLErr (List Int))
  (SuLOut)
  (SuLBlocked Int SuA)
  (SuLFail SuA)
  (SuLVals (List Int) SuA))

;; force a node to WHNF (call-by-need: thunks update to indirections)
(fn su_whnf
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (r Int))
  SuR
  (measure fuel)
  (if (lt fuel 1) (SuROut)
  (match (sa_get a r)
    (None (SuRErr "superpose: dangling node id"))
    ((Some n)
     (match n
       ((SuThunk e env)
        ;; the memo first: a prior forcing whose consulted choices the
        ;; current assignment agrees with replays without evaluating
        (match (mp_probe (mm_find (sa_mm a) r) asg)
          ((MpHit res cons)
           (match res
             ((SuMFail) (SuRFail (sa_give_cs a cons)))
             ((SuMVal v) (SuRVal v (sa_give_cs a cons)))))
          ((MpMiss)
           (match (sa_take_cs a)
             ((Pair saved a1)
              (match (su_eval (- fuel 1) m candq body g asg a1 env e)
                ((SuRErr msg) (SuRErr msg))
                ((SuROut) (SuROut))
                ((SuRBlocked h a2) (SuRBlocked h (sa_give_cs a2 saved)))
                ((SuRFail a2)
                 (SuRFail
                   (sa_give_cs (mm_record a2 r (sa_cs a2) (SuMFail)) saved)))
                ((SuRVal v a2)
                 (match (sa_cs a2)
                   (Nil
                     ;; consulted nothing: region-independent — a plain
                     ;; call-by-need indirection, paid once per drive
                     (SuRVal v (sa_give_cs (sa_put a2 r (SuInd v)) saved)))
                   ((Cons _ _)
                    (SuRVal
                      v
                      (sa_give_cs (mm_record a2 r (sa_cs a2) (SuMVal v)) saved)))))))))))
       ((SuInd v) (su_whnf (- fuel 1) m candq body g asg a v))
       ((SuInt _) (SuRVal r a))
       ((SuQuote _) (SuRVal r a))
       ((SuCtor _ _) (SuRVal r a)))))))

;; evaluate an expr to WHNF under an env of node ids (BVar 0 = head)
(fn su_eval
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (env (List Int))
   (e Expr))
  SuR
  (measure fuel)
  (if (lt fuel 1) (SuROut)
  (let ((a (sa_step a)))
    (match (hole_view e)
      ((HVHole h)
       ;; a HOLE: assigned -> evaluate the chosen alternative in THIS
       ;; env (the fill contract's frame); an unassigned singleton is
       ;; deterministic and can be entered without a branch or consultation;
       ;; any genuinely open choice blocks.
       (let ((c (ch_get asg h)))
         (match (sug_alts g h)
           (None (SuRErr "superpose: unknown hole"))
           ((Some alts)
            (if (lt c 0)
              (match alts
                ((Cons ae Nil) (su_eval (- fuel 1) m candq body g asg a env ae))
                (_ (SuRBlocked h a)))
              (match (alt_nth alts c)
                (None (SuRErr "superpose: alternative out of range"))
                ((Some ae)
                 (su_eval
                   (- fuel 1)
                   m
                   candq
                   body
                   g
                   asg
                   (sa_consult a h c)
                   env
                   ae))))))))
      ((HVBad msg) (SuRErr msg))
      ((HVNot)
       (match e
         ((FVar _) (SuRErr "superpose: free variable"))
         ((BVar k)
          (match (env_nth_i k env)
            (None (SuRErr "superpose: BVar out of scope"))
            ((Some r) (su_whnf (- fuel 1) m candq body g asg a r))))
         ((Ctor q args)
          (match (su_thunks a env args)
            ((Pair rs a2)
             (match (sa_alloc a2 (SuCtor q rs))
               ((Pair r a3) (SuRVal r a3))))))
         ((Call q args)
          (if (qname_eq q candq)
            (match (su_thunks a env args)
              ((Pair rs a2)
               (su_eval (- fuel 1) m candq body g asg a2 (rev_ints rs Nil) body)))
            (match (trie_lookup q (mod_ft_su m))
              ((Some fd)
               (match fd
                 ((FnDef _ _ _ fbody)
                  (match (su_thunks a env args)
                    ((Pair rs a2)
                     (su_eval
                       (- fuel 1)
                       m
                       candq
                       body
                       g
                       asg
                       a2
                       (rev_ints rs Nil)
                       fbody))))))
              (None
                ;; a prim: deep-force the args to ground exprs, step
                ;; through the kernel's own prim table, evaluate the
                ;; ground result
                (match (su_thunks a env args)
                  ((Pair rs a2)
                   (match (su_gexprs (- fuel 1) m candq body g asg a2 rs)
                     ((SuGLErr msg) (SuRErr msg))
                     ((SuGLOut) (SuROut))
                     ((SuGLBlocked h a3) (SuRBlocked h a3))
                     ((SuGLFail a3) (SuRFail a3))
                     ((SuGLOk es a3)
                      (match (try_step_prim (qn_name q) es)
                        (None
                          ;; An untyped grammar can feed a real primitive the
                          ;; wrong ground shapes.  That is a stuck candidate,
                          ;; not an engine error; reject its whole region.
                          (SuRFail a3))
                        ((Some res)
                         (su_eval (- fuel 1) m candq body g asg a3 Nil res)))))))))))
         ((Match scrut arms)
          (match (su_eval (- fuel 1) m candq body g asg a env scrut)
            ((SuRErr msg) (SuRErr msg))
            ((SuROut) (SuROut))
            ((SuRBlocked h a2) (SuRBlocked h a2))
            ((SuRFail a2) (SuRFail a2))
            ((SuRVal sv a2)
             (su_arms (- fuel 1) m candq body g asg a2 env sv arms))))
         ((Let bs bd)
          (match (su_thunks a env bs)
            ((Pair rs a2)
             (su_eval (- fuel 1) m candq body g asg a2 (ext_env_i rs env) bd))))
         ((If c t e2)
          (match (su_eval (- fuel 1) m candq body g asg a env c)
            ((SuRErr msg) (SuRErr msg))
            ((SuROut) (SuROut))
            ((SuRBlocked h a2) (SuRBlocked h a2))
            ((SuRFail a2) (SuRFail a2))
            ((SuRVal cv a2)
             (match (sa_get a2 cv)
               (None (SuRErr "superpose: dangling if condition"))
               ((Some n)
                (match n
                  ((SuCtor cq _)
                   (if (sym_eq (qn_name cq) (quote True))
                     (su_eval (- fuel 1) m candq body g asg a2 env t)
                   (if (sym_eq (qn_name cq) (quote False))
                     (su_eval (- fuel 1) m candq body g asg a2 env e2)
                     (SuRFail a2))))
                  (_ (SuRFail a2))))))))
         ((IntLit k)
          (match (sa_alloc a (SuInt k))
            ((Pair r a2) (SuRVal r a2))))
         ((SymLit s)
          (match (sa_alloc a (SuQuote s))
            ((Pair r a2) (SuRVal r a2))))))))))

;; allocate arg thunks WITHOUT evaluating (laziness lives here)
(fn su_thunks ((a SuA) (env (List Int)) (es (List Expr))) (Pair (List Int) SuA)
  (measure (struct es))
  (match es
    (Nil (Pair Nil a))
    ((Cons e rest)
     (match (su_thunk1 a e env)
       ((Pair r a2)
        (match (su_thunks a2 env rest)
          ((Pair rs a3) (Pair (Cons r rs) a3))))))))

;; first-match arm walk; a Blocked scrutinee position stops the walk
(fn su_arms
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (env (List Int))
   (sv Int)
   (arms (List Arm)))
  SuR
  (measure fuel)
  (if (lt fuel 1) (SuROut)
  (match arms
    (Nil (SuRFail a))
    ((Cons (Arm p b) rest)
     (match (su_pat (- fuel 1) m candq body g asg a p sv)
       ((SuPErr msg) (SuRErr msg))
       ((SuPOut) (SuROut))
       ((SuPBlocked h a2) (SuRBlocked h a2))
       ((SuPFail a2) (SuRFail a2))
       ((SuPNo a2) (su_arms (- fuel 1) m candq body g asg a2 env sv rest))
       ((SuPOk binds a2)
        (su_eval (- fuel 1) m candq body g asg a2 (ext_env_i binds env) b)))))))

(type SuP
  (SuPErr (List Int))
  (SuPOut)
  (SuPBlocked Int SuA)
  (SuPFail SuA)
  (SuPNo SuA)
  (SuPOk (List Int) SuA))

;; match a pattern against a node, forcing only what the pattern
;; inspects; binds are node ids in pattern order
(fn su_pat
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (p Pat)
   (r Int))
  SuP
  (measure fuel)
  (if (lt fuel 1) (SuPOut)
  (match p
    ((PVar) (SuPOk (Cons r Nil) a))
    ((PCtor q ps)
     (match (su_whnf (- fuel 1) m candq body g asg a r)
       ((SuRErr msg) (SuPErr msg))
       ((SuROut) (SuPOut))
       ((SuRBlocked h a2) (SuPBlocked h a2))
       ((SuRFail a2) (SuPFail a2))
       ((SuRVal v a2)
        (match (sa_get a2 v)
          (None (SuPErr "superpose: dangling scrutinee"))
          ((Some n)
           (match n
             ((SuCtor cq fs)
              (if (qname_eq q cq)
                (su_pats (- fuel 1) m candq body g asg a2 ps fs)
                (SuPNo a2)))
             (_ (SuPNo a2))))))))
    ((PInt k)
     (match (su_whnf (- fuel 1) m candq body g asg a r)
       ((SuRErr msg) (SuPErr msg))
       ((SuROut) (SuPOut))
       ((SuRBlocked h a2) (SuPBlocked h a2))
       ((SuRFail a2) (SuPFail a2))
       ((SuRVal v a2)
        (match (sa_get a2 v)
          (None (SuPErr "superpose: dangling scrutinee"))
          ((Some n)
           (match n
             ((SuInt x) (if (int_eq x k) (SuPOk Nil a2) (SuPNo a2)))
             (_ (SuPNo a2))))))))
    ((PSym s)
     (match (su_whnf (- fuel 1) m candq body g asg a r)
       ((SuRErr msg) (SuPErr msg))
       ((SuROut) (SuPOut))
       ((SuRBlocked h a2) (SuPBlocked h a2))
       ((SuRFail a2) (SuPFail a2))
       ((SuRVal v a2)
        (match (sa_get a2 v)
          (None (SuPErr "superpose: dangling scrutinee"))
          ((Some n)
           (match n
             ((SuQuote x) (if (sym_eq x s) (SuPOk Nil a2) (SuPNo a2)))
             (_ (SuPNo a2)))))))))))

(fn su_pats
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (ps (List Pat))
   (rs (List Int)))
  SuP
  (measure fuel)
  (if (lt fuel 1) (SuPOut)
  (match ps
    (Nil
      (match rs
        (Nil (SuPOk Nil a))
        ((Cons _ _) (SuPErr "superpose: pattern arity"))))
    ((Cons p pr)
     (match rs
       (Nil (SuPErr "superpose: pattern arity"))
       ((Cons r rr)
        (match (su_pat (- fuel 1) m candq body g asg a p r)
          ((SuPErr msg) (SuPErr msg))
          ((SuPOut) (SuPOut))
          ((SuPBlocked h a2) (SuPBlocked h a2))
          ((SuPFail a2) (SuPFail a2))
          ((SuPNo a2) (SuPNo a2))
          ((SuPOk binds a2)
           (match (su_pats (- fuel 1) m candq body g asg a2 pr rr)
             ((SuPErr msg) (SuPErr msg))
             ((SuPOut) (SuPOut))
             ((SuPBlocked h a3) (SuPBlocked h a3))
             ((SuPFail a3) (SuPFail a3))
             ((SuPNo a3) (SuPNo a3))
             ((SuPOk binds2 a3) (SuPOk (ints_app binds binds2) a3)))))))))))

(type SuGr
  (SuGErr (List Int))
  (SuGOut)
  (SuGBlocked Int SuA)
  (SuGFail SuA)
  (SuGOk Expr SuA))

;; ground one node to an Expr (deep force)
(fn su_gexpr
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (r Int))
  SuGr
  (measure fuel)
  (if (lt fuel 1) (SuGOut)
  (match (su_whnf (- fuel 1) m candq body g asg a r)
    ((SuRErr msg) (SuGErr msg))
    ((SuROut) (SuGOut))
    ((SuRBlocked h a2) (SuGBlocked h a2))
    ((SuRFail a2) (SuGFail a2))
    ((SuRVal v a2)
     (match (sa_get a2 v)
       (None (SuGErr "superpose: dangling ground node"))
       ((Some n)
        (match n
          ((SuThunk _ _) (SuGErr "superpose: whnf returned a thunk"))
          ((SuInd _) (SuGErr "superpose: whnf returned an indirection"))
          ((SuInt k) (SuGOk (IntLit k) a2))
          ((SuQuote s) (SuGOk (SymLit s) a2))
          ((SuCtor q fs)
           (match (su_gexprs (- fuel 1) m candq body g asg a2 fs)
             ((SuGLErr msg) (SuGErr msg))
             ((SuGLOut) (SuGOut))
             ((SuGLBlocked h a3) (SuGBlocked h a3))
             ((SuGLFail a3) (SuGFail a3))
             ((SuGLOk es a3) (SuGOk (Ctor q es) a3)))))))))))

(type SuGL
  (SuGLErr (List Int))
  (SuGLOut)
  (SuGLBlocked Int SuA)
  (SuGLFail SuA)
  (SuGLOk (List Expr) SuA))

(fn su_gexprs
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (rs (List Int)))
  SuGL
  (measure fuel)
  (if (lt fuel 1) (SuGLOut)
  (match rs
    (Nil (SuGLOk Nil a))
    ((Cons r rest)
     (match (su_gexpr (- fuel 1) m candq body g asg a r)
       ((SuGErr msg) (SuGLErr msg))
       ((SuGOut) (SuGLOut))
       ((SuGBlocked h a2) (SuGLBlocked h a2))
       ((SuGFail a2) (SuGLFail a2))
       ((SuGOk e a2)
        (match (su_gexprs (- fuel 1) m candq body g asg a2 rest)
          ((SuGLErr msg) (SuGLErr msg))
          ((SuGLOut) (SuGLOut))
          ((SuGLBlocked h a3) (SuGLBlocked h a3))
          ((SuGLFail a3) (SuGLFail a3))
          ((SuGLOk es a3) (SuGLOk (Cons e es) a3)))))))))

;; ---- small helpers -----------------------------------------------------------

(fn env_nth_i ((n Int) (env (List Int))) (Option Int)
  (measure (struct env))
  (match env
    (Nil None)
    ((Cons r rest) (if (le n 0) (Some r) (env_nth_i (- n 1) rest)))))

(fn ext_env_i ((binds (List Int)) (env (List Int))) (List Int)
  (measure (struct binds))
  (match binds
    (Nil env)
    ((Cons b rest) (ext_env_i rest (Cons b env)))))

(fn rev_ints ((xs (List Int)) (acc (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_ints t (Cons h acc)))))

(fn ints_app ((xs (List Int)) (ys (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (ints_app t ys)))))

(fn mod_ft_su ((m Module)) FnTrie
  (match m
    ((Module _ _ _ ft _) ft)))


;; ---- test checking -----------------------------------------------------------

(type SuT
  (SuTErr (List Int))
  (SuTOut)
  (SuTBlocked Int SuA)
  (SuTFail SuA)
  (SuTPass SuA))

;; walk the result spine against the expected ints, forcing lazily
(fn su_expect
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (r Int)
   (want (List Int)))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match (su_whnf (- fuel 1) m candq body g asg a r)
    ((SuRErr msg) (SuTErr msg))
    ((SuROut) (SuTOut))
    ((SuRBlocked h a2) (SuTBlocked h a2))
    ((SuRFail a2) (SuTFail a2))
    ((SuRVal v a2)
     (match (sa_get a2 v)
       (None (SuTErr "superpose: dangling result"))
       ((Some n)
        (match n
          ((SuCtor cq fs)
           (if (sym_eq (qn_name cq) (quote Cons))
             (match fs
               ((Cons hf (Cons tf Nil))
                (match want
                  (Nil (SuTFail a2))
                  ((Cons w rest)
                   (match (su_whnf (- fuel 1) m candq body g asg a2 hf)
                     ((SuRErr msg) (SuTErr msg))
                     ((SuROut) (SuTOut))
                     ((SuRBlocked h a3) (SuTBlocked h a3))
                     ((SuRFail a3) (SuTFail a3))
                     ((SuRVal hv a3)
                      (match (sa_get a3 hv)
                        (None (SuTErr "superpose: dangling head"))
                        ((Some hn)
                         (match hn
                           ((SuInt x)
                            (if (int_eq x w)
                              (su_expect
                                (- fuel 1)
                                m
                                candq
                                body
                                g
                                asg
                                a3
                                tf
                                rest)
                              (SuTFail a3)))
                           (_ (SuTFail a3))))))))))
               (_ (SuTErr "superpose: malformed Cons")))
           (if (sym_eq (qn_name cq) (quote Nil))
             (match want
               (Nil (SuTPass a2))
               ((Cons _ _) (SuTFail a2)))
             (SuTFail a2))))
          (_ (SuTFail a2)))))))))

;; one test: the sketch body under (xs = input, acc = Nil)
(fn su_test
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (inp (List Int))
   (want (List Int)))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match (su_thunk1 a (intlist_to_expr inp) Nil)
    ((Pair xsr a2)
     (match (su_thunk1 a2 (Ctor (qn (quote Nil)) Nil) Nil)
       ((Pair accr a3)
        (match
          (su_eval
            (- fuel 1)
            m
            candq
            body
            g
            asg
            a3
            (Cons accr (Cons xsr Nil))
            body)
          ((SuRErr msg) (SuTErr msg))
          ((SuROut) (SuTOut))
          ((SuRBlocked h a4) (SuTBlocked h a4))
          ((SuRFail a4) (SuTFail a4))
          ((SuRVal r a4) (su_expect (- fuel 1) m candq body g asg a4 r want)))))))))

;; the battery, sequential; the arena THREADS across tests (within a
;; region, forced thunks stay forced)
(fn su_tests
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (ts (List (Pair (List Int) (List Int)))))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match ts
    (Nil (SuTPass a))
    ((Cons (Pair inp want) rest)
     (match (su_test (- fuel 1) m candq body g asg a inp want)
       ((SuTErr msg) (SuTErr msg))
       ((SuTOut) (SuTOut))
       ((SuTBlocked h a2) (SuTBlocked h a2))
       ((SuTFail a2) (SuTFail a2))
       ((SuTPass a2) (su_tests (- fuel 1) m candq body g asg a2 rest)))))))

;; Generic value comparison for dynamic tasks.  `want` is an already-invoked
;; ground Shard value; the candidate side stays lazy.  Constructor fields are
;; compared left-to-right, so the first differing observation blocks only on
;; the holes needed to expose that difference and then kills the whole region.
(fn su_expect_expr
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (r Int)
   (want Expr))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match (su_whnf (- fuel 1) m candq body g asg a r)
    ((SuRErr msg) (SuTErr msg))
    ((SuROut) (SuTOut))
    ((SuRBlocked h a2) (SuTBlocked h a2))
    ((SuRFail a2) (SuTFail a2))
    ((SuRVal v a2)
     (match (sa_get a2 v)
       (None (SuTErr "superpose: dangling generic result"))
       ((Some got)
        (match want
          ((IntLit w)
           (match got
             ((SuInt x) (if (int_eq x w) (SuTPass a2) (SuTFail a2)))
             (_ (SuTFail a2))))
          ((SymLit w)
           (match got
             ((SuQuote x) (if (sym_eq x w) (SuTPass a2) (SuTFail a2)))
             (_ (SuTFail a2))))
          ((Ctor wq wes)
           (match got
             ((SuCtor gq ges)
              (if (qname_eq gq wq)
                (su_expect_exprs (- fuel 1) m candq body g asg a2 ges wes)
                (SuTFail a2)))
             (_ (SuTFail a2))))
          (_ (SuTErr "superpose: generic target is not a ground value")))))))))

(fn su_expect_exprs
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (got (List Int))
   (want (List Expr)))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match got
    (Nil
      (match want
        (Nil (SuTPass a))
        ((Cons _ _) (SuTFail a))))
    ((Cons r rest)
     (match want
       (Nil (SuTFail a))
       ((Cons w wrest)
        (match (su_expect_expr (- fuel 1) m candq body g asg a r w)
          ((SuTErr msg) (SuTErr msg))
          ((SuTOut) (SuTOut))
          ((SuTBlocked h a2) (SuTBlocked h a2))
          ((SuTFail a2) (SuTFail a2))
          ((SuTPass a2)
           (su_expect_exprs (- fuel 1) m candq body g asg a2 rest wrest)))))))))

;; Evaluate an arbitrary task query containing the candidate sketch and compare
;; its value lazily with the target.  `candq`/`body` retain the recursive-body
;; substitution seam used by rev; data-program tasks pass an unbound candq.
(fn su_query
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (asg (List (Pair Int Int)))
   (a SuA)
   (query Expr)
   (want Expr))
  SuT
  (measure fuel)
  (if (lt fuel 1) (SuTOut)
  (match (su_eval (- fuel 1) m candq body g asg a Nil query)
    ((SuRErr msg) (SuTErr msg))
    ((SuROut) (SuTOut))
    ((SuRBlocked h a2) (SuTBlocked h a2))
    ((SuRFail a2) (SuTFail a2))
    ((SuRVal r a2) (su_expect_expr (- fuel 1) m candq body g asg a2 r want)))))

;; ---- the region loop -----------------------------------------------------------

(fn su_efuel () Int 200000)

;; Push one job per still-allowed alternative of the demanded hole.  Fixed
;; choices remain the evaluator's ordinary positive assignment map; forbidden
;; choices stay in the region and never contaminate consulted-choice memo keys.
(type SuForkR (SuForkErr (List Int)) (SuForkOk (List SkRegion)))

(fn su_fork
  ((g SuG)
   (alts (List Expr))
   (region SkRegion)
   (h Int)
   (k Int)
   (jobs (List SkRegion)))
  SuForkR
  (measure k)
  (if (lt k 1)
    (if (lt k 0) (SuForkOk jobs)
      (if (sug_productive g h 0)
        (match (sk_region_choose_known region h 0 alts)
          ((SkRegionEditErr msg) (SuForkErr msg))
          ((SkRegionEditEmpty) (SuForkOk jobs))
          ((SkRegionEditOk child) (SuForkOk (Cons child jobs))))
        (SuForkOk jobs)))
    (if (sug_productive g h k)
      (match (sk_region_choose_known region h k alts)
        ((SkRegionEditErr msg) (SuForkErr msg))
        ((SkRegionEditEmpty) (su_fork g alts region h (- k 1) jobs))
        ((SkRegionEditOk child)
         (su_fork g alts region h (- k 1) (Cons child jobs))))
      (su_fork g alts region h (- k 1) jobs))))

(fn su_region_count ((root Expr) (grammar Grammar) (region SkRegion)) CcR
  (match (sk_region_count root grammar region)
    ((SkCErr msg) (CcRErr msg))
    ((SkCOk count) (CcROk count))))

(type SuPartitionCountR
  (SuPartitionCountErr (List Int))
  (SuPartitionCountOk Int Int Int (List SkRegion)))
  ; redex count, clear count, terminal regions, passing regions

(fn su_count_partition_clear
  ((candidate Expr)
   (grammar Grammar)
   (clear (List SkRegion))
   (redex_count Int)
   (clear_count Int)
   (terminals Int)
   (sols (List SkRegion)))
  SuPartitionCountR
  (measure (struct clear))
  (match clear
    (Nil (SuPartitionCountOk redex_count clear_count terminals sols))
    ((Cons region rest)
     (match (sk_region_count candidate grammar region)
       ((SkCErr msg) (SuPartitionCountErr msg))
       ((SkCOk count)
        (su_count_partition_clear
          candidate
          grammar
          rest
          redex_count
          (+ clear_count count)
          (+ terminals 1)
          (Cons region sols)))))))

(fn su_count_partition
  ((candidate Expr)
   (grammar Grammar)
   (redex (List MsCitedRegion))
   (clear (List SkRegion))
   (redex_count Int)
   (terminals Int)
   (sols (List SkRegion)))
  SuPartitionCountR
  (measure (struct redex))
  (match redex
    (Nil
      (su_count_partition_clear
        candidate grammar clear redex_count 0 terminals sols))
    ((Cons (MsCitedRegion _ region) rest)
     (match (sk_region_count candidate grammar region)
       ((SkCErr msg) (SuPartitionCountErr msg))
       ((SkCOk count)
        (su_count_partition
          candidate grammar rest clear (+ redex_count count)
          (+ terminals 1) sols))))))

(type SuS
  (SuSErr (List Int))
  (SuSBudget Int Int Int Int Int Int Int Int (List SkRegion))
  (SuSOk Int Int Int Int Int Int (List SkRegion)))
; budget: found, killed, constraint-killed, regions, forks, steps,
;         nodes, expressions, passing regions
; ok:     found, killed, constraint-killed, regions, forks, steps,
;         passing regions

(fn su_cat ((parts (List (List Int)))) (List Int)
  (measure (struct parts))
  (match parts
    (Nil Nil)
    ((Cons h rest) (append_int h (su_cat rest)))))

(fn su_budget_report
  ((found Int)
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (steps Int)
   (nodes Int)
   (exprs Int))
  (List Int)
  (su_cat
    (list
      "superpose: drive budget exhausted; found "
      (show_int found)
      " killed "
      (show_int killed)
      " constraint-killed "
      (show_int constrained)
      " regions "
      (show_int regions)
      " forks "
      (show_int forks)
      " steps "
      (show_int steps)
      " nodes "
      (show_int nodes)
      " exprs "
      (show_int exprs))))

;; Generic branch-and-prune drive.  `candidate` is used for exact restricted
;; region counting and theorem matching; `query` is what the lazy evaluator
;; executes.
;; Residual checked constraints run first. A definite redex kills the whole
;; consistent region. A blocked constraint does not steal demand from the
;; semantic query: failure may still kill the larger region immediately. Only
;; when the query passes does the constraint's demanded hole become the fork.
;; The public wrapper prepares grammar-stable match facts once; this recursive
;; loop reuses them across every partial-assignment region.
(fn su_drive_query_prepared
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (prepared MsPrepared)
   (query Expr)
   (want Expr)
   (g SuG)
   (memo (List (Pair Int Int)))
   (ar SuA)
   (jobs (List SkRegion))
   (found Int)
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (sols (List SkRegion)))
  SuS
  (measure fuel)
  (if (lt fuel 1)
    (SuSBudget
      found
      killed
      constrained
      regions
      forks
      (sa_steps ar)
      (sa_nodes ar)
      (sa_exprs ar)
      sols)
    (match jobs
      (Nil (SuSOk found killed constrained regions forks (sa_steps ar) sols))
      ((Cons region rest)
       (let ((asg (sk_region_choices region)))
       (match (ms_check_prepared_region 1000000 prepared region candidate)
         ((MsErr msg) (SuSErr msg))
         ((MsRedex _)
          (match (su_region_count candidate (sug_raw g) region)
            ((CcRErr msg) (SuSErr msg))
            ((CcROk n)
             (su_drive_query_prepared
               (- fuel 1)
               m
               candq
               body
               candidate
               prepared
               query
               want
               g
               memo
               ar
               rest
               found
               (+ killed n)
               (+ constrained n)
               (+ regions 1)
               forks
               sols))))
         (constraint_verdict
           (match (su_query (su_efuel) m candq body g asg ar query want)
             ((SuTErr msg) (SuSErr msg))
             ((SuTOut) (SuSErr "superpose: generic evaluation fuel exhausted"))
             ((SuTBlocked h ar2)
              (match (sug_alts g h)
                (None
                  (SuSErr "superpose: generic query blocked on unknown hole"))
                ((Some alts)
                 (match
                   (su_fork g alts region h (- (alts_len alts) 1) rest)
                   ((SuForkErr msg) (SuSErr msg))
                   ((SuForkOk jobs2)
                    (su_drive_query_prepared
                      (- fuel 1)
                      m
                      candq
                      body
                      candidate
                      prepared
                      query
                      want
                      g
                      memo
                      ar2
                      jobs2
                      found
                      killed
                      constrained
                      regions
                      (+ forks 1)
                      sols))))))
             ((SuTFail ar2)
              (match (su_region_count candidate (sug_raw g) region)
                ((CcRErr msg) (SuSErr msg))
                ((CcROk n)
                 (su_drive_query_prepared
                   (- fuel 1)
                   m
                   candq
                   body
                   candidate
                   prepared
                   query
                   want
                   g
                   memo
                   ar2
                   rest
                   found
                   (+ killed n)
                   constrained
                   (+ regions 1)
                   forks
                   sols))))
             ((SuTPass ar2)
              (match constraint_verdict
                ((MsBlocked h)
                 ;; The semantic query passed without demanding the theorem's
                 ;; blocked choice.  Every refinement therefore preserves that
                 ;; pass.  Finish the theorem-only relation tree now, coalescing
                 ;; equal verdict classes into exact restricted regions.
                 (match
                   (ms_partition_prepared 1000000 prepared region candidate)
                   ((MsPlanPartitionErr msg) (SuSErr msg))
                   ((MsPlanPartitionOk redex clear partition_forks)
                    (match
                      (su_count_partition
                        candidate (sug_raw g) redex clear 0 0 sols)
                      ((SuPartitionCountErr msg) (SuSErr msg))
                      ((SuPartitionCountOk
                         redex_count clear_count terminals sols2)
                       (su_drive_query_prepared
                         (- fuel 1)
                         m
                         candq
                         body
                         candidate
                         prepared
                         query
                         want
                         g
                         memo
                         ar2
                         rest
                         (+ found clear_count)
                         (+ killed redex_count)
                         (+ constrained redex_count)
                         (+ regions terminals)
                         (+ forks partition_forks)
                         sols2))))))
                ((MsClear)
                 (match (su_region_count candidate (sug_raw g) region)
                   ((CcRErr msg) (SuSErr msg))
                   ((CcROk n)
                    (su_drive_query_prepared
                      (- fuel 1)
                      m
                      candq
                      body
                      candidate
                      prepared
                      query
                      want
                      g
                      memo
                      ar2
                      rest
                      (+ found n)
                      killed
                      constrained
                      (+ regions 1)
                      forks
                      (Cons region sols)))))
                ((MsErr msg) (SuSErr msg))
                ((MsRedex _)
                 (SuSErr "superpose: inconsistent residual verdict"))))))))))))

(fn su_drive_query
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (constraints MsPlan)
   (query Expr)
   (want Expr)
   (g Grammar)
   (memo (List (Pair Int Int)))
   (ar SuA)
   (jobs (List SkRegion))
   (found Int)
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (sols (List SkRegion)))
  SuS
  (match (ms_prepare 1000000 constraints g)
    ((MsPrepareErr msg)
     (SuSErr (append_int "superpose: constraint preparation: " msg)))
    ((MsPrepareOk prepared)
     (su_drive_query_prepared
       fuel
       m
       candq
       body
       candidate
       prepared
       query
       want
       (sug_compile g)
       memo
       ar
       jobs
       found
       killed
       constrained
       regions
       forks
       sols))))

;; ---- cardinality-free first-result drive ----------------------------------
;;
;; Exact found/killed weights are a census concern.  A synthesis run looking
;; for one passing program must not multiply every untouched sibling subspace
;; merely to discard it.  This drive retains the same restricted regions,
;; evaluator, prepared checked constraints, and demand-order forks, but counts
;; terminal regions rather than their members and stops at the first clear
;; passing region.

(type SuFind
  (SuFindErr (List Int))
  (SuFindBudget Int Int Int Int Int Int Int)
  (SuFindEmpty Int Int Int Int Int Int Int)
  (SuFindFound Int Int Int Int Int SkRegion Expr))
; budget/empty: killed regions, constraint regions, terminal regions, forks,
;               evaluator steps, arena nodes, arena expressions
; found:        killed regions, constraint regions, terminal regions, forks,
;               evaluator steps, passing region, productive representative

(fn su_find_budget_report
  ((killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (steps Int)
   (nodes Int)
   (exprs Int))
  (List Int)
  (su_cat
    (list
      "superpose: first-result budget exhausted; killed-regions "
      (show_int killed)
      " constraint-regions "
      (show_int constrained)
      " terminal-regions "
      (show_int regions)
      " forks "
      (show_int forks)
      " steps "
      (show_int steps)
      " nodes "
      (show_int nodes)
      " exprs "
      (show_int exprs))))

(fn su_cited_region_len ((regions (List MsCitedRegion))) Int
  (measure (struct regions))
  (match regions
    (Nil 0)
    ((Cons _ rest) (+ 1 (su_cited_region_len rest)))))

;; Representative selection shares the driver's compiled productivity view.
;; An unconsulted hole may still have a syntactically admitted but barren first
;; production at the depth boundary; choosing the first *productive* allowed
;; alternative keeps first-result extraction cardinality-free and exact.
(type SuFirstAltR (SuFirstAltErr (List Int)) (SuFirstAltOk Expr))

(fn su_first_alt
  ((hole_id Int)
   (index Int)
   (alts (List Expr))
   (g SuG)
   (region SkRegion))
  SuFirstAltR
  (measure (struct alts))
  (match alts
    (Nil (SuFirstAltErr "region has no productive permitted alternative"))
    ((Cons alt rest)
     (let
       ((selected
          (match (skr_choice hole_id region)
            ((Some chosen) (int_eq chosen index))
            (None True))))
       (if
         (if selected
           (if (skr_forbidden hole_id index region)
             True
             (if (sug_productive g hole_id index) False True))
           True)
         (su_first_alt hole_id (+ index 1) rest g region)
         (SuFirstAltOk alt))))))

(type SuFirstExprR
  (SuFirstExprErr (List Int))
  (SuFirstExprOk Expr))

(type SuFirstListR
  (SuFirstListErr (List Int))
  (SuFirstListOk (List Expr)))

(type SuFirstArmsR
  (SuFirstArmsErr (List Int))
  (SuFirstArmsOk (List Arm)))

;; Close a productive region directly through the language interface.  The
;; old representative pass scanned every entry of a materialized occurrence
;; grammar.  Structural occurrence addresses make recursive closure both more
;; general and proportional only to the selected candidate.
(fn su_first_expr
  ((fuel Int) (g SuG) (region SkRegion) (e Expr)) SuFirstExprR
  (measure fuel)
  (if (lt fuel 1) (SuFirstExprErr "region first fuel exhausted")
  (match (hole_view e)
    ((HVBad msg) (SuFirstExprErr msg))
    ((HVHole hole_id)
     (match (sug_alts g hole_id)
       (None (SuFirstExprErr "region first references an unknown occurrence"))
       ((Some alts)
        (match (su_first_alt hole_id 0 alts g region)
          ((SuFirstAltErr msg) (SuFirstExprErr msg))
          ((SuFirstAltOk alt) (su_first_expr (- fuel 1) g region alt))))))
    ((HVNot)
     (match e
       ((Ctor q args)
        (match (su_first_list (- fuel 1) g region args)
          ((SuFirstListErr msg) (SuFirstExprErr msg))
          ((SuFirstListOk args2) (SuFirstExprOk (Ctor q args2)))))
       ((Call q args)
        (match (su_first_list (- fuel 1) g region args)
          ((SuFirstListErr msg) (SuFirstExprErr msg))
          ((SuFirstListOk args2) (SuFirstExprOk (Call q args2)))))
       ((Match scrut arms)
        (match (su_first_expr (- fuel 1) g region scrut)
          ((SuFirstExprErr msg) (SuFirstExprErr msg))
          ((SuFirstExprOk scrut2)
           (match (su_first_arms (- fuel 1) g region arms)
             ((SuFirstArmsErr msg) (SuFirstExprErr msg))
             ((SuFirstArmsOk arms2)
              (SuFirstExprOk (Match scrut2 arms2)))))))
       ((Let binds body)
        (match (su_first_list (- fuel 1) g region binds)
          ((SuFirstListErr msg) (SuFirstExprErr msg))
          ((SuFirstListOk binds2)
           (match (su_first_expr (- fuel 1) g region body)
             ((SuFirstExprErr msg) (SuFirstExprErr msg))
             ((SuFirstExprOk body2)
              (SuFirstExprOk (Let binds2 body2)))))))
       ((If cond yes no)
        (match (su_first_expr (- fuel 1) g region cond)
          ((SuFirstExprErr msg) (SuFirstExprErr msg))
          ((SuFirstExprOk cond2)
           (match (su_first_expr (- fuel 1) g region yes)
             ((SuFirstExprErr msg) (SuFirstExprErr msg))
             ((SuFirstExprOk yes2)
              (match (su_first_expr (- fuel 1) g region no)
                ((SuFirstExprErr msg) (SuFirstExprErr msg))
                ((SuFirstExprOk no2)
                 (SuFirstExprOk (If cond2 yes2 no2)))))))))
       (_ (SuFirstExprOk e)))))))

(fn su_first_list
  ((fuel Int) (g SuG) (region SkRegion) (es (List Expr))) SuFirstListR
  (measure fuel)
  (if (lt fuel 1) (SuFirstListErr "region first list fuel exhausted")
  (match es
    (Nil (SuFirstListOk Nil))
    ((Cons head rest)
     (match (su_first_expr (- fuel 1) g region head)
       ((SuFirstExprErr msg) (SuFirstListErr msg))
       ((SuFirstExprOk head2)
        (match (su_first_list (- fuel 1) g region rest)
          ((SuFirstListErr msg) (SuFirstListErr msg))
          ((SuFirstListOk rest2)
           (SuFirstListOk (Cons head2 rest2))))))))))

(fn su_first_arms
  ((fuel Int) (g SuG) (region SkRegion) (arms (List Arm))) SuFirstArmsR
  (measure fuel)
  (if (lt fuel 1) (SuFirstArmsErr "region first arms fuel exhausted")
  (match arms
    (Nil (SuFirstArmsOk Nil))
    ((Cons (Arm pattern body) rest)
     (match (su_first_expr (- fuel 1) g region body)
       ((SuFirstExprErr msg) (SuFirstArmsErr msg))
       ((SuFirstExprOk body2)
        (match (su_first_arms (- fuel 1) g region rest)
          ((SuFirstArmsErr msg) (SuFirstArmsErr msg))
          ((SuFirstArmsOk rest2)
           (SuFirstArmsOk (Cons (Arm pattern body2) rest2))))))))))

(fn su_region_first ((root Expr) (g SuG) (region SkRegion)) SkE
  (match (su_first_expr 1000000 g region root)
    ((SuFirstExprErr msg) (SkEErr msg))
    ((SuFirstExprOk result)
     (if (sk_closed result) (SkEOk result)
       (SkEErr "region first left holes")))))

;; Cardinality-free theorem partitioning uses the same demanded language as
;; evaluation.  It needs neither materialized occurrence entries nor exact
;; counts: every productive fixed child is inhabited by construction, and a
;; complete walk yields an exact disjoint cover of redex and clear regions.
(type SuTheoryPartitionR
  (SuTheoryPartitionErr (List Int))
  (SuTheoryPartitionOk Int (List SkRegion) Int))
  ; redex terminal regions, clear terminal regions, split boundaries

(fn su_theory_partition
  ((fuel Int)
   (prepared MsPrepared)
   (candidate Expr)
   (g SuG)
   (jobs (List SkRegion))
   (redex Int)
   (clear (List SkRegion))
   (forks Int))
  SuTheoryPartitionR
  (measure fuel)
  (if (lt fuel 1)
    (SuTheoryPartitionErr "schema theorem partition fuel exhausted")
  (match jobs
    (Nil (SuTheoryPartitionOk redex clear forks))
    ((Cons region rest)
     (match
       (ms_check_prepared_restricted 1000000 prepared region candidate)
       ((MsErr msg) (SuTheoryPartitionErr msg))
       ((MsRedex _)
        (su_theory_partition
          (- fuel 1) prepared candidate g rest (+ redex 1) clear forks))
       ((MsClear)
        (su_theory_partition
          (- fuel 1) prepared candidate g rest redex (Cons region clear) forks))
       ((MsBlocked hole_id)
        (match (sug_alts g hole_id)
          (None
            (SuTheoryPartitionErr
              "theorem partition references an unknown occurrence"))
          ((Some alts)
           (match
             (su_fork
               g alts region hole_id (- (alts_len alts) 1) rest)
             ((SuForkErr msg) (SuTheoryPartitionErr msg))
             ((SuForkOk jobs2)
              (su_theory_partition
                (- fuel 1) prepared candidate g jobs2 redex clear
                (+ forks 1))))))))))))

(fn su_find_query_prepared
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (prepared MsPrepared)
   (query Expr)
   (want Expr)
   (g SuG)
   (ar SuA)
   (jobs (List SkRegion))
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int))
  SuFind
  (measure fuel)
  (if (lt fuel 1)
    (SuFindBudget
      killed constrained regions forks (sa_steps ar) (sa_nodes ar)
      (sa_exprs ar))
  (match jobs
    (Nil
      (SuFindEmpty
        killed constrained regions forks (sa_steps ar) (sa_nodes ar)
        (sa_exprs ar)))
    ((Cons region rest)
     (let ((asg (sk_region_choices region)))
     (match (ms_check_prepared_restricted 1000000 prepared region candidate)
       ((MsErr msg) (SuFindErr msg))
       ((MsRedex _)
        (su_find_query_prepared
          (- fuel 1) m candq body candidate prepared query want g ar rest
          killed (+ constrained 1) (+ regions 1) forks))
       (constraint_verdict
        (match (su_query (su_efuel) m candq body g asg ar query want)
          ((SuTErr msg) (SuFindErr msg))
          ((SuTOut) (SuFindErr "superpose: generic evaluation fuel exhausted"))
          ((SuTBlocked h ar2)
           (match (sug_alts g h)
             (None (SuFindErr "superpose: generic query blocked on unknown hole"))
             ((Some alts)
              (match
                (su_fork g alts region h (- (alts_len alts) 1) rest)
                ((SuForkErr msg) (SuFindErr msg))
                ((SuForkOk jobs2)
                 (su_find_query_prepared
                   (- fuel 1) m candq body candidate prepared query want g ar2
                   jobs2 killed constrained regions (+ forks 1)))))))
          ((SuTFail ar2)
           (su_find_query_prepared
             (- fuel 1) m candq body candidate prepared query want g ar2 rest
             (+ killed 1) constrained (+ regions 1) forks))
          ((SuTPass ar2)
           (match constraint_verdict
             ((MsBlocked _)
              (match
                (su_theory_partition
                  1000000 prepared candidate g (Cons region Nil) 0 Nil 0)
                ((SuTheoryPartitionErr msg) (SuFindErr msg))
                ((SuTheoryPartitionOk redex_regions clear partition_forks)
                 (match clear
                   (Nil
                     (su_find_query_prepared
                       (- fuel 1) m candq body candidate prepared query want
                       g ar2 rest killed (+ constrained redex_regions)
                       (+ regions redex_regions)
                       (+ forks partition_forks)))
                   ((Cons passing _)
                    (match (su_region_first candidate g passing)
                      ((SkEErr msg) (SuFindErr msg))
                      ((SkEOk representative)
                       (SuFindFound
                         killed
                         (+ constrained redex_regions)
                         (+ regions (+ redex_regions 1))
                         (+ forks partition_forks)
                         (sa_steps ar2)
                         passing
                         representative))))))))
             ((MsClear)
              (match (su_region_first candidate g region)
                ((SkEErr msg) (SuFindErr msg))
                ((SkEOk representative)
                 (SuFindFound
                   killed constrained (+ regions 1) forks (sa_steps ar2) region
                   representative))))
             ((MsErr msg) (SuFindErr msg))
             ((MsRedex _)
              (SuFindErr "superpose: inconsistent residual verdict"))))))))))))

(fn su_find_query
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (constraints MsPlan)
   (query Expr)
   (want Expr)
   (g Grammar))
  SuFind
  (match (ms_prepare 1000000 constraints g)
    ((MsPrepareErr msg)
     (SuFindErr (append_int "superpose: constraint preparation: " msg)))
    ((MsPrepareOk prepared)
     (su_find_query_prepared
       fuel m candq body candidate prepared query want (sug_compile g)
       (sa_new) (Cons (sk_empty_region) Nil) 0 0 0 0))))

;; Regular schema languages enter through the cardinality-free path. Separable
;; pressure is already compiled into typed schema states; residual theorem
;; matching now reads the same occurrence language lazily and partitions only
;; the branches demanded after a semantic pass.
(fn su_find_query_schema
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (constraints MsPlan)
  (query Expr)
  (want Expr)
  (grammar SkSchemaGrammar))
  SuFind
  (match (ms_prepare_schema 1000000 constraints grammar)
    ((MsPrepareErr msg)
     (SuFindErr (append_int "superpose: constraint preparation: " msg)))
    ((MsPrepareOk prepared)
     (su_find_query_prepared
       fuel
       m
       candq
       body
       candidate
       prepared
       query
       want
       (sug_compile_schema grammar)
       (sa_new)
       (Cons (sk_empty_region) Nil)
       0 0 0 0))))

;; Optional theorem-first scheduling.  It is intentionally a mode, not the
;; universal default: a semantic failure can sometimes kill a broader region
;; than any theorem partition.  This prepass is useful for canonical-census and
;; refinement workloads where quotient pressure itself is the object being
;; measured.  It partitions each incoming job completely, settles cited redex
;; regions, then runs the ordinary lazy evaluator only over the exact clear
;; complement.

(fn su_regions_append
  ((left (List SkRegion)) (right (List SkRegion))) (List SkRegion)
  (measure (struct left))
  (match left
    (Nil right)
    ((Cons head rest) (Cons head (su_regions_append rest right)))))

(type SuPrepartitionR
  (SuPrepartitionErr (List Int))
  (SuPrepartitionOk (List SkRegion) Int Int Int))
  ; clear jobs, redex candidates, redex terminal regions, split boundaries

(fn su_prepartition_jobs
  ((fuel Int)
   (prepared MsPrepared)
   (candidate Expr)
   (grammar Grammar)
   (jobs (List SkRegion))
   (clear_jobs (List SkRegion))
   (redex_count Int)
   (redex_regions Int)
   (forks Int))
  SuPrepartitionR
  (measure fuel)
  (if (lt fuel 1) (SuPrepartitionErr "theorem-first prepartition fuel exhausted")
  (match jobs
    (Nil (SuPrepartitionOk clear_jobs redex_count redex_regions forks))
    ((Cons region rest)
     (match (ms_partition_prepared fuel prepared region candidate)
       ((MsPlanPartitionErr msg) (SuPrepartitionErr msg))
       ((MsPlanPartitionOk redex clear partition_forks)
        (match
          (su_count_partition candidate grammar redex Nil 0 0 Nil)
          ((SuPartitionCountErr msg) (SuPrepartitionErr msg))
          ((SuPartitionCountOk here _ terminals _)
           (su_prepartition_jobs
             (- fuel 1)
             prepared
             candidate
             grammar
             rest
             (su_regions_append clear clear_jobs)
             (+ redex_count here)
             (+ redex_regions terminals)
             (+ forks partition_forks))))))))))

(fn su_drive_query_theorem_first
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (constraints MsPlan)
   (query Expr)
   (want Expr)
   (g Grammar)
   (memo (List (Pair Int Int)))
   (ar SuA)
   (jobs (List SkRegion))
   (found Int)
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (sols (List SkRegion)))
  SuS
  (match (ms_prepare 1000000 constraints g)
    ((MsPrepareErr msg)
     (SuSErr (append_int "superpose: constraint preparation: " msg)))
    ((MsPrepareOk prepared)
     (match
       (su_prepartition_jobs
         fuel prepared candidate g jobs Nil 0 0 0)
       ((SuPrepartitionErr msg) (SuSErr msg))
       ((SuPrepartitionOk clear_jobs redex_count redex_regions split_forks)
        (su_drive_query_prepared
          fuel
          m
          candq
          body
          candidate
          prepared
          query
          want
          (sug_compile g)
          memo
          ar
          clear_jobs
          found
          (+ killed redex_count)
          (+ constrained redex_count)
          (+ regions redex_regions)
          (+ forks split_forks)
          sols))))))

(fn su_drive_query_ordered
  ((theorem_first Bool)
   (fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (candidate Expr)
   (constraints MsPlan)
   (query Expr)
   (want Expr)
   (g Grammar)
   (memo (List (Pair Int Int)))
   (ar SuA)
   (jobs (List SkRegion))
   (found Int)
   (killed Int)
   (constrained Int)
   (regions Int)
   (forks Int)
   (sols (List SkRegion)))
  SuS
  (if theorem_first
    (su_drive_query_theorem_first
      fuel m candq body candidate constraints query want g memo ar jobs
      found killed constrained regions forks sols)
    (su_drive_query
      fuel m candq body candidate constraints query want g memo ar jobs
      found killed constrained regions forks sols)))

(fn su_drive
  ((fuel Int)
   (m Module)
   (candq QName)
   (body Expr)
   (g SuG)
   (memo (List (Pair Int Int)))
   (ts (List (Pair (List Int) (List Int))))
   (ar SuA)
   (jobs (List SkRegion))
   (found Int)
   (killed Int)
   (regions Int)
   (forks Int)
   (sols (List SkRegion)))
  SuS
  (measure fuel)
  (if (lt fuel 1)
    (SuSBudget
      found
      killed
      0
      regions
      forks
      (sa_steps ar)
      (sa_nodes ar)
      (sa_exprs ar)
      sols)
    (match jobs
      (Nil (SuSOk found killed 0 regions forks (sa_steps ar) sols))
      ((Cons region rest)
       (let ((asg (sk_region_choices region)))
       (match (su_tests (su_efuel) m candq body g asg ar ts)
         ((SuTErr msg) (SuSErr msg))
         ((SuTOut) (SuSErr "superpose: evaluation fuel exhausted"))
         ((SuTBlocked h ar2)
          (match (sug_alts g h)
            (None (SuSErr "superpose: blocked on an unknown hole"))
            ((Some alts)
             (match
               (su_fork g alts region h (- (alts_len alts) 1) rest)
               ((SuForkErr msg) (SuSErr msg))
               ((SuForkOk jobs2)
                (su_drive
                  (- fuel 1)
                  m
                  candq
                  body
                  g
                  memo
                  ts
                  ar2
                  jobs2
                  found
                  killed
                  regions
                  (+ forks 1)
                  sols))))))
         ((SuTFail ar2)
          (match (su_region_count body (sug_raw g) region)
            ((CcRErr msg) (SuSErr msg))
            ((CcROk n)
             (su_drive
               (- fuel 1)
               m
               candq
               body
               g
               memo
               ts
               ar2
               rest
               found
               (+ killed n)
               (+ regions 1)
               forks
               sols))))
         ((SuTPass ar2)
          (match (su_region_count body (sug_raw g) region)
            ((CcRErr msg) (SuSErr msg))
            ((CcROk n)
             (su_drive
               (- fuel 1)
               m
               candq
               body
               g
               memo
               ts
               ar2
               rest
               (+ found n)
               killed
               (+ regions 1)
               forks
               (Cons region sols)))))))))))

;; ---- region membership + representatives (the AGREE gate) ---------------------

;; the region as a TEMPLATE: assigned holes filled (recursively),
;; unassigned holes kept — a candidate is a member iff the rank
;; matcher accepts it against the template
(fn su_tpl ((g Grammar) (asg (List (Pair Int Int))) (e Expr) (fuel Int))
  (Option Expr)
  (measure fuel)
  (if (lt fuel 1) None
  (match (hole_view e)
    ((HVHole h)
     (let ((c (ch_get asg h)))
       (if (lt c 0)
         ;; Keep genuinely open choices as template holes, but expand a
         ;; deterministic wrapper so assignments below it remain visible.
         (match (su_alts g h)
           (None None)
           ((Some alts)
            (match alts
              ((Cons ae Nil) (su_tpl g asg ae (- fuel 1)))
              (_ (Some e)))))
         (match (su_alts g h)
           (None None)
           ((Some alts)
            (match (alt_nth alts c)
              (None None)
              ((Some ae) (su_tpl g asg ae (- fuel 1)))))))))
    ((HVBad _) None)
    ((HVNot)
     (match e
       ((FVar _) (Some e))
       ((BVar _) (Some e))
       ((Ctor q es)
        (match (su_tpls g asg es (- fuel 1))
          (None None)
          ((Some es2) (Some (Ctor q es2)))))
       ((Call q es)
        (match (su_tpls g asg es (- fuel 1))
          (None None)
          ((Some es2) (Some (Call q es2)))))
       ((Match s arms)
        (match (su_tpl g asg s (- fuel 1))
          (None None)
          ((Some s2)
           (match (su_tpl_arms g asg arms (- fuel 1))
             (None None)
             ((Some arms2) (Some (Match s2 arms2)))))))
       ((Let bs bd)
        (match (su_tpls g asg bs (- fuel 1))
          (None None)
          ((Some bs2)
           (match (su_tpl g asg bd (- fuel 1))
             (None None)
             ((Some bd2) (Some (Let bs2 bd2)))))))
       ((If c t e2)
        (match (su_tpl g asg c (- fuel 1))
          (None None)
          ((Some c2)
           (match (su_tpl g asg t (- fuel 1))
             (None None)
             ((Some t2)
              (match (su_tpl g asg e2 (- fuel 1))
                (None None)
                ((Some e22) (Some (If c2 t2 e22)))))))))
       ((IntLit _) (Some e))
       ((SymLit _) (Some e)))))))

(fn su_tpls
  ((g Grammar) (asg (List (Pair Int Int))) (es (List Expr)) (fuel Int))
  (Option (List Expr))
  (measure fuel)
  (if (lt fuel 1) None
  (match es
    (Nil (Some Nil))
    ((Cons e rest)
     (match (su_tpl g asg e (- fuel 1))
       (None None)
       ((Some e2)
        (match (su_tpls g asg rest (- fuel 1))
          (None None)
          ((Some es2) (Some (Cons e2 es2))))))))))

(fn su_tpl_arms
  ((g Grammar) (asg (List (Pair Int Int))) (arms (List Arm)) (fuel Int))
  (Option (List Arm))
  (measure fuel)
  (if (lt fuel 1) None
  (match arms
    (Nil (Some Nil))
    ((Cons (Arm p b) rest)
     (match (su_tpl g asg b (- fuel 1))
       (None None)
       ((Some b2)
        (match (su_tpl_arms g asg rest (- fuel 1))
          (None None)
          ((Some arms2) (Some (Cons (Arm p b2) arms2))))))))))

;; a region representative: don't-cares filled with alternative 0
(fn su_rep ((g Grammar) (asg (List (Pair Int Int))) (e Expr) (fuel Int))
  (Option Expr)
  (measure fuel)
  (if (lt fuel 1) None
  (match (hole_view e)
    ((HVHole h)
     (let ((c (ch_get asg h)))
       (match (su_alts g h)
         (None None)
         ((Some alts)
          (match (alt_nth alts (if (lt c 0) 0 c))
            (None None)
            ((Some ae) (su_rep g asg ae (- fuel 1))))))))
    ((HVBad _) None)
    ((HVNot)
     (match e
       ((FVar _) (Some e))
       ((BVar _) (Some e))
       ((Ctor q es)
        (match (su_reps g asg es (- fuel 1))
          (None None)
          ((Some es2) (Some (Ctor q es2)))))
       ((Call q es)
        (match (su_reps g asg es (- fuel 1))
          (None None)
          ((Some es2) (Some (Call q es2)))))
       ((Match s arms)
        (match (su_rep g asg s (- fuel 1))
          (None None)
          ((Some s2)
           (match (su_rep_arms g asg arms (- fuel 1))
             (None None)
             ((Some arms2) (Some (Match s2 arms2)))))))
       ((Let bs bd)
        (match (su_reps g asg bs (- fuel 1))
          (None None)
          ((Some bs2)
           (match (su_rep g asg bd (- fuel 1))
             (None None)
             ((Some bd2) (Some (Let bs2 bd2)))))))
       ((If c t e2)
        (match (su_rep g asg c (- fuel 1))
          (None None)
          ((Some c2)
           (match (su_rep g asg t (- fuel 1))
             (None None)
             ((Some t2)
              (match (su_rep g asg e2 (- fuel 1))
                (None None)
                ((Some e22) (Some (If c2 t2 e22)))))))))
       ((IntLit _) (Some e))
       ((SymLit _) (Some e)))))))

(fn su_reps
  ((g Grammar) (asg (List (Pair Int Int))) (es (List Expr)) (fuel Int))
  (Option (List Expr))
  (measure fuel)
  (if (lt fuel 1) None
  (match es
    (Nil (Some Nil))
    ((Cons e rest)
     (match (su_rep g asg e (- fuel 1))
       (None None)
       ((Some e2)
        (match (su_reps g asg rest (- fuel 1))
          (None None)
          ((Some es2) (Some (Cons e2 es2))))))))))

(fn su_rep_arms
  ((g Grammar) (asg (List (Pair Int Int))) (arms (List Arm)) (fuel Int))
  (Option (List Arm))
  (measure fuel)
  (if (lt fuel 1) None
  (match arms
    (Nil (Some Nil))
    ((Cons (Arm p b) rest)
     (match (su_rep g asg b (- fuel 1))
       (None None)
       ((Some b2)
        (match (su_rep_arms g asg rest (- fuel 1))
          (None None)
          ((Some arms2) (Some (Cons (Arm p b2) arms2))))))))))

;; does a closed candidate belong to a found region?
(fn su_member ((g Grammar) (asg (List (Pair Int Int))) (body Expr) (c Expr))
  Bool
  (match (su_tpl g asg body 100000)
    (None False)
    ((Some tpl)
     (match (match_e tpl c Nil)
       ((MtRErr _) False)
       ((MtRNo) False)
       ((MtROk _) True)))))

;; Exact region gates use meta/sketch's restricted addressing.  Keep the
;; assignment-template helpers above as compatibility/debugging vocabulary;
;; they cannot express forbidden choices by themselves.
(fn su_region_rep
  ((g Grammar) (region SkRegion) (body Expr)) (Option Expr)
  (match (sk_region_unrank body g region 0)
    ((SkEErr _) None)
    ((SkEOk candidate) (Some candidate))))

;; every enumerative solution lies in some found region
(fn su_covered
  ((g Grammar) (body Expr) (sols (List SkRegion)) (c Expr))
  Bool
  (measure (struct sols))
  (match sols
    (Nil False)
    ((Cons region rest)
     (if (sk_region_member body g region c) True
     (su_covered g body rest c)))))

(fn su_agree
  ((root Expr)
   (g Grammar)
   (m Module)
   (body Expr)
   (sols (List SkRegion))
   (ixs (List Int))
   (ts (List (Pair (List Int) (List Int)))))
  (Option (List Int))
  (measure (struct ixs))
  (match ixs
    (Nil None)
    ((Cons i rest)
     (match (sk_unrank root g i)
       ((SkEErr _) (Some (cz_at "agree unrank" i "unrank failed")))
       ((SkEOk c)
        (if (su_covered g body sols c) (su_agree root g m body sols rest ts)
        (Some (cz_at "agree" i "an enumerative solution escaped every region"))))))))

;; every found region's representative passes the evm battery
(fn su_reps_pass
  ((g Grammar)
   (m Module)
   (body Expr)
   (sols (List SkRegion))
   (ts (List (Pair (List Int) (List Int)))))
  (Option (List Int))
  (measure (struct sols))
  (match sols
    (Nil None)
    ((Cons region rest)
     (match (su_region_rep g region body)
       (None (Some "agree: representative fill failed"))
       ((Some c)
        (match (extend_fn m (cand_fd c))
          (None (Some "agree: representative qname bound"))
          ((Some m2)
           (if (run_tests m2 (cand_fd c) ts) (su_reps_pass g m body rest ts)
           (Some "agree: a region representative FAILS the evm battery")))))))))

;; ---- driver --------------------------------------------------------------------

(fn su_run ((m Module) (apq QName) (d Int) (w World)) World
  (let ((body (rev_sketch)) (g (rev_grammar d apq)) (ts (rev_tests)))
    (match (g_counts g)
      ((GCtErr msg)
       (exit
         1
         (write (append_int "SUPERPOSE FAIL counts: " (append_int msg "\n")) w)))
      ((GCtOk memo)
       (match (sk_count body g)
         ((SkCErr msg)
          (exit
            1
            (write
              (append_int "SUPERPOSE FAIL count: " (append_int msg "\n"))
              w)))
         ((SkCOk total)
          (match
            (su_drive
              (+ (* 4 total) 64)
              m
              (cand_q)
              body
              (sug_compile g)
              memo
              ts
              (sa_new)
              (Cons (sk_empty_region) Nil)
              0
              0
              0
              0
              Nil)
            ((SuSErr msg)
             (exit
               1
               (write (append_int "SUPERPOSE FAIL " (append_int msg "\n")) w)))
            ((SuSBudget found killed constrained regions forks steps nodes exprs
               _)
             (exit
               1
               (write
                 (append_int
                   "SUPERPOSE BUDGET "
                   (append_int
                     (su_budget_report found killed constrained regions forks
                       steps nodes exprs)
                     "\n"))
                 w)))
            ((SuSOk found killed _ regions forks steps sols)
             (if (int_eq (+ found killed) total)
               (match (enum_go total total body g m ts Nil)
                 ((EnRErr msg)
                  (exit
                    1
                    (write
                      (append_int "SUPERPOSE FAIL enum: " (append_int msg "\n"))
                      w)))
                 ((EnROk ixs)
                  (if (int_eq found (list_len_i ixs))
                    (match (su_agree body g m body sols ixs ts)
                      ((Some msg)
                       (exit
                         1
                         (write
                           (append_int "SUPERPOSE FAIL " (append_int msg "\n"))
                           w)))
                      (None
                        (match (su_reps_pass g m body sols ts)
                          ((Some msg)
                           (exit
                             1
                             (write
                               (append_int
                                 "SUPERPOSE FAIL "
                                 (append_int msg "\n"))
                               w)))
                          (None
                            (write
                              (append_int
                                "SUPERPOSE rev DEPTH "
                                (append_int
                                  (show_int d)
                                  (append_int
                                    "\nTOTAL "
                                    (append_int
                                      (show_int total)
                                      (append_int
                                        " FOUND "
                                        (append_int
                                          (show_int found)
                                          (append_int
                                            " KILLED "
                                            (append_int
                                              (show_int killed)
                                              (append_int
                                                " REGIONS "
                                                (append_int
                                                  (show_int regions)
                                                  (append_int
                                                    " FORKS "
                                                    (append_int
                                                      (show_int forks)
                                                      (append_int
                                                        " STEPS "
                                                        (append_int
                                                          (show_int steps)
                                                          "\nAGREE OK\n"))))))))))))))
                              w)))))
                    (exit
                      1
                      (write
                        "SUPERPOSE FAIL: found coverage != enum solutions\n"
                        w)))))
               (exit 1 (write "SUPERPOSE FAIL: found + killed != total\n" w)))))))))))

;; args: none -> the pinned suite (d1 then d2); "rev N" -> depth N
(fn su_args ((as (List (List Int))) (m Module) (apq QName) (w World)) World
  (match as
    (Nil (su_run m apq 2 (su_run m apq 1 w)))
    ((Cons a rest)
     (if (int_list_eq a "rev")
       (match rest
         ((Cons ds Nil)
          (match (parse_nat ds)
            (None (exit 2 (write "usage: superpose [rev N]\n" w)))
            ((Some d) (su_run m apq d w))))
         (_ (exit 2 (write "usage: superpose [rev N]\n" w))))
       (exit 2 (write "usage: superpose [rev N]\n" w))))))

(fn main ((w World)) World
  (match (load_run_module "tools/search/rev_obj.shard" w)
    ((Pair om w2)
     (match om
       (None (exit 1 (write "SUPERPOSE FAIL: object module load\n" w2)))
       ((Some m)
        (match (find_fn (quote append) m)
          (None (exit 1 (write "SUPERPOSE FAIL: no append in closure\n" w2)))
          ((Some apfd)
           (match apfd
             ((FnDef apq _ _ _)
              (match (get_args w2)
                ((Pair as w3) (su_args as m apq w3))))))))))))
