;;; Generic shallow transition-window collision census.
;;;
;;; A task supplies the ordinary typed-expression scope protocol, but its
;;; search_probe observation must be `Option (List Int)`: an exact stable
;;; transition key owned by the task's semantics adapter.  This driver builds
;;; the same reflected Grammar as typed_expr, rank/unrank- and type-checks every
;;; member, groups exact keys through meta/census, and retains several concrete
;;; exemplars from high-mass buckets.  A collision is a theorem proposal only;
;;; no rewrite profile is installed here.
;;;
;;; RUN:
;;;   bin/shard_eval run tools/search/transition_mine.shard TASK.shard

(import "../../kernel/stdlib.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reader.shard")
(import "../../kernel/loader.shard")
(import "../../meta/census")
(import "../../meta/antiunify")
(import "../../meta/antiunify/typed.shard")
(import "../../meta/rewrite")
(import "../../meta/search/mod.req.shard")
(import "../../meta/invoke")
(import "../../meta/invoke/prepared.shard")
(import "../../meta/sketch")
(import "../../meta/spell")
(import "typed_expr.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel reader RCtx))
(use (:: kernel loader World))
(use (:: kernel loader read_file))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader exit))
(use (:: meta census *))
(use (:: meta antiunify *))
(use (:: meta antiunify typed *))
(use (:: meta rewrite *))
(use (:: meta search *))
(use (:: meta invoke *))
(use (:: meta invoke prepared *))
(use (:: meta sketch *))
(use (:: meta spell *))
(use (:: tools search typed_expr *))

(type TmAuthDomain (TmAuthEverywhere) (TmAuthRoot) (TmAuthSpine))

(type TmAuthRule (TmAuthRule TmAuthDomain TrsConditionedRule))

(fn tm_auth_append ((xs (List TmAuthRule)) (ys (List TmAuthRule)))
  (List TmAuthRule)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons x rest) (Cons x (tm_auth_append rest ys)))))

(fn tm_auth_plain ((domain TmAuthDomain) (rules (List TrsRule)))
  (List TmAuthRule)
  (measure (struct rules))
  (match rules
    (Nil Nil)
    ((Cons rule rest)
     (Cons
       (TmAuthRule domain (TrsConditionedRule rule Nil))
       (tm_auth_plain domain rest)))))

(fn tm_auth_spine ((rules (List TrsSpineRule))) (List TmAuthRule)
  (measure (struct rules))
  (match rules
    (Nil Nil)
    ((Cons (TrsSpineRule _ conditioned) rest)
     (Cons (TmAuthRule (TmAuthSpine) conditioned) (tm_auth_spine rest)))))

(fn tm_auth_reductions ((reductions TeReductions)) (List TmAuthRule)
  (match reductions
    ((TeReductions
       (TeCanon canon _ _ _)
       (TeObserved observed _ _ _)
       (MsPlan _ _ spine))
     (tm_auth_append
       (tm_auth_plain (TmAuthEverywhere) (trs_profile_rules canon))
       (tm_auth_append
         (tm_auth_plain (TmAuthRoot) (trs_root_profile_rules observed))
         (tm_auth_spine (trs_spine_profile_rules spine)))))))

(type TmMember (TmMember Int Expr (List Int)))  ; rank, candidate, exact key

(type TmSweepR
  (TmSweepErr (List Int))
  (TmSweepOk KcCensus Int Int (List TmMember)))
; census, accepted, rejected, accepted members

(fn tm_at ((rank Int) (msg (List Int))) (List Int)
  (append_int
    "transition census at rank "
    (append_int (show_int rank) (append_int ": " msg))))

(fn tm_sweep
  ((remaining Int)
   (total Int)
   (root Expr)
   (grammar Grammar)
   (m Module)
   (want Type)
   (ctx InvokeCtx)
   (probe FnDef)
   (census KcCensus)
   (accepted Int)
   (rejected Int)
   (members (List TmMember)))
  TmSweepR
  (measure
    remaining
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (le remaining 0) (TmSweepOk census accepted rejected members)
  (let ((rank (- total remaining)))
    (match (sk_unrank root grammar rank)
      ((SkEErr msg) (TmSweepErr (tm_at rank msg)))
      ((SkEOk candidate)
       (match (sk_rank root grammar candidate)
         ((SkCErr msg) (TmSweepErr (tm_at rank msg)))
         ((SkCOk rank2)
          (if (int_eq rank rank2)
            (match (te_typecheck m want candidate)
              ((TeTcErr msg) (TmSweepErr (tm_at rank msg)))
              ((TeTcOk)
               (match (te_observe ctx probe candidate)
                 ((TeObsErr msg) (TmSweepErr (tm_at rank msg)))
                 ((TeObsReject)
                  (tm_sweep
                    (- remaining 1)
                    total
                    root
                    grammar
                    m
                    want
                    ctx
                    probe
                    census
                    accepted
                    (+ rejected 1)
                    members))
                 ((TeObsOk key_expr)
                  (match (expr_ints key_expr)
                    (None
                      (TmSweepErr
                        (tm_at rank "transition key is not a List Int")))
                    ((Some key)
                     (match (kc_add key 1 rank 6 census)
                       ((KcErr msg) (TmSweepErr (tm_at rank msg)))
                       ((KcOk more)
                        (tm_sweep
                          (- remaining 1)
                          total
                          root
                          grammar
                          m
                          want
                          ctx
                          probe
                          more
                          (+ accepted 1)
                          rejected
                          (Cons (TmMember rank candidate key) members))))))))))
            (TmSweepErr (tm_at rank "rank/unrank disagreement"))))))))))

(type TmStats (TmStats Int Int Int))  ; collided buckets, excess, max support

(fn tm_stats ((bs (List KcBucket)) (collided Int) (excess Int) (maximum Int))
  TmStats
  (measure (struct bs))
  (match bs
    (Nil (TmStats collided excess maximum))
    ((Cons b rest)
     (let ((support (kc_support b)))
       (tm_stats
         rest
         (if (lt 1 support) (+ collided 1) collided)
         (if (lt 1 support) (+ excess (- support 1)) excess)
         (if (lt maximum support) support maximum))))))

(fn tm_cat ((parts (List (List Int)))) (List Int)
  (measure (struct parts))
  (match parts
    (Nil Nil)
    ((Cons part rest) (append_int part (tm_cat rest)))))

;; ---- collision edges and anti-unified candidate basis ---------------------
;;
;; Each collided behavior is oriented toward its least structural-cost member.
;; Pairwise simultaneous anti-unification across those concrete edges recovers
;; register-/atom-renamed schemas while preserving repeated-variable
;; correlations.  Every proposed schema is replayed over the COMPLETE census:
;; all represented RHSs must exist in the grammar and have the same exact key.
;; This is still finite observational evidence, never a theorem license.

(fn tm_exprs_size ((es (List Expr))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons e rest) (+ (tm_expr_size e) (tm_exprs_size rest)))))

(fn tm_arms_size ((arms (List Arm))) Int
  (measure (struct arms))
  (match arms
    (Nil 0)
    ((Cons (Arm _ body) rest) (+ (tm_expr_size body) (tm_arms_size rest)))))

(fn tm_expr_size ((e Expr)) Int
  (measure (struct e))
  (match e
    ((Ctor _ args) (+ 1 (tm_exprs_size args)))
    ((Call _ args) (+ 1 (tm_exprs_size args)))
    ((If c t f)
     (+ 1 (+ (tm_expr_size c) (+ (tm_expr_size t) (tm_expr_size f)))))
    ((Match scrut arms) (+ 1 (+ (tm_expr_size scrut) (tm_arms_size arms))))
    ((Let bindings body) (+ 1 (+ (tm_exprs_size bindings) (tm_expr_size body))))
    (_ 1)))

(fn tm_member_rank ((member TmMember)) Int
  (match member
    ((TmMember rank _ _) rank)))

(fn tm_member_expr ((member TmMember)) Expr
  (match member
    ((TmMember _ candidate _) candidate)))

(fn tm_member_key ((member TmMember)) (List Int)
  (match member
    ((TmMember _ _ key) key)))

(fn tm_member_better ((candidate TmMember) (prior TmMember)) Bool
  (let
    ((cc (tm_expr_size (tm_member_expr candidate)))
     (pc (tm_expr_size (tm_member_expr prior))))
    (if (lt cc pc) True
    (if (lt pc cc) False
    (lt (tm_member_rank candidate) (tm_member_rank prior))))))

(fn tm_best_key
  ((key (List Int)) (members (List TmMember)) (best (Option TmMember)))
  (Option TmMember)
  (measure (struct members))
  (match members
    (Nil best)
    ((Cons member rest)
     (if (kc_key_eq key (tm_member_key member))
       (match best
         (None (tm_best_key key rest (Some member)))
         ((Some prior)
          (tm_best_key
            key
            rest
            (Some (if (tm_member_better member prior) member prior)))))
       (tm_best_key key rest best)))))

(type TmEdge (TmEdge AuEquation Int Int))  ; equation, member rank, rep rank

(fn tm_min_members ((key (List Int)) (cost Int) (members (List TmMember)))
  (List TmMember)
  (measure (struct members))
  (match members
    (Nil Nil)
    ((Cons member rest)
     (let ((more (tm_min_members key cost rest)))
       (if (kc_key_eq key (tm_member_key member))
         (if (int_eq cost (tm_expr_size (tm_member_expr member)))
           (Cons member more)
           more)
         more)))))

(fn tm_edges_to_reps ((member TmMember) (representatives (List TmMember)))
  (List TmEdge)
  (measure (struct representatives))
  (match representatives
    (Nil Nil)
    ((Cons representative rest)
     (let ((more (tm_edges_to_reps member rest)))
       (if
         (lt
           (tm_expr_size (tm_member_expr representative))
           (tm_expr_size (tm_member_expr member)))
         (Cons
           (TmEdge
             (AuEquation
               (tm_member_expr member)
               (tm_member_expr representative))
             (tm_member_rank member)
             (tm_member_rank representative))
           more)
         more)))))

(fn tm_edge_members
  ((key (List Int)) (representatives (List TmMember)) (members (List TmMember)))
  (List TmEdge)
  (measure (struct members))
  (match members
    (Nil Nil)
    ((Cons member rest)
     (let ((more (tm_edge_members key representatives rest)))
       (if (kc_key_eq key (tm_member_key member))
         (tm_edges_append (tm_edges_to_reps member representatives) more)
         more)))))

(fn tm_edges_append ((xs (List TmEdge)) (ys (List TmEdge))) (List TmEdge)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons x rest) (Cons x (tm_edges_append rest ys)))))

(fn tm_edges ((buckets (List KcBucket)) (members (List TmMember))) (List TmEdge)
  (measure (struct buckets))
  (match buckets
    (Nil Nil)
    ((Cons bucket rest)
     (let ((more (tm_edges rest members)))
       (if (lt 1 (kc_support bucket))
         (match (tm_best_key (kc_key bucket) members None)
           (None more)
           ((Some representative)
            (let
              ((representatives
                 (tm_min_members
                   (kc_key bucket)
                   (tm_expr_size (tm_member_expr representative))
                   members)))
              (tm_edges_append
                (tm_edge_members (kc_key bucket) representatives members)
                more))))
         more)))))

(fn tm_distinct_eq ((a AuDistinct) (b AuDistinct)) Bool
  (match a
    ((AuDistinct ai aj)
     (match b
       ((AuDistinct bi bj) (if (int_eq ai bi) (int_eq aj bj) False))))))

(fn tm_distinct_list_eq ((as (List AuDistinct)) (bs (List AuDistinct))) Bool
  (measure (struct as))
  (match as
    (Nil
      (match bs
        (Nil True)
        (_ False)))
    ((Cons a rest)
     (match bs
       (Nil False)
       ((Cons b rest2)
        (if (tm_distinct_eq a b) (tm_distinct_list_eq rest rest2) False))))))

(fn tm_guards_hold ((env TrsEnv) (guards (List AuDistinct))) Bool
  (measure (struct guards))
  (match guards
    (Nil True)
    ((Cons (AuDistinct a b) rest)
     (match (trs_env_get a env)
       (None False)
       ((Some av)
        (match (trs_env_get b env)
          (None False)
          ((Some bv) (if (expr_eq av bv) False (tm_guards_hold env rest)))))))))

(fn tm_member_expr_find ((wanted Expr) (members (List TmMember)))
  (Option TmMember)
  (measure (struct members))
  (match members
    (Nil None)
    ((Cons member rest)
     (if (expr_eq wanted (tm_member_expr member)) (Some member)
     (tm_member_expr_find wanted rest)))))

(type TmValidate (TmValidateBad) (TmValidateOk Int))

(fn tm_validate_schema
  ((lhs Expr)
   (rhs Expr)
   (guards (List AuDistinct))
   (all (List TmMember))
   (remaining (List TmMember))
   (matched Int))
  TmValidate
  (measure (struct remaining))
  (match remaining
    (Nil (TmValidateOk matched))
    ((Cons member rest)
     (match (trs_match lhs (tm_member_expr member) (TrsEmpty))
       (None (tm_validate_schema lhs rhs guards all rest matched))
       ((Some env)
        (if (tm_guards_hold env guards)
          (match (trs_inst rhs env)
            ((TrsInstErr _) (TmValidateBad))
            ((TrsInstOk replacement)
             (match (tm_member_expr_find replacement all)
               (None (TmValidateBad))
               ((Some target)
                (if (kc_key_eq (tm_member_key member) (tm_member_key target))
                  (tm_validate_schema lhs rhs guards all rest (+ matched 1))
                  (TmValidateBad))))))
          (tm_validate_schema lhs rhs guards all rest matched)))))))

(fn tm_schema_well_formed ((schema AuSchema)) Bool
  (match schema
    ((AuSchema (AuEquation lhs rhs) arity)
     (if (lt (tm_expr_size rhs) (tm_expr_size lhs))
       (if (trs_rooted lhs)
         (if (expr_eq lhs rhs) False
         (match (trs_lhs_vars lhs arity Nil)
           ((TrsVarsErr _) False)
           ((TrsVarsOk lhsvars)
            (match (trs_rhs_vars rhs arity lhsvars)
              ((TrsVarsErr _) False)
              ((TrsVarsOk _) True)))))
         False)
       False))))

(fn tm_typed_schema_well_formed ((typed AuTypedSchema)) Bool
  (match typed
    ((AuTypedSchema (AuSchema (AuEquation lhs rhs) _) types)
     (match (trs_rule (qn (quote __transition_proposal)) types lhs rhs)
       ((TrsRuleErr _) False)
       ((TrsRuleOk _) True)))))

(type TmProposal (TmProposal AuTypedSchema (List AuDistinct) Int Int Int))
; typed schema, empirical guards, exact matched lhs count, seed ranks

(fn tm_proposal_eq ((a TmProposal) (b TmProposal)) Bool
  (match a
    ((TmProposal (AuTypedSchema (AuSchema (AuEquation al ar) aa) at) ag _ _ _)
     (match b
       ((TmProposal
          (AuTypedSchema (AuSchema (AuEquation bl br) ba) bt)
          bg
          _
          _
          _)
        (if (int_eq aa ba)
          (if (type_eq_list at bt)
            (if (expr_eq al bl)
              (if (expr_eq ar br) (tm_distinct_list_eq ag bg) False)
              False)
            False)
          False))))))

(fn tm_proposal_mem ((proposal TmProposal) (items (List TmProposal))) Bool
  (measure (struct items))
  (match items
    (Nil False)
    ((Cons prior rest)
     (if (tm_proposal_eq proposal prior) True (tm_proposal_mem proposal rest)))))

(fn tm_proposal_support ((proposal TmProposal)) Int
  (match proposal
    ((TmProposal _ _ support _ _) support)))

(fn tm_proposal_arity ((proposal TmProposal)) Int
  (match proposal
    ((TmProposal typed _ _ _ _) (au_schema_arity (au_typed_schema typed)))))

(fn tm_proposal_gain ((proposal TmProposal)) Int
  (match proposal
    ((TmProposal
       (AuTypedSchema (AuSchema (AuEquation lhs rhs) _) _)
       _
       support
       _
       _)
     (* support (- (tm_expr_size lhs) (tm_expr_size rhs))))))

(fn tm_proposal_lhs_size ((proposal TmProposal)) Int
  (match proposal
    ((TmProposal (AuTypedSchema (AuSchema (AuEquation lhs _) _) _) _ _ _ _)
     (tm_expr_size lhs))))

(fn tm_proposal_before ((a TmProposal) (b TmProposal)) Bool
  (let ((ag (tm_proposal_gain a)) (bg (tm_proposal_gain b)))
    (if (lt bg ag) True
    (if (lt ag bg) False
    (let ((as (tm_proposal_support a)) (bs (tm_proposal_support b)))
      (if (lt bs as) True
      (if (lt as bs) False
      (let ((al (tm_proposal_lhs_size a)) (bl (tm_proposal_lhs_size b)))
        (if (lt al bl) True
        (if (lt bl al) False
        (lt (tm_proposal_arity a) (tm_proposal_arity b))))))))))))

(fn tm_proposal_insert ((proposal TmProposal) (items (List TmProposal)))
  (List TmProposal)
  (measure (struct items))
  (if (tm_proposal_mem proposal items) items
  (match items
    (Nil (Cons proposal Nil))
    ((Cons prior rest)
     (if (tm_proposal_before proposal prior) (Cons proposal items)
     (Cons prior (tm_proposal_insert proposal rest)))))))

(fn tm_edge_equation ((edge TmEdge)) AuEquation
  (match edge
    ((TmEdge eq _ _) eq)))

(fn tm_edge_rank ((edge TmEdge)) Int
  (match edge
    ((TmEdge _ rank _) rank)))

(type TmSeed (TmSeed AuSchema (List AuDistinct) AuEquation AuEquation Int Int))
; unique untyped schema+guards, two concrete supports, seed ranks

(type TmPairMode (TmGaugePairs) (TmOrbitPairs) (TmAllPairs))

;; Gauge-orbit skeleton: preserve every non-leaf algebraic head and its field
;; topology, while erasing the identity of nullary constructors and literals.
;; Register names, enum operations, atoms, and constants may therefore vary;
;; unrelated instruction/list shapes never enter the quadratic anti-unifier.
;; The optional all-pairs mode retains the broader structural experiment.
(fn tm_orbit_exprs ((as (List Expr)) (bs (List Expr))) Bool
  (measure (struct as))
  (match as
    (Nil
      (match bs
        (Nil True)
        (_ False)))
    ((Cons a rest)
     (match bs
       (Nil False)
       ((Cons b rest2)
        (if (tm_orbit_expr a b) (tm_orbit_exprs rest rest2) False))))))

(fn tm_orbit_expr ((a Expr) (b Expr)) Bool
  (measure (struct a))
  (match a
    ((Ctor q args)
     (match b
       ((Ctor q2 args2)
        (match args
          (Nil
            (match args2
              (Nil True)
              (_ False)))
          ((Cons _ _) (if (qname_eq q q2) (tm_orbit_exprs args args2) False))))
       (_ False)))
    ((Call q args)
     (match b
       ((Call q2 args2)
        (match args
          (Nil
            (match args2
              (Nil True)
              (_ False)))
          ((Cons _ _) (if (qname_eq q q2) (tm_orbit_exprs args args2) False))))
       (_ False)))
    ((If ac at af)
     (match b
       ((If bc bt bf)
        (if (tm_orbit_expr ac bc)
          (if (tm_orbit_expr at bt) (tm_orbit_expr af bf) False)
          False))
       (_ False)))
    ((IntLit _)
     (match b
       ((IntLit _) True)
       (_ False)))
    ((SymLit _)
     (match b
       ((SymLit _) True)
       (_ False)))
    (_ (expr_eq a b))))

(fn tm_orbit_equation ((a AuEquation) (b AuEquation)) Bool
  (if (tm_orbit_expr (au_lhs a) (au_lhs b))
    (tm_orbit_expr (au_rhs a) (au_rhs b))
    False))

(fn tm_expr_append ((xs (List Expr)) (ys (List Expr))) (List Expr)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons x rest) (Cons x (tm_expr_append rest ys)))))

(fn tm_orbit_leaves_many ((es (List Expr))) (List Expr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons e rest)
     (tm_expr_append (tm_orbit_leaves e) (tm_orbit_leaves_many rest)))))

(fn tm_orbit_leaves ((e Expr)) (List Expr)
  (measure (struct e))
  (match e
    ((Ctor _ args)
     (match args
       (Nil (Cons e Nil))
       ((Cons _ _) (tm_orbit_leaves_many args))))
    ((Call _ args)
     (match args
       (Nil (Cons e Nil))
       ((Cons _ _) (tm_orbit_leaves_many args))))
    ((If c t f)
     (tm_expr_append
       (tm_orbit_leaves c)
       (tm_expr_append (tm_orbit_leaves t) (tm_orbit_leaves f))))
    ((IntLit _) (Cons e Nil))
    ((SymLit _) (Cons e Nil))
    (_ (Cons e Nil))))

(fn tm_equation_leaves ((eq AuEquation)) (List Expr)
  (tm_expr_append (tm_orbit_leaves (au_lhs eq)) (tm_orbit_leaves (au_rhs eq))))

(fn tm_same_leaf_row ((x Expr) (xs (List Expr)) (y Expr) (ys (List Expr))) Bool
  (measure (struct xs))
  (match xs
    (Nil
      (match ys
        (Nil True)
        (_ False)))
    ((Cons a rest)
     (match ys
       (Nil False)
       ((Cons b rest2)
        (if (expr_eq x a)
          (if (expr_eq y b) (tm_same_leaf_row x rest y rest2) False)
        (if (expr_eq y b) False
        (tm_same_leaf_row x rest y rest2))))))))

;; Two leaf vectors occupy the same gauge orbit exactly when they induce the
;; same equality partition.  Concrete leaf identities may all be renamed, but
;; repeated roles and distinct roles cannot collapse into one another.
(fn tm_same_leaf_partition ((xs (List Expr)) (ys (List Expr))) Bool
  (measure (struct xs))
  (match xs
    (Nil
      (match ys
        (Nil True)
        (_ False)))
    ((Cons x rest)
     (match ys
       (Nil False)
       ((Cons y rest2)
        (if (tm_same_leaf_row x rest y rest2)
          (tm_same_leaf_partition rest rest2)
          False))))))

(fn tm_same_gauge_orbit ((a AuEquation) (b AuEquation)) Bool
  (if (tm_orbit_equation a b)
    (tm_same_leaf_partition (tm_equation_leaves a) (tm_equation_leaves b))
    False))

(fn tm_pair_allowed ((mode TmPairMode) (a TmEdge) (b TmEdge)) Bool
  (match mode
    ((TmAllPairs) True)
    ((TmOrbitPairs)
     (tm_orbit_equation (tm_edge_equation a) (tm_edge_equation b)))
    ((TmGaugePairs)
     (tm_same_gauge_orbit (tm_edge_equation a) (tm_edge_equation b)))))

;; ---- whole-orbit abstraction ----------------------------------------------
;;
;; Pairwise anti-unification can leave a role concrete merely because the two
;; chosen supports happen to use the same leaf there.  Gauge mode instead
;; collects the full equivalence class, marks every aligned leaf position that
;; varies anywhere in that class, and abstracts those roles simultaneously.
;; Singleton leaves in the scoped corpus (for example its only opcode) remain
;; concrete.  This is the scope-driven, maximally varying orbit schema.

(type TmGaugeOrbit (TmGaugeOrbit (List TmEdge)))

(fn tm_gauge_insert ((edge TmEdge) (orbits (List TmGaugeOrbit)))
  (List TmGaugeOrbit)
  (measure (struct orbits))
  (match orbits
    (Nil (Cons (TmGaugeOrbit (Cons edge Nil)) Nil))
    ((Cons (TmGaugeOrbit items) rest)
     (match items
       (Nil (Cons (TmGaugeOrbit (Cons edge Nil)) rest))
       ((Cons representative _)
        (if
          (tm_same_gauge_orbit
            (tm_edge_equation edge)
            (tm_edge_equation representative))
          (Cons (TmGaugeOrbit (Cons edge items)) rest)
          (Cons (TmGaugeOrbit items) (tm_gauge_insert edge rest))))))))

(fn tm_gauge_orbits ((edges (List TmEdge)) (orbits (List TmGaugeOrbit)))
  (List TmGaugeOrbit)
  (measure (struct edges))
  (match edges
    (Nil orbits)
    ((Cons edge rest) (tm_gauge_orbits rest (tm_gauge_insert edge orbits)))))

(fn tm_expr_mem ((wanted Expr) (items (List Expr))) Bool
  (measure (struct items))
  (match items
    (Nil False)
    ((Cons item rest) (if (expr_eq wanted item) True (tm_expr_mem wanted rest)))))

(fn tm_expr_add ((item Expr) (items (List Expr))) (List Expr)
  (if (tm_expr_mem item items) items (Cons item items)))

(fn tm_varying_row
  ((base (List Expr)) (other (List Expr)) (varying (List Expr)))
  (List Expr)
  (measure (struct base))
  (match base
    (Nil varying)
    ((Cons a rest)
     (match other
       (Nil varying)
       ((Cons b rest2)
        (tm_varying_row
          rest
          rest2
          (if (expr_eq a b) varying (tm_expr_add a varying))))))))

(fn tm_gauge_varying
  ((base (List Expr)) (edges (List TmEdge)) (varying (List Expr)))
  (List Expr)
  (measure (struct edges))
  (match edges
    (Nil varying)
    ((Cons edge rest)
     (tm_gauge_varying
       base
       rest
       (tm_varying_row
         base
         (tm_equation_leaves (tm_edge_equation edge))
         varying)))))

(type TmAbsState (TmAbsState Int (List (Pair Expr Int))))

(type TmAbsR (TmAbsErr (List Int)) (TmAbsOk Expr TmAbsState))

(type TmAbsListR (TmAbsListErr (List Int)) (TmAbsListOk (List Expr) TmAbsState))

(fn tm_abs_find ((e Expr) (items (List (Pair Expr Int)))) (Option Int)
  (measure (struct items))
  (match items
    (Nil None)
    ((Cons (Pair prior index) rest)
     (if (expr_eq e prior) (Some index) (tm_abs_find e rest)))))

(fn tm_abs_leaf ((e Expr) (varying (List Expr)) (state TmAbsState)) TmAbsR
  (if (tm_expr_mem e varying)
    (match state
      ((TmAbsState next items)
       (match (tm_abs_find e items)
         ((Some index) (TmAbsOk (BVar index) state))
         (None
           (TmAbsOk
             (BVar next)
             (TmAbsState (+ next 1) (Cons (Pair e next) items)))))))
    (TmAbsOk e state)))

(fn tm_abs_exprs ((es (List Expr)) (varying (List Expr)) (state TmAbsState))
  TmAbsListR
  (measure (struct es))
  (match es
    (Nil (TmAbsListOk Nil state))
    ((Cons e rest)
     (match (tm_abs_expr e varying state)
       ((TmAbsErr msg) (TmAbsListErr msg))
       ((TmAbsOk item state2)
        (match (tm_abs_exprs rest varying state2)
          ((TmAbsListErr msg) (TmAbsListErr msg))
          ((TmAbsListOk items state3) (TmAbsListOk (Cons item items) state3))))))))

(fn tm_abs_expr ((e Expr) (varying (List Expr)) (state TmAbsState)) TmAbsR
  (measure (struct e))
  (match e
    ((Ctor q args)
     (match args
       (Nil (tm_abs_leaf e varying state))
       ((Cons _ _)
        (match (tm_abs_exprs args varying state)
          ((TmAbsListErr msg) (TmAbsErr msg))
          ((TmAbsListOk rebuilt state2) (TmAbsOk (Ctor q rebuilt) state2))))))
    ((Call q args)
     (match args
       (Nil (tm_abs_leaf e varying state))
       ((Cons _ _)
        (match (tm_abs_exprs args varying state)
          ((TmAbsListErr msg) (TmAbsErr msg))
          ((TmAbsListOk rebuilt state2) (TmAbsOk (Call q rebuilt) state2))))))
    ((If c t f)
     (match (tm_abs_expr c varying state)
       ((TmAbsErr msg) (TmAbsErr msg))
       ((TmAbsOk c2 state2)
        (match (tm_abs_expr t varying state2)
          ((TmAbsErr msg) (TmAbsErr msg))
          ((TmAbsOk t2 state3)
           (match (tm_abs_expr f varying state3)
             ((TmAbsErr msg) (TmAbsErr msg))
             ((TmAbsOk f2 state4) (TmAbsOk (If c2 t2 f2) state4))))))))
    ((IntLit _) (tm_abs_leaf e varying state))
    ((SymLit _) (tm_abs_leaf e varying state))
    (_ (TmAbsErr "gauge abstraction requires closed algebraic expressions"))))

(type TmAbsSchemaR (TmAbsSchemaErr (List Int)) (TmAbsSchemaOk AuSchema))

(fn tm_abs_equation ((eq AuEquation) (varying (List Expr))) TmAbsSchemaR
  (match (tm_abs_expr (au_lhs eq) varying (TmAbsState 0 Nil))
    ((TmAbsErr msg) (TmAbsSchemaErr msg))
    ((TmAbsOk lhs state)
     (match (tm_abs_expr (au_rhs eq) varying state)
       ((TmAbsErr msg) (TmAbsSchemaErr msg))
       ((TmAbsOk rhs (TmAbsState arity _))
        (TmAbsSchemaOk (AuSchema (AuEquation lhs rhs) arity)))))))

(fn tm_edge_equations ((edges (List TmEdge))) (List AuEquation)
  (measure (struct edges))
  (match edges
    (Nil Nil)
    ((Cons edge rest) (Cons (tm_edge_equation edge) (tm_edge_equations rest)))))

(type TmGaugeSeedR (TmGaugeSeedNo) (TmGaugeSeedYes TmSeed))

(fn tm_gauge_seed_build
  ((first TmEdge) (second TmEdge) (edges (List TmEdge)) (varying (List Expr)))
  TmGaugeSeedR
  (match (tm_abs_equation (tm_edge_equation first) varying)
    ((TmAbsSchemaErr _) (TmGaugeSeedNo))
    ((TmAbsSchemaOk schema)
     (if (tm_schema_well_formed schema)
       (match (au_distinct_guards schema (tm_edge_equations edges))
         ((AuDistinctErr _) (TmGaugeSeedNo))
         ((AuDistinctOk guards)
          (TmGaugeSeedYes
            (TmSeed
              schema
              guards
              (tm_edge_equation first)
              (tm_edge_equation second)
              (tm_edge_rank first)
              (tm_edge_rank second)))))
       (TmGaugeSeedNo)))))

(fn tm_gauge_seed ((orbit TmGaugeOrbit)) TmGaugeSeedR
  (match orbit
    ((TmGaugeOrbit edges)
     (match edges
       ((Cons first (Cons second _))
        (let ((base (tm_equation_leaves (tm_edge_equation first))))
          (let ((varying (tm_gauge_varying base edges Nil)))
            (match varying
              (Nil (TmGaugeSeedNo))
              ((Cons _ _) (tm_gauge_seed_build first second edges varying))))))
       (_ (TmGaugeSeedNo))))))

(fn tm_gauge_seeds ((orbits (List TmGaugeOrbit)) (seeds (List TmSeed)))
  (List TmSeed)
  (measure (struct orbits))
  (match orbits
    (Nil seeds)
    ((Cons orbit rest)
     (match (tm_gauge_seed orbit)
       ((TmGaugeSeedNo) (tm_gauge_seeds rest seeds))
       ((TmGaugeSeedYes seed) (tm_gauge_seeds rest (tm_seed_insert seed seeds)))))))

(fn tm_seed_eq ((a TmSeed) (b TmSeed)) Bool
  (match a
    ((TmSeed (AuSchema (AuEquation al ar) aa) ag _ _ _ _)
     (match b
       ((TmSeed (AuSchema (AuEquation bl br) ba) bg _ _ _ _)
        (if (int_eq aa ba)
          (if (expr_eq al bl)
            (if (expr_eq ar br) (tm_distinct_list_eq ag bg) False)
            False)
          False))))))

(fn tm_seed_mem ((seed TmSeed) (items (List TmSeed))) Bool
  (measure (struct items))
  (match items
    (Nil False)
    ((Cons prior rest)
     (if (tm_seed_eq seed prior) True (tm_seed_mem seed rest)))))

(fn tm_seed_insert ((seed TmSeed) (items (List TmSeed))) (List TmSeed)
  (if (tm_seed_mem seed items) items (Cons seed items)))

(fn tm_seed_pair ((mode TmPairMode) (a TmEdge) (b TmEdge) (seeds (List TmSeed)))
  (List TmSeed)
  (if (tm_pair_allowed mode a b)
    (match (au_equations (tm_edge_equation a) (tm_edge_equation b))
      ((AuSchemaErr _) seeds)
      ((AuSchemaOk schema)
       (if (tm_schema_well_formed schema)
         (match
           (au_distinct_guards
             schema
             (list (tm_edge_equation a) (tm_edge_equation b)))
           ((AuDistinctErr _) seeds)
           ((AuDistinctOk guards)
            (tm_seed_insert
              (TmSeed
                schema
                guards
                (tm_edge_equation a)
                (tm_edge_equation b)
                (tm_edge_rank a)
                (tm_edge_rank b))
              seeds)))
         seeds)))
    seeds))

(fn tm_seed_row
  ((mode TmPairMode) (a TmEdge) (rest (List TmEdge)) (seeds (List TmSeed)))
  (List TmSeed)
  (measure (struct rest))
  (match rest
    (Nil seeds)
    ((Cons b more) (tm_seed_row mode a more (tm_seed_pair mode a b seeds)))))

(fn tm_seeds ((mode TmPairMode) (edges (List TmEdge)) (seeds (List TmSeed)))
  (List TmSeed)
  (measure (struct edges))
  (match edges
    (Nil seeds)
    ((Cons edge rest) (tm_seeds mode rest (tm_seed_row mode edge rest seeds)))))

(fn tm_mined_seeds ((mode TmPairMode) (edges (List TmEdge))) (List TmSeed)
  (match mode
    ((TmGaugePairs) (tm_gauge_seeds (tm_gauge_orbits edges Nil) Nil))
    (_ (tm_seeds mode edges Nil))))

(fn tm_seed_count ((seeds (List TmSeed))) Int
  (measure (struct seeds))
  (match seeds
    (Nil 0)
    ((Cons _ rest) (+ 1 (tm_seed_count rest)))))

(fn tm_pair_mode_name ((mode TmPairMode)) (List Int)
  (match mode
    ((TmGaugePairs) "gauge-orbit")
    ((TmOrbitPairs) "orbit-skeleton")
    ((TmAllPairs) "all-pairs")))

(fn tm_validate_seed
  ((m Module)
   (seed TmSeed)
   (members (List TmMember))
   (proposals (List TmProposal)))
  (List TmProposal)
  (match seed
    ((TmSeed schema guards left right a b)
     (match schema
       ((AuSchema (AuEquation lhs rhs) _)
        (match (tm_validate_schema lhs rhs guards members members 0)
          ((TmValidateBad) proposals)
          ((TmValidateOk support)
           (if (lt 1 support)
             (match (au_type_schema m schema left right)
               ((AuTypedSchemaErr _) proposals)
               ((AuTypedSchemaOk typed)
                (if (tm_typed_schema_well_formed typed)
                  (tm_proposal_insert
                    (TmProposal typed guards support a b)
                    proposals)
                  proposals)))
             proposals))))))))

(fn tm_validate_seeds
  ((m Module)
   (seeds (List TmSeed))
   (members (List TmMember))
   (proposals (List TmProposal)))
  (List TmProposal)
  (measure (struct seeds))
  (match seeds
    (Nil proposals)
    ((Cons seed rest)
     (tm_validate_seeds
       m
       rest
       members
       (tm_validate_seed m seed members proposals)))))

(fn tm_proposal_count ((proposals (List TmProposal))) Int
  (measure (struct proposals))
  (match proposals
    (Nil 0)
    ((Cons _ rest) (+ 1 (tm_proposal_count rest)))))

(fn tm_auth_find ((proposal TmProposal) (rules (List TmAuthRule)))
  (Option TmAuthRule)
  (measure (struct rules))
  (match rules
    (Nil None)
    ((Cons auth rest)
     (match proposal
       ((TmProposal typed guards _ _ _)
        (match auth
          ((TmAuthRule _ conditioned)
           (if (au_conditioned_rule_covers typed guards conditioned) (Some auth)
           (tm_auth_find proposal rest)))))))))

(fn tm_authenticated_count
  ((proposals (List TmProposal)) (rules (List TmAuthRule)))
  Int
  (measure (struct proposals))
  (match proposals
    (Nil 0)
    ((Cons proposal rest)
     (+
       (match (tm_auth_find proposal rules)
         (None 0)
         ((Some _) 1))
       (tm_authenticated_count rest rules)))))

(fn tm_authenticated_proposals
  ((proposals (List TmProposal)) (rules (List TmAuthRule)))
  (List TmProposal)
  (measure (struct proposals))
  (match proposals
    (Nil Nil)
    ((Cons proposal rest)
     (let ((more (tm_authenticated_proposals rest rules)))
       (match (tm_auth_find proposal rules)
         (None more)
         ((Some _) (Cons proposal more)))))))

(fn tm_worklist_proposals
  ((proposals (List TmProposal)) (rules (List TmAuthRule)))
  (List TmProposal)
  (measure (struct proposals))
  (match proposals
    (Nil Nil)
    ((Cons proposal rest)
     (let ((more (tm_worklist_proposals rest rules)))
       (match (tm_auth_find proposal rules)
         (None (Cons proposal more))
         ((Some _) more))))))

(fn tm_auth_domain_name ((domain TmAuthDomain)) (List Int)
  (match domain
    ((TmAuthEverywhere) "everywhere")
    ((TmAuthRoot) "root")
    ((TmAuthSpine) "spine")))

(fn tm_auth_rule_name ((conditioned TrsConditionedRule)) (List Int)
  (match conditioned
    ((TrsConditionedRule (TrsRule name _ _ _) _) (chars_of_sym (qn_name name)))))

(fn tm_auth_status ((proposal TmProposal) (rules (List TmAuthRule))) (List Int)
  (match (tm_auth_find proposal rules)
    (None "    PROOF-WORKLIST\n")
    ((Some (TmAuthRule domain conditioned))
     (tm_cat
       (list
         "    AUTHENTICATED "
         (tm_auth_domain_name domain)
         " "
         (tm_auth_rule_name conditioned)
         "\n")))))

(fn tm_meta_name ((arity Int) (index Int)) (List Int)
  (append_int "x" (show_int (- (- arity 1) index))))

(fn tm_distinct_lines ((arity Int) (guards (List AuDistinct))) (List Int)
  (measure (struct guards))
  (match guards
    (Nil "")
    ((Cons (AuDistinct a b) rest)
     (tm_cat
       (list
         " "
         (tm_meta_name arity a)
         " != "
         (tm_meta_name arity b)
         (tm_distinct_lines arity rest))))))

(fn tm_has_guards ((guards (List AuDistinct))) Bool
  (match guards
    (Nil False)
    ((Cons _ _) True)))

(fn tm_type_lines ((types (List Type)) (index Int)) (List Int)
  (measure (struct types))
  (match types
    (Nil "")
    ((Cons ty rest)
     (tm_cat
       (list
         " x"
         (show_int index)
         ":"
         (sp_bytes (sp_ty ty))
         (tm_type_lines rest (+ index 1)))))))

(fn tm_proposal_lines
  ((remaining Int)
   (table (List (Pair QName Symbol)))
   (proposals (List TmProposal))
   (rules (List TmAuthRule)))
  (List Int)
  (measure (struct proposals))
  (if (le remaining 0) Nil
  (match proposals
    (Nil Nil)
    ((Cons
       (TmProposal
         (AuTypedSchema (AuSchema (AuEquation lhs rhs) arity) types)
         guards
         support
         a
         b)
       rest)
     (match (sp_e table arity lhs)
       ((SpRErr _) (tm_proposal_lines remaining table rest rules))
       ((SpROk ldoc)
        (match (sp_e table arity rhs)
          ((SpRErr _) (tm_proposal_lines remaining table rest rules))
          ((SpROk rdoc)
           (tm_cat
             (list
               "  REMOVES "
               (show_int support)
               " GAIN "
               (show_int (* support (- (tm_expr_size lhs) (tm_expr_size rhs))))
               " ARITY "
               (show_int arity)
               " SEEDS "
               (show_int a)
               ","
               (show_int b)
               "\n"
               "    TYPES"
               (tm_type_lines types 0)
               "\n"
               "    "
               (sp_bytes ldoc)
               "\n"
               "    => "
               (sp_bytes rdoc)
               "\n"
               (if (tm_has_guards guards)
                 (tm_cat
                   (list
                     "    EMPIRICAL-GUARDS"
                     (tm_distinct_lines arity guards)
                     "\n"))
                 "")
               (tm_auth_status
                 (TmProposal
                   (AuTypedSchema (AuSchema (AuEquation lhs rhs) arity) types)
                   guards
                   support
                   a
                   b)
                 rules)
               (tm_proposal_lines (- remaining 1) table rest rules)))))))))))

(fn tm_sample_lines
  ((table (List (Pair QName Symbol)))
   (root Expr)
   (grammar Grammar)
   (ranks (List Int)))
  (List Int)
  (measure (struct ranks))
  (match ranks
    (Nil Nil)
    ((Cons rank rest)
     (match (sk_unrank root grammar rank)
       ((SkEErr msg)
        (tm_cat
          (list
            "    RANK "
            (show_int rank)
            " <unrank-error "
            msg
            ">\n"
            (tm_sample_lines table root grammar rest))))
       ((SkEOk candidate)
        (match (sp_e table 0 candidate)
          ((SpRErr msg)
           (tm_cat
             (list
               "    RANK "
               (show_int rank)
               " <spell-error "
               msg
               ">\n"
               (tm_sample_lines table root grammar rest))))
          ((SpROk doc)
           (tm_cat
             (list
               "    RANK "
               (show_int rank)
               " "
               (sp_bytes doc)
               "\n"
               (tm_sample_lines table root grammar rest))))))))))

(fn tm_bucket_lines
  ((remaining Int)
   (table (List (Pair QName Symbol)))
   (root Expr)
   (grammar Grammar)
   (bs (List KcBucket)))
  (List Int)
  (measure (struct bs))
  (if (le remaining 0) Nil
  (match bs
    (Nil Nil)
    ((Cons b rest)
     (if (lt 1 (kc_support b))
       (tm_cat
         (list
           "  BUCKET SUPPORT "
           (show_int (kc_support b))
           " REPRESENTATIVE "
           (show_int (kc_first b))
           "\n"
           (tm_sample_lines table root grammar (kc_samples b))
           (tm_bucket_lines (- remaining 1) table root grammar rest)))
       (tm_bucket_lines remaining table root grammar rest))))))

(fn tm_report
  ((path (List Int))
   (mode TmPairMode)
   (m Module)
   (table (List (Pair QName Symbol)))
   (root Expr)
   (grammar Grammar)
   (total Int)
   (accepted Int)
   (rejected Int)
   (census KcCensus)
   (members (List TmMember))
   (rules (List TmAuthRule)))
  (List Int)
  (match (tm_stats (kc_buckets census) 0 0 0)
    ((TmStats collided excess maximum)
     (let ((edges (tm_edges (kc_buckets census) members)))
       (let ((seeds (tm_mined_seeds mode edges)))
         (let ((proposals (tm_validate_seeds m seeds members Nil)))
           (let ((authenticated (tm_authenticated_count proposals rules)))
             (tm_cat
               (list
                 "TRANSITION-CENSUS "
                 path
                 "\n"
                 "PAIR-MODE "
                 (tm_pair_mode_name mode)
                 "\n"
                 "TOTAL "
                 (show_int total)
                 " ACCEPTED "
                 (show_int accepted)
                 " REJECTED "
                 (show_int rejected)
                 " BEHAVIORS "
                 (show_int (kc_bucket_count census))
                 " COLLIDED-BUCKETS "
                 (show_int collided)
                 " EXCESS "
                 (show_int excess)
                 " MAX-BUCKET "
                 (show_int maximum)
                 " UNIQUE-SCHEMAS "
                 (show_int (tm_seed_count seeds))
                 " VALIDATED-PROPOSALS "
                 (show_int (tm_proposal_count proposals))
                 " AUTHENTICATED "
                 (show_int authenticated)
                 " PROOF-WORKLIST "
                 (show_int (- (tm_proposal_count proposals) authenticated))
                 "\nTOP COLLISIONS\n"
                 (tm_bucket_lines 8 table root grammar (kc_ranked census))
                 "AUTHENTICATED BASIS\n"
                 (tm_proposal_lines
                   8
                   table
                   (tm_authenticated_proposals proposals rules)
                   rules)
                 "PROOF WORKLIST (complete-census replay)\n"
                 (tm_proposal_lines
                   8
                   table
                   (tm_worklist_proposals proposals rules)
                   rules)
                 "EXACT KEYS; ONLY AUTHENTICATED SCHEMAS ARE LICENSES\n")))))))))

(fn tm_space
  ((path (List Int))
   (mode TmPairMode)
   (m Module)
   (want Type)
   (ctx InvokeCtx)
   (probe FnDef)
   (scope RCtx)
   (cfg TeCfg)
   (rules (List TmAuthRule))
   (w World))
  World
  (match (te_make_space m want scope cfg)
    ((TeSpaceErr msg)
     (exit 1 (write (append_int "TRANSITION-MINE FAIL " msg) w)))
    ((TeSpaceOk (TeSpace table _ root grammar _))
     (match (sk_count root grammar)
       ((SkCErr msg)
        (exit 1 (write (append_int "TRANSITION-MINE FAIL " msg) w)))
       ((SkCOk total)
        (match
          (tm_sweep
            total
            total
            root
            grammar
            m
            want
            ctx
            probe
            (kc_empty)
            0
            0
            Nil)
          ((TmSweepErr msg)
           (exit 1 (write (append_int "TRANSITION-MINE FAIL " msg) w)))
          ((TmSweepOk census accepted rejected members)
           (write
             (tm_report path mode m table root grammar total accepted rejected
               census members rules)
             w))))))))

(fn tm_load_reductions
  ((path (List Int)) (m Module) (ctx InvokeCtx) (probe FnDef) (w World))
  (Pair TeReductionsR World)
  (match (te_canon_names ctx m)
    ((TeCanonNamesErr msg) (Pair (TeReductionsErr msg) w))
    ((TeCanonNamesOk canon_names)
     (match (te_observer_names ctx m)
       ((TeObserverNamesErr msg) (Pair (TeReductionsErr msg) w))
       ((TeObserverNamesOk observer_names)
        (match (te_spine_cfg ctx m)
          ((TeSpineCfgErr msg) (Pair (TeReductionsErr msg) w))
          ((TeSpineCfgOk spine_cfg)
           (te_load_reductions
             path
             (te_probe_qname probe)
             canon_names
             observer_names
             spine_cfg
             w))))))))

(fn tm_ready
  ((path (List Int)) (mode TmPairMode) (src (List Int)) (m Module) (w World))
  World
  (let ((ctx (prepare_invoke m)))
    (match (te_protocol m)
      ((TeSigErr msg)
       (exit 1 (write (append_int "TRANSITION-MINE FAIL protocol: " msg) w)))
      ((TeSigOk probe _ _ want obs)
       (if
         (type_eq
           obs
           (TCon (qn (quote List)) (Cons (TCon (qn (quote Int)) Nil) Nil)))
         (match (te_config ctx m)
           ((TeCfgErr msg)
            (exit 1 (write (append_int "TRANSITION-MINE FAIL config: " msg) w)))
           ((TeCfgOk cfg)
            (match (tm_load_reductions path m ctx probe w)
              ((Pair (TeReductionsErr msg) w2)
               (exit
                 1
                 (write (append_int "TRANSITION-MINE FAIL reductions: " msg) w2)))
              ((Pair (TeReductionsOk reductions) w2)
               (tm_space
                 path
                 mode
                 m
                 want
                 ctx
                 probe
                 (te_import_ctx m path src)
                 cfg
                 (tm_auth_reductions reductions)
                 w2)))))
         (exit
           1
           (write
             "TRANSITION-MINE FAIL search_probe observation must be List Int\n"
             w)))))))

(fn tm_bytes_eq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        (_ False)))
    ((Cons x rest)
     (match b
       (Nil False)
       ((Cons y rest2) (if (int_eq x y) (tm_bytes_eq rest rest2) False))))))

(fn tm_main_path ((path (List Int)) (mode TmPairMode) (w World)) World
  (match (load_run_module path w)
    ((Pair None w2)
     (exit 1 (write "TRANSITION-MINE FAIL task module load\n" w2)))
    ((Pair (Some m) w2)
     (match (read_file path w2)
       ((Pair None w3)
        (exit 1 (write "TRANSITION-MINE FAIL task source read\n" w3)))
       ((Pair (Some src) w3) (tm_ready path mode src m w3))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons path Nil) (tm_main_path path (TmGaugePairs) w1))
       ((Cons path (Cons mode Nil))
        (if (tm_bytes_eq mode "orbit") (tm_main_path path (TmOrbitPairs) w1)
        (if (tm_bytes_eq mode "all") (tm_main_path path (TmAllPairs) w1)
        (exit 2 (write "usage: transition_mine TASK.shard [orbit|all]\n" w1)))))
       (_ (exit 2 (write "usage: transition_mine TASK.shard [orbit|all]\n" w1)))))))
