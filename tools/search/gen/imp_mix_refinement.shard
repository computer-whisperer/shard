;;; The depth-2 imp search's lowest solution for lg_mix (BEST 6).  The search
;;; found that the source's 2*x + (y-x) is simply x+y, replacing rank 4760's
;;; nested implementation with the depth-1 expression at rank 6.  This checked
;;; pin also records the contract improvement: only the final U32 result must
;;; fit, rather than every intermediate in the source spelling.

(import "../../../kernel/stdlib.shard")
(import "../../lowbuild/fixtures/wasmgen_src.shard")
(import "../../lowbuild/fixtures/wasmgen_out.shard")
(import "../../../models/imp/imp.shard")
(import "../../../models/imp/to_wasm.shard")
(import "../../../models/wasm/wasm.shard")
(use (:: tools lowbuild fixtures wasmgen_src lg_add))
(use (:: tools lowbuild fixtures wasmgen_src lg_mix))
(use (:: tools lowbuild fixtures wasmgen_out lowered_lg_add))
(use (:: models imp imp *))
(use (:: models imp to_wasm imp2w_fn))
(use (:: models imp to_wasm w_of))
(use (:: models wasm wasm *))

;; BEST 6 from tools/search/tasks/imp_mix.shard under meta/sketch addressing.
(fn searched_mix_fn () IFn
  (MkIFn (list U32 U32) Nil Nil (IBin U32 IAdd (ILoc 0) (ILoc 1)) U32))

(claim searched_mix_tie
  (goal () ()
    (=
      (w_of (imp2w_fn (searched_mix_fn)))
      (MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Bin BAdd)))))
  (steps ((compute both)) refl))

(claim searched_mix_algebra
  (goal ((x Int) (y Int)) () (= (lg_add x y) (lg_mix x y)))
  (auto))

(claim searched_mix_wasm
  (goal ((x Int) (y Int) (c Nat))
    ((= (le 0 (+ x y)) True) (= (lt (+ x y) 4294967296) True))
    (=
      (call_fn
        (S^ 9 c)
        (MkWModule (list (w_of (imp2w_fn (searched_mix_fn)))) 0)
        0
        (list x y))
      (Some (lg_mix x y))))
  (chain
    (rewrite-with (lemma searched_mix_tie) lr lhs () ())
    (rewrite-with
      (lemma lowered_lg_add)
      lr
      lhs
      ((inst restfs Nil))
      ((steps ((rewrite (premise 0) lr lhs true ())) refl)
       (steps ((rewrite (premise 1) lr lhs true ())) refl)))
    (rewrite-with (lemma searched_mix_algebra) lr lhs () ())
    refl))
