;;; Nested imp refinement under the general reflected grammar.  This is the
;;; typed-scope counterpart of imp_mix.shard: no imp production is named by
;;; the engine, and the broad Int atom pool is narrowed by ikchk.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(import "../../../models/imp/imp.shard")
(import "../../../examples/wasmgen_src.shard")

(use (:: models imp imp IExp))
(use (:: models imp imp ILoc))
(use (:: models imp imp IConst))
(use (:: models imp imp IBin))
(use (:: models imp imp U32))
(use (:: models imp imp IAdd))
(use (:: models imp imp ISub))
(use (:: models imp imp IMul))

(use (:: models imp imp) as imp)
(use (:: std mem) as mem)
(use (:: examples wasmgen_src) as spec)

(fn search_forms () (List Symbol) (list (quote ctor)))

(fn search_ints () (List Int) (list 0 1 2))

(fn search_symbols () (List Symbol) Nil)

;; Constructor depth counts ILoc/IConst themselves.  Depth three therefore
;; reaches the same nested-IBin shape as imp_expr's depth-two grammar.
(fn search_depth () Int 3)

(fn search_observe ((e IExp)) (List (Option Int))
  (list
    ((:: imp iexp) e (list 0 0) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 0 1) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 1 1) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 1 2) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 2 7) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 7 31) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 31 255) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 65535 100000) ((:: mem mem_empty)) 0)
    ((:: imp iexp) e (list 2147483647 2147483648) ((:: mem mem_empty)) 0)))

(fn search_probe ((e IExp)) (Option (List (Option Int)))
  (if ((:: imp ikchk) (list ((:: imp U32)) ((:: imp U32))) e ((:: imp U32)))
    (Some (search_observe e))
    None))

(fn search_target () (List (Option Int))
  (list
    (Some ((:: spec lg_mix) 0 0))
    (Some ((:: spec lg_mix) 0 1))
    (Some ((:: spec lg_mix) 1 1))
    (Some ((:: spec lg_mix) 1 2))
    (Some ((:: spec lg_mix) 2 7))
    (Some ((:: spec lg_mix) 7 31))
    (Some ((:: spec lg_mix) 31 255))
    (Some ((:: spec lg_mix) 65535 100000))
    (Some ((:: spec lg_mix) 2147483647 2147483648))))

(fn search_witness () IExp
  (IBin
    U32
    IAdd
    (IBin U32 IMul (ILoc 0) (IConst 2))
    (IBin U32 ISub (ILoc 1) (ILoc 0))))
