;;; Cardinality-free regular-schema regression for residual theorem pressure.
;;; The checked observer theorem relates two constructor positions together,
;;; so it cannot become an independent formation exclusion.  First-result
;;; search must therefore match and partition it against lazy occurrences.

(import "../../../kernel/stdlib.shard")
(import "observer_model.shard")

(use (:: tools search tasks observer_model Tagged))
(use (:: tools search tasks observer_model Keep))
(use (:: tools search tasks observer_model Noise))
(use (:: tools search tasks observer_model Trio))

(fn search_forms () (List Symbol) (list (quote ctor)))
(fn search_ints () (List Int) (list 1))
(fn search_symbols () (List Symbol) Nil)
(fn search_depth () Int 2)

(fn search_result_mode () Symbol (quote first))
(fn search_drive_budget () Int 100)

(fn observe_tagged ((candidate Tagged)) Int
  (match candidate
    ((Keep n) n)
    ((Noise n) n)))

(fn search_probe ((candidate Trio)) (Option Int)
  (match candidate
    ((Trio left middle right)
     (Some
       (+
         (+ (observe_tagged left) (observe_tagged middle))
         (observe_tagged right))))))

(claim keeps_observe_as_noises
  (goal ((a Int) (b Int) (rest Tagged)) ()
    (=
      (search_probe (Trio (Keep a) (Keep b) rest))
      (search_probe (Trio (Noise a) (Noise b) rest))))
  (steps
    ((unfold search_probe lhs)
     (unfold search_probe rhs)
     (reduce lhs)
     (reduce rhs)
     (unfold observe_tagged lhs)
     (unfold observe_tagged lhs)
     (unfold observe_tagged rhs)
     (unfold observe_tagged rhs)
     (reduce lhs)
     (reduce rhs))
    refl))

(fn search_observer_profile () (List Symbol)
  (list (quote keeps_observe_as_noises)))

(fn search_target () Int 3)
(fn search_witness () Trio (Trio (Noise 1) (Noise 1) (Keep 1)))
