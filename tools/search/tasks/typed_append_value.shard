;;; Theorem-filtered dynamic search over ordinary Shard list expressions.
;;;
;;; The raw depth-5 language contains Nil, Cons over {0,1}, and std/list
;;; append.  It has 210,066,388,900 members.  The task explicitly selects the
;;; four checked append requirements as an ordered canon profile.  Their exact
;;; separable formation projection removes every append redex before ranking,
;;; leaving the 63 canonical bit lists of length at most five.

(import "../../../kernel/stdlib.shard")
(import "../../../std/list")

;; Candidate vocabulary.
(use (:: core List))
(use (:: core Nil))
(use (:: core Cons))
(use (:: std list append))

;; Explicit theorem authority for generation filtering.  Merely importing the
;; module would not license these rules; each selected name must be a checked
;; claim or granted requirement in this root scope.
(use (:: std list append_nil_left))
(use (:: std list append_cons))
(use (:: std list append_assoc))
(use (:: std list append_nil_right))

(fn search_forms () (List Symbol) (list (quote ctor) (quote call)))

(fn search_ints () (List Int) (list 0 1))

(fn search_symbols () (List Symbol) Nil)

(fn search_depth () Int 5)

(fn search_canon_profile () (List Symbol)
  (list
    (quote append_nil_left)
    (quote append_cons)
    (quote append_assoc)
    (quote append_nil_right)))

;; Identity observation makes the first differing list cell an immediate
;; branch failure in the lazy comparator.
(fn search_probe ((xs (List Int))) (Option (List Int)) (Some xs))

(fn search_target () (List Int) (list 0 1))

(fn search_witness () (List Int) (list 0 1))
