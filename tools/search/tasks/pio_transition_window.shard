;;; Checked PIO transition-window narrowing (docs/PIO.md P5b).
;;;
;;; The x86_transition_window pattern over the PIO model: the same
;;; zero-to-three instruction straight-line scope as pio_transition_mining,
;;; now searched under CHECKED spine pressure.  The probe is a task-local
;;; total projection of the straight-line fragment (PTW below) — pio_run
;;; carries the program inside its configuration, so prefix induction is
;;; stated over the projection and the real model is tied back by a
;;; flagship theorem on pio_run/pio_final plus a ground observer-agreement
;;; pin.  The checked laws are the mining census's top schema family: a
;;; same-value pin re-drive absorbs into delay cycles.  Each law holds for
;;; EVERY start state and carries its MovOp as a nonlinear metavariable —
;;; both sides compute the identical stuck operation, so no case split and
;;; no premise is needed.  The mined mov-y collapse family (pins-y-y =>
;;; pins-pins) needs a y-is-32-bit-word state premise, which spine capture
;;; refuses by design; it stays on the proof worklist.
;;;
;;; RUN:
;;;   bin/shard_eval run tools/search/typed_superpose.shard \
;;;     tools/search/tasks/pio_transition_window.shard audit

(import "../../../kernel/stdlib.shard")
(import "../../../models/pio/pio.shard")
(import "../typed_grammar.shard")
(use (:: tools search typed_grammar *))

;; Generic program spine.
(use (:: core List))
(use (:: core Nil))
(use (:: core Cons))
(use (:: core None))

;; Candidate PIO scope.
(use (:: models pio pio PIns))
(use (:: models pio pio MkPIns))
(use (:: models pio pio PInstr))
(use (:: models pio pio POut))
(use (:: models pio pio OutDst))
(use (:: models pio pio ODX))
(use (:: models pio pio PMov))
(use (:: models pio pio MovDst))
(use (:: models pio pio MDY))
(use (:: models pio pio MDPins))
(use (:: models pio pio MovOp))
(use (:: models pio pio MOInvert))
(use (:: models pio pio MONone))
(use (:: models pio pio MOReverse))
(use (:: models pio pio MovSrc))
(use (:: models pio pio MSY))
(use (:: models pio pio PSlot))
(use (:: models pio pio PCfg))
(use (:: models pio pio PSt))

;; Broad model access is observer-only and adds no candidate productions.
(use (:: models pio pio) as pio)

(fn search_forms () (List Symbol) (list (quote ctor)))

(fn search_ints () (List Int) Nil)

(fn search_symbols () (List Symbol) Nil)

(fn search_depth () Int 8)

;; Narrowing stays semantic-first (the default): this task's observation is
;; a cycle TRACE, so behavioral prefixes kill broad parents early — measured
;; 45 regions / 2408 steps vs 140 / 3418 under theorem_first, the opposite
;; of the state-observed x86 window census.  The checked laws still settle
;; the same 44-candidate quotient either way.

(fn ptw_ctor ((name Symbol)) TgScopeHead (TgScopeCtor name))

(fn ptw_route ((head Symbol) (index Int) (zone Symbol)) TgScopeRoute
  (TgScopeRoute (ptw_ctor head) index zone))

(fn ptw_one ((name Symbol) (head Symbol)) TgScopeZone
  (TgScopeZone name (list (ptw_ctor head)) Nil Nil Nil))

(fn ptw_seq_zone ((name Symbol) (instruction Symbol) (tail Symbol)) TgScopeZone
  (TgScopeZone
    name
    (list (ptw_ctor (quote Nil)) (ptw_ctor (quote Cons)))
    Nil
    Nil
    (list
      (ptw_route (quote Cons) 0 instruction)
      (ptw_route (quote Cons) 1 tail))))

(fn search_environment () TgScopeEnv
  (TgScopeEnv
    (quote sequence0)
    (list
      (ptw_seq_zone (quote sequence0) (quote instruction) (quote sequence1))
      (ptw_seq_zone (quote sequence1) (quote instruction) (quote sequence2))
      (ptw_seq_zone (quote sequence2) (quote instruction) (quote sequence3))
      (TgScopeZone (quote sequence3) (list (ptw_ctor (quote Nil))) Nil Nil Nil)
      (TgScopeZone
        (quote instruction)
        (list (ptw_ctor (quote MkPIns)))
        Nil
        Nil
        (list
          (ptw_route (quote MkPIns) 0 (quote operation))
          (ptw_route (quote MkPIns) 1 (quote sideset))
          (ptw_route (quote MkPIns) 2 (quote delay))))
      (TgScopeZone
        (quote operation)
        (list (ptw_ctor (quote POut)) (ptw_ctor (quote PMov)))
        Nil
        Nil
        (list
          (ptw_route (quote POut) 0 (quote odx))
          (ptw_route (quote POut) 1 (quote one))
          (ptw_route (quote PMov) 0 (quote movdst))
          (ptw_route (quote PMov) 1 (quote movop))
          (ptw_route (quote PMov) 2 (quote msy))))
      (TgScopeZone
        (quote movdst)
        (list (ptw_ctor (quote MDY)) (ptw_ctor (quote MDPins)))
        Nil
        Nil
        Nil)
      (TgScopeZone
        (quote movop)
        (list (ptw_ctor (quote MOInvert)) (ptw_ctor (quote MONone)))
        Nil
        Nil
        Nil)
      (ptw_one (quote odx) (quote ODX))
      (ptw_one (quote msy) (quote MSY))
      (ptw_one (quote sideset) (quote None))
      (TgScopeZone (quote one) Nil (list 1) Nil Nil)
      (TgScopeZone (quote delay) Nil (list 0 1) Nil Nil))))

;; --- the straight-line projection --------------------------------------------------

;; Exactly the state the fragment can read or write, with the pin and pindir
;; latches held as single BITS (the mining observer's band-1 view).  Keeping
;; the latch pre-masked makes every window law an identity of one shared
;; stuck term, so the laws hold for arbitrary Int fields with no
;; normalization premise (the x86 adapter needed a word invariant here).
(type PTW (MkPTW Int Int Int Int Int Int))

(fn ptw_op ((op MovOp) (v Int)) Int
  (match op
    (MONone v)
    (MOInvert (bxor v 4294967295))
    (MOReverse ((:: pio rev_bits) v))))

;; One instruction's state action, mirroring the model's out_shift/exec_mov
;; arms for the searched scope (out_right = 1, out_base 0, out_count 1, no
;; autopull, so nothing ever stalls).  Non-fragment instructions are
;; observational no-ops and are absent from the reflected candidate scope.
(fn ptw_step ((i PIns) (st PTW)) PTW
  (match i
    ((MkPIns op side delay)
     (match st
       ((MkPTW x y osr oc pin dir)
        (match op
          ((POut d b)
           (match d
             (ODX
               (MkPTW
                 (band osr ((:: pio bit_lo) b))
                 y
                 (bshr osr b)
                 ((:: pio imin) (+ oc b) 32)
                 pin
                 dir))
             (_ st)))
          ((PMov d o s)
           (match s
             (MSY
               (match d
                 (MDY (MkPTW x (ptw_op o y) osr oc pin dir))
                 (MDPins (MkPTW x y osr oc (band (ptw_op o y) 1) dir))
                 (_ st)))
             (_ st)))
          (_ st)))))))

(fn ptw_reps ((n Int) (b Int)) (List Int)
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) Nil (Cons b (ptw_reps (- n 1) b))))

;; The observed pad bit: driven level AND output-enable, like the model's
;; compose at bit 0.
(fn ptw_bit ((st PTW)) Int
  (match st
    ((MkPTW x y osr oc pin dir) (band pin dir))))

(fn ptw_app ((a (List Int)) (b (List Int))) (List Int)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons head tail) (Cons head (ptw_app tail b)))))

;; The pin-0 cycle trace: an instruction occupies 1 + delay cycles and the
;; post-execute level is visible on every one of them (the model records
;; levels AFTER the step, and a delay cycle only counts down).
(fn ptw_wave ((body (List PIns)) (st PTW)) (List Int)
  (measure (struct body))
  (match body
    (Nil Nil)
    ((Cons i rest)
     (let ((st1 (ptw_step i st)))
       (ptw_app
         (ptw_reps (+ 1 ((:: pio pi_delay_of) i)) (ptw_bit st1))
         (ptw_wave rest st1))))))

(fn ptw_fin ((body (List PIns)) (st PTW)) PTW
  (measure (struct body))
  (match body
    (Nil st)
    ((Cons i rest) (ptw_fin rest (ptw_step i st)))))

(fn ptw_key ((st PTW)) (List Int)
  (match st
    ((MkPTW x y osr oc pin dir) (list x y osr oc pin dir))))

(fn ptw_key1 ((body (List PIns)) (st PTW)) (List Int)
  (ptw_app (ptw_wave body st) (ptw_key (ptw_fin body st))))

;; The mining seeds' projections: (x y osr osr_cnt pin dir).
(fn ptw_seeds () (List PTW)
  (list
    (MkPTW 0 0 22 0 1 1)
    (MkPTW 1 4294967295 21 0 0 1)
    (MkPTW 1 0 10 0 0 1)
    (MkPTW 0 4294967295 30 0 1 1)))

(fn ptw_observe ((body (List PIns)) (seeds (List PTW))) (List Int)
  (measure (struct seeds))
  (match seeds
    (Nil Nil)
    ((Cons st rest) (ptw_app (ptw_key1 body st) (ptw_observe body rest)))))

(fn search_probe ((body (List PIns))) (Option (List Int))
  (Some (ptw_observe body (ptw_seeds))))

(fn search_target () (List Int) (ptw_observe Nil (ptw_seeds)))

(fn search_witness () (List PIns) Nil)

;; Transparent right action used to authenticate contextual sequence laws.
;; theorem_scope derives the Cons/tail path from this body; the task never
;; states that path as configuration data.
(fn ptw_plug ((prefix (List PIns)) (suffix (List PIns))) (List PIns)
  (measure (struct prefix))
  (match prefix
    (Nil suffix)
    ((Cons head tail) (Cons head (ptw_plug tail suffix)))))

;; --- law A: pins[0] pins[1] y[0]  =>  pins[1] y[1]  (drive-absorb) -----------------
;;
;; Both sides drive the same value for four cycles and land in the same
;; state: the second same-value drive is a delay in disguise.  The MovOp
;; stays a shared stuck term, so one theorem covers invert/none/reverse.

(claim ptw_absorb_a_wave_tail
  (goal ((tail (List PIns)) (st PTW) (x0 MovOp)) ()
    (=
      (ptw_wave
        (Cons
          (MkPIns (PMov MDPins x0 MSY) None 0)
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail)))
        st)
      (ptw_wave
        (Cons
          (MkPIns (PMov MDPins x0 MSY) None 1)
          (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail))
        st)))
  (case-on st PTW
    ((case MkPTW
       (x y osr oc pin dir)
       (steps ((rewrite (hyp MkPTW) lr both true ()) (compute both)) refl)))))

(claim ptw_absorb_a_fin_tail
  (goal ((tail (List PIns)) (st PTW) (x0 MovOp)) ()
    (=
      (ptw_fin
        (Cons
          (MkPIns (PMov MDPins x0 MSY) None 0)
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail)))
        st)
      (ptw_fin
        (Cons
          (MkPIns (PMov MDPins x0 MSY) None 1)
          (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail))
        st)))
  (case-on st PTW
    ((case MkPTW
       (x y osr oc pin dir)
       (steps ((rewrite (hyp MkPTW) lr both true ()) (compute both)) refl)))))

(claim ptw_absorb_a_wave_ctx
  (goal ((prefix (List PIns)) (tail (List PIns)) (st PTW) (x0 MovOp)) ()
    (=
      (ptw_wave
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 0)
            (Cons
              (MkPIns (PMov MDPins x0 MSY) None 1)
              (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail))))
        st)
      (ptw_wave
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail)))
        st)))
  (induct prefix
    ((case Nil
       (steps
         ((unfold ptw_plug both)
          (reduce both)
          (rewrite (lemma ptw_absorb_a_wave_tail) lr lhs true ()))
         refl))
     (case Cons
       (head rest)
       (steps ((simp both) (rewrite (hyp ih) lr lhs true ())) refl)))))

(claim ptw_absorb_a_fin_ctx
  (goal ((prefix (List PIns)) (tail (List PIns)) (st PTW) (x0 MovOp)) ()
    (=
      (ptw_fin
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 0)
            (Cons
              (MkPIns (PMov MDPins x0 MSY) None 1)
              (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail))))
        st)
      (ptw_fin
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail)))
        st)))
  (induct prefix
    ((case Nil
       (steps
         ((unfold ptw_plug both)
          (reduce both)
          (rewrite (lemma ptw_absorb_a_fin_tail) lr lhs true ()))
         refl))
     (case Cons
       (head rest)
       (steps ((simp both) (rewrite (hyp ih) lr lhs true ())) refl)))))

(claim ptw_absorb_a_observe
  (goal ((prefix (List PIns)) (tail (List PIns)) (seeds (List PTW)) (x0 MovOp))
    ()
    (=
      (ptw_observe
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 0)
            (Cons
              (MkPIns (PMov MDPins x0 MSY) None 1)
              (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail))))
        seeds)
      (ptw_observe
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail)))
        seeds)))
  (induct seeds
    ((case Nil (steps ((simp both)) refl))
     (case Cons
       (rs rest)
       (steps
         ((unfold ptw_observe both)
          (reduce both)
          (unfold ptw_key1 both)
          (reduce both)
          (rewrite (lemma ptw_absorb_a_wave_ctx) lr lhs true ())
          (rewrite (lemma ptw_absorb_a_fin_ctx) lr lhs true ())
          (rewrite (hyp ih) lr lhs true ()))
         refl)))))

(claim ptw_absorb_a_spine
  (goal ((prefix (List PIns)) (tail (List PIns)) (x0 MovOp)) ()
    (=
      (search_probe
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 0)
            (Cons
              (MkPIns (PMov MDPins x0 MSY) None 1)
              (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail)))))
      (search_probe
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 1)
            (Cons (MkPIns (PMov MDY x0 MSY) None 1) tail))))))
  (steps
    ((unfold search_probe both)
     (rewrite (lemma ptw_absorb_a_observe) lr lhs true ()))
    refl))

