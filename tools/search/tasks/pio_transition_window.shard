  (goal ((prefix (List PIns)) (tail (List PIns)) (st PTW) (x0 MovOp)) ()
    (=
      (ptw_fin
        (ptw_plug
          prefix
          (Cons
            (MkPIns (PMov MDPins x0 MSY) None 0)
            (Cons
              (MkPIns (PMov MDPins x0 MSY) None 0)
              (Cons (MkPIns (PMov MDY x0 MSY) None 0) tail))))
        st)
