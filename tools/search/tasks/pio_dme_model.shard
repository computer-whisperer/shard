;;; The delay-normal candidate language for the template-free DME search
;;; (docs/PIO.md P5c; companion of pio_dme_free.shard, which holds the
;;; decoder, the grammar, and the kernel-checked encoder pins).
;;;
;;; One slot: consume a bit / toggle Y / drive the pin with a hold / jump.
;;; Delay fields appear exactly where timing is load-bearing — the mined
;;; and proven delay-splitting gauge (P5a/P5b) is unrepresentable by
;;; construction.

(import "../../../kernel/stdlib.shard")
(import "../../../models/pio/pio.shard")

(use (:: models pio pio MovOp))
(use (:: models pio pio JmpCond))

(type PDFOp (PDFOut) (PDFTogg) (PDFDrive MovOp Int) (PDFJump JmpCond Int Int))
