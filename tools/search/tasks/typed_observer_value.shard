;;; Root-only observational reduction regression.
;;;
;;; The raw candidate language has four distinct Tagged values.  The checked
;;; theorem does NOT claim `(Noise n) = (Keep n)`; it proves equality only
;;; through this task's exact search_probe.  `search_observer_profile` strips
;;; that common observer after CHECK authentication and filters
;;; `Leaf (Noise n)` only at the candidate root.  In particular,
;;; `Wrap (Leaf (Noise n))` remains: applying the theorem recursively below
;;; Wrap would exceed its license.

(import "../../../kernel/stdlib.shard")
(import "observer_model.shard")

(use (:: tools search tasks observer_model Tagged))
(use (:: tools search tasks observer_model Keep))
(use (:: tools search tasks observer_model Noise))
(use (:: tools search tasks observer_model Nest))
(use (:: tools search tasks observer_model Leaf))
(use (:: tools search tasks observer_model Wrap))

(fn search_forms () (List Symbol) (list (quote ctor)))
(fn search_ints () (List Int) (list 1))
(fn search_symbols () (List Symbol) Nil)
(fn search_depth () Int 3)

(fn observe_tagged ((candidate Tagged)) Int
  (match candidate
    ((Keep n) n)
    ((Noise n) n)))

(fn observe_nest ((candidate Nest)) Int
  (measure (struct candidate))
  (match candidate
    ((Leaf tagged) (observe_tagged tagged))
    ((Wrap inner) (observe_nest inner))))

(fn search_probe ((candidate Nest)) (Option Int)
  (Some (observe_nest candidate)))

(claim noise_observes_as_keep
  (goal ((n Int)) ()
    (= (search_probe (Leaf (Noise n))) (search_probe (Leaf (Keep n)))))
  (steps
    ((unfold search_probe lhs)
     (unfold search_probe rhs)
     (unfold observe_nest lhs)
     (unfold observe_nest rhs)
     (reduce lhs)
     (reduce rhs)
     (unfold observe_tagged lhs)
     (unfold observe_tagged rhs)
     (reduce lhs)
     (reduce rhs))
    refl))

(fn search_observer_profile () (List Symbol)
  (list (quote noise_observes_as_keep)))

(fn search_target () Int 1)
(fn search_witness () Nest (Leaf (Keep 1)))
