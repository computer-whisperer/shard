;;; Tiny interpreted-ADT vocabulary for the generic observer-reduction pin.
;;; `Keep n` and `Noise n` are distinct data.  Only a consumer's observer can
;;; prove that its search objective deliberately identifies them.

(import "../../../kernel/stdlib.shard")

(type Tagged (Keep Int) (Noise Int))

;; Two independently chosen Tagged fields make conjunctive observer patterns
;; visible to the generic search-constraint engine.
(type Duo (Duo Tagged Tagged))

;; The third field is left unconstrained by the residual theorem pin, so one
;; definite match covers a nontrivial subtree of the candidate grammar.
(type Trio (Trio Tagged Tagged Tagged))

;; Nest makes the root-only boundary observable: a theorem about
;; `search_probe (Leaf ...)` must not silently rewrite a Leaf below Wrap.
(type Nest (Leaf Tagged) (Wrap Nest))
