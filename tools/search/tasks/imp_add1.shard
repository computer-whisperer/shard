;;; Standard task module for tools/search/imp_expr.shard.  Only task data and
;;; oracle code live here; the search engine has no add1 branch.

(import "../../../kernel/stdlib.shard")
(import "../../../std/mem")
(import "../../../models/imp/imp.shard")
(import "../../lowbuild/fixtures/wasmgen_src.shard")
(use (:: std mem mem_empty))
(use (:: models imp imp *))
(use (:: tools lowbuild fixtures wasmgen_src lg_add1))

(fn search_local_kinds () (List IKind) (list U32))

(fn search_result_kind () IKind U32)

(fn search_constants () (List Int) (list 0 1 2))

(fn search_ops () (List IOp) (list IAdd ISub IMul))

(fn search_depth () Int 1)

(fn search_wf ((e IExp)) Bool (ikchk (list U32) e U32))

;; Eight fit-domain probes.  The top value is the boundary witness just below
;; U32 overflow; the spec⊑imp theorem carries the same fit discipline.
(fn search_observe ((e IExp)) (List (Option Int))
  (list
    (iexp e (list 0) (mem_empty) 0)
    (iexp e (list 1) (mem_empty) 0)
    (iexp e (list 2) (mem_empty) 0)
    (iexp e (list 7) (mem_empty) 0)
    (iexp e (list 31) (mem_empty) 0)
    (iexp e (list 255) (mem_empty) 0)
    (iexp e (list 65535) (mem_empty) 0)
    (iexp e (list 4294967294) (mem_empty) 0)))

(fn search_probe ((e IExp)) (Option (List (Option Int)))
  (if (search_wf e) (Some (search_observe e)) None))

(fn search_target () (List (Option Int))
  (list
    (Some (lg_add1 0))
    (Some (lg_add1 1))
    (Some (lg_add1 2))
    (Some (lg_add1 7))
    (Some (lg_add1 31))
    (Some (lg_add1 255))
    (Some (lg_add1 65535))
    (Some (lg_add1 4294967294))))

;; This exact value is already certified spec⊑imp and imp⊑wasm in the scalar
;; tower.  The engine must rediscover it by rank; the generated G4 pin imports
;; those theorems and closes the searched wasm statement.
(fn search_witness () IExp (IBin U32 IAdd (ILoc 0) (IConst 1)))
