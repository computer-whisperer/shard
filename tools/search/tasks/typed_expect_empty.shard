;;; Cardinality-free exhaustive-absence regression.  The candidate language is
;;; exactly the two integer atoms 0 and 1, while the target observation is 2.
;;; No positive witness exists: completing the whole census is the witness.

(import "../../../kernel/stdlib.shard")
(import "../../../std/list")

(use (:: core List))
(use (:: core Nil))
(use (:: core Some))
(use (:: std list list))

(fn search_forms () (List Symbol) Nil)
(fn search_ints () (List Int) (list 0 1))
(fn search_symbols () (List Symbol) Nil)
(fn search_depth () Int 0)

(fn search_result_mode () Symbol (quote exhaustive))

(fn search_probe ((candidate Int)) (Option Int) (Some candidate))
(fn search_target () Int 2)
(fn search_expect_empty () Bool True)
