(import "../../kernel/driver.shard")
(import "../../kernel/canon.shard")
(import "../../meta/sketch")
(import "../../meta/invoke")
(import "../../meta/doc")
(import "../../meta/spell")
(import "../../meta/format")
(import "sym.shard")
(import "rev.shard")
(import "catalog.shard")
(import "render_gate.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel proof Goal))
(use (:: kernel proof Param))
(use (:: kernel proof Equation))
(use (:: kernel reader Decl))
(use (:: kernel reader DClaim))
(use (:: kernel reader DAxiom))
(use (:: kernel reader DReq))
(use (:: kernel reader DFul))
(use (:: kernel reader Req))
(use (:: kernel reader req_name))
(use (:: kernel reader req_goal))
(use (:: kernel reader RCtx))
(use (:: kernel reader parse_decls))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMRes))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: kernel reduce run_expr))
(use (:: kernel loader resolve_closure))
(use (:: kernel loader World))
(use (:: kernel loader read_file))
(use (:: kernel loader write_file))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader exit))
(use (:: kernel driver file_rctx))
