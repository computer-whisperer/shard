;;; wasmgen — the certifying emitter (docs/LOWERING.md §6): the scalar
;;; let/if fragment. For every fn in the target file whose body is
;;; arithmetic over Int params, u32 literals (+ - * ediv mod band bor
;;; bxor), single-
;;; binding lets, and tail-position ifs over int_eq/lt/le comparisons, emit:
;;;   - the wasm function literal (postorder stack code; one LocalSet per
;;;     let, locals allocated after the params in textual order; each if
;;;     a Block/BrIf/Br diamond — True exits the inner block to the THEN
;;;     code, False falls through the ELSE code), and
;;;   - the standard lowered-conformance claim (docs/LOWERING.md §2) with
;;;     its full proof, in chain form mirroring the branch tree: compute
;;;     lhs + unfold/ζ-reduce SPEC rhs; per if a case-on with the fixed
;;;     arm template (rewrite ctor-named case hyp into both sides, compute
;;;     both — the probe-pinned fuel max+slack law needs ONE tower for the
;;;     longest path, no per-branch fuel); per unique arith node,
;;;     discharged in the REGION where its code executes, a named have
;;;     citing wrap32_id once + an all-occurrences rewrite of the have
;;;     fact (the sharing-proof pattern — a let-bound value read k times
;;;     duplicates k-fold under ζ but is discharged once).
;;; The emitted statement generator IS the schema consensus mechanism; the
;;; output is deterministic (weld discipline: regenerable byte-identical
;;; after shardfmt).
;;;
;;; THE CONTRACT (lower.shard's): front end is the KERNEL'S by library
;;; import; refuse, don't guess — any body outside the fragment is a loud
;;; per-fn error and exit 1. Fragment rules: all params Int, return Int;
;;; body nodes are params, let-bound names, literals in [0, 2^32), and
;;; binary + - * ediv mod band bor bxor; lets bind exactly one name; ifs in TAIL position
;;; only, conditions = int_eq/lt/le over params/aliases/literals (no arith
;;; in conditions — wraps must never enter the case-on spelling); every
;;; arith node of the SUBSTITUTED body must contain a param (constant-fold
;;; ground subtrees in the source). PREs are §6j-hygienic: arm-local
;;; premises are CONDITION-RELATIVE ((= (if COND BOUND True) True),
;;; stripped in-arm), and bounds derivable from read intervals or path
;;; conditions are discharged silently (wb_*/cb_* helper claims with
;;; computed farkas certs — no premise emitted).
;;; ediv/mod fns take the STAGED pure walk (§6y — guard PRE per symbolic
;;; divisor, compute interleaved with guard rewrites) and are
;;; straight-line/let only for now: div + if is behind the fence.
;;; band/bor/bxor are TRANSPARENT ops (§6z — prims applied directly, no
;;; wrap, no guard, no premise of their own) and compose everywhere the
;;; fragment goes, ifs included; bounds on containing arith nodes are
;;; consumer premises (std/bits is the discharge kit).
;;;
;;; THE MEM FRAGMENT (first param Mem): bodies that read/write bytes lower
;;; to wasm Calls against std/mem's shipped artifact functions and the
;;; proofs COMPOSE BY CITATION (call_bridge + lowered_mem_get/set) — the
;;; callee bodies are never computed into. See the mem-fragment section
;;; below for the fragment rules and the stage law.
;;;
;;; THE KIT: the reusable emitter library lives in tools/low — doc.shard
;;; (output documents + path/header text), schema.shard (canonical-expr
;;; spelling, premise layouts, statement builders), proof.shard (the
;;; wrap-event / call_bridge / link-derivation proof templates), and
;;; shape.shard (the FRONT END: fragment dispatch, the region-tree
;;; vocabulary, the loop-shape recognizers, the callee registry — the
;;; target-independent canonical source form). This file keeps what is
;;; genuinely the wasm BACK END: the code walks, claim assembly, proof
;;; emission, the module walk, and the CLI.
;;;
;;; RUN IT:  bin/shard_eval run tools/wasmgen/wasmgen.shard SRC OUT.raw
;;;          then shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reader.shard")
(import "../../meta/doc")
(import "../../meta/spell")
(import "../low/schema.shard")
(import "../../meta/lin")
(import "../../meta/proof")
(import "../../meta/shape")

(use (:: kernel loader resolve_closure))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term BVar))
(use (:: kernel term Call))
(use (:: kernel term Let))
(use (:: kernel term If))
(use (:: kernel term IntLit))
(use (:: kernel term Match))
(use (:: kernel term Arm))
(use (:: kernel term Pat))
(use (:: kernel term PCtor))
(use (:: kernel term PVar))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term core_named))
(use (:: kernel term append_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module FnTrie))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: kernel reader read_all))
(use (:: kernel reader SExpr))
(use (:: kernel reader is_lib_form))
(use (:: kernel reader lib_of_form))
(use (:: kernel reader Lib))
(use (:: kernel reader SrcEntry))
(use (:: kernel loader int_list_eq))
(use (:: meta doc *))
(use (:: meta spell *))
(use (:: tools low schema *))
(use (:: meta lin *))
(use (:: meta proof *))
(use (:: meta shape *))

;; ---- the wasm proof templates (moved from tools/low/proof in the
;; meta/proof split): the wrap event instantiated at the wasm modulus,
;; the PItem stage-law flush, the call_bridge citation builders, and
;; the link-derivation discharge templates.

(fn bnd_ltwrap ((e Doc)) Doc (dcat3 (DStr "(lt ") e (DStr " 4294967296)")))

;; the wasm instantiation of meta/proof's wrap_event (2^32 / wrap32_id)
(fn w32_event ((e Expr) (loref Doc) (hiref Doc) (j Int)) Doc
  (wrap_event e "4294967296" "wrap32_id" loref hiref j))

;; premise pair from the PItem layout (wrap pairs after the three fixed
;; portable slots — the mem fragment's discovery-order layout)
(fn m_event ((e Expr) (pres (List PItem)) (j Int)) Doc
  (let ((k (wrap_ix (spell e) pres 3))) (w32_event e (dint k) (dint (+ k 1)) j)))

;; the auto wrap event: a read-linear node's bounds derived (names bJ,
;; bJ+1), then the wrap event at wJ+2 citing them
(fn m_event_auto ((e Expr) (fnm Doc) (pres (List PItem)) (j Int)) Doc
  (let ((k (paut_ix (spell e) pres 0)))
    (let
      ((rs
         (match (pl_e e True)
           ((Some p) (pl_atoms p))
           (None Nil))))
      (dcat3
        (iv_have
          (DCat (DStr "b") (dint j))
          (bnd_le0 (pr_e e))
          (wb_name fnm k True)
          rs)
        (iv_have
          (DCat (DStr "b") (dint (+ j 1)))
          (bnd_ltwrap (pr_e e))
          (wb_name fnm k False)
          rs)
        (w32_event
          e
          (DCat (DStr "b") (dint j))
          (DCat (DStr "b") (dint (+ j 1)))
          (+ j 2))))))

;; ---- the stage-law flush ----------------------------------------------------------

(fn m_flush_go ((ns (List Expr)) (pres (List PItem)) (fnm Doc) (j Int))
  (Pair Doc Int)
  (measure (struct ns))
  (match ns
    (Nil (Pair (DStr "") j))
    ((Cons e t)
     (if (wrap_seen (spell e) pres)
       (match (m_flush_go t pres fnm (+ j 1))
         ((Pair d j2) (Pair (DCat (m_event e pres j) d) j2)))
       (match (m_flush_go t pres fnm (+ j 3))
         ((Pair d j2) (Pair (DCat (m_event_auto e fnm pres j) d) j2)))))))

;; flush the pending wrap events (dedup within the stage, walk order =
;; postorder — children collapse before parents read them)
(fn m_flush ((pend (List Expr)) (pres (List PItem)) (fnm Doc) (j Int))
  (Pair Doc Int)
  (m_flush_go (add_unique pend Nil) pres fnm j))

(fn m_stage_open () Doc (DStr "(steps ((compute lhs (stop eval_call)))) "))

;; ---- the call_bridge citation builders --------------------------------------------

(fn m_bridge_head () Doc
  (DStr "(rewrite-with (lemma call_bridge) lr lhs ((inst f "))

;; bridge premises 0-3: func_at via the spine premise, pop_n/arity via the
;; callee's arity premise (index aix), wrev by compute
(fn m_bridge_pre ((aix Int)) Doc
  (dcat3
    (dcat3
      (DStr
        "((steps ((rewrite (premise 0) lr lhs true ()) (compute both)) refl) (steps ((rewrite (premise ")
      (dint aix)
      (DStr ") lr lhs true ()) (compute both)) refl) "))
    (dcat3
      (DStr "(steps ((compute both)) refl) (steps ((rewrite (premise ")
      (dint aix)
      (DStr ") lr lhs true ()) (compute both)) refl) "))
    (DStr "")))

;; the run-premise sub-proof: THE behavior premise, verbatim
(fn m_run_sub ((bidx Int)) Doc
  (dcat3
    (DStr "(steps ((rewrite (premise ")
    (dint bidx)
    (DStr ") lr lhs true ())) refl)")))

;; the read bridge: f = the abstract slot-0 binder; the run premise is
;; the site's behavior premise, at the site's CURRENT memory mm
(fn m_bridge_get
  ((mm Expr) (addr Expr) (below (List Expr)) (rnode Expr) (bidx Int))
  Doc
  (dcat3
    (dcat3
      (dcat3 (m_bridge_head) (DStr "f0") (DStr ") (inst popped (Cons "))
      (dcat3 (pr_e addr) (DStr " Nil)) (inst rest ") (stack_spell below))
      (dcat3 (DStr ") (inst args (Cons ") (pr_e addr) (DStr " Nil)) (inst v ")))
    (dcat3
      (DCat (pr_e rnode) (DStr ") (inst mem2 "))
      (DCat (pr_e mm) (DStr ")) "))
      (m_bridge_pre 1))
    (dcat3 (m_run_sub bidx) (DStr ")) ") (DStr ""))))

;; the write bridge: f = the abstract slot-1 binder
(fn m_bridge_set
  ((mm Expr) (addr Expr) (val Expr) (below (List Expr)) (bidx Int))
  Doc
  (dcat3
    (dcat3
      (dcat3 (m_bridge_head) (DStr "f1") (DStr ") (inst popped (Cons "))
      (dcat3 (pr_e val) (DStr " (Cons ") (pr_e addr))
      (dcat3
        (DStr " Nil))) (inst rest ")
        (stack_spell below)
        (DStr ") (inst args (Cons ")))
    (dcat3
      (dcat3 (pr_e addr) (DStr " (Cons ") (pr_e val))
      (dcat3 (DStr " Nil))) (inst v ") (pr_e val) (DStr ""))
      (dcat3
        (DCat (DStr ") (inst mem2 (mem_set ") (pr_e mm))
        (DCat (sp) (pr_e addr))
        (DCat (sp) (pr_e val))))
    (dcat3
      (DCat (DStr "))) ") (m_bridge_pre 2))
      (dcat3 (m_run_sub bidx) (DStr ")) ") (DStr ""))
      (DStr ""))))

;; ---- link-derivation discharge templates ------------------------------------------

;; the two address sub-proofs for one behavior, by address class: cite the
;; linked cert's premise pair, compute a ground literal's bound, or derive
;; a read-linear address's bound via the generated ab helper
(fn ac_sub ((ac AC) (fnm Doc) (lo Bool)) Doc
  (match ac
    ((ACPrem k)
     (dcat3
       (DStr "(steps ((rewrite (premise ")
       (dint (if lo (* 2 k) (+ (* 2 k) 1)))
       (DStr ") lr lhs true ())) refl) ")))
    (ACGround (DStr "(steps ((compute both)) refl) "))
    ((ACRead k rs)
     (dcat3
       (dcat3
         (DStr "(rewrite-with (lemma ")
         (ab_name fnm k lo)
         (DCat (DStr ") lr lhs (") (pr_read_insts rs 0)))
       (dcat3 (DStr ") (") (get_subs rs) (DStr ") refl) "))
       (DStr "")))))

;; discharge one behavior premise by citing a shipped callee cert, its
;; two premises by the address's class
(fn link_beh ((cert (List Int)) (ac AC) (fnm Doc)) Doc
  (dcat3
    (dcat3 (DStr "(rewrite-with (lemma ") (DStr cert) (DStr ") lr lhs () "))
    (dcat3
      (DStr "(")
      (DCat (ac_sub ac fnm True) (ac_sub ac fnm False))
      (DStr ") "))
    (DStr "refl) ")))

(fn ac_at ((acs (List AC)) (i Int)) AC
  (measure (struct acs))
  (match acs
    (Nil ACGround)
    ((Cons h t) (if (int_eq i 0) h (ac_at t (- i 1))))))

;; sub-proofs for the portable cert's item premises, in item order;
;; wb = the linked premise index where the wrap pairs start; getc/setc =
;; the shipped cert names for slot-0 reads / slot-1 writes; acs = the
;; address classes aligned with `as`
(fn link_subs
  ((ps (List PItem))
   (as (List Expr))
   (acs (List AC))
   (wb Int)
   (w Int)
   (getc (List Int))
   (setc (List Int))
   (fnm Doc))
  Doc
  (measure (struct ps))
  (match ps
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((PWrap _)
        (dcat3
          (dcat3
            (DStr "(steps ((rewrite (premise ")
            (dint (+ wb (* 2 w)))
            (DStr ") lr lhs true ())) refl) "))
          (dcat3
            (DStr "(steps ((rewrite (premise ")
            (dint (+ (+ wb (* 2 w)) 1))
            (DStr ") lr lhs true ())) refl) "))
          (link_subs t as acs wb (+ w 1) getc setc fnm)))
       ((PAuto _) (link_subs t as acs wb w getc setc fnm))
       ((PGet _ a _)
        (DCat
          (link_beh getc (ac_at acs (pres_ix (spell a) as 0)) fnm)
          (link_subs t as acs wb w getc setc fnm)))
       ((PSet _ a _ _)
        (DCat
          (link_beh setc (ac_at acs (pres_ix (spell a) as 0)) fnm)
          (link_subs t as acs wb w getc setc fnm)))))))

;; ---- the wasm statement vocabulary (moved from tools/low/schema in the
;; meta/spell split): opcode rendering over the shared source-op
;; classification, the PItem premise renderers at the wasm modulus and
;; call_fn_mem spellings, and the RHS / self-literal statement builders.

;; ---- target vocabulary ------------------------------------------------------------

(fn bop_of ((q QName)) (Option Doc)
  (if (core_named q (quote +)) (Some (DStr "BAdd"))
  (if (core_named q (quote -)) (Some (DStr "BSub"))
  (if (core_named q (quote *)) (Some (DStr "BMul"))
  None))))

;; the PARTIAL ops: ediv/mod lower to the guarded BDivU/BRemU. A symbolic
;; divisor sticks bop_val's guard if mid-compute, so these ride the STAGED
;; pure walk (docs/LOWERING.md §6y), never the one-shot compute.
(fn dop_of ((q QName)) (Option Doc)
  (if (core_named q (quote ediv)) (Some (DStr "BDivU"))
  (if (core_named q (quote mod)) (Some (DStr "BRemU"))
  None)))

;; the TRANSPARENT bitwise ops: bop_val applies the kernel prims directly
;; (total, no wrap, no guard — docs/LOWERING.md §6z), so a bitwise node
;; contributes no premise and no discharge event; the machine spelling IS
;; the spec spelling. Bounds on CONTAINING arith nodes are consumer
;; premises (std/bits is the discharge kit).
(fn top_of ((q QName)) (Option Doc)
  (if (core_named q (quote band)) (Some (DStr "BAnd"))
  (if (core_named q (quote bor)) (Some (DStr "BOr"))
  (if (core_named q (quote bxor)) (Some (DStr "BXor"))
  None))))

(fn cond_op ((q QName)) (Option Doc)
  (if (core_named q (quote int_eq)) (Some (DStr "BEq"))
  (if (core_named q (quote lt)) (Some (DStr "BLtU"))
  (if (core_named q (quote le)) (Some (DStr "BLeU"))
  None))))

;; the portable premise text for one item
(fn pit_prem ((p PItem)) Doc
  (match p
    ((PWrap e)
     (dcat3
       (dcat3 (DStr "(= (le 0 ") (pr_e e) (DStr ") True) "))
       (dcat3 (DStr "(= (lt ") (pr_e e) (DStr " 4294967296) True) "))
       (DStr "")))
    ((PAuto _) (DStr ""))
    ((PGet mm a k)
     (dcat3
       (dcat3 (DStr "(= (call_fn_mem (S^ ") (dint k) (DStr " c) m 0 (Cons "))
       (dcat3
         (dcat3 (pr_e a) (DStr " Nil) ") (pr_e mm))
         (DStr ") (Some (Pair (mem_get ")
         (DCat (pr_e mm) (DCat (sp) (pr_e a))))
       (dcat3 (DStr ") ") (pr_e mm) (DStr "))) "))))
    ((PSet mm a v k)
     (dcat3
       (dcat3 (DStr "(= (call_fn_mem (S^ ") (dint k) (DStr " c) m 1 (Cons "))
       (dcat3
         (dcat3 (pr_e a) (DStr " (Cons ") (pr_e v))
         (DStr " Nil)) ")
         (DCat (pr_e mm) (DStr ") (Some (Pair ")))
       (dcat3
         (DCat (pr_e v) (DStr " (mem_set "))
         (DCat (pr_e mm) (DCat (sp) (DCat (pr_e a) (DCat (sp) (pr_e v)))))
         (DStr ")))) "))))))

(fn pits_prems ((ps (List PItem))) Doc
  (measure (struct ps))
  (match ps
    (Nil (DStr ""))
    ((Cons h t) (DCat (pit_prem h) (pits_prems t)))))

;; the linked cert's wrap premises (an address pair per ACPrem address
;; comes first — see wasmgen's link_addr_prems2)
(fn link_wrap_prems ((ps (List PItem))) Doc
  (measure (struct ps))
  (match ps
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((PWrap e)
        (dcat3
          (dcat3 (DStr "(= (le 0 ") (pr_e e) (DStr ") True) "))
          (dcat3 (DStr "(= (lt ") (pr_e e) (DStr " 4294967296) True) "))
          (link_wrap_prems t)))
       (_ (link_wrap_prems t))))))

(fn bnd_leaddr ((e Doc)) Doc (dcat3 (DStr "(le (+ ") e (DStr " 1) 65536)")))

;; ---- RHS / self-literal / spec-application builders -------------------------------

;; the SPEC application (NAME m0 x0 …)
(fn m_spec_app ((q QName) (ints (List Type))) Doc
  (dcat3
    (dcat3 (DStr "(") (dsym (qn_name q)) (DStr " m0"))
    (pr_args_lead ints)
    (DStr ")")))

;; the SELF function literal (from the code walk)
(fn m_self_lit ((n Int) (nxt Int) (code (List Doc))) Doc
  (dcat3
    (dcat3 (DStr "(MkFunc ") (dint (- n 1)) (sp))
    (dcat3 (dint (- nxt (- n 1))) (DStr " (list ") (djoin code))
    (DStr "))")))

;; the RHS: value slot + the SPEC application (memory slot for Mem fns)
(fn m_rhs ((q QName) (ints (List Type)) (rty Type) (ce Expr)) Doc
  (if (is_int_ty rty)
    (dcat3 (DStr "(Some (Pair ") (m_spec_app q ints) (DStr " m0))"))
    (dcat3
      (dcat3 (DStr "(Some (Pair ") (pr_e ce) (sp))
      (m_spec_app q ints)
      (DStr "))"))))


;; ---- the fragment ------------------------------------------------------------
;;
;; TWO WALKS, TWO CONCERNS (the let design, docs/LOWERING.md §6):
;;   - CODE is emitted from the ORIGINAL let tree — sharing preserved, one
;;     LocalSet per binding, locals allocated in textual order after the
;;     params (deterministic → regen-stable).
;;   - PREMISES/CITATIONS come from the ζ-SUBSTITUTED body — the kernel
;;     opens lets by substitution, so the compute residue's mod-sites are
;;     exactly the substituted tree's arith nodes. Duplicates (a shared
;;     local read twice) dedupe by spelling into ONE citation; an unused
;;     binding's nodes never appear at all.
;; gen_e does the code walk and simultaneously builds the CANONICAL
;; substituted expr (params as FVars named x0…, let-free, BVar-free);
;; nodes_e then collects the unique arith nodes postorder from it.

;; canonical walk result: instr docs (emission order), instr count, next
;; free local index, canonical substituted expr, discharge events.
;;
;; EVENTS (the staged pure walk, docs/LOWERING.md §6y): the code walk
;; collects, in MACHINE ORDER, one EvW per computed arith node (its wrap
;; materializes at that code point) and one EvD per division with a
;; symbolic divisor (bop_val's guard if sticks there). Collection rides
;; the CODE walk, not the substituted tree, because only the code walk
;; can tell a let-SHARE (one materialization — a re-fire would find no
;; site) from a textual RECOMPUTATION (a fresh wrap after any earlier
;; all-occurrences fire — a re-fire is required). Div-free fns produce
;; events too; the region path simply ignores them (nodes_e stays its
;; source of truth), so their output is untouched.
(type DEv (EvW Expr) (EvD Expr))

(type G (GOk (List Doc) Int Int Expr (List DEv)) (GErr (List Int)))

(fn ev_app ((a (List DEv)) (b (List DEv))) (List DEv)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (ev_app t b)))))

(fn gen_e ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) G
  (measure (struct e))
  (match e
    ((BVar i)
     (match (env_at env i)
       ((Some (Pair ce k))
        (GOk
          (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil)
          1
          nxt
          ce
          Nil))
       (None
         (let ((pos (- (- n 1) (- i (env_len env)))))
           (GOk
             (Cons (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")")) Nil)
             1
             nxt
             (FVar (xsym pos))
             Nil)))))
    ((IntLit k)
     (if (le 0 k)
       (if (lt k 4294967296)
         (GOk
           (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil)
           1
           nxt
           e
           Nil)
         (GErr "literal outside [0, 2^32)"))
       (GErr "literal outside [0, 2^32)")))
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (match (gen_e n env nxt a)
          ((GErr m) (GErr m))
          ((GOk ia ca nxa cea eva)
           (match (gen_e n env nxa b)
             ((GErr m) (GErr m))
             ((GOk ib cb nxb ceb evb)
              (let ((ce (Call q (Cons cea (Cons ceb Nil)))))
                (if (has_fv ce)
                  (match (bop_of q)
                    ((Some opd)
                     (GOk
                       (dapp
                         ia
                         (dapp
                           ib
                           (Cons (dcat3 (DStr "(I32Bin ") opd (DStr ")")) Nil)))
                       (+ ca (+ cb 1))
                       nxb
                       ce
                       (ev_app eva (ev_app evb (Cons (EvW ce) Nil)))))
                    (None
                      (match (dop_of q)
                        ((Some opd)
                         (match ceb
                           ((IntLit dk)
                            (if (int_eq dk 0)
                              (GErr "division by a zero literal")
                              (GOk
                                (dapp
                                  ia
                                  (dapp
                                    ib
                                    (Cons
                                      (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                      Nil)))
                                (+ ca (+ cb 1))
                                nxb
                                ce
                                (ev_app eva evb))))
                           (_
                             (GOk
                               (dapp
                                 ia
                                 (dapp
                                   ib
                                   (Cons
                                     (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                     Nil)))
                               (+ ca (+ cb 1))
                               nxb
                               ce
                               (ev_app eva (ev_app evb (Cons (EvD ceb) Nil)))))))
                        (None
                          (match (top_of q)
                            ((Some opd)
                             (GOk
                               (dapp
                                 ia
                                 (dapp
                                   ib
                                   (Cons
                                     (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                     Nil)))
                               (+ ca (+ cb 1))
                               nxb
                               ce
                               (ev_app eva evb)))
                            (None
                              (GErr
                                "call outside the fragment (only + - * ediv mod band bor bxor allowed)")))))))
                  (GErr
                    "ground arithmetic subtree (constant-fold it in the source)"))))))))
       (_
         (match (bop_of q)
           (None
             (match (dop_of q)
               (None
                 (match (top_of q)
                   (None
                     (GErr
                       "call outside the fragment (only + - * ediv mod band bor bxor allowed)"))
                   ((Some _) (GErr "arith call must be binary"))))
               ((Some _) (GErr "arith call must be binary"))))
           ((Some _) (GErr "arith call must be binary"))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (GErr m))
          ((GOk ir cr nxr cer evr)
           (match (gen_e n (Cons (Pair cer nxr) env) (+ nxr 1) body)
             ((GErr m) (GErr m))
             ((GOk ib cb nxb ceb evb)
              (GOk
                (dapp
                  ir
                  (Cons (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")")) ib))
                (+ cr (+ cb 1))
                nxb
                ceb
                (ev_app evr evb)))))))
       (_ (GErr "let must bind exactly one name (split into nested lets)"))))
    (_ (GErr "body outside the scalar let/straight-line fragment"))))

;; ---- premise nodes: meta/shape's nodes_e (the shared wrap-node collector,
;; is_bit_op transparency — graduated with the x86 loop slice) ------------------

;; ---- tail walk: the branch/region tree -----------------------------------------
;;
;; `if` lives in TAIL position (the fn body's result spine after lets, and
;; arm tails — nested ifs and arm-local lets allowed). The proof mirrors the
;; branch tree: one case-on per if, and each arith node is discharged in the
;; REGION where its code executes — pre-branch let bindings before the
;; case-on, arm-local nodes inside their arm — deduped against ancestor
;; regions (a spelling rewritten pre-branch stays rewritten when the arm's
;; compute resumes from the rewritten term).
;;
;; Conditions are (int_eq c1 c2) / (lt c1 c2) / (le c1 c2) with operands whose CANONICAL
;; form is a param or literal (FVar/IntLit — bare params, let-ALIASES,
;; literals). Wraps never enter a condition, so the case-on spelling matches
;; the compute residue on both sides. Arith inside a condition is refused.
;;
;; PRE hygiene (§6j): arm-local range premises are CONDITION-RELATIVE —
;; if-wrapped in the arm's condition path and stripped inside the arm;
;; a side derivable from a path condition (the abs pattern) is discharged
;; silently by a generated single-condition Farkas helper, no premise at
;; all. (if (lt 0 x) (- x 1) 0) is in the fragment with the honest
;; contract.

;; the diamond, result through a fresh LOCAL rl:
;;   Block [ Block [ COND, BrIf 0, ELSE…, LocalSet rl, Br 1 ],
;;           THEN…, LocalSet rl ]
;;   LocalGet rl
;; BrIf pops b2i(COND): nonzero (True) exits the inner block to THEN; zero
;; (False) falls through ELSE and Br 1 exits the outer block. The result
;; local is LOAD-BEARING for the REAL ISA: wasm blocks are typed and these
;; are void — every block boundary must have an EMPTY stack (V8 rejects a
;; value flowing out of a void block; the model's untyped Block would not
;; have caught it — the engine gate did). Locals-not-stack across block
;; edges is the same discipline the hand-written loop pieces follow.
(fn diamond
  ((cond_code (List Doc))
   (then_code (List Doc))
   (else_code (List Doc))
   (rl Int))
  (List Doc)
  (Cons
    (dcat3
      (DStr "(Block (list (Block (list ")
      (djoin
        (dapp
          cond_code
          (dapp
            (Cons (DStr "(BrIf 0)") Nil)
            (dapp
              else_code
              (Cons
                (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")"))
                (Cons (DStr "(Br 1)") Nil))))))
      (dcat3
        (DStr ")) ")
        (djoin
          (dapp
            then_code
            (Cons (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")")) Nil)))
        (DStr "))")))
    (Cons (dcat3 (DStr "(LocalGet ") (dint rl) (DStr ")")) Nil)))

(fn gen_t ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) TRes
  (measure (struct e))
  (match e
    ((If c a b)
     (match c
       ((Call q ops)
        (match (cond_op q)
          (None (TErr "if condition outside the fragment (int_eq/lt/le only)"))
          ((Some opd)
           (match ops
             ((Cons c1 (Cons c2 Nil))
              (match (gen_e n env nxt c1)
                ((GErr m) (TErr m))
                ((GOk i1 n1 nx1 ce1 _)
                 (match (gen_e n env nx1 c2)
                   ((GErr m) (TErr m))
                   ((GOk i2 n2 nx2 ce2 _)
                    (if (cond_operand_ok ce1)
                      (if (cond_operand_ok ce2)
                        (match (gen_t n env (+ nx2 1) a)
                          ((TErr m) (TErr m))
                          ((TOk rta)
                           (match (gen_t n env (rt_nxt rta) b)
                             ((TErr m) (TErr m))
                             ((TOk rtb)
                              (TOk
                                (RTif
                                  (diamond
                                    (dapp
                                      i1
                                      (dapp
                                        i2
                                        (Cons
                                          (dcat3
                                            (DStr "(I32Bin ")
                                            opd
                                            (DStr ")"))
                                          Nil)))
                                    (rt_code rta)
                                    (rt_code rtb)
                                    nx2)
                                  (+
                                    (+ n1 (+ n2 1))
                                    (+ (rt_count rta) (+ (rt_count rtb) 7)))
                                  (rt_nxt rtb)
                                  Nil
                                  (Call q (Cons ce1 (Cons ce2 Nil)))
                                  rta
                                  rtb))))))
                        (TErr
                          "if condition operand must be a param or literal (no arith in conditions)"))
                      (TErr
                        "if condition operand must be a param or literal (no arith in conditions)")))))))
             (_ (TErr "if condition must be a binary comparison"))))))
       (_ (TErr "if condition outside the fragment (int_eq/lt/le only)"))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (TErr m))
          ((GOk ir cr nxr cer _)
           (match (nodes_e cer Nil)
             ((NErr m) (TErr m))
             ((NOk rns)
              (match (gen_t n (Cons (Pair cer nxr) env) (+ nxr 1) body)
                ((TErr m) (TErr m))
                ((TOk rt)
                 (TOk
                   (rt_prepend
                     (dapp
                       ir
                       (Cons
                         (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")"))
                         Nil))
                     (+ cr 1)
                     rns
                     rt)))))))))
       (_ (TErr "let must bind exactly one name (split into nested lets)"))))
    (_
      (match (gen_e n env nxt e)
        ((GErr m) (TErr m))
        ((GOk code cnt nx ce _)
         (match (nodes_e ce Nil)
           ((NErr m) (TErr m))
           ((NOk ns) (TOk (RTv code cnt nx ns)))))))))

;; ---- the wasm wrap key (the §6j condition-path walk, meta/proof) --------------
;;
;; The fused premise/helper/proof walk over the region tree GRADUATED to
;; meta/proof (pw_* — parametric in the wrap key; the second back end
;; spoke it). This is the wasm instantiation: 2^32 / wrap32_id.

(fn wk32 () WrapK (MkWrapK 4294967296 "4294967296" "wrap32_id"))


;; ---- the mem fragment: bodies that CALL std/mem's shipped artifacts -----------
;;
;; Source fns (m Mem) (x Int) … whose bodies read/write bytes lower to
;; wasm Calls against std/mem's artifact module (call-per-byte v1; the
;; probes' composed-by-citation discipline, mechanized):
;;   - Int return: arith over params/literals + (mem_get m ADDR) reads;
;;     memory returned untouched — RHS (Some (Pair (SPEC m0 args) m0)).
;;   - Mem return: lets above a trailing (mem_set …) store — and since
;;     the WRITE-THEN-READ slice (probe: models/wasm/probes/wtrmem_probe.shard),
;;     Mem-typed lets sequence MULTIPLE stores with reads THROUGH them:
;;     the walk threads the CURRENT MEMORY TERM (m0 growing one mem_set
;;     per store); reads and behavior premises fire AT that term, so
;;     machine and spec spellings stay identical and no collapse lemmas
;;     or disequality premises exist anywhere. LINEARITY is enforced —
;;     using the param or a stale Mem binding after a store refuses
;;     loudly. Intermediate mset returns park in scratch locals (no
;;     Drop). RHS (Some (Pair LASTVAL (SPEC m0 args))). Int-return fns
;;     stay store-free (the schema pins their memory unchanged).
;; The emitted module is (Cons mget (Cons mset (Cons SELF restfs))) at
;; index 2 — std/mem's minimal-prefix convention; the callee literals are
;; SPLICED by the generator (the (inline …) same-file rule's link-time
;; answer), and the proofs cite lowered_mem_get/lowered_mem_set through
;; call_bridge, never computing into the callee bodies.
;;
;; THE STAGE LAW (the machine-order discharge discipline): arith nodes are
;; collected during the CODE walk — a let-bound value collects once (later
;; reads are LocalGets of the already-collapsed local), a recomputed
;; spelling collects AGAIN (its wrap re-materializes after the earlier
;; all-occurrences fire and needs a fresh event). At each call site the
;; proof emits (compute lhs (stop eval_call)), flushes the pending wrap
;; events (every so-far-materialized occurrence — stack, locals, and the
;; folded call's arguments — is on the lhs and collapses), then rewrites
;; by call_bridge with CLEAN spellings. PREs are per unique (kind,
;; spelling): wrap bounds for arith nodes, address bounds for read/write
;; addresses (the callee certs' own premise shapes).

;; the spliced std/mem artifact literals (std/mem/mem.wasm.shard's fns —
;; drift fails loudly at the kernel gate when the citations stop matching)
(fn mget_lit () Doc (DStr "(MkFunc 1 0 (list (LocalGet 0) (I32Load8U)))"))

(fn mset_lit () Doc
  (DStr
    "(MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Store8) (LocalGet 1)))"))

;; PRE hygiene (§6j): a READ-LINEAR arith node whose interval fits the
;; wrap window carries NO premises — PAuto, bounds derived in-proof via a
;; generated interval helper + get_lo/get_hi
(fn wrap_item ((e Expr)) PItem
  (match (pl_e e True)
    (None (PWrap e))
    ((Some p)
     (if (le 0 (pl_lo p)) (if (lt (pl_hi p) 4294967296) (PAuto e) (PWrap e))
     (PWrap e)))))

;; a GROUND byte address outside [0, 65535] can never satisfy the callee
;; cert's bound — refuse at generation (the linked artifact would be
;; vacuous)
(fn addr_ground_bad ((a Expr)) Bool
  (match (pl_e a True)
    ((Some p)
     (match (pl_atoms p)
       (Nil (if (le 0 (pl_const p)) (lt 65535 (pl_const p)) True))
       (_ False)))
    (None False)))


;; ---- the mem walk: code + symbolic machine state + staged proof ----------------
;;
;; state: code docs, instr count, next free local, symbolic stack (clean
;; spellings, top first), proof doc so far, have counter, tagged PREs,
;; pending wrap events, get/set counts, and the CURRENT MEMORY TERM (the
;; spec spelling of the machine memory; starts at m0, grows one mem_set
;; per store). WRITE-THEN-READ discipline: reads and writes fire AT the
;; current term — machine and spec stay on identical spellings, so no
;; collapse lemmas or disequality premises are ever needed; Mem-typed
;; lets are the linear sequencing form (they ζ-open by substitution on
;; the spec side, exactly like scalar lets).
(type MSt
  (MkMSt
    (List Doc)
    Int
    Int
    (List Expr)
    Doc
    Int
    (List PItem)
    (List Expr)
    Int
    Int
    Expr))

(type MRes (MOk MSt Expr) (MErr (List Int)))

(fn m0v () Expr (FVar (quote m0)))

;; the env marker for a Mem-typed binding (its scratch local is dead)
(fn memk () Int (- 0 1))

(fn mg_e
  ((n Int) (nn Int) (fnm Doc) (env (List (Pair Expr Int))) (st MSt) (e Expr))
  MRes
  (measure (struct e))
  (match st
    ((MkMSt code cnt nxt stk prf j pres pend gets sets mm)
     (match e
       ((BVar i)
        (match (env_at env i)
          ((Some (Pair ce k))
           (if (int_eq k (memk))
             (MErr "a Mem-typed binding cannot be used as a scalar value")
             (MOk
               (MkMSt
                 (dapp
                   code
                   (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil))
                 (+ cnt 1)
                 nxt
                 (Cons ce stk)
                 prf
                 j
                 pres
                 pend
                 gets
                 sets
                 mm)
               ce)))
          (None
            (let ((pos (- (- n 1) (- i (env_len env)))))
              (if (int_eq pos 0)
                (MErr
                  "the Mem param may appear only as the memory argument of mem_get/mem_set")
                (let ((ce (FVar (xsym (- pos 1)))))
                  (MOk
                    (MkMSt
                      (dapp
                        code
                        (Cons
                          (dcat3
                            (DStr "(LocalGet ")
                            (dint (- pos 1))
                            (DStr ")"))
                          Nil))
                      (+ cnt 1)
                      nxt
                      (Cons ce stk)
                      prf
                      j
                      pres
                      pend
                      gets
                      sets
                      mm)
                    ce)))))))
       ((IntLit k)
        (if (le 0 k)
          (if (lt k 4294967296)
            (MOk
              (MkMSt
                (dapp
                  code
                  (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil))
                (+ cnt 1)
                nxt
                (Cons e stk)
                prf
                j
                pres
                pend
                gets
                sets
                mm)
              e)
            (MErr "literal outside [0, 2^32)"))
          (MErr "literal outside [0, 2^32)")))
       ((Call q as)
        (match (bop_of q)
          ((Some opd)
           (match as
             ((Cons a (Cons b Nil))
              (match (mg_e n nn fnm env st a)
                ((MErr m) (MErr m))
                ((MOk st1 cea)
                 (match (mg_e n nn fnm env st1 b)
                   ((MErr m) (MErr m))
                   ((MOk st2 ceb)
                    (let ((node (Call q (Cons cea (Cons ceb Nil)))))
                      (if (has_fv node)
                        (match st2
                          ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                           (match s2
                             ((Cons _ (Cons _ below))
                              (MOk
                                (MkMSt
                                  (dapp
                                    c2
                                    (Cons
                                      (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                      Nil))
                                  (+ n2 1)
                                  x2
                                  (Cons node below)
                                  p2
                                  j2
                                  (if (node_known (spell node) pr2) pr2
                                  (pit_add pr2 (wrap_item node)))
                                  (dapp_e pd2 (Cons node Nil))
                                  g2
                                  w2
                                  mm2)
                                node))
                             (_ (MErr "internal: stack underflow at arith")))))
                        (MErr
                          "ground arithmetic subtree (constant-fold it in the source)"))))))))
             (_ (MErr "arith call must be binary"))))
          (None
            (if (memq_named q (quote mem_get))
              (match as
                ((Cons marg (Cons addr Nil))
                 (match (mg_mem n nn fnm env st marg False)
                   ((MErr m) (MErr m))
                   ((MOk stm mmt)
                    (match (mg_e n nn fnm env stm addr)
                      ((MErr m) (MErr m))
                      ((MOk st1 cea)
                       (if (addr_ground_bad cea)
                         (MErr "literal byte address outside [0, 65535]")
                         (match st1
                           ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                            (match s1
                              ((Cons _ below)
                               (let
                                 ((pr1b
                                    (pit_add pr1 (PGet mmt cea (- nn (+ n1 3))))))
                                 (match (m_flush pd1 pr1b fnm j1)
                                   ((Pair evd j2)
                                    (let
                                      ((rnode
                                         (Call q (Cons mmt (Cons cea Nil)))))
                                      (MOk
                                        (MkMSt
                                          (dapp c1 (Cons (DStr "(Call 0)") Nil))
                                          (+ n1 1)
                                          x1
                                          (Cons rnode below)
                                          (dcat3
                                            p1
                                            (DCat (m_stage_open) evd)
                                            (m_bridge_get
                                              mmt
                                              cea
                                              below
                                              rnode
                                              (+ 3 (poff pr1))))
                                          j2
                                          pr1b
                                          Nil
                                          (+ g1 1)
                                          w1
                                          mm1)
                                        rnode))))))
                              (_ (MErr "internal: stack underflow at mem_get")))))))))))
                (_ (MErr "mem_get must have exactly (m ADDR)")))
            (if (memq_named q (quote mem_set))
              (MErr
                "mem_set is a memory expression (bind it with a Mem let or nest it as a memory argument)")
              (MErr "call outside the mem fragment (+ - * mem_get only)"))))))
       ((Let bs body)
        (match bs
          ((Cons rhs Nil)
           (if (rhs_is_set rhs)
             (match (mg_mem n nn fnm env st rhs False)
               ((MErr m) (MErr m))
               ((MOk st1 mmt)
                (mg_e n nn fnm (Cons (Pair mmt (memk)) env) st1 body)))
             (match (mg_e n nn fnm env st rhs)
               ((MErr m) (MErr m))
               ((MOk st1 cer)
                (match st1
                  ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                   (match s1
                     ((Cons _ below)
                      (mg_e
                        n
                        nn
                        fnm
                        (Cons (Pair cer x1) env)
                        (MkMSt
                          (dapp
                            c1
                            (Cons
                              (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                              Nil))
                          (+ n1 1)
                          (+ x1 1)
                          below
                          p1
                          j1
                          pr1
                          pd1
                          g1
                          w1
                          mm1)
                        body))
                     (_ (MErr "internal: stack underflow at let")))))))))
          (_ (MErr "let must bind exactly one name (split into nested lets)"))))
       (_
         (MErr
           "body outside the mem fragment (straight-line + lets; no if yet)"))))))

;; is this let-rhs a Mem-typed expression (a mem_set application)?
(fn rhs_is_set ((e Expr)) Bool
  (match e
    ((Call q _) (memq_named q (quote mem_set)))
    (_ False)))

;; a MEMORY expression: the Mem param, a Mem binding, or a
;; (mem_set MEMEXPR ADDR VAL) nest. Emits the nest's stores in execution
;; order; the intermediate mset returns PARK in a fresh scratch local
;; (the no-Drop discipline) — tail=True leaves the LAST store's return
;; on the stack (the Mem-returning fn's scalar result). LINEARITY: a
;; param/binding use must denote the CURRENT memory term.
(fn mg_mem
  ((n Int)
   (nn Int)
   (fnm Doc)
   (env (List (Pair Expr Int)))
   (st MSt)
   (e Expr)
   (tail Bool))
  MRes
  (measure (struct e))
  (match st
    ((MkMSt code cnt nxt stk prf j pres pend gets sets mm)
     (match e
       ((BVar i)
        (match (env_at env i)
          ((Some (Pair ce k))
           (if (int_eq k (memk))
             (if (chars_eq (spell ce) (spell mm)) (MOk st ce)
             (MErr
               "memory used non-linearly (a stale Mem binding was read or written)"))
             (MErr "a scalar binding cannot be used as a memory argument")))
          (None
            (let ((pos (- (- n 1) (- i (env_len env)))))
              (if (int_eq pos 0)
                (if (chars_eq (spell mm) (spell (m0v))) (MOk st mm)
                (MErr
                  "memory used non-linearly (the Mem param was used after a store)"))
                (MErr "an Int param cannot be used as a memory argument"))))))
       ((Call q as)
        (if (memq_named q (quote mem_set))
          (match as
            ((Cons marg (Cons addr (Cons val Nil)))
             (match (mg_mem n nn fnm env st marg False)
               ((MErr m) (MErr m))
               ((MOk st0 mmt)
                (match (mg_e n nn fnm env st0 addr)
                  ((MErr m) (MErr m))
                  ((MOk st1 cea)
                   (if (addr_ground_bad cea)
                     (MErr "literal byte address outside [0, 65535]")
                     (match (mg_e n nn fnm env st1 val)
                       ((MErr m) (MErr m))
                       ((MOk st2 cev)
                        (match st2
                          ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                           (match s2
                             ((Cons _ (Cons _ below))
                              (let
                                ((newmm
                                   (Call q (Cons mmt (Cons cea (Cons cev Nil))))))
                                (let
                                  ((pr2b
                                     (pit_add
                                       pr2
                                       (PSet mmt cea cev (- nn (+ n2 3))))))
                                  (match (m_flush pd2 pr2b fnm j2)
                                    ((Pair evd j3)
                                     (let
                                       ((prf2
                                          (dcat3
                                            p2
                                            (DCat (m_stage_open) evd)
                                            (m_bridge_set
                                              mmt
                                              cea
                                              cev
                                              below
                                              (+ 3 (poff pr2))))))
                                       (if tail
                                         (MOk
                                           (MkMSt
                                             (dapp
                                               c2
                                               (Cons (DStr "(Call 1)") Nil))
                                             (+ n2 1)
                                             x2
                                             (Cons cev below)
                                             prf2
                                             j3
                                             pr2b
                                             Nil
                                             g2
                                             (+ w2 1)
                                             newmm)
                                           newmm)
                                         (MOk
                                           (MkMSt
                                             (dapp
                                               c2
                                               (Cons
                                                 (DStr "(Call 1)")
                                                 (Cons
                                                   (dcat3
                                                     (DStr "(LocalSet ")
                                                     (dint x2)
                                                     (DStr ")"))
                                                   Nil)))
                                             (+ n2 2)
                                             (+ x2 1)
                                             below
                                             prf2
                                             j3
                                             pr2b
                                             Nil
                                             g2
                                             (+ w2 1)
                                             newmm)
                                           newmm))))))))
                             (_ (MErr "internal: stack underflow at mem_set")))))))))))))
            (_ (MErr "mem_set must have exactly (m ADDR VAL)")))
          (MErr
            "memory argument must be the Mem param, a Mem binding, or a (mem_set …) nest")))
       (_
         (MErr
           "memory argument must be the Mem param, a Mem binding, or a (mem_set …) nest"))))))

;; the Mem-returning tail: lets above a trailing memory expression (the
;; final store's return value stays on the stack as the scalar result)
(fn mg_tail
  ((n Int) (nn Int) (fnm Doc) (env (List (Pair Expr Int))) (st MSt) (e Expr))
  MRes
  (measure (struct e))
  (match e
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (if (rhs_is_set rhs)
          (match (mg_mem n nn fnm env st rhs False)
            ((MErr m) (MErr m))
            ((MOk st1 mmt)
             (mg_tail n nn fnm (Cons (Pair mmt (memk)) env) st1 body)))
          (match (mg_e n nn fnm env st rhs)
            ((MErr m) (MErr m))
            ((MOk st1 cer)
             (match st1
               ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                (match s1
                  ((Cons _ below)
                   (mg_tail
                     n
                     nn
                     fnm
                     (Cons (Pair cer x1) env)
                     (MkMSt
                       (dapp
                         c1
                         (Cons
                           (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                           Nil))
                       (+ n1 1)
                       (+ x1 1)
                       below
                       p1
                       j1
                       pr1
                       pd1
                       g1
                       w1
                       mm1)
                     body))
                  (_ (MErr "internal: stack underflow at let")))))))))
       (_ (MErr "let must bind exactly one name (split into nested lets)"))))
    ((Call q as)
     (if (memq_named q (quote mem_set))
       (match as
         ((Cons marg (Cons addr (Cons val Nil)))
          (match (mg_mem n nn fnm env st marg False)
            ((MErr m) (MErr m))
            ((MOk st0 mmt)
             (match (mg_e n nn fnm env st0 addr)
               ((MErr m) (MErr m))
               ((MOk st1 cea)
                (if (addr_ground_bad cea)
                  (MErr "literal byte address outside [0, 65535]")
                  (match (mg_e n nn fnm env st1 val)
                    ((MErr m) (MErr m))
                    ((MOk st2 cev)
                     (match st2
                       ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                        (match s2
                          ((Cons _ (Cons _ below))
                           (let
                             ((newmm
                                (Call q (Cons mmt (Cons cea (Cons cev Nil))))))
                             (let
                               ((pr2b
                                  (pit_add
                                    pr2
                                    (PSet mmt cea cev (- nn (+ n2 3))))))
                               (match (m_flush pd2 pr2b fnm j2)
                                 ((Pair evd j3)
                                  (MOk
                                    (MkMSt
                                      (dapp c2 (Cons (DStr "(Call 1)") Nil))
                                      (+ n2 1)
                                      x2
                                      (Cons cev below)
                                      (dcat3
                                        p2
                                        (DCat (m_stage_open) evd)
                                        (m_bridge_set
                                          mmt
                                          cea
                                          cev
                                          below
                                          (+ 3 (poff pr2))))
                                      j3
                                      pr2b
                                      Nil
                                      g2
                                      (+ w2 1)
                                      newmm)
                                    cev))))))
                          (_ (MErr "internal: stack underflow at mem_set")))))))))))))
         (_ (MErr "mem_set must have exactly (m ADDR VAL)")))
       (MErr "Mem-returning body must end in a (mem_set …) store")))
    (_ (MErr "Mem-returning body must end in a (mem_set …) store"))))

;; ---- loop codegen ----------------------------------------------------------------

(fn lp_lget ((k Int)) Doc
  (dconc (list (DStr "(LocalGet ") (dint k) (DStr ")"))))

(fn lp_const ((k Int)) Doc
  (dconc (list (DStr "(I32Const ") (dint k) (DStr ")"))))

(fn lp_lset ((k Int)) Doc
  (dconc (list (DStr "(LocalSet ") (dint k) (DStr ")"))))

;; the range-shift store value is x86's rung (docs/X86.md §28): a flagless
;; ISA pays a compare-and-skip diamond for it, and wasm's own emission is
;; unwritten. The loop gate REFUSES it by name before any LVal is
;; consumed, so lp_valcode/lp_vlen never meet an LVXf (a missing match arm
;; would go MStuck and exit 0 silently — the shape must refuse LOUDLY).
(fn lp_is_xf ((v LVal)) Bool
  (match v
    ((LVXf _ _ _ _) True)
    (_ False)))

(fn lp_has_xf ((sts (List (Pair Int LVal)))) Bool
  (measure (struct sts))
  (match sts
    (Nil False)
    ((Cons (Pair _ v) rest) (if (lp_is_xf v) True (lp_has_xf rest)))))

(fn lp_valcode ((v LVal)) (List Doc)
  (match v
    ((LVAcc i) (Cons (lp_lget i) Nil))
    ((LVLit l) (Cons (lp_const l) Nil))
    ((LVRead i) (Cons (lp_lget i) (Cons (DStr "(I32Load8U)") Nil)))
    ((LVXf _ _ _ _) Nil)))

(fn lp_vlen ((v LVal)) Int
  (match v
    ((LVAcc _) 1)
    ((LVLit _) 1)
    ((LVRead _) 2)
    ((LVXf _ _ _ _) 0)))

(fn lp_advcode ((adv (List LStr)) (i Int)) (List Doc)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t)
     (match h
       ((LSStat) (lp_advcode t (+ i 1)))
       ((LSInc)
        (dapp
          (list (lp_lget i) (lp_const 1) (DStr "(I32Bin BAdd)") (lp_lset i))
          (lp_advcode t (+ i 1))))
       ((LSDec)
        (dapp
          (list (lp_lget i) (lp_const 1) (DStr "(I32Bin BSub)") (lp_lset i))
          (lp_advcode t (+ i 1))))
       ((LSIncK s)
        (dapp
          (list (lp_lget i) (lp_const s) (DStr "(I32Bin BAdd)") (lp_lset i))
          (lp_advcode t (+ i 1))))))))

;; the store block: (addr, value) pairs pushed in REVERSE execution
;; order (outer store deepest), then one I32Store8 per store — every
;; load executes before either store (pure stack, no scratch locals)
(fn lp_storecode ((sts (List (Pair Int LVal)))) (List Doc)
  (match sts
    ((Cons (Pair a1 v1) (Cons (Pair a2 v2) Nil))
     (dapp
       (Cons (lp_lget a2) (lp_valcode v2))
       (dapp
         (Cons (lp_lget a1) (lp_valcode v1))
         (list (DStr "(I32Store8)") (DStr "(I32Store8)")))))
    ((Cons (Pair a1 v1) Nil)
     (dapp (Cons (lp_lget a1) (lp_valcode v1)) (list (DStr "(I32Store8)"))))
    (_ Nil)))

;; instruction count of the store block
(fn lp_stlen ((sts (List (Pair Int LVal)))) Int
  (measure (struct sts))
  (match sts
    (Nil 0)
    ((Cons (Pair _ v) t) (+ (+ 2 (lp_vlen v)) (lp_stlen t)))))

;; guard / stores / advances / decrement / re-enter
;; (instrs = 8 + stlen + 4*nAdv)
(fn lp_code ((n Int) (adv (List LStr)) (sts (List (Pair Int LVal)))) (List Doc)
  (dapp
    (list (lp_lget n) (DStr "(I32Eqz)") (DStr "(BrIf 1)"))
    (dapp
      (lp_storecode sts)
      (dapp
        (lp_advcode adv 0)
        (list
          (lp_lget n)
          (lp_const 1)
          (DStr "(I32Bin BSub)")
          (lp_lset n)
          (DStr "(Br 0)"))))))

;; Int-return: guard / sum FIRST (reads accum j's OLD value) / advances /
;; decrement / re-enter (instrs = 13 + 4*nAdv)
(fn li_code ((n Int) (adv (List LStr)) (r Int) (j Int)) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget r)
      (lp_lget j)
      (DStr "(I32Load8U)")
      (DStr "(I32Bin BAdd)")
      (lp_lset r))
    (dapp
      (lp_advcode adv 0)
      (list
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; SCAN codegen: budget guard / load + literal-test exit / r += 1 /
;; k -= 1 / re-enter. The zero literal keeps the one-instr I32Eqz test
;; (16 instrs); a nonzero literal pays I32Const + BEq (17 instrs) —
;; both leave (b2i (int_eq BYTE LIT)) as the machine flag residue.
(fn lc_test ((z Int)) (List Doc)
  (if (int_eq z 0) (list (DStr "(I32Eqz)"))
  (list (lp_const z) (DStr "(I32Bin BEq)"))))

(fn lc_code ((n Int) (r Int) (z Int)) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget r)
      (DStr "(I32Load8U)"))
    (dapp
      (lc_test z)
      (list
        (DStr "(BrIf 1)")
        (lp_lget r)
        (lp_const 1)
        (DStr "(I32Bin BAdd)")
        (lp_lset r)
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; FLAG codegen: budget guard / two loads + BEq into the flag local /
;; exit if flag=0 / advances / k -= 1 / re-enter (instrs = 17 + 4*nAdv;
;; the flag local sits at index n+1, past the counter)
(fn lb_code ((n Int) (a Int) (b Int) (adv (List LStr))) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget a)
      (DStr "(I32Load8U)")
      (lp_lget b)
      (DStr "(I32Load8U)")
      (DStr "(I32Bin BEq)")
      (lp_lset (+ n 1))
      (lp_lget (+ n 1))
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)"))
    (dapp
      (lp_advcode adv 0)
      (list
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; ---- loop claim assembly ----------------------------------------------------------

(fn lp_nadv ((bs (List LStr))) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (+ (if (ls_adv h) 1 0) (lp_nadv t)))))

;; number of advancing accums among the first i (= accum i's group-A premise ix)
(fn lp_advpos ((bs (List LStr)) (i Int)) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t)
     (if (int_eq i 0) 0 (+ (if (ls_adv h) 1 0) (lp_advpos t (- i 1)))))))

;; the first INCREMENTING accum — the counter wrap (lg_kM or the
;; stride-scaled instance) rides its premise pair, so every loop needs
;; one (v1 fence)
(fn lp_first_inc ((bs (List LStr)) (i Int)) (Option Int)
  (measure (struct bs))
  (match bs
    (Nil None)
    ((Cons h t)
     (match h
       ((LSInc) (Some i))
       ((LSIncK _) (Some i))
       (_ (lp_first_inc t (+ i 1)))))))

(fn lp_has_dec ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSDec) True)
       (_ (lp_has_dec t))))))

;; group-A premises, param order: inc -> nonneg, dec -> count-lower
(fn lp_prems_lo ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc) (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True) "))))
         ((LSIncK _)
          (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True) "))))
         ((LSDec)
          (dconc
            (list (DStr "(= (le (int_of_nat k) x") (dint i) (DStr ") True) ")))))
       (lp_prems_lo t (+ i 1))))))

;; group-B premises, param order: inc -> range (stride-scaled for
;; LSIncK), dec -> address-upper
(fn lp_prems_rng ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc)
          (dconc
            (list
              (DStr "(= (le (+ x")
              (dint i)
              (DStr " (int_of_nat k)) 65536) True) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(= (le (+ x")
              (dint i)
              (DStr " (* ")
              (dint s)
              (DStr " (int_of_nat k))) 65536) True) "))))
         ((LSDec)
          (dconc
            (list (DStr "(= (le (+ x") (dint i) (DStr " 1) 65536) True) ")))))
       (lp_prems_rng t (+ i 1))))))

;; exit locals: inc -> (lg_adv xi k), stride-C -> (lg_advk xi C k),
;; dec -> (lg_dec xi k), static -> xi, counter -> 0
(fn lp_exits ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr "0"))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (dconc (list (DStr "(lg_adv x") (dint i) (DStr " k) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(lg_advk x")
              (dint i)
              (DStr " ")
              (dint s)
              (DStr " k) "))))
         ((LSDec) (dconc (list (DStr "(lg_dec x") (dint i) (DStr " k) "))))
         ((LSStat) (dconc (list (DStr "x") (dint i) (DStr " ")))))
       (lp_exits t (+ i 1))))))

;; ---- Int-return claim pieces ------------------------------------------------------

;; premised accums for the Int-return shape: the return accum joins as a
;; nonneg-premised (inc-marked) slot; its group-B premise and exit stay
;; special-cased by position r
(fn li_pflags ((adv (List LStr)) (r Int) (i Int)) (List LStr)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t) (Cons (if (int_eq i r) (LSInc) h) (li_pflags t r (+ i 1))))))

;; range premises: the k-scaled sum invariant at r, stride-shaped elsewhere
(fn li_prems_rng ((adv (List LStr)) (r Int) (i Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (int_eq i r)
         (dconc
           (list
             (DStr "(= (le (+ x")
             (dint i)
             (DStr " (* 256 (int_of_nat k))) 4294967296) True) ")))
         (match h
           ((LSStat) (DStr ""))
           ((LSInc)
            (dconc
              (list
                (DStr "(= (le (+ x")
                (dint i)
                (DStr " (int_of_nat k)) 65536) True) "))))
           ((LSIncK _)
            (dconc
              (list
                (DStr "(= (le (+ x")
                (dint i)
                (DStr " (int_of_nat k)) 65536) True) "))))
           ((LSDec)
            (dconc
              (list (DStr "(= (le (+ x") (dint i) (DStr " 1) 65536) True) "))))))
       (li_prems_rng t r (+ i 1))))))

;; exit locals: return accum -> the SPEC-CALL spelling, else by stride
(fn li_exits ((adv (List LStr)) (r Int) (i Int) (spec Doc)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr "0"))
    ((Cons h t)
     (DCat
       (if (int_eq i r) (DCat spec (DStr " "))
       (match h
         ((LSInc) (dconc (list (DStr "(lg_adv x") (dint i) (DStr " k) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(lg_advk x")
              (dint i)
              (DStr " ")
              (dint s)
              (DStr " k) "))))
         ((LSDec) (dconc (list (DStr "(lg_dec x") (dint i) (DStr " k) "))))
         ((LSStat) (dconc (list (DStr "x") (dint i) (DStr " "))))))
       (li_exits t r (+ i 1) spec)))))

;; memory-op address occurrences, code order: pushes are in REVERSE
;; execution order, so the OUTER store's value-load fires first; then the
;; stores in execution order
(fn lp_read_occ ((v LVal)) (List Int)
  (match v
    ((LVRead i) (Cons i Nil))
    (_ Nil)))

(fn lp_occs ((sts (List (Pair Int LVal)))) (List Int)
  (match sts
    ((Cons (Pair a1 v1) (Cons (Pair a2 v2) Nil))
     (append_int
       (lp_read_occ v2)
       (append_int (lp_read_occ v1) (Cons a1 (Cons a2 Nil)))))
    ((Cons (Pair a1 v1) Nil) (append_int (lp_read_occ v1) (Cons a1 Nil)))
    (_ Nil)))

;; one INC address-guard stage: premise-rewrite the nonneg guard, cite
;; lg_a1_ms for the upper guard, compute on
(fn lp_stage ((p Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint r)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; ---- stride != 1 support (LSIncK; probe: strideloop_probe) -------------------
;; A stride-C accum rides the SAME stage/wrap/IH shapes as stride 1, but
;; its helper certs are C-scaled instances GENERATED per (fn, stride)
;; with computed farkas lists (the kit lemmas cannot take C as a binder
;; — C*n is nonlinear; as a literal it is a coefficient). Closed
;; formulas, mined at C=4 in the probe:
;;   a1ms / ac  -> (list 1 1 C C)      lo / c32 -> (list 1 1)
;;   kM         -> (list C 1 C 1)      shift    -> (list 1 1 C)

;; generated-helper name: lgs_<fn>_<C>_<suffix>
(fn lgs_nm ((fnm Doc) (s Int) (suf (List Int))) Doc
  (dconc (list (DStr "lgs_") fnm (DStr "_") (dint s) (DStr "_") (DStr suf))))

(fn lp_has_inck ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSIncK _) True)
       (_ (lp_has_inck t))))))

(fn lp_has_inc1 ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSInc) True)
       (_ (lp_has_inc1 t))))))

(fn int_in ((x Int) (xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (int_eq h x) True (int_in x t)))))

;; the distinct LSIncK strides, first-seen order
(fn lp_incks ((bs (List LStr)) (seen (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons h t)
     (match h
       ((LSIncK s)
        (if (int_in s seen) (lp_incks t seen)
        (Cons s (lp_incks t (Cons s seen)))))
       (_ (lp_incks t seen))))))

;; the six C-scaled helper claims for one (fn, stride)
(fn lgs_one ((fnm Doc) (s Int)) Doc
  (dconc
    (list
      (DStr "(claim ")
      (lgs_nm fnm s "a1ms")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ a 1) 65536) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr " ")
      (dint s)
      (DStr ")))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "ac")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ a ")
      (dint s)
      (DStr ") 65536) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr " ")
      (dint s)
      (DStr ")))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "lo")
      (DStr " (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (+ x ")
      (dint s)
      (DStr ")) True)) (by arith (list 1 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "c32")
      (DStr " (goal ((x Int)) ((= (le (+ x ")
      (dint s)
      (DStr ") 65536) True)) (= (lt (+ x ")
      (dint s)
      (DStr ") 4294967296) True)) (by arith (list 1 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "kM")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 a) True)) (= (lt (int_of_nat c) 4294967296) True)) (by arith (list ")
      (dint s)
      (DStr " 1 ")
      (dint s)
      (DStr " 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "shift")
      (DStr " (goal ((b Int) (w Int) (c Nat)) ((= (le (+ b (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) w) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))) (= (le (+ (+ b ")
      (dint s)
      (DStr ") (* ")
      (dint s)
      (DStr " (int_of_nat c))) w) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr ")))")
      (DStr (nl)))))

(fn lgs_all ((fnm Doc) (ss (List Int))) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons s t) (DCat (lgs_one fnm s) (lgs_all fnm t)))))

;; the stride-C address-guard stage (lp_stage with the generated a1ms)
(fn lp_kstage ((anm Doc) (p Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma ")
      anm
      (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint r)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; the stride-C counter wrap (lp_hwk with the generated kM)
(fn lp_khwk ((knm Doc) (f Int) (rng Int) (lo Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma ")
      knm
      (DStr ") lr lhs ((inst a x")
      (dint f)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint rng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise ")
      (dint lo)
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; the stride-C advance wrap (lp_hw with the generated lo/c32/ac chain)
(fn lp_khw ((fnm Doc) (s Int) (p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr ") 4294967296) (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr ")) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr "))) ((rewrite-with (lemma ")
      (lgs_nm fnm s "lo")
      (DStr ") lr lhs () ((steps ((rewrite (premise ")
      (dint p)
      (DStr ") lr lhs true ())) refl)) refl) (rewrite-with (lemma ")
      (lgs_nm fnm s "c32")
      (DStr ") lr lhs () ((rewrite-with (lemma ")
      (lgs_nm fnm s "ac")
      (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

;; one DEC address-guard stage: cite lg_dlo for the lower guard, then
;; premise-rewrite the address-upper directly
(fn lp_dstage ((p Int) (r Int)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_dlo) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint r)
      (DStr ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lp_stages ((fnm Doc) (occs (List Int)) (adv (List LStr)) (na Int)) Doc
  (measure (struct occs))
  (match occs
    (Nil (DStr ""))
    ((Cons i t)
     (DCat
       (match (ls_at adv i)
         ((LSDec) (lp_dstage (lp_advpos adv i) (+ na (lp_advpos adv i))))
         ((LSIncK s)
          (lp_kstage
            (lgs_nm fnm s "a1ms")
            (lp_advpos adv i)
            (+ na (lp_advpos adv i))))
         (_ (lp_stage (lp_advpos adv i) (+ na (lp_advpos adv i)))))
       (lp_stages fnm t adv na)))))

;; the counter wrap: (1+n)-1 collapse, then wrap32_id via lg_kM off the
;; FIRST incrementing accum's range premise (rng) and nonneg premise (lo)
(fn lp_hwk ((f Int) (rng Int) (lo Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma lg_kM) lr lhs ((inst a x")
      (dint f)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint rng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise ")
      (dint lo)
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; one incrementing accum's advance-wrap have + all-occurrences rewrite
(fn lp_hw ((p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " 1) 4294967296) (+ x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl)) refl) (rewrite-with (lemma lg_32) lr lhs () ((rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

;; one decrementing accum's wrap have (lg_dlo1 / lg_d32 off the dec pair)
(fn lp_dhw ((p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (- x")
      (dint i)
      (DStr " 1) 4294967296) (- x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (- x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma lg_dlo1) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl) (rewrite-with (lemma lg_d32) lr lhs () ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

(fn lp_hws ((fnm Doc) (bs (List LStr)) (i Int) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_hws fnm t (+ i 1) p na))
       ((LSInc) (DCat (lp_hw p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))
       ((LSIncK s)
        (DCat (lp_khw fnm s p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))
       ((LSDec) (DCat (lp_dhw p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))))))

;; the IH's group-A discharges: lg_lo1 (inc) / lg_dshift (dec) / the
;; generated lo (stride C)
(fn lp_lo1s ((fnm Doc) (bs (List LStr)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_lo1s fnm t p))
       ((LSInc)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))
       ((LSIncK s)
        (DCat
          (dconc
            (list
              (DStr "(rewrite-with (lemma ")
              (lgs_nm fnm s "lo")
              (DStr ") lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))
       ((LSDec)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_dshift) lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))))))

;; the IH's group-B discharges: lg_shift (inc) / lg_dhi (dec) / the
;; generated shift (stride C)
(fn lp_shifts ((fnm Doc) (bs (List LStr)) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_shifts fnm t p na))
       ((LSInc)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))
       ((LSIncK s)
        (DCat
          (dconc
            (list
              (DStr "(rewrite-with (lemma ")
              (lgs_nm fnm s "shift")
              (DStr ") lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))
       ((LSDec)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_dhi) lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))))))

;; Int-return advance wraps: per advancing accum in param order, premise
;; indices from the PREMISED-accum position (pf includes r)
(fn li_hws ((adv (List LStr)) (pf (List LStr)) (i Int) (nap Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc) (lp_hw (lp_advpos pf i) i nap))
         ((LSIncK _) (lp_hw (lp_advpos pf i) i nap))
         ((LSDec) (lp_dhw (lp_advpos pf i) i nap)))
       (li_hws t pf (+ i 1) nap)))))

;; the sum wrap: the machine BAdd's (mod (+ xr (mem_get m0 xj)) 2^32)
;; collapses via wrap32_id off the sum-invariant pair + get_lo/get_hi
(fn li_hwa ((r Int) (j Int) (plo Int) (prng Int)) Doc
  (dconc
    (list
      (DStr "(have hwa (= (mod (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr ")) 4294967296) (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr "))) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr
        ")))) ((rewrite-with (lemma lg_sum_lo) lr lhs () ((steps ((rewrite (premise ")
      (dint plo)
      (DStr
        ") lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) (rewrite-with (lemma lg_sum_32) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint prng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) (steps ((rewrite (premise hwa) lr lhs true ()))) "))))

;; the IH's group-A discharges, Int-return: lg_sum_lo (+ get_lo) at r,
;; stride-shaped elsewhere
(fn li_los ((pf (List LStr)) (r Int) (i Int) (p Int)) Doc
  (measure (struct pf))
  (match pf
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (if (int_eq i r)
           (dconc
             (list
               (DStr
                 "(rewrite-with (lemma lg_sum_lo) lr lhs () ((steps ((rewrite (premise ")
               (dint p)
               (DStr
                 ") lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) ")))
           (match h
             ((LSDec)
              (dconc
                (list
                  (DStr
                    "(rewrite-with (lemma lg_dshift) lr lhs () ((steps ((rewrite (premise ")
                  (dint p)
                  (DStr
                    ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) "))))
             (_
               (dconc
                 (list
                   (DStr
                     "(rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
                   (dint p)
                   (DStr ") lr lhs true ())) refl)) refl) "))))))
         (DStr ""))
       (li_los t r (+ i 1) (+ p (if (ls_adv h) 1 0)))))))

;; the IH's group-B discharges, Int-return: lg_sum_shift (+ get_hi) at r,
;; stride-shaped elsewhere
(fn li_shs ((pf (List LStr)) (r Int) (i Int) (p Int) (nap Int)) Doc
  (measure (struct pf))
  (match pf
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (if (int_eq i r)
           (dconc
             (list
               (DStr
                 "(rewrite-with (lemma lg_sum_shift) lr lhs () ((steps ((rewrite (premise ")
               (dint (+ nap p))
               (DStr
                 ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl)) refl) ")))
           (match h
             ((LSDec)
              (dconc
                (list
                  (DStr
                    "(rewrite-with (lemma lg_dhi) lr lhs () ((steps ((rewrite (premise ")
                  (dint (+ nap p))
                  (DStr ") lr lhs true ())) refl)) refl) "))))
             (_
               (dconc
                 (list
                   (DStr
                     "(rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise ")
                   (dint (+ nap p))
                   (DStr
                     ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) "))))))
         (DStr ""))
       (li_shs t r (+ i 1) (+ p (if (ls_adv h) 1 0)) nap)))))

;; pass-through premise steps (theorem -> worker), one per premised accum
(fn lp_pass1 ((bs (List LStr)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h)
       (DCat
         (dconc
           (list
             (DStr "(steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl) ")))
         (lp_pass1 t (+ p 1)))
       (lp_pass1 t p)))))

;; the SELF literal as spelled in claims ((inline …) rides the emitted body fn)
(fn lp_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (I32Const 0)))"))))

(fn lp_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (sts (List (Pair Int LVal)))
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr
          "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (eval_loop (S^ ")
        (dint p)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) (inline ")
        nm
        (DStr "_body) (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
        (lp_exits adv 0)
        (DStr ") (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
        (lp_stages nm (lp_occs sts) adv na)
        (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)))) ")
        (match (ls_at adv fa)
          ((LSIncK s)
           (lp_khwk
             (lgs_nm nm s "kM")
             fa
             (+ na (lp_advpos adv fa))
             (lp_advpos adv fa)))
          (_ (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))))
        (lp_hws nm adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (if (lp_has_inc1 adv) (DStr "(unfold lg_adv rhs) ") (DStr ""))
        (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
        (if (lp_has_inck adv) (DStr "(unfold lg_advk rhs) ") (DStr ""))
        (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
        (lp_lo1s nm adv 0)
        (lp_shifts nm adv 0 na)
        (DStr ")) (steps ((compute both))) refl)))))")
        (DStr (nl))))))

(fn lp_thm ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (p4 Int)) Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p4)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + worker + theorem, one unit per source fn
(fn lp_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (sts (List (Pair Int LVal)))
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lp_code n adv sts))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (I32Const 0))))")
      (DStr (nl))
      (lgs_all nm (lp_incks adv Nil))
      (lp_worker nm mids n adv sts fa p)
      (lp_thm nm mids n adv (+ p 4)))))

;; the Int-return SELF literal: epilogue reads the return accum's local
(fn li_self ((nm Doc) (n Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr ")))"))))

;; the Int-return spec-call spelling (rides the worker's exit locals and
;; the theorem's scalar result)
(fn li_spec ((nm Doc) (mids (List Type))) Doc
  (dconc (list (DStr "(") nm (DStr " m0") (pr_args_lead mids) (DStr " k)"))))

(fn li_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (r Int)
   (j Int)
   (fa Int)
   (p Int))
  Doc
  (let ((pf (li_pflags adv r 0)))
    (let ((nap (lp_nadv pf)))
      (dconc
        (list
          (DStr "(claim lgw_")
          nm
          (DStr " (goal (")
          (pr_binds mids 0)
          (DStr
            "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
          (lp_prems_lo pf 0)
          (li_prems_rng adv r 0)
          (DStr ") (= (eval_loop (S^ ")
          (dint p)
          (DStr " (lg_fuel k c)) (MkWModule (Cons ")
          (li_self nm n r)
          (DStr " restfs) 65536) (inline ")
          nm
          (DStr "_body) (list ")
          (pr_args mids 0)
          (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
          (li_exits adv r 0 (li_spec nm mids))
          (DStr
            ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
          (match (ls_at adv j)
            ((LSDec) (lp_dstage (lp_advpos pf j) (+ nap (lp_advpos pf j))))
            (_ (lp_stage (lp_advpos pf j) (+ nap (lp_advpos pf j)))))
          (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)))) ")
          (lp_hwk fa (+ nap (lp_advpos pf fa)) (lp_advpos pf fa))
          (li_hws adv pf 0 nap)
          (li_hwa r j (lp_advpos pf r) (+ nap (lp_advpos pf r)))
          (DStr "(steps ((unfold ")
          nm
          (DStr " rhs) (unfold lg_adv rhs) ")
          (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
          (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
          (li_los pf r 0 0)
          (li_shs pf r 0 0 nap)
          (DStr ")) (steps ((compute both))) refl)))))")
          (DStr (nl)))))))

(fn li_thm
  ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (r Int) (p4 Int))
  Doc
  (let ((pf (li_pflags adv r 0)))
    (let ((nap (lp_nadv pf)))
      (dconc
        (list
          (DStr "(claim lowered_")
          nm
          (DStr " (goal (")
          (pr_binds mids 0)
          (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
          (lp_prems_lo pf 0)
          (li_prems_rng adv r 0)
          (DStr ") (= (call_fn_mem (S^ ")
          (dint p4)
          (DStr " (lg_fuel k c)) (MkWModule (Cons ")
          (li_self nm n r)
          (DStr " restfs) 65536) 0 (list ")
          (pr_args mids 0)
          (DStr " (int_of_nat k)) m0) (Some (Pair ")
          (li_spec nm mids)
          (DStr
            " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
          nm
          (DStr ") lr lhs () (")
          (lp_pass1 pf 0)
          (lp_pass1 pf nap)
          (DStr ")) (steps ((compute both))) refl))")
          (DStr (nl)))))))

(fn li_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (r Int)
   (j Int)
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (li_code n adv r j))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr "))))")
      (DStr (nl))
      (li_worker nm mids n adv r j fa p)
      (li_thm nm mids n adv r (+ p 4)))))

;; ---- the SCAN shape (conditional early exit; probe: scanloop_probe) ----------

;; the twin's self-call args: r advanced, statics passed through
(fn lc_targs ((mids (List Type)) (r Int) (i Int)) Doc
  (measure (struct mids))
  (match mids
    (Nil (DStr ""))
    ((Cons _ t)
     (DCat
       (if (int_eq i r) (dconc (list (DStr " (+ x") (dint i) (DStr " 1)")))
       (dconc (list (DStr " x") (dint i))))
       (lc_targs t r (+ i 1))))))

;; the machine-generated COUNTER TWIN: the budget local's exit value —
;; the first fn the emitter writes with real recursion (spec-side only;
;; gate 3 checks it like any article)
(fn lc_twin ((nm Doc) (mids (List Type)) (r Int) (z Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_kf ((m Mem) ")
      (pr_binds mids 0)
      (DStr
        "(k Nat)) Int (measure (struct k)) (match k (Z 0) ((S k2) (if (int_eq (mem_get m x")
      (dint r)
      (DStr ") ")
      (dint z)
      (DStr ") (int_of_nat (S k2)) (")
      nm
      (DStr "_kf m")
      (lc_targs mids r 0)
      (DStr " k2)))))")
      (DStr (nl)))))

(fn lc_tspec ((nm Doc) (mids (List Type))) Doc
  (dconc (list (DStr "(") nm (DStr "_kf m0") (pr_args_lead mids) (DStr " k)"))))

;; exit locals: r -> the spec call, statics -> xi, counter -> the twin
(fn lc_exits ((mids (List Type)) (r Int) (i Int) (spec Doc) (twin Doc)) Doc
  (measure (struct mids))
  (match mids
    (Nil twin)
    ((Cons _ t)
     (DCat
       (if (int_eq i r) (DCat spec (DStr " "))
       (dconc (list (DStr "x") (dint i) (DStr " "))))
       (lc_exits t r (+ i 1) spec twin)))))

;; the shared head of both condition arms: fuel/eval_loop open, guard
;; decider, the read stage at r, then the flag collapse via the case hyp
(fn lc_arm_head ((r Int)) Doc
  (dconc
    (list
      (DStr
        "(chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (hyp 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lc_worker ((nm Doc) (mids (List Type)) (n Int) (r Int) (z Int) (p Int)) Doc
  (dconc
    (list
      (DStr "(claim lgw_")
      nm
      (DStr " (goal (")
      (pr_binds mids 0)
      (DStr
        "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) ((= (le 0 x")
      (dint r)
      (DStr ") True) (= (le (+ x")
      (dint r)
      (DStr " (int_of_nat k)) 65536) True)) (= (eval_loop (S^ ")
      (dint p)
      (DStr " (lg_fuel k c)) (MkWModule (Cons ")
      (li_self nm n r)
      (DStr " restfs) 65536) (inline ")
      nm
      (DStr "_body) (list ")
      (pr_args mids 0)
      (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
      (lc_exits mids r 0 (li_spec nm mids) (lc_tspec nm mids))
      (DStr
        ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (case-on (int_eq (mem_get m0 x")
      (dint r)
      (DStr ") ")
      (dint z)
      (DStr ") Bool ((case True ")
      (lc_arm_head r)
      (DStr "(steps ((unfold ")
      nm
      (DStr " rhs) (unfold ")
      nm
      (DStr
        "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()) (rewrite (lemma int_of_nat_succ) lr rhs true ()))) (steps ((compute both))) refl)) (case False ")
      (lc_arm_head r)
      (lp_hwk r 1 0)
      (lp_hw 0 r 1)
      (DStr "(steps ((unfold ")
      nm
      (DStr " rhs) (unfold ")
      nm
      (DStr
        "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()))) (rewrite-with (hyp 1) lr lhs () ((rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl))) (steps ((compute both))) refl))))))))")
      (DStr (nl)))))

(fn lc_thm ((nm Doc) (mids (List Type)) (n Int) (r Int) (p4 Int)) Doc
  (dconc
    (list
      (DStr "(claim lowered_")
      nm
      (DStr " (goal (")
      (pr_binds mids 0)
      (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) ((= (le 0 x")
      (dint r)
      (DStr ") True) (= (le (+ x")
      (dint r)
      (DStr " (int_of_nat k)) 65536) True)) (= (call_fn_mem (S^ ")
      (dint p4)
      (DStr " (lg_fuel k c)) (MkWModule (Cons ")
      (li_self nm n r)
      (DStr " restfs) 65536) 0 (list ")
      (pr_args mids 0)
      (DStr " (int_of_nat k)) m0) (Some (Pair ")
      (li_spec nm mids)
      (DStr
        " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
      nm
      (DStr
        ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))")
      (DStr (nl)))))

(fn lc_unit ((nm Doc) (mids (List Type)) (n Int) (r Int) (z Int) (p Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lc_code n r z))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr "))))")
      (DStr (nl))
      (lc_twin nm mids r z)
      (lc_worker nm mids n r z p)
      (lc_thm nm mids n r (+ p 4)))))

;; ---- the FLAG shape (two-region comparison; probe: beqloop_probe) ------------
;; bytes_eq: Z arm literal 1, S arm (if (int_eq READ READ) SELF-CALL 0).
;; The machine materializes the result in an EXTRA LOCAL (index n+1):
;; initialized to 1 BEFORE the loop, set to the BEq bit each iteration,
;; exit-tested by I32Eqz — its exit value IS the spec fn (the literals
;; are pinned 1/0 by this encoding). Every advancing accum gets a spec
;; TWIN (nm_t<i>) for its exit local, plus the counter twin (nm_kf).

;; the condition spelling ("m" in twins, "m0" in claims)
(fn lb_cnd ((mv Doc) (a Int) (b Int)) Doc
  (dconc
    (list
      (DStr "(int_eq (mem_get ")
      mv
      (DStr " x")
      (dint a)
      (DStr ") (mem_get ")
      mv
      (DStr " x")
      (dint b)
      (DStr "))"))))

;; the twins' self-call args: advancing accums stepped, statics through
(fn lb_targs ((ss (List LStr)) (i Int)) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (dconc (list (DStr " (+ x") (dint i) (DStr " 1)"))))
         (_ (dconc (list (DStr " x") (dint i)))))
       (lb_targs t (+ i 1))))))

;; accum i's twin: its local's exit value (exit arm returns the OLD value)
(fn lb_twin
  ((nm Doc) (mids (List Type)) (all (List LStr)) (a Int) (b Int) (i Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_t")
      (dint i)
      (DStr " ((m Mem) ")
      (pr_binds mids 0)
      (DStr "(k Nat)) Int (measure (struct k)) (match k (Z x")
      (dint i)
      (DStr ") ((S k2) (if ")
      (lb_cnd (DStr "m") a b)
      (DStr " (")
      nm
      (DStr "_t")
      (dint i)
      (DStr " m")
      (lb_targs all 0)
      (DStr " k2) x")
      (dint i)
      (DStr "))))")
      (DStr (nl)))))

(fn lb_twins
  ((nm Doc)
   (mids (List Type))
   (all (List LStr))
   (ss (List LStr))
   (a Int)
   (b Int)
   (i Int))
  Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (lb_twin nm mids all a b i))
         (_ (DStr "")))
       (lb_twins nm mids all t a b (+ i 1))))))

;; the counter twin: the budget local's exit value (exit arm keeps the
;; undecremented count)
(fn lb_ktwin ((nm Doc) (mids (List Type)) (ss (List LStr)) (a Int) (b Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_kf ((m Mem) ")
      (pr_binds mids 0)
      (DStr "(k Nat)) Int (measure (struct k)) (match k (Z 0) ((S k2) (if ")
      (lb_cnd (DStr "m") a b)
      (DStr " (")
      nm
      (DStr "_kf m")
      (lb_targs ss 0)
      (DStr " k2) (int_of_nat (S k2))))))")
      (DStr (nl)))))

;; exit locals: inc -> its twin, static -> xi, counter -> the counter
;; twin, flag -> the spec call
(fn lb_exits ((ss (List LStr)) (nm Doc) (mids (List Type)) (i Int) (spec Doc))
  Doc
  (measure (struct ss))
  (match ss
    (Nil
      (dconc
        (list
          (DStr "(")
          nm
          (DStr "_kf m0")
          (pr_args_lead mids)
          (DStr " k) ")
          spec)))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc)
          (dconc
            (list
              (DStr "(")
              nm
              (DStr "_t")
              (dint i)
              (DStr " m0")
              (pr_args_lead mids)
              (DStr " k) "))))
         (_ (dconc (list (DStr "x") (dint i) (DStr " ")))))
       (lb_exits t nm mids (+ i 1) spec)))))

;; per-inc-accum twin unfolds for the rhs opening
(fn lb_unfolds ((nm Doc) (ss (List LStr)) (i Int)) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc)
          (dconc
            (list (DStr "(unfold ") nm (DStr "_t") (dint i) (DStr " rhs) "))))
         (_ (DStr "")))
       (lb_unfolds nm t (+ i 1))))))

;; the FLAG SELF literal: extra local + pre-loop init + flag epilogue
(fn lb_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 1 (list (I32Const 1) (LocalSet ")
      (dint (+ n 1))
      (DStr ") (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint (+ n 1))
      (DStr ")))"))))

;; the shared head of both condition arms: fuel/eval_loop open, guard
;; decider, the read stages at A and B in code order, then the flag
;; collapse via the case hyp
(fn lb_arm_head ((adv (List LStr)) (a Int) (b Int) (na Int)) Doc
  (dconc
    (list
      (DStr
        "(chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
      (lp_stage (lp_advpos adv a) (+ na (lp_advpos adv a)))
      (lp_stage (lp_advpos adv b) (+ na (lp_advpos adv b)))
      (DStr
        "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (hyp 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lb_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (a Int)
   (b Int)
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr
          "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (eval_loop (S^ ")
        (dint p)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lb_self nm n)
        (DStr " restfs) 65536) (inline ")
        nm
        (DStr "_body) (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k) 1) st m0) (Some (OBr 0 st (list ")
        (lb_exits adv nm mids 0 (li_spec nm mids))
        (DStr
          ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (case-on ")
        (lb_cnd (DStr "m0") a b)
        (DStr " Bool ((case True ")
        (lb_arm_head adv a b na)
        (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))
        (lp_hws nm adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (lb_unfolds nm adv 0)
        (DStr "(unfold ")
        nm
        (DStr
          "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()))) (rewrite-with (hyp 1) lr lhs () (")
        (lp_lo1s nm adv 0)
        (lp_shifts nm adv 0 na)
        (DStr ")) (steps ((compute both))) refl)) (case False ")
        (lb_arm_head adv a b na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (lb_unfolds nm adv 0)
        (DStr "(unfold ")
        nm
        (DStr
          "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()) (rewrite (lemma int_of_nat_succ) lr rhs true ()))) (steps ((compute both))) refl))))))))")
        (DStr (nl))))))

(fn lb_thm ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (p6 Int)) Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p6)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lb_self nm n)
        (DStr " restfs) 65536) 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair ")
        (li_spec nm mids)
        (DStr
          " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

(fn lb_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (a Int)
   (b Int)
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lb_code n a b adv))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 1 (list (I32Const 1) (LocalSet ")
      (dint (+ n 1))
      (DStr ") (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint (+ n 1))
      (DStr "))))")
      (DStr (nl))
      (lb_twins nm mids adv adv a b 0)
      (lb_ktwin nm mids adv a b)
      (lb_worker nm mids n adv a b fa p)
      (lb_thm nm mids n adv (+ p 6)))))

;; ---- calls-in-loops (LRCall; probe: models/wasm/probes/callloop_probe.shard) -----------
;;
;; A Mem-return loop whose per-iteration work is a CALL to an earlier
;; same-file mem-fragment fn. STRUCTURAL form only (the §6f portability
;; limit): the callee's literal rides the module spine and its linked
;; cert is cited inside the S case at the iteration's fuel, so this unit
;; is emitted into the LINKED file and regenerates on callee edits. The
;; callee's return value is discarded by Drop (the re-entry stack equals
;; the entry stack — no scratch local, no return twin); its premises are
;; discharged from the loop's scaled range premises through generated
;; clh_* helper claims with computed farkas lists (the §6j discipline;
;; upper bounds (1 1 C C), lower bounds (1 1), C = the address
;; accumulator's stride).

;; index of x<i> among the loop's (or callee's) canonical param symbols
(fn xsym_idx ((s Symbol) (n Int) (i Int)) (Option Int)
  (measure (- n i))
  (if (le n i) None (if (sym_eq s (xsym i)) (Some i) (xsym_idx s n (+ i 1)))))

(fn lk_at ((ks (List LKArg)) (j Int)) (Option LKArg)
  (measure (struct ks))
  (match ks
    (Nil None)
    ((Cons h t) (if (int_eq j 0) (Some h) (lk_at t (- j 1))))))

;; instantiate a callee-frame expr at the call site: callee param x<j>
;; becomes the site's argument (a loop accum x<i> or a literal)
(fn lk_subst ((e Expr) (ks (List LKArg)) (ncal Int)) Expr
  (measure (struct e))
  (match e
    ((FVar s)
     (match (xsym_idx s ncal 0)
       ((Some j)
        (match (lk_at ks j)
          ((Some a)
           (match a
             ((LKAcc i) (FVar (xsym i)))
             ((LKLit l) (IntLit l))))
          (None e)))
       (None e)))
    ((Call q as) (Call q (lk_subst_l as ks ncal)))
    (_ e)))

(fn lk_subst_l ((es (List Expr)) (ks (List LKArg)) (ncal Int)) (List Expr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons e t) (Cons (lk_subst e ks ncal) (lk_subst_l t ks ncal)))))

;; linear form of an instantiated bound expr: one accum atom plus
;; literal offsets ((+ E L) nests), or fully ground
(type LKLin (LKLAcc Int Int) (LKLGround) (LKLBad))

(fn lk_lin ((e Expr) (n Int)) LKLin
  (measure (struct e))
  (match e
    ((FVar s)
     (match (xsym_idx s n 0)
       ((Some i) (LKLAcc i 0))
       (None (LKLBad))))
    ((IntLit _) (LKLGround))
    ((Call q as)
     (if (core_named q (quote +))
       (match as
         ((Cons a (Cons b Nil))
          (match b
            ((IntLit l)
             (match (lk_lin a n)
               ((LKLAcc i j) (LKLAcc i (+ j l)))
               ((LKLGround) (LKLGround))
               ((LKLBad) (LKLBad))))
            (_ (LKLBad))))
         (_ (LKLBad)))
       (LKLBad)))
    (_ (LKLBad))))

;; how one callee premise discharges at the loop site
(type LKD
  (LKDirect Int)
  (LKGround)
  (LKLo Int)
  (LKUp Int)
  (LKW32 Int)
  (LKBad (List Int)))

(fn lk_stride1 ((adv (List LStr)) (i Int)) (Option Int)
  (match (ls_at adv i)
    ((LSInc) (Some 1))
    ((LSIncK s) (Some s))
    (_ None)))

(fn lk_disch ((cp CPre) (ks (List LKArg)) (adv (List LStr)) (ncal Int) (n Int))
  LKD
  (let ((b (lk_subst (cpre_bound cp) ks ncal)))
    (match (lk_lin b n)
      ((LKLGround) (LKGround))
      ((LKLBad)
       (LKBad
         "callee premise is not linear (one accumulator plus literal offsets) at the call site (v1)"))
      ((LKLAcc i j)
       (match (lk_stride1 adv i)
         (None
           (LKBad
             "callee premises may only touch INCREMENTING loop accumulators (v1)"))
         ((Some cs)
          (if (lt j 0)
            (LKBad "callee premise has a negative offset at the call site")
            (match cp
              ((CPLo _) (if (int_eq j 0) (LKDirect (lp_advpos adv i)) (LKLo i)))
              ((CPWLo _)
               (if (int_eq j 0) (LKDirect (lp_advpos adv i)) (LKLo i)))
              ((CPHi _)
               (if (le (+ j 1) cs) (LKUp i)
               (LKBad
                 "callee footprint exceeds the address accumulator's stride")))
              ((CPWHi _) (LKW32 i))))))))))

;; loud pre-scan: the first LKBad message, if any
(fn lk_check
  ((cps (List CPre)) (ks (List LKArg)) (adv (List LStr)) (ncal Int) (n Int))
  (Option (List Int))
  (measure (struct cps))
  (match cps
    (Nil None)
    ((Cons cp t)
     (match (lk_disch cp ks adv ncal n)
       ((LKBad m) (Some m))
       (_ (lk_check t ks adv ncal n))))))

;; print a bound expr with the atom accum spelled as the helper binder a
(fn lk_pra ((e Expr) (ai Int)) Doc
  (measure (struct e))
  (match e
    ((FVar s) (if (sym_eq s (xsym ai)) (DStr "a") (dsym s)))
    ((IntLit l) (dint l))
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (dcat3
          (dcat3 (DStr "(") (dsym (qn_name q)) (sp))
          (DCat (lk_pra a ai) (sp))
          (DCat (lk_pra b ai) (DStr ")"))))
       (_ (DStr "?"))))
    (_ (DStr "?"))))

(fn clh_nm ((fnm Doc) (p Int)) Doc
  (dconc (list (DStr "clh_") fnm (DStr "_") (dint p))))

;; the scaled-range premise tail at stride cs (stride 1 has no (*))
(fn lk_rngtail ((cs Int)) Doc
  (if (int_eq cs 1) (DStr "(int_of_nat (S c))")
  (dconc (list (DStr "(* ") (dint cs) (DStr " (int_of_nat (S c)))")))))

;; one generated helper claim: the callee's premise at the site,
;; over the helper binder a, from the atom accum's loop premises
(fn lk_clh1 ((fnm Doc) (p Int) (d LKD) (b Expr) (adv (List LStr))) Doc
  (match d
    ((LKLo i)
     (dconc
       (list
         (DStr "(claim ")
         (clh_nm fnm p)
         (DStr " (goal ((a Int)) ((= (le 0 a) True)) (= (le 0 ")
         (lk_pra b i)
         (DStr ") True)) (by arith (list 1 1)))")
         (DStr (nl)))))
    ((LKUp i)
     (match (lk_stride1 adv i)
       ((Some cs)
        (dconc
          (list
            (DStr "(claim ")
            (clh_nm fnm p)
            (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a ")
            (lk_rngtail cs)
            (DStr
              ") 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ ")
            (lk_pra b i)
            (DStr " 1) 65536) True)) (by arith (list 1 1 ")
            (dint cs)
            (DStr " ")
            (dint cs)
            (DStr ")))")
            (DStr (nl)))))
       (None (DStr ""))))
    ((LKW32 i)
     (match (lk_stride1 adv i)
       ((Some cs)
        (dconc
          (list
            (DStr "(claim ")
            (clh_nm fnm p)
            (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a ")
            (lk_rngtail cs)
            (DStr
              ") 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (lt ")
            (lk_pra b i)
            (DStr " 4294967296) True)) (by arith (list 1 1 ")
            (dint cs)
            (DStr " ")
            (dint cs)
            (DStr ")))")
            (DStr (nl)))))
       (None (DStr ""))))
    (_ (DStr ""))))

(fn lk_clhs
  ((fnm Doc)
   (cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (lk_clh1
         fnm
         p
         (lk_disch cp ks adv ncal n)
         (lk_subst (cpre_bound cp) ks ncal)
         adv)
       (lk_clhs fnm t ks adv ncal n (+ p 1))))))

;; the hoisted haves, one per helper-discharged premise, in premise order
(fn lk_have1 ((fnm Doc) (p Int) (d LKD) (b Expr) (adv (List LStr)) (na Int)) Doc
  (match d
    ((LKLo i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (le 0 ")
         (pr_e b)
         (DStr ") True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs () ((steps ((rewrite (premise ")
         (dint (lp_advpos adv i))
         (DStr ") lr lhs true ())) refl)) refl)) "))))
    ((LKUp i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (le (+ ")
         (pr_e b)
         (DStr " 1) 65536) True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
         (dint (+ na (lp_advpos adv i)))
         (DStr
           ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) "))))
    ((LKW32 i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (lt ")
         (pr_e b)
         (DStr " 4294967296) True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
         (dint (+ na (lp_advpos adv i)))
         (DStr
           ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) "))))
    (_ (DStr ""))))

(fn lk_haves
  ((fnm Doc)
   (cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (na Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (lk_have1
         fnm
         p
         (lk_disch cp ks adv ncal n)
         (lk_subst (cpre_bound cp) ks ncal)
         adv
         na)
       (lk_haves fnm t ks adv ncal n na (+ p 1))))))

;; the callee-cert citation subproofs, one per premise, premise order
(fn lk_cites
  ((cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (match (lk_disch cp ks adv ncal n)
         ((LKDirect ix)
          (dconc
            (list
              (DStr "(steps ((rewrite (premise ")
              (dint ix)
              (DStr ") lr lhs true ())) refl) "))))
         ((LKGround) (DStr "(steps ((compute both)) refl) "))
         (_
           (dconc
             (list
               (DStr "(steps ((rewrite (premise hcp")
               (dint p)
               (DStr ") lr lhs true ())) refl) ")))))
       (lk_cites t ks adv ncal n (+ p 1))))))

;; call-site argument docs (site spelling / machine code)
(fn lk_argdoc ((k LKArg)) Doc
  (match k
    ((LKAcc i) (dcat3 (DStr "x") (dint i) (DStr "")))
    ((LKLit l) (dint l))))

(fn lk_argcode ((ks (List LKArg))) (List Doc)
  (measure (struct ks))
  (match ks
    (Nil Nil)
    ((Cons h t)
     (Cons
       (match h
         ((LKAcc i) (lp_lget i))
         ((LKLit l) (lp_const l)))
       (lk_argcode t)))))

(fn lk_conses ((ks (List LKArg))) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr "Nil"))
    ((Cons h t)
     (dcat3
       (DCat (DStr "(Cons ") (lk_argdoc h))
       (DCat (sp) (lk_conses t))
       (DStr ")")))))

(fn lk_rev ((ks (List LKArg)) (acc (List LKArg))) (List LKArg)
  (measure (struct ks))
  (match ks
    (Nil acc)
    ((Cons h t) (lk_rev t (Cons h acc)))))

;; the spec work application (the source S arm's spelling)
(fn lk_specwork ((cnm Symbol) (ks (List LKArg))) Doc
  (dcat3 (dcat3 (DStr "(") (dsym cnm) (DStr " m0")) (lk_specargs ks) (DStr ")")))

(fn lk_specargs ((ks (List LKArg))) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr ""))
    ((Cons h t) (dcat3 (sp) (lk_argdoc h) (lk_specargs t)))))

;; the return-value doc: the callee's Pair value slot at the site
(fn lk_retdoc ((ce Expr) (ks (List LKArg)) (ncal Int)) (Option Doc)
  (match ce
    ((FVar s)
     (match (xsym_idx s ncal 0)
       ((Some j)
        (match (lk_at ks j)
          ((Some a) (Some (lk_argdoc a)))
          (None None)))
       (None None)))
    ((IntLit l) (Some (dint l)))
    (_ None)))

;; the bridge stage: call_bridge + the callee's linked cert
(fn lk_bridge
  ((cnm Symbol)
   (cself Doc)
   (ks (List LKArg))
   (vdoc Doc)
   (cps (List CPre))
   (adv (List LStr))
   (ncal Int)
   (n Int))
  Doc
  (dconc
    (list
      (DStr "(rewrite-with (lemma call_bridge) lr lhs ((inst f ")
      cself
      (DStr ") (inst popped ")
      (lk_conses (lk_rev ks Nil))
      (DStr ") (inst rest st) (inst args ")
      (lk_conses ks)
      (DStr ") (inst v ")
      vdoc
      (DStr ") (inst mem2 ")
      (lk_specwork cnm ks)
      (DStr
        ")) ((steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) (rewrite-with (lemma linked_")
      (dsym cnm)
      (DStr ") lr lhs () (")
      (lk_cites cps ks adv ncal n 0)
      (DStr ") refl))) "))))

;; guard / arg pushes / Call 2 / Drop / advances / decrement / re-enter
;; (instrs = 8 + (nargs + 2) + 4*nAdv)
(fn lk_code ((n Int) (adv (List LStr)) (ks (List LKArg))) (List Doc)
  (dapp
    (list (lp_lget n) (DStr "(I32Eqz)") (DStr "(BrIf 1)"))
    (dapp
      (lk_argcode ks)
      (dapp
        (list (DStr "(Call 2)") (DStr "(Drop)"))
        (dapp
          (lp_advcode adv 0)
          (list
            (lp_lget n)
            (lp_const 1)
            (DStr "(I32Bin BSub)")
            (lp_lset n)
            (DStr "(Br 0)")))))))

;; the 4-slot module spine: [mget, mset, callee, self | restfs]
(fn lk_mod ((nm Doc) (n Int) (cself Doc)) Doc
  (dconc
    (list
      (DStr "(MkWModule (Cons ")
      (mget_lit)
      (DStr " (Cons ")
      (mset_lit)
      (DStr " (Cons ")
      cself
      (DStr " (Cons ")
      (lp_self nm n)
      (DStr " restfs)))) 65536)"))))

(fn lk_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ci CInfo)
   (ks (List LKArg))
   (vdoc Doc)
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (match ci
      ((MkCInfo cnm cself _ ncal cps _)
       (dconc
         (list
           (DStr "(claim lgw_")
           nm
           (DStr " (goal (")
           (pr_binds mids 0)
           (DStr
             "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
           (lp_prems_lo adv 0)
           (lp_prems_rng adv 0)
           (DStr ") (= (eval_loop (S^ ")
           (dint p)
           (DStr " (lg_fuel k c)) ")
           (lk_mod nm n cself)
           (DStr " (inline ")
           nm
           (DStr "_body) (list ")
           (pr_args mids 0)
           (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
           (lp_exits adv 0)
           (DStr ") (")
           nm
           (DStr " m0")
           (pr_args_lead mids)
           (DStr
             " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_call eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_call eval_loop lg_fuel)))) ")
           (lk_haves nm cps ks adv ncal n na 0)
           (lk_bridge cnm cself ks vdoc cps adv ncal n)
           (DStr "(steps ((compute lhs (stop eval_call eval_loop lg_fuel)))) ")
           (match (ls_at adv fa)
             ((LSIncK s)
              (lp_khwk
                (lgs_nm nm s "kM")
                fa
                (+ na (lp_advpos adv fa))
                (lp_advpos adv fa)))
             (_ (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))))
           (lp_hws nm adv 0 0 na)
           (DStr "(steps ((unfold ")
           nm
           (DStr " rhs) ")
           (if (lp_has_inc1 adv) (DStr "(unfold lg_adv rhs) ") (DStr ""))
           (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
           (if (lp_has_inck adv) (DStr "(unfold lg_advk rhs) ") (DStr ""))
           (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
           (lp_lo1s nm adv 0)
           (lp_shifts nm adv 0 na)
           (DStr ")) (steps ((compute both))) refl)))))")
           (DStr (nl))))))))

(fn lk_thm
  ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (cself Doc) (p4 Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p4)
        (DStr " (lg_fuel k c)) ")
        (lk_mod nm n cself)
        (DStr " 3 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + stride kit + premise helpers + worker + theorem —
;; the whole unit lands in the LINKED file (callee literals inside)
(fn lk_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ci CInfo)
   (ks (List LKArg))
   (vdoc Doc)
   (fa Int)
   (p Int))
  Doc
  (match ci
    ((MkCInfo _ cself _ ncal cps _)
     (dconc
       (list
         (DStr "(fn ")
         nm
         (DStr "_body () (List Instr) (list ")
         (djoin (lk_code n adv ks))
         (DStr "))")
         (DStr (nl))
         (DStr "(fn ")
         nm
         (DStr "_func () Func (MkFunc ")
         (dint (+ n 1))
         (DStr " 0 (list (Block (list (Loop (")
         nm
         (DStr "_body)))) (I32Const 0))))")
         (DStr (nl))
         (lgs_all nm (lp_incks adv Nil))
         (lk_clhs nm cps ks adv ncal n 0)
         (lk_worker nm mids n adv ci ks vdoc fa p)
         (lk_thm nm mids n adv cself (+ p 4)))))))

(fn emit_claim_loop ((f FnDef) (reg (List CInfo))) CRes
  (match f
    ((FnDef q ts rty body)
     (match ts
       ((Cons _ rest)
        (match (ts_lasto rest)
          ((Some lt)
           (if (is_nat_ty lt)
             (let ((mids (ts_mids rest)))
               (if (all_int mids)
                 (let ((n (count_ts mids)))
                   (if (lt 0 n)
                     (if (is_mem_ty rty)
                       (match (lp_recognize q n body reg)
                         ((LRErr m) (cerr_at q m))
                         ((LRCall adv cnm ks)
                          (match (reg_find reg cnm)
                            (None
                              (cerr_at
                                q
                                "loop call target must be an EARLIER same-file mem-fragment fn"))
                            ((Some ci)
                             (match ci
                               ((MkCInfo _ _ cnn ncal cps ce)
                                (match (lp_first_inc adv 0)
                                  (None
                                    (cerr_at
                                      q
                                      "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                                  ((Some fa)
                                   (match (lk_retdoc ce ks ncal)
                                     (None
                                       (cerr_at
                                         q
                                         "callee's return value must be a parameter or a u32 literal (v1) -- read-returning callees do not ride the loop template yet"))
                                     ((Some vdoc)
                                      (match (lk_check cps ks adv ncal n)
                                        ((Some m) (cerr_at q m))
                                        (None
                                          (let
                                            ((cnt
                                               (+
                                                 8
                                                 (+
                                                   (+ (lk_nargs ks) 2)
                                                   (* 4 (lp_nadv adv))))))
                                            (COkC
                                              (lk_unit
                                                (dsym (qn_name q))
                                                mids
                                                n
                                                adv
                                                ci
                                                ks
                                                vdoc
                                                fa
                                                (+ cnt (+ 4 (+ (* 2 cnn) 1)))))))))))))))))
                         ((LROk adv sts)
                          (if (lp_has_xf sts)
                            (cerr_at
                              q
                              "range-shift store values (LVXf) are not in the wasm loop fragment yet (the x86 rung, docs/X86.md §28, speaks first)")
                            (match (lp_first_inc adv 0)
                              (None
                                (cerr_at
                                  q
                                  "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                              ((Some fa)
                               (let
                                 ((cnt
                                    (+ 8 (+ (lp_stlen sts) (* 4 (lp_nadv adv))))))
                                 (COk
                                   (lp_unit
                                     (dsym (qn_name q))
                                     mids
                                     n
                                     adv
                                     sts
                                     fa
                                     (+ cnt 4))
                                   (DStr ""))))))))
                     (if (is_int_ty rty)
                       (match (li_recognize q n body)
                         ((LIErr m) (cerr_at q m))
                         ((LFOk adv r j a c)
                          (cerr_at
                            q
                            "decimal-fold accumulators (LUFold) are not in the wasm loop fragment yet (the x86 rung, docs/X86.md rung B, speaks first)"))
                         ((LCOk adv r z)
                          (COk
                            (lc_unit
                              (dsym (qn_name q))
                              mids
                              n
                              r
                              z
                              (if (int_eq z 0) 20 21))
                            (DStr "")))
                         ((LBOk adv a b)
                          (match (lp_first_inc adv 0)
                            (None
                              (cerr_at
                                q
                                "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                            ((Some fa)
                             (let ((cnt (+ 17 (* 4 (lp_nadv adv)))))
                               (COk
                                 (lb_unit
                                   (dsym (qn_name q))
                                   mids
                                   n
                                   adv
                                   a
                                   b
                                   fa
                                   (+ cnt 4))
                                 (DStr ""))))))
                         ((LIOk adv r j)
                          (if (lp_has_inck adv)
                            (cerr_at
                              q
                              "stride != 1 is Mem-return-loop-only in v1 (Int-return loops keep +-1 accums)")
                            (match (lp_first_inc adv 0)
                              (None
                                (cerr_at
                                  q
                                  "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                              ((Some fa)
                               (let ((cnt (+ 13 (* 4 (lp_nadv adv)))))
                                 (COk
                                   (li_unit
                                     (dsym (qn_name q))
                                     mids
                                     n
                                     adv
                                     r
                                     j
                                     fa
                                     (+ cnt 4))
                                   (DStr ""))))))))
                       (cerr_at q "loop fn must return Mem or Int")))
                     (cerr_at q "loop fn needs at least one Int accumulator")))
                 (cerr_at q "loop accumulators must all be Int")))
             (cerr_at q "loop fn's last param must be the Nat counter")))
          (None (cerr_at q "loop fn needs (m Mem) (accums Int...) (k Nat)"))))
       (Nil (cerr_at q "loop fn needs params"))))))

;; ---- claim emission ----------------------------------------------------------


;; COk = portable + linked docs (linked used only for mem fns);
;; COkM = a mem fn, carrying its callee-registry entry (None when the fn
;; is not a valid loop callee — Int return);
;; COkC = a calls-in-loops unit, resident in the LINKED file
(type CRes
  (COk Doc Doc)
  (COkM Doc Doc (Option CInfo))
  (COkC Doc)
  (CErr (List Int)))

(fn cerr_at ((q QName) (m (List Int))) CRes
  (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))


;; the PORTABLE claim (the primary cert): module abstract, callee slots
;; abstract binders, premises = spine + arities + the item list. The
;; callee bytes appear NOWHERE — a callee edit leaves this file byte-
;; identical; only the linked derivation regenerates.
(fn m_claim_port
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc)
   (prf Doc)
   (evd Doc))
  Doc
  (dcat3
    (dcat3
      (dcat3
        (DStr "(claim lowered_")
        (dsym (qn_name q))
        (dcat3
          (DStr " (goal (")
          (pr_binds ints 0)
          (DStr
            "(m0 Mem) (m WModule) (f0 Func) (f1 Func) (restm (List Func)) (c Nat)) ((= (funcs_of m) (Cons f0 (Cons f1 (Cons ")))
      (DCat self (DStr " restm)))) (= (params_of f0) 1) (= (params_of f1) 2) "))
      (pits_prems pres))
    (dcat3
      (dcat3 (DStr ") (= (call_fn_mem (S^ ") (dint nn) (DStr " c) m 2 (list "))
      (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
      (dcat3
        (dcat3
          (DStr
            ")) (chain (steps ((compute lhs (stop eval_call funcs_of)) (rewrite (premise 0) lr lhs true ()) (unfold ")
          (dsym (qn_name q))
          (DStr " rhs) (reduce rhs))) "))
        prf
        (DStr "(steps ((compute lhs))) ")))
    (dcat3 evd (DStr "refl))") (DStr (nl)))))

;; ---- the LINKED derivation (the artifact form, derived by citation) ------------

;; address classification (PRE hygiene §6j): a ground literal's bound
;; pair computes; a read-linear address whose interval fits [0, 65535]
;; derives via a generated ab_* helper; anything else keeps its premise
;; pair. np / nr = the running premise-pair / helper ordinals.
(fn classify_addrs ((as (List Expr)) (np Int) (nr Int)) (List AC)
  (measure (struct as))
  (match as
    (Nil Nil)
    ((Cons a t)
     (match (pl_e a True)
       (None (Cons (ACPrem np) (classify_addrs t (+ np 1) nr)))
       ((Some p)
        (match (pl_atoms p)
          (Nil (Cons ACGround (classify_addrs t np nr)))
          (_
            (if (le 0 (pl_lo p))
              (if (le (+ (pl_hi p) 1) 65536)
                (Cons (ACRead nr (pl_atoms p)) (classify_addrs t np (+ nr 1)))
                (Cons (ACPrem np) (classify_addrs t (+ np 1) nr)))
              (Cons (ACPrem np) (classify_addrs t (+ np 1) nr))))))))))

(fn ac_nprem ((acs (List AC))) Int
  (measure (struct acs))
  (match acs
    (Nil 0)
    ((Cons h t)
     (match h
       ((ACPrem _) (+ 1 (ac_nprem t)))
       (_ (ac_nprem t))))))

;; the linked cert's premises as CPre items, EXACTLY the order the
;; linked claim declares them (link_addr_prems2 then link_wrap_prems) —
;; the calls-in-loops walk consumes these; any drift between the two
;; enumerations fails the kernel gate loudly at the citation subproofs
(fn cpre_addrs ((as (List Expr)) (acs (List AC))) (List CPre)
  (measure (struct as))
  (match as
    (Nil Nil)
    ((Cons a t)
     (match acs
       (Nil Nil)
       ((Cons ac acst)
        (match ac
          ((ACPrem _) (Cons (CPLo a) (Cons (CPHi a) (cpre_addrs t acst))))
          (_ (cpre_addrs t acst))))))))

(fn cpre_wraps ((ps (List PItem))) (List CPre)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons h t)
     (match h
       ((PWrap e) (Cons (CPWLo e) (Cons (CPWHi e) (cpre_wraps t))))
       (_ (cpre_wraps t))))))

(fn cpre_app ((a (List CPre)) (b (List CPre))) (List CPre)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (cpre_app t b)))))

;; the linked cert's address premises: one pair per ACPrem address only
(fn link_addr_prems2 ((as (List Expr)) (acs (List AC))) Doc
  (measure (struct as))
  (match as
    (Nil (DStr ""))
    ((Cons a t)
     (match acs
       (Nil (DStr ""))
       ((Cons ac acst)
        (match ac
          ((ACPrem _)
           (dcat3
             (dcat3 (DStr "(= (le 0 ") (pr_e a) (DStr ") True) "))
             (dcat3 (DStr "(= (le (+ ") (pr_e a) (DStr " 1) 65536) True) "))
             (link_addr_prems2 t acst)))
          (_ (link_addr_prems2 t acst))))))))

;; the generated address-bound helper claims, one lo/hi pair per ACRead
(fn ab_claims ((as (List Expr)) (acs (List AC)) (fnm Doc)) Doc
  (measure (struct as))
  (match as
    (Nil (DStr ""))
    ((Cons a t)
     (match acs
       (Nil (DStr ""))
       ((Cons ac acst)
        (match ac
          ((ACRead k rs)
           (dcat3
             (iv_claim
               (ab_name fnm k True)
               rs
               (bnd_le0 (pr_e (subst_reads a rs)))
               (iv_lo_mults rs))
             (iv_claim
               (ab_name fnm k False)
               rs
               (bnd_leaddr (pr_e (subst_reads a rs)))
               (iv_hi_mults rs))
             (ab_claims t acst fnm)))
          (_ (ab_claims t acst fnm))))))))


;; the LINKED claim: the structural artifact statement, proven by ONE
;; citation of the portable cert (zero interpreter steps)
(fn m_claim_link
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc))
  Doc
  (let ((as (addrs_of pres Nil)))
    (let ((acs (classify_addrs as 0 0)))
      (dcat3
        (DCat
          (ab_claims as acs (dsym (qn_name q)))
          (dcat3
            (dcat3
              (DStr "(claim linked_")
              (dsym (qn_name q))
              (dcat3
                (DStr " (goal (")
                (pr_binds ints 0)
                (DStr "(m0 Mem) (c Nat) (restfs (List Func))) (")))
            (DCat (link_addr_prems2 as acs) (link_wrap_prems pres))
            (dcat3
              (dcat3
                (DStr ") (= (call_fn_mem (S^ ")
                (dint nn)
                (DStr " c) (MkWModule (Cons "))
              (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
              (dcat3
                (DCat (DStr " (Cons ") self)
                (DStr " restfs))) 65536) 2 (list ")
                (DStr "")))))
        (dcat3
          (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
          (dcat3
            (dcat3
              (DStr ")) (chain (rewrite-with (lemma lowered_")
              (dsym (qn_name q))
              (DStr ") lr lhs ((inst m (MkWModule (Cons "))
            (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
            (dcat3
              (DCat (DStr " (Cons ") self)
              (DStr " restfs))) 65536)) (inst f0 ")
              (DStr "")))
          (dcat3
            (dcat3 (mget_lit) (DStr ") (inst f1 ") (mset_lit))
            (DStr
              ") (inst restm restfs)) ((steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) ")
            (link_subs
              pres
              as
              acs
              (* 2 (ac_nprem acs))
              0
              "lowered_mem_get"
              "lowered_mem_set"
              (dsym (qn_name q)))))
        (dcat3 (DStr ")) refl))") (DStr (nl)) (DStr ""))))))

;; dispatch by return type, shared by both passes
(fn mg_walk ((n Int) (nn Int) (fnm Doc) (rty Type) (body Expr)) MRes
  (let ((st0 (MkMSt Nil 0 (- n 1) Nil (DStr "") 0 Nil Nil 0 0 (m0v))))
    (if (is_int_ty rty) (mg_e n nn fnm Nil st0 body)
    (if (is_mem_ty rty) (mg_tail n nn fnm Nil st0 body)
    (MErr "return type must be Int or Mem")))))

;; the generated read-interval helper claims, one lo/hi pair per PAuto
;; node (ordinals in discovery order — paut_ix's order)
(fn wb_claims ((ps (List PItem)) (fnm Doc) (k Int)) Doc
  (measure (struct ps))
  (match ps
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((PAuto e)
        (let
          ((rs
             (match (pl_e e True)
               ((Some p) (pl_atoms p))
               (None Nil))))
          (dcat3
            (iv_claim
              (wb_name fnm k True)
              rs
              (bnd_le0 (pr_e (subst_reads e rs)))
              (iv_lo_mults rs))
            (iv_claim
              (wb_name fnm k False)
              rs
              (bnd_ltwrap (pr_e (subst_reads e rs)))
              (iv_hi_mults rs))
            (wb_claims t fnm (+ k 1)))))
       (_ (wb_claims t fnm k))))))

;; TWO-PASS: behavior premises embed site fuels, which depend on the
;; total tower — pass 1 counts, pass 2 emits. Budget: each call site is
;; charged 2x its callee's tower + 1 (callee growth within 2x relinks
;; without touching this cert).
(fn emit_claim_mem ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (match ts
       (Nil (cerr_at q "no params"))
       ((Cons _ ints)
        (if (all_int ints)
          (let ((n (count_ts ts)))
            (match (mg_walk n 0 (dsym (qn_name q)) rty body)
              ((MErr m) (cerr_at q m))
              ((MOk st1 ce1)
               (match st1
                 ((MkMSt cd1 cnt1 nx1 sk1 pf1 j1 pr1 pd1 gets1 sets1 mm1)
                  (if (int_eq (+ gets1 sets1) 0)
                    (cerr_at
                      q
                      "no memory operations (use the scalar fragment: drop the Mem param)")
                  (if
                    (if (is_int_ty rty)
                      (if (chars_eq (spell mm1) (spell (m0v))) False True)
                      False)
                    (cerr_at
                      q
                      "stores in an Int-returning fn (the schema pins its memory unchanged) -- return Mem")
                    (let
                      ((nn (+ (* 2 cnt1) (+ 3 (+ (* 13 gets1) (* 21 sets1))))))
                      (match (mg_walk n nn (dsym (qn_name q)) rty body)
                        ((MErr m) (cerr_at q m))
                        ((MOk st ce)
                         (match st
                           ((MkMSt code cnt nxt stk prf j pres pend gets sets
                              mmf)
                            (match (m_flush pend pres (dsym (qn_name q)) j)
                              ((Pair evd _)
                               (let ((self (m_self_lit n nxt code)))
                                 (let ((rhs (m_rhs q ints rty ce)))
                                   (COkM
                                     (DCat
                                       (wb_claims pres (dsym (qn_name q)) 0)
                                       (m_claim_port q ints nn self pres rhs prf
                                         evd))
                                     (m_claim_link q ints nn self pres rhs)
                                     (if (is_mem_ty rty)
                                       (let ((as2 (addrs_of pres Nil)))
                                         (Some
                                           (MkCInfo
                                             (qn_name q)
                                             self
                                             nn
                                             (- n 1)
                                             (cpre_app
                                               (cpre_addrs
                                                 as2
                                                 (classify_addrs as2 0 0))
                                               (cpre_wraps pres))
                                             ce)))
                                       None))))))))))))))))))
          (cerr_at q "params after the Mem param must all be Int")))))))

(fn emit_claim ((f FnDef) (reg (List CInfo))) CRes
  (match f
    ((FnDef _ ts _ _)
     (match ts
       ((Cons t0 _)
        (if (is_mem_ty t0)
          (if (fn_is_loop f) (emit_claim_loop f reg) (emit_claim_mem f))
          (emit_claim_pure f 0)))
       (Nil (emit_claim_pure f 0))))))

;; ---- the staged pure walk: ediv/mod (docs/LOWERING.md §6y) ---------------------
;;
;; A division's guard makes bop_val reduce to (if (le 1 B) (Some (ediv A
;; B)) None); with B symbolic the machine fold JAMS at that instruction,
;; so the one-shot (compute lhs) no longer runs the whole machine. The
;; proof interleaves instead (the mem fragment's stage law, probe:
;; models/wasm/probes/divfrag_probe.shard): per div site in code order — flush the
;; wrap events materialized so far (their all-occurrence rewrites clean
;; the divisor spelling), rewrite the guard PRE (= (le 1 B) True) into
;; the stuck if, resume (compute lhs). The div node itself contributes
;; NO wrap event (bop_val returns the ediv/mod unwrapped — machine
;; spelling = spec spelling); a LITERAL divisor's guard computes away
;; (zero staging — (ediv x 2^k) is slice D's constant right shift, free);
;; a zero-literal divisor refuses at generation. v1 fence: div fns are
;; straight-line/let only (no ifs — the region templates and the stage
;; law have not been composed yet).
;;
;; Premise layout in EVENT ORDER, dedup by spelling: a wrap node claims
;; the (le 0 E)/(lt E 2^32) pair, a symbolic divisor the single guard
;; (le 1 B). Guard spellings are le-headed and wrap spellings
;; arith-headed, but separate assoc lists keep the lookup honest.
(type DLay (MkDLay Doc (List (Pair Expr Int)) (List (Pair Expr Int)) Int))

(fn dvx_at ((a (List (Pair Expr Int))) (s (List Int))) Int
  (measure (struct a))
  (match a
    (Nil 0)
    ((Cons (Pair k v) t) (if (chars_eq s (spell k)) v (dvx_at t s)))))

(fn dvx_seen ((a (List (Pair Expr Int))) (s (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil False)
    ((Cons (Pair k _) t) (if (chars_eq s (spell k)) True (dvx_seen t s)))))

(fn dv_lay
  ((evs (List DEv))
   (pd Doc)
   (wa (List (Pair Expr Int)))
   (ga (List (Pair Expr Int)))
   (ni Int))
  DLay
  (measure (struct evs))
  (match evs
    (Nil (MkDLay pd wa ga ni))
    ((Cons ev t)
     (match ev
       ((EvW e)
        (if (dvx_seen wa (spell e)) (dv_lay t pd wa ga ni)
        (dv_lay
          t
          (dcat3
            pd
            (dcat3 (DStr "(= ") (bnd_le0 (pr_e e)) (DStr " True) "))
            (dcat3 (DStr "(= ") (bnd_ltwrap (pr_e e)) (DStr " True) ")))
          (Cons (Pair e ni) wa)
          ga
          (+ ni 2))))
       ((EvD b)
        (if (dvx_seen ga (spell b)) (dv_lay t pd wa ga ni)
        (dv_lay
          t
          (DCat pd (dcat3 (DStr "(= ") (bnd_ge1 (pr_e b)) (DStr " True) ")))
          wa
          (Cons (Pair b ni) ga)
          (+ ni 1))))))))

;; flush the pending wrap events (all materialized in the residue by this
;; stage point), machine order; j = the running have ordinal
(fn dv_flush ((pend (List Expr)) (wa (List (Pair Expr Int))) (j Int))
  (Pair Doc Int)
  (measure (struct pend))
  (match pend
    (Nil (Pair (DStr "") j))
    ((Cons e t)
     (match (dv_flush t wa (+ j 1))
       ((Pair d j2)
        (Pair
          (DCat
            (w32_event
              e
              (dint (dvx_at wa (spell e)))
              (dint (+ (dvx_at wa (spell e)) 1))
              j)
            d)
          j2))))))

;; the staged proof body: pending wraps batch per segment (dedup WITHIN
;; the segment — one all-occurrences fire covers same-segment duplicates;
;; a spelling recomputed in a LATER segment re-enters pending and
;; re-fires); each EvD flushes, rewrites its guard premise (re-use
;; re-fires the same index), and resumes compute.
(fn dv_pf
  ((evs (List DEv))
   (pend (List Expr))
   (wa (List (Pair Expr Int)))
   (ga (List (Pair Expr Int)))
   (j Int))
  Doc
  (measure (struct evs))
  (match evs
    (Nil
      (match (dv_flush pend wa j)
        ((Pair d _) (DCat d (DStr "refl")))))
    ((Cons ev t)
     (match ev
       ((EvW e)
        (if (node_seen (spell e) pend) (dv_pf t pend wa ga j)
        (dv_pf t (node_add e pend) wa ga j)))
       ((EvD b)
        (match (dv_flush pend wa j)
          ((Pair d j1)
           (DCat
             d
             (DCat
               (dcat3
                 (DStr "(steps ((rewrite (premise ")
                 (dint (dvx_at ga (spell b)))
                 (DStr ") lr lhs true ()) (compute lhs))) "))
               (dv_pf t Nil wa ga j1))))))))))

;; ---- lib position vocabulary (the lib-build arc) --------------------------------
;; A lib module lays EVERY fn of the source file into ONE WModule; the cert
;; for the fn at index K quantifies the K slots before it ((f0 Func) …) and
;; keeps the tail in restfs — the probe form (models/wasm/probes/libmod_probe.shard).
;; pfx = 0 emits today's leaf form byte-for-byte.
(fn pr_fbinds ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "")
  (DCat (pr_fbinds (- k 1)) (dcat3 (DStr "(f") (dint (- k 1)) (DStr " Func) ")))))

(fn pr_fcons ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "")
  (DCat (pr_fcons (- k 1)) (dcat3 (DStr "(Cons f") (dint (- k 1)) (DStr " ")))))

(fn pr_rpars ((k Int)) Doc
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt k 1) (DStr "") (DCat (pr_rpars (- k 1)) (DStr ")"))))

;; ---- the WORD fragment: std/word u32 ops (docs/LOWERING.md §7.8) ---------------
;;
;; Source fns whose signatures speak std/word's U32 lower with the word op
;; AS the machine op: u32_xor = I32Bin BXor, u32_shl/u32_shr at a LITERAL
;; count = the §6x slice-D constant multiply/divide, and the u32 maker /
;; u32_val = identity code (the Int image IS the machine value). The
;; statement keeps Int binders; ENC = the u32 maker spec-side, DEC =
;; u32_val (the §2 adapter slots in the module's own vocabulary).
;; Premises: ONE width pair per param the tree touches as a word (the
;; argw32 family — vacuous at any real i32 boundary), plus §6y div guards.
;; The proof (probe: models/wasm/probes/wordfrag_probe.shard, first-generation
;; template): defining-equation opens outside-in, maker-atom collapses,
;; then per node bottom-up — std/bits literal bridges at shl/shr,
;; wrap32_id rep-collapse with derived bounds at xor/shr (bxor_lo /
;; bxor_lt32, mod_lo/mod_hi, generated wq_* quotient-bound helper claims
;; via div-facts + formulaic farkas). Every spec-side rewrite = named
;; have + ONE all-occurrences premise rewrite (rewrite-with rewrites the
;; FIRST occurrence only — the P2b sharing law).

(fn is_u32_ty ((t Type)) Bool
  (match t
    ((TCon q _) (sym_eq (qn_name q) (quote U32)))
    ((TVar _) False)))

(fn any_u32 ((ts (List Type))) Bool
  (measure (struct ts))
  (match ts
    (Nil False)
    ((Cons t rest) (if (is_u32_ty t) True (any_u32 rest)))))

(fn word_sig ((ts (List Type)) (rty Type)) Bool
  (if (any_u32 ts) True (is_u32_ty rty)))

;; std/word's fn named s? (strict module identity, memq_named's shape)
(fn wordq_named ((q QName) (s Symbol)) Bool
  (match q
    ((QName mp nm)
     (if (sym_eq nm s)
       (sym_list_eq mp (Cons (quote std) (Cons (quote word) Nil)))
       False))))

(fn wd_wq ((s Symbol)) QName
  (QName (Cons (quote std) (Cons (quote word) Nil)) s))

(type WOp (WOXor) (WOShl) (WOShr) (WOMk) (WOVal))

(fn wd_op ((q QName)) (Option WOp)
  (if (wordq_named q (quote u32_xor)) (Some WOXor)
  (if (wordq_named q (quote u32_shl)) (Some WOShl)
  (if (wordq_named q (quote u32_shr)) (Some WOShr)
  (if (wordq_named q (quote u32)) (Some WOMk)
  (if (wordq_named q (quote u32_val)) (Some WOVal)
  None))))))

;; the shl/shr widths std/bits ships literal bridges for (shlK_mul /
;; shrK_div + the wq farkas formulas below); a new width = grow std/bits
;; by the documented two patterns.
(fn wd_shl_ok ((k Int)) Bool
  (if (int_eq k 1) True
  (if (int_eq k 5) True
  (if (int_eq k 8) True
  (if (int_eq k 13) True
  False)))))

(fn wd_shr_ok ((k Int)) Bool
  (if (int_eq k 1) True (if (int_eq k 8) True (if (int_eq k 17) True False))))

(fn wd_p2 ((k Int)) Int (bshl 1 k))

;; canonical-tree builders (std/word qnames so wd_op matches uniformly;
;; the printer emits bare names resolved by the generated file's use-globs)
(fn wd_c1 ((s Symbol) (a Expr)) Expr (Call (wd_wq s) (Cons a Nil)))

(fn wd_c2 ((s Symbol) (a Expr) (b Expr)) Expr
  (Call (wd_wq s) (Cons a (Cons b Nil))))

;; the word spelling printer — pr_e's 2/3-ary grammar plus the 1-ary
;; calls the word vocabulary needs ((u32 x0), (u32_val …))
(fn wd_pr ((e Expr)) Doc
  (measure (struct e))
  (match e
    ((FVar s) (dsym s))
    ((IntLit k) (dint k))
    ((Call q as)
     (match as
       ((Cons a Nil)
        (dcat3 (dcat3 (DStr "(") (dsym (qn_name q)) (sp)) (wd_pr a) (DStr ")")))
       ((Cons a (Cons b Nil))
        (dcat3
          (dcat3 (DStr "(") (dsym (qn_name q)) (sp))
          (DCat (wd_pr a) (sp))
          (DCat (wd_pr b) (DStr ")"))))
       (_ (DStr "?"))))
    (_ (DStr "?"))))

(fn wd_spell ((e Expr)) (List Int) (doc_flat (wd_pr e) Nil))

(fn wd_seen ((s (List Int)) (ns (List Expr))) Bool
  (measure (struct ns))
  (match ns
    (Nil False)
    ((Cons h t) (if (chars_eq s (wd_spell h)) True (wd_seen s t)))))

(fn wd_ix ((s (List Int)) (ns (List Expr)) (k Int)) Int
  (measure (struct ns))
  (match ns
    (Nil 0)
    ((Cons h t) (if (chars_eq s (wd_spell h)) k (wd_ix s t (+ k 1))))))

;; ---- the word walk: code + canonical tree + guards + width-pair needs ----------

(fn ts_at ((ts (List Type)) (i Int)) (Option Type)
  (measure (struct ts))
  (match ts
    (Nil None)
    ((Cons h t) (if (int_eq i 0) (Some h) (ts_at t (- i 1))))))

;; insert a param position, ascending, dedup
(fn wd_ins ((p Int) (ns (List Int))) (List Int)
  (measure (struct ns))
  (match ns
    (Nil (Cons p Nil))
    ((Cons h t)
     (if (int_eq p h) ns (if (lt p h) (Cons p ns) (Cons h (wd_ins p t)))))))

(fn wd_norm ((ps (List Int)) (acc (List Int))) (List Int)
  (measure (struct ps))
  (match ps
    (Nil acc)
    ((Cons h t) (wd_norm t (wd_ins h acc)))))

;; rank of the width-pair param spelled s among the (sorted) needs
(fn wd_rank ((s Symbol) (ns (List Int)) (k Int)) Int
  (measure (struct ns))
  (match ns
    (Nil 0)
    ((Cons h t) (if (sym_eq s (xsym h)) k (wd_rank s t (+ k 1))))))

(fn wd_is32 ((e Expr)) Bool
  (match e
    ((Call q _)
     (match (wd_op q)
       ((Some WOXor) True)
       ((Some WOShl) True)
       ((Some WOShr) True)
       ((Some WOMk) True)
       ((Some WOVal) False)
       (None False)))
    (_ False)))

(fn wd_len ((ns (List Int))) Int
  (measure (struct ns))
  (match ns
    (Nil 0)
    ((Cons _ t) (+ 1 (wd_len t)))))

;; walk result: code docs, instr count, next local, canonical tree,
;; symbolic div-guard divisors (machine order), width-pair positions
(type WG
  (WGOk (List Doc) Int Int Expr (List Expr) (List Int))
  (WGErr (List Int)))

(fn wd_e
  ((n Int)
   (pts (List Type))
   (env (List (Pair Expr Int)))
   (nxt Int)
   (e Expr)
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef)))
  WG
  (measure (struct e))
  (match e
    ((BVar i)
     (match (env_at env i)
       ((Some (Pair ce k))
        (WGOk
          (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil)
          1
          nxt
          ce
          Nil
          Nil))
       (None
         (let ((pos (- (- n 1) (- i (env_len env)))))
           (match (ts_at pts pos)
             (None (WGErr "param index out of range"))
             ((Some t)
              (if (is_u32_ty t)
                (WGOk
                  (Cons (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")")) Nil)
                  1
                  nxt
                  (wd_c1 (quote u32) (FVar (xsym pos)))
                  Nil
                  (Cons pos Nil))
                (WGOk
                  (Cons (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")")) Nil)
                  1
                  nxt
                  (FVar (xsym pos))
                  Nil
                  Nil))))))))
    ((IntLit k)
     (if (le 0 k)
       (if (lt k 4294967296)
         (WGOk
           (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil)
           1
           nxt
           e
           Nil
           Nil)
         (WGErr "literal outside [0, 2^32)"))
       (WGErr "literal outside [0, 2^32)")))
    ((Call q as)
     (match (wd_op q)
       ((Some WOXor)
        (match as
          ((Cons a (Cons b Nil))
           (match (wd_e n pts env nxt a tbl fns)
             ((WGErr m) (WGErr m))
             ((WGOk ia ca nxa cea ga na)
              (if (wd_is32 cea)
                (match (wd_e n pts env nxa b tbl fns)
                  ((WGErr m) (WGErr m))
                  ((WGOk ib cb nxb ceb gb nb)
                   (if (wd_is32 ceb)
                     (WGOk
                       (dapp ia (dapp ib (Cons (DStr "(I32Bin BXor)") Nil)))
                       (+ ca (+ cb 1))
                       nxb
                       (Call q (Cons cea (Cons ceb Nil)))
                       (dapp_e ga gb)
                       (append_int na nb))
                     (WGErr "u32_xor operand is not word-typed"))))
                (WGErr "u32_xor operand is not word-typed")))))
          (_ (WGErr "u32_xor must be binary"))))
       ((Some WOShl)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (if (wd_shl_ok k)
             (match (wd_e n pts env nxt a tbl fns)
               ((WGErr m) (WGErr m))
               ((WGOk ia ca nxa cea ga na)
                (if (wd_is32 cea)
                  (WGOk
                    (Cons
                      (dcat3 (DStr "(I32Const ") (dint (wd_p2 k)) (DStr ")"))
                      (dapp ia (Cons (DStr "(I32Bin BMul)") Nil)))
                    (+ ca 2)
                    nxa
                    (Call q (Cons cea (Cons (IntLit k) Nil)))
                    ga
                    na)
                  (WGErr "u32_shl operand is not word-typed"))))
             (WGErr
               "u32_shl count has no std/bits bridge (grow shlK_mul + wd_shl_ok)")))
          (_ (WGErr "u32_shl needs a literal count"))))
       ((Some WOShr)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (if (wd_shr_ok k)
             (match (wd_e n pts env nxt a tbl fns)
               ((WGErr m) (WGErr m))
               ((WGOk ia ca nxa cea ga na)
                (if (wd_is32 cea)
                  (WGOk
                    (dapp
                      ia
                      (Cons
                        (dcat3 (DStr "(I32Const ") (dint (wd_p2 k)) (DStr ")"))
                        (Cons (DStr "(I32Bin BDivU)") Nil)))
                    (+ ca 2)
                    nxa
                    (Call q (Cons cea (Cons (IntLit k) Nil)))
                    ga
                    na)
                  (WGErr "u32_shr operand is not word-typed"))))
             (WGErr
               "u32_shr count has no std/bits bridge (grow shrK_div + wd_shr_ok)")))
          (_ (WGErr "u32_shr needs a literal count"))))
       ((Some WOMk)
        (match as
          ((Cons x Nil)
           (match x
             ((BVar i)
              (match (env_at env i)
                ((Some _)
                 (WGErr
                   "u32 maker over a let-bound value is not in the fragment yet"))
                (None
                  (let ((pos (- (- n 1) (- i (env_len env)))))
                    (match (ts_at pts pos)
                      (None (WGErr "param index out of range"))
                      ((Some t)
                       (if (is_u32_ty t) (WGErr "u32 maker over a word value")
                       (WGOk
                         (Cons
                           (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")"))
                           Nil)
                         1
                         nxt
                         (wd_c1 (quote u32) (FVar (xsym pos)))
                         Nil
                         (Cons pos Nil)))))))))
             ((IntLit k)
              (if (le 0 k)
                (if (lt k 4294967296)
                  (WGOk
                    (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil)
                    1
                    nxt
                    (wd_c1 (quote u32) (IntLit k))
                    Nil
                    Nil)
                  (WGErr "u32 maker literal outside [0, 2^32)"))
                (WGErr "u32 maker literal outside [0, 2^32)")))
             (_
               (WGErr
                 "u32 maker over a computed value is not in the fragment yet"))))
          (_ (WGErr "u32 maker must be unary"))))
       ((Some WOVal)
        (match as
          ((Cons x Nil)
           (match (wd_e n pts env nxt x tbl fns)
             ((WGErr m) (WGErr m))
             ((WGOk ia ca nxa cea ga na)
              (if (wd_is32 cea) (WGOk ia ca nxa (Call q (Cons cea Nil)) ga na)
              (WGErr "u32_val over a non-word value")))))
          (_ (WGErr "u32_val must be unary"))))
       (None
         (match (dop_of q)
           (None
             (match (wd_tbl_idx tbl (qn_name q))
               (None
                 (WGErr
                   "call outside the WORD fragment (u32 ops + ediv/mod + same-file word fns)"))
               ((Some cidx)
                (match as
                  ((Cons a Nil)
                   (match (wd_e n pts env nxt a tbl fns)
                     ((WGErr m) (WGErr m))
                     ((WGOk ia ca nxa cea ga na)
                      (if (wd_is32 cea)
                        (match (wd_find_fd fns (qn_name q))
                          (None (WGErr "same-file callee not found"))
                          ((Some cf)
                           (match cf
                             ((FnDef _ cts _ cbody)
                              (match
                                (wd_e
                                  (count_ts cts)
                                  cts
                                  (Cons (Pair cea 0) Nil)
                                  9
                                  cbody
                                  tbl
                                  fns)
                                ((WGErr m) (WGErr m))
                                ((WGOk _ cc _ ctree cg cn)
                                 (WGOk
                                   (dapp
                                     ia
                                     (Cons
                                       (dcat3
                                         (DStr "(Call ")
                                         (dint cidx)
                                         (DStr ")"))
                                       Nil))
                                   (+ ca (+ cc 3))
                                   nxa
                                   ctree
                                   (dapp_e ga cg)
                                   (append_int na cn))))))))
                        (WGErr "call argument is not word-typed")))))
                  (_ (WGErr "same-file calls take exactly one argument"))))))
           ((Some opd)
            (match as
              ((Cons a (Cons b Nil))
               (match (wd_e n pts env nxt a tbl fns)
                 ((WGErr m) (WGErr m))
                 ((WGOk ia ca nxa cea ga na)
                  (if (wd_is32 cea)
                    (WGErr "ediv/mod over a word value (project with u32_val)")
                    (match b
                      ((IntLit dk)
                       (if (int_eq dk 0) (WGErr "division by a zero literal")
                       (if (le 0 dk)
                         (if (lt dk 4294967296)
                           (WGOk
                             (dapp
                               ia
                               (Cons
                                 (dcat3
                                   (DStr "(I32Const ")
                                   (dint dk)
                                   (DStr ")"))
                                 (Cons
                                   (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                   Nil)))
                             (+ ca 2)
                             nxa
                             (Call q (Cons cea (Cons (IntLit dk) Nil)))
                             ga
                             na)
                           (WGErr "literal outside [0, 2^32)"))
                         (WGErr "literal outside [0, 2^32)"))))
                      ((BVar i)
                       (match (env_at env i)
                         ((Some _)
                          (WGErr
                            "ediv/mod divisor must be an Int param or literal"))
                         (None
                           (let ((pos (- (- n 1) (- i (env_len env)))))
                             (match (ts_at pts pos)
                               (None (WGErr "param index out of range"))
                               ((Some t)
                                (if (is_u32_ty t)
                                  (WGErr
                                    "ediv/mod divisor must be an Int param or literal")
                                  (WGOk
                                    (dapp
                                      ia
                                      (Cons
                                        (dcat3
                                          (DStr "(LocalGet ")
                                          (dint pos)
                                          (DStr ")"))
                                        (Cons
                                          (dcat3
                                            (DStr "(I32Bin ")
                                            opd
                                            (DStr ")"))
                                          Nil)))
                                    (+ ca 2)
                                    nxa
                                    (Call
                                      q
                                      (Cons cea (Cons (FVar (xsym pos)) Nil)))
                                    (dapp_e ga (Cons (FVar (xsym pos)) Nil))
                                    na))))))))
                      (_
                        (WGErr
                          "ediv/mod divisor must be an Int param or literal")))))))
              (_ (WGErr "ediv/mod must be binary"))))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (wd_e n pts env nxt rhs tbl fns)
          ((WGErr m) (WGErr m))
          ((WGOk ir cr nxr cer gr nr)
           (match (wd_e n pts (Cons (Pair cer nxr) env) (+ nxr 1) body tbl fns)
             ((WGErr m) (WGErr m))
             ((WGOk ib cb nxb ceb gb nb)
              (WGOk
                (dapp
                  ir
                  (Cons (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")")) ib))
                (+ cr (+ cb 1))
                nxb
                ceb
                (dapp_e gr gb)
                (append_int nr nb)))))))
       (_ (WGErr "let must bind exactly one name (split into nested lets)"))))
    (_
      (WGErr "body outside the WORD fragment (straight-line/let over u32 ops)"))))

;; U32-typed canonical node? (params ride as (u32 xN): maker head = marker)


;; ---- machine spelling of a canonical word tree ---------------------------------

(fn wd_m ((e Expr)) Expr
  (measure (struct e))
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOXor)
        (match as
          ((Cons a (Cons b Nil)) (wd_c2 (quote bxor) (wd_m a) (wd_m b)))
          (_ e)))
       ((Some WOShl)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (wd_c2
             (quote mod)
             (wd_c2 (quote *) (IntLit (wd_p2 k)) (wd_m a))
             (IntLit 4294967296)))
          (_ e)))
       ((Some WOShr)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (wd_c2 (quote ediv) (wd_m a) (IntLit (wd_p2 k))))
          (_ e)))
       ((Some WOMk)
        (match as
          ((Cons x Nil) x)
          (_ e)))
       ((Some WOVal)
        (match as
          ((Cons x Nil) (wd_m x))
          (_ e)))
       (None (Call q (wd_ms as)))))
    (_ e)))

(fn wd_ms ((as (List Expr))) (List Expr)
  (measure (struct as))
  (match as
    (Nil Nil)
    ((Cons h t) (Cons (wd_m h) (wd_ms t)))))

;; ---- node/atom collectors (preorder, dedup by word spelling) --------------------

(fn wd_ops ((e Expr) (acc (List Expr))) (List Expr)
  (measure (struct e))
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOXor)
        (wd_ops_l as (if (wd_seen (wd_spell e) acc) acc (node_add e acc))))
       ((Some WOShl)
        (wd_ops_l as (if (wd_seen (wd_spell e) acc) acc (node_add e acc))))
       ((Some WOShr)
        (wd_ops_l as (if (wd_seen (wd_spell e) acc) acc (node_add e acc))))
       ((Some WOMk) acc)
       ((Some WOVal) (wd_ops_l as acc))
       (None (wd_ops_l as acc))))
    (_ acc)))

(fn wd_ops_l ((as (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct as))
  (match as
    (Nil acc)
    ((Cons h t) (wd_ops_l t (wd_ops h acc)))))

(fn wd_atoms ((e Expr) (acc (List Expr))) (List Expr)
  (measure (struct e))
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOMk) (if (wd_seen (wd_spell e) acc) acc (node_add e acc)))
       (_ (wd_atoms_l as acc))))
    (_ acc)))

(fn wd_atoms_l ((as (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct as))
  (match as
    (Nil acc)
    ((Cons h t) (wd_atoms_l t (wd_atoms h acc)))))

;; ---- have names ----------------------------------------------------------------

(fn wd_nm ((pfx (List Int)) (j Int)) Doc (DCat (DStr pfx) (dint j)))

;; ---- bound-fact subproofs for a word operand ------------------------------------
;;
;; per operand KIND: width-pair premise rewrites (param atoms), ground
;; compute (literal makers), mod_lo/mod_hi citations (shl nodes = mod
;; spellings), or the node's own lo<j>/lt<j> haves (xor/shr nodes).

(fn wd_sub_prem ((d Doc)) Doc
  (dcat3
    (DStr "(steps ((rewrite (premise ")
    d
    (DStr ") lr lhs true ())) refl)")))

(fn wd_sub_modlo () Doc
  (DStr
    "(rewrite-with (lemma mod_lo) lr lhs () ((steps ((compute both)) refl)) refl)"))

(fn wd_sub_modhi () Doc
  (DStr
    "(rewrite-with (lemma mod_hi) lr lhs () ((steps ((compute both)) refl)) refl)"))

;; lo=True -> the lower-bound subproof, else the upper; rg = the region
;; name prefix ("" straight, "t"/"e" per if arm — P2c's region discipline)
(fn wd_bsub
  ((e Expr) (ns (List Int)) (tab (List Expr)) (lo Bool) (rg (List Int)))
  Doc
  (measure (struct e))
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOMk)
        (match as
          ((Cons (FVar s) Nil)
           (wd_sub_prem (dint (+ (* 2 (wd_rank s ns 0)) (if lo 0 1)))))
          (_ (DStr "(steps ((compute both)) refl)"))))
       ((Some WOShl) (if lo (wd_sub_modlo) (wd_sub_modhi)))
       ((Some WOXor)
        (wd_sub_prem
          (wd_nm (append_int rg (if lo "lo" "lt")) (wd_ix (wd_spell e) tab 0))))
       ((Some WOShr)
        (wd_sub_prem
          (wd_nm (append_int rg (if lo "lo" "lt")) (wd_ix (wd_spell e) tab 0))))
       ((Some WOVal)
        (match as
          ((Cons x Nil) (wd_bsub x ns tab lo rg))
          (_ (DStr "(steps ((compute both)) refl)"))))
       (None (DStr "(steps ((compute both)) refl)"))))
    (_ (DStr "(steps ((compute both)) refl)"))))

;; ---- have/apply doc builders -----------------------------------------------------

(fn wd_apply ((nm Doc)) Doc
  (dcat3 (DStr " (steps ((rewrite (premise ") nm (DStr ") lr rhs true ())))")))

;; the defining-equation OPEN have for op node j
(fn wd_open ((e Expr) (j Int) (rg (List Int))) Doc
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOXor)
        (match as
          ((Cons a (Cons b Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "o") j)
               (DStr " (= (u32_val ")
               (wd_pr e)
               (DStr ") (mod (bxor (u32_val ")
               (wd_pr a)
               (DStr ") (u32_val ")
               (wd_pr b)
               (DStr
                 ")) 4294967296)) (rewrite-with (lemma u32_xor_val) lr lhs ((inst a ")
               (wd_pr a)
               (DStr ") (inst b ")
               (wd_pr b)
               (DStr ")) () refl))"))))
          (_ (DStr ""))))
       ((Some WOShl)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "o") j)
               (DStr " (= (u32_val ")
               (wd_pr e)
               (DStr ") (mod (bshl (u32_val ")
               (wd_pr a)
               (DStr ") ")
               (dint k)
               (DStr
                 ") 4294967296)) (rewrite-with (lemma u32_shl_val) lr lhs ((inst x ")
               (wd_pr a)
               (DStr ") (inst k ")
               (dint k)
               (DStr ")) () refl))"))))
          (_ (DStr ""))))
       ((Some WOShr)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "o") j)
               (DStr " (= (u32_val ")
               (wd_pr e)
               (DStr ") (mod (bshr (u32_val ")
               (wd_pr a)
               (DStr ") ")
               (dint k)
               (DStr
                 ") 4294967296)) (rewrite-with (lemma u32_shr_val) lr lhs ((inst x ")
               (wd_pr a)
               (DStr ") (inst k ")
               (dint k)
               (DStr ")) () refl))"))))
          (_ (DStr ""))))
       (_ (DStr ""))))
    (_ (DStr ""))))

(fn wd_opens ((es (List Expr)) (tab (List Expr)) (rg (List Int))) Doc
  (measure (struct es))
  (match es
    (Nil (DStr ""))
    ((Cons h t)
     (dcat3
       (DCat
         (wd_open h (wd_ix (wd_spell h) tab 0) rg)
         (wd_apply (wd_nm (append_int rg "o") (wd_ix (wd_spell h) tab 0))))
       (wd_opens t tab rg)
       (DStr "")))))

;; the maker-atom collapse have for atom i: (u32_val (u32 X)) = X
(fn wd_atom ((e Expr) (i Int) (ns (List Int)) (rg (List Int))) Doc
  (match e
    ((Call q as)
     (match as
       ((Cons (FVar s) Nil)
        (dconc
          (list
            (DStr " (have ")
            (wd_nm (append_int rg "a") i)
            (DStr " (= (u32_val ")
            (wd_pr e)
            (DStr ") ")
            (dsym s)
            (DStr ") (chain (rewrite-with (lemma u32_val_of) lr lhs ((inst nn ")
            (dsym s)
            (DStr ")) ()) (rewrite-with (lemma wrap32_id) lr lhs ((inst x ")
            (dsym s)
            (DStr ")) (")
            (wd_sub_prem (dint (* 2 (wd_rank s ns 0))))
            (sp)
            (wd_sub_prem (dint (+ (* 2 (wd_rank s ns 0)) 1)))
            (DStr ") refl)))"))))
       ((Cons (IntLit k) Nil)
        (dconc
          (list
            (DStr " (have ")
            (wd_nm (append_int rg "a") i)
            (DStr " (= (u32_val ")
            (wd_pr e)
            (DStr ") ")
            (dint k)
            (DStr ") (chain (rewrite-with (lemma u32_val_of) lr lhs ((inst nn ")
            (dint k)
            (DStr ")) ()) (steps ((compute lhs)) refl)))"))))
       (_ (DStr ""))))
    (_ (DStr ""))))

(fn wd_atoms_doc ((es (List Expr)) (i Int) (ns (List Int)) (rg (List Int))) Doc
  (measure (struct es))
  (match es
    (Nil (DStr ""))
    ((Cons h t)
     (dcat3
       (DCat (wd_atom h i ns rg) (wd_apply (wd_nm (append_int rg "a") i)))
       (wd_atoms_doc t (+ i 1) ns rg)
       (DStr "")))))

;; the per-node bottom-up events: bridge (shl/shr), bounds pair + wrap32_id
;; collapse (xor/shr). j = the node's PREORDER-table ordinal.
(fn wd_node
  ((e Expr)
   (j Int)
   (ns (List Int))
   (tab (List Expr))
   (fnm Symbol)
   (rg (List Int)))
  Doc
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOShl)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "b") j)
               (DStr " (= (bshl ")
               (wd_pr (wd_m a))
               (DStr " ")
               (dint k)
               (DStr ") (* ")
               (dint (wd_p2 k))
               (DStr " ")
               (wd_pr (wd_m a))
               (DStr ")) (rewrite-with (lemma shl")
               (dint k)
               (DStr "_mul) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (DStr ") refl))")
               (wd_apply (wd_nm (append_int rg "b") j)))))
          (_ (DStr ""))))
       ((Some WOShr)
        (match as
          ((Cons a (Cons (IntLit k) Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "b") j)
               (DStr " (= (bshr ")
               (wd_pr (wd_m a))
               (DStr " ")
               (dint k)
               (DStr ") (ediv ")
               (wd_pr (wd_m a))
               (DStr " ")
               (dint (wd_p2 k))
               (DStr ")) (rewrite-with (lemma shr")
               (dint k)
               (DStr "_div) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (DStr ") refl))")
               (wd_apply (wd_nm (append_int rg "b") j))
               (DStr " (have ")
               (wd_nm (append_int rg "lo") j)
               (DStr " (= (le 0 ")
               (wd_pr (wd_m e))
               (DStr ") True) (rewrite-with (lemma wq_")
               (dsym fnm)
               (DStr "_")
               (dint k)
               (DStr "_lo) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (DStr ") refl))")
               (DStr " (have ")
               (wd_nm (append_int rg "lt") j)
               (DStr " (= (lt ")
               (wd_pr (wd_m e))
               (DStr " 4294967296) True) (rewrite-with (lemma wq_")
               (dsym fnm)
               (DStr "_")
               (dint k)
               (DStr "_lt32) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (sp)
               (wd_bsub a ns tab False rg)
               (DStr ") refl))")
               (DStr " (have ")
               (wd_nm (append_int rg "w") j)
               (DStr " (= (mod ")
               (wd_pr (wd_m e))
               (DStr " 4294967296) ")
               (wd_pr (wd_m e))
               (DStr ") (rewrite-with (lemma wrap32_id) lr lhs ((inst x ")
               (wd_pr (wd_m e))
               (DStr ")) (")
               (wd_sub_prem (wd_nm (append_int rg "lo") j))
               (sp)
               (wd_sub_prem (wd_nm (append_int rg "lt") j))
               (DStr ") refl))")
               (wd_apply (wd_nm (append_int rg "w") j)))))
          (_ (DStr ""))))
       ((Some WOXor)
        (match as
          ((Cons a (Cons b Nil))
           (dconc
             (list
               (DStr " (have ")
               (wd_nm (append_int rg "lo") j)
               (DStr " (= (le 0 ")
               (wd_pr (wd_m e))
               (DStr ") True) (rewrite-with (lemma bxor_lo) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ") (inst b ")
               (wd_pr (wd_m b))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (sp)
               (wd_bsub b ns tab True rg)
               (DStr ") refl))")
               (DStr " (have ")
               (wd_nm (append_int rg "lt") j)
               (DStr " (= (lt ")
               (wd_pr (wd_m e))
               (DStr
                 " 4294967296) True) (rewrite-with (lemma bxor_lt32) lr lhs ((inst a ")
               (wd_pr (wd_m a))
               (DStr ") (inst b ")
               (wd_pr (wd_m b))
               (DStr ")) (")
               (wd_bsub a ns tab True rg)
               (sp)
               (wd_bsub a ns tab False rg)
               (sp)
               (wd_bsub b ns tab True rg)
               (sp)
               (wd_bsub b ns tab False rg)
               (DStr ") refl))")
               (DStr " (have ")
               (wd_nm (append_int rg "w") j)
               (DStr " (= (mod ")
               (wd_pr (wd_m e))
               (DStr " 4294967296) ")
               (wd_pr (wd_m e))
               (DStr ") (rewrite-with (lemma wrap32_id) lr lhs ((inst x ")
               (wd_pr (wd_m e))
               (DStr ")) (")
               (wd_sub_prem (wd_nm (append_int rg "lo") j))
               (sp)
               (wd_sub_prem (wd_nm (append_int rg "lt") j))
               (DStr ") refl))")
               (wd_apply (wd_nm (append_int rg "w") j)))))
          (_ (DStr ""))))
       (_ (DStr ""))))
    (_ (DStr ""))))

;; ---- postorder node collection (children before parents, dedup FIRST
;; occurrence; reversed-preorder is NOT enough under sharing) -----------------------

(fn wd_post ((e Expr) (acc (List Expr))) (List Expr)
  (measure (struct e))
  (match e
    ((Call q as)
     (match (wd_op q)
       ((Some WOXor)
        (let ((acc2 (wd_post_l as acc)))
          (if (wd_seen (wd_spell e) acc2) acc2 (node_add e acc2))))
       ((Some WOShl)
        (let ((acc2 (wd_post_l as acc)))
          (if (wd_seen (wd_spell e) acc2) acc2 (node_add e acc2))))
       ((Some WOShr)
        (let ((acc2 (wd_post_l as acc)))
          (if (wd_seen (wd_spell e) acc2) acc2 (node_add e acc2))))
       ((Some WOMk) acc)
       ((Some WOVal) (wd_post_l as acc))
       (None (wd_post_l as acc))))
    (_ acc)))

(fn wd_post_l ((as (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct as))
  (match as
    (Nil acc)
    ((Cons h t) (wd_post_l t (wd_post h acc)))))

(fn wd_revl ((es (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct es))
  (match es
    (Nil acc)
    ((Cons h t) (wd_revl t (Cons h acc)))))

;; per-node events in postorder; names keyed by the PREORDER table
(fn wd_nodes_post
  ((es (List Expr))
   (ns (List Int))
   (tab (List Expr))
   (fnm Symbol)
   (rg (List Int)))
  Doc
  (measure (struct es))
  (match es
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (wd_node h (wd_ix (wd_spell h) tab 0) ns tab fnm rg)
       (wd_nodes_post t ns tab fnm rg)))))

;; THE CASCADE over one region's tree: opens in REVERSED POSTORDER (every
;; projection user before the node), atom collapses, node events in true
;; postorder. rg prefixes the region's have names.
(fn wd_casc ((tree Expr) (ns (List Int)) (fnm Symbol) (rg (List Int))) Doc
  (let ((tab (wd_ops tree Nil)))
    (dcat3
      (wd_opens (wd_revl (wd_post tree Nil) Nil) tab rg)
      (wd_atoms_doc (wd_atoms tree Nil) 0 ns rg)
      (wd_nodes_post (wd_post tree Nil) ns tab fnm rg))))

;; ---- the wq quotient-bound helper claims (one pair per shr width) ---------------

(fn wd_widths ((es (List Expr)) (acc (List Int))) (List Int)
  (measure (struct es))
  (match es
    (Nil acc)
    ((Cons h t)
     (match h
       ((Call q as)
        (match (wd_op q)
          ((Some WOShr)
           (match as
             ((Cons _ (Cons (IntLit k) Nil)) (wd_widths t (wd_ins k acc)))
             (_ (wd_widths t acc))))
          (_ (wd_widths t acc))))
       (_ (wd_widths t acc))))))

(fn wd_wq_claims ((ws (List Int)) (fnm Symbol)) Doc
  (measure (struct ws))
  (match ws
    (Nil (DStr ""))
    ((Cons k t)
     (dcat3
       (dconc
         (list
           (DStr "(claim wq_")
           (dsym fnm)
           (DStr "_")
           (dint k)
           (DStr "_lo (goal ((a Int)) ((= (le 0 a) True)) (= (le 0 (ediv a ")
           (dint (wd_p2 k))
           (DStr ")) True)) (div-facts a ")
           (dint (wd_p2 k))
           (DStr " q (by arith (list ")
           (dint (wd_p2 k))
           (DStr " 1 -1 0 1 ")
           (dint (wd_p2 k))
           (DStr "))))")
           (DStr (nl))
           (DStr "(claim wq_")
           (dsym fnm)
           (DStr "_")
           (dint k)
           (DStr
             "_lt32 (goal ((a Int)) ((= (le 0 a) True) (= (lt a 4294967296) True)) (= (lt (ediv a ")
           (dint (wd_p2 k))
           (DStr ") 4294967296) True)) (div-facts a ")
           (dint (wd_p2 k))
           (DStr " q (by arith (list ")
           (dint (wd_p2 k))
           (DStr " 0 1 1 1 0 -")
           (dint (wd_p2 k))
           (DStr "))))")
           (DStr (nl))))
       (wd_wq_claims t fnm)
       (DStr "")))))

;; ---- premise / spec-arg rendering ------------------------------------------------

(fn wd_prems ((ns (List Int))) Doc
  (measure (struct ns))
  (match ns
    (Nil (DStr ""))
    ((Cons p t)
     (dconc
       (list
         (DStr "(= (le 0 x")
         (dint p)
         (DStr ") True) (= (lt x")
         (dint p)
         (DStr " 4294967296) True) ")
         (wd_prems t))))))

(fn wd_gprems ((gs (List Expr))) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons g t)
     (dconc (list (DStr "(= (le 1 ") (wd_pr g) (DStr ") True) ") (wd_gprems t))))))

;; guard discharge stages: rewrite the guard premise into the stuck if,
;; resume compute (§6y; the word walk has no wrap events to flush)
(fn wd_gstages ((gs (List Expr)) (gi Int)) Doc
  (measure (struct gs))
  (match gs
    (Nil (DStr ""))
    ((Cons _ t)
     (dcat3
       (dcat3
         (DStr " (steps ((rewrite (premise ")
         (dint gi)
         (DStr ") lr lhs true ()) (compute lhs)))"))
       (wd_gstages t (+ gi 1))
       (DStr "")))))

;; spec-side call args: (u32 xN) for U32 params, xN for Int params
(fn wd_args ((ts (List Type)) (i Int)) Doc
  (measure (struct ts))
  (match ts
    (Nil (DStr ""))
    ((Cons t rest)
     (dcat3
       (if (is_u32_ty t) (dcat3 (DStr " (u32 x") (dint i) (DStr ")"))
       (dcat3 (DStr " x") (dint i) (DStr "")))
       (wd_args rest (+ i 1))
       (DStr "")))))

(fn wd_all_ok ((ts (List Type))) Bool
  (measure (struct ts))
  (match ts
    (Nil True)
    ((Cons t rest)
     (if (is_u32_ty t) (wd_all_ok rest)
     (if (is_int_ty t) (wd_all_ok rest)
     False)))))

;; ---- same-file call support: table/fn lookup, transitive callee scan ------------

(fn wd_tbl_idx ((tbl (List (Pair Symbol Int))) (s Symbol)) (Option Int)
  (measure (struct tbl))
  (match tbl
    (Nil None)
    ((Cons (Pair n k) rest) (if (sym_eq s n) (Some k) (wd_tbl_idx rest s)))))

(fn wd_find_fd ((fns (List FnDef)) (s Symbol)) (Option FnDef)
  (measure (struct fns))
  (match fns
    (Nil None)
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (if (sym_eq (qn_name q) s) (Some f) (wd_find_fd rest s)))))))

(fn wd_symin ((x Symbol) (xs (List Symbol))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (sym_eq x h) True (wd_symin x t)))))

;; the called same-file fns reachable from a body (callee bodies included:
;; the spec-side unfolds need every name whose body the residue opens)
(fn wd_callees
  ((e Expr)
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef))
   (fuel Int)
   (acc (List Symbol)))
  (List Symbol)
  (measure fuel)
  (if (le fuel 0) acc
  (match e
    ((Call q as)
     (let ((acc2 (wd_callees_l as tbl fns (- fuel 1) acc)))
       (match (wd_tbl_idx tbl (qn_name q))
         (None acc2)
         ((Some _)
          (if (wd_symin (qn_name q) acc2) acc2
          (match (wd_find_fd fns (qn_name q))
            (None acc2)
            ((Some cf)
             (match cf
               ((FnDef _ _ _ cbody)
                (wd_callees cbody tbl fns (- fuel 1) (Cons (qn_name q) acc2)))))))))))
    ((Let bs body)
     (wd_callees
       body
       tbl
       fns
       (- fuel 1)
       (wd_callees_l bs tbl fns (- fuel 1) acc)))
    ((If c a b)
     (wd_callees
       c
       tbl
       fns
       (- fuel 1)
       (wd_callees a tbl fns (- fuel 1) (wd_callees b tbl fns (- fuel 1) acc))))
    (_ acc))))

(fn wd_callees_l
  ((as (List Expr))
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef))
   (fuel Int)
   (acc (List Symbol)))
  (List Symbol)
  (measure fuel)
  (if (le fuel 0) acc
  (match as
    (Nil acc)
    ((Cons h t)
     (wd_callees_l t tbl fns (- fuel 1) (wd_callees h tbl fns (- fuel 1) acc))))))

(fn wd_unfolds ((ss (List Symbol))) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons s t)
     (dcat3
       (dcat3 (DStr " (unfold ") (dsym s) (DStr " rhs) (reduce rhs)"))
       (wd_unfolds t)
       (DStr "")))))

;; ---- the tail walk: lets, ONE tail if (the P2c diamond), straight bodies --------

(type WTR (WTStraight Expr) (WTIf Expr Expr Expr))

(type WT
  (WTOk (List Doc) Int Int WTR (List Expr) (List Int))
  (WTErr (List Int)))

;; the condition walk: (int_eq A B) over Int-typed word-free sides
(fn wd_cond
  ((n Int)
   (pts (List Type))
   (env (List (Pair Expr Int)))
   (nxt Int)
   (e Expr)
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef)))
  WG
  (match e
    ((Call q as)
     (if (core_named q (quote int_eq))
       (match as
         ((Cons a (Cons b Nil))
          (match (wd_e n pts env nxt a tbl fns)
            ((WGErr m) (WGErr m))
            ((WGOk ia ca nxa cea ga na)
             (if (wd_is32 cea)
               (WGErr "if condition side is word-typed (project with u32_val)")
               (match (wd_e n pts env nxa b tbl fns)
                 ((WGErr m) (WGErr m))
                 ((WGOk ib cb nxb ceb gb nb)
                  (if (wd_is32 ceb)
                    (WGErr
                      "if condition side is word-typed (project with u32_val)")
                    (WGOk
                      (dapp ia (dapp ib (Cons (DStr "(I32Bin BEq)") Nil)))
                      (+ ca (+ cb 1))
                      nxb
                      (Call q (Cons cea (Cons ceb Nil)))
                      (dapp_e ga gb)
                      (append_int na nb)))))))))
         (_ (WGErr "if condition must be binary int_eq")))
       (WGErr "if condition outside the word fragment (int_eq only)")))
    (_ (WGErr "if condition outside the word fragment (int_eq only)"))))

(fn wd_t
  ((n Int)
   (pts (List Type))
   (env (List (Pair Expr Int)))
   (nxt Int)
   (e Expr)
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef)))
  WT
  (measure (struct e))
  (match e
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (wd_e n pts env nxt rhs tbl fns)
          ((WGErr m) (WTErr m))
          ((WGOk ir cr nxr cer gr nr)
           (match (wd_t n pts (Cons (Pair cer nxr) env) (+ nxr 1) body tbl fns)
             ((WTErr m) (WTErr m))
             ((WTOk ib cb nxb rb gb nb)
              (WTOk
                (dapp
                  ir
                  (Cons (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")")) ib))
                (+ cr (+ cb 1))
                nxb
                rb
                (dapp_e gr gb)
                (append_int nr nb)))))))
       (_ (WTErr "let must bind exactly one name (split into nested lets)"))))
    ((If c a b)
     (match (wd_cond n pts env nxt c tbl fns)
       ((WGErr m) (WTErr m))
       ((WGOk ic cc nxc cec gc nc)
        (match (wd_e n pts env nxc a tbl fns)
          ((WGErr m) (WTErr m))
          ((WGOk it ct nxt2 cet gt nt)
           (match (wd_e n pts env nxt2 b tbl fns)
             ((WGErr m) (WTErr m))
             ((WGOk ie ce2 nxe cee ge ne)
              (if (dconc_nil gc)
                (if (dconc_nil gt)
                  (if (dconc_nil ge)
                    (WTOk
                      (Cons
                        (dconc
                          (list
                            (DStr "(Block (list (Block (list ")
                            (djoin ic)
                            (DStr " (BrIf 0) ")
                            (djoin ie)
                            (DStr " (LocalSet ")
                            (dint nxe)
                            (DStr ") (Br 1))) ")
                            (djoin it)
                            (DStr " (LocalSet ")
                            (dint nxe)
                            (DStr ")))")))
                        (Cons
                          (dcat3 (DStr "(LocalGet ") (dint nxe) (DStr ")"))
                          Nil))
                      (+ cc (+ ct (+ ce2 7)))
                      (+ nxe 1)
                      (WTIf cec cet cee)
                      Nil
                      (append_int nc (append_int nt ne)))
                    (WTErr
                      "ediv/mod under an if is not in the word fragment yet"))
                  (WTErr "ediv/mod under an if is not in the word fragment yet"))
                (WTErr "ediv/mod under an if is not in the word fragment yet")))))))))
    (_
      (match (wd_e n pts env nxt e tbl fns)
        ((WGErr m) (WTErr m))
        ((WGOk ia ca nxa cea ga na) (WTOk ia ca nxa (WTStraight cea) ga na))))))

(fn dconc_nil ((gs (List Expr))) Bool
  (match gs
    (Nil True)
    ((Cons _ _) False)))


;; ---- the literal call-prefix spine (the §6ac structural precedent) --------------
;;
;; A word fn WITH same-file calls cannot ride the quantified Func-binder
;; prefix — the machine computes THROUGH the Call, so the callee slots
;; must be pinned literals. In lib mode the whole file regenerates
;; together, so the structural pin costs nothing. Call-free fns keep the
;; position-general binder form.

(fn wd_revp ((xs (List (Pair Symbol Int))) (acc (List (Pair Symbol Int))))
  (List (Pair Symbol Int))
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (wd_revp t (Cons h acc)))))

(fn wd_spine_l
  ((entries (List (Pair Symbol Int)))
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef)))
  (Option Doc)
  (measure (struct entries))
  (match entries
    (Nil (Some (DStr "")))
    ((Cons (Pair nm _) rest)
     (match (wd_find_fd fns nm)
       (None None)
       ((Some f)
        (match (lib_flit f tbl fns)
          (None None)
          ((Some flit)
           (match (wd_spine_l rest tbl fns)
             (None None)
             ((Some d) (Some (DCat (dcat3 (DStr "(Cons ") flit (sp)) d)))))))))))

;; (goal-binder doc, module-prefix doc) per shape: binders when call-free,
;; the pinned literal spine when the body calls
(fn wd_spinep
  ((cls (List Symbol))
   (pfx Int)
   (tbl (List (Pair Symbol Int)))
   (fns (List FnDef)))
  (Option (Pair Doc Doc))
  (match cls
    (Nil (Some (Pair (pr_fbinds pfx) (pr_fcons pfx))))
    ((Cons _ _)
     (match (wd_spine_l (wd_revp tbl Nil) tbl fns)
       (None None)
       ((Some d) (Some (Pair (DStr "") d)))))))

;; ---- the WORD claim ---------------------------------------------------------------

;; one if arm's proof chain: collapse the condition (the case hyp), run
;; the machine arm, cascade the arm's word tree, converge
(fn wd_arm
  ((hy (List Int)) (tree Expr) (ns (List Int)) (fnm Symbol) (rg (List Int)))
  Doc
  (dconc
    (list
      (DStr " (case ")
      (DStr hy)
      (DStr " (chain (steps ((rewrite (hyp ")
      (DStr hy)
      (DStr ") lr both true ()) (compute both)))")
      (wd_casc tree ns fnm rg)
      (DStr " (steps ((compute both))) refl))"))))

(fn emit_claim_word
  ((f FnDef) (pfx Int) (tbl (List (Pair Symbol Int))) (fns (List FnDef)))
  CRes
  (match f
    ((FnDef q ts rty body)
     (if (wd_all_ok ts)
       (if (if (is_int_ty rty) True (is_u32_ty rty))
         (match (wd_t (count_ts ts) ts Nil (count_ts ts) body tbl fns)
           ((WTErr m)
            (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
           ((WTOk code cnt nxt res guards needs0)
            (let ((needs (wd_norm needs0 Nil)))
              (match (wd_spinep (wd_callees body tbl fns 99 Nil) pfx tbl fns)
                (None
                  (CErr
                    (append_int
                      (chars_of_sym (qn_name q))
                      ": call-prefix literal generation failed")))
                ((Some (Pair fbd fcd))
                 (COk
                   (DCat
                     (wd_wq_claims (wd_res_widths res) (qn_name q))
                     (dconc
                       (list
                         (DStr "(claim lowered_")
                         (dsym (qn_name q))
                         (DStr " (goal (")
                         (pr_binds ts 0)
                         fbd
                         (DStr "(c Nat) (restfs (List Func))) (")
                         (wd_prems needs)
                         (wd_gprems guards)
                         (DStr ") (= (call_fn (S^ ")
                         (dint (+ (* 2 cnt) 3))
                         (DStr " c) (MkWModule ")
                         fcd
                         (DStr "(Cons (MkFunc ")
                         (dint (count_ts ts))
                         (sp)
                         (dint (- nxt (count_ts ts)))
                         (DStr " (list ")
                         (djoin code)
                         (DStr ")) restfs)")
                         (pr_rpars pfx)
                         (DStr " 0) ")
                         (dint pfx)
                         (DStr " (list ")
                         (pr_args ts 0)
                         (DStr "))")
                         (if (is_u32_ty rty)
                           (dconc
                             (list
                               (DStr " (Some (u32_val (")
                               (dsym (qn_name q))
                               (wd_args ts 0)
                               (DStr ")))))")))
                           (dconc
                             (list
                               (DStr " (Some (")
                               (dsym (qn_name q))
                               (wd_args ts 0)
                               (DStr "))))"))))
                         (DStr " (chain (steps ((compute lhs) (unfold ")
                         (dsym (qn_name q))
                         (DStr " rhs) (reduce rhs)")
                         (wd_unfolds (wd_callees body tbl fns 99 Nil))
                         (DStr "))")
                         (match res
                           ((WTStraight tree)
                            (dconc
                              (list
                                (wd_gstages guards (* 2 (wd_len needs)))
                                (wd_casc tree needs (qn_name q) "")
                                (DStr " refl"))))
                           ((WTIf ct tt et)
                            (dconc
                              (list
                                (wd_atoms_doc (wd_atoms ct Nil) 0 needs "c")
                                (DStr " (case-on ")
                                (wd_pr (wd_m ct))
                                (DStr " Bool (")
                                (wd_arm "True" tt needs (qn_name q) "t")
                                (wd_arm "False" et needs (qn_name q) "e")
                                (DStr "))")))))
                         (DStr "))")
                         (DStr (nl)))))
                   (DStr "")))))))
         (CErr
           (append_int
             (chars_of_sym (qn_name q))
             ": return type is not Int/U32")))
       (CErr
         (append_int (chars_of_sym (qn_name q)) ": params are not all Int/U32"))))))

;; wq widths across the result's region trees
(fn wd_res_widths ((res WTR)) (List Int)
  (match res
    ((WTStraight tree) (wd_widths (wd_ops tree Nil) Nil))
    ((WTIf _ tt et) (wd_widths (wd_ops tt Nil) (wd_widths (wd_ops et Nil) Nil)))))


(fn emit_claim_div ((q QName) (ts (List Type)) (body Expr) (pfx Int)) CRes
  (if (dv_has_if body)
    (CErr
      (append_int
        (chars_of_sym (qn_name q))
        ": ediv/mod with if is not in the fragment yet (straight-line/let bodies only)"))
    (match (gen_e (count_ts ts) Nil (count_ts ts) body)
      ((GErr m)
       (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
      ((GOk code cnt nxt _ evs)
       (match (dv_lay evs (DStr "") Nil Nil 0)
         ((MkDLay prems wa ga _)
          (COk
            (dcat3
              (dcat3
                (dcat3
                  (DStr "(claim lowered_")
                  (dsym (qn_name q))
                  (dcat3
                    (DStr " (goal (")
                    (pr_binds ts 0)
                    (DCat
                      (pr_fbinds pfx)
                      (DStr "(c Nat) (restfs (List Func))) ("))))
                prems
                (dcat3
                  (dcat3
                    (DStr ") (= (call_fn (S^ ")
                    (dint (+ (* 2 cnt) 3))
                    (DCat
                      (DStr " c) (MkWModule ")
                      (DCat (pr_fcons pfx) (DStr "(Cons (MkFunc "))))
                  (dint (count_ts ts))
                  (dcat3
                    (dcat3
                      (DCat (sp) (dint (- nxt (count_ts ts))))
                      (DStr " (list ")
                      (djoin code))
                    (dconc
                      (list
                        (DStr ")) restfs)")
                        (pr_rpars pfx)
                        (DStr " 0) ")
                        (dint pfx)
                        (DStr " (list ")))
                    (DStr ""))))
              (dcat3
                (pr_args ts 0)
                (dcat3 (DStr ")) (Some (") (dsym (qn_name q)) (DStr ""))
                (dcat3
                  (pr_args_lead ts)
                  (DStr "))))")
                  (dcat3
                    (dcat3
                      (DStr " (chain (steps ((compute lhs) (unfold ")
                      (dsym (qn_name q))
                      (DStr " rhs) (reduce rhs))) "))
                    (dv_pf evs Nil wa ga 0)
                    (DStr "))"))))
              (DStr (nl)))
            (DStr ""))))))))

(fn emit_claim_pure ((f FnDef) (pfx Int)) CRes
  (match f
    ((FnDef q ts rty body)
     (if (word_sig ts rty) (emit_claim_word f pfx Nil Nil)
     (if (all_int ts)
       (if (is_int_ty rty)
         (if (has_div body) (emit_claim_div q ts body pfx)
         (match (gen_t (count_ts ts) Nil (count_ts ts) body)
           ((TErr m)
            (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
           ((TOk rt)
            (match (pw_region rt Nil Nil (dsym (qn_name q)) (wk32) 0 0 0)
              ((MkPWR proof_body prems helpers _ _ _)
               (COk
                 (DCat
                   helpers
                   (dcat3
                     (dcat3
                       (dcat3
                         (DStr "(claim lowered_")
                         (dsym (qn_name q))
                         (dcat3
                           (DStr " (goal (")
                           (pr_binds ts 0)
                           (DCat
                             (pr_fbinds pfx)
                             (DStr "(c Nat) (restfs (List Func))) ("))))
                       prems
                       (dcat3
                         (dcat3
                           (DStr ") (= (call_fn (S^ ")
                           (dint (+ (* 2 (rt_count rt)) 3))
                           (DCat
                             (DStr " c) (MkWModule ")
                             (DCat (pr_fcons pfx) (DStr "(Cons (MkFunc "))))
                         (dint (count_ts ts))
                         (dcat3
                           (dcat3
                             (DCat (sp) (dint (- (rt_nxt rt) (count_ts ts))))
                             (DStr " (list ")
                             (djoin (rt_code rt)))
                           (dconc
                             (list
                               (DStr ")) restfs)")
                               (pr_rpars pfx)
                               (DStr " 0) ")
                               (dint pfx)
                               (DStr " (list ")))
                           (DStr ""))))
                     (dcat3
                       (pr_args ts 0)
                       (dcat3 (DStr ")) (Some (") (dsym (qn_name q)) (DStr ""))
                       (dcat3
                         (pr_args_lead ts)
                         (DStr "))))")
                         (dcat3
                           (dcat3
                             (DStr " (chain (steps ((compute lhs) (unfold ")
                             (dsym (qn_name q))
                             (DStr " rhs) (reduce rhs))) "))
                           proof_body
                           (DStr "))"))))
                     (DStr (nl))))
                 (DStr "")))))))
         (CErr
           (append_int (chars_of_sym (qn_name q)) ": return type is not Int")))
       (CErr (append_int (chars_of_sym (qn_name q)) ": params are not all Int")))))))


;; ---- module walk -------------------------------------------------------------

(type ERes (EOk Doc Doc Bool Bool Bool) (EErr (List Int)))

(fn emit_fns
  ((fns (List FnDef))
   (modpath (List Symbol))
   (accp Doc)
   (accl Doc)
   (memf Bool)
   (loopf Bool)
   (callf Bool)
   (reg (List CInfo)))
  ERes
  (measure (struct fns))
  (match fns
    (Nil (EOk accp accl memf loopf callf))
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (match q
          ((QName mp _)
           (if (sym_list_eq mp modpath)
             (match (emit_claim f reg)
               ((CErr m) (EErr m))
               ((COkM dp dl cio)
                (emit_fns
                  rest
                  modpath
                  (DCat accp (DCat (DStr (nl)) dp))
                  (DCat accl (DCat (DStr (nl)) dl))
                  True
                  loopf
                  callf
                  (match cio
                    ((Some ci) (reg_add reg ci))
                    (None reg))))
               ((COkC dl)
                (emit_fns
                  rest
                  modpath
                  accp
                  (DCat accl (DCat (DStr (nl)) dl))
                  memf
                  loopf
                  True
                  reg))
               ((COk dp dl)
                (emit_fns
                  rest
                  modpath
                  (DCat accp (DCat (DStr (nl)) dp))
                  accl
                  memf
                  (if loopf True (fn_is_loop f))
                  callf
                  reg)))
             (emit_fns rest modpath accp accl memf loopf callf reg)))))))))


;; ---- lib mode (the lib-build arc) ----------------------------------------------
;; With a (lib …) declaration in the source file, the WHOLE file lays out as
;; ONE module: every fn at its source-order index, certs in the position-
;; general leaf form (pfx = the index; models/wasm/probes/libmod_probe.shard), and the
;; OUT file additionally ships the CLOSED module value (LIBNAME_wmod) and
;; the named-export table (LIBNAME_exports) for the build entry — the
;; declaration's exports baked BY NAME, internal fns present but
;; unexported. v1 fragment: pure Int fns (straight-line/let/div); mem, loop
;; and call fns refuse loudly.

;; a Func literal, spelled exactly as the claim spells it (same generator,
;; same inputs — the byte tie holds both to the shipped bytes anyway)
(fn flit_doc ((np Int) (extra Int) (code (List Doc))) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint np)
      (sp)
      (dint extra)
      (DStr " (list ")
      (djoin code)
      (DStr "))"))))

(fn lib_flit ((f FnDef) (tbl (List (Pair Symbol Int))) (fns (List FnDef)))
  (Option Doc)
  (match f
    ((FnDef q ts rty body)
     (if (word_sig ts rty)
       (match (wd_t (count_ts ts) ts Nil (count_ts ts) body tbl fns)
         ((WTErr _) None)
         ((WTOk code cnt nxt _ _ _)
          (Some (flit_doc (count_ts ts) (- nxt (count_ts ts)) code))))
     (if (has_div body)
       (match (gen_e (count_ts ts) Nil (count_ts ts) body)
         ((GErr _) None)
         ((GOk code cnt nxt _ evs)
          (Some (flit_doc (count_ts ts) (- nxt (count_ts ts)) code))))
       (match (gen_t (count_ts ts) Nil (count_ts ts) body)
         ((TErr _) None)
         ((TOk rt)
          (Some
            (flit_doc (count_ts ts) (- (rt_nxt rt) (count_ts ts)) (rt_code rt))))))))))

;; claims, the wmod cons spine (open), name -> index, count
(type LERes (LEOk Doc Doc (List (Pair Symbol Int)) Int) (LEErr (List Int)))

(fn emit_fns_lib
  ((fns (List FnDef))
   (modpath (List Symbol))
   (modpath2 (List Symbol))
   (k Int)
   (accp Doc)
   (accw Doc)
   (accn (List (Pair Symbol Int)))
   (allfns (List FnDef)))
  LERes
  (measure (struct fns))
  (match fns
    (Nil (LEOk accp accw accn k))
    ((Cons f rest)
     (match f
       ((FnDef q ts rty _)
        (match q
          ((QName mp nm)
           (if (if (sym_list_eq mp modpath) True (sym_list_eq mp modpath2))
             (match
               (if (word_sig ts rty) (emit_claim_word f k accn allfns)
               (emit_claim_pure f k))
               ((CErr m) (LEErr m))
               ((COkM d1 d2 d3)
                (LEErr "mem fns are not in the lib fragment yet"))
               ((COkC d1) (LEErr "call fns are not in the lib fragment yet"))
               ((COk dp dl)
                (match (lib_flit f accn allfns)
                  (None (LEErr "lib literal generation failed"))
                  ((Some flit)
                   (emit_fns_lib
                     rest
                     modpath
                     modpath2
                     (+ k 1)
                     (DCat accp (DCat (DStr (nl)) dp))
                     (DCat accw (dcat3 (DStr "(Cons ") flit (sp)))
                     (Cons (Pair nm k) accn)
                     allfns)))))
             (emit_fns_lib rest modpath modpath2 k accp accw accn allfns)))))))))

(fn lib_wmod_doc ((lname Symbol) (accw Doc) (k Int)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr ";; the lib module: every fn of the file at its source-order index")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_wmod () WModule (MkWModule ")
      accw
      (DStr "Nil")
      (pr_rpars k)
      (DStr " 0))")
      (DStr (nl)))))

(fn lib_exp_at ((x Symbol) (ns (List (Pair Symbol Int)))) (Option Int)
  (measure (struct ns))
  (match ns
    (Nil None)
    ((Cons (Pair n i) rest) (if (sym_eq x n) (Some i) (lib_exp_at x rest)))))

(fn lib_exp_entries ((exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (measure (struct exps))
  (match exps
    (Nil (Some (DStr "")))
    ((Cons x rest)
     (match (lib_exp_at x ns)
       (None None)
       ((Some i)
        (match (lib_exp_entries rest ns)
          (None None)
          ((Some d)
           (Some
             (DCat
               (dconc
                 (list
                   (DStr " (WX ")
                   (DStr (list 34))
                   (dsym x)
                   (DStr (list 34))
                   (sp)
                   (dint i)
                   (DStr ")")))
               d)))))))))

(fn lib_exports_doc
  ((lname Symbol) (exps (List Symbol)) (ns (List (Pair Symbol Int))))
  (Option Doc)
  (match (lib_exp_entries exps ns)
    (None None)
    ((Some entries)
     (Some
       (dconc
         (list
           (DStr (nl))
           (DStr
             ";; the export table: the (lib …) declaration's names, by index")
           (DStr (nl))
           (DStr "(fn ")
           (dsym lname)
           (DStr "_exports () (List WExport) (list")
           entries
           (DStr "))")
           (DStr (nl))))))))

;; the encoded binary, spec-side: the plan driver evaluates this instead
;; of importing target encoders — the plan vocabulary stays target-generic
(fn lib_bytes_doc ((lname Symbol)) Doc
  (dconc
    (list
      (DStr (nl))
      (DStr
        ";; the encoded lib binary: the module + named exports through enc_lib")
      (DStr (nl))
      (DStr "(fn ")
      (dsym lname)
      (DStr "_bytes () (List Int) (enc_lib (")
      (dsym lname)
      (DStr "_wmod) (")
      (dsym lname)
      (DStr "_exports)))")
      (DStr (nl)))))

;; the (lib …) declaration of the TARGET source, if any
(fn lib_scan_forms ((forms (List SExpr))) (Option Lib)
  (measure (struct forms))
  (match forms
    (Nil None)
    ((Cons f rest)
     (if (is_lib_form f)
       (match (lib_of_form f)
         (None (lib_scan_forms rest))
         ((Some l) (Some l)))
       (lib_scan_forms rest)))))

(fn lib_scan ((srcs (List SrcEntry)) (target (List Int))) (Option Lib)
  (measure (struct srcs))
  (match srcs
    (Nil None)
    ((Cons (SrcEntry path _ src) rest)
     (if (int_list_eq path target)
       (match (read_all src)
         (None None)
         ((Some forms) (lib_scan_forms forms)))
       (lib_scan rest target)))))

(fn header ((target (List Int)) (memf Bool) (loopf Bool)) Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/wasmgen (the certifying emitter, scalar let/straight-line fragment) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (if (if memf True loopf) (dimport (append_int (updots target) "std/mem"))
      (DStr ""))
      (if loopf (dimport (append_int (updots target) "std/nat.shard"))
      (DStr ""))
      (dimport (append_int (updots target) "models/wasm/wasm.shard"))
      (if loopf
        (dimport (append_int (updots target) "models/wasm/loopkit.shard"))
        (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
      (if loopf (DStr (append_int "(use (:: models wasm loopkit *))" (nl)))
      (DStr ""))
      (if (if memf True loopf) (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr ""))
      (if loopf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl))))))

;; the LIB file's header: the model, the encoder (WExport/WX for the
;; export table), and the source; a WORD lib (any u32-signature fn) adds
;; the fragment's citation surface — kernel/facts (mod_lo/mod_hi),
;; std/word (the defining equations), std/bits (bridges + closure facts)
;; a dir-module impl file's fns key at the MODULE path (the file's
;; dirname), not the file path — resolve by first hit
(fn lib_mp_hit ((fns (List FnDef)) (mp (List Symbol))) Bool
  (measure (struct fns))
  (match fns
    (Nil False)
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (match q
          ((QName fmp _) (if (sym_list_eq fmp mp) True (lib_mp_hit rest mp)))))))))

(fn lib_dirname ((mp (List Symbol))) (List Symbol)
  (measure (struct mp))
  (match mp
    (Nil Nil)
    ((Cons _ Nil) Nil)
    ((Cons h t) (Cons h (lib_dirname t)))))

(fn lib_header
  ((target (List Int))
   (wordy Bool)
   (mp (List Symbol))
   (mp2 (List Symbol))
   (h2 Bool))
  Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/wasmgen (LIB mode: one module, named exports) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (if wordy (dimport (append_int (updots target) "kernel/facts.shard"))
      (DStr ""))
      (dimport (append_int (updots target) "models/wasm/wasm.shard"))
      (dimport (append_int (updots target) "models/wasm/encode.shard"))
      (if wordy
        (DCat
          (dimport (append_int (updots target) "std/word"))
          (dimport (append_int (updots target) "std/bits")))
        (DStr ""))
      (dimport (basename_go target Nil))
      (if wordy (DStr (append_int "(use (:: kernel facts *))" (nl))) (DStr ""))
      (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
      (DStr (append_int "(use (:: models wasm encode WExport))" (nl)))
      (DStr (append_int "(use (:: models wasm encode WX))" (nl)))
      (DStr (append_int "(use (:: models wasm encode enc_lib))" (nl)))
      (if wordy
        (DCat
          (DStr (append_int "(use (:: std word *))" (nl)))
          (DStr (append_int "(use (:: std bits *))" (nl))))
        (DStr ""))
      (DStr "(use (:: ")
      (pr_modpath mp)
      (DStr (append_int " *))" (nl)))
      (if h2
        (dcat3
          (DStr "(use (:: ")
          (pr_modpath mp2)
          (DStr (append_int " *))" (nl))))
        (DStr "")))))

;; does this file (modpath-filtered) contain a word-signature fn?
(fn any_word_fn
  ((fns (List FnDef)) (modpath (List Symbol)) (modpath2 (List Symbol)))
  Bool
  (measure (struct fns))
  (match fns
    (Nil False)
    ((Cons f rest)
     (match f
       ((FnDef q ts rty _)
        (match q
          ((QName mp _)
           (if (if (sym_list_eq mp modpath) True (sym_list_eq mp modpath2))
             (if (word_sig ts rty) True (any_word_fn rest modpath modpath2))
             (any_word_fn rest modpath modpath2)))))))))

;; the LINKED file's header: needs the shipped certs AND the portable
;; file; a calls-in-loops unit (callf) adds the loop kit and std/nat
(fn link_header ((target (List Int)) (portout (List Int)) (callf Bool)) Doc
  (dcat3
    (dcat3
      (DStr
        ";;; GENERATED by tools/wasmgen (the LINKED derivations for the mem fragment) --")
      (DStr (nl))
      (dcat3
        (DStr ";;; DO NOT EDIT; regenerate from ")
        (DStr target)
        (DStr (append_int "." (nl)))))
    (dcat3
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (dcat3
        (dimport (append_int (updots target) "std/mem"))
        (if callf (dimport (append_int (updots target) "std/nat.shard"))
        (DStr ""))
        (dimport (append_int (updots target) "models/wasm/wasm.shard")))
      (dcat3
        (if callf
          (dimport (append_int (updots target) "models/wasm/loopkit.shard"))
          (DStr ""))
        (dimport (append_int (updots target) "std/mem/mem.wasm.shard"))
        (DCat
          (dimport (basename_go portout Nil))
          (dimport (basename_go target Nil)))))
    (dcat3
      (dcat3
        (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
        (if callf (DStr (append_int "(use (:: models wasm loopkit *))" (nl)))
        (DStr ""))
        (DStr ""))
      (dcat3
        (DStr (append_int "(use (:: std mem *))" (nl)))
        (dcat3
          (if callf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
          (DStr (append_int "(use (:: std mem mem.wasm *))" (nl)))
          (DStr ""))
        (use_sibling target portout))
      (use_of target))))

;; ---- driver ------------------------------------------------------------------

(fn prelude_ctors_l () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn fail2 ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn wrote2 ((out (List Int)) (lo (List Int)) (w World)) World
  (exit
    0
    (write
      (append_int
        "wrote "
        (append_int out (append_int " " (append_int lo (nl)))))
      w)))

;; lib mode: emit the position-general claims + the closed module value +
;; the export table; no link file.
(fn lib_run
  ((l Lib) (fns (List FnDef)) (target (List Int)) (out (List Int)) (w World))
  World
  (match l
    ((Lib lname exps _acc)
     (match
       (emit_fns_lib
         fns
         (split_slash (until_dot target) Nil)
         (lib_dirname (split_slash (until_dot target) Nil))
         0
         (DStr "")
         (DStr "")
         Nil
         fns)
       ((LEErr msg)
        (exit 1 (write (append_int "refused: " (append_int msg (nl))) w)))
       ((LEOk bodyp accw ns k)
        (match (lib_exports_doc lname exps ns)
          (None
            (exit
              1
              (write
                "refused: a (lib exports) name is not an emitted fn of this file\n"
                w)))
          ((Some expdoc)
           (match
             (write_file
               out
               (doc_flat
                 (dconc
                   (list
                     (lib_header
                       target
                       (any_word_fn
                         fns
                         (split_slash (until_dot target) Nil)
                         (lib_dirname (split_slash (until_dot target) Nil)))
                       (split_slash (until_dot target) Nil)
                       (lib_dirname (split_slash (until_dot target) Nil))
                       (lib_mp_hit
                         fns
                         (lib_dirname (split_slash (until_dot target) Nil))))
                     bodyp
                     (lib_wmod_doc lname accw k)
                     expdoc
                     (lib_bytes_doc lname)))
                 Nil)
               w)
             ((Pair ok w2)
              (if ok
                (exit 0 (write (append_int "wrote " (append_int out (nl))) w2))
                (fail2 (append_int "cannot write " out) w2)))))))))))

(fn gen_run
  ((target (List Int)) (out (List Int)) (linko (Option (List Int))) (w World))
  World
  (match (resolve_closure target True w)
    ((Pair Nil w1) (fail2 (append_int "cannot read closure of " target) w1))
    ((Pair srcs w1)
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors_l)
         1)
       ((BMFail diag) (fail2 diag w1))
       ((BMOk m)
        (match m
          ((Module _ fns _ _ _)
           (match (lib_scan srcs target)
             ((Some l) (lib_run l fns target out w1))
             (None
               (match
                 (emit_fns
                   fns
                   (split_slash (until_dot target) Nil)
                   (DStr "")
                   (DStr "")
                   False
                   False
                   False
                   Nil)
                 ((EErr msg)
                  (exit
                    1
                    (write (append_int "refused: " (append_int msg (nl))) w1)))
                 ((EOk bodyp bodyl memf loopf callf)
                  (match
                    (write_file
                      out
                      (doc_flat (DCat (header target memf loopf) bodyp) Nil)
                      w1)
                    ((Pair ok w2)
                     (if ok
                       (if memf
                         (match linko
                           (None
                             (fail2
                               "mem-fragment fns present -- usage: wasmgen SRC OUT LINKOUT"
                               w2))
                           ((Some lo)
                            (match
                              (write_file
                                lo
                                (doc_flat
                                  (DCat (link_header target out callf) bodyl)
                                  Nil)
                                w2)
                              ((Pair ok2 w3)
                               (if ok2 (wrote2 out lo w3)
                               (fail2 (append_int "cannot write " lo) w3))))))
                         (exit
                           0
                           (write
                             (append_int "wrote " (append_int out (nl)))
                             w2)))
                       (fail2 (append_int "cannot write " out) w2)))))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target (Cons out Nil)) (gen_run target out None w1))
       ((Cons target (Cons out (Cons lo Nil)))
        (gen_run target out (Some lo) w1))
       (_ (fail2 "usage: wasmgen SRC OUT [LINKOUT]" w1))))))
