;;; wasmgen — the certifying emitter (docs/LOWERING.md §6): the scalar
;;; let/if fragment. For every fn in the target file whose body is
;;; arithmetic over Int params, u32 literals (+ - * ediv mod band bor
;;; bxor), single-
;;; binding lets, and tail-position ifs over int_eq/lt/le comparisons, emit:
;;;   - the wasm function literal (postorder stack code; one LocalSet per
;;;     let, locals allocated after the params in textual order; each if
;;;     a Block/BrIf/Br diamond — True exits the inner block to the THEN
;;;     code, False falls through the ELSE code), and
;;;   - the standard lowered-conformance claim (docs/LOWERING.md §2) with
;;;     its full proof, in chain form mirroring the branch tree: compute
;;;     lhs + unfold/ζ-reduce SPEC rhs; per if a case-on with the fixed
;;;     arm template (rewrite ctor-named case hyp into both sides, compute
;;;     both — the probe-pinned fuel max+slack law needs ONE tower for the
;;;     longest path, no per-branch fuel); per unique arith node,
;;;     discharged in the REGION where its code executes, a named have
;;;     citing wrap32_id once + an all-occurrences rewrite of the have
;;;     fact (the sharing-proof pattern — a let-bound value read k times
;;;     duplicates k-fold under ζ but is discharged once).
;;; The emitted statement generator IS the schema consensus mechanism; the
;;; output is deterministic (weld discipline: regenerable byte-identical
;;; after shardfmt).
;;;
;;; THE CONTRACT (lower.shard's): front end is the KERNEL'S by library
;;; import; refuse, don't guess — any body outside the fragment is a loud
;;; per-fn error and exit 1. Fragment rules: all params Int, return Int;
;;; body nodes are params, let-bound names, literals in [0, 2^32), and
;;; binary + - * ediv mod band bor bxor; lets bind exactly one name; ifs in TAIL position
;;; only, conditions = int_eq/lt/le over params/aliases/literals (no arith
;;; in conditions — wraps must never enter the case-on spelling); every
;;; arith node of the SUBSTITUTED body must contain a param (constant-fold
;;; ground subtrees in the source). PREs are §6j-hygienic: arm-local
;;; premises are CONDITION-RELATIVE ((= (if COND BOUND True) True),
;;; stripped in-arm), and bounds derivable from read intervals or path
;;; conditions are discharged silently (wb_*/cb_* helper claims with
;;; computed farkas certs — no premise emitted).
;;; ediv/mod fns take the STAGED pure walk (§6y — guard PRE per symbolic
;;; divisor, compute interleaved with guard rewrites) and are
;;; straight-line/let only for now: div + if is behind the fence.
;;; band/bor/bxor are TRANSPARENT ops (§6z — prims applied directly, no
;;; wrap, no guard, no premise of their own) and compose everywhere the
;;; fragment goes, ifs included; bounds on containing arith nodes are
;;; consumer premises (std/bits is the discharge kit).
;;;
;;; THE MEM FRAGMENT (first param Mem): bodies that read/write bytes lower
;;; to wasm Calls against std/mem's shipped artifact functions and the
;;; proofs COMPOSE BY CITATION (call_bridge + lowered_mem_get/set) — the
;;; callee bodies are never computed into. See the mem-fragment section
;;; below for the fragment rules and the stage law.
;;;
;;; THE KIT: the reusable emitter library lives in tools/low — doc.shard
;;; (output documents + path/header text), schema.shard (canonical-expr
;;; spelling, premise layouts, statement builders), proof.shard (the
;;; wrap-event / call_bridge / link-derivation proof templates), and
;;; shape.shard (the FRONT END: fragment dispatch, the region-tree
;;; vocabulary, the loop-shape recognizers, the callee registry — the
;;; target-independent canonical source form). This file keeps what is
;;; genuinely the wasm BACK END: the code walks, claim assembly, proof
;;; emission, the module walk, and the CLI.
;;;
;;; RUN IT:  bin/shard_eval run tools/wasmgen/wasmgen.shard SRC OUT.raw
;;;          then shardfmt OUT.raw -> the committed cert file.

(import "../../kernel/stdlib.shard")
(import "../../kernel/loader.shard")
(import "../../kernel/term.shard")
(import "../../kernel/module.shard")
(import "../../kernel/reader.shard")
(import "../../meta/doc")
(import "../low/schema.shard")
(import "../low/lin.shard")
(import "../low/proof.shard")
(import "../low/shape.shard")

(use (:: kernel loader resolve_closure))
(use (:: kernel loader World))
(use (:: kernel loader get_args))
(use (:: kernel loader write))
(use (:: kernel loader write_file))
(use (:: kernel loader exit))
(use (:: kernel term Expr))
(use (:: kernel term FVar))
(use (:: kernel term BVar))
(use (:: kernel term Call))
(use (:: kernel term Let))
(use (:: kernel term If))
(use (:: kernel term IntLit))
(use (:: kernel term Match))
(use (:: kernel term Arm))
(use (:: kernel term Pat))
(use (:: kernel term PCtor))
(use (:: kernel term PVar))
(use (:: kernel term QName))
(use (:: kernel term qn_name))
(use (:: kernel term core_named))
(use (:: kernel term append_int))
(use (:: kernel module Module))
(use (:: kernel module FnDef))
(use (:: kernel module Type))
(use (:: kernel module FnTrie))
(use (:: kernel reader build_module_d))
(use (:: kernel reader BMOk))
(use (:: kernel reader BMFail))
(use (:: meta doc *))
(use (:: tools low schema *))
(use (:: tools low lin *))
(use (:: tools low proof *))
(use (:: tools low shape *))


;; ---- the fragment ------------------------------------------------------------
;;
;; TWO WALKS, TWO CONCERNS (the let design, docs/LOWERING.md §6):
;;   - CODE is emitted from the ORIGINAL let tree — sharing preserved, one
;;     LocalSet per binding, locals allocated in textual order after the
;;     params (deterministic → regen-stable).
;;   - PREMISES/CITATIONS come from the ζ-SUBSTITUTED body — the kernel
;;     opens lets by substitution, so the compute residue's mod-sites are
;;     exactly the substituted tree's arith nodes. Duplicates (a shared
;;     local read twice) dedupe by spelling into ONE citation; an unused
;;     binding's nodes never appear at all.
;; gen_e does the code walk and simultaneously builds the CANONICAL
;; substituted expr (params as FVars named x0…, let-free, BVar-free);
;; nodes_e then collects the unique arith nodes postorder from it.

;; canonical walk result: instr docs (emission order), instr count, next
;; free local index, canonical substituted expr, discharge events.
;;
;; EVENTS (the staged pure walk, docs/LOWERING.md §6y): the code walk
;; collects, in MACHINE ORDER, one EvW per computed arith node (its wrap
;; materializes at that code point) and one EvD per division with a
;; symbolic divisor (bop_val's guard if sticks there). Collection rides
;; the CODE walk, not the substituted tree, because only the code walk
;; can tell a let-SHARE (one materialization — a re-fire would find no
;; site) from a textual RECOMPUTATION (a fresh wrap after any earlier
;; all-occurrences fire — a re-fire is required). Div-free fns produce
;; events too; the region path simply ignores them (nodes_e stays its
;; source of truth), so their output is untouched.
(type DEv (EvW Expr) (EvD Expr))

(type G (GOk (List Doc) Int Int Expr (List DEv)) (GErr (List Int)))

(fn ev_app ((a (List DEv)) (b (List DEv))) (List DEv)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (ev_app t b)))))

(fn gen_e ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) G
  (measure (struct e))
  (match e
    ((BVar i)
     (match (env_at env i)
       ((Some (Pair ce k))
        (GOk
          (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil)
          1
          nxt
          ce
          Nil))
       (None
         (let ((pos (- (- n 1) (- i (env_len env)))))
           (GOk
             (Cons (dcat3 (DStr "(LocalGet ") (dint pos) (DStr ")")) Nil)
             1
             nxt
             (FVar (xsym pos))
             Nil)))))
    ((IntLit k)
     (if (le 0 k)
       (if (lt k 4294967296)
         (GOk
           (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil)
           1
           nxt
           e
           Nil)
         (GErr "literal outside [0, 2^32)"))
       (GErr "literal outside [0, 2^32)")))
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (match (gen_e n env nxt a)
          ((GErr m) (GErr m))
          ((GOk ia ca nxa cea eva)
           (match (gen_e n env nxa b)
             ((GErr m) (GErr m))
             ((GOk ib cb nxb ceb evb)
              (let ((ce (Call q (Cons cea (Cons ceb Nil)))))
                (if (has_fv ce)
                  (match (bop_of q)
                    ((Some opd)
                     (GOk
                       (dapp
                         ia
                         (dapp
                           ib
                           (Cons (dcat3 (DStr "(I32Bin ") opd (DStr ")")) Nil)))
                       (+ ca (+ cb 1))
                       nxb
                       ce
                       (ev_app eva (ev_app evb (Cons (EvW ce) Nil)))))
                    (None
                      (match (dop_of q)
                        ((Some opd)
                         (match ceb
                           ((IntLit dk)
                            (if (int_eq dk 0)
                              (GErr "division by a zero literal")
                              (GOk
                                (dapp
                                  ia
                                  (dapp
                                    ib
                                    (Cons
                                      (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                      Nil)))
                                (+ ca (+ cb 1))
                                nxb
                                ce
                                (ev_app eva evb))))
                           (_
                             (GOk
                               (dapp
                                 ia
                                 (dapp
                                   ib
                                   (Cons
                                     (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                     Nil)))
                               (+ ca (+ cb 1))
                               nxb
                               ce
                               (ev_app eva (ev_app evb (Cons (EvD ceb) Nil)))))))
                        (None
                          (match (top_of q)
                            ((Some opd)
                             (GOk
                               (dapp
                                 ia
                                 (dapp
                                   ib
                                   (Cons
                                     (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                     Nil)))
                               (+ ca (+ cb 1))
                               nxb
                               ce
                               (ev_app eva evb)))
                            (None
                              (GErr
                                "call outside the fragment (only + - * ediv mod band bor bxor allowed)")))))))
                  (GErr
                    "ground arithmetic subtree (constant-fold it in the source)"))))))))
       (_
         (match (bop_of q)
           (None
             (match (dop_of q)
               (None
                 (match (top_of q)
                   (None
                     (GErr
                       "call outside the fragment (only + - * ediv mod band bor bxor allowed)"))
                   ((Some _) (GErr "arith call must be binary"))))
               ((Some _) (GErr "arith call must be binary"))))
           ((Some _) (GErr "arith call must be binary"))))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (GErr m))
          ((GOk ir cr nxr cer evr)
           (match (gen_e n (Cons (Pair cer nxr) env) (+ nxr 1) body)
             ((GErr m) (GErr m))
             ((GOk ib cb nxb ceb evb)
              (GOk
                (dapp
                  ir
                  (Cons (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")")) ib))
                (+ cr (+ cb 1))
                nxb
                ceb
                (ev_app evr evb)))))))
       (_ (GErr "let must bind exactly one name (split into nested lets)"))))
    (_ (GErr "body outside the scalar let/straight-line fragment"))))

;; ---- premise nodes (the substituted tree's arith sites) -----------------------


;; unique arith nodes, postorder (children before parents, so each node's
;; spelling is already child-unwrapped at its discharge point). Bitwise
;; nodes are NOT wrap sites (bop_val applies the prims directly, §6z) —
;; they recurse for children but never claim a premise pair or an event.
(type NRes (NOk (List Expr)) (NErr (List Int)))

(fn nodes_e ((e Expr) (acc (List Expr))) NRes
  (measure (struct e))
  (match e
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (match (nodes_e a acc)
          ((NErr m) (NErr m))
          ((NOk acc1)
           (match (nodes_e b acc1)
             ((NErr m) (NErr m))
             ((NOk acc2)
              (match (top_of q)
                ((Some _) (NOk acc2))
                (None
                  (if (has_fv e)
                    (NOk (if (node_seen (spell e) acc2) acc2 (node_add e acc2)))
                    (NErr
                      "ground arithmetic subtree (constant-fold it in the source)")))))))))
       (_ (NErr "arith call must be binary"))))
    (_ (NOk acc))))

;; ---- tail walk: the branch/region tree -----------------------------------------
;;
;; `if` lives in TAIL position (the fn body's result spine after lets, and
;; arm tails — nested ifs and arm-local lets allowed). The proof mirrors the
;; branch tree: one case-on per if, and each arith node is discharged in the
;; REGION where its code executes — pre-branch let bindings before the
;; case-on, arm-local nodes inside their arm — deduped against ancestor
;; regions (a spelling rewritten pre-branch stays rewritten when the arm's
;; compute resumes from the rewritten term).
;;
;; Conditions are (int_eq c1 c2) / (lt c1 c2) / (le c1 c2) with operands whose CANONICAL
;; form is a param or literal (FVar/IntLit — bare params, let-ALIASES,
;; literals). Wraps never enter a condition, so the case-on spelling matches
;; the compute residue on both sides. Arith inside a condition is refused.
;;
;; PRE hygiene (§6j): arm-local range premises are CONDITION-RELATIVE —
;; if-wrapped in the arm's condition path and stripped inside the arm;
;; a side derivable from a path condition (the abs pattern) is discharged
;; silently by a generated single-condition Farkas helper, no premise at
;; all. (if (lt 0 x) (- x 1) 0) is in the fragment with the honest
;; contract.

;; the diamond, result through a fresh LOCAL rl:
;;   Block [ Block [ COND, BrIf 0, ELSE…, LocalSet rl, Br 1 ],
;;           THEN…, LocalSet rl ]
;;   LocalGet rl
;; BrIf pops b2i(COND): nonzero (True) exits the inner block to THEN; zero
;; (False) falls through ELSE and Br 1 exits the outer block. The result
;; local is LOAD-BEARING for the REAL ISA: wasm blocks are typed and these
;; are void — every block boundary must have an EMPTY stack (V8 rejects a
;; value flowing out of a void block; the model's untyped Block would not
;; have caught it — the engine gate did). Locals-not-stack across block
;; edges is the same discipline the hand-written loop pieces follow.
(fn diamond
  ((cond_code (List Doc))
   (then_code (List Doc))
   (else_code (List Doc))
   (rl Int))
  (List Doc)
  (Cons
    (dcat3
      (DStr "(Block (list (Block (list ")
      (djoin
        (dapp
          cond_code
          (dapp
            (Cons (DStr "(BrIf 0)") Nil)
            (dapp
              else_code
              (Cons
                (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")"))
                (Cons (DStr "(Br 1)") Nil))))))
      (dcat3
        (DStr ")) ")
        (djoin
          (dapp
            then_code
            (Cons (dcat3 (DStr "(LocalSet ") (dint rl) (DStr ")")) Nil)))
        (DStr "))")))
    (Cons (dcat3 (DStr "(LocalGet ") (dint rl) (DStr ")")) Nil)))

(fn gen_t ((n Int) (env (List (Pair Expr Int))) (nxt Int) (e Expr)) TRes
  (measure (struct e))
  (match e
    ((If c a b)
     (match c
       ((Call q ops)
        (match (cond_op q)
          (None (TErr "if condition outside the fragment (int_eq/lt/le only)"))
          ((Some opd)
           (match ops
             ((Cons c1 (Cons c2 Nil))
              (match (gen_e n env nxt c1)
                ((GErr m) (TErr m))
                ((GOk i1 n1 nx1 ce1 _)
                 (match (gen_e n env nx1 c2)
                   ((GErr m) (TErr m))
                   ((GOk i2 n2 nx2 ce2 _)
                    (if (cond_operand_ok ce1)
                      (if (cond_operand_ok ce2)
                        (match (gen_t n env (+ nx2 1) a)
                          ((TErr m) (TErr m))
                          ((TOk rta)
                           (match (gen_t n env (rt_nxt rta) b)
                             ((TErr m) (TErr m))
                             ((TOk rtb)
                              (TOk
                                (RTif
                                  (diamond
                                    (dapp
                                      i1
                                      (dapp
                                        i2
                                        (Cons
                                          (dcat3
                                            (DStr "(I32Bin ")
                                            opd
                                            (DStr ")"))
                                          Nil)))
                                    (rt_code rta)
                                    (rt_code rtb)
                                    nx2)
                                  (+
                                    (+ n1 (+ n2 1))
                                    (+ (rt_count rta) (+ (rt_count rtb) 7)))
                                  (rt_nxt rtb)
                                  Nil
                                  (Call q (Cons ce1 (Cons ce2 Nil)))
                                  rta
                                  rtb))))))
                        (TErr
                          "if condition operand must be a param or literal (no arith in conditions)"))
                      (TErr
                        "if condition operand must be a param or literal (no arith in conditions)")))))))
             (_ (TErr "if condition must be a binary comparison"))))))
       (_ (TErr "if condition outside the fragment (int_eq/lt/le only)"))))
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (match (gen_e n env nxt rhs)
          ((GErr m) (TErr m))
          ((GOk ir cr nxr cer _)
           (match (nodes_e cer Nil)
             ((NErr m) (TErr m))
             ((NOk rns)
              (match (gen_t n (Cons (Pair cer nxr) env) (+ nxr 1) body)
                ((TErr m) (TErr m))
                ((TOk rt)
                 (TOk
                   (rt_prepend
                     (dapp
                       ir
                       (Cons
                         (dcat3 (DStr "(LocalSet ") (dint nxr) (DStr ")"))
                         Nil))
                     (+ cr 1)
                     rns
                     rt)))))))))
       (_ (TErr "let must bind exactly one name (split into nested lets)"))))
    (_
      (match (gen_e n env nxt e)
        ((GErr m) (TErr m))
        ((GOk code cnt nx ce _)
         (match (nodes_e ce Nil)
           ((NErr m) (TErr m))
           ((NOk ns) (TOk (RTv code cnt nx ns)))))))))

;; ---- proof + premise emission over the region tree (PRE hygiene, §6j) ----------
;;
;; ONE fused walk emits, per node, its premises (condition-wrapped in the
;; node's region path), any generated helper claims, and the discharge
;; proof text — so premise indices, helper ordinals, and have names never
;; drift apart. Per node SIDE (lower / upper wrap bound):
;;   - derivable from a path condition (single-cond Farkas, computed
;;     multipliers): a cb_* helper claim + a silent (have dJ …) — NO
;;     premise at all;
;;   - otherwise: a premise — bare when the path is empty (today's form),
;;     if-wrapped in the path when arm-local, stripped inside the arm by
;;     a (have pJ …) (premise rl-rewrite, path hyp rewrites, compute).

;; find the first path condition that derives ng (returns position + the
;; computed multiplier pair)
(fn pw_find ((ng Poly) (path (List (Pair Expr Bool))) (pos Int))
  (Option (Pair Int (Pair Int Int)))
  (measure (struct path))
  (match path
    (Nil None)
    ((Cons (Pair cnd pol) rest)
     (match (cond_poly cnd pol)
       (None (pw_find ng rest (+ pos 1)))
       ((Some (Pair cp iseq))
        (match (solve1 ng cp iseq)
          ((Some gm) (Some (Pair pos gm)))
          (None (pw_find ng rest (+ pos 1)))))))))

(fn path_at ((p (List (Pair Expr Bool))) (i Int)) (Pair Expr Bool)
  (measure (struct p))
  (match p
    (Nil (Pair (IntLit 0) True))
    ((Cons h t) (if (int_eq i 0) h (path_at t (- i 1))))))

(fn path_app ((p (List (Pair Expr Bool))) (s (Pair Expr Bool)))
  (List (Pair Expr Bool))
  (measure (struct p))
  (match p
    (Nil (Cons s Nil))
    ((Cons h t) (Cons h (path_app t s)))))

;; one side's emission: proof doc, premise doc, helper doc, the reference
;; the wrap event cites, next premise index / helper ordinal / have name
(type SR (MkSR Doc Doc Doc Doc Int Int Int))

(fn pw_side
  ((e Expr)
   (lo Bool)
   (path (List (Pair Expr Bool)))
   (fnm Doc)
   (ngo (Option Poly))
   (ni Int)
   (nk Int)
   (j Int))
  SR
  (let ((bound (if lo (bnd_le0 (pr_e e)) (bnd_ltwrap (pr_e e)))))
    (match
      (match ngo
        (None None)
        ((Some pe) (pw_find (if lo (ng_le0 pe) (ng_ltwrap pe)) path 0)))
      ((Some (Pair pos (Pair g m)))
       (match (path_at path pos)
         ((Pair cnd pol)
          (let ((syms (fv_syms cnd (fv_syms e Nil))))
            (MkSR
              (drv_have
                (DCat (DStr "d") (dint j))
                bound
                (cb_name fnm nk)
                (pr_sym_insts syms)
                (- (- (path_len path) 1) pos))
              (DStr "")
              (cb_claim
                (cb_name fnm nk)
                (pr_sym_binds syms)
                (pr_e cnd)
                pol
                bound
                g
                m)
              (DCat (DStr "d") (dint j))
              ni
              (+ nk 1)
              (+ j 1))))))
      (None
        (let
          ((prem (dcat3 (DStr "(= ") (cond_wrap path bound) (DStr " True) "))))
          (match path
            (Nil (MkSR (DStr "") prem (DStr "") (dint ni) (+ ni 1) nk j))
            (_
              (MkSR
                (strip_have (DCat (DStr "p") (dint j)) bound ni path)
                prem
                (DStr "")
                (DCat (DStr "p") (dint j))
                (+ ni 1)
                nk
                (+ j 1)))))))))

;; walk result: proof doc, premises doc, helper claims doc, counters
(type PWR (MkPWR Doc Doc Doc Int Int Int))

(fn pw_node
  ((e Expr) (path (List (Pair Expr Bool))) (fnm Doc) (ni Int) (nk Int) (j Int))
  PWR
  (let ((ngo (pl_e e False)))
    (match (pw_side e True path fnm ngo ni nk j)
      ((MkSR pf1 pr1 hl1 loref ni1 nk1 j1)
       (match (pw_side e False path fnm ngo ni1 nk1 j1)
         ((MkSR pf2 pr2 hl2 hiref ni2 nk2 j2)
          (MkPWR
            (dcat3 pf1 pf2 (wrap_event e loref hiref j2))
            (DCat pr1 pr2)
            (DCat hl1 hl2)
            ni2
            nk2
            (+ j2 1))))))))

;; the region's discharge items: nodes not already discharged in an
;; ancestor region (nor earlier in this one)
(fn pw_items
  ((ns (List Expr))
   (anc (List Expr))
   (path (List (Pair Expr Bool)))
   (fnm Doc)
   (ni Int)
   (nk Int)
   (j Int))
  (Pair PWR (List Expr))
  (measure (struct ns))
  (match ns
    (Nil (Pair (MkPWR (DStr "") (DStr "") (DStr "") ni nk j) anc))
    ((Cons e t)
     (if (node_seen (spell e) anc) (pw_items t anc path fnm ni nk j)
     (match (pw_node e path fnm ni nk j)
       ((MkPWR pf pr hl ni1 nk1 j1)
        (match (pw_items t (node_add e anc) path fnm ni1 nk1 j1)
          ((Pair (MkPWR pf2 pr2 hl2 ni2 nk2 j2) anc2)
           (Pair
             (MkPWR (DCat pf pf2) (DCat pr pr2) (DCat hl hl2) ni2 nk2 j2)
             anc2)))))))))

;; region body = discharge items + closer (refl, or the case-on tree).
;; Each arm re-enters via the fixed template: rewrite the ctor-named case
;; hyp into BOTH sides, compute both to resume past the fired branch.
(fn pw_region
  ((r RT)
   (anc (List Expr))
   (path (List (Pair Expr Bool)))
   (fnm Doc)
   (ni Int)
   (nk Int)
   (j Int))
  PWR
  (measure (struct r))
  (match r
    ((RTv _ _ _ ns)
     (match (pw_items ns anc path fnm ni nk j)
       ((Pair (MkPWR pf pr hl ni1 nk1 j1) _)
        (MkPWR (DCat pf (DStr "refl")) pr hl ni1 nk1 j1))))
    ((RTif _ _ _ ns cond a b)
     (match (pw_items ns anc path fnm ni nk j)
       ((Pair (MkPWR pf pr hl ni1 nk1 j1) anc2)
        (match
          (pw_region a anc2 (path_app path (Pair cond True)) fnm ni1 nk1 j1)
          ((MkPWR pfa pra hla ni2 nk2 j2)
           (match
             (pw_region b anc2 (path_app path (Pair cond False)) fnm ni2 nk2 j2)
             ((MkPWR pfb prb hlb ni3 nk3 j3)
              (MkPWR
                (dcat3
                  (dcat3
                    (dcat3 pf (DStr "(case-on ") (pr_e cond))
                    (DStr
                      " Bool ((case True (chain (steps ((rewrite (hyp True) lr both true ()) (compute both))) ")
                    pfa)
                  (dcat3
                    (DStr
                      ")) (case False (chain (steps ((rewrite (hyp False) lr both true ()) (compute both))) ")
                    pfb
                    (DStr "))))"))
                  (DStr ""))
                (dcat3 pr (DCat pra prb) (DStr ""))
                (dcat3 hl (DCat hla hlb) (DStr ""))
                ni3
                nk3
                j3))))))))))

;; ---- the mem fragment: bodies that CALL std/mem's shipped artifacts -----------
;;
;; Source fns (m Mem) (x Int) … whose bodies read/write bytes lower to
;; wasm Calls against std/mem's artifact module (call-per-byte v1; the
;; probes' composed-by-citation discipline, mechanized):
;;   - Int return: arith over params/literals + (mem_get m ADDR) reads;
;;     memory returned untouched — RHS (Some (Pair (SPEC m0 args) m0)).
;;   - Mem return: lets above a trailing (mem_set …) store — and since
;;     the WRITE-THEN-READ slice (probe: examples/wtrmem_probe.shard),
;;     Mem-typed lets sequence MULTIPLE stores with reads THROUGH them:
;;     the walk threads the CURRENT MEMORY TERM (m0 growing one mem_set
;;     per store); reads and behavior premises fire AT that term, so
;;     machine and spec spellings stay identical and no collapse lemmas
;;     or disequality premises exist anywhere. LINEARITY is enforced —
;;     using the param or a stale Mem binding after a store refuses
;;     loudly. Intermediate mset returns park in scratch locals (no
;;     Drop). RHS (Some (Pair LASTVAL (SPEC m0 args))). Int-return fns
;;     stay store-free (the schema pins their memory unchanged).
;; The emitted module is (Cons mget (Cons mset (Cons SELF restfs))) at
;; index 2 — std/mem's minimal-prefix convention; the callee literals are
;; SPLICED by the generator (the (inline …) same-file rule's link-time
;; answer), and the proofs cite lowered_mem_get/lowered_mem_set through
;; call_bridge, never computing into the callee bodies.
;;
;; THE STAGE LAW (the machine-order discharge discipline): arith nodes are
;; collected during the CODE walk — a let-bound value collects once (later
;; reads are LocalGets of the already-collapsed local), a recomputed
;; spelling collects AGAIN (its wrap re-materializes after the earlier
;; all-occurrences fire and needs a fresh event). At each call site the
;; proof emits (compute lhs (stop eval_call)), flushes the pending wrap
;; events (every so-far-materialized occurrence — stack, locals, and the
;; folded call's arguments — is on the lhs and collapses), then rewrites
;; by call_bridge with CLEAN spellings. PREs are per unique (kind,
;; spelling): wrap bounds for arith nodes, address bounds for read/write
;; addresses (the callee certs' own premise shapes).

;; the spliced std/mem artifact literals (std/mem/mem.wasm.shard's fns —
;; drift fails loudly at the kernel gate when the citations stop matching)
(fn mget_lit () Doc (DStr "(MkFunc 1 0 (list (LocalGet 0) (I32Load8U)))"))

(fn mset_lit () Doc
  (DStr
    "(MkFunc 2 0 (list (LocalGet 0) (LocalGet 1) (I32Store8) (LocalGet 1)))"))

;; PRE hygiene (§6j): a READ-LINEAR arith node whose interval fits the
;; wrap window carries NO premises — PAuto, bounds derived in-proof via a
;; generated interval helper + get_lo/get_hi
(fn wrap_item ((e Expr)) PItem
  (match (pl_e e True)
    (None (PWrap e))
    ((Some p)
     (if (le 0 (pl_lo p)) (if (lt (pl_hi p) 4294967296) (PAuto e) (PWrap e))
     (PWrap e)))))

;; a GROUND byte address outside [0, 65535] can never satisfy the callee
;; cert's bound — refuse at generation (the linked artifact would be
;; vacuous)
(fn addr_ground_bad ((a Expr)) Bool
  (match (pl_e a True)
    ((Some p)
     (match (pl_atoms p)
       (Nil (if (le 0 (pl_const p)) (lt 65535 (pl_const p)) True))
       (_ False)))
    (None False)))


;; ---- the mem walk: code + symbolic machine state + staged proof ----------------
;;
;; state: code docs, instr count, next free local, symbolic stack (clean
;; spellings, top first), proof doc so far, have counter, tagged PREs,
;; pending wrap events, get/set counts, and the CURRENT MEMORY TERM (the
;; spec spelling of the machine memory; starts at m0, grows one mem_set
;; per store). WRITE-THEN-READ discipline: reads and writes fire AT the
;; current term — machine and spec stay on identical spellings, so no
;; collapse lemmas or disequality premises are ever needed; Mem-typed
;; lets are the linear sequencing form (they ζ-open by substitution on
;; the spec side, exactly like scalar lets).
(type MSt
  (MkMSt
    (List Doc)
    Int
    Int
    (List Expr)
    Doc
    Int
    (List PItem)
    (List Expr)
    Int
    Int
    Expr))

(type MRes (MOk MSt Expr) (MErr (List Int)))

(fn m0v () Expr (FVar (quote m0)))

;; the env marker for a Mem-typed binding (its scratch local is dead)
(fn memk () Int (- 0 1))

(fn mg_e
  ((n Int) (nn Int) (fnm Doc) (env (List (Pair Expr Int))) (st MSt) (e Expr))
  MRes
  (measure (struct e))
  (match st
    ((MkMSt code cnt nxt stk prf j pres pend gets sets mm)
     (match e
       ((BVar i)
        (match (env_at env i)
          ((Some (Pair ce k))
           (if (int_eq k (memk))
             (MErr "a Mem-typed binding cannot be used as a scalar value")
             (MOk
               (MkMSt
                 (dapp
                   code
                   (Cons (dcat3 (DStr "(LocalGet ") (dint k) (DStr ")")) Nil))
                 (+ cnt 1)
                 nxt
                 (Cons ce stk)
                 prf
                 j
                 pres
                 pend
                 gets
                 sets
                 mm)
               ce)))
          (None
            (let ((pos (- (- n 1) (- i (env_len env)))))
              (if (int_eq pos 0)
                (MErr
                  "the Mem param may appear only as the memory argument of mem_get/mem_set")
                (let ((ce (FVar (xsym (- pos 1)))))
                  (MOk
                    (MkMSt
                      (dapp
                        code
                        (Cons
                          (dcat3
                            (DStr "(LocalGet ")
                            (dint (- pos 1))
                            (DStr ")"))
                          Nil))
                      (+ cnt 1)
                      nxt
                      (Cons ce stk)
                      prf
                      j
                      pres
                      pend
                      gets
                      sets
                      mm)
                    ce)))))))
       ((IntLit k)
        (if (le 0 k)
          (if (lt k 4294967296)
            (MOk
              (MkMSt
                (dapp
                  code
                  (Cons (dcat3 (DStr "(I32Const ") (dint k) (DStr ")")) Nil))
                (+ cnt 1)
                nxt
                (Cons e stk)
                prf
                j
                pres
                pend
                gets
                sets
                mm)
              e)
            (MErr "literal outside [0, 2^32)"))
          (MErr "literal outside [0, 2^32)")))
       ((Call q as)
        (match (bop_of q)
          ((Some opd)
           (match as
             ((Cons a (Cons b Nil))
              (match (mg_e n nn fnm env st a)
                ((MErr m) (MErr m))
                ((MOk st1 cea)
                 (match (mg_e n nn fnm env st1 b)
                   ((MErr m) (MErr m))
                   ((MOk st2 ceb)
                    (let ((node (Call q (Cons cea (Cons ceb Nil)))))
                      (if (has_fv node)
                        (match st2
                          ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                           (match s2
                             ((Cons _ (Cons _ below))
                              (MOk
                                (MkMSt
                                  (dapp
                                    c2
                                    (Cons
                                      (dcat3 (DStr "(I32Bin ") opd (DStr ")"))
                                      Nil))
                                  (+ n2 1)
                                  x2
                                  (Cons node below)
                                  p2
                                  j2
                                  (if (node_known (spell node) pr2) pr2
                                  (pit_add pr2 (wrap_item node)))
                                  (dapp_e pd2 (Cons node Nil))
                                  g2
                                  w2
                                  mm2)
                                node))
                             (_ (MErr "internal: stack underflow at arith")))))
                        (MErr
                          "ground arithmetic subtree (constant-fold it in the source)"))))))))
             (_ (MErr "arith call must be binary"))))
          (None
            (if (memq_named q (quote mem_get))
              (match as
                ((Cons marg (Cons addr Nil))
                 (match (mg_mem n nn fnm env st marg False)
                   ((MErr m) (MErr m))
                   ((MOk stm mmt)
                    (match (mg_e n nn fnm env stm addr)
                      ((MErr m) (MErr m))
                      ((MOk st1 cea)
                       (if (addr_ground_bad cea)
                         (MErr "literal byte address outside [0, 65535]")
                         (match st1
                           ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                            (match s1
                              ((Cons _ below)
                               (let
                                 ((pr1b
                                    (pit_add pr1 (PGet mmt cea (- nn (+ n1 3))))))
                                 (match (m_flush pd1 pr1b fnm j1)
                                   ((Pair evd j2)
                                    (let
                                      ((rnode
                                         (Call q (Cons mmt (Cons cea Nil)))))
                                      (MOk
                                        (MkMSt
                                          (dapp c1 (Cons (DStr "(Call 0)") Nil))
                                          (+ n1 1)
                                          x1
                                          (Cons rnode below)
                                          (dcat3
                                            p1
                                            (DCat (m_stage_open) evd)
                                            (m_bridge_get
                                              mmt
                                              cea
                                              below
                                              rnode
                                              (+ 3 (poff pr1))))
                                          j2
                                          pr1b
                                          Nil
                                          (+ g1 1)
                                          w1
                                          mm1)
                                        rnode))))))
                              (_ (MErr "internal: stack underflow at mem_get")))))))))))
                (_ (MErr "mem_get must have exactly (m ADDR)")))
            (if (memq_named q (quote mem_set))
              (MErr
                "mem_set is a memory expression (bind it with a Mem let or nest it as a memory argument)")
              (MErr "call outside the mem fragment (+ - * mem_get only)"))))))
       ((Let bs body)
        (match bs
          ((Cons rhs Nil)
           (if (rhs_is_set rhs)
             (match (mg_mem n nn fnm env st rhs False)
               ((MErr m) (MErr m))
               ((MOk st1 mmt)
                (mg_e n nn fnm (Cons (Pair mmt (memk)) env) st1 body)))
             (match (mg_e n nn fnm env st rhs)
               ((MErr m) (MErr m))
               ((MOk st1 cer)
                (match st1
                  ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                   (match s1
                     ((Cons _ below)
                      (mg_e
                        n
                        nn
                        fnm
                        (Cons (Pair cer x1) env)
                        (MkMSt
                          (dapp
                            c1
                            (Cons
                              (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                              Nil))
                          (+ n1 1)
                          (+ x1 1)
                          below
                          p1
                          j1
                          pr1
                          pd1
                          g1
                          w1
                          mm1)
                        body))
                     (_ (MErr "internal: stack underflow at let")))))))))
          (_ (MErr "let must bind exactly one name (split into nested lets)"))))
       (_
         (MErr
           "body outside the mem fragment (straight-line + lets; no if yet)"))))))

;; is this let-rhs a Mem-typed expression (a mem_set application)?
(fn rhs_is_set ((e Expr)) Bool
  (match e
    ((Call q _) (memq_named q (quote mem_set)))
    (_ False)))

;; a MEMORY expression: the Mem param, a Mem binding, or a
;; (mem_set MEMEXPR ADDR VAL) nest. Emits the nest's stores in execution
;; order; the intermediate mset returns PARK in a fresh scratch local
;; (the no-Drop discipline) — tail=True leaves the LAST store's return
;; on the stack (the Mem-returning fn's scalar result). LINEARITY: a
;; param/binding use must denote the CURRENT memory term.
(fn mg_mem
  ((n Int)
   (nn Int)
   (fnm Doc)
   (env (List (Pair Expr Int)))
   (st MSt)
   (e Expr)
   (tail Bool))
  MRes
  (measure (struct e))
  (match st
    ((MkMSt code cnt nxt stk prf j pres pend gets sets mm)
     (match e
       ((BVar i)
        (match (env_at env i)
          ((Some (Pair ce k))
           (if (int_eq k (memk))
             (if (chars_eq (spell ce) (spell mm)) (MOk st ce)
             (MErr
               "memory used non-linearly (a stale Mem binding was read or written)"))
             (MErr "a scalar binding cannot be used as a memory argument")))
          (None
            (let ((pos (- (- n 1) (- i (env_len env)))))
              (if (int_eq pos 0)
                (if (chars_eq (spell mm) (spell (m0v))) (MOk st mm)
                (MErr
                  "memory used non-linearly (the Mem param was used after a store)"))
                (MErr "an Int param cannot be used as a memory argument"))))))
       ((Call q as)
        (if (memq_named q (quote mem_set))
          (match as
            ((Cons marg (Cons addr (Cons val Nil)))
             (match (mg_mem n nn fnm env st marg False)
               ((MErr m) (MErr m))
               ((MOk st0 mmt)
                (match (mg_e n nn fnm env st0 addr)
                  ((MErr m) (MErr m))
                  ((MOk st1 cea)
                   (if (addr_ground_bad cea)
                     (MErr "literal byte address outside [0, 65535]")
                     (match (mg_e n nn fnm env st1 val)
                       ((MErr m) (MErr m))
                       ((MOk st2 cev)
                        (match st2
                          ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                           (match s2
                             ((Cons _ (Cons _ below))
                              (let
                                ((newmm
                                   (Call q (Cons mmt (Cons cea (Cons cev Nil))))))
                                (let
                                  ((pr2b
                                     (pit_add
                                       pr2
                                       (PSet mmt cea cev (- nn (+ n2 3))))))
                                  (match (m_flush pd2 pr2b fnm j2)
                                    ((Pair evd j3)
                                     (let
                                       ((prf2
                                          (dcat3
                                            p2
                                            (DCat (m_stage_open) evd)
                                            (m_bridge_set
                                              mmt
                                              cea
                                              cev
                                              below
                                              (+ 3 (poff pr2))))))
                                       (if tail
                                         (MOk
                                           (MkMSt
                                             (dapp
                                               c2
                                               (Cons (DStr "(Call 1)") Nil))
                                             (+ n2 1)
                                             x2
                                             (Cons cev below)
                                             prf2
                                             j3
                                             pr2b
                                             Nil
                                             g2
                                             (+ w2 1)
                                             newmm)
                                           newmm)
                                         (MOk
                                           (MkMSt
                                             (dapp
                                               c2
                                               (Cons
                                                 (DStr "(Call 1)")
                                                 (Cons
                                                   (dcat3
                                                     (DStr "(LocalSet ")
                                                     (dint x2)
                                                     (DStr ")"))
                                                   Nil)))
                                             (+ n2 2)
                                             (+ x2 1)
                                             below
                                             prf2
                                             j3
                                             pr2b
                                             Nil
                                             g2
                                             (+ w2 1)
                                             newmm)
                                           newmm))))))))
                             (_ (MErr "internal: stack underflow at mem_set")))))))))))))
            (_ (MErr "mem_set must have exactly (m ADDR VAL)")))
          (MErr
            "memory argument must be the Mem param, a Mem binding, or a (mem_set …) nest")))
       (_
         (MErr
           "memory argument must be the Mem param, a Mem binding, or a (mem_set …) nest"))))))

;; the Mem-returning tail: lets above a trailing memory expression (the
;; final store's return value stays on the stack as the scalar result)
(fn mg_tail
  ((n Int) (nn Int) (fnm Doc) (env (List (Pair Expr Int))) (st MSt) (e Expr))
  MRes
  (measure (struct e))
  (match e
    ((Let bs body)
     (match bs
       ((Cons rhs Nil)
        (if (rhs_is_set rhs)
          (match (mg_mem n nn fnm env st rhs False)
            ((MErr m) (MErr m))
            ((MOk st1 mmt)
             (mg_tail n nn fnm (Cons (Pair mmt (memk)) env) st1 body)))
          (match (mg_e n nn fnm env st rhs)
            ((MErr m) (MErr m))
            ((MOk st1 cer)
             (match st1
               ((MkMSt c1 n1 x1 s1 p1 j1 pr1 pd1 g1 w1 mm1)
                (match s1
                  ((Cons _ below)
                   (mg_tail
                     n
                     nn
                     fnm
                     (Cons (Pair cer x1) env)
                     (MkMSt
                       (dapp
                         c1
                         (Cons
                           (dcat3 (DStr "(LocalSet ") (dint x1) (DStr ")"))
                           Nil))
                       (+ n1 1)
                       (+ x1 1)
                       below
                       p1
                       j1
                       pr1
                       pd1
                       g1
                       w1
                       mm1)
                     body))
                  (_ (MErr "internal: stack underflow at let")))))))))
       (_ (MErr "let must bind exactly one name (split into nested lets)"))))
    ((Call q as)
     (if (memq_named q (quote mem_set))
       (match as
         ((Cons marg (Cons addr (Cons val Nil)))
          (match (mg_mem n nn fnm env st marg False)
            ((MErr m) (MErr m))
            ((MOk st0 mmt)
             (match (mg_e n nn fnm env st0 addr)
               ((MErr m) (MErr m))
               ((MOk st1 cea)
                (if (addr_ground_bad cea)
                  (MErr "literal byte address outside [0, 65535]")
                  (match (mg_e n nn fnm env st1 val)
                    ((MErr m) (MErr m))
                    ((MOk st2 cev)
                     (match st2
                       ((MkMSt c2 n2 x2 s2 p2 j2 pr2 pd2 g2 w2 mm2)
                        (match s2
                          ((Cons _ (Cons _ below))
                           (let
                             ((newmm
                                (Call q (Cons mmt (Cons cea (Cons cev Nil))))))
                             (let
                               ((pr2b
                                  (pit_add
                                    pr2
                                    (PSet mmt cea cev (- nn (+ n2 3))))))
                               (match (m_flush pd2 pr2b fnm j2)
                                 ((Pair evd j3)
                                  (MOk
                                    (MkMSt
                                      (dapp c2 (Cons (DStr "(Call 1)") Nil))
                                      (+ n2 1)
                                      x2
                                      (Cons cev below)
                                      (dcat3
                                        p2
                                        (DCat (m_stage_open) evd)
                                        (m_bridge_set
                                          mmt
                                          cea
                                          cev
                                          below
                                          (+ 3 (poff pr2))))
                                      j3
                                      pr2b
                                      Nil
                                      g2
                                      (+ w2 1)
                                      newmm)
                                    cev))))))
                          (_ (MErr "internal: stack underflow at mem_set")))))))))))))
         (_ (MErr "mem_set must have exactly (m ADDR VAL)")))
       (MErr "Mem-returning body must end in a (mem_set …) store")))
    (_ (MErr "Mem-returning body must end in a (mem_set …) store"))))

;; ---- loop codegen ----------------------------------------------------------------

(fn lp_lget ((k Int)) Doc
  (dconc (list (DStr "(LocalGet ") (dint k) (DStr ")"))))

(fn lp_const ((k Int)) Doc
  (dconc (list (DStr "(I32Const ") (dint k) (DStr ")"))))

(fn lp_lset ((k Int)) Doc
  (dconc (list (DStr "(LocalSet ") (dint k) (DStr ")"))))

(fn lp_valcode ((v LVal)) (List Doc)
  (match v
    ((LVAcc i) (Cons (lp_lget i) Nil))
    ((LVLit l) (Cons (lp_const l) Nil))
    ((LVRead i) (Cons (lp_lget i) (Cons (DStr "(I32Load8U)") Nil)))))

(fn lp_vlen ((v LVal)) Int
  (match v
    ((LVAcc _) 1)
    ((LVLit _) 1)
    ((LVRead _) 2)))

(fn lp_advcode ((adv (List LStr)) (i Int)) (List Doc)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t)
     (match h
       ((LSStat) (lp_advcode t (+ i 1)))
       ((LSInc)
        (dapp
          (list (lp_lget i) (lp_const 1) (DStr "(I32Bin BAdd)") (lp_lset i))
          (lp_advcode t (+ i 1))))
       ((LSDec)
        (dapp
          (list (lp_lget i) (lp_const 1) (DStr "(I32Bin BSub)") (lp_lset i))
          (lp_advcode t (+ i 1))))
       ((LSIncK s)
        (dapp
          (list (lp_lget i) (lp_const s) (DStr "(I32Bin BAdd)") (lp_lset i))
          (lp_advcode t (+ i 1))))))))

;; the store block: (addr, value) pairs pushed in REVERSE execution
;; order (outer store deepest), then one I32Store8 per store — every
;; load executes before either store (pure stack, no scratch locals)
(fn lp_storecode ((sts (List (Pair Int LVal)))) (List Doc)
  (match sts
    ((Cons (Pair a1 v1) (Cons (Pair a2 v2) Nil))
     (dapp
       (Cons (lp_lget a2) (lp_valcode v2))
       (dapp
         (Cons (lp_lget a1) (lp_valcode v1))
         (list (DStr "(I32Store8)") (DStr "(I32Store8)")))))
    ((Cons (Pair a1 v1) Nil)
     (dapp (Cons (lp_lget a1) (lp_valcode v1)) (list (DStr "(I32Store8)"))))
    (_ Nil)))

;; instruction count of the store block
(fn lp_stlen ((sts (List (Pair Int LVal)))) Int
  (measure (struct sts))
  (match sts
    (Nil 0)
    ((Cons (Pair _ v) t) (+ (+ 2 (lp_vlen v)) (lp_stlen t)))))

;; guard / stores / advances / decrement / re-enter
;; (instrs = 8 + stlen + 4*nAdv)
(fn lp_code ((n Int) (adv (List LStr)) (sts (List (Pair Int LVal)))) (List Doc)
  (dapp
    (list (lp_lget n) (DStr "(I32Eqz)") (DStr "(BrIf 1)"))
    (dapp
      (lp_storecode sts)
      (dapp
        (lp_advcode adv 0)
        (list
          (lp_lget n)
          (lp_const 1)
          (DStr "(I32Bin BSub)")
          (lp_lset n)
          (DStr "(Br 0)"))))))

;; Int-return: guard / sum FIRST (reads accum j's OLD value) / advances /
;; decrement / re-enter (instrs = 13 + 4*nAdv)
(fn li_code ((n Int) (adv (List LStr)) (r Int) (j Int)) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget r)
      (lp_lget j)
      (DStr "(I32Load8U)")
      (DStr "(I32Bin BAdd)")
      (lp_lset r))
    (dapp
      (lp_advcode adv 0)
      (list
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; SCAN codegen: budget guard / load + literal-test exit / r += 1 /
;; k -= 1 / re-enter. The zero literal keeps the one-instr I32Eqz test
;; (16 instrs); a nonzero literal pays I32Const + BEq (17 instrs) —
;; both leave (b2i (int_eq BYTE LIT)) as the machine flag residue.
(fn lc_test ((z Int)) (List Doc)
  (if (int_eq z 0) (list (DStr "(I32Eqz)"))
  (list (lp_const z) (DStr "(I32Bin BEq)"))))

(fn lc_code ((n Int) (r Int) (z Int)) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget r)
      (DStr "(I32Load8U)"))
    (dapp
      (lc_test z)
      (list
        (DStr "(BrIf 1)")
        (lp_lget r)
        (lp_const 1)
        (DStr "(I32Bin BAdd)")
        (lp_lset r)
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; FLAG codegen: budget guard / two loads + BEq into the flag local /
;; exit if flag=0 / advances / k -= 1 / re-enter (instrs = 17 + 4*nAdv;
;; the flag local sits at index n+1, past the counter)
(fn lb_code ((n Int) (a Int) (b Int) (adv (List LStr))) (List Doc)
  (dapp
    (list
      (lp_lget n)
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)")
      (lp_lget a)
      (DStr "(I32Load8U)")
      (lp_lget b)
      (DStr "(I32Load8U)")
      (DStr "(I32Bin BEq)")
      (lp_lset (+ n 1))
      (lp_lget (+ n 1))
      (DStr "(I32Eqz)")
      (DStr "(BrIf 1)"))
    (dapp
      (lp_advcode adv 0)
      (list
        (lp_lget n)
        (lp_const 1)
        (DStr "(I32Bin BSub)")
        (lp_lset n)
        (DStr "(Br 0)")))))

;; ---- loop claim assembly ----------------------------------------------------------

(fn lp_nadv ((bs (List LStr))) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t) (+ (if (ls_adv h) 1 0) (lp_nadv t)))))

;; number of advancing accums among the first i (= accum i's group-A premise ix)
(fn lp_advpos ((bs (List LStr)) (i Int)) Int
  (measure (struct bs))
  (match bs
    (Nil 0)
    ((Cons h t)
     (if (int_eq i 0) 0 (+ (if (ls_adv h) 1 0) (lp_advpos t (- i 1)))))))

;; the first INCREMENTING accum — the counter wrap (lg_kM or the
;; stride-scaled instance) rides its premise pair, so every loop needs
;; one (v1 fence)
(fn lp_first_inc ((bs (List LStr)) (i Int)) (Option Int)
  (measure (struct bs))
  (match bs
    (Nil None)
    ((Cons h t)
     (match h
       ((LSInc) (Some i))
       ((LSIncK _) (Some i))
       (_ (lp_first_inc t (+ i 1)))))))

(fn lp_has_dec ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSDec) True)
       (_ (lp_has_dec t))))))

;; group-A premises, param order: inc -> nonneg, dec -> count-lower
(fn lp_prems_lo ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc) (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True) "))))
         ((LSIncK _)
          (dconc (list (DStr "(= (le 0 x") (dint i) (DStr ") True) "))))
         ((LSDec)
          (dconc
            (list (DStr "(= (le (int_of_nat k) x") (dint i) (DStr ") True) ")))))
       (lp_prems_lo t (+ i 1))))))

;; group-B premises, param order: inc -> range (stride-scaled for
;; LSIncK), dec -> address-upper
(fn lp_prems_rng ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc)
          (dconc
            (list
              (DStr "(= (le (+ x")
              (dint i)
              (DStr " (int_of_nat k)) 65536) True) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(= (le (+ x")
              (dint i)
              (DStr " (* ")
              (dint s)
              (DStr " (int_of_nat k))) 65536) True) "))))
         ((LSDec)
          (dconc
            (list (DStr "(= (le (+ x") (dint i) (DStr " 1) 65536) True) ")))))
       (lp_prems_rng t (+ i 1))))))

;; exit locals: inc -> (lg_adv xi k), stride-C -> (lg_advk xi C k),
;; dec -> (lg_dec xi k), static -> xi, counter -> 0
(fn lp_exits ((bs (List LStr)) (i Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr "0"))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (dconc (list (DStr "(lg_adv x") (dint i) (DStr " k) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(lg_advk x")
              (dint i)
              (DStr " ")
              (dint s)
              (DStr " k) "))))
         ((LSDec) (dconc (list (DStr "(lg_dec x") (dint i) (DStr " k) "))))
         ((LSStat) (dconc (list (DStr "x") (dint i) (DStr " ")))))
       (lp_exits t (+ i 1))))))

;; ---- Int-return claim pieces ------------------------------------------------------

;; premised accums for the Int-return shape: the return accum joins as a
;; nonneg-premised (inc-marked) slot; its group-B premise and exit stay
;; special-cased by position r
(fn li_pflags ((adv (List LStr)) (r Int) (i Int)) (List LStr)
  (measure (struct adv))
  (match adv
    (Nil Nil)
    ((Cons h t) (Cons (if (int_eq i r) (LSInc) h) (li_pflags t r (+ i 1))))))

;; range premises: the k-scaled sum invariant at r, stride-shaped elsewhere
(fn li_prems_rng ((adv (List LStr)) (r Int) (i Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (int_eq i r)
         (dconc
           (list
             (DStr "(= (le (+ x")
             (dint i)
             (DStr " (* 256 (int_of_nat k))) 4294967296) True) ")))
         (match h
           ((LSStat) (DStr ""))
           ((LSInc)
            (dconc
              (list
                (DStr "(= (le (+ x")
                (dint i)
                (DStr " (int_of_nat k)) 65536) True) "))))
           ((LSIncK _)
            (dconc
              (list
                (DStr "(= (le (+ x")
                (dint i)
                (DStr " (int_of_nat k)) 65536) True) "))))
           ((LSDec)
            (dconc
              (list (DStr "(= (le (+ x") (dint i) (DStr " 1) 65536) True) "))))))
       (li_prems_rng t r (+ i 1))))))

;; exit locals: return accum -> the SPEC-CALL spelling, else by stride
(fn li_exits ((adv (List LStr)) (r Int) (i Int) (spec Doc)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr "0"))
    ((Cons h t)
     (DCat
       (if (int_eq i r) (DCat spec (DStr " "))
       (match h
         ((LSInc) (dconc (list (DStr "(lg_adv x") (dint i) (DStr " k) "))))
         ((LSIncK s)
          (dconc
            (list
              (DStr "(lg_advk x")
              (dint i)
              (DStr " ")
              (dint s)
              (DStr " k) "))))
         ((LSDec) (dconc (list (DStr "(lg_dec x") (dint i) (DStr " k) "))))
         ((LSStat) (dconc (list (DStr "x") (dint i) (DStr " "))))))
       (li_exits t r (+ i 1) spec)))))

;; memory-op address occurrences, code order: pushes are in REVERSE
;; execution order, so the OUTER store's value-load fires first; then the
;; stores in execution order
(fn lp_read_occ ((v LVal)) (List Int)
  (match v
    ((LVRead i) (Cons i Nil))
    (_ Nil)))

(fn lp_occs ((sts (List (Pair Int LVal)))) (List Int)
  (match sts
    ((Cons (Pair a1 v1) (Cons (Pair a2 v2) Nil))
     (append_int
       (lp_read_occ v2)
       (append_int (lp_read_occ v1) (Cons a1 (Cons a2 Nil)))))
    ((Cons (Pair a1 v1) Nil) (append_int (lp_read_occ v1) (Cons a1 Nil)))
    (_ Nil)))

;; one INC address-guard stage: premise-rewrite the nonneg guard, cite
;; lg_a1_ms for the upper guard, compute on
(fn lp_stage ((p Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint r)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; ---- stride != 1 support (LSIncK; probe: strideloop_probe) -------------------
;; A stride-C accum rides the SAME stage/wrap/IH shapes as stride 1, but
;; its helper certs are C-scaled instances GENERATED per (fn, stride)
;; with computed farkas lists (the kit lemmas cannot take C as a binder
;; — C*n is nonlinear; as a literal it is a coefficient). Closed
;; formulas, mined at C=4 in the probe:
;;   a1ms / ac  -> (list 1 1 C C)      lo / c32 -> (list 1 1)
;;   kM         -> (list C 1 C 1)      shift    -> (list 1 1 C)

;; generated-helper name: lgs_<fn>_<C>_<suffix>
(fn lgs_nm ((fnm Doc) (s Int) (suf (List Int))) Doc
  (dconc (list (DStr "lgs_") fnm (DStr "_") (dint s) (DStr "_") (DStr suf))))

(fn lp_has_inck ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSIncK _) True)
       (_ (lp_has_inck t))))))

(fn lp_has_inc1 ((bs (List LStr))) Bool
  (measure (struct bs))
  (match bs
    (Nil False)
    ((Cons h t)
     (match h
       ((LSInc) True)
       (_ (lp_has_inc1 t))))))

(fn int_in ((x Int) (xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (int_eq h x) True (int_in x t)))))

;; the distinct LSIncK strides, first-seen order
(fn lp_incks ((bs (List LStr)) (seen (List Int))) (List Int)
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons h t)
     (match h
       ((LSIncK s)
        (if (int_in s seen) (lp_incks t seen)
        (Cons s (lp_incks t (Cons s seen)))))
       (_ (lp_incks t seen))))))

;; the six C-scaled helper claims for one (fn, stride)
(fn lgs_one ((fnm Doc) (s Int)) Doc
  (dconc
    (list
      (DStr "(claim ")
      (lgs_nm fnm s "a1ms")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ a 1) 65536) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr " ")
      (dint s)
      (DStr ")))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "ac")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ a ")
      (dint s)
      (DStr ") 65536) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr " ")
      (dint s)
      (DStr ")))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "lo")
      (DStr " (goal ((x Int)) ((= (le 0 x) True)) (= (le 0 (+ x ")
      (dint s)
      (DStr ")) True)) (by arith (list 1 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "c32")
      (DStr " (goal ((x Int)) ((= (le (+ x ")
      (dint s)
      (DStr ") 65536) True)) (= (lt (+ x ")
      (dint s)
      (DStr ") 4294967296) True)) (by arith (list 1 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "kM")
      (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 a) True)) (= (lt (int_of_nat c) 4294967296) True)) (by arith (list ")
      (dint s)
      (DStr " 1 ")
      (dint s)
      (DStr " 1)))")
      (DStr (nl))
      (DStr "(claim ")
      (lgs_nm fnm s "shift")
      (DStr " (goal ((b Int) (w Int) (c Nat)) ((= (le (+ b (* ")
      (dint s)
      (DStr
        " (int_of_nat (S c)))) w) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c)))) (= (le (+ (+ b ")
      (dint s)
      (DStr ") (* ")
      (dint s)
      (DStr " (int_of_nat c))) w) True)) (by arith (list 1 1 ")
      (dint s)
      (DStr ")))")
      (DStr (nl)))))

(fn lgs_all ((fnm Doc) (ss (List Int))) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons s t) (DCat (lgs_one fnm s) (lgs_all fnm t)))))

;; the stride-C address-guard stage (lp_stage with the generated a1ms)
(fn lp_kstage ((anm Doc) (p Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma ")
      anm
      (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint r)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) "))))

;; the stride-C counter wrap (lp_hwk with the generated kM)
(fn lp_khwk ((knm Doc) (f Int) (rng Int) (lo Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma ")
      knm
      (DStr ") lr lhs ((inst a x")
      (dint f)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint rng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise ")
      (dint lo)
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; the stride-C advance wrap (lp_hw with the generated lo/c32/ac chain)
(fn lp_khw ((fnm Doc) (s Int) (p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr ") 4294967296) (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr ")) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr " ")
      (dint s)
      (DStr "))) ((rewrite-with (lemma ")
      (lgs_nm fnm s "lo")
      (DStr ") lr lhs () ((steps ((rewrite (premise ")
      (dint p)
      (DStr ") lr lhs true ())) refl)) refl) (rewrite-with (lemma ")
      (lgs_nm fnm s "c32")
      (DStr ") lr lhs () ((rewrite-with (lemma ")
      (lgs_nm fnm s "ac")
      (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

;; one DEC address-guard stage: cite lg_dlo for the lower guard, then
;; premise-rewrite the address-upper directly
(fn lp_dstage ((p Int) (r Int)) Doc
  (dconc
    (list
      (DStr
        "(steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_dlo) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise ")
      (dint r)
      (DStr ") lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lp_stages ((fnm Doc) (occs (List Int)) (adv (List LStr)) (na Int)) Doc
  (measure (struct occs))
  (match occs
    (Nil (DStr ""))
    ((Cons i t)
     (DCat
       (match (ls_at adv i)
         ((LSDec) (lp_dstage (lp_advpos adv i) (+ na (lp_advpos adv i))))
         ((LSIncK s)
          (lp_kstage
            (lgs_nm fnm s "a1ms")
            (lp_advpos adv i)
            (+ na (lp_advpos adv i))))
         (_ (lp_stage (lp_advpos adv i) (+ na (lp_advpos adv i)))))
       (lp_stages fnm t adv na)))))

;; the counter wrap: (1+n)-1 collapse, then wrap32_id via lg_kM off the
;; FIRST incrementing accum's range premise (rng) and nonneg premise (lo)
(fn lp_hwk ((f Int) (rng Int) (lo Int)) Doc
  (dconc
    (list
      (DStr
        "(have hsub (= (- (+ 1 (int_of_nat k2)) 1) (int_of_nat k2)) (rewrite-with (lemma lg_sub) lr lhs () () refl)) (steps ((rewrite (premise hsub) lr lhs true ()))) (have hwk (= (mod (int_of_nat k2) 4294967296) (int_of_nat k2)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (int_of_nat k2))) ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl) (rewrite-with (lemma lg_kM) lr lhs ((inst a x")
      (dint f)
      (DStr ") (inst c k2)) ((steps ((rewrite (premise ")
      (dint rng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (steps ((rewrite (premise ")
      (dint lo)
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hwk) lr lhs true ()))) "))))

;; one incrementing accum's advance-wrap have + all-occurrences rewrite
(fn lp_hw ((p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (+ x")
      (dint i)
      (DStr " 1) 4294967296) (+ x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl)) refl) (rewrite-with (lemma lg_32) lr lhs () ((rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

;; one decrementing accum's wrap have (lg_dlo1 / lg_d32 off the dec pair)
(fn lp_dhw ((p Int) (i Int) (na Int)) Doc
  (dconc
    (list
      (DStr "(have hw")
      (dint p)
      (DStr " (= (mod (- x")
      (dint i)
      (DStr " 1) 4294967296) (- x")
      (dint i)
      (DStr " 1)) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (- x")
      (dint i)
      (DStr
        " 1))) ((rewrite-with (lemma lg_dlo1) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint p)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl) (rewrite-with (lemma lg_d32) lr lhs () ((steps ((rewrite (premise ")
      (dint (+ na p))
      (DStr
        ") lr lhs true ())) refl)) refl)) refl)) (steps ((rewrite (premise hw")
      (dint p)
      (DStr ") lr lhs true ()))) "))))

(fn lp_hws ((fnm Doc) (bs (List LStr)) (i Int) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_hws fnm t (+ i 1) p na))
       ((LSInc) (DCat (lp_hw p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))
       ((LSIncK s)
        (DCat (lp_khw fnm s p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))
       ((LSDec) (DCat (lp_dhw p i na) (lp_hws fnm t (+ i 1) (+ p 1) na)))))))

;; the IH's group-A discharges: lg_lo1 (inc) / lg_dshift (dec) / the
;; generated lo (stride C)
(fn lp_lo1s ((fnm Doc) (bs (List LStr)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_lo1s fnm t p))
       ((LSInc)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))
       ((LSIncK s)
        (DCat
          (dconc
            (list
              (DStr "(rewrite-with (lemma ")
              (lgs_nm fnm s "lo")
              (DStr ") lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))
       ((LSDec)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_dshift) lr lhs () ((steps ((rewrite (premise ")
              (dint p)
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_lo1s fnm t (+ p 1))))))))

;; the IH's group-B discharges: lg_shift (inc) / lg_dhi (dec) / the
;; generated shift (stride C)
(fn lp_shifts ((fnm Doc) (bs (List LStr)) (p Int) (na Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((LSStat) (lp_shifts fnm t p na))
       ((LSInc)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))
       ((LSIncK s)
        (DCat
          (dconc
            (list
              (DStr "(rewrite-with (lemma ")
              (lgs_nm fnm s "shift")
              (DStr ") lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr
                ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))
       ((LSDec)
        (DCat
          (dconc
            (list
              (DStr
                "(rewrite-with (lemma lg_dhi) lr lhs () ((steps ((rewrite (premise ")
              (dint (+ na p))
              (DStr ") lr lhs true ())) refl)) refl) ")))
          (lp_shifts fnm t (+ p 1) na)))))))

;; Int-return advance wraps: per advancing accum in param order, premise
;; indices from the PREMISED-accum position (pf includes r)
(fn li_hws ((adv (List LStr)) (pf (List LStr)) (i Int) (nap Int)) Doc
  (measure (struct adv))
  (match adv
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSStat) (DStr ""))
         ((LSInc) (lp_hw (lp_advpos pf i) i nap))
         ((LSIncK _) (lp_hw (lp_advpos pf i) i nap))
         ((LSDec) (lp_dhw (lp_advpos pf i) i nap)))
       (li_hws t pf (+ i 1) nap)))))

;; the sum wrap: the machine BAdd's (mod (+ xr (mem_get m0 xj)) 2^32)
;; collapses via wrap32_id off the sum-invariant pair + get_lo/get_hi
(fn li_hwa ((r Int) (j Int) (plo Int) (prng Int)) Doc
  (dconc
    (list
      (DStr "(have hwa (= (mod (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr ")) 4294967296) (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr "))) (rewrite-with (lemma wrap32_id) lr lhs ((inst x (+ x")
      (dint r)
      (DStr " (mem_get m0 x")
      (dint j)
      (DStr
        ")))) ((rewrite-with (lemma lg_sum_lo) lr lhs () ((steps ((rewrite (premise ")
      (dint plo)
      (DStr
        ") lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) (rewrite-with (lemma lg_sum_32) lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
      (dint prng)
      (DStr
        ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) refl)) (steps ((rewrite (premise hwa) lr lhs true ()))) "))))

;; the IH's group-A discharges, Int-return: lg_sum_lo (+ get_lo) at r,
;; stride-shaped elsewhere
(fn li_los ((pf (List LStr)) (r Int) (i Int) (p Int)) Doc
  (measure (struct pf))
  (match pf
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (if (int_eq i r)
           (dconc
             (list
               (DStr
                 "(rewrite-with (lemma lg_sum_lo) lr lhs () ((steps ((rewrite (premise ")
               (dint p)
               (DStr
                 ") lr lhs true ())) refl) (rewrite-with (lemma get_lo) lr lhs () () refl)) refl) ")))
           (match h
             ((LSDec)
              (dconc
                (list
                  (DStr
                    "(rewrite-with (lemma lg_dshift) lr lhs () ((steps ((rewrite (premise ")
                  (dint p)
                  (DStr
                    ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) "))))
             (_
               (dconc
                 (list
                   (DStr
                     "(rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise ")
                   (dint p)
                   (DStr ") lr lhs true ())) refl)) refl) "))))))
         (DStr ""))
       (li_los t r (+ i 1) (+ p (if (ls_adv h) 1 0)))))))

;; the IH's group-B discharges, Int-return: lg_sum_shift (+ get_hi) at r,
;; stride-shaped elsewhere
(fn li_shs ((pf (List LStr)) (r Int) (i Int) (p Int) (nap Int)) Doc
  (measure (struct pf))
  (match pf
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (if (ls_adv h)
         (if (int_eq i r)
           (dconc
             (list
               (DStr
                 "(rewrite-with (lemma lg_sum_shift) lr lhs () ((steps ((rewrite (premise ")
               (dint (+ nap p))
               (DStr
                 ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma get_hi) lr lhs () () refl)) refl) ")))
           (match h
             ((LSDec)
              (dconc
                (list
                  (DStr
                    "(rewrite-with (lemma lg_dhi) lr lhs () ((steps ((rewrite (premise ")
                  (dint (+ nap p))
                  (DStr ") lr lhs true ())) refl)) refl) "))))
             (_
               (dconc
                 (list
                   (DStr
                     "(rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise ")
                   (dint (+ nap p))
                   (DStr
                     ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl) "))))))
         (DStr ""))
       (li_shs t r (+ i 1) (+ p (if (ls_adv h) 1 0)) nap)))))

;; pass-through premise steps (theorem -> worker), one per premised accum
(fn lp_pass1 ((bs (List LStr)) (p Int)) Doc
  (measure (struct bs))
  (match bs
    (Nil (DStr ""))
    ((Cons h t)
     (if (ls_adv h)
       (DCat
         (dconc
           (list
             (DStr "(steps ((rewrite (premise ")
             (dint p)
             (DStr ") lr lhs true ())) refl) ")))
         (lp_pass1 t (+ p 1)))
       (lp_pass1 t p)))))

;; the SELF literal as spelled in claims ((inline …) rides the emitted body fn)
(fn lp_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (I32Const 0)))"))))

(fn lp_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (sts (List (Pair Int LVal)))
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr
          "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (eval_loop (S^ ")
        (dint p)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) (inline ")
        nm
        (DStr "_body) (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
        (lp_exits adv 0)
        (DStr ") (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
        (lp_stages nm (lp_occs sts) adv na)
        (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)))) ")
        (match (ls_at adv fa)
          ((LSIncK s)
           (lp_khwk
             (lgs_nm nm s "kM")
             fa
             (+ na (lp_advpos adv fa))
             (lp_advpos adv fa)))
          (_ (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))))
        (lp_hws nm adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (if (lp_has_inc1 adv) (DStr "(unfold lg_adv rhs) ") (DStr ""))
        (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
        (if (lp_has_inck adv) (DStr "(unfold lg_advk rhs) ") (DStr ""))
        (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
        (lp_lo1s nm adv 0)
        (lp_shifts nm adv 0 na)
        (DStr ")) (steps ((compute both))) refl)))))")
        (DStr (nl))))))

(fn lp_thm ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (p4 Int)) Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p4)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lp_self nm n)
        (DStr " restfs) 65536) 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + worker + theorem, one unit per source fn
(fn lp_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (sts (List (Pair Int LVal)))
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lp_code n adv sts))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (I32Const 0))))")
      (DStr (nl))
      (lgs_all nm (lp_incks adv Nil))
      (lp_worker nm mids n adv sts fa p)
      (lp_thm nm mids n adv (+ p 4)))))

;; the Int-return SELF literal: epilogue reads the return accum's local
(fn li_self ((nm Doc) (n Int) (r Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr ")))"))))

;; the Int-return spec-call spelling (rides the worker's exit locals and
;; the theorem's scalar result)
(fn li_spec ((nm Doc) (mids (List Type))) Doc
  (dconc (list (DStr "(") nm (DStr " m0") (pr_args_lead mids) (DStr " k)"))))

(fn li_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (r Int)
   (j Int)
   (fa Int)
   (p Int))
  Doc
  (let ((pf (li_pflags adv r 0)))
    (let ((nap (lp_nadv pf)))
      (dconc
        (list
          (DStr "(claim lgw_")
          nm
          (DStr " (goal (")
          (pr_binds mids 0)
          (DStr
            "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
          (lp_prems_lo pf 0)
          (li_prems_rng adv r 0)
          (DStr ") (= (eval_loop (S^ ")
          (dint p)
          (DStr " (lg_fuel k c)) (MkWModule (Cons ")
          (li_self nm n r)
          (DStr " restfs) 65536) (inline ")
          nm
          (DStr "_body) (list ")
          (pr_args mids 0)
          (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
          (li_exits adv r 0 (li_spec nm mids))
          (DStr
            ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
          (match (ls_at adv j)
            ((LSDec) (lp_dstage (lp_advpos pf j) (+ nap (lp_advpos pf j))))
            (_ (lp_stage (lp_advpos pf j) (+ nap (lp_advpos pf j)))))
          (DStr "(steps ((compute lhs (stop eval_loop lg_fuel)))) ")
          (lp_hwk fa (+ nap (lp_advpos pf fa)) (lp_advpos pf fa))
          (li_hws adv pf 0 nap)
          (li_hwa r j (lp_advpos pf r) (+ nap (lp_advpos pf r)))
          (DStr "(steps ((unfold ")
          nm
          (DStr " rhs) (unfold lg_adv rhs) ")
          (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
          (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
          (li_los pf r 0 0)
          (li_shs pf r 0 0 nap)
          (DStr ")) (steps ((compute both))) refl)))))")
          (DStr (nl)))))))

(fn li_thm
  ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (r Int) (p4 Int))
  Doc
  (let ((pf (li_pflags adv r 0)))
    (let ((nap (lp_nadv pf)))
      (dconc
        (list
          (DStr "(claim lowered_")
          nm
          (DStr " (goal (")
          (pr_binds mids 0)
          (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
          (lp_prems_lo pf 0)
          (li_prems_rng adv r 0)
          (DStr ") (= (call_fn_mem (S^ ")
          (dint p4)
          (DStr " (lg_fuel k c)) (MkWModule (Cons ")
          (li_self nm n r)
          (DStr " restfs) 65536) 0 (list ")
          (pr_args mids 0)
          (DStr " (int_of_nat k)) m0) (Some (Pair ")
          (li_spec nm mids)
          (DStr
            " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
          nm
          (DStr ") lr lhs () (")
          (lp_pass1 pf 0)
          (lp_pass1 pf nap)
          (DStr ")) (steps ((compute both))) refl))")
          (DStr (nl)))))))

(fn li_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (r Int)
   (j Int)
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (li_code n adv r j))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr "))))")
      (DStr (nl))
      (li_worker nm mids n adv r j fa p)
      (li_thm nm mids n adv r (+ p 4)))))

;; ---- the SCAN shape (conditional early exit; probe: scanloop_probe) ----------

;; the twin's self-call args: r advanced, statics passed through
(fn lc_targs ((mids (List Type)) (r Int) (i Int)) Doc
  (measure (struct mids))
  (match mids
    (Nil (DStr ""))
    ((Cons _ t)
     (DCat
       (if (int_eq i r) (dconc (list (DStr " (+ x") (dint i) (DStr " 1)")))
       (dconc (list (DStr " x") (dint i))))
       (lc_targs t r (+ i 1))))))

;; the machine-generated COUNTER TWIN: the budget local's exit value —
;; the first fn the emitter writes with real recursion (spec-side only;
;; gate 3 checks it like any article)
(fn lc_twin ((nm Doc) (mids (List Type)) (r Int) (z Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_kf ((m Mem) ")
      (pr_binds mids 0)
      (DStr
        "(k Nat)) Int (measure (struct k)) (match k (Z 0) ((S k2) (if (int_eq (mem_get m x")
      (dint r)
      (DStr ") ")
      (dint z)
      (DStr ") (int_of_nat (S k2)) (")
      nm
      (DStr "_kf m")
      (lc_targs mids r 0)
      (DStr " k2)))))")
      (DStr (nl)))))

(fn lc_tspec ((nm Doc) (mids (List Type))) Doc
  (dconc (list (DStr "(") nm (DStr "_kf m0") (pr_args_lead mids) (DStr " k)"))))

;; exit locals: r -> the spec call, statics -> xi, counter -> the twin
(fn lc_exits ((mids (List Type)) (r Int) (i Int) (spec Doc) (twin Doc)) Doc
  (measure (struct mids))
  (match mids
    (Nil twin)
    ((Cons _ t)
     (DCat
       (if (int_eq i r) (DCat spec (DStr " "))
       (dconc (list (DStr "x") (dint i) (DStr " "))))
       (lc_exits t r (+ i 1) spec twin)))))

;; the shared head of both condition arms: fuel/eval_loop open, guard
;; decider, the read stage at r, then the flag collapse via the case hyp
(fn lc_arm_head ((r Int)) Doc
  (dconc
    (list
      (DStr
        "(chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (premise 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_a1_ms) lr lhs ((inst c k2)) ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (hyp 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lc_worker ((nm Doc) (mids (List Type)) (n Int) (r Int) (z Int) (p Int)) Doc
  (dconc
    (list
      (DStr "(claim lgw_")
      nm
      (DStr " (goal (")
      (pr_binds mids 0)
      (DStr
        "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) ((= (le 0 x")
      (dint r)
      (DStr ") True) (= (le (+ x")
      (dint r)
      (DStr " (int_of_nat k)) 65536) True)) (= (eval_loop (S^ ")
      (dint p)
      (DStr " (lg_fuel k c)) (MkWModule (Cons ")
      (li_self nm n r)
      (DStr " restfs) 65536) (inline ")
      nm
      (DStr "_body) (list ")
      (pr_args mids 0)
      (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
      (lc_exits mids r 0 (li_spec nm mids) (lc_tspec nm mids))
      (DStr
        ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (case-on (int_eq (mem_get m0 x")
      (dint r)
      (DStr ") ")
      (dint z)
      (DStr ") Bool ((case True ")
      (lc_arm_head r)
      (DStr "(steps ((unfold ")
      nm
      (DStr " rhs) (unfold ")
      nm
      (DStr
        "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()) (rewrite (lemma int_of_nat_succ) lr rhs true ()))) (steps ((compute both))) refl)) (case False ")
      (lc_arm_head r)
      (lp_hwk r 1 0)
      (lp_hw 0 r 1)
      (DStr "(steps ((unfold ")
      nm
      (DStr " rhs) (unfold ")
      nm
      (DStr
        "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()))) (rewrite-with (hyp 1) lr lhs () ((rewrite-with (lemma lg_lo1) lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl)) refl) (rewrite-with (lemma lg_shift) lr lhs () ((steps ((rewrite (premise 1) lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl)) refl))) (steps ((compute both))) refl))))))))")
      (DStr (nl)))))

(fn lc_thm ((nm Doc) (mids (List Type)) (n Int) (r Int) (p4 Int)) Doc
  (dconc
    (list
      (DStr "(claim lowered_")
      nm
      (DStr " (goal (")
      (pr_binds mids 0)
      (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) ((= (le 0 x")
      (dint r)
      (DStr ") True) (= (le (+ x")
      (dint r)
      (DStr " (int_of_nat k)) 65536) True)) (= (call_fn_mem (S^ ")
      (dint p4)
      (DStr " (lg_fuel k c)) (MkWModule (Cons ")
      (li_self nm n r)
      (DStr " restfs) 65536) 0 (list ")
      (pr_args mids 0)
      (DStr " (int_of_nat k)) m0) (Some (Pair ")
      (li_spec nm mids)
      (DStr
        " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
      nm
      (DStr
        ") lr lhs () ((steps ((rewrite (premise 0) lr lhs true ())) refl) (steps ((rewrite (premise 1) lr lhs true ())) refl))) (steps ((compute both))) refl))")
      (DStr (nl)))))

(fn lc_unit ((nm Doc) (mids (List Type)) (n Int) (r Int) (z Int) (p Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lc_code n r z))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 0 (list (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint r)
      (DStr "))))")
      (DStr (nl))
      (lc_twin nm mids r z)
      (lc_worker nm mids n r z p)
      (lc_thm nm mids n r (+ p 4)))))

;; ---- the FLAG shape (two-region comparison; probe: beqloop_probe) ------------
;; bytes_eq: Z arm literal 1, S arm (if (int_eq READ READ) SELF-CALL 0).
;; The machine materializes the result in an EXTRA LOCAL (index n+1):
;; initialized to 1 BEFORE the loop, set to the BEq bit each iteration,
;; exit-tested by I32Eqz — its exit value IS the spec fn (the literals
;; are pinned 1/0 by this encoding). Every advancing accum gets a spec
;; TWIN (nm_t<i>) for its exit local, plus the counter twin (nm_kf).

;; the condition spelling ("m" in twins, "m0" in claims)
(fn lb_cnd ((mv Doc) (a Int) (b Int)) Doc
  (dconc
    (list
      (DStr "(int_eq (mem_get ")
      mv
      (DStr " x")
      (dint a)
      (DStr ") (mem_get ")
      mv
      (DStr " x")
      (dint b)
      (DStr "))"))))

;; the twins' self-call args: advancing accums stepped, statics through
(fn lb_targs ((ss (List LStr)) (i Int)) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (dconc (list (DStr " (+ x") (dint i) (DStr " 1)"))))
         (_ (dconc (list (DStr " x") (dint i)))))
       (lb_targs t (+ i 1))))))

;; accum i's twin: its local's exit value (exit arm returns the OLD value)
(fn lb_twin
  ((nm Doc) (mids (List Type)) (all (List LStr)) (a Int) (b Int) (i Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_t")
      (dint i)
      (DStr " ((m Mem) ")
      (pr_binds mids 0)
      (DStr "(k Nat)) Int (measure (struct k)) (match k (Z x")
      (dint i)
      (DStr ") ((S k2) (if ")
      (lb_cnd (DStr "m") a b)
      (DStr " (")
      nm
      (DStr "_t")
      (dint i)
      (DStr " m")
      (lb_targs all 0)
      (DStr " k2) x")
      (dint i)
      (DStr "))))")
      (DStr (nl)))))

(fn lb_twins
  ((nm Doc)
   (mids (List Type))
   (all (List LStr))
   (ss (List LStr))
   (a Int)
   (b Int)
   (i Int))
  Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc) (lb_twin nm mids all a b i))
         (_ (DStr "")))
       (lb_twins nm mids all t a b (+ i 1))))))

;; the counter twin: the budget local's exit value (exit arm keeps the
;; undecremented count)
(fn lb_ktwin ((nm Doc) (mids (List Type)) (ss (List LStr)) (a Int) (b Int)) Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_kf ((m Mem) ")
      (pr_binds mids 0)
      (DStr "(k Nat)) Int (measure (struct k)) (match k (Z 0) ((S k2) (if ")
      (lb_cnd (DStr "m") a b)
      (DStr " (")
      nm
      (DStr "_kf m")
      (lb_targs ss 0)
      (DStr " k2) (int_of_nat (S k2))))))")
      (DStr (nl)))))

;; exit locals: inc -> its twin, static -> xi, counter -> the counter
;; twin, flag -> the spec call
(fn lb_exits ((ss (List LStr)) (nm Doc) (mids (List Type)) (i Int) (spec Doc))
  Doc
  (measure (struct ss))
  (match ss
    (Nil
      (dconc
        (list
          (DStr "(")
          nm
          (DStr "_kf m0")
          (pr_args_lead mids)
          (DStr " k) ")
          spec)))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc)
          (dconc
            (list
              (DStr "(")
              nm
              (DStr "_t")
              (dint i)
              (DStr " m0")
              (pr_args_lead mids)
              (DStr " k) "))))
         (_ (dconc (list (DStr "x") (dint i) (DStr " ")))))
       (lb_exits t nm mids (+ i 1) spec)))))

;; per-inc-accum twin unfolds for the rhs opening
(fn lb_unfolds ((nm Doc) (ss (List LStr)) (i Int)) Doc
  (measure (struct ss))
  (match ss
    (Nil (DStr ""))
    ((Cons h t)
     (DCat
       (match h
         ((LSInc)
          (dconc
            (list (DStr "(unfold ") nm (DStr "_t") (dint i) (DStr " rhs) "))))
         (_ (DStr "")))
       (lb_unfolds nm t (+ i 1))))))

;; the FLAG SELF literal: extra local + pre-loop init + flag epilogue
(fn lb_self ((nm Doc) (n Int)) Doc
  (dconc
    (list
      (DStr "(MkFunc ")
      (dint (+ n 1))
      (DStr " 1 (list (I32Const 1) (LocalSet ")
      (dint (+ n 1))
      (DStr ") (Block (list (Loop (inline ")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint (+ n 1))
      (DStr ")))"))))

;; the shared head of both condition arms: fuel/eval_loop open, guard
;; decider, the read stages at A and B in code order, then the flag
;; collapse via the case hyp
(fn lb_arm_head ((adv (List LStr)) (a Int) (b Int) (na Int)) Doc
  (dconc
    (list
      (DStr
        "(chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) ")
      (lp_stage (lp_advpos adv a) (+ na (lp_advpos adv a)))
      (lp_stage (lp_advpos adv b) (+ na (lp_advpos adv b)))
      (DStr
        "(steps ((compute lhs (stop eval_loop lg_fuel)) (rewrite (hyp 0) lr lhs true ()) (compute lhs (stop eval_loop lg_fuel)))) "))))

(fn lb_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (a Int)
   (b Int)
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lgw_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr
          "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (eval_loop (S^ ")
        (dint p)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lb_self nm n)
        (DStr " restfs) 65536) (inline ")
        nm
        (DStr "_body) (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k) 1) st m0) (Some (OBr 0 st (list ")
        (lb_exits adv nm mids 0 (li_spec nm mids))
        (DStr
          ") m0)))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (case-on ")
        (lb_cnd (DStr "m0") a b)
        (DStr " Bool ((case True ")
        (lb_arm_head adv a b na)
        (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))
        (lp_hws nm adv 0 0 na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (lb_unfolds nm adv 0)
        (DStr "(unfold ")
        nm
        (DStr
          "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()))) (rewrite-with (hyp 1) lr lhs () (")
        (lp_lo1s nm adv 0)
        (lp_shifts nm adv 0 na)
        (DStr ")) (steps ((compute both))) refl)) (case False ")
        (lb_arm_head adv a b na)
        (DStr "(steps ((unfold ")
        nm
        (DStr " rhs) ")
        (lb_unfolds nm adv 0)
        (DStr "(unfold ")
        nm
        (DStr
          "_kf rhs) (reduce rhs) (rewrite (hyp 0) lr rhs true ()) (rewrite (lemma int_of_nat_succ) lr rhs true ()))) (steps ((compute both))) refl))))))))")
        (DStr (nl))))))

(fn lb_thm ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (p6 Int)) Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p6)
        (DStr " (lg_fuel k c)) (MkWModule (Cons ")
        (lb_self nm n)
        (DStr " restfs) 65536) 0 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair ")
        (li_spec nm mids)
        (DStr
          " m0)))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

(fn lb_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (a Int)
   (b Int)
   (fa Int)
   (p Int))
  Doc
  (dconc
    (list
      (DStr "(fn ")
      nm
      (DStr "_body () (List Instr) (list ")
      (djoin (lb_code n a b adv))
      (DStr "))")
      (DStr (nl))
      (DStr "(fn ")
      nm
      (DStr "_func () Func (MkFunc ")
      (dint (+ n 1))
      (DStr " 1 (list (I32Const 1) (LocalSet ")
      (dint (+ n 1))
      (DStr ") (Block (list (Loop (")
      nm
      (DStr "_body)))) (LocalGet ")
      (dint (+ n 1))
      (DStr "))))")
      (DStr (nl))
      (lb_twins nm mids adv adv a b 0)
      (lb_ktwin nm mids adv a b)
      (lb_worker nm mids n adv a b fa p)
      (lb_thm nm mids n adv (+ p 6)))))

;; ---- calls-in-loops (LRCall; probe: examples/callloop_probe.shard) -----------
;;
;; A Mem-return loop whose per-iteration work is a CALL to an earlier
;; same-file mem-fragment fn. STRUCTURAL form only (the §6f portability
;; limit): the callee's literal rides the module spine and its linked
;; cert is cited inside the S case at the iteration's fuel, so this unit
;; is emitted into the LINKED file and regenerates on callee edits. The
;; callee's return value is discarded by Drop (the re-entry stack equals
;; the entry stack — no scratch local, no return twin); its premises are
;; discharged from the loop's scaled range premises through generated
;; clh_* helper claims with computed farkas lists (the §6j discipline;
;; upper bounds (1 1 C C), lower bounds (1 1), C = the address
;; accumulator's stride).

;; index of x<i> among the loop's (or callee's) canonical param symbols
(fn xsym_idx ((s Symbol) (n Int) (i Int)) (Option Int)
  (measure (- n i))
  (if (le n i) None (if (sym_eq s (xsym i)) (Some i) (xsym_idx s n (+ i 1)))))

(fn lk_at ((ks (List LKArg)) (j Int)) (Option LKArg)
  (measure (struct ks))
  (match ks
    (Nil None)
    ((Cons h t) (if (int_eq j 0) (Some h) (lk_at t (- j 1))))))

;; instantiate a callee-frame expr at the call site: callee param x<j>
;; becomes the site's argument (a loop accum x<i> or a literal)
(fn lk_subst ((e Expr) (ks (List LKArg)) (ncal Int)) Expr
  (measure (struct e))
  (match e
    ((FVar s)
     (match (xsym_idx s ncal 0)
       ((Some j)
        (match (lk_at ks j)
          ((Some a)
           (match a
             ((LKAcc i) (FVar (xsym i)))
             ((LKLit l) (IntLit l))))
          (None e)))
       (None e)))
    ((Call q as) (Call q (lk_subst_l as ks ncal)))
    (_ e)))

(fn lk_subst_l ((es (List Expr)) (ks (List LKArg)) (ncal Int)) (List Expr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons e t) (Cons (lk_subst e ks ncal) (lk_subst_l t ks ncal)))))

;; linear form of an instantiated bound expr: one accum atom plus
;; literal offsets ((+ E L) nests), or fully ground
(type LKLin (LKLAcc Int Int) (LKLGround) (LKLBad))

(fn lk_lin ((e Expr) (n Int)) LKLin
  (measure (struct e))
  (match e
    ((FVar s)
     (match (xsym_idx s n 0)
       ((Some i) (LKLAcc i 0))
       (None (LKLBad))))
    ((IntLit _) (LKLGround))
    ((Call q as)
     (if (core_named q (quote +))
       (match as
         ((Cons a (Cons b Nil))
          (match b
            ((IntLit l)
             (match (lk_lin a n)
               ((LKLAcc i j) (LKLAcc i (+ j l)))
               ((LKLGround) (LKLGround))
               ((LKLBad) (LKLBad))))
            (_ (LKLBad))))
         (_ (LKLBad)))
       (LKLBad)))
    (_ (LKLBad))))

;; how one callee premise discharges at the loop site
(type LKD
  (LKDirect Int)
  (LKGround)
  (LKLo Int)
  (LKUp Int)
  (LKW32 Int)
  (LKBad (List Int)))

(fn lk_stride1 ((adv (List LStr)) (i Int)) (Option Int)
  (match (ls_at adv i)
    ((LSInc) (Some 1))
    ((LSIncK s) (Some s))
    (_ None)))

(fn lk_disch ((cp CPre) (ks (List LKArg)) (adv (List LStr)) (ncal Int) (n Int))
  LKD
  (let ((b (lk_subst (cpre_bound cp) ks ncal)))
    (match (lk_lin b n)
      ((LKLGround) (LKGround))
      ((LKLBad)
       (LKBad
         "callee premise is not linear (one accumulator plus literal offsets) at the call site (v1)"))
      ((LKLAcc i j)
       (match (lk_stride1 adv i)
         (None
           (LKBad
             "callee premises may only touch INCREMENTING loop accumulators (v1)"))
         ((Some cs)
          (if (lt j 0)
            (LKBad "callee premise has a negative offset at the call site")
            (match cp
              ((CPLo _) (if (int_eq j 0) (LKDirect (lp_advpos adv i)) (LKLo i)))
              ((CPWLo _)
               (if (int_eq j 0) (LKDirect (lp_advpos adv i)) (LKLo i)))
              ((CPHi _)
               (if (le (+ j 1) cs) (LKUp i)
               (LKBad
                 "callee footprint exceeds the address accumulator's stride")))
              ((CPWHi _) (LKW32 i))))))))))

;; loud pre-scan: the first LKBad message, if any
(fn lk_check
  ((cps (List CPre)) (ks (List LKArg)) (adv (List LStr)) (ncal Int) (n Int))
  (Option (List Int))
  (measure (struct cps))
  (match cps
    (Nil None)
    ((Cons cp t)
     (match (lk_disch cp ks adv ncal n)
       ((LKBad m) (Some m))
       (_ (lk_check t ks adv ncal n))))))

;; print a bound expr with the atom accum spelled as the helper binder a
(fn lk_pra ((e Expr) (ai Int)) Doc
  (measure (struct e))
  (match e
    ((FVar s) (if (sym_eq s (xsym ai)) (DStr "a") (dsym s)))
    ((IntLit l) (dint l))
    ((Call q as)
     (match as
       ((Cons a (Cons b Nil))
        (dcat3
          (dcat3 (DStr "(") (dsym (qn_name q)) (sp))
          (DCat (lk_pra a ai) (sp))
          (DCat (lk_pra b ai) (DStr ")"))))
       (_ (DStr "?"))))
    (_ (DStr "?"))))

(fn clh_nm ((fnm Doc) (p Int)) Doc
  (dconc (list (DStr "clh_") fnm (DStr "_") (dint p))))

;; the scaled-range premise tail at stride cs (stride 1 has no (*))
(fn lk_rngtail ((cs Int)) Doc
  (if (int_eq cs 1) (DStr "(int_of_nat (S c))")
  (dconc (list (DStr "(* ") (dint cs) (DStr " (int_of_nat (S c)))")))))

;; one generated helper claim: the callee's premise at the site,
;; over the helper binder a, from the atom accum's loop premises
(fn lk_clh1 ((fnm Doc) (p Int) (d LKD) (b Expr) (adv (List LStr))) Doc
  (match d
    ((LKLo i)
     (dconc
       (list
         (DStr "(claim ")
         (clh_nm fnm p)
         (DStr " (goal ((a Int)) ((= (le 0 a) True)) (= (le 0 ")
         (lk_pra b i)
         (DStr ") True)) (by arith (list 1 1)))")
         (DStr (nl)))))
    ((LKUp i)
     (match (lk_stride1 adv i)
       ((Some cs)
        (dconc
          (list
            (DStr "(claim ")
            (clh_nm fnm p)
            (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a ")
            (lk_rngtail cs)
            (DStr
              ") 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (le (+ ")
            (lk_pra b i)
            (DStr " 1) 65536) True)) (by arith (list 1 1 ")
            (dint cs)
            (DStr " ")
            (dint cs)
            (DStr ")))")
            (DStr (nl)))))
       (None (DStr ""))))
    ((LKW32 i)
     (match (lk_stride1 adv i)
       ((Some cs)
        (dconc
          (list
            (DStr "(claim ")
            (clh_nm fnm p)
            (DStr " (goal ((a Int) (c Nat)) ((= (le (+ a ")
            (lk_rngtail cs)
            (DStr
              ") 65536) True) (= (int_of_nat (S c)) (+ 1 (int_of_nat c))) (= (le 0 (int_of_nat c)) True)) (= (lt ")
            (lk_pra b i)
            (DStr " 4294967296) True)) (by arith (list 1 1 ")
            (dint cs)
            (DStr " ")
            (dint cs)
            (DStr ")))")
            (DStr (nl)))))
       (None (DStr ""))))
    (_ (DStr ""))))

(fn lk_clhs
  ((fnm Doc)
   (cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (lk_clh1
         fnm
         p
         (lk_disch cp ks adv ncal n)
         (lk_subst (cpre_bound cp) ks ncal)
         adv)
       (lk_clhs fnm t ks adv ncal n (+ p 1))))))

;; the hoisted haves, one per helper-discharged premise, in premise order
(fn lk_have1 ((fnm Doc) (p Int) (d LKD) (b Expr) (adv (List LStr)) (na Int)) Doc
  (match d
    ((LKLo i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (le 0 ")
         (pr_e b)
         (DStr ") True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs () ((steps ((rewrite (premise ")
         (dint (lp_advpos adv i))
         (DStr ") lr lhs true ())) refl)) refl)) "))))
    ((LKUp i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (le (+ ")
         (pr_e b)
         (DStr " 1) 65536) True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
         (dint (+ na (lp_advpos adv i)))
         (DStr
           ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) "))))
    ((LKW32 i)
     (dconc
       (list
         (DStr "(have hcp")
         (dint p)
         (DStr " (= (lt ")
         (pr_e b)
         (DStr " 4294967296) True) (rewrite-with (lemma ")
         (clh_nm fnm p)
         (DStr ") lr lhs ((inst c k2)) ((steps ((rewrite (premise ")
         (dint (+ na (lp_advpos adv i)))
         (DStr
           ") lr lhs true ())) refl) (steps ((rewrite (lemma int_of_nat_succ) lr lhs true ())) refl) (rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl)) refl)) "))))
    (_ (DStr ""))))

(fn lk_haves
  ((fnm Doc)
   (cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (na Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (lk_have1
         fnm
         p
         (lk_disch cp ks adv ncal n)
         (lk_subst (cpre_bound cp) ks ncal)
         adv
         na)
       (lk_haves fnm t ks adv ncal n na (+ p 1))))))

;; the callee-cert citation subproofs, one per premise, premise order
(fn lk_cites
  ((cps (List CPre))
   (ks (List LKArg))
   (adv (List LStr))
   (ncal Int)
   (n Int)
   (p Int))
  Doc
  (measure (struct cps))
  (match cps
    (Nil (DStr ""))
    ((Cons cp t)
     (DCat
       (match (lk_disch cp ks adv ncal n)
         ((LKDirect ix)
          (dconc
            (list
              (DStr "(steps ((rewrite (premise ")
              (dint ix)
              (DStr ") lr lhs true ())) refl) "))))
         ((LKGround) (DStr "(steps ((compute both)) refl) "))
         (_
           (dconc
             (list
               (DStr "(steps ((rewrite (premise hcp")
               (dint p)
               (DStr ") lr lhs true ())) refl) ")))))
       (lk_cites t ks adv ncal n (+ p 1))))))

;; call-site argument docs (site spelling / machine code)
(fn lk_argdoc ((k LKArg)) Doc
  (match k
    ((LKAcc i) (dcat3 (DStr "x") (dint i) (DStr "")))
    ((LKLit l) (dint l))))

(fn lk_argcode ((ks (List LKArg))) (List Doc)
  (measure (struct ks))
  (match ks
    (Nil Nil)
    ((Cons h t)
     (Cons
       (match h
         ((LKAcc i) (lp_lget i))
         ((LKLit l) (lp_const l)))
       (lk_argcode t)))))

(fn lk_conses ((ks (List LKArg))) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr "Nil"))
    ((Cons h t)
     (dcat3
       (DCat (DStr "(Cons ") (lk_argdoc h))
       (DCat (sp) (lk_conses t))
       (DStr ")")))))

(fn lk_rev ((ks (List LKArg)) (acc (List LKArg))) (List LKArg)
  (measure (struct ks))
  (match ks
    (Nil acc)
    ((Cons h t) (lk_rev t (Cons h acc)))))

;; the spec work application (the source S arm's spelling)
(fn lk_specwork ((cnm Symbol) (ks (List LKArg))) Doc
  (dcat3 (dcat3 (DStr "(") (dsym cnm) (DStr " m0")) (lk_specargs ks) (DStr ")")))

(fn lk_specargs ((ks (List LKArg))) Doc
  (measure (struct ks))
  (match ks
    (Nil (DStr ""))
    ((Cons h t) (dcat3 (sp) (lk_argdoc h) (lk_specargs t)))))

;; the return-value doc: the callee's Pair value slot at the site
(fn lk_retdoc ((ce Expr) (ks (List LKArg)) (ncal Int)) (Option Doc)
  (match ce
    ((FVar s)
     (match (xsym_idx s ncal 0)
       ((Some j)
        (match (lk_at ks j)
          ((Some a) (Some (lk_argdoc a)))
          (None None)))
       (None None)))
    ((IntLit l) (Some (dint l)))
    (_ None)))

;; the bridge stage: call_bridge + the callee's linked cert
(fn lk_bridge
  ((cnm Symbol)
   (cself Doc)
   (ks (List LKArg))
   (vdoc Doc)
   (cps (List CPre))
   (adv (List LStr))
   (ncal Int)
   (n Int))
  Doc
  (dconc
    (list
      (DStr "(rewrite-with (lemma call_bridge) lr lhs ((inst f ")
      cself
      (DStr ") (inst popped ")
      (lk_conses (lk_rev ks Nil))
      (DStr ") (inst rest st) (inst args ")
      (lk_conses ks)
      (DStr ") (inst v ")
      vdoc
      (DStr ") (inst mem2 ")
      (lk_specwork cnm ks)
      (DStr
        ")) ((steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) (rewrite-with (lemma linked_")
      (dsym cnm)
      (DStr ") lr lhs () (")
      (lk_cites cps ks adv ncal n 0)
      (DStr ") refl))) "))))

;; guard / arg pushes / Call 2 / Drop / advances / decrement / re-enter
;; (instrs = 8 + (nargs + 2) + 4*nAdv)
(fn lk_code ((n Int) (adv (List LStr)) (ks (List LKArg))) (List Doc)
  (dapp
    (list (lp_lget n) (DStr "(I32Eqz)") (DStr "(BrIf 1)"))
    (dapp
      (lk_argcode ks)
      (dapp
        (list (DStr "(Call 2)") (DStr "(Drop)"))
        (dapp
          (lp_advcode adv 0)
          (list
            (lp_lget n)
            (lp_const 1)
            (DStr "(I32Bin BSub)")
            (lp_lset n)
            (DStr "(Br 0)")))))))

;; the 4-slot module spine: [mget, mset, callee, self | restfs]
(fn lk_mod ((nm Doc) (n Int) (cself Doc)) Doc
  (dconc
    (list
      (DStr "(MkWModule (Cons ")
      (mget_lit)
      (DStr " (Cons ")
      (mset_lit)
      (DStr " (Cons ")
      cself
      (DStr " (Cons ")
      (lp_self nm n)
      (DStr " restfs)))) 65536)"))))

(fn lk_worker
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ci CInfo)
   (ks (List LKArg))
   (vdoc Doc)
   (fa Int)
   (p Int))
  Doc
  (let ((na (lp_nadv adv)))
    (match ci
      ((MkCInfo cnm cself _ ncal cps _)
       (dconc
         (list
           (DStr "(claim lgw_")
           nm
           (DStr " (goal (")
           (pr_binds mids 0)
           (DStr
             "(st (List Int)) (m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
           (lp_prems_lo adv 0)
           (lp_prems_rng adv 0)
           (DStr ") (= (eval_loop (S^ ")
           (dint p)
           (DStr " (lg_fuel k c)) ")
           (lk_mod nm n cself)
           (DStr " (inline ")
           nm
           (DStr "_body) (list ")
           (pr_args mids 0)
           (DStr " (int_of_nat k)) st m0) (Some (OBr 0 st (list ")
           (lp_exits adv 0)
           (DStr ") (")
           nm
           (DStr " m0")
           (pr_args_lead mids)
           (DStr
             " k))))) (induct k ((case Z (steps ((rewrite (lemma int_of_nat_zero) lr lhs true ()) (compute both)) refl)) (case S (k2) (chain (steps ((unfold lg_fuel lhs) (reduce lhs) (unfold eval_loop lhs) (rewrite (lemma int_of_nat_succ) lr lhs true ()) (compute lhs (stop eval_call eval_loop lg_fuel)))) (rewrite-with (lemma lg_ne) lr lhs () ((rewrite-with (lemma int_of_nat_nonneg) lr lhs () () refl))) (steps ((compute lhs (stop eval_call eval_loop lg_fuel)))) ")
           (lk_haves nm cps ks adv ncal n na 0)
           (lk_bridge cnm cself ks vdoc cps adv ncal n)
           (DStr "(steps ((compute lhs (stop eval_call eval_loop lg_fuel)))) ")
           (match (ls_at adv fa)
             ((LSIncK s)
              (lp_khwk
                (lgs_nm nm s "kM")
                fa
                (+ na (lp_advpos adv fa))
                (lp_advpos adv fa)))
             (_ (lp_hwk fa (+ na (lp_advpos adv fa)) (lp_advpos adv fa))))
           (lp_hws nm adv 0 0 na)
           (DStr "(steps ((unfold ")
           nm
           (DStr " rhs) ")
           (if (lp_has_inc1 adv) (DStr "(unfold lg_adv rhs) ") (DStr ""))
           (if (lp_has_dec adv) (DStr "(unfold lg_dec rhs) ") (DStr ""))
           (if (lp_has_inck adv) (DStr "(unfold lg_advk rhs) ") (DStr ""))
           (DStr "(reduce rhs))) (rewrite-with (hyp 0) lr lhs () (")
           (lp_lo1s nm adv 0)
           (lp_shifts nm adv 0 na)
           (DStr ")) (steps ((compute both))) refl)))))")
           (DStr (nl))))))))

(fn lk_thm
  ((nm Doc) (mids (List Type)) (n Int) (adv (List LStr)) (cself Doc) (p4 Int))
  Doc
  (let ((na (lp_nadv adv)))
    (dconc
      (list
        (DStr "(claim lowered_")
        nm
        (DStr " (goal (")
        (pr_binds mids 0)
        (DStr "(m0 Mem) (c Nat) (k Nat) (restfs (List Func))) (")
        (lp_prems_lo adv 0)
        (lp_prems_rng adv 0)
        (DStr ") (= (call_fn_mem (S^ ")
        (dint p4)
        (DStr " (lg_fuel k c)) ")
        (lk_mod nm n cself)
        (DStr " 3 (list ")
        (pr_args mids 0)
        (DStr " (int_of_nat k)) m0) (Some (Pair 0 (")
        nm
        (DStr " m0")
        (pr_args_lead mids)
        (DStr
          " k))))) (chain (steps ((compute lhs (stop eval_loop lg_fuel)))) (rewrite-with (lemma lgw_")
        nm
        (DStr ") lr lhs () (")
        (lp_pass1 adv 0)
        (lp_pass1 adv na)
        (DStr ")) (steps ((compute both))) refl))")
        (DStr (nl))))))

;; body/func fns + stride kit + premise helpers + worker + theorem —
;; the whole unit lands in the LINKED file (callee literals inside)
(fn lk_unit
  ((nm Doc)
   (mids (List Type))
   (n Int)
   (adv (List LStr))
   (ci CInfo)
   (ks (List LKArg))
   (vdoc Doc)
   (fa Int)
   (p Int))
  Doc
  (match ci
    ((MkCInfo _ cself _ ncal cps _)
     (dconc
       (list
         (DStr "(fn ")
         nm
         (DStr "_body () (List Instr) (list ")
         (djoin (lk_code n adv ks))
         (DStr "))")
         (DStr (nl))
         (DStr "(fn ")
         nm
         (DStr "_func () Func (MkFunc ")
         (dint (+ n 1))
         (DStr " 0 (list (Block (list (Loop (")
         nm
         (DStr "_body)))) (I32Const 0))))")
         (DStr (nl))
         (lgs_all nm (lp_incks adv Nil))
         (lk_clhs nm cps ks adv ncal n 0)
         (lk_worker nm mids n adv ci ks vdoc fa p)
         (lk_thm nm mids n adv cself (+ p 4)))))))

(fn emit_claim_loop ((f FnDef) (reg (List CInfo))) CRes
  (match f
    ((FnDef q ts rty body)
     (match ts
       ((Cons _ rest)
        (match (ts_lasto rest)
          ((Some lt)
           (if (is_nat_ty lt)
             (let ((mids (ts_mids rest)))
               (if (all_int mids)
                 (let ((n (count_ts mids)))
                   (if (lt 0 n)
                     (if (is_mem_ty rty)
                       (match (lp_recognize q n body reg)
                         ((LRErr m) (cerr_at q m))
                         ((LRCall adv cnm ks)
                          (match (reg_find reg cnm)
                            (None
                              (cerr_at
                                q
                                "loop call target must be an EARLIER same-file mem-fragment fn"))
                            ((Some ci)
                             (match ci
                               ((MkCInfo _ _ cnn ncal cps ce)
                                (match (lp_first_inc adv 0)
                                  (None
                                    (cerr_at
                                      q
                                      "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                                  ((Some fa)
                                   (match (lk_retdoc ce ks ncal)
                                     (None
                                       (cerr_at
                                         q
                                         "callee's return value must be a parameter or a u32 literal (v1) -- read-returning callees do not ride the loop template yet"))
                                     ((Some vdoc)
                                      (match (lk_check cps ks adv ncal n)
                                        ((Some m) (cerr_at q m))
                                        (None
                                          (let
                                            ((cnt
                                               (+
                                                 8
                                                 (+
                                                   (+ (lk_nargs ks) 2)
                                                   (* 4 (lp_nadv adv))))))
                                            (COkC
                                              (lk_unit
                                                (dsym (qn_name q))
                                                mids
                                                n
                                                adv
                                                ci
                                                ks
                                                vdoc
                                                fa
                                                (+ cnt (+ 4 (+ (* 2 cnn) 1)))))))))))))))))
                         ((LROk adv sts)
                          (match (lp_first_inc adv 0)
                            (None
                              (cerr_at
                                q
                                "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                            ((Some fa)
                             (let
                               ((cnt
                                  (+ 8 (+ (lp_stlen sts) (* 4 (lp_nadv adv))))))
                               (COk
                                 (lp_unit
                                   (dsym (qn_name q))
                                   mids
                                   n
                                   adv
                                   sts
                                   fa
                                   (+ cnt 4))
                                 (DStr "")))))))
                     (if (is_int_ty rty)
                       (match (li_recognize q n body)
                         ((LIErr m) (cerr_at q m))
                         ((LCOk adv r z)
                          (COk
                            (lc_unit
                              (dsym (qn_name q))
                              mids
                              n
                              r
                              z
                              (if (int_eq z 0) 20 21))
                            (DStr "")))
                         ((LBOk adv a b)
                          (match (lp_first_inc adv 0)
                            (None
                              (cerr_at
                                q
                                "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                            ((Some fa)
                             (let ((cnt (+ 17 (* 4 (lp_nadv adv)))))
                               (COk
                                 (lb_unit
                                   (dsym (qn_name q))
                                   mids
                                   n
                                   adv
                                   a
                                   b
                                   fa
                                   (+ cnt 4))
                                 (DStr ""))))))
                         ((LIOk adv r j)
                          (if (lp_has_inck adv)
                            (cerr_at
                              q
                              "stride != 1 is Mem-return-loop-only in v1 (Int-return loops keep +-1 accums)")
                            (match (lp_first_inc adv 0)
                              (None
                                (cerr_at
                                  q
                                  "v1: at least one (+ ACCUM 1) accumulator is required (the counter wrap rides its range premise)"))
                              ((Some fa)
                               (let ((cnt (+ 13 (* 4 (lp_nadv adv)))))
                                 (COk
                                   (li_unit
                                     (dsym (qn_name q))
                                     mids
                                     n
                                     adv
                                     r
                                     j
                                     fa
                                     (+ cnt 4))
                                   (DStr ""))))))))
                       (cerr_at q "loop fn must return Mem or Int")))
                     (cerr_at q "loop fn needs at least one Int accumulator")))
                 (cerr_at q "loop accumulators must all be Int")))
             (cerr_at q "loop fn's last param must be the Nat counter")))
          (None (cerr_at q "loop fn needs (m Mem) (accums Int...) (k Nat)"))))
       (Nil (cerr_at q "loop fn needs params"))))))

;; ---- claim emission ----------------------------------------------------------


;; COk = portable + linked docs (linked used only for mem fns);
;; COkM = a mem fn, carrying its callee-registry entry (None when the fn
;; is not a valid loop callee — Int return);
;; COkC = a calls-in-loops unit, resident in the LINKED file
(type CRes
  (COk Doc Doc)
  (COkM Doc Doc (Option CInfo))
  (COkC Doc)
  (CErr (List Int)))

(fn cerr_at ((q QName) (m (List Int))) CRes
  (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))


;; the PORTABLE claim (the primary cert): module abstract, callee slots
;; abstract binders, premises = spine + arities + the item list. The
;; callee bytes appear NOWHERE — a callee edit leaves this file byte-
;; identical; only the linked derivation regenerates.
(fn m_claim_port
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc)
   (prf Doc)
   (evd Doc))
  Doc
  (dcat3
    (dcat3
      (dcat3
        (DStr "(claim lowered_")
        (dsym (qn_name q))
        (dcat3
          (DStr " (goal (")
          (pr_binds ints 0)
          (DStr
            "(m0 Mem) (m WModule) (f0 Func) (f1 Func) (restm (List Func)) (c Nat)) ((= (funcs_of m) (Cons f0 (Cons f1 (Cons ")))
      (DCat self (DStr " restm)))) (= (params_of f0) 1) (= (params_of f1) 2) "))
      (pits_prems pres))
    (dcat3
      (dcat3 (DStr ") (= (call_fn_mem (S^ ") (dint nn) (DStr " c) m 2 (list "))
      (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
      (dcat3
        (dcat3
          (DStr
            ")) (chain (steps ((compute lhs (stop eval_call funcs_of)) (rewrite (premise 0) lr lhs true ()) (unfold ")
          (dsym (qn_name q))
          (DStr " rhs) (reduce rhs))) "))
        prf
        (DStr "(steps ((compute lhs))) ")))
    (dcat3 evd (DStr "refl))") (DStr (nl)))))

;; ---- the LINKED derivation (the artifact form, derived by citation) ------------

;; address classification (PRE hygiene §6j): a ground literal's bound
;; pair computes; a read-linear address whose interval fits [0, 65535]
;; derives via a generated ab_* helper; anything else keeps its premise
;; pair. np / nr = the running premise-pair / helper ordinals.
(fn classify_addrs ((as (List Expr)) (np Int) (nr Int)) (List AC)
  (measure (struct as))
  (match as
    (Nil Nil)
    ((Cons a t)
     (match (pl_e a True)
       (None (Cons (ACPrem np) (classify_addrs t (+ np 1) nr)))
       ((Some p)
        (match (pl_atoms p)
          (Nil (Cons ACGround (classify_addrs t np nr)))
          (_
            (if (le 0 (pl_lo p))
              (if (le (+ (pl_hi p) 1) 65536)
                (Cons (ACRead nr (pl_atoms p)) (classify_addrs t np (+ nr 1)))
                (Cons (ACPrem np) (classify_addrs t (+ np 1) nr)))
              (Cons (ACPrem np) (classify_addrs t (+ np 1) nr))))))))))

(fn ac_nprem ((acs (List AC))) Int
  (measure (struct acs))
  (match acs
    (Nil 0)
    ((Cons h t)
     (match h
       ((ACPrem _) (+ 1 (ac_nprem t)))
       (_ (ac_nprem t))))))

;; the linked cert's premises as CPre items, EXACTLY the order the
;; linked claim declares them (link_addr_prems2 then link_wrap_prems) —
;; the calls-in-loops walk consumes these; any drift between the two
;; enumerations fails the kernel gate loudly at the citation subproofs
(fn cpre_addrs ((as (List Expr)) (acs (List AC))) (List CPre)
  (measure (struct as))
  (match as
    (Nil Nil)
    ((Cons a t)
     (match acs
       (Nil Nil)
       ((Cons ac acst)
        (match ac
          ((ACPrem _) (Cons (CPLo a) (Cons (CPHi a) (cpre_addrs t acst))))
          (_ (cpre_addrs t acst))))))))

(fn cpre_wraps ((ps (List PItem))) (List CPre)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons h t)
     (match h
       ((PWrap e) (Cons (CPWLo e) (Cons (CPWHi e) (cpre_wraps t))))
       (_ (cpre_wraps t))))))

(fn cpre_app ((a (List CPre)) (b (List CPre))) (List CPre)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (cpre_app t b)))))

;; the linked cert's address premises: one pair per ACPrem address only
(fn link_addr_prems2 ((as (List Expr)) (acs (List AC))) Doc
  (measure (struct as))
  (match as
    (Nil (DStr ""))
    ((Cons a t)
     (match acs
       (Nil (DStr ""))
       ((Cons ac acst)
        (match ac
          ((ACPrem _)
           (dcat3
             (dcat3 (DStr "(= (le 0 ") (pr_e a) (DStr ") True) "))
             (dcat3 (DStr "(= (le (+ ") (pr_e a) (DStr " 1) 65536) True) "))
             (link_addr_prems2 t acst)))
          (_ (link_addr_prems2 t acst))))))))

;; the generated address-bound helper claims, one lo/hi pair per ACRead
(fn ab_claims ((as (List Expr)) (acs (List AC)) (fnm Doc)) Doc
  (measure (struct as))
  (match as
    (Nil (DStr ""))
    ((Cons a t)
     (match acs
       (Nil (DStr ""))
       ((Cons ac acst)
        (match ac
          ((ACRead k rs)
           (dcat3
             (iv_claim
               (ab_name fnm k True)
               rs
               (bnd_le0 (pr_e (subst_reads a rs)))
               (iv_lo_mults rs))
             (iv_claim
               (ab_name fnm k False)
               rs
               (bnd_leaddr (pr_e (subst_reads a rs)))
               (iv_hi_mults rs))
             (ab_claims t acst fnm)))
          (_ (ab_claims t acst fnm))))))))


;; the LINKED claim: the structural artifact statement, proven by ONE
;; citation of the portable cert (zero interpreter steps)
(fn m_claim_link
  ((q QName)
   (ints (List Type))
   (nn Int)
   (self Doc)
   (pres (List PItem))
   (rhs Doc))
  Doc
  (let ((as (addrs_of pres Nil)))
    (let ((acs (classify_addrs as 0 0)))
      (dcat3
        (DCat
          (ab_claims as acs (dsym (qn_name q)))
          (dcat3
            (dcat3
              (DStr "(claim linked_")
              (dsym (qn_name q))
              (dcat3
                (DStr " (goal (")
                (pr_binds ints 0)
                (DStr "(m0 Mem) (c Nat) (restfs (List Func))) (")))
            (DCat (link_addr_prems2 as acs) (link_wrap_prems pres))
            (dcat3
              (dcat3
                (DStr ") (= (call_fn_mem (S^ ")
                (dint nn)
                (DStr " c) (MkWModule (Cons "))
              (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
              (dcat3
                (DCat (DStr " (Cons ") self)
                (DStr " restfs))) 65536) 2 (list ")
                (DStr "")))))
        (dcat3
          (dcat3 (pr_args ints 0) (DStr ") m0) ") rhs)
          (dcat3
            (dcat3
              (DStr ")) (chain (rewrite-with (lemma lowered_")
              (dsym (qn_name q))
              (DStr ") lr lhs ((inst m (MkWModule (Cons "))
            (dcat3 (mget_lit) (DStr " (Cons ") (mset_lit))
            (dcat3
              (DCat (DStr " (Cons ") self)
              (DStr " restfs))) 65536)) (inst f0 ")
              (DStr "")))
          (dcat3
            (dcat3 (mget_lit) (DStr ") (inst f1 ") (mset_lit))
            (DStr
              ") (inst restm restfs)) ((steps ((compute both)) refl) (steps ((compute both)) refl) (steps ((compute both)) refl) ")
            (link_subs
              pres
              as
              acs
              (* 2 (ac_nprem acs))
              0
              "lowered_mem_get"
              "lowered_mem_set"
              (dsym (qn_name q)))))
        (dcat3 (DStr ")) refl))") (DStr (nl)) (DStr ""))))))

;; dispatch by return type, shared by both passes
(fn mg_walk ((n Int) (nn Int) (fnm Doc) (rty Type) (body Expr)) MRes
  (let ((st0 (MkMSt Nil 0 (- n 1) Nil (DStr "") 0 Nil Nil 0 0 (m0v))))
    (if (is_int_ty rty) (mg_e n nn fnm Nil st0 body)
    (if (is_mem_ty rty) (mg_tail n nn fnm Nil st0 body)
    (MErr "return type must be Int or Mem")))))

;; the generated read-interval helper claims, one lo/hi pair per PAuto
;; node (ordinals in discovery order — paut_ix's order)
(fn wb_claims ((ps (List PItem)) (fnm Doc) (k Int)) Doc
  (measure (struct ps))
  (match ps
    (Nil (DStr ""))
    ((Cons h t)
     (match h
       ((PAuto e)
        (let
          ((rs
             (match (pl_e e True)
               ((Some p) (pl_atoms p))
               (None Nil))))
          (dcat3
            (iv_claim
              (wb_name fnm k True)
              rs
              (bnd_le0 (pr_e (subst_reads e rs)))
              (iv_lo_mults rs))
            (iv_claim
              (wb_name fnm k False)
              rs
              (bnd_ltwrap (pr_e (subst_reads e rs)))
              (iv_hi_mults rs))
            (wb_claims t fnm (+ k 1)))))
       (_ (wb_claims t fnm k))))))

;; TWO-PASS: behavior premises embed site fuels, which depend on the
;; total tower — pass 1 counts, pass 2 emits. Budget: each call site is
;; charged 2x its callee's tower + 1 (callee growth within 2x relinks
;; without touching this cert).
(fn emit_claim_mem ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (match ts
       (Nil (cerr_at q "no params"))
       ((Cons _ ints)
        (if (all_int ints)
          (let ((n (count_ts ts)))
            (match (mg_walk n 0 (dsym (qn_name q)) rty body)
              ((MErr m) (cerr_at q m))
              ((MOk st1 ce1)
               (match st1
                 ((MkMSt cd1 cnt1 nx1 sk1 pf1 j1 pr1 pd1 gets1 sets1 mm1)
                  (if (int_eq (+ gets1 sets1) 0)
                    (cerr_at
                      q
                      "no memory operations (use the scalar fragment: drop the Mem param)")
                  (if
                    (if (is_int_ty rty)
                      (if (chars_eq (spell mm1) (spell (m0v))) False True)
                      False)
                    (cerr_at
                      q
                      "stores in an Int-returning fn (the schema pins its memory unchanged) -- return Mem")
                    (let
                      ((nn (+ (* 2 cnt1) (+ 3 (+ (* 13 gets1) (* 21 sets1))))))
                      (match (mg_walk n nn (dsym (qn_name q)) rty body)
                        ((MErr m) (cerr_at q m))
                        ((MOk st ce)
                         (match st
                           ((MkMSt code cnt nxt stk prf j pres pend gets sets
                              mmf)
                            (match (m_flush pend pres (dsym (qn_name q)) j)
                              ((Pair evd _)
                               (let ((self (m_self_lit n nxt code)))
                                 (let ((rhs (m_rhs q ints rty ce)))
                                   (COkM
                                     (DCat
                                       (wb_claims pres (dsym (qn_name q)) 0)
                                       (m_claim_port q ints nn self pres rhs prf
                                         evd))
                                     (m_claim_link q ints nn self pres rhs)
                                     (if (is_mem_ty rty)
                                       (let ((as2 (addrs_of pres Nil)))
                                         (Some
                                           (MkCInfo
                                             (qn_name q)
                                             self
                                             nn
                                             (- n 1)
                                             (cpre_app
                                               (cpre_addrs
                                                 as2
                                                 (classify_addrs as2 0 0))
                                               (cpre_wraps pres))
                                             ce)))
                                       None))))))))))))))))))
          (cerr_at q "params after the Mem param must all be Int")))))))

(fn emit_claim ((f FnDef) (reg (List CInfo))) CRes
  (match f
    ((FnDef _ ts _ _)
     (match ts
       ((Cons t0 _)
        (if (is_mem_ty t0)
          (if (fn_is_loop f) (emit_claim_loop f reg) (emit_claim_mem f))
          (emit_claim_pure f)))
       (Nil (emit_claim_pure f))))))

;; ---- the staged pure walk: ediv/mod (docs/LOWERING.md §6y) ---------------------
;;
;; A division's guard makes bop_val reduce to (if (le 1 B) (Some (ediv A
;; B)) None); with B symbolic the machine fold JAMS at that instruction,
;; so the one-shot (compute lhs) no longer runs the whole machine. The
;; proof interleaves instead (the mem fragment's stage law, probe:
;; examples/divfrag_probe.shard): per div site in code order — flush the
;; wrap events materialized so far (their all-occurrence rewrites clean
;; the divisor spelling), rewrite the guard PRE (= (le 1 B) True) into
;; the stuck if, resume (compute lhs). The div node itself contributes
;; NO wrap event (bop_val returns the ediv/mod unwrapped — machine
;; spelling = spec spelling); a LITERAL divisor's guard computes away
;; (zero staging — (ediv x 2^k) is slice D's constant right shift, free);
;; a zero-literal divisor refuses at generation. v1 fence: div fns are
;; straight-line/let only (no ifs — the region templates and the stage
;; law have not been composed yet).
;;
;; Premise layout in EVENT ORDER, dedup by spelling: a wrap node claims
;; the (le 0 E)/(lt E 2^32) pair, a symbolic divisor the single guard
;; (le 1 B). Guard spellings are le-headed and wrap spellings
;; arith-headed, but separate assoc lists keep the lookup honest.
(type DLay (MkDLay Doc (List (Pair Expr Int)) (List (Pair Expr Int)) Int))

(fn dvx_at ((a (List (Pair Expr Int))) (s (List Int))) Int
  (measure (struct a))
  (match a
    (Nil 0)
    ((Cons (Pair k v) t) (if (chars_eq s (spell k)) v (dvx_at t s)))))

(fn dvx_seen ((a (List (Pair Expr Int))) (s (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil False)
    ((Cons (Pair k _) t) (if (chars_eq s (spell k)) True (dvx_seen t s)))))

(fn dv_lay
  ((evs (List DEv))
   (pd Doc)
   (wa (List (Pair Expr Int)))
   (ga (List (Pair Expr Int)))
   (ni Int))
  DLay
  (measure (struct evs))
  (match evs
    (Nil (MkDLay pd wa ga ni))
    ((Cons ev t)
     (match ev
       ((EvW e)
        (if (dvx_seen wa (spell e)) (dv_lay t pd wa ga ni)
        (dv_lay
          t
          (dcat3
            pd
            (dcat3 (DStr "(= ") (bnd_le0 (pr_e e)) (DStr " True) "))
            (dcat3 (DStr "(= ") (bnd_ltwrap (pr_e e)) (DStr " True) ")))
          (Cons (Pair e ni) wa)
          ga
          (+ ni 2))))
       ((EvD b)
        (if (dvx_seen ga (spell b)) (dv_lay t pd wa ga ni)
        (dv_lay
          t
          (DCat pd (dcat3 (DStr "(= ") (bnd_ge1 (pr_e b)) (DStr " True) ")))
          wa
          (Cons (Pair b ni) ga)
          (+ ni 1))))))))

;; flush the pending wrap events (all materialized in the residue by this
;; stage point), machine order; j = the running have ordinal
(fn dv_flush ((pend (List Expr)) (wa (List (Pair Expr Int))) (j Int))
  (Pair Doc Int)
  (measure (struct pend))
  (match pend
    (Nil (Pair (DStr "") j))
    ((Cons e t)
     (match (dv_flush t wa (+ j 1))
       ((Pair d j2)
        (Pair
          (DCat
            (wrap_event
              e
              (dint (dvx_at wa (spell e)))
              (dint (+ (dvx_at wa (spell e)) 1))
              j)
            d)
          j2))))))

;; the staged proof body: pending wraps batch per segment (dedup WITHIN
;; the segment — one all-occurrences fire covers same-segment duplicates;
;; a spelling recomputed in a LATER segment re-enters pending and
;; re-fires); each EvD flushes, rewrites its guard premise (re-use
;; re-fires the same index), and resumes compute.
(fn dv_pf
  ((evs (List DEv))
   (pend (List Expr))
   (wa (List (Pair Expr Int)))
   (ga (List (Pair Expr Int)))
   (j Int))
  Doc
  (measure (struct evs))
  (match evs
    (Nil
      (match (dv_flush pend wa j)
        ((Pair d _) (DCat d (DStr "refl")))))
    ((Cons ev t)
     (match ev
       ((EvW e)
        (if (node_seen (spell e) pend) (dv_pf t pend wa ga j)
        (dv_pf t (node_add e pend) wa ga j)))
       ((EvD b)
        (match (dv_flush pend wa j)
          ((Pair d j1)
           (DCat
             d
             (DCat
               (dcat3
                 (DStr "(steps ((rewrite (premise ")
                 (dint (dvx_at ga (spell b)))
                 (DStr ") lr lhs true ()) (compute lhs))) "))
               (dv_pf t Nil wa ga j1))))))))))

(fn emit_claim_div ((q QName) (ts (List Type)) (body Expr)) CRes
  (if (dv_has_if body)
    (CErr
      (append_int
        (chars_of_sym (qn_name q))
        ": ediv/mod with if is not in the fragment yet (straight-line/let bodies only)"))
    (match (gen_e (count_ts ts) Nil (count_ts ts) body)
      ((GErr m)
       (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
      ((GOk code cnt nxt _ evs)
       (match (dv_lay evs (DStr "") Nil Nil 0)
         ((MkDLay prems wa ga _)
          (COk
            (dcat3
              (dcat3
                (dcat3
                  (DStr "(claim lowered_")
                  (dsym (qn_name q))
                  (dcat3
                    (DStr " (goal (")
                    (pr_binds ts 0)
                    (DStr "(c Nat) (restfs (List Func))) (")))
                prems
                (dcat3
                  (dcat3
                    (DStr ") (= (call_fn (S^ ")
                    (dint (+ (* 2 cnt) 3))
                    (DStr " c) (MkWModule (Cons (MkFunc "))
                  (dint (count_ts ts))
                  (dcat3
                    (dcat3
                      (DCat (sp) (dint (- nxt (count_ts ts))))
                      (DStr " (list ")
                      (djoin code))
                    (DStr ")) restfs) 0) 0 (list ")
                    (DStr ""))))
              (dcat3
                (pr_args ts 0)
                (dcat3 (DStr ")) (Some (") (dsym (qn_name q)) (DStr ""))
                (dcat3
                  (pr_args_lead ts)
                  (DStr "))))")
                  (dcat3
                    (dcat3
                      (DStr " (chain (steps ((compute lhs) (unfold ")
                      (dsym (qn_name q))
                      (DStr " rhs) (reduce rhs))) "))
                    (dv_pf evs Nil wa ga 0)
                    (DStr "))"))))
              (DStr (nl)))
            (DStr ""))))))))

(fn emit_claim_pure ((f FnDef)) CRes
  (match f
    ((FnDef q ts rty body)
     (if (all_int ts)
       (if (is_int_ty rty)
         (if (has_div body) (emit_claim_div q ts body)
         (match (gen_t (count_ts ts) Nil (count_ts ts) body)
           ((TErr m)
            (CErr (append_int (chars_of_sym (qn_name q)) (append_int ": " m))))
           ((TOk rt)
            (match (pw_region rt Nil Nil (dsym (qn_name q)) 0 0 0)
              ((MkPWR proof_body prems helpers _ _ _)
               (COk
                 (DCat
                   helpers
                   (dcat3
                     (dcat3
                       (dcat3
                         (DStr "(claim lowered_")
                         (dsym (qn_name q))
                         (dcat3
                           (DStr " (goal (")
                           (pr_binds ts 0)
                           (DStr "(c Nat) (restfs (List Func))) (")))
                       prems
                       (dcat3
                         (dcat3
                           (DStr ") (= (call_fn (S^ ")
                           (dint (+ (* 2 (rt_count rt)) 3))
                           (DStr " c) (MkWModule (Cons (MkFunc "))
                         (dint (count_ts ts))
                         (dcat3
                           (dcat3
                             (DCat (sp) (dint (- (rt_nxt rt) (count_ts ts))))
                             (DStr " (list ")
                             (djoin (rt_code rt)))
                           (DStr ")) restfs) 0) 0 (list ")
                           (DStr ""))))
                     (dcat3
                       (pr_args ts 0)
                       (dcat3 (DStr ")) (Some (") (dsym (qn_name q)) (DStr ""))
                       (dcat3
                         (pr_args_lead ts)
                         (DStr "))))")
                         (dcat3
                           (dcat3
                             (DStr " (chain (steps ((compute lhs) (unfold ")
                             (dsym (qn_name q))
                             (DStr " rhs) (reduce rhs))) "))
                           proof_body
                           (DStr "))"))))
                     (DStr (nl))))
                 (DStr "")))))))
         (CErr
           (append_int (chars_of_sym (qn_name q)) ": return type is not Int")))
       (CErr (append_int (chars_of_sym (qn_name q)) ": params are not all Int"))))))


;; ---- module walk -------------------------------------------------------------

(type ERes (EOk Doc Doc Bool Bool Bool) (EErr (List Int)))

(fn emit_fns
  ((fns (List FnDef))
   (modpath (List Symbol))
   (accp Doc)
   (accl Doc)
   (memf Bool)
   (loopf Bool)
   (callf Bool)
   (reg (List CInfo)))
  ERes
  (measure (struct fns))
  (match fns
    (Nil (EOk accp accl memf loopf callf))
    ((Cons f rest)
     (match f
       ((FnDef q _ _ _)
        (match q
          ((QName mp _)
           (if (sym_list_eq mp modpath)
             (match (emit_claim f reg)
               ((CErr m) (EErr m))
               ((COkM dp dl cio)
                (emit_fns
                  rest
                  modpath
                  (DCat accp (DCat (DStr (nl)) dp))
                  (DCat accl (DCat (DStr (nl)) dl))
                  True
                  loopf
                  callf
                  (match cio
                    ((Some ci) (reg_add reg ci))
                    (None reg))))
               ((COkC dl)
                (emit_fns
                  rest
                  modpath
                  accp
                  (DCat accl (DCat (DStr (nl)) dl))
                  memf
                  loopf
                  True
                  reg))
               ((COk dp dl)
                (emit_fns
                  rest
                  modpath
                  (DCat accp (DCat (DStr (nl)) dp))
                  accl
                  memf
                  (if loopf True (fn_is_loop f))
                  callf
                  reg)))
             (emit_fns rest modpath accp accl memf loopf callf reg)))))))))


(fn header ((target (List Int)) (memf Bool) (loopf Bool)) Doc
  (dconc
    (list
      (DStr
        ";;; GENERATED by tools/wasmgen (the certifying emitter, scalar let/straight-line fragment) --")
      (DStr (nl))
      (DStr ";;; DO NOT EDIT; regenerate from ")
      (DStr target)
      (DStr (append_int "." (nl)))
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (if (if memf True loopf) (dimport (append_int (updots target) "std/mem"))
      (DStr ""))
      (if loopf (dimport (append_int (updots target) "std/nat.shard"))
      (DStr ""))
      (dimport (append_int (updots target) "models/wasm/wasm.shard"))
      (if loopf
        (dimport (append_int (updots target) "models/wasm/loopkit.shard"))
        (DStr ""))
      (dimport (basename_go target Nil))
      (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
      (if loopf (DStr (append_int "(use (:: models wasm loopkit *))" (nl)))
      (DStr ""))
      (if (if memf True loopf) (DStr (append_int "(use (:: std mem *))" (nl)))
      (DStr ""))
      (if loopf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
      (DStr "(use (:: ")
      (pr_modpath (split_slash (until_dot target) Nil))
      (DStr (append_int " *))" (nl))))))

;; the LINKED file's header: needs the shipped certs AND the portable
;; file; a calls-in-loops unit (callf) adds the loop kit and std/nat
(fn link_header ((target (List Int)) (portout (List Int)) (callf Bool)) Doc
  (dcat3
    (dcat3
      (DStr
        ";;; GENERATED by tools/wasmgen (the LINKED derivations for the mem fragment) --")
      (DStr (nl))
      (dcat3
        (DStr ";;; DO NOT EDIT; regenerate from ")
        (DStr target)
        (DStr (append_int "." (nl)))))
    (dcat3
      (dimport (append_int (updots target) "kernel/stdlib.shard"))
      (dcat3
        (dimport (append_int (updots target) "std/mem"))
        (if callf (dimport (append_int (updots target) "std/nat.shard"))
        (DStr ""))
        (dimport (append_int (updots target) "models/wasm/wasm.shard")))
      (dcat3
        (if callf
          (dimport (append_int (updots target) "models/wasm/loopkit.shard"))
          (DStr ""))
        (dimport (append_int (updots target) "std/mem/mem.wasm.shard"))
        (DCat
          (dimport (basename_go portout Nil))
          (dimport (basename_go target Nil)))))
    (dcat3
      (dcat3
        (DStr (append_int "(use (:: models wasm wasm *))" (nl)))
        (if callf (DStr (append_int "(use (:: models wasm loopkit *))" (nl)))
        (DStr ""))
        (DStr ""))
      (dcat3
        (DStr (append_int "(use (:: std mem *))" (nl)))
        (dcat3
          (if callf (DStr (append_int "(use (:: std nat *))" (nl))) (DStr ""))
          (DStr (append_int "(use (:: std mem mem.wasm *))" (nl)))
          (DStr ""))
        (use_sibling target portout))
      (use_of target))))

;; ---- driver ------------------------------------------------------------------

(fn prelude_ctors_l () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn fail2 ((msg (List Int)) (w World)) World
  (exit 2 (write (append_int "error: " (append_int msg (nl))) w)))

(fn wrote2 ((out (List Int)) (lo (List Int)) (w World)) World
  (exit
    0
    (write
      (append_int
        "wrote "
        (append_int out (append_int " " (append_int lo (nl)))))
      w)))

(fn gen_run
  ((target (List Int)) (out (List Int)) (linko (Option (List Int))) (w World))
  World
  (match (resolve_closure target True w)
    ((Pair Nil w1) (fail2 (append_int "cannot read closure of " target) w1))
    ((Pair srcs w1)
     (match
       (build_module_d
         srcs
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors_l)
         1)
       ((BMFail diag) (fail2 diag w1))
       ((BMOk m)
        (match m
          ((Module _ fns _ _ _)
           (match
             (emit_fns
               fns
               (split_slash (until_dot target) Nil)
               (DStr "")
               (DStr "")
               False
               False
               False
               Nil)
             ((EErr msg)
              (exit 1 (write (append_int "refused: " (append_int msg (nl))) w1)))
             ((EOk bodyp bodyl memf loopf callf)
              (match
                (write_file
                  out
                  (doc_flat (DCat (header target memf loopf) bodyp) Nil)
                  w1)
                ((Pair ok w2)
                 (if ok
                   (if memf
                     (match linko
                       (None
                         (fail2
                           "mem-fragment fns present -- usage: wasmgen SRC OUT LINKOUT"
                           w2))
                       ((Some lo)
                        (match
                          (write_file
                            lo
                            (doc_flat
                              (DCat (link_header target out callf) bodyl)
                              Nil)
                            w2)
                          ((Pair ok2 w3)
                           (if ok2 (wrote2 out lo w3)
                           (fail2 (append_int "cannot write " lo) w3))))))
                     (exit
                       0
                       (write (append_int "wrote " (append_int out (nl))) w2)))
                   (fail2 (append_int "cannot write " out) w2)))))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons target (Cons out Nil)) (gen_run target out None w1))
       ((Cons target (Cons out (Cons lo Nil)))
        (gen_run target out (Some lo) w1))
       (_ (fail2 "usage: wasmgen SRC OUT [LINKOUT]" w1))))))
