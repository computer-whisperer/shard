;;; shardfmt — the IMPL (private) for the shardfmt module: the canonical .shard
;;; source formatter. Supplies the CST reader, the printer, `fmt`, and `main`,
;;; and DISCHARGES the contract's requirements via `fulfills`. It imports its
;;; own interface as an ordinary `.shard` FILE (ungranted), so each requirement
;;; loads as an OBLIGATION; the goals are never restated here (single source of
;;; truth in mod.req.shard).
;;;
;;; This is the FUNGIBLE half. The reason it is safe for this much layout code
;;; to be unreviewed is the GATE: `fmt` re-parses its own output with the
;;; production reader and refuses to return bytes that parse differently from
;;; the input (fmt_gate is about that guard, not about the printer). A printer
;;; bug can cost prettiness, never meaning.
;;;
;;; PIPELINE  bytes --cst_read--> (List CNode) --pp_top--> bytes --gate--> out
;;;
;;;   - The CST keeps what the SExpr reader throws away: comments (own-line vs
;;;     trailing), blank lines, the 'x quote sugar, and the RAW spelling of
;;;     every atom and string (escapes preserved byte-for-byte, so printing
;;;     can never corrupt them).
;;;   - The printer is fit-or-break: a form prints flat if it fits the line
;;;     (80 columns), else it breaks after the head with 2-space indent.
;;;     Per-head keep counts hold e.g. a fn's name/params/ret on the head
;;;     line (greedy prefix — whatever fits). All-atom lists (requires lists,
;;;     byte strings) FILL instead of going one-per-line. Closers pack onto
;;;     the last child's line, lisp-style.
;;;   - Emitter discipline: every render function threads a REVERSED byte
;;;     accumulator (tail calls, one final rev) and fitting is decided by
;;;     `flat_w`, a width probe that decrements a budget and aborts negative —
;;;     no intermediate strings, no quadratic re-rendering.
;;;
;;; RUN IT:   ./rust_bootstrap/target/release/eval run tools/shardfmt/shardfmt.shard [--check] FILE
;;; (formatted source on stdout; exit 0 gate-passed, 2 bad input, 3 gate refusal;
;;; with --check the write is identical but exit 0 = file already canonical,
;;; exit 1 = a reformat would change bytes — the pre-stamp drift gate)
;;; CHECK IT: ./rust_bootstrap/target/release/eval run kernel/check.shard tools/shardfmt/shardfmt.shard

(import "../../kernel/stdlib.shard")  ; List / Option / Bool / Pair
(import "../../std/list.shard")  ; append (bolt vocabulary)
(import "../../meta/format")  ; the formatter core: fmt / gate_check / cst_read
(import "mod.req/mod.req.shard")  ; own interface: obligations + World/externs
(use (:: tools shardfmt *))  ; the interface vocabulary: World/externs/sigs
(use (:: tools shardfmt gate *))  ; gate_holds / fmt_run_ok (the run contract)
;; fmt + gate_check/cst_read/pp_top/parses_eq/bytes_eq — main pipes through
;; fmt; the fmt_gate discharge unfolds the whole guard closure.
(use (:: meta format *))
(use (:: std list append))
(use (:: std list *))  ; interface lemmas for citations (Stage 4)
(use (:: kernel reader *))  ; production reader vocabulary (SExpr/read_all/helpers)

;; ===========================================================================
;; MAIN — read the file, fmt, write; exit 0/2/3 per the contract.
;; ===========================================================================
(fn cat ((a (List Int)) (b (List Int))) (List Int)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (cat t b)))))

;; The shared run: read, fmt, write the formatted bytes, exit. In CHECK mode
;; the write is identical but the exit code reports canonicality: 0 = the
;; file already equals its formatted form, 1 = a reformat would change bytes.
;; Both modes' 0-exits therefore have the SAME observable shape (one read,
;; one write of exactly fmt's bytes), which is why fmt_main_contract holds
;; over both without any change to the requirement: nonzero exits promise
;; nothing, and check-mode's exit 0 is a special case of format-mode's.
(fn run_fmt ((path (List Int)) (check Bool) (w World)) World
  (match (read_file path w)
    ((Pair r w2)
     (match r
       (None (exit 2 (write "shardfmt: cannot read file\n" w2)))
       ((Some src)
        (match (fmt src)
          ((Some out)
           (if check
             (if (bytes_eq out src) (exit 0 (write out w2))
             (exit 1 (write out w2)))
             (exit 0 (write out w2))))
          (None
            (match (cst_read src)
              (None
                (exit
                  2
                  (write
                    (cat "shardfmt: " (cat (parse_diag src Nil 1) "\n"))
                    w2)))
              (_
                (exit
                  3
                  (write
                    "shardfmt: reformat changed the parse; refusing to emit\n"
                    w2)))))))))))

(fn main ((w World)) World
  (match (get_args w)
    ((Pair aa w1)
     (match aa
       (Nil (exit 2 (write "usage: shardfmt [--check] <file.shard>\n" w1)))
       ((Cons a0 more)
        (if (bytes_eq a0 "--check")
          (match more
            (Nil (exit 2 (write "usage: shardfmt [--check] <file.shard>\n" w1)))
            ((Cons path more2) (run_fmt path True w1)))
          (run_fmt a0 False w1)))))))

;; ===========================================================================
;; DISCHARGE — the fulfills, smallest first.
;; ===========================================================================

;; eqdec closes int_eq a a abstractly; bytes_eq_refl lifts it over a list by
;; structural induction. These feed the success leaf of fmt_main_contract
;; (the written chunk IS fmt's answer, so the comparison is X == X).
(claim int_eq_refl (goal ((a Int)) () (= (int_eq a a) True)) (by arith (list)))

(claim bytes_eq_refl
  (goal ((b (List Int))) () (= (bytes_eq b b) True))
  (induct b
    ((case Nil (steps ((unfold bytes_eq lhs) (reduce lhs)) refl))
     (case Cons
       (steps
         ((unfold bytes_eq lhs)
          (reduce lhs)
          (rewrite (lemma int_eq_refl) lr lhs true ())
          (reduce lhs)
          (rewrite (hyp ih) lr lhs true ()))
         refl)))))

;; R-STYLE — the ground scenarios: one computation each.
(fulfills fmt_scenario_collapse (steps ((compute both)) refl))
(fulfills fmt_scenario_fit (steps ((compute both)) refl))
(fulfills fmt_scenario_break (steps ((compute both)) refl))
(fulfills fmt_scenario_comments (steps ((compute both)) refl))
(fulfills fmt_scenario_blanks (steps ((compute both)) refl))
(fulfills fmt_scenario_sugar (steps ((compute both)) refl))
(fulfills fmt_scenario_idem (steps ((compute both)) refl))
(fulfills fmt_scenario_match (steps ((compute both)) refl))
(fulfills fmt_scenario_ifchain (steps ((compute both)) refl))

;; R-GATE — by construction: fmt ENDS in the gate_check guard, so the proof is
;; a case split on the comparison; no printer internals enter the argument.
(fulfills fmt_gate
  (steps
    ((unfold fmt lhs))
    (case-on (cst_read src) Option
      ((case None
         (steps
           ((rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (unfold gate_holds lhs)
            (reduce lhs))
           refl))
       (case Some
         (ns)
         (steps
           ((rewrite (hyp 0) lr lhs true ())
            (reduce lhs)
            (unfold gate_check lhs))
           (case-on (parses_eq src (pp_top ns)) Bool
             ((case True
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (reduce lhs)
                   (unfold gate_holds lhs)
                   (reduce lhs)
                   (rewrite (hyp 0) lr lhs true ()))
                  refl))
              (case False
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (reduce lhs)
                   (unfold gate_holds lhs)
                   (reduce lhs))
                  refl))))))))))

;; R-RUN — symbolic execution of main: case the four effects in program order,
;; thread each observable down to the fresh world through the bolts, then run
;; fmt_run_ok on the resulting ground traces. Error leaves never look past the
;; nonzero exit code; each 0-exit leaf ends in bytes_eq out out. The --check
;; dispatch adds one Bool split: the format branch is the historical body;
;; the check branch re-runs it with the extra canonicality split, whose
;; nonzero (needs-reformat) leg is an error leaf like any other.
(fulfills fmt_main_contract
  (steps
    ((unfold main lhs) (unfold main lhs) (unfold main lhs))
    (case-on (get_args w) Pair
      ((case Pair
         (aa w1)
         (steps
           ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
           (case-on aa List
             ((case Nil
                (steps
                  ((rewrite (hyp 0) lr lhs true ())
                   (reduce lhs)
                   (rewrite (lemma exit_code) lr lhs true ())
                   (compute lhs))
                  refl))
              (case Cons
                (a0 more)
                (steps
                  ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                  (case-on (bytes_eq a0 "--check") Bool
                    ((case False
                       (steps
                         ((rewrite (hyp 0) lr lhs true ())
                          (reduce lhs)
                          (unfold run_fmt lhs)
                          (unfold run_fmt lhs)
                          (unfold run_fmt lhs))
                         (case-on (read_file a0 w1) Pair
                           ((case Pair
                              (r w2)
                              (steps
                                ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                                (case-on r Option
                                  ((case None
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs)
                                        (rewrite
                                          (lemma exit_code)
                                          lr
                                          lhs
                                          true
                                          ())
                                        (compute lhs))
                                       refl))
                                   (case Some
                                     (src)
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       (case-on (fmt src) Option
                                         ((case Some
                                            (out)
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ())
                                               (reduce lhs)
                                               (rewrite
                                                 (lemma exit_code)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma exit_reads)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma exit_output)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma write_reads)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (rewrite
                                                 (lemma write_output)
                                                 lr
                                                 lhs
                                                 true
                                                 ()))
                                              (rewrite-with
                                                (lemma read_reads)
                                                lr
                                                lhs
                                                ((inst p a0)
                                                 (inst w w1)
                                                 (inst r r)
                                                 (inst w1 w2))
                                                ((steps
                                                   ((rewrite
                                                      (hyp 2)
                                                      lr
                                                      lhs
                                                      true
                                                      ()))
                                                   refl))
                                                (rewrite-with
                                                  (lemma read_output)
                                                  lr
                                                  lhs
                                                  ((inst p a0)
                                                   (inst w w1)
                                                   (inst r r)
                                                   (inst w1 w2))
                                                  ((steps
                                                     ((rewrite
                                                        (hyp 2)
                                                        lr
                                                        lhs
                                                        true
                                                        ()))
                                                     refl))
                                                  (rewrite-with
                                                    (lemma args_reads)
                                                    lr
                                                    lhs
                                                    ((inst w w)
                                                     (inst aa aa)
                                                     (inst w1 w1))
                                                    ((steps
                                                       ((rewrite
                                                          (hyp 5)
                                                          lr
                                                          lhs
                                                          true
                                                          ()))
                                                       refl))
                                                    (rewrite-with
                                                      (lemma args_output)
                                                      lr
                                                      lhs
                                                      ((inst w w)
                                                       (inst aa aa)
                                                       (inst w1 w1))
                                                      ((steps
                                                         ((rewrite
                                                            (hyp 5)
                                                            lr
                                                            lhs
                                                            true
                                                            ()))
                                                         refl))
                                                      (steps
                                                        ((rewrite
                                                           (premise 0)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (rewrite
                                                           (premise 1)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (rewrite
                                                           (hyp 1)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (rewrite
                                                           (lemma
                                                             append_nil_left)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (unfold fmt_run_ok lhs)
                                                         (reduce lhs)
                                                         (rewrite
                                                           (lemma int_eq_refl)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (reduce lhs)
                                                         (rewrite
                                                           (hyp 0)
                                                           lr
                                                           lhs
                                                           true
                                                           ())
                                                         (reduce lhs)
                                                         (rewrite
                                                           (lemma bytes_eq_refl)
                                                           lr
                                                           lhs
                                                           true
                                                           ()))
                                                        refl)))))))
                                          (case None
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ())
                                               (reduce lhs))
                                              (case-on (cst_read src) Option
                                                ((case None
                                                   (steps
                                                     ((rewrite
                                                        (hyp 0)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (reduce lhs)
                                                      (rewrite
                                                        (lemma exit_code)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (compute lhs))
                                                     refl))
                                                 (case Some
                                                   (ns2)
                                                   (steps
                                                     ((rewrite
                                                        (hyp 0)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (reduce lhs)
                                                      (rewrite
                                                        (lemma exit_code)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (compute lhs))
                                                     refl))))))))))))))))))
                     (case True
                       (steps
                         ((rewrite (hyp 0) lr lhs true ()) (reduce lhs))
                         (case-on more List
                           ((case Nil
                              (steps
                                ((rewrite (hyp 0) lr lhs true ())
                                 (reduce lhs)
                                 (rewrite (lemma exit_code) lr lhs true ())
                                 (compute lhs))
                                refl))
                            (case Cons
                              (path more2)
                              (steps
                                ((rewrite (hyp 0) lr lhs true ())
                                 (reduce lhs)
                                 (unfold run_fmt lhs)
                                 (unfold run_fmt lhs)
                                 (unfold run_fmt lhs))
                                (case-on (read_file path w1) Pair
                                  ((case Pair
                                     (r w2)
                                     (steps
                                       ((rewrite (hyp 0) lr lhs true ())
                                        (reduce lhs))
                                       (case-on r Option
                                         ((case None
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ())
                                               (reduce lhs)
                                               (rewrite
                                                 (lemma exit_code)
                                                 lr
                                                 lhs
                                                 true
                                                 ())
                                               (compute lhs))
                                              refl))
                                          (case Some
                                            (src)
                                            (steps
                                              ((rewrite (hyp 0) lr lhs true ())
                                               (reduce lhs))
                                              (case-on (fmt src) Option
                                                ((case Some
                                                   (out)
                                                   (steps
                                                     ((rewrite
                                                        (hyp 0)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (reduce lhs))
                                                     (case-on (bytes_eq out src)
                                                       Bool
                                                       ((case True
                                                          (steps
                                                            ((rewrite
                                                               (hyp 0)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (reduce lhs)
                                                             (rewrite
                                                               (lemma exit_code)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (rewrite
                                                               (lemma exit_reads)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (rewrite
                                                               (lemma
                                                                 exit_output)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (rewrite
                                                               (lemma
                                                                 write_reads)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (rewrite
                                                               (lemma
                                                                 write_output)
                                                               lr
                                                               lhs
                                                               true
                                                               ()))
                                                            (rewrite-with
                                                              (lemma read_reads)
                                                              lr
                                                              lhs
                                                              ((inst p path)
                                                               (inst w w1)
                                                               (inst r r)
                                                               (inst w1 w2))
                                                              ((steps
                                                                 ((rewrite
                                                                    (hyp 3)
                                                                    lr
                                                                    lhs
                                                                    true
                                                                    ()))
                                                                 refl))
                                                              (rewrite-with
                                                                (lemma
                                                                  read_output)
                                                                lr
                                                                lhs
                                                                ((inst p path)
                                                                 (inst w w1)
                                                                 (inst r r)
                                                                 (inst w1 w2))
                                                                ((steps
                                                                   ((rewrite
                                                                      (hyp 3)
                                                                      lr
                                                                      lhs
                                                                      true
                                                                      ()))
                                                                   refl))
                                                                (rewrite-with
                                                                  (lemma
                                                                    args_reads)
                                                                  lr
                                                                  lhs
                                                                  ((inst w w)
                                                                   (inst aa aa)
                                                                   (inst w1 w1))
                                                                  ((steps
                                                                     ((rewrite
                                                                        (hyp 7)
                                                                        lr
                                                                        lhs
                                                                        true
                                                                        ()))
                                                                     refl))
                                                                  (rewrite-with
                                                                    (lemma
                                                                      args_output)
                                                                    lr
                                                                    lhs
                                                                    ((inst w w)
                                                                     (inst aa aa)
                                                                     (inst w1 w1))
                                                                    ((steps
                                                                       ((rewrite
                                                                          (hyp 7)
                                                                          lr
                                                                          lhs
                                                                          true
                                                                          ()))
                                                                       refl))
                                                                    (steps
                                                                      ((rewrite
                                                                         (premise
                                                                           0)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (rewrite
                                                                         (premise
                                                                           1)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (rewrite
                                                                         (hyp 2)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (rewrite
                                                                         (lemma
                                                                           append_nil_left)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (unfold
                                                                         fmt_run_ok
                                                                         lhs)
                                                                       (reduce
                                                                         lhs)
                                                                       (rewrite
                                                                         (lemma
                                                                           int_eq_refl)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (reduce
                                                                         lhs)
                                                                       (rewrite
                                                                         (hyp 1)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ())
                                                                       (reduce
                                                                         lhs)
                                                                       (rewrite
                                                                         (lemma
                                                                           bytes_eq_refl)
                                                                         lr
                                                                         lhs
                                                                         true
                                                                         ()))
                                                                      refl)))))))
                                                        (case False
                                                          (steps
                                                            ((rewrite
                                                               (hyp 0)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (reduce lhs)
                                                             (rewrite
                                                               (lemma exit_code)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (compute lhs))
                                                            refl))))))
                                                 (case None
                                                   (steps
                                                     ((rewrite
                                                        (hyp 0)
                                                        lr
                                                        lhs
                                                        true
                                                        ())
                                                      (reduce lhs))
                                                     (case-on (cst_read src)
                                                       Option
                                                       ((case None
                                                          (steps
                                                            ((rewrite
                                                               (hyp 0)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (reduce lhs)
                                                             (rewrite
                                                               (lemma exit_code)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (compute lhs))
                                                            refl))
                                                        (case Some
                                                          (ns2)
                                                          (steps
                                                            ((rewrite
                                                               (hyp 0)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (reduce lhs)
                                                             (rewrite
                                                               (lemma exit_code)
                                                               lr
                                                               lhs
                                                               true
                                                               ())
                                                             (compute lhs))
                                                            refl))))))))))))))))))))))))))))))))))
