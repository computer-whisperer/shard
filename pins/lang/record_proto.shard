;;; record_proto.shard — HAND-EXPANDED prototype of the (record …) expansion
;;; (issue #3). This file is what the loader-level expander will GENERATE for
;;;
;;;   (record Rec3 (a Int) (b Bool) (c (List Int)))
;;;
;;; written out by hand first to pin the templates: the positional single-ctor
;;; type, FIELD_of accessors, with_FIELD updaters, and the law family with its
;;; machine proof shape (case-on + compute + refl). Once the generator lands
;;; this file becomes the shape-regression pin for the expansion.

(import "../../kernel/stdlib.shard")  ; stdlib types (List/Option/Bool/Pair)

(type Rec3 (MkRec3 Int Bool (List Int)))

;; accessors
(fn a_of ((r Rec3)) Int
  (match r
    ((MkRec3 a b c) a)))
(fn b_of ((r Rec3)) Bool
  (match r
    ((MkRec3 a b c) b)))
(fn c_of ((r Rec3)) (List Int)
  (match r
    ((MkRec3 a b c) c)))

;; updaters (value-first: (with r (a 5)) desugars to (with_a 5 r))
(fn with_a ((v Int) (r Rec3)) Rec3
  (match r
    ((MkRec3 a b c) (MkRec3 v b c))))
(fn with_b ((v Bool) (r Rec3)) Rec3
  (match r
    ((MkRec3 a b c) (MkRec3 a v c))))
(fn with_c ((v (List Int)) (r Rec3)) Rec3
  (match r
    ((MkRec3 a b c) (MkRec3 a b v))))

;; defining equations
(claim a_of_def
  (goal ((a Int) (b Bool) (c (List Int))) () (= (a_of (MkRec3 a b c)) a))
  (steps ((compute both)) refl))
(claim with_a_def
  (goal ((v Int) (a Int) (b Bool) (c (List Int))) ()
    (= (with_a v (MkRec3 a b c)) (MkRec3 v b c)))
  (steps ((compute both)) refl))

;; select-over-update, same field
(claim a_of_with_a
  (goal ((v Int) (r Rec3)) () (= (a_of (with_a v r)) v))
  (case-on r Rec3
    ((case MkRec3
       (a b c)
       (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))

;; select-over-update, cross field
(claim a_of_with_b
  (goal ((v Bool) (r Rec3)) () (= (a_of (with_b v r)) (a_of r)))
  (case-on r Rec3
    ((case MkRec3
       (a b c)
       (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))

;; update-over-update, same field
(claim with_a_with_a
  (goal ((v Int) (u Int) (r Rec3)) () (= (with_a v (with_a u r)) (with_a v r)))
  (case-on r Rec3
    ((case MkRec3
       (a b c)
       (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))

;; reconstruction (lemma-level eta — the case-on replacement)
(claim Rec3_eta
  (goal ((r Rec3)) () (= r (MkRec3 (a_of r) (b_of r) (c_of r))))
  (case-on r Rec3
    ((case MkRec3
       (a b c)
       (steps ((rewrite (hyp 0) lr both true ()) (compute both)) refl)))))
