;;; NEGATIVE FIXTURE (friction item 1 residue, 2026-07-10): a bare
;;; CAPITALIZED symbol in pattern position that names no visible ctor
;;; must be REFUSED, not silently bound — the ctor-capture footgun (an
;;; unimported or typo'd 0-ary ctor pattern would match EVERYTHING).
;;; The applied case was always rejected; this pins the bare-sym gap.
(type PB (PBA) (PBB))

(fn pb ((x PB)) Int
  (match x
    (PBA 1)
    (Kaboom 0)))
