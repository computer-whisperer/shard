;;; Refinement-type slice 2: the intro side — a refined RETURN type.
;;; A fn whose return type is a refinement R = (refine BASE PRED) is admitted
;;; with an ordinary BASE-typed body (tc_fn_body_ret); the (returns f PROOF)
;;; top-level form discharges the invariant
;;;     ∀args, (= (PRED (refine_val (f args))) True).
;;; The driver ENFORCES it — a missing or failing proof is a HARD failure (see
;;; refine_return_rejects.shard). See docs/REFINEMENT.md.

(import "../../kernel/stdlib.shard")

(fn is_small ((n Int)) Bool (lt n 5))

(type Small (refine Int is_small))

;; the body is a bare Int (3 : Int = BASE), admitted at the refined return Small.
(fn three () Small 3)

;; the obligation: unfold three → (is_small (refine_val 3)); refine_val reduces
;; (identity) → (is_small 3); compute → True.
(returns three (steps ((compute lhs)) refl))

;; an independent sanity claim: the goal the gate generates is itself provable.
(claim three_is_small
  (goal () () (= (is_small (refine_val (three))) True))
  (steps ((compute lhs)) refl))
