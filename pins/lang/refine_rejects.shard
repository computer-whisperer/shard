;;; Must-FAIL pins for the refinement elim gate. EVERY claim here MUST be
;;; rejected by the kernel — these are the soundness boundaries of refine-fact.
;;; See docs/REFINEMENT.md.

(import "../../kernel/stdlib.shard")

(fn is_small ((n Int)) Bool (lt n 5))
(fn is_big ((n Int)) Bool (lt 100 n))

(type Small (refine Int is_small))
(type Big (refine Int is_big))

;; CHEAT 1 — borrowing another refinement's predicate. b is a Big; naming Small
;; would grant is_small for a value that need not be small. The kernel infers
;; b's type (Big) and refuses because the head != the named Small. MUST FAIL.
(claim borrow_predicate
  (goal ((b Big)) () (= (is_small (refine_val b)) True))
  (refine-fact Small b (steps ((rewrite (premise 0) lr lhs true ())) refl)))

;; CHEAT 2 — refine-fact on a non-refined type. Bool is an ordinary datatype, so
;; typedef_refine returns None and the step is refused (even though the goal is
;; trivially true, THIS proof must not be accepted). MUST FAIL.
(claim not_refined (goal ((x Bool)) () (= x x)) (refine-fact Bool x refl))
