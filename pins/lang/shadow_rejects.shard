;;; shadow_rejects.shard — SOUNDNESS REGRESSION TEST (must FAIL to check).
;;;
;;; Guards the Stage-3 fix for the name-shadowing soundness bug. A user
;;; function named `le` that returns True for ALL inputs must NOT be read by
;;; the farkas backend as the built-in linear `<=`.
;;;
;;; The bug (pre-Stage-3): farkas matched a call head by its BARE name, so it
;;; read the premise `(le 5 3) = True` — which the reducer makes true, since
;;; this `le` is the constant-True user fn — as the linear fact `3 - 5 >= 0`.
;;; That false constraint let farkas derive the bogus goal `2 <= 1`, and from a
;;; contradiction anything follows (0 = 1). The reducer and the backend had
;;; assigned the same `(le …)` two different meanings.
;;;
;;; The fix: under strict resolution this `le` resolves to its own module-path,
;;; not `core`; the backends now admit an interpreted symbol only via
;;; `core_named` (core path + name), so this `le` is an opaque atom and the
;;; claim below no longer checks. If a future change re-opens the hole, this
;;; file flips from "0 passed, 1 failed" to "1 passed" and the corpus diff
;;; catches it.

(import "../../kernel/stdlib.shard")

(fn le ((a Int) (b Int)) Bool True)

(claim shadow_le_must_not_prove_2_le_1
  (goal () ((= (le 5 3) True)) (= (le 2 1) True))
  (steps () (by arith (list 0 1))))
