;;; axiom_untagged_rejects.shard — an own axiom with NO (kind …) clause is
;;; REFUSED before admission (driver.shard ax_admit_veto): the trust ledger
;;; never carries an unclassified entry. Distinct from axiom_kind_rejects
;;; (an unrecognized kind is a MALFORMED decl, a __decls__ stream failure);
;;; a missing kind parses fine and is refused BY NAME at the admission veto.
;;; Expected:
;;;   FAIL  no_kind / axiom missing its (kind ...) tag
;;;   0 passed, 1 failed

(import "../../kernel/stdlib.shard")

(axiom no_kind (goal ((n Int)) () (= (+ n 0) n)))
