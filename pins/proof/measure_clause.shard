;;; measure_clause.shard — the (measure E P…) admissibility clause (issue #1,
;;; Phase B/B2). Exercised by `check admit pins/proof/measure_clause.shard`:
;;;   cdown    MEASURED OK    — if-polarity path condition, one site
;;;   cdown2   MEASURED OK    — closed match arm + if as TWO premises
;;;   divdown  MEASURED OK    — div-facts quotient-naming: recurses on the
;;;                            NON-LINEAR term (ediv n 10); the (ediv n d)=q
;;;                            fact is the bridge that lets farkas descend
;;;   liar2    MEASURED FAIL  — the measure CHEAT: claims measure n but
;;;                            recurses on (+ n 1); the decrease obligation
;;;                            is false and its proof must be rejected
;;;   sumlist  MEASURED OK    — B2: site under a binder-ful arm; the
;;;                            param-pure guard hyp is KEPT, the binder-
;;;                            mentioning arm equation is DROPPED (sound)
;;;   sumbad   MEASURED FAIL  — B2 over-admission pin: same shape but NO
;;;                            lower-bound guard — nonneg is unprovable
;;;                            (hyp-dropping must never manufacture facts;
;;;                            since Phase C the typed arm equation is
;;;                            recorded then dropped, so ndrop = 1)
;;;   lensum   MEASURED OK    — Phase C case instantiation: the measure
;;;                            argument references the arm binder ((len t)),
;;;                            so the obligation is stated over the params
;;;                            PLUS the typed binders ((h Int) (t (List
;;;                            Int))), with the arm equation as a premise;
;;;                            discharged citing GRANTED len_cons/len_nonneg
;;;   dropper  MEASURED FAIL  — drop-note pin: a binder-mentioning if-guard
;;;                            is dropped and the failure names the count
;;;                            (ndrop = 2 since Phase C: + the arm equation)
;;;   lencheat MEASURED FAIL  — typed-path cheat: recurses on (Cons h t)
;;;                            itself, so decrease is lt of equal lengths —
;;;                            no proof may close it
;;;   owncite  MEASURED OK    — stratified citation (downstream cite ACCEPTED):
;;;                            own_lemma is pure arithmetic — its statement
;;;                            reaches no fn, so it cannot depend on owncite.
;;;                            The call-graph filter keeps it; the cite works.
;;;   selfcite MEASURED FAIL  — stratified citation (reaches-F cite REFUSED):
;;;                            self_fact's statement mentions circ (the fn under
;;;                            admission), so it reaches circ's own SCC; the
;;;                            filter drops it and the cite is unresolved. Same
;;;                            proof shape as owncite, opposite outcome — that
;;;                            difference IS the acyclicity rule.
;;; Inline proof order: per site (pre-order body walk), decrease then
;;; nonnegativity. farkas cert layout: (list GOAL_MULT M_premise…) — one
;;; slot per KEPT premise.
;;; Under plain `check` the claims (own_lemma, self_fact) pass and the measure
;;; obligations render in a report-only block (MEASURED OK/FAIL) — they bump no
;;; pass/fail count until the Phase D enforcement flip.

(import "../../kernel/stdlib.shard")
(import "../../std/list.shard")  ; len + the len_cons/len_nonneg lemmas (lensum)
(use (:: std list *))

(fn cdown ((n Int)) Int
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) 0 (cdown (- n 1))))

(fn liar2 ((n Int)) Int
  (measure n (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt n 1) 0 (liar2 (+ n 1))))

(fn probe_main ((x Int)) Int (cdown x))

(fn cdown2 ((n Int) (go Bool)) Int
  (measure n (by arith (list 1 0 0)) (by arith (list 1 0 1)))
  (match go
    (False 0)
    (True (if (lt n 1) 0 (cdown2 (- n 1) go)))))

;; div-facts quotient-naming pin (issue #1): the recursive arg is (ediv n 10),
;; a NON-LINEAR term that farkas sees as opaque. The div-facts step injects the
;; Euclidean triple AND the new naming fact (ediv n 10) = q (premise 4), which
;; is the only bridge that lets the linear backend close the descent. Premises
;; at each obligation: 0 = path (lt n 10)=False i.e. n>=10; 1 = decomp
;; n=10q+mod; 2 = (0<=mod); 3 = (mod<=9); 4 = (ediv n 10)=q.
(fn divdown ((n Int)) Int
  (measure
    n
    ;; decrease (lt (ediv n 10) n): 10*neg_goal + 9*path + decomp + lo - 10*ediv
    (div-facts n 10 q (by arith (list 10 9 1 1 0 -10)))
    ;; nonneg (le 0 (ediv n 10)): 10*neg_goal + path - decomp + hi + 10*ediv
    (div-facts n 10 q (by arith (list 10 1 -1 0 1 10))))
  (if (lt n 10) 0 (divdown (ediv n 10))))

;; B2: the site sits under (Cons h t) — the arm equation (= xs (Cons h t))
;; is dropped (mentions binders) but the param-pure k-guard is kept, so
;; both obligations discharge: k decreases and stays >= 0.
(fn sumlist ((xs (List Int)) (k Int)) Int
  (measure k (by arith (list 1 0)) (by arith (list 1 1)))
  (if (le k 0) 0
  (match xs
    (Nil 0)
    ((Cons h t) (+ h (sumlist t (- k 1)))))))

;; B2 over-admission pin: NO k-guard — after the arm equation is dropped
;; there is no premise at all, and (le 0 (- k 1)) is simply false at k=0.
;; The nonneg obligation must FAIL no matter the cert.
(fn sumbad ((xs (List Int)) (k Int)) Int
  (measure k (by arith (list 1)) (by arith (list 1)))
  (match xs
    (Nil 0)
    ((Cons h t) (+ h (sumbad t (- k 1))))))

;; the measure descends through the data: (len t) references the arm
;; binder t, so the goal gains typed binder params and the arm equation
;; premise ((= xs (Cons h t)), premise 0). decrease rewrites xs to the
;; ctor form, cites len_cons, and closes linearly; nonneg is len_nonneg.
(fn lensum ((xs (List Int))) Int
  (measure
    (len xs)
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma len_cons) lr lhs true ()))
      (by arith (list 1 0)))
    (steps ((rewrite (lemma len_nonneg) lr lhs true ())) refl))
  (match xs
    (Nil 0)
    ((Cons h t) (+ h (lensum t)))))

;; drop-note pin: the if-guard mentions binder h, so it is DROPPED from
;; the obligation (ndrop = 1) — and with no param-pure guard left, nonneg
;; fails WITH the diagnostic note naming the dropped premise count.
(fn dropper ((xs (List Int)) (k Int)) Int
  (measure k (by arith (list 1)) (by arith (list 1)))
  (match xs
    (Nil 0)
    ((Cons h t) (if (lt h 5) (dropper t (- k 1)) 0))))

;; stratified citation — DOWNSTREAM CITE ACCEPTED. own_lemma states the nonneg
;; obligation EXACTLY and is pure arithmetic: its statement names only primitives
;; (lt/le/-), so it reaches NO fn and cannot depend on owncite. The call-graph
;; filter keeps it, so owncite's nonneg cite resolves and the obligation closes.
(claim own_lemma
  (goal ((n Int)) ((= (lt 0 n) True)) (= (le 0 (- n 1)) True))
  (by arith (list 1 1)))

(fn owncite ((n Int)) Int
  (measure
    n
    (by arith (list 1 0))
    (rewrite-with
      (lemma own_lemma)
      lr
      lhs
      ()
      ((steps ((rewrite (premise 0) lr lhs true ())) refl))
      refl))
  (if (lt 0 n) (owncite (- n 1)) 0))

;; stratified citation — REACHES-F CITE REFUSED. self_fact is a true, checked
;; claim (circ 0 = 0, so 0 <= circ 0), but its STATEMENT mentions circ — the very
;; fn under admission — so it reaches circ's own SCC and the filter drops it from
;; circ's obligation theory. The decrease proof uses self_fact as the LOAD-BEARING
;; justification of a `have` (a goal self_fact would close if citable), so the
;; failure is unambiguously the refused cite: were self_fact kept, the have would
;; discharge and the decrease close. A lemma may not help prove the fn it rests on.
(claim self_fact
  (goal () () (= (le 0 (circ 0)) True))
  (steps ((compute lhs)) refl))

(fn circ ((n Int)) Int
  (measure
    n
    (have (= (le 0 (circ 0)) True)
      (rewrite-with (lemma self_fact) lr lhs () () refl)
      (by arith (list 1 0 0)))
    (by arith (list 1 1)))
  (if (lt 0 n) (circ (- n 1)) 0))

;; typed-path cheat pin: the recursive call passes (Cons h t) — the very
;; value xs is known to equal (premise 0) — so the decrease obligation is
;; (lt (len (Cons h t)) (len xs)) with the two sides EQUAL. No cert closes
;; lt a a; the gate must refuse however the proof is spelled.
(fn lencheat ((xs (List Int))) Int
  (measure
    (len xs)
    (steps ((rewrite (premise 0) rl lhs true ())) (by arith (list 1 0)))
    (steps ((rewrite (lemma len_nonneg) lr lhs true ())) refl))
  (match xs
    (Nil 0)
    ((Cons h t) (+ h (lencheat (Cons h t))))))
