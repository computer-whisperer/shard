;;; cert_rows.shard — pins for keyed cert rows: inside a (by THEORY …)
;;; payload, (rows (KEY MULT) …) expands at desugar to the positional
;;; multiplier list (list G M0 … M_{pc-1}). KEY = `goal` (slot 0), a named
;;; premise (a have's name), or a premise index literal; unmentioned rows
;;; are 0. The point is insertion stability: a keyed cert names its rows,
;;; so premise insertions/appends shift nothing — the positional spelling
;;; shifts every downstream multiplier. See cert_rows_rejects.shard for
;;; the refusal boundaries.

(import "../../kernel/stdlib.shard")

;; goal + index keys: (rows (goal 1) (0 1)) ≡ (list 1 1).
(claim rows_single
  (goal ((a Int) (b Int)) ((= (le a 5) True)) (= (le a 7) True))
  (by arith (rows (goal 1) (0 1))))

;; named have + index keys, rows in BOTH the have's cert and the final
;; cert; row order is free (keys, not positions).
(claim rows_named
  (goal ((a Int) (b Int)) ((= (le a b) True) (= (le b 4) True))
    (= (le a 9) True))
  (have hb (= (le b 5) True)
    (by arith (rows (goal 1) (1 1)))
    (by arith (rows (hb 1) (goal 1) (0 1)))))

;; the two-sided equality cert: (rows …) expands at any payload depth.
(claim rows_eq
  (goal ((x Int) (y Int)) ((= x y)) (= (+ x 1) (+ y 1)))
  (by arith (list (rows (goal 1) (0 -1)) (rows (goal 1) (0 1)))))

;; positional twin of rows_named's final cert — pins the expansion
;; against the spelling it must produce.
(claim rows_positional_twin
  (goal ((a Int) (b Int)) ((= (le a b) True) (= (le b 4) True))
    (= (le a 9) True))
  (have hb (= (le b 5) True) (by arith (list 1 0 1)) (by arith (list 1 1 0 1))))
