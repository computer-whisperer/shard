;;; Must-FAIL pin for the literal-sort rewrite gate. Ground Nat literals
;;; pack to the SAME IntLit atom as Int, so before the gate a bare-literal
;;; rewrite could carry an Int equation into a packed-Nat position — the
;;; wn_q incident (IMP.md): the rewritten goal is ill-sorted and no later
;;; pass re-types it. EVERY claim in THIS file must be rejected. See
;;; sort_gate.shard for the accepted shapes.

(import "../../kernel/stdlib.shard")

(fn sg_n ((k Nat)) Nat k)

;; THE SMUGGLE — this claim PROVED before the gate: rewriting both 16s
;; through the Int premise turns the goal into (= (sg_n x) (sg_n x)),
;; closed by refl — an Int equation deciding a Nat-position fact. The
;; sites are Nat-sorted (sg_n's declared param), the replacement is an
;; Int param: the gate refuses the match. MUST FAIL.
(claim sg_cross_both
  (goal ((x Int)) ((= x 16)) (= (sg_n 16) (sg_n 16)))
  (steps ((rewrite (premise 0) rl both true ())) refl))
