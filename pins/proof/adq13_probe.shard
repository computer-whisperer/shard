;;; friction item 4 PIN (2026-07-10): the 13-ctor mechanical fuel induction
;;; shape (the generic adequacy theorem's skeleton — xadequacy_probe's
;;; header names it as the reason the generic form was skipped) is
;;; MACHINE-SOLVED by tools/prove with the natural hints
;;; (auto (induct f) (case-on i I13)): fuel induction, 13-way case, each
;;; arm closed by unfold/reduce/case-hyp chains. The sidecar entry is
;;; solver output — regenerate with tools/prove, do not hand-edit.
(import "../../kernel/stdlib.shard")
(use (:: kernel stdlib *))

(type I13
  (IA)
  (IB)
  (IC)
  (ID)
  (IE)
  (IF2)
  (IG)
  (IH2)
  (II)
  (IJ)
  (IK)
  (IL)
  (IBlk (List I13)))

(fn ev_i ((f Nat) (i I13) (acc Int)) (Option Int)
  (measure (struct f))
  (match f
    (Z None)
    ((S f2)
     (match i
       (IA (Some (+ acc 1)))
       (IB (Some (+ acc 2)))
       (IC (Some (+ acc 3)))
       (ID (Some (+ acc 4)))
       (IE (Some (+ acc 5)))
       (IF2 (Some (+ acc 6)))
       (IG (Some (+ acc 7)))
       (IH2 (Some (+ acc 8)))
       (II (Some (+ acc 9)))
       (IJ (Some (+ acc 10)))
       (IK (Some (+ acc 11)))
       (IL (Some (+ acc 12)))
       ((IBlk body) (ev_l f2 body acc))))))

(fn ev_l ((f Nat) (is (List I13)) (acc Int)) (Option Int)
  (measure (struct f))
  (match f
    (Z None)
    ((S f2)
     (match is
       (Nil (Some acc))
       ((Cons h t)
        (match (ev_i f2 h acc)
          (None None)
          ((Some a2) (ev_l f2 t a2))))))))

;; the lift: what agreement MEANS (the adq shape — value + empty trace)
(fn lft ((o (Option Int))) (Option (Pair Int (List Int)))
  (match o
    (None None)
    ((Some v) (Some (Pair v Nil)))))

;; the TWIN: mirrors ev_i arm-by-arm but in the LIFTED codomain (the
;; weval-mirrors-xeval shape: same recursion, trace threaded — empty for
;; pure code). The IBlk arm delegates to lft∘ev_l directly, so this claim
;; isolates fuel-induction + the 13-way case with real per-arm work and
;; NO mutual sibling yet.
(fn wv_i ((f Nat) (i I13) (acc Int)) (Option (Pair Int (List Int)))
  (measure (struct f))
  (match f
    (Z None)
    ((S f2)
     (match i
       (IA (Some (Pair (+ acc 1) Nil)))
       (IB (Some (Pair (+ acc 2) Nil)))
       (IC (Some (Pair (+ acc 3) Nil)))
       (ID (Some (Pair (+ acc 4) Nil)))
       (IE (Some (Pair (+ acc 5) Nil)))
       (IF2 (Some (Pair (+ acc 6) Nil)))
       (IG (Some (Pair (+ acc 7) Nil)))
       (IH2 (Some (Pair (+ acc 8) Nil)))
       (II (Some (Pair (+ acc 9) Nil)))
       (IJ (Some (Pair (+ acc 10) Nil)))
       (IK (Some (Pair (+ acc 11) Nil)))
       (IL (Some (Pair (+ acc 12) Nil)))
       ((IBlk body) (lft (ev_l f2 body acc)))))))

(claim adq13_leaf
  (goal ((f Nat) (i I13) (acc Int)) () (= (wv_i f i acc) (lft (ev_i f i acc))))
  (auto (induct f) (case-on i I13)))

;; the SEQ case (the item's named example), layered over the proven leaf
;; lemma: the Cons arm needs adq13_leaf cited at the sub-fuel plus a split
;; on the head's Option result before the tail IH fires.
(fn wv_l ((f Nat) (is (List I13)) (acc Int)) (Option (Pair Int (List Int)))
  (measure (struct f))
  (match f
    (Z None)
    ((S f2)
     (match is
       (Nil (Some (Pair acc Nil)))
       ((Cons h t)
        (match (wv_i f2 h acc)
          (None None)
          ((Some (Pair a2 _)) (wv_l f2 t a2))))))))

;; the genuinely-MUTUAL seq claim: its Cons branch needs a lemma-cite of
;; adq13_leaf at the sub-fuel PLUS a case split on the head call's Option
;; result — an inner case-on over a COMPUTED term whose scrutinee mentions
;; case-local binders, which no hint can name. MACHINE-SOLVED 2026-07-10 by
;; the unhinted case-on DISCOVERY rung (tools/prove): when the hint chain's
;; Cons case exhausts, the solver applies a normalizing prefix (case-hyp
;; rewrites + one adq13_leaf citation), reads the stuck match scrutinee
;; (ev_i f2 h acc) off the residual's reduction frontier, and synthesizes
;; the inner case-on — the outer split's binders spelled via the lazy
;; named-binder retry so the discovered scrutinee text replays.
(claim adq13_seq
  (goal ((f Nat) (is (List I13)) (acc Int)) ()
    (= (wv_l f is acc) (lft (ev_l f is acc))))
  (auto (induct f) (case-on is List)))
