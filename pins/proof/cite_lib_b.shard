;;; Stage-4 regression fixture: module B proves `shared_fact` over ITS OWN fn
;;; — same bare name as cite_lib_a's claim, different equation.
(import "../../kernel/stdlib.shard")

(fn fb ((n Int)) Int (+ n 2))

(claim shared_fact
  (goal ((n Int)) () (= (fb n) (+ n 2)))
  (steps ((compute both)) refl))
