;;; rewrite_with_occ_rejects.shard — refusal boundaries for the
;;; rewrite-with occurrence selector (see rewrite_with_occ.shard). Every
;;; claim here must FAIL. Expected-fail corpus target.

(import "../../kernel/stdlib.shard")

(fn wrapq ((n Int)) Int (if (le 0 n) n -1))

(claim wrapq_id
  (goal ((n Int)) ((= (le 0 n) True)) (= (wrapq n) n))
  (steps
    ((unfold wrapq lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs))
    refl))

;; (at 5) with two sites — out of range fails the citation loudly.
(claim occ_at_out_of_range
  (goal ((k Int)) ((= (le 0 k) True)) (= (+ (wrapq k) (wrapq k)) (+ k k)))
  (rewrite-with
    (lemma wrapq_id)
    lr
    lhs
    (at 5)
    ((inst n k))
    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
    refl))

;; `true` is ALL, not first: rewriting both twins cannot leave one — the
;; residue this claim asserts does not exist.
(claim occ_all_is_not_first
  (goal ((k Int)) ((= (le 0 k) True))
    (= (+ (wrapq k) (wrapq k)) (+ (wrapq k) k)))
  (rewrite-with
    (lemma wrapq_id)
    lr
    lhs
    true
    ((inst n k))
    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
    refl))

;; a 7-arg form with a garbage selector is a PARSE refusal, never a
;; silent reinterpretation as the 6-arg spelling.
(claim occ_bad_selector
  (goal ((k Int)) ((= (le 0 k) True)) (= (wrapq k) k))
  (rewrite-with
    (lemma wrapq_id)
    lr
    lhs
    banana
    ((inst n k))
    ((steps ((rewrite (premise 0) lr lhs true ())) refl))
    refl))
