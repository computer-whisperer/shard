;;; auto_missing_rejects.shard — MUST-FAIL regression: an `auto` proof whose
;;; sidecar entry does not exist. There is deliberately NO
;;; auto_missing_rejects.auto.shard next to this file, so the claim fails
;;; with the missing-entry message and the run exits nonzero. Pins: the
;;; `auto` indirection never silently admits.

(claim no_sidecar_here (goal ((x Int)) () (= (+ x 0) x)) auto)
