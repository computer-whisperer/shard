;;; inject_basic.shard — pins for (inject …): constructor injectivity, the
;;; converse of absurd's no-confusion half. From a cited CLOSED equation
;;; (= (C a1…an) (C b1…bn)) — the SAME ctor heading both sides, as spelled —
;;; inject appends the fieldwise equations (= ai bi) as the LAST premises,
;;; one per listed name in field order (`_` = counted hole, not registered).
;;; The name-list length is pinned into the certificate and checked against
;;; the ctor's arity. Sound because ctor values are FREE: expr_eq/the matcher
;;; already equate two ctor values iff heads agree and fields are pairwise
;;; equal. See inject_rejects.shard for the refusal boundaries.

(import "../../kernel/stdlib.shard")

;; first field off a Pair equation, cited by name
(claim inj_pair_fst
  (goal ((a Int) (b Int) (c Int) (d Int)) ((= (Pair a b) (Pair c d))) (= a c))
  (inject
    (premise 0)
    (hac hbd)
    (steps ((rewrite (premise hac) lr lhs true ())) refl)))

;; second field, with a `_` hole for the first
(claim inj_pair_snd
  (goal ((a Int) (b Int) (c Int) (d Int)) ((= (Pair a b) (Pair c d))) (= b d))
  (inject
    (premise 0)
    (_ hbd)
    (steps ((rewrite (premise hbd) lr lhs true ())) refl)))

;; positional citation: field i lands at premise base+i (append-at-end, so
;; here 0 = the pair equation, 1 = (= a c), 2 = (= b d))
(claim inj_pair_positional
  (goal ((a Int) (b Int) (c Int) (d Int)) ((= (Pair a b) (Pair c d))) (= b d))
  (inject (premise 0) (_ _) (steps ((rewrite (premise 2) lr lhs true ())) refl)))

;; the composition-proof shape (call_bridge's Some-injectivity, sans the
;; projection-fn workaround): peel Some, then Pair — in chain form
(claim inj_nested
  (goal ((v Int) (m2 Int) (h Int) (m3 Int))
    ((= (Some (Pair v m2)) (Some (Pair h m3))))
    (= v h))
  (chain
    (inject (premise 0) (hp))
    (inject (premise hp) (hv hm))
    (steps ((rewrite (premise hv) lr lhs true ())))
    refl))

;; zero-field ctor: degenerate — appends nothing, continuation unchanged
(claim inj_zero_fields
  (goal ((x Int)) ((= True True)) (= x x))
  (inject (premise 0) () refl))

;; a user-declared ctor with heterogeneous fields; middle field named, holes
;; around it
(type Node (MkNode Int (List Int) Bool))

(claim inj_user_ctor
  (goal ((n Int) (xs (List Int)) (b Bool) (m Int) (ys (List Int)) (c Bool))
    ((= (MkNode n xs b) (MkNode m ys c)))
    (= xs ys))
  (inject
    (premise 0)
    (_ hxy _)
    (steps ((rewrite (premise hxy) lr lhs true ())) refl)))

;; lemma citations resolve through the same gate — a closed ground lemma
(claim pair_ground
  (goal () () (= (Pair 1 2) (Pair (+ 0 1) 2)))
  (steps ((compute both)) refl))

(claim inj_lemma_cite
  (goal () () (= 1 (+ 0 1)))
  (inject
    (lemma pair_ground)
    (h1 h2)
    (steps ((rewrite (premise h1) rl rhs true ())) refl)))

;; an OPEN ctor=ctor lemma — cited from inject_rejects.shard to pin that
;; inject refuses equations that resolve with binders
(claim pair_open (goal ((a Int) (b Int)) () (= (Pair a b) (Pair a b))) refl)
