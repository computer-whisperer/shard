;;; Must-FAIL pins for the conversion forms (CERT.md §3, A3 rung (c)).
;;; The cw_dbl_thm fixture PASSES (it is the citation target); every
;;; other claim here must be REJECTED. See conv_probe.shard for the
;;; accepted shapes.

(import "../../kernel/stdlib.shard")

(fn cw_three () Int 3)

(fn cw_natv () Nat 2)

(fn cw_inc ((i Int)) Int (+ i 1))

(fn cw_dbl ((k Int)) Int (+ k k))

;; fixture (passes): the citation target for the exact-conv rejects.
(claim cw_dbl_thm
  (goal ((k Int)) () (= (cw_dbl k) (* 2 k)))
  (steps ((unfold cw_dbl lhs)) (by arith (list))))

;; change: the NF (3) occurs nowhere in the goal — the step fails
;; loudly instead of silently doing nothing. MUST FAIL.
(claim cw_change_nomatch
  (goal () () (= 2 2))
  (steps ((change lhs true (cw_three))) refl))

;; change: THE SORT CROSSING — cw_natv's NF is the packed literal 2,
;; the goal's 2 sits at cw_inc's declared Int param, the replacement is
;; Nat-typed: the literal-sort walk refuses the fold (the wn_q hazard
;; blocked in the NEW form — rung (b)'s gate carries into rung (c)).
;; MUST FAIL.
(claim cw_change_sort
  (goal () () (= (cw_inc 2) 3))
  (steps ((change lhs true (cw_natv)) (compute lhs)) refl))

;; exact-conv: an unpinned cited binder — FULL instantiation is
;; mandatory (there is no conclusion match to infer k from). MUST FAIL.
(claim cw_xconv_uninst
  (goal ((j Int)) () (= (+ (+ j 1) (+ j 1)) (* 2 (+ j 1))))
  (exact-conv (lemma cw_dbl_thm) () ()))

;; exact-conv: the goal lhs (+ j 2) is NOT convertible to the cited
;; lhs NF (+ (+ j 1) (+ j 1)) — true arithmetically, refused
;; definitionally. Conversion is computation, never theory reasoning.
;; MUST FAIL.
(claim cw_xconv_notconv
  (goal ((j Int)) () (= (+ j 2) (* 2 (+ j 1))))
  (exact-conv (lemma cw_dbl_thm) ((inst k (+ j 1))) ()))

;; exact-conv: a Bool inst for the Int binder — the citation TYPE GATE
;; (the same gate Rewrite/RewriteWith citations pass). MUST FAIL.
(claim cw_xconv_badtype
  (goal () () (= (cw_dbl 1) 2))
  (exact-conv (lemma cw_dbl_thm) ((inst k True)) ()))
