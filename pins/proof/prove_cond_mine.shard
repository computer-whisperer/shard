;;; prove_cond_mine.shard — probe for the prover's conditional-citation
;;; (rewrite-with on a premised lemma) and premise-mining (lemma-fed have)
;;; synthesis. Three auto decls, each unreachable by the flat ladder:
;;;
;;;   cond_probe      — needs cap_small REWRITTEN in (a premised local
;;;                     lemma; its guard premise discharges by farkas
;;;                     against the goal's own premise).
;;;   mine_probe      — needs mod_lo MINED as a have (the std/word idiom:
;;;                     materialize the instantiated conclusion, close the
;;;                     divisor premise, farkas over the extended set).
;;;   mine_pair_probe — needs TWO mined facts (mod_hi at 7, mod_lo at 5)
;;;                     among four minable candidates — pins the monotone
;;;                     accumulation (a greedy fixed pair-pick guesses
;;;                     wrong here).

(import "../../kernel/facts.shard")
(use (:: kernel facts *))

(fn cap ((x Int)) Int (if (lt x 10) x 10))

(claim cap_small
  (goal ((x Int)) ((= (lt x 10) True)) (= (cap x) x))
  (steps
    ((unfold cap lhs) (rewrite (premise 0) lr lhs true ()) (reduce lhs))
    refl))

(claim cond_probe
  (goal ((y Int)) ((= (lt y 10) True)) (= (+ (cap y) 1) (+ y 1)))
  auto)

(claim mine_probe (goal ((n Int)) () (= (le 0 (+ (mod n 7) 3)) True)) auto)

(claim mine_pair_probe
  (goal ((n Int)) () (= (lt (mod n 7) (+ 7 (mod n 5))) True))
  auto)
