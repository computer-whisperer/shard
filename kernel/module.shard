;;; Module-level structures: type definitions, function definitions,
;;; and the Module that aggregates them. Loaded from source files;
;;; the reducer reads them to dispatch Call expressions.
;;;
;;; FnDef bodies are stored in locally-nameless form: BVars 0..arity-1
;;; refer to the parameters. The loader is responsible for converting
;;; source-level parameter names into BVars at parse time, following
;;; the same innermost-first convention as match arms (last parameter
;;; in the source list becomes BVar 0).

;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(use (:: kernel term *))

(type Type
  (TCon QName (List Type))  ; type application: Nat, (List Nat), (Map K V)
  (TVar Symbol))  ; type variable (erased at runtime in narrow; module-local)

(type CtorDef (CtorDef QName (List Type)))  ; ctor name, field types

(type TypeDef
  (TypeDef
    QName  ; type name
    (List Symbol)  ; type parameters (e.g., 'T for List — module-local)
    (List CtorDef)  ; constructors
    (Option (Pair Type QName))))  ; refinement: (Some (base, predicate)) for a
;   refined type `(type R (refine BASE PRED))`, None for an ordinary datatype.
;   A refined type is a nominal nullary type (no ctors) whose values ARE their
;   BASE carriers; PRED is a total BASE->Bool fn that holds of every inhabitant.
;   See docs/REFINEMENT.md.

(type FnDef
  (FnDef
    QName  ; function name
    (List Type)  ; parameter types (length = arity)
    Type  ; return type
    Expr))  ; body — BVars 0..arity-1 are parameters

;; Extern function: signature only, no body. Opaque to the reducer;
;; calls remain stuck (same protocol as native primitives), and the
;; Rust runtime intercepts them and dispatches to a linked native
;; implementation. See docs/BOUNDARIES.md.
(type ExternDef
  (ExternDef
    QName  ; function name
    (List Type)  ; parameter types
    Type))  ; return type

;; Function-dispatch index: a character trie over function names, mapping a
;; name (its `chars_of_sym`) to its FnDef. Built once when a module is parsed/
;; merged so the reducer resolves a Call in O(name length) instead of scanning
;; the whole fn list per step (the old `lookup_fn`). A node holds the FnDef
;; whose name ENDS here (if any) plus child edges keyed by the next char code.
(type FnTrie
  (FnTrie
    (Option FnDef)  ; fn whose name ends at this node
    (List (Pair Int FnTrie)))  ; children, keyed by next char code
  (FnLeaf
    (List Int)  ; the UNIQUE remaining suffix (path compression: once a
    FnDef))  ;   name's prefix is unshared, store the tail + def directly —
;   a lookup compares the suffix in one cheap list walk instead
;   of one branch node (+ child-list scan) PER CHARACTER

(type Module
  (Module
    (List TypeDef)
    (List FnDef)
    (List ExternDef)  ; extern signatures (may be Nil)
    FnTrie  ; fn-dispatch index over `fns` (built at parse/merge)
    (List (Pair Symbol (List Symbol)))))  ; claim/requirement/axiom items: name -> defining module path (Stage 4)

;; ---------------------------------------------------------------------------
;; FnTrie: build / insert / lookup. Callees precede callers (no forward refs).
;; ---------------------------------------------------------------------------

;; find the child subtrie reached by char `c`, if any.
(fn trie_child ((c Int) (cs (List (Pair Int FnTrie)))) (Option FnTrie)
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons (Pair k t) rest) (if (int_eq k c) (Some t) (trie_child c rest)))))

;; replace (or append) the child keyed by `c` with `sub`.
(fn child_set ((c Int) (sub FnTrie) (cs (List (Pair Int FnTrie))))
  (List (Pair Int FnTrie))
  (measure (struct cs))
  (match cs
    (Nil (Cons (Pair c sub) Nil))
    ((Cons (Pair k t) rest)
     (if (int_eq k c) (Cons (Pair c sub) rest)
     (Cons (Pair k t) (child_set c sub rest))))))

;; suffix equality for the FnLeaf arm — a plain simultaneous walk.
(fn trie_suffix_eq ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil True)
        (_ False)))
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (int_eq x y) (trie_suffix_eq xs ys) False))))))

;; walk the trie by the remaining chars; at the end return this node's payload.
(fn trie_lookup_chars ((cs (List Int)) (t FnTrie)) (Option FnDef)
  (measure (struct cs))
  (match t
    ((FnLeaf suffix fd) (if (trie_suffix_eq cs suffix) (Some fd) None))
    ((FnTrie here children)
     (match cs
       (Nil here)
       ((Cons c rest)
        (match (trie_child c children)
          (None None)
          ((Some sub) (trie_lookup_chars rest sub))))))))

;; trie key: the FULL qualified name — module path segments then the bare
;; name, '/'-separated. Same-named fns in different modules are DIFFERENT
;; functions (the path is identity); a bare-name key would conflate them and
;; keep-first would silently hand the loser's calls the winner's def.
(fn qn_key_go ((segs (List Symbol)) (name Symbol)) (List Int)
  (measure (struct segs))
  (match segs
    (Nil (chars_of_sym name))
    ((Cons s rest)
     (append_int (chars_of_sym s) (Cons 47 (qn_key_go rest name))))))

(fn qn_key_chars ((q QName)) (List Int) (qn_key_go (qn_mod q) (qn_name q)))

;; resolve a function name to its FnDef, O(name length). The reducer's hot path.
(fn trie_lookup ((name QName) (t FnTrie)) (Option FnDef)
  (trie_lookup_chars (qn_key_chars name) t))

;; explode a leaf one level into a branch node so an insert can proceed past it.
(fn trie_leaf_split ((suffix (List Int)) (fd FnDef)) FnTrie
  (match suffix
    (Nil (FnTrie (Some fd) Nil))
    ((Cons c rest) (FnTrie None (Cons (Pair c (FnLeaf rest fd)) Nil)))))

;; --- termination measure for trie_insert_chars (lexicographic) -------------
;; trie_insert_chars recurses two ways: (1) on the FnLeaf arm it re-inserts the
;; SAME cs into a leaf exploded one level into a branch — cs is unchanged but
;; the node goes leaf→branch; (2) on the FnTrie/Cons arm it descends with the
;; tail of cs. Neither argument alone decreases at both sites, so the measure
;; is the lexicographic combination  2*(len cs) + leafbit(t):  site (1) keeps
;; len cs and drops leafbit 1→0 (−1); site (2) drops len cs by one (−2) while
;; leafbit rises by at most one (net ≤ −1). Both helpers are kernel-local; the
;; facts cited by the measure (below trie_insert_chars) reach neither
;; trie_insert_chars in the call graph, so stratified citation admits them.
(fn tic_len ((cs (List Int))) Int
  (measure (struct cs))
  (match cs
    (Nil 0)
    ((Cons _ t) (+ 1 (tic_len t)))))

(fn tic_leafbit ((t FnTrie)) Int
  (match t
    ((FnLeaf _ _) 1)
    ((FnTrie _ _) 0)))

;; insert fd under the remaining chars; KEEP-FIRST on a name clash (mirrors the
;; old list-scan lookup_fn, which returned the first matching def). A fresh
;; unshared tail is stored as a compressed FnLeaf; inserting THROUGH a leaf
;; first explodes it one level (recursively, while the two names share chars).
(fn trie_insert_chars ((cs (List Int)) (fd FnDef) (t FnTrie)) FnTrie
  (measure
    (+ (* 2 (tic_len cs)) (tic_leafbit t))
    ;; site 0 (FnLeaf arm): cs unchanged, t = (FnLeaf suffix old) → branch.
    ;; decrease: leafbit(leaf_split …)=0 (tic_split_branch) < leafbit t =1.
    (steps
      ((rewrite (lemma tic_split_branch) lr lhs true ())
       (rewrite (premise 0) lr lhs true ())
       (rewrite (lemma tic_leafbit_fnleaf) lr lhs true ()))
      (by arith (list 1 0 0)))
    ;; nonneg: 0 <= 2*(len cs) + 0.
    (have (= (le 0 (tic_len cs)) True)
      (rewrite-with (lemma tic_len_nonneg) lr lhs ((inst xs cs)) () refl)
      (steps
        ((rewrite (lemma tic_split_branch) lr lhs true ()))
        (by arith (list 1 0 0 2))))
    ;; site 1 (FnTrie/Cons arm): cs = (Cons c rest), descend on rest.
    ;; decrease: 2*len rest + leafbit sub  <  2*(1+len rest) + 0, given
    ;; leafbit sub <= 1 (tic_leafbit_le1).
    (have (= (le (tic_leafbit sub) 1) True)
      (rewrite-with (lemma tic_leafbit_le1) lr lhs ((inst tt sub)) () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (premise 1) lr lhs true ())
         (rewrite (lemma tic_leafbit_fntrie) lr lhs true ())
         (rewrite (lemma tic_len_cons) lr lhs true ()))
        (by arith (list 1 0 0 0 1))))
    ;; nonneg: 0 <= 2*(len rest) + leafbit sub.
    (have (= (le 0 (tic_len rest)) True)
      (rewrite-with (lemma tic_len_nonneg) lr lhs ((inst xs rest)) () refl)
      (have (= (le 0 (tic_leafbit sub)) True)
        (rewrite-with (lemma tic_leafbit_ge0) lr lhs ((inst tt sub)) () refl)
        (by arith (list 1 0 0 0 2 1)))))
  (match t
    ((FnLeaf suffix old)
     (if (trie_suffix_eq cs suffix) t  ; same name → KEEP-FIRST
     (trie_insert_chars cs fd (trie_leaf_split suffix old))))
    ((FnTrie here children)
     (match cs
       (Nil
         (match here
           (None (FnTrie (Some fd) children))
           ((Some _) t)))
       ((Cons c rest)
        (match (trie_child c children)
          (None (FnTrie here (child_set c (FnLeaf rest fd) children)))
          ((Some sub)
           (FnTrie here (child_set c (trie_insert_chars rest fd sub) children)))))))))

;; ---- totality support for trie_insert_chars (cited by its measure) ---------
;; None of these reaches trie_insert_chars in the call graph, so stratified
;; citation admits them as same-closure facts.

;; tic_len's defining equations.
(claim tic_len_nil (goal () () (= (tic_len Nil) 0)) (steps ((simp lhs)) refl))

(claim tic_len_cons
  (goal ((h Int) (t (List Int))) () (= (tic_len (Cons h t)) (+ 1 (tic_len t))))
  (steps ((simp lhs)) refl))

;; 0 <= tic_len xs. Induction; the step materializes the IH as a premise
;; (farkas does not read induct IHs as slots), then bumps it past the +1.
(claim tic_len_nonneg
  (goal ((xs (List Int))) () (= (le 0 (tic_len xs)) True))
  (induct xs
    ((case Nil
       (steps
         ((rewrite (lemma tic_len_nil) lr lhs true ()))
         (by arith (list 1))))
     (case Cons
       (h t)
       (have (= (le 0 (tic_len t)) True)
         (steps ((rewrite (hyp 0) lr lhs true ())) refl)
         (steps
           ((rewrite (lemma tic_len_cons) lr lhs true ()))
           (by arith (list 1 1))))))))

;; tic_leafbit's defining equations.
(claim tic_leafbit_fnleaf
  (goal ((s (List Int)) (f FnDef)) () (= (tic_leafbit (FnLeaf s f)) 1))
  (steps ((simp lhs)) refl))

(claim tic_leafbit_fntrie
  (goal ((h (Option FnDef)) (c (List (Pair Int FnTrie)))) ()
    (= (tic_leafbit (FnTrie h c)) 0))
  (steps ((simp lhs)) refl))

;; leafbit is the bit {0,1}: bound it both ways by a case split on the node.
(claim tic_leafbit_ge0
  (goal ((tt FnTrie)) () (= (le 0 (tic_leafbit tt)) True))
  (case-on tt FnTrie
    ((case FnTrie
       (h c)
       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
     (case FnLeaf
       (s f)
       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl)))))

(claim tic_leafbit_le1
  (goal ((tt FnTrie)) () (= (le (tic_leafbit tt) 1) True))
  (case-on tt FnTrie
    ((case FnTrie
       (h c)
       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
     (case FnLeaf
       (s f)
       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl)))))

;; the leaf-split always yields a branch node, so its leafbit is 0.
(claim tic_split_branch
  (goal ((suffix (List Int)) (fd FnDef)) ()
    (= (tic_leafbit (trie_leaf_split suffix fd)) 0))
  (case-on suffix List
    ((case Nil (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
     (case Cons
       (c rest)
       (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl)))))

(fn trie_insert ((fd FnDef) (t FnTrie)) FnTrie
  (match fd
    ((FnDef name _ _ _) (trie_insert_chars (qn_key_chars name) fd t))))

;; first fn with this BARE name, in load order (the old name-keyed trie
;; semantics) — for walks whose names come from OUTSIDE resolution (a bin
;; form's entry symbol, the ledger's bare-symbol call closure).
(fn find_fn_named ((n Symbol) (fds (List FnDef))) (Option FnDef)
  (measure (struct fds))
  (match fds
    (Nil None)
    ((Cons fd rest)
     (match fd
       ((FnDef q _ _ _)
        (if (sym_eq (qn_name q) n) (Some fd) (find_fn_named n rest)))))))

(fn trie_insert_many ((fds (List FnDef)) (t FnTrie)) FnTrie
  (measure (struct fds))
  (match fds
    (Nil t)
    ((Cons fd rest) (trie_insert_many rest (trie_insert fd t)))))

(fn build_fn_trie ((fds (List FnDef))) FnTrie
  (trie_insert_many fds (FnTrie None Nil)))

;; ---------------------------------------------------------------------------
;; Type-level helpers.
;; ---------------------------------------------------------------------------

;; An OPAQUE datatype contributes TWO same-qname typedefs to the merged
;; HOME closure: the interface's `(sig type T)` (ctorless) and the impl's
;; transparent `(type T (C …) …)`. merge_modules orders deps first, so the
;; sig precedes the impl and a plain first-by-name scan reads ZERO ctors —
;; which made home-module induct/case-on blind to the module's OWN ctors
;; (the issue-#16 vacuous proofs, then blanket refusals). Prefer the twin
;; that CARRIES ctors, the find_refinement pattern below: a module's
;; fulfills proofs may open their own type. In a CONSUMER's check-mode
;; closure the impl typedef is ABSENT, so nothing is pierced — opacity
;; stays structural, not policed. Refined types carry ctors in NEITHER
;; twin, so zero-ctor induct/case-on still refuse over them.
(fn lookup_typedef ((name QName) (m Module)) (Option TypeDef)
  (match m
    ((Module tds _ _ _ _)
     (match (find_typedef_ctors name tds)
       ((Some td) (Some td))
       (None (find_typedef name tds))))))

;; the same-qname entry that actually carries constructors, if any.
(fn find_typedef_ctors ((name QName) (tds (List TypeDef))) (Option TypeDef)
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons td rest)
     (match td
       ((TypeDef tname _ ctors _)
        (if (qname_eq name tname)
          (match ctors
            (Nil (find_typedef_ctors name rest))
            (_ (Some td)))
          (find_typedef_ctors name rest)))))))

;; Lookup an extern declaration by name. The runtime uses this when
;; intercepting stuck calls to extern symbols; not needed by the
;; reducer (which treats all unknown calls as stuck regardless).
(fn lookup_extern ((name QName) (m Module)) (Option ExternDef)
  (match m
    ((Module _ _ exts _ _) (find_extern name exts))))

(fn find_extern ((name QName) (exts (List ExternDef))) (Option ExternDef)
  (measure (struct exts))
  (match exts
    (Nil None)
    ((Cons ed rest)
     (match ed
       ((ExternDef ename _ _)
        (if (qname_eq name ename) (Some ed) (find_extern name rest)))))))

(fn find_typedef ((name QName) (tds (List TypeDef))) (Option TypeDef)
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons td rest)
     (match td
       ((TypeDef tname _ _ _)
        (if (qname_eq name tname) (Some td) (find_typedef name rest)))))))

;; The refinement of a named type: (Some (base, predicate)) if `name` is a
;; refined type `(type name (refine base predicate))`, else None. The single
;; lookup the refinement rules (typing of refine_val/refine_try, the refine-fact
;; step, the refined-return obligation) consult. See docs/REFINEMENT.md.
;;
;; An OPAQUE refined type contributes TWO same-qname typedefs to the merged
;; closure: the imported `(sig type R)` (ctorless, refinement None) and the
;; impl's `(type R (refine BASE PRED))` (refinement Some). merge_modules orders
;; deps first, so the sig precedes the impl — a plain first-by-name lookup would
;; read the sig's None and miss the refinement. So scan for the same-qname entry
;; that actually CARRIES a refinement; only `(type … (refine …))` ever sets it,
;; so a Some is unambiguous (a datatype/sig same-qname twin is always None).
(fn typedef_refine ((name QName) (m Module)) (Option (Pair Type QName))
  (match m
    ((Module tds _ _ _ _) (find_refinement name tds))))

(fn find_refinement ((name QName) (tds (List TypeDef)))
  (Option (Pair Type QName))
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons (TypeDef tname _ _ r) rest)
     (if (qname_eq name tname)
       (match r
         ((Some _) r)
         (None (find_refinement name rest)))
       (find_refinement name rest)))))

;; type_head: extract (ctor_name, args) from a TCon; None for TVar.
(fn type_head ((t Type)) (Option (Pair QName (List Type)))
  (match t
    ((TCon c args) (Some (Pair c args)))
    ((TVar _) None)))

;; Structural equality on Type.
(fn type_eq ((a Type) (b Type)) Bool
  (measure (struct a))
  (match a
    ((TVar xa)
     (match b
       ((TVar xb) (sym_eq xa xb))
       (_ False)))
    ((TCon ca aa)
     (match b
       ((TCon cb ab) (if (qname_eq ca cb) (type_eq_list aa ab) False))
       (_ False)))))

(fn type_eq_list ((xs (List Type)) (ys (List Type))) Bool
  (measure (struct xs))
  (match xs
    (Nil
      (match ys
        (Nil True)
        (_ False)))
    ((Cons x xr)
     (match ys
       (Nil False)
       ((Cons y yr) (if (type_eq x y) (type_eq_list xr yr) False))))))

;; type_subst: substitute TVars in t per the assoc list. Used to
;; instantiate a TypeDef's parameters when inducting on a generic type.
(fn type_subst ((env (List (Pair Symbol Type))) (t Type)) Type
  (measure (struct t))
  (match t
    ((TVar x)
     (match (assoc_sym_type x env)
       ((Some t2) t2)
       (None t)))
    ((TCon c args) (TCon c (type_subst_list env args)))))

(fn type_subst_list ((env (List (Pair Symbol Type))) (ts (List Type)))
  (List Type)
  (measure (struct ts))
  (match ts
    (Nil Nil)
    ((Cons h t) (Cons (type_subst env h) (type_subst_list env t)))))

(fn assoc_sym_type ((x Symbol) (env (List (Pair Symbol Type)))) (Option Type)
  (measure (struct env))
  (match env
    (Nil None)
    ((Cons (Pair k v) rest) (if (sym_eq x k) (Some v) (assoc_sym_type x rest)))))

(fn zip_pairs ((xs (List Symbol)) (ys (List Type))) (List (Pair Symbol Type))
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons x xrest)
     (match ys
       (Nil Nil)
       ((Cons y yrest) (Cons (Pair x y) (zip_pairs xrest yrest)))))))
