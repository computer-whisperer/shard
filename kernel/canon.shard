;;; canon.shard — the canonical-form recognizer: syntactic tier C1–C6 +
;;; C8–C10, and the tier-2 theory check C7 (the append rule set)
;;; (docs/CANON.md §3/§5). An ADMISSION-layer predicate over the elaborated
;;; core AST: semantics-neutral and trust-neutral — a verdict here can only
;;; admit or reject source, never prove anything. Stage-1 enforcement is
;;; ADVISORY (CANON.md §3 ratchet): the driver renders one count-free
;;; `CANON <fn>: C<k> <subject>` line per violation found in the TARGET
;;; file's own fns (COCanon outcome); nothing fails, no exit code changes.
;;;
;;; Scope: fn BODIES only. Goal positions (claims/requirements) are exempt
;;; BY CONSTRUCTION — this module is never consulted for them (CANON.md C1
;;; scope ruling: goals exist to relate spellings). Patterns are likewise
;;; untouched: Z/S in a match arm is structural case analysis, not a ground
;;; value spelled the long way.
;;;
;;; C1 consults the reducer's OWN prim table (try_step_prim): a ground prim
;;; redex is exactly a core-pathed Call whose literal args make the table
;;; step, so the recognizer cannot drift from what actually folds. Two
;;; table entries are excluded: gen_fresh (effectful — folding it would be
;;; wrong, not just non-canonical) and refine_val (a typing coercion, not a
;;; value spelled the long way).

(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(import "reduce.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel reduce try_step_prim))
(use (:: kernel reduce try_match_arms))

;; one violation: invariant number (1..10) + a subject symbol for the line
;; (C1: the prim; C2: 'if/'match; C3: 'dead/'order/'merge; C4/C5: the ctor
;; or 'lit/'unreachable; C6: 'S/'Z; C7: the rule name (nil_left/cons/
;; assoc/nil_right); C8: 'respell/'rebuild; C9: 'bool; C10: 'vacif/'match).
(type CViol (CViol Int Symbol))

;; ---------------------------------------------------------------------------
;; small local helpers (Module field access + list plumbing)
;; ---------------------------------------------------------------------------

(fn cn_tds ((m Module)) (List TypeDef)
  (match m
    ((Module tds _ _ _ _) tds)))

(fn cn_fns ((m Module)) (List FnDef)
  (match m
    ((Module _ fs _ _ _) fs)))

(fn cn_app ((a (List CViol)) (b (List CViol))) (List CViol)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons v rest) (Cons v (cn_app rest b)))))

(fn cn_len_el ((es (List Expr))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons _ rest) (+ 1 (cn_len_el rest)))))

(fn cn_len_i ((xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ rest) (+ 1 (cn_len_i rest)))))

(fn cn_int_mem ((x Int) (xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h rest) (if (int_eq h x) True (cn_int_mem x rest)))))

;; strictly descending Int list (the reversed first-use accumulator is
;; descending exactly when first-use order is ascending)
(fn cn_desc ((xs (List Int))) Bool
  (measure (struct xs))
  (match xs
    (Nil True)
    ((Cons a rest)
     (match rest
       (Nil True)
       ((Cons b _) (if (lt b a) (cn_desc rest) False))))))

;; lexicographic order on symbol names (C4's key for PSym arms)
(fn cn_chars_lt ((a (List Int)) (b (List Int))) Bool
  (measure (struct a))
  (match a
    (Nil
      (match b
        (Nil False)
        (_ True)))
    ((Cons x xr)
     (match b
       (Nil False)
       ((Cons y yr) (if (lt x y) True (if (lt y x) False (cn_chars_lt xr yr))))))))

;; ---------------------------------------------------------------------------
;; ground values (C2) and ground Nats (C6)
;; ---------------------------------------------------------------------------

(fn cn_ground ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((IntLit _) True)
    ((SymLit _) True)
    ((Ctor _ args) (cn_ground_l args))
    (_ False)))

(fn cn_ground_l ((es (List Expr))) Bool
  (measure (struct es))
  (match es
    (Nil True)
    ((Cons a rest) (if (cn_ground a) (cn_ground_l rest) False))))

;; a ground Nat: the packed literal, or a Z/S ctor tower over one (the
;; matcher's nat view, read as a value recognizer — cf. reduce.shard's
;; match_nat_view and types.shard's tc_nat_lit_view)
(fn cn_nat_ground ((e Expr)) Bool
  (measure (struct e))
  (match e
    ((IntLit n) (le 0 n))
    ((Ctor q args)
     (if (core_named q (quote Z)) True
     (if (core_named q (quote S))
       (match args
         ((Cons a Nil) (cn_nat_ground a))
         (_ False))
       False)))
    (_ False)))

;; ---------------------------------------------------------------------------
;; C3 support: the first-use walk. Collects the enclosing Let's binders as
;; SOURCE positions (0..n-1, source order) in PREORDER first-use order,
;; REVERSED (front = latest first-use). d = extra binder depth below the
;; Let body; the Let's binders sit at BVar d..d+n-1 there, and the
;; elaborator assigns BVar indices INNERMOST-FIRST (source binding i =
;; BVar n-1-i — the parameter convention, pinned by examples/canon_pin's
;; cp_pair), so source position = n-1-(i-d).
;; ---------------------------------------------------------------------------

(fn cn_ord ((e Expr) (d Int) (n Int) (acc (List Int))) (List Int)
  (measure (struct e))
  (match e
    ((BVar i)
     (let ((j (- i d)))
       (if (le 0 j)
         (if (lt j n)
           (let ((sp (- (- n 1) j))) (if (cn_int_mem sp acc) acc (Cons sp acc)))
           acc)
         acc)))
    ((Ctor _ args) (cn_ord_l args d n acc))
    ((Call _ args) (cn_ord_l args d n acc))
    ((If c t e2) (cn_ord e2 d n (cn_ord t d n (cn_ord c d n acc))))
    ((Let bs body) (cn_ord body (+ d (cn_len_el bs)) n (cn_ord_l bs d n acc)))
    ((Match s arms) (cn_ord_arms arms d n (cn_ord s d n acc)))
    (_ acc)))

(fn cn_ord_l ((es (List Expr)) (d Int) (n Int) (acc (List Int))) (List Int)
  (measure (struct es))
  (match es
    (Nil acc)
    ((Cons a rest) (cn_ord_l rest d n (cn_ord a d n acc)))))

(fn cn_ord_arms ((arms (List Arm)) (d Int) (n Int) (acc (List Int))) (List Int)
  (measure (struct arms))
  (match arms
    (Nil acc)
    ((Cons (Arm p b) rest)
     (cn_ord_arms rest d n (cn_ord b (+ d (cn_pat_binds p)) n acc)))))

(fn cn_pat_binds ((p Pat)) Int
  (measure (struct p))
  (match p
    ((PVar) 1)
    ((PCtor _ ps) (cn_pats_binds ps))
    (_ 0)))

(fn cn_pats_binds ((ps (List Pat))) Int
  (measure (struct ps))
  (match ps
    (Nil 0)
    ((Cons p rest) (+ (cn_pat_binds p) (cn_pats_binds rest)))))

;; C3 on one Let node: every binding used (dead), first-use order matches
;; binding order (order), and an immediately nested INDEPENDENT Let is a
;; missed parallel merge (merge — nesting is the spelling of dependence).
(fn cn_c3 ((bs (List Expr)) (body Expr)) (List CViol)
  (let ((n (cn_len_el bs)))
    (let ((used (cn_ord body 0 n Nil)))
      (cn_app
        (if (lt (cn_len_i used) n) (Cons (CViol 3 (quote dead)) Nil) Nil)
        (cn_app
          (if (cn_desc used) Nil (Cons (CViol 3 (quote order)) Nil))
          (match body
            ((Let bs2 _)
             (match (cn_ord_l bs2 0 n Nil)
               (Nil (Cons (CViol 3 (quote merge)) Nil))
               (_ Nil)))
            (_ Nil)))))))

;; ---------------------------------------------------------------------------
;; C8 support: arm-local scrutinee discipline (var scrutinee only).
;; (a) 'respell — a binder-less arm (ground ctor / literal pattern) must not
;;     mention the scrutinee var: the arm's equation has pinned the value.
;; (b) 'rebuild — no arm body may contain the EXACT rebuild of a binding
;;     PCtor pattern over the arm's own binders: the scrutinee var already
;;     names (and shares) that value. Bare-PVar catch-alls are excluded —
;;     binder aliasing is not a priced freedom.
;; Binder convention: the pattern's k-th DFS PVar = BVar nb-1-k at arm-body
;; top (innermost-first, as parameters and lets) — arbitrated by
;; examples/canon_rejects' cr_c8b two-binder rebuild.
;; ---------------------------------------------------------------------------

(fn cn_occf ((e Expr) (x Symbol)) Bool
  (measure (struct e))
  (match e
    ((FVar y) (sym_eq y x))
    ((Ctor _ args) (cn_occf_l args x))
    ((Call _ args) (cn_occf_l args x))
    ((If c t e2) (if (cn_occf c x) True (if (cn_occf t x) True (cn_occf e2 x))))
    ((Let bs body) (if (cn_occf_l bs x) True (cn_occf body x)))
    ((Match s arms) (if (cn_occf s x) True (cn_occf_arms arms x)))
    (_ False)))

(fn cn_occf_l ((es (List Expr)) (x Symbol)) Bool
  (measure (struct es))
  (match es
    (Nil False)
    ((Cons a rest) (if (cn_occf a x) True (cn_occf_l rest x)))))

(fn cn_occf_arms ((arms (List Arm)) (x Symbol)) Bool
  (measure (struct arms))
  (match arms
    (Nil False)
    ((Cons (Arm _ b) rest) (if (cn_occf b x) True (cn_occf_arms rest x)))))

;; does e spell pattern p exactly, with p's k-th DFS PVar as
;; BVar (dd + nb-1-k)? Threads k; Some k' = matched so far.
;; the GROUND-PIN context: binder index (current depth) -> the ground value
;; a nested match arm pinned it to. This is what lets the rebuild check
;; COMPOSE through nesting (the playground's PinnedNil): in
;;   (match xs ((Cons h t) (match t (Nil ... (Cons h Nil) ...))))
;; the inner Nil arm pins t = Nil, so (Cons h Nil) IS the rebuild of xs.
(fn cn_pin_get ((j Int) (pins (List (Pair Int Expr)))) (Option Expr)
  (measure (struct pins))
  (match pins
    (Nil None)
    ((Cons (Pair i v) rest) (if (int_eq i j) (Some v) (cn_pin_get j rest)))))

;; keys shift as binders enter; VALUES shift too — C8's ground values are
;; untouched (shift is the identity on closed terms) and C11's shape
;; values spell arm binders, which must track depth.
(fn cn_pins_shift ((pins (List (Pair Int Expr))) (n Int)) (List (Pair Int Expr))
  (measure (struct pins))
  (match pins
    (Nil Nil)
    ((Cons (Pair i v) rest)
     (Cons (Pair (+ i n) (shift n 0 v)) (cn_pins_shift rest n)))))

;; a fully-ground pattern as the closed value it pins (None if it binds)
(fn cn_pat_val ((p Pat)) (Option Expr)
  (measure (struct p))
  (match p
    ((PVar) None)
    ((PCtor q ps)
     (match (cn_pat_val_l ps)
       ((Some es) (Some (Ctor q es)))
       (None None)))
    ((PInt v) (Some (IntLit v)))
    ((PSym s) (Some (SymLit s)))))

(fn cn_pat_val_l ((ps (List Pat))) (Option (List Expr))
  (measure (struct ps))
  (match ps
    (Nil (Some Nil))
    ((Cons p rest)
     (match (cn_pat_val p)
       ((Some e)
        (match (cn_pat_val_l rest)
          ((Some es) (Some (Cons e es)))
          (None None)))
       (None None)))))

;; ---------------------------------------------------------------------------
;; C11 support (CANON.md §13, slice 1): SHAPE pins. Every ctor/literal arm
;; over a variable scrutinee pins that variable to the pattern's shape —
;; the k-th DFS PVar spelled as arm binder BVar nb-1-k (the parameter
;; convention). Unlike cn_pat_val this is total: binder-bearing patterns
;; pin partially-symbolic shapes, which is what lets the re-split check
;; decide DEEP patterns by composing pins through nesting.
;; ---------------------------------------------------------------------------

(fn cn_pat_shape ((p Pat) (nb Int) (k Int)) (Pair Expr Int)
  (measure (struct p))
  (match p
    ((PVar) (Pair (BVar (- (- nb 1) k)) (+ k 1)))
    ((PCtor q ps)
     (match (cn_pat_shape_l ps nb k)
       ((Pair es k2) (Pair (Ctor q es) k2))))
    ((PInt v) (Pair (IntLit v) k))
    ((PSym s) (Pair (SymLit s) k))))

(fn cn_pat_shape_l ((ps (List Pat)) (nb Int) (k Int)) (Pair (List Expr) Int)
  (measure (struct ps))
  (match ps
    (Nil (Pair Nil k))
    ((Cons p rest)
     (match (cn_pat_shape p nb k)
       ((Pair e k2)
        (match (cn_pat_shape_l rest nb k2)
          ((Pair es k3) (Pair (Cons e es) k3))))))))

;; FVar-keyed pins (fn-param scrutinees). Keys never shift; VALUES spell
;; arm binders, so they shift with depth exactly like the Int-keyed pins'.
(fn cn_fpin_get ((x Symbol) (fp (List (Pair Symbol Expr)))) (Option Expr)
  (measure (struct fp))
  (match fp
    (Nil None)
    ((Cons (Pair y v) rest) (if (sym_eq y x) (Some v) (cn_fpin_get x rest)))))

(fn cn_fpins_shift ((fp (List (Pair Symbol Expr))) (n Int))
  (List (Pair Symbol Expr))
  (measure (struct fp))
  (match fp
    (Nil Nil)
    ((Cons (Pair y v) rest)
     (Cons (Pair y (shift n 0 v)) (cn_fpins_shift rest n)))))

;; one pin-substitution pass: pinned variables become their shapes. Values
;; are NOT re-entered here — cn_px iterates passes instead, one per
;; Int-keyed pin (a chase is depth-ordered: shape values spell only
;; binders, an FVar hit can occur only at the root, so len(bp)+1 passes
;; reach the composed shape).
(fn cn_px1 ((e Expr) (fp (List (Pair Symbol Expr))) (bp (List (Pair Int Expr))))
  Expr
  (measure (struct e))
  (match e
    ((FVar x)
     (match (cn_fpin_get x fp)
       ((Some v) v)
       (None e)))
    ((BVar j)
     (match (cn_pin_get j bp)
       ((Some v) v)
       (None e)))
    ((Ctor q args) (Ctor q (cn_px1_l args fp bp)))
    (_ e)))

(fn cn_px1_l
  ((es (List Expr)) (fp (List (Pair Symbol Expr))) (bp (List (Pair Int Expr))))
  (List Expr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons a rest) (Cons (cn_px1 a fp bp) (cn_px1_l rest fp bp)))))

(fn cn_px
  ((e Expr)
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr)))
   (todo (List (Pair Int Expr))))
  Expr
  (measure (struct todo))
  (match todo
    (Nil (cn_px1 e fp bp))
    ((Cons _ rest) (cn_px (cn_px1 e fp bp) fp bp rest))))

;; C11 'resplit: a match on a variable some enclosing arm PINNED re-splits
;; decided control — after expanding the pins the matcher FIRES an arm
;; (the composed shape decides deep patterns too). Pin-dependence is
;; load-bearing: a match the BARE variable already fires (a catch-all
;; first arm) is C5/C10m territory, not a re-split. Three-valuedness
;; keeps partial knowledge honest: an arm the shape leaves UNDECIDED
;; (MStuck) is a runtime filter and no flag is raised.
(fn cn_c11
  ((s Expr)
   (arms (List Arm))
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr))))
  (List CViol)
  (match s
    ((FVar x)
     (match (cn_fpin_get x fp)
       (None Nil)
       ((Some _) (cn_c11f s arms fp bp))))
    ((BVar j)
     (match (cn_pin_get j bp)
       (None Nil)
       ((Some _) (cn_c11f s arms fp bp))))
    (_ Nil)))

(fn cn_c11f
  ((s Expr)
   (arms (List Arm))
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr))))
  (List CViol)
  (match (try_match_arms arms s)
    ((ArmFired _) Nil)
    (_
      (match (try_match_arms arms (cn_px s fp bp bp))
        ((ArmFired _) (Cons (CViol 11 (quote resplit)) Nil))
        (_ Nil)))))

(fn cn_rbp
  ((p Pat) (e Expr) (dd Int) (nb Int) (k Int) (pins (List (Pair Int Expr))))
  (Option Int)
  (measure (struct p))
  (match p
    ((PVar)
     (match e
       ((BVar j) (if (int_eq j (+ dd (- (- nb 1) k))) (Some (+ k 1)) None))
       (_
         ;; the binder's position may be spelled by its pinned GROUND value
         (match (cn_pin_get (+ dd (- (- nb 1) k)) pins)
           ((Some v) (if (expr_eq e v) (Some (+ k 1)) None))
           (None None)))))
    ((PCtor q ps)
     (match e
       ((Ctor q2 es) (if (qname_eq q q2) (cn_rbp_l ps es dd nb k pins) None))
       (_ None)))
    ((PInt v)
     (match e
       ((IntLit w) (if (int_eq v w) (Some k) None))
       (_ None)))
    ((PSym s)
     (match e
       ((SymLit s2) (if (sym_eq s s2) (Some k) None))
       (_ None)))))

(fn cn_rbp_l
  ((ps (List Pat))
   (es (List Expr))
   (dd Int)
   (nb Int)
   (k Int)
   (pins (List (Pair Int Expr))))
  (Option Int)
  (measure (struct ps))
  (match ps
    (Nil
      (match es
        (Nil (Some k))
        (_ None)))
    ((Cons p prest)
     (match es
       (Nil None)
       ((Cons e erest)
        (match (cn_rbp p e dd nb k pins)
          (None None)
          ((Some k2) (cn_rbp_l prest erest dd nb k2 pins))))))))

;; rebuild scan: the exact rebuild anywhere in e (dd = binder depth below
;; the arm-body top). pins carry the ground equations nested match arms
;; establish (indices at the CURRENT depth, shifted as binders enter), so
;; the scan composes through nesting — the pinned-list normal form's
;; recognizer image (CANON.md D17's family, measured by the stack machine).
(fn cn_rbs ((e Expr) (p Pat) (nb Int) (dd Int) (pins (List (Pair Int Expr))))
  Bool
  (measure (struct e))
  (match (cn_rbp p e dd nb 0 pins)
    ((Some _) True)
    (None
      (match e
        ((Ctor _ args) (cn_rbs_l args p nb dd pins))
        ((Call _ args) (cn_rbs_l args p nb dd pins))
        ((If c t e2)
         (if (cn_rbs c p nb dd pins) True
         (if (cn_rbs t p nb dd pins) True
         (cn_rbs e2 p nb dd pins))))
        ((Let bs body)
         (if (cn_rbs_l bs p nb dd pins) True
         (cn_rbs
           body
           p
           nb
           (+ dd (cn_len_el bs))
           (cn_pins_shift pins (cn_len_el bs)))))
        ((Match s arms)
         (if (cn_rbs s p nb dd pins) True (cn_rbs_arms arms s p nb dd pins)))
        (_ False)))))

(fn cn_rbs_l
  ((es (List Expr)) (p Pat) (nb Int) (dd Int) (pins (List (Pair Int Expr))))
  Bool
  (measure (struct es))
  (match es
    (Nil False)
    ((Cons a rest)
     (if (cn_rbs a p nb dd pins) True (cn_rbs_l rest p nb dd pins)))))

;; s = the nested match's scrutinee. A GROUND arm over a BVar scrutinee
;; pins that binder to the arm's value for the arm's own body (ground
;; patterns bind nothing, so the index needs no shift at creation).
(fn cn_rbs_arms
  ((arms (List Arm))
   (s Expr)
   (p Pat)
   (nb Int)
   (dd Int)
   (pins (List (Pair Int Expr))))
  Bool
  (measure (struct arms))
  (match arms
    (Nil False)
    ((Cons (Arm p2 b) rest)
     (let
       ((nb2 (cn_pat_binds p2))
        (pins2
          (match s
            ((BVar j)
             (match (cn_pat_val p2)
               ((Some v) (Cons (Pair j v) pins))
               (None pins)))
            (_ pins))))
       (if (cn_rbs b p nb (+ dd nb2) (cn_pins_shift pins2 nb2)) True
       (cn_rbs_arms rest s p nb dd pins))))))

;; per-arm C8. sf/sb: the scrutinee as FVar name or BVar index (exactly
;; one Some). (a) fires only at nb=0 where the scrutinee's index needs no
;; shift (cn_ord handles deeper binders itself); (b) never references the
;; scrutinee at all.
(fn cn_c8_arm ((p Pat) (b Expr) (sf (Option Symbol)) (sb (Option Int)))
  (List CViol)
  (let ((nb (cn_pat_binds p)))
    (if (int_eq nb 0)
      (match sf
        ((Some x) (if (cn_occf b x) (Cons (CViol 8 (quote respell)) Nil) Nil))
        (None
          (match sb
            ((Some i)
             (match (cn_ord b i 1 Nil)
               (Nil Nil)
               (_ (Cons (CViol 8 (quote respell)) Nil))))
            (None Nil))))
      (match p
        ((PCtor _ _)
         (if (cn_rbs b p nb 0 Nil) (Cons (CViol 8 (quote rebuild)) Nil) Nil))
        (_ Nil)))))

(fn cn_c8_arms ((arms (List Arm)) (sf (Option Symbol)) (sb (Option Int)))
  (List CViol)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p b) rest)
     (cn_app (cn_c8_arm p b sf sb) (cn_c8_arms rest sf sb)))))

(fn cn_c8 ((s Expr) (arms (List Arm))) (List CViol)
  (match s
    ((FVar x) (cn_c8_arms arms (Some x) None))
    ((BVar i) (cn_c8_arms arms None (Some i)))
    (_ Nil)))

;; ---------------------------------------------------------------------------
;; C10 'match — vacuous matches (the stack machine's measured tail: control
;; that decides nothing). Two coverage-guarded shapes:
;;   constant — every arm body ignores its binders and all bodies agree:
;;              the match IS that body;
;;   identity — every arm body respells the scrutinee (the shifted scrut
;;              var, the arm's ground value, or a bare-PVar alias): the
;;              match IS its scrutinee.
;; Coverage is load-bearing: a PARTIAL match is a runtime filter, not a
;; vacuous one — only a catch-all or a full ctor set makes it decorative.
;; ---------------------------------------------------------------------------

;; e with its free BVars shifted DOWN past nb arm binders (dd = inner
;; binder depth); None if e references any of the nb binders
(fn cn_shdn ((e Expr) (nb Int) (dd Int)) (Option Expr)
  (measure (struct e))
  (match e
    ((BVar j)
     (if (lt j dd) (Some (BVar j))
     (if (lt (- j dd) nb) None
     (Some (BVar (- j nb))))))
    ((Ctor q args)
     (match (cn_shdn_l args nb dd)
       ((Some es) (Some (Ctor q es)))
       (None None)))
    ((Call q args)
     (match (cn_shdn_l args nb dd)
       ((Some es) (Some (Call q es)))
       (None None)))
    ((If c t e2)
     (match (cn_shdn c nb dd)
       ((Some c2)
        (match (cn_shdn t nb dd)
          ((Some t2)
           (match (cn_shdn e2 nb dd)
             ((Some e3) (Some (If c2 t2 e3)))
             (None None)))
          (None None)))
       (None None)))
    ((Let bs body)
     (match (cn_shdn_l bs nb dd)
       ((Some bs2)
        (match (cn_shdn body nb (+ dd (cn_len_el bs)))
          ((Some b2) (Some (Let bs2 b2)))
          (None None)))
       (None None)))
    ((Match s arms)
     (match (cn_shdn s nb dd)
       ((Some s2)
        (match (cn_shdn_arms arms nb dd)
          ((Some arms2) (Some (Match s2 arms2)))
          (None None)))
       (None None)))
    (_ (Some e))))

(fn cn_shdn_l ((es (List Expr)) (nb Int) (dd Int)) (Option (List Expr))
  (measure (struct es))
  (match es
    (Nil (Some Nil))
    ((Cons a rest)
     (match (cn_shdn a nb dd)
       ((Some a2)
        (match (cn_shdn_l rest nb dd)
          ((Some es2) (Some (Cons a2 es2)))
          (None None)))
       (None None)))))

(fn cn_shdn_arms ((arms (List Arm)) (nb Int) (dd Int)) (Option (List Arm))
  (measure (struct arms))
  (match arms
    (Nil (Some Nil))
    ((Cons (Arm p b) rest)
     (match (cn_shdn b nb (+ dd (cn_pat_binds p)))
       ((Some b2)
        (match (cn_shdn_arms rest nb dd)
          ((Some arms2) (Some (Cons (Arm p b2) arms2)))
          (None None)))
       (None None)))))

;; the typedef's full ctor list, found from any member ctor
(fn cn_ctor_home ((q QName) (tds (List TypeDef))) (Option (List CtorDef))
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons (TypeDef _ _ cs _) rest)
     (match (cn_ctor_ix_go q cs 0)
       ((Some _) (Some cs))
       (None (cn_ctor_home q rest))))))

(fn cn_arm_has_ctor ((q QName) (arms (List Arm))) Bool
  (measure (struct arms))
  (match arms
    (Nil False)
    ((Cons (Arm p _) rest)
     (match p
       ((PCtor q2 _) (if (qname_eq q q2) True (cn_arm_has_ctor q rest)))
       (_ (cn_arm_has_ctor q rest))))))

(fn cn_ctors_all_present ((cs (List CtorDef)) (arms (List Arm))) Bool
  (measure (struct cs))
  (match cs
    (Nil True)
    ((Cons (CtorDef cq _) rest)
     (if (cn_arm_has_ctor cq arms) (cn_ctors_all_present rest arms) False))))

(fn cn_any_pvar ((arms (List Arm))) Bool
  (measure (struct arms))
  (match arms
    (Nil False)
    ((Cons (Arm p _) rest)
     (match p
       ((PVar) True)
       (_ (cn_any_pvar rest))))))

(fn cn_first_ctor ((arms (List Arm))) (Option QName)
  (measure (struct arms))
  (match arms
    (Nil None)
    ((Cons (Arm p _) rest)
     (match p
       ((PCtor q _) (Some q))
       (_ (cn_first_ctor rest))))))

;; exhaustive arms: a bare-PVar catch-all, or the full ctor set of the
;; typedef any ctor arm names
(fn cn_covered ((arms (List Arm)) (m Module)) Bool
  (if (cn_any_pvar arms) True
  (match (cn_first_ctor arms)
    ((Some q)
     (match (cn_ctor_home q (cn_tds m))
       ((Some cs) (cn_ctors_all_present cs arms))
       (None False)))
    (None False))))

;; constant: all arm bodies binder-free and (shift-normalized) equal
(fn cn_const_arms ((arms (List Arm)) (prev (Option Expr))) Bool
  (measure (struct arms))
  (match arms
    (Nil True)
    ((Cons (Arm p b) rest)
     (match (cn_shdn b (cn_pat_binds p) 0)
       ((Some nb2)
        (match prev
          ((Some v) (if (expr_eq v nb2) (cn_const_arms rest prev) False))
          (None (cn_const_arms rest (Some nb2)))))
       (None False)))))

;; identity: the arm body respells the scrutinee inside that arm
(fn cn_id_arm ((p Pat) (b Expr) (sf (Option Symbol)) (sb (Option Int))) Bool
  (let ((nb (cn_pat_binds p)))
    (if
      (match sf
        ((Some x)
         (match b
           ((FVar y) (sym_eq y x))
           (_ False)))
        (None
          (match sb
            ((Some i)
             (match b
               ((BVar j) (int_eq j (+ i nb)))
               (_ False)))
            (None False))))
      True
      (match (cn_pat_val p)
        ((Some v) (expr_eq b v))
        (None
          (match p
            ((PVar)
             (match b
               ((BVar j) (int_eq j 0))
               (_ False)))
            (_ False)))))))

(fn cn_id_arms ((arms (List Arm)) (sf (Option Symbol)) (sb (Option Int))) Bool
  (measure (struct arms))
  (match arms
    (Nil True)
    ((Cons (Arm p b) rest)
     (if (cn_id_arm p b sf sb) (cn_id_arms rest sf sb) False))))

(fn cn_c10m ((s Expr) (arms (List Arm)) (m Module)) (List CViol)
  (match arms
    (Nil Nil)
    (_
      (if (cn_covered arms m)
        (if (cn_const_arms arms None) (Cons (CViol 10 (quote match)) Nil)
        (match s
          ((FVar x)
           (if (cn_id_arms arms (Some x) None)
             (Cons (CViol 10 (quote match)) Nil)
             Nil))
          ((BVar i)
           (if (cn_id_arms arms None (Some i))
             (Cons (CViol 10 (quote match)) Nil)
             Nil))
          (_ Nil)))
        Nil))))

;; ---------------------------------------------------------------------------
;; C4/C5 support: arm discipline. Ctor arms in declaration order, literal
;; arms ascending, at most one catch-all and only last, no duplicates.
;; ---------------------------------------------------------------------------

(fn cn_ctor_ix_go ((q QName) (cs (List CtorDef)) (i Int)) (Option Int)
  (measure (struct cs))
  (match cs
    (Nil None)
    ((Cons (CtorDef cq _) rest)
     (if (qname_eq cq q) (Some i) (cn_ctor_ix_go q rest (+ i 1))))))

;; declaration index of ctor q within its type (scan all typedefs; a miss
;; — e.g. a builtin former — yields None and the arm is skipped, never
;; guessed about)
(fn cn_ctor_ix ((q QName) (tds (List TypeDef))) (Option Int)
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons (TypeDef _ _ cs _) rest)
     (match (cn_ctor_ix_go q cs 0)
       ((Some i) (Some i))
       (None (cn_ctor_ix q rest))))))

;; one pass over the arms. State: last ctor decl index (pix, None before
;; the first placed ctor arm), last Int literal, last Sym literal, and
;; whether a catch-all has been seen (everything after it is unreachable).
(fn cn_arms_disc
  ((arms (List Arm))
   (tds (List TypeDef))
   (pix (Option Int))
   (pint (Option Int))
   (psym (Option Symbol))
   (seen_catch Bool))
  (List CViol)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p _) rest)
     (if seen_catch
       (Cons
         (CViol 5 (quote unreachable))
         (cn_arms_disc rest tds pix pint psym True))
       (match p
         ((PVar) (cn_arms_disc rest tds pix pint psym True))
         ((PCtor q _)
          (match (cn_ctor_ix q tds)
            (None (cn_arms_disc rest tds pix pint psym False))
            ((Some ix)
             (match pix
               (None (cn_arms_disc rest tds (Some ix) pint psym False))
               ((Some prev)
                (if (int_eq ix prev)
                  (Cons
                    (CViol 5 (qn_name q))
                    (cn_arms_disc rest tds (Some ix) pint psym False))
                (if (lt ix prev)
                  (Cons
                    (CViol 4 (qn_name q))
                    (cn_arms_disc rest tds (Some ix) pint psym False))
                  (cn_arms_disc rest tds (Some ix) pint psym False))))))))
         ((PInt v)
          (match pint
            (None (cn_arms_disc rest tds pix (Some v) psym False))
            ((Some pv)
             (if (int_eq v pv)
               (Cons
                 (CViol 5 (quote lit))
                 (cn_arms_disc rest tds pix (Some v) psym False))
             (if (lt v pv)
               (Cons
                 (CViol 4 (quote lit))
                 (cn_arms_disc rest tds pix (Some v) psym False))
               (cn_arms_disc rest tds pix (Some v) psym False))))))
         ((PSym s)
          (match psym
            (None (cn_arms_disc rest tds pix pint (Some s) False))
            ((Some ps)
             (if (sym_eq s ps)
               (Cons
                 (CViol 5 (quote lit))
                 (cn_arms_disc rest tds pix pint (Some s) False))
             (if (cn_chars_lt (chars_of_sym s) (chars_of_sym ps))
               (Cons
                 (CViol 4 (quote lit))
                 (cn_arms_disc rest tds pix pint (Some s) False))
               (cn_arms_disc rest tds pix pint (Some s) False)))))))))))

;; C9: no match on Bool — `(match b (True X) (_ Y))` and `(if b X Y)` are
;; two spellings of the same branch; the if is canonical (shorter,
;; binder-free). Syntactic detection: any arm whose pattern head is the
;; core Bool ctor. Flagged once per match.
(fn cn_c9 ((arms (List Arm))) (List CViol)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p _) rest)
     (match p
       ((PCtor q _)
        (if (core_named q (quote True)) (Cons (CViol 9 (quote bool)) Nil)
        (if (core_named q (quote False)) (Cons (CViol 9 (quote bool)) Nil)
        (cn_c9 rest))))
       (_ (cn_c9 rest))))))

;; ---------------------------------------------------------------------------
;; per-node checks C1 / C2 / C6
;; ---------------------------------------------------------------------------

(fn cn_prim_flaggable ((s Symbol)) Bool
  (if (sym_eq s (quote gen_fresh)) False
  (if (sym_eq s (quote refine_val)) False
  True)))

(fn cn_c1 ((q QName) (args (List Expr))) (List CViol)
  (if (sym_path_eq (qn_mod q) (qn_core))
    (if (cn_prim_flaggable (qn_name q))
      (match (try_step_prim (qn_name q) args)
        ((Some _) (Cons (CViol 1 (qn_name q)) Nil))
        (None Nil))
      Nil)
    Nil))

;; ---------------------------------------------------------------------------
;; C7 — the tier-2 theory check, v1's ONE ratified rule set (CANON.md §5/§6):
;; the append family, each rule a PROVEN REQUIREMENT in std/list/mod.req.shard:
;;   append_nil_left    (append Nil ys)         -> ys
;;   append_cons        (append (Cons h t) ys)  -> (Cons h (append t ys))
;;   append_assoc       (append (append a b) c) -> (append a (append b c))
;;   append_nil_right   (append xs Nil)         -> xs
;; Detection is qname + shape: the rules are keyed to std/list's OWN append
;; (resolution already happened at load), and the operand types the §6
;; escape-rule side-condition guards are exactly what the TYPE GATE has
;; vetted by the time a checked module's advisory matters — this is why C7
;; is the check-time tier and can never join a read-time refusal stage.
;; ---------------------------------------------------------------------------

(fn cn_std_list_path () (List Symbol) (list (quote std) (quote list)))

(fn cn_is_std_append ((q QName)) Bool
  (if (sym_eq (qn_name q) (quote append))
    (sym_path_eq (qn_mod q) (cn_std_list_path))
    False))

(fn cn_c7_left ((a Expr)) (List CViol)
  (match a
    ((Ctor q _)
     (if (core_named q (quote Nil)) (Cons (CViol 7 (quote nil_left)) Nil)
     (if (core_named q (quote Cons)) (Cons (CViol 7 (quote cons)) Nil)
     Nil)))
    ((Call q _)
     (if (cn_is_std_append q) (Cons (CViol 7 (quote assoc)) Nil) Nil))
    (_ Nil)))

(fn cn_c7_right ((b Expr)) (List CViol)
  (match b
    ((Ctor q _)
     (if (core_named q (quote Nil)) (Cons (CViol 7 (quote nil_right)) Nil) Nil))
    (_ Nil)))

(fn cn_c7 ((q QName) (args (List Expr))) (List CViol)
  (if (cn_is_std_append q)
    (match args
      ((Cons a (Cons b Nil)) (cn_app (cn_c7_left a) (cn_c7_right b)))
      (_ Nil))
    Nil))

(fn cn_c2_if ((c Expr)) (List CViol)
  (match c
    ((Ctor q _)
     (if (core_named q (quote True)) (Cons (CViol 2 (quote if)) Nil)
     (if (core_named q (quote False)) (Cons (CViol 2 (quote if)) Nil)
     Nil)))
    (_ Nil)))

;; C10: an if whose branches are structurally equal decides nothing —
;; (if c X X) = X is the Bool case tautology. If binds nothing, so
;; expr_eq on nameless terms IS exact alpha-equality of the branches.
(fn cn_c10 ((t Expr) (e2 Expr)) (List CViol)
  (if (expr_eq t e2) (Cons (CViol 10 (quote vacif)) Nil) Nil))

(fn cn_c6 ((q QName) (args (List Expr))) (List CViol)
  (if (core_named q (quote Z)) (Cons (CViol 6 (quote Z)) Nil)
  (if (core_named q (quote S))
    (match args
      ((Cons a Nil) (if (cn_nat_ground a) (Cons (CViol 6 (quote S)) Nil) Nil))
      (_ Nil))
    Nil)))

;; ---------------------------------------------------------------------------
;; the main walk (mutual over Expr / List Expr / arm bodies)
;; ---------------------------------------------------------------------------

;; the external surface — pins start empty (a fn body's params are unpinned)
(fn cn_e ((e Expr) (m Module)) (List CViol) (cn_ep e m Nil Nil))

(fn cn_ep
  ((e Expr)
   (m Module)
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr))))
  (List CViol)
  (measure (struct e))
  (match e
    ((Call q args)
     (cn_app (cn_c1 q args) (cn_app (cn_c7 q args) (cn_lp args m fp bp))))
    ((Ctor q args) (cn_app (cn_c6 q args) (cn_lp args m fp bp)))
    ((If c t e2)
     (cn_app
       (cn_c2_if c)
       (cn_app
         (cn_c10 t e2)
         (cn_app
           (cn_ep c m fp bp)
           (cn_app (cn_ep t m fp bp) (cn_ep e2 m fp bp))))))
    ((Match s arms)
     (cn_app
       (if (cn_ground s) (Cons (CViol 2 (quote match)) Nil) Nil)
       (cn_app
         (cn_arms_disc arms (cn_tds m) None None None False)
         (cn_app
           (cn_c8 s arms)
           (cn_app
             (cn_c10m s arms m)
             (cn_app
               (cn_c9 arms)
               (cn_app
                 (cn_c11 s arms fp bp)
                 (cn_app (cn_ep s m fp bp) (cn_abp s arms m fp bp)))))))))
    ((Let bs body)
     (cn_app
       (cn_c3 bs body)
       (cn_app
         (cn_lp bs m fp bp)
         (cn_ep
           body
           m
           (cn_fpins_shift fp (cn_len_el bs))
           (cn_pins_shift bp (cn_len_el bs))))))
    (_ Nil)))

(fn cn_lp
  ((es (List Expr))
   (m Module)
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr))))
  (List CViol)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons a rest) (cn_app (cn_ep a m fp bp) (cn_lp rest m fp bp)))))

;; arm entry: shift both pin environments past the arm's binders, then pin
;; a VARIABLE scrutinee to the arm's shape. Bare-PVar arms pin nothing
;; (binder aliasing is not a shape).
(fn cn_abp
  ((s Expr)
   (arms (List Arm))
   (m Module)
   (fp (List (Pair Symbol Expr)))
   (bp (List (Pair Int Expr))))
  (List CViol)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p b) rest)
     (cn_app
       (cn_ep b m (cn_abp_fp s p fp) (cn_abp_bp s p bp))
       (cn_abp s rest m fp bp)))))

(fn cn_abp_fp ((s Expr) (p Pat) (fp (List (Pair Symbol Expr))))
  (List (Pair Symbol Expr))
  (let ((nb (cn_pat_binds p)))
    (let ((fp2 (cn_fpins_shift fp nb)))
      (match p
        ((PVar) fp2)
        (_
          (match s
            ((FVar x)
             (match (cn_pat_shape p nb 0)
               ((Pair v _) (Cons (Pair x v) fp2))))
            (_ fp2)))))))

(fn cn_abp_bp ((s Expr) (p Pat) (bp (List (Pair Int Expr))))
  (List (Pair Int Expr))
  (let ((nb (cn_pat_binds p)))
    (let ((bp2 (cn_pins_shift bp nb)))
      (match p
        ((PVar) bp2)
        (_
          (match s
            ((BVar j)
             (match (cn_pat_shape p nb 0)
               ((Pair v _) (Cons (Pair (+ j nb) v) bp2))))
            (_ bp2)))))))

;; ---------------------------------------------------------------------------
;; module surface: scan the target module's own fns, render advisory lines
;; ---------------------------------------------------------------------------

(fn cn_code_chars ((c Int)) (List Int)
  (if (lt c 10) (Cons 67 (Cons (+ 48 c) Nil))
  (Cons 67 (Cons (+ 48 (/ c 10)) (Cons (+ 48 (mod c 10)) Nil)))))

(fn cn_render_v ((fname Symbol) (v CViol)) (List Int)
  (match v
    ((CViol c subj)
     (append_int
       "CANON "
       (append_int
         (chars_of_sym fname)
         (append_int
           ": "
           (append_int
             (cn_code_chars c)
             (append_int " " (append_int (chars_of_sym subj) (Cons 10 Nil))))))))))

(fn cn_render_vs ((fname Symbol) (vs (List CViol))) (List Int)
  (measure (struct vs))
  (match vs
    (Nil Nil)
    ((Cons v rest) (append_int (cn_render_v fname v) (cn_render_vs fname rest)))))

(fn cn_scan_fns ((fs (List FnDef)) (m Module) (mp (List Symbol))) (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons fd rest)
     (match fd
       ((FnDef q _ _ body)
        (if (sym_path_eq (qn_mod q) mp)
          (append_int
            (cn_render_vs (qn_name q) (cn_e body m))
            (cn_scan_fns rest m mp))
          (cn_scan_fns rest m mp)))))))

;; the stage-1 advisory block for the module at path mp: empty (all
;; canonical) or one CANON line per violation in mp's own fn bodies.
(fn canon_block ((m Module) (mp (List Symbol))) (List Int)
  (cn_scan_fns (cn_fns m) m mp))
