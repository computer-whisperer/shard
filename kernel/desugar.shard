;;; desugar.shard — named-citation desugaring at the SOURCE (s-expr) level.
;;;
;;; The proof AST (proof.shard) is purely POSITIONAL: `(Hyp k)` / `(Premise
;;; k)`. Proof authors may instead write names — `(hyp ih)`, `(premise
;;; lo_bound)`, `(have NAME EQ PE K)` — for readability. This pass (ds_proof)
;;; rewrites a proof S-EXPR to positional form BEFORE it is parsed, by
;;; simulating the checker's hyp stack and premise list over the surface
;;; grammar. No name ctor exists in the native AST, so the reader, checker,
;;; and every proof walker see positional citations only.
;;;
;;; Hyp stack discipline (front = index 0 = `(hyp 0)`):
;;;   wf-induct /
;;;   subterm-induct : PREPEND one IH, named 'ih
;;;   induct         : per case, APPEND one IH per recursive ctor field
;;;                    (do_induct order), named 'ih, 'ih1, …
;;;   case-on        : per case, PREPEND the case equation (the checker's
;;;                    build_case_on_subgoal puts it at Hyp 0), auto-named
;;;                    after the ctor — `(hyp Alive)` cites the enclosing
;;;                    Alive arm's equation; inner arms shadow outer (the
;;;                    front-first stack_pos search)
;;; Everything else leaves the stack unchanged. Positional `(hyp k)` is
;;; untouched.
;;;
;;; Premise discipline (APPEND-at-end, so indices are stable once assigned;
;;; base = the goal's own premise count, threaded in by the driver):
;;;   have        : the fact lands at index pc; continuation at pc+1. The
;;;                 named form records NAME → pc (newest shadows) and is
;;;                 REWRITTEN to the plain 3-arg form.
;;;   div-facts   : +4 — div_facts_eqs emits exactly four facts
;;;                 (decomposition, both mod bounds, quotient naming); a
;;;                 div-facts that would emit otherwise is rejected by the
;;;                 checker itself, taking the whole proof with it.
;;;   refine-fact : +1
;;;   inject      : +N, N = the surface name-list length — one fieldwise
;;;                 equation per listed name (`_` = counted hole, not
;;;                 registered). The count rides INTO the AST, where the
;;;                 checker pins it against the cited ctor's arity — so a
;;;                 miscounted list is a loud kernel rejection, never a
;;;                 silent index drift here.
;;;
;;; An unbound name is a LOUD error (DsErr carrying the name), surfaced as
;;; the decl's failure message. Unrecognized forms pass through untouched and
;;; fail at the parser as before. The pass is UNTRUSTED either way: a wrong
;;; index fails at the checker's citation gate; it can never make a bad
;;; proof check.

;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(import "proof.shard")  ; Param
(import "reader.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel proof *))
(use (:: kernel reader *))

(fn stack_pos ((s Symbol) (stk (List (Option Symbol))) (k Int)) (Option Int)
  (measure (struct stk))
  (match stk
    (Nil None)
    ((Cons mh t)
     (match mh
       ((Some h) (if (sym_eq s h) (Some k) (stack_pos s t (+ k 1))))
       (None (stack_pos s t (+ k 1)))))))

;; named-premise registry: name → absolute premise index; newest CONSED on
;; front, so re-using a name shadows the older fact.
(fn pn_pos ((s Symbol) (pn (List (Pair Symbol Int)))) (Option Int)
  (measure (struct pn))
  (match pn
    (Nil None)
    ((Cons (Pair nm k) t) (if (sym_eq s nm) (Some k) (pn_pos s t)))))

(fn param_type ((v Symbol) (ps (List Param))) (Option Type)
  (measure (struct ps))
  (match ps
    (Nil None)
    ((Cons (Param nm ty) rest) (if (sym_eq v nm) (Some ty) (param_type v rest)))))

;; "ih", "ih1", "ih2", … (the auto-IH naming; i=0 → 'ih).
(fn ih_name ((i Int)) Symbol
  (if (int_eq i 0) (quote ih)
  (sym_of_chars (Cons 105 (Cons 104 (Cons (+ 48 i) Nil))))))  ; 'i' 'h' digit

(fn ih_entries ((i Int) (n Int)) (List (Option Symbol))
  ;; counts UP: measure is the remaining gap (- n i), descending by 1; the
  ;; (lt i n)=True guard gives n - i >= 1 >= 0.
  (measure (- n i) (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt i n) (Cons (Some (ih_name i)) (ih_entries (+ i 1) n)) Nil))

(fn append_ms ((a (List (Option Symbol))) (b (List (Option Symbol))))
  (List (Option Symbol))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (append_ms t b)))))

;; ---------------------------------------------------------------------------
;; IH count for an induct case: one IH per ctor field whose CONCRETE type
;; equals the inducting var's type (mirrors do_induct). The typedef is pinned
;; by the goal-param's type, so the case ctor — written bare or as a
;; (:: SEG … NAME) path — is matched by BASE NAME within that typedef's ctor
;; list, where base names are unique.
;; ---------------------------------------------------------------------------

(fn ds_last_sym ((ss (List SExpr))) (Option Symbol)
  (measure (struct ss))
  (match ss
    (Nil None)
    ((Cons (SSym n) Nil) (Some n))
    ((Cons _ t) (ds_last_sym t))))

;; inject name-list bookkeeping: the list's LENGTH advances the premise
;; counter; each non-`_` name is registered at its fact's absolute index
;; (field order), consed front-first so a repeated name shadows newest-wins
;; like have's registry.
(fn ds_inj_count ((ss (List SExpr))) Int
  (measure (struct ss))
  (match ss
    (Nil 0)
    ((Cons _ t) (+ 1 (ds_inj_count t)))))

(fn ds_inj_reg ((ss (List SExpr)) (k Int) (pn (List (Pair Symbol Int))))
  (List (Pair Symbol Int))
  (measure (struct ss))
  (match ss
    (Nil pn)
    ((Cons hd t)
     (match hd
       ((SSym nm)
        (if (sym_eq nm (sym_of_chars (Cons 95 Nil)))  ; '_' — hole, no name
          (ds_inj_reg t (+ k 1) pn)
          (ds_inj_reg t (+ k 1) (Cons (Pair nm k) pn))))
       (_ (ds_inj_reg t (+ k 1) pn))))))

;; a case's ctor as written: bare `Cons`, or the (:: SEG … NAME) path form.
(fn ds_ctor_name ((s SExpr)) (Option Symbol)
  (match s
    ((SSym n) (Some n))
    ((SList (Cons (SSym h) segs))
     (if (sym_eq h (coloncolon_sym)) (ds_last_sym segs) None))
    (_ None)))

(fn ds_count_rec ((var_type Type) (fields (List Type))) Int
  (measure (struct fields))
  (match fields
    (Nil 0)
    ((Cons f rest)
     (if (type_eq var_type f) (+ 1 (ds_count_rec var_type rest))
     (ds_count_rec var_type rest)))))

(fn ds_ctor_fields ((cname Symbol) (ctors (List CtorDef))) (Option (List Type))
  (measure (struct ctors))
  (match ctors
    (Nil None)
    ((Cons (CtorDef nm fts) rest)
     (if (sym_eq (qn_name nm) cname) (Some fts) (ds_ctor_fields cname rest)))))

;; How many IHs do_induct appends for ctor `cname` when inducting on `var`.
(fn ds_case_ihs ((m Module) (ps (List Param)) (var Symbol) (cname Symbol)) Int
  (match (param_type var ps)
    (None 0)
    ((Some ty)
     (match (type_head ty)
       (None 0)
       ((Some (Pair tname targs))
        (match (lookup_typedef tname m)
          (None 0)
          ((Some (TypeDef _ tparams ctors _))
           (match (ds_ctor_fields cname ctors)
             (None 0)
             ((Some fts)
              (ds_count_rec ty (type_subst_list (zip_pairs tparams targs) fts)))))))))))

;; ===========================================================================
;; The s-expr walk. DsErr = an unbound name (message carries it); everything
;; the grammar doesn't recognize passes through untouched for the parser to
;; judge. Subforms are extracted by DIRECT structural matching (not helper
;; wrappers) so (struct s) closes the recursion — same style as parse_proof.
;; ===========================================================================

(type DsRes (DsOk SExpr) (DsErr (List Int)))
(type DsLRes (DsLOk (List SExpr)) (DsLErr (List Int)))

;; the in-scope names, each space-prefixed (" a b c"); Nil when none.
(fn ds_stk_names ((stk (List (Option Symbol)))) (List Int)
  (measure (struct stk))
  (match stk
    (Nil Nil)
    ((Cons mh t)
     (match mh
       ((Some h) (append_int (Cons 32 (chars_of_sym h)) (ds_stk_names t)))
       (None (ds_stk_names t))))))

(fn ds_pn_names ((pn (List (Pair Symbol Int)))) (List Int)
  (measure (struct pn))
  (match pn
    (Nil Nil)
    ((Cons (Pair nm _) t)
     (append_int (Cons 32 (chars_of_sym nm)) (ds_pn_names t)))))

;; An unbound name lists what IS in scope: the gap between "the name is
;; wrong" and "the fact isn't here at all" is the first diagnosis fork,
;; and the empty case says which structural edit lost the binding.
(fn ds_scope_note ((names (List Int))) (List Int)
  (match names
    (Nil " -- no names in scope here")
    (_ (append_int " -- in scope:" names))))

;; (hyp NAME) / (premise NAME) → positional; anything else untouched.
(fn ds_ref
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (s SExpr))
  DsRes
  (match s
    ((SList (Cons (SSym h) (Cons (SSym nm) Nil)))
     (if (sym_eq h (quote hyp))
       (match (stack_pos nm stk 0)
         ((Some k) (DsOk (SList (Cons (SSym h) (Cons (SInt k) Nil)))))
         (None
           (DsErr
             (append_int
               "unbound hyp name: "
               (append_int (chars_of_sym nm) (ds_scope_note (ds_stk_names stk)))))))
     (if (sym_eq h (quote premise))
       (match (pn_pos nm pn)
         ((Some k) (DsOk (SList (Cons (SSym h) (Cons (SInt k) Nil)))))
         (None
           (DsErr
             (append_int
               "unbound premise name: "
               (append_int (chars_of_sym nm) (ds_scope_note (ds_pn_names pn)))))))
       (DsOk s))))
    (_ (DsOk s))))

;; a step: only (rewrite REF …) carries a citation, in argument 1.
(fn ds_step
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (s SExpr))
  DsRes
  (match s
    ((SList (Cons (SSym h) (Cons refS rest)))
     (if (sym_eq h (quote rewrite))
       (match (ds_ref stk pn refS)
         ((DsErr e) (DsErr e))
         ((DsOk r2) (DsOk (SList (Cons (SSym h) (Cons r2 rest))))))
       (DsOk s)))
    (_ (DsOk s))))

(fn ds_steps
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (ss (List SExpr)))
  DsLRes
  (measure (struct ss))
  (match ss
    (Nil (DsLOk Nil))
    ((Cons h t)
     (match (ds_step stk pn h)
       ((DsErr e) (DsLErr e))
       ((DsOk h2)
        (match (ds_steps stk pn t)
          ((DsLErr e) (DsLErr e))
          ((DsLOk t2) (DsLOk (Cons h2 t2)))))))))

(fn ds_proof
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (s SExpr))
  DsRes
  (measure (struct s))
  (match s
    ((SList (Cons (SSym h) args))
     (if (sym_eq h (quote steps))
       (match args
         ((Cons stepsS (Cons contS Nil))
          (match stepsS
            ((SList items)
             (match (ds_steps stk pn items)
               ((DsLErr e) (DsErr e))
               ((DsLOk items2)
                (match (ds_proof m ps stk pc pn contS)
                  ((DsErr e) (DsErr e))
                  ((DsOk cont2)
                   (DsOk
                     (SList
                       (Cons (SSym h) (Cons (SList items2) (Cons cont2 Nil))))))))))
            (_ (DsOk s))))
         (_ (DsOk s)))
     (if (sym_eq h (quote induct))
       (match args
         ((Cons (SSym var) (Cons casesS Nil))
          (match casesS
            ((SList cs)
             (match (ds_icases m ps stk pc pn var cs)
               ((DsLErr e) (DsErr e))
               ((DsLOk cs2)
                (DsOk
                  (SList
                    (Cons (SSym h) (Cons (SSym var) (Cons (SList cs2) Nil))))))))
            (_ (DsOk s))))
         (_ (DsOk s)))
     (if (sym_eq h (quote case-on))
       (match args
         ((Cons termS (Cons tyS (Cons casesS Nil)))
          (match casesS
            ((SList cs)
             (match (ds_ccases m ps stk pc pn cs)
               ((DsLErr e) (DsErr e))
               ((DsLOk cs2)
                (DsOk
                  (SList
                    (Cons
                      (SSym h)
                      (Cons termS (Cons tyS (Cons (SList cs2) Nil)))))))))
            (_ (DsOk s))))
         (_ (DsOk s)))
     (if (sym_eq h (quote wf-induct))
       (match args
         ((Cons measureS (Cons subS Nil))
          (match (ds_proof m ps (Cons (Some (quote ih)) stk) pc pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk (SList (Cons (SSym h) (Cons measureS (Cons sub2 Nil))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote subterm-induct))
       (match args
         ((Cons varS (Cons subS Nil))
          (match (ds_proof m ps (Cons (Some (quote ih)) stk) pc pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk (SList (Cons (SSym h) (Cons varS (Cons sub2 Nil))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote fin-split))
       (match args
         ((Cons varS (Cons loS (Cons hiS (Cons casesS Nil))))
          (match (ds_ref stk pn loS)
            ((DsErr e) (DsErr e))
            ((DsOk lo2)
             (match (ds_ref stk pn hiS)
               ((DsErr e) (DsErr e))
               ((DsOk hi2)
                (match casesS
                  ((SList cs)
                   (match (ds_fincases m ps stk pc pn cs)
                     ((DsLErr e) (DsErr e))
                     ((DsLOk cs2)
                      (DsOk
                        (SList
                          (Cons
                            (SSym h)
                            (Cons
                              varS
                              (Cons lo2 (Cons hi2 (Cons (SList cs2) Nil))))))))))
                  (_ (DsOk s))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote absurd))
       (match args
         ((Cons refS Nil)
          (match (ds_ref stk pn refS)
            ((DsErr e) (DsErr e))
            ((DsOk r2) (DsOk (SList (Cons (SSym h) (Cons r2 Nil)))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote rewrite-with))
       (match args
         ((Cons
            refS
            (Cons dirS (Cons sideS (Cons instsS (Cons subsS (Cons contS Nil))))))
          (match (ds_ref stk pn refS)
            ((DsErr e) (DsErr e))
            ((DsOk r2)
             (match subsS
               ((SList subs)
                (match (ds_proofs m ps stk pc pn subs)
                  ((DsLErr e) (DsErr e))
                  ((DsLOk subs2)
                   (match (ds_proof m ps stk pc pn contS)
                     ((DsErr e) (DsErr e))
                     ((DsOk cont2)
                      (DsOk
                        (SList
                          (Cons
                            (SSym h)
                            (Cons
                              r2
                              (Cons
                                dirS
                                (Cons
                                  sideS
                                  (Cons
                                    instsS
                                    (Cons (SList subs2) (Cons cont2 Nil))))))))))))))
               (_ (DsOk s))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote have))
       (match args
         ;; named form: (have NAME EQ PE K) — NAME a bare symbol (the 3-arg
         ;; form's EQ is always a list, so the shapes are disjoint). Record
         ;; NAME → pc for the continuation, emit the plain 3-arg form.
         ((Cons (SSym nm) (Cons eqS (Cons peS (Cons prS Nil))))
          (match (ds_proof m ps stk pc pn peS)
            ((DsErr e) (DsErr e))
            ((DsOk pe2)
             (match (ds_proof m ps stk (+ pc 1) (Cons (Pair nm pc) pn) prS)
               ((DsErr e) (DsErr e))
               ((DsOk pr2)
                (DsOk
                  (SList (Cons (SSym h) (Cons eqS (Cons pe2 (Cons pr2 Nil)))))))))))
         ((Cons eqS (Cons peS (Cons prS Nil)))
          (match (ds_proof m ps stk pc pn peS)
            ((DsErr e) (DsErr e))
            ((DsOk pe2)
             (match (ds_proof m ps stk (+ pc 1) pn prS)
               ((DsErr e) (DsErr e))
               ((DsOk pr2)
                (DsOk
                  (SList (Cons (SSym h) (Cons eqS (Cons pe2 (Cons pr2 Nil)))))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote div-facts))
       (match args
         ((Cons termS (Cons dS (Cons qS (Cons subS Nil))))
          (match (ds_proof m ps stk (+ pc 4) pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk
               (SList
                 (Cons
                   (SSym h)
                   (Cons termS (Cons dS (Cons qS (Cons sub2 Nil))))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote refine-fact))
       (match args
         ((Cons rS (Cons exprS (Cons subS Nil)))
          (match (ds_proof m ps stk (+ pc 1) pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk
               (SList (Cons (SSym h) (Cons rS (Cons exprS (Cons sub2 Nil)))))))))
         (_ (DsOk s)))
     (if (sym_eq h (quote inject))
       (match args
         ((Cons refS (Cons namesS (Cons subS Nil)))
          (match (ds_ref stk pn refS)
            ((DsErr e) (DsErr e))
            ((DsOk r2)
             (match namesS
               ((SList names)
                (match
                  (ds_proof
                    m
                    ps
                    stk
                    (+ pc (ds_inj_count names))
                    (ds_inj_reg names pc pn)
                    subS)
                  ((DsErr e) (DsErr e))
                  ((DsOk sub2)
                   (DsOk
                     (SList
                       (Cons (SSym h) (Cons r2 (Cons namesS (Cons sub2 Nil)))))))))
               (_ (DsOk s))))))
         (_ (DsOk s)))
       (DsOk s))))))))))))))  ; refl/admit/below/by/inspect & unknown forms
    (_ (DsOk s))))

;; induct cases: each appends its IH entries before the sub-proof.
(fn ds_icase
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (var Symbol)
   (s SExpr))
  DsRes
  (measure (struct s))
  (match s
    ((SList (Cons (SSym h) (Cons ctorS (Cons subS Nil))))  ; (case CTOR SUB)
     (if (sym_eq h (quote case))
       (match (ds_ctor_name ctorS)
         (None (DsOk s))
         ((Some cn)
          (match
            (ds_proof
              m
              ps
              (append_ms stk (ih_entries 0 (ds_case_ihs m ps var cn)))
              pc
              pn
              subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk (SList (Cons (SSym h) (Cons ctorS (Cons sub2 Nil)))))))))
       (DsOk s)))
    ((SList (Cons (SSym h) (Cons ctorS (Cons fieldsS (Cons subS Nil)))))
     ;; (case CTOR (FIELD…) SUB)
     (if (sym_eq h (quote case))
       (match (ds_ctor_name ctorS)
         (None (DsOk s))
         ((Some cn)
          (match
            (ds_proof
              m
              ps
              (append_ms stk (ih_entries 0 (ds_case_ihs m ps var cn)))
              pc
              pn
              subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk
               (SList
                 (Cons (SSym h) (Cons ctorS (Cons fieldsS (Cons sub2 Nil))))))))))
       (DsOk s)))
    (_ (DsOk s))))

(fn ds_icases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (var Symbol)
   (ss (List SExpr)))
  DsLRes
  (measure (struct ss))
  (match ss
    (Nil (DsLOk Nil))
    ((Cons h t)
     (match (ds_icase m ps stk pc pn var h)
       ((DsErr e) (DsLErr e))
       ((DsOk h2)
        (match (ds_icases m ps stk pc pn var t)
          ((DsLErr e) (DsLErr e))
          ((DsLOk t2) (DsLOk (Cons h2 t2)))))))))

;; case-on cases: no IH, but the checker prepends the case equation at Hyp 0
;; (build_case_on_subgoal) — so each arm prepends one stack slot, auto-named
;; after the arm's ctor. Inner arms shadow outer (front-first stack_pos).
(fn ds_ccase
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (s SExpr))
  DsRes
  (measure (struct s))
  (match s
    ((SList (Cons (SSym h) (Cons ctorS (Cons subS Nil))))  ; (case CTOR SUB)
     (if (sym_eq h (quote case))
       (match (ds_ctor_name ctorS)
         (None (DsOk s))
         ((Some cn)
          (match (ds_proof m ps (Cons (Some cn) stk) pc pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk (SList (Cons (SSym h) (Cons ctorS (Cons sub2 Nil)))))))))
       (DsOk s)))
    ((SList (Cons (SSym h) (Cons ctorS (Cons fieldsS (Cons subS Nil)))))
     ;; (case CTOR (FIELD…) SUB)
     (if (sym_eq h (quote case))
       (match (ds_ctor_name ctorS)
         (None (DsOk s))
         ((Some cn)
          (match (ds_proof m ps (Cons (Some cn) stk) pc pn subS)
            ((DsErr e) (DsErr e))
            ((DsOk sub2)
             (DsOk
               (SList
                 (Cons (SSym h) (Cons ctorS (Cons fieldsS (Cons sub2 Nil))))))))))
       (DsOk s)))
    (_ (DsOk s))))

(fn ds_ccases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (ss (List SExpr)))
  DsLRes
  (measure (struct ss))
  (match ss
    (Nil (DsLOk Nil))
    ((Cons h t)
     (match (ds_ccase m ps stk pc pn h)
       ((DsErr e) (DsLErr e))
       ((DsOk h2)
        (match (ds_ccases m ps stk pc pn t)
          ((DsLErr e) (DsLErr e))
          ((DsLOk t2) (DsLOk (Cons h2 t2)))))))))

;; fin-split cases: (case INT SUB) — no hyp pushed; stack and premises pass
;; through unchanged.
(fn ds_fincase
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (s SExpr))
  DsRes
  (measure (struct s))
  (match s
    ((SList (Cons (SSym h) (Cons vS (Cons subS Nil))))
     (if (sym_eq h (quote case))
       (match (ds_proof m ps stk pc pn subS)
         ((DsErr e) (DsErr e))
         ((DsOk sub2) (DsOk (SList (Cons (SSym h) (Cons vS (Cons sub2 Nil)))))))
       (DsOk s)))
    (_ (DsOk s))))

(fn ds_fincases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (ss (List SExpr)))
  DsLRes
  (measure (struct ss))
  (match ss
    (Nil (DsLOk Nil))
    ((Cons h t)
     (match (ds_fincase m ps stk pc pn h)
       ((DsErr e) (DsLErr e))
       ((DsOk h2)
        (match (ds_fincases m ps stk pc pn t)
          ((DsLErr e) (DsLErr e))
          ((DsLOk t2) (DsLOk (Cons h2 t2)))))))))

;; rewrite-with premise sub-proofs: same stack / premise context.
(fn ds_proofs
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (ss (List SExpr)))
  DsLRes
  (measure (struct ss))
  (match ss
    (Nil (DsLOk Nil))
    ((Cons h t)
     (match (ds_proof m ps stk pc pn h)
       ((DsErr e) (DsLErr e))
       ((DsOk h2)
        (match (ds_proofs m ps stk pc pn t)
          ((DsLErr e) (DsLErr e))
          ((DsLOk t2) (DsLOk (Cons h2 t2)))))))))
