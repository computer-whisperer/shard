;;; desugar.shard — named-hypothesis & named-premise desugaring, in shard.
;;;
;;; The kernel only understands POSITIONAL citations `(Hyp k)` / `(Premise
;;; k)`. Proof authors may instead name them — `(hyp ih)`, `(premise
;;; lo_bound)` — for readability. proof_reader emits native `(HypName s)` /
;;; `(PremiseName s)` (and the named-cut form `(HaveN s eq pe k)`); this
;;; pass (desugar_proof_named) rewrites each to positional by simulating
;;; the kernel's hyp stack AND premise list over the native Proof, and
;;; strips HaveN to a plain Have — the checker never sees a name.
;;;
;;; Hyp stack discipline (front = index 0 = `(Hyp 0)`):
;;;   WfInduct        : PREPEND one IH, named 'ih
;;;   Induct/Induct2  : per case, APPEND one IH per recursive ctor field
;;;                     (do_induct order), named 'ih, 'ih1, … (count via the
;;;                     kernel's dbg_ih_count; Induct2: 'SS→1 else 0)
;;;   CaseOn          : per case, PREPEND the case equation (the checker's
;;;                     build_case_on_subgoal puts it at Hyp 0), auto-named
;;;                     after the ctor — `(hyp Alive)` cites the enclosing
;;;                     Alive arm's equation; inner arms shadow outer (the
;;;                     front-first stack_pos search)
;;; Everything else leaves the stack unchanged. Positional `(Hyp k)` is
;;; untouched.
;;;
;;; Premise discipline (APPEND-at-end, so indices are stable once assigned;
;;; base = the goal's own premise count, threaded in by the driver):
;;;   Have/HaveN      : the fact lands at index pc; continuation at pc+1.
;;;                     HaveN records NAME→pc (newest shadows).
;;;   DivFacts        : likewise via div_facts_checked; its fresh quotient
;;;                     param also extends ps for the continuation.
;;; CAVEAT: div fact counting type-checks the term against `ps`, which here
;;; lacks induction/case field params — a div-facts on a case-bound field
;;; under-counts (0) and a named premise BELOW it then resolves to a lower
;;; index. Never unsound (the checker verifies whatever is cited); fails
;;; loudly at the citation. Spell those rare chains positionally.

;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(import "proof.shard")
(import "checker.shard")
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel proof *))
(use (:: kernel checker *))

(fn stack_pos ((s Symbol) (stk (List (Option Symbol))) (k Int)) (Option Int)
  (measure (struct stk))
  (match stk
    (Nil None)
    ((Cons mh t)
     (match mh
       ((Some h) (if (sym_eq s h) (Some k) (stack_pos s t (+ k 1))))
       (None (stack_pos s t (+ k 1)))))))

;; named-premise registry: name → absolute premise index; newest CONSED on
;; front, so re-using a name shadows the older fact.
(fn pn_pos ((s Symbol) (pn (List (Pair Symbol Int)))) (Option Int)
  (measure (struct pn))
  (match pn
    (Nil None)
    ((Cons (Pair nm k) t) (if (sym_eq s nm) (Some k) (pn_pos s t)))))

(fn param_type ((v Symbol) (ps (List Param))) (Option Type)
  (measure (struct ps))
  (match ps
    (Nil None)
    ((Cons (Param nm ty) rest) (if (sym_eq v nm) (Some ty) (param_type v rest)))))

;; "ih", "ih1", "ih2", … (the auto-IH naming; i=0 → 'ih).
(fn ih_name ((i Int)) Symbol
  (if (int_eq i 0) (quote ih)
  (sym_of_chars (Cons 105 (Cons 104 (Cons (+ 48 i) Nil))))))  ; 'i' 'h' digit

(fn ih_entries ((i Int) (n Int)) (List (Option Symbol))
  ;; counts UP: measure is the remaining gap (- n i), descending by 1; the
  ;; (lt i n)=True guard gives n - i >= 1 >= 0.
  (measure (- n i) (by farkas (list 1 0)) (by farkas (list 1 1)))
  (if (lt i n) (Cons (Some (ih_name i)) (ih_entries (+ i 1) n)) Nil))

(fn append_ms ((a (List (Option Symbol))) (b (List (Option Symbol))))
  (List (Option Symbol))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (append_ms t b)))))

(fn dsn_eqs_len ((es (List Equation))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons _ t) (+ 1 (dsn_eqs_len t)))))

;; How many IHs do_induct appends for ctor `cname` when inducting on `var`.
(fn case_ih_count
  ((m Module) (ps (List Param)) (head Symbol) (var Symbol) (cname QName))
  Int
  (if (sym_eq head (quote Induct2)) (if (sym_eq (qn_name cname) (quote SS)) 1 0)
  (match (param_type var ps)
    (None 0)
    ((Some ty) (dbg_ih_count ty cname m)))))

;; ===========================================================================
;; Native named-citation desugaring — over the native Proof. Simulates the
;; SAME hyp stack and premise list the checker builds (see the header) and
;; rewrites every (HypName s) → (Hyp k), (PremiseName s) → (Premise k),
;; (HaveN s …) → (Have …). An unbound name is left as-is and fails cleanly
;; at resolve_eq (checker.shard).
;; ===========================================================================

(fn dsn_ref
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (er EqRef))
  EqRef
  (match er
    ((HypName s)
     (match (stack_pos s stk 0)
       ((Some k) (Hyp k))
       (None (HypName s))))
    ((PremiseName s)
     (match (pn_pos s pn)
       ((Some k) (Premise k))
       (None (PremiseName s))))
    (_ er)))

(fn dsn_step
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (st Step))
  Step
  (match st
    ((Rewrite ref dir side all insts)
     (Rewrite (dsn_ref stk pn ref) dir side all insts))
    (_ st)))

(fn dsn_steps
  ((stk (List (Option Symbol))) (pn (List (Pair Symbol Int))) (sts (List Step)))
  (List Step)
  (measure (struct sts))
  (match sts
    (Nil Nil)
    ((Cons h t) (Cons (dsn_step stk pn h) (dsn_steps stk pn t)))))

(fn desugar_proof_named
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (p Proof))
  Proof
  (measure (struct p))
  (match p
    (Refl Refl)
    (Admit Admit)
    ((Steps steps cont)
     (Steps (dsn_steps stk pn steps) (desugar_proof_named m ps stk pc pn cont)))
    ((Induct var cases)
     (Induct var (dsn_cases m ps stk pc pn (quote Induct) var cases)))
    ((Induct2 var cases)
     (Induct2 var (dsn_cases m ps stk pc pn (quote Induct2) var cases)))
    ((CaseOn e var cases)
     (CaseOn e var (dsn_caseon_cases m ps stk pc pn cases)))
    ((WfInduct measure sub)
     (WfInduct
       measure
       (desugar_proof_named m ps (Cons (Some (quote ih)) stk) pc pn sub)))
    ((SubtermInduct var sub)  ; prepends one IH at Hyp 0, named 'ih (like WfInduct)
     (SubtermInduct
       var
       (desugar_proof_named m ps (Cons (Some (quote ih)) stk) pc pn sub)))
    ((RewriteWith ref dir side insts subs cont)
     (RewriteWith
       (dsn_ref stk pn ref)
       dir
       side
       insts
       (dsn_proofs m ps stk pc pn subs)
       (desugar_proof_named m ps stk pc pn cont)))
    ((Absurd ref) (Absurd (dsn_ref stk pn ref)))
    ((FinSplit var lo hi cases)  ; no IH pushed; bounds + cases keep the stack
     (FinSplit
       var
       (dsn_ref stk pn lo)
       (dsn_ref stk pn hi)
       (dsn_fincases m ps stk pc pn cases)))
    ((Have eq pe pr)  ; cut: the fact lands at premise pc; continuation +1
     (Have
       eq
       (desugar_proof_named m ps stk pc pn pe)
       (desugar_proof_named m ps stk (+ pc 1) pn pr)))
    ((HaveN nm eq pe pr)  ; named cut: record nm → pc, strip to Have
     (Have
       eq
       (desugar_proof_named m ps stk pc pn pe)
       (desugar_proof_named m ps stk (+ pc 1) (Cons (Pair nm pc) pn) pr)))
    ((DivFacts n d q pr)  ; facts appended + the fresh quotient param
     (DivFacts
       n
       d
       q
       (match (div_facts_checked m ps n d q)
         (None (desugar_proof_named m ps stk pc pn pr))
         ((Some (Pair ps2 fs))
          (desugar_proof_named m ps2 stk (+ pc (dsn_eqs_len fs)) pn pr)))))
    ((RefineFact r ev pr)  ; one structural-invariant fact appended, no new param
     (RefineFact r ev (desugar_proof_named m ps stk (+ pc 1) pn pr)))
    (_ p)))  ; ByTheory — no hyp refs

(fn dsn_fincases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (cases (List FinCase)))
  (List FinCase)
  (measure (struct cases))
  (match cases
    (Nil Nil)
    ((Cons (FinCase v sub) rest)
     (Cons
       (FinCase v (desugar_proof_named m ps stk pc pn sub))
       (dsn_fincases m ps stk pc pn rest)))))

(fn dsn_proofs
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (subs (List Proof)))
  (List Proof)
  (measure (struct subs))
  (match subs
    (Nil Nil)
    ((Cons h t)
     (Cons (desugar_proof_named m ps stk pc pn h) (dsn_proofs m ps stk pc pn t)))))

;; Induct/Induct2 cases: each appends its IH entries before the sub-proof.
(fn dsn_cases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (head Symbol)
   (var Symbol)
   (cases (List Case)))
  (List Case)
  (measure (struct cases))
  (match cases
    (Nil Nil)
    ((Cons c rest)
     (Cons
       (dsn_case m ps stk pc pn head var c)
       (dsn_cases m ps stk pc pn head var rest)))))

(fn dsn_case
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (head Symbol)
   (var Symbol)
   (c Case))
  Case
  (measure (struct c))
  (match c
    ((Case cname sub)
     (Case
       cname
       (desugar_proof_named
         m
         ps
         (append_ms stk (ih_entries 0 (case_ih_count m ps head var cname)))
         pc
         pn
         sub)))
    ((CaseB cname fields sub)
     (CaseB
       cname
       fields
       (desugar_proof_named
         m
         ps
         (append_ms stk (ih_entries 0 (case_ih_count m ps head var cname)))
         pc
         pn
         sub)))))

;; CaseOn cases: no IH, but the checker prepends the case equation at Hyp 0
;; (build_case_on_subgoal) — so each arm prepends one stack slot, auto-named
;; after the arm's ctor: `(hyp Alive)` cites the enclosing Alive arm's
;; equation. Inner arms shadow outer (front-first stack_pos search).
(fn dsn_caseon_cases
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (cases (List Case)))
  (List Case)
  (measure (struct cases))
  (match cases
    (Nil Nil)
    ((Cons c rest)
     (Cons
       (dsn_caseon_case m ps stk pc pn c)
       (dsn_caseon_cases m ps stk pc pn rest)))))

(fn dsn_caseon_case
  ((m Module)
   (ps (List Param))
   (stk (List (Option Symbol)))
   (pc Int)
   (pn (List (Pair Symbol Int)))
   (c Case))
  Case
  (measure (struct c))
  (match c
    ((Case cname sub)
     (Case
       cname
       (desugar_proof_named m ps (Cons (Some (qn_name cname)) stk) pc pn sub)))
    ((CaseB cname fields sub)
     (CaseB
       cname
       fields
       (desugar_proof_named m ps (Cons (Some (qn_name cname)) stk) pc pn sub)))))
