;; AST size for Expr — the citable measure foundation for the recursive Expr
;; SCCs: render_term (trace.shard), rewrite_all (checker.shard) and the step*
;; reducers (reduce.shard). Lives in its OWN file (not term.shard) so its claims
;; do not surface in every term-importing target, mirroring proof_size.shard.
;; size / size_list / size_arm / size_arms are a STRUCTURAL mutual SCC
;; ((struct …) each); size_nonneg uses (subterm-induct) to reach sub-Exprs
;; nested in the (List Expr)/(List Arm) fields.

(import "stdlib.shard")
(import "term.shard")
(use (:: kernel term *))

(fn size ((e Expr)) Int
  (measure (struct e))
  (match e
    ((FVar _) 1)
    ((BVar _) 1)
    ((Ctor _ args) (+ 2 (size_list args)))
    ((Call _ args) (+ 2 (size_list args)))
    ((Match s arms) (+ 2 (+ (size s) (size_arms arms))))
    ((Let bs body) (+ 2 (+ (size_list bs) (size body))))
    ((If c t e2) (+ 2 (+ (size c) (+ (size t) (size e2)))))
    ((IntLit _) 1)
    ((SymLit _) 1)))

(fn size_list ((xs (List Expr))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons a rest) (+ 1 (+ (size a) (size_list rest))))))

;; size descends into Match (scrutinee + arm BODIES) and Let (bindings + body)
;; — the consumers rewrite_all / step* recurse there, so the measure must too.
;; (size_arm/size_arms mirror proof_size's case_size/case_list_size.)
(fn size_arm ((a Arm)) Int
  (measure (struct a))
  (match a ((Arm _ b) (size b))))

(fn size_arms ((arms (List Arm))) Int
  (measure (struct arms))
  (match arms
    (Nil 0)
    ((Cons a rest) (+ 1 (+ (size_arm a) (size_arms rest))))))

;; defining equations (one structural unfold each)
(claim size_ctor
  (goal ((name QName) (args (List Expr))) ()
    (= (size (Ctor name args)) (+ 2 (size_list args))))
  (steps ((simp lhs)) refl))

(claim size_call
  (goal ((name QName) (args (List Expr))) ()
    (= (size (Call name args)) (+ 2 (size_list args))))
  (steps ((simp lhs)) refl))

(claim size_if
  (goal ((c Expr) (t Expr) (e Expr)) ()
    (= (size (If c t e)) (+ 2 (+ (size c) (+ (size t) (size e))))))
  (steps ((simp lhs)) refl))

(claim size_match
  (goal ((s Expr) (arms (List Arm))) ()
    (= (size (Match s arms)) (+ 2 (+ (size s) (size_arms arms)))))
  (steps ((simp lhs)) refl))

(claim size_let
  (goal ((bs (List Expr)) (body Expr)) ()
    (= (size (Let bs body)) (+ 2 (+ (size_list bs) (size body)))))
  (steps ((simp lhs)) refl))

(claim size_list_nil
  (goal () () (= (size_list Nil) 0))
  (steps ((simp lhs)) refl))

(claim size_list_cons
  (goal ((a Expr) (rest (List Expr))) ()
    (= (size_list (Cons a rest)) (+ 1 (+ (size a) (size_list rest)))))
  (steps ((simp lhs)) refl))

(claim size_arm_arm
  (goal ((p Pat) (b Expr)) () (= (size_arm (Arm p b)) (size b)))
  (steps ((simp lhs)) refl))

(claim size_arms_nil
  (goal () () (= (size_arms Nil) 0))
  (steps ((simp lhs)) refl))

(claim size_arms_cons
  (goal ((a Arm) (rest (List Arm))) ()
    (= (size_arms (Cons a rest)) (+ 1 (+ (size_arm a) (size_arms rest)))))
  (steps ((simp lhs)) refl))

;; the mutual nonneg pair. subterm-induction on e: the Ctor/Call cases prove
;; 0 <= size_list args inline (ordinary induct on args, each head's bound from
;; the strong IH via (below)); the If case pulls each child's bound straight
;; from the strong IH. size_list_nonneg then cites size_nonneg one-directionally.
(claim size_nonneg
  (goal ((e Expr)) () (= (le 0 (size e)) True))
  (subterm-induct
    e
    (case-on e Expr
      ((case FVar
         (s)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case BVar
         (k)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case Ctor
         (name args)
         ;; hyp 0 = (= e (Ctor name args)); hyp 1 = subterm-IH 'ih
         (have (= (le 0 (size_list args)) True)
           (induct args
             ((case Nil
                (steps
                  ((rewrite (lemma size_list_nil) lr lhs true ()))
                  (by farkas (list 1))))
              (case Cons
                (a rest)
                ;; after (induct args): hyp 0 = (= e (Ctor name (Cons a rest))),
                ;; hyp 1 = subterm-IH 'ih, hyp 2 = list-IH (le 0 (size_list rest))
                (have (= (le 0 (size a)) True)
                  (rewrite-with (hyp ih) lr lhs () ((below)) refl)
                  (have (= (le 0 (size_list rest)) True)
                    ;; (induct args) generalized BOTH surviving outer vars (e and
                    ;; the other Ctor field name) into the list-IH: pin both.
                    (rewrite-with
                      (hyp 2)
                      lr
                      lhs
                      ((inst e e) (inst name name))
                      ()
                      refl)
                    (steps
                      ((rewrite (lemma size_list_cons) lr lhs true ()))
                      (by farkas (list 1 1 1))))))))
           (steps
             ((rewrite (hyp 0) lr lhs true ())
              (rewrite (lemma size_ctor) lr lhs true ()))
             (by farkas (list 1 1)))))
       (case Call
         (name args)
         (have (= (le 0 (size_list args)) True)
           (induct args
             ((case Nil
                (steps
                  ((rewrite (lemma size_list_nil) lr lhs true ()))
                  (by farkas (list 1))))
              (case Cons
                (a rest)
                (have (= (le 0 (size a)) True)
                  (rewrite-with (hyp ih) lr lhs () ((below)) refl)
                  (have (= (le 0 (size_list rest)) True)
                    (rewrite-with
                      (hyp 2)
                      lr
                      lhs
                      ((inst e e) (inst name name))
                      ()
                      refl)
                    (steps
                      ((rewrite (lemma size_list_cons) lr lhs true ()))
                      (by farkas (list 1 1 1))))))))
           (steps
             ((rewrite (hyp 0) lr lhs true ())
              (rewrite (lemma size_call) lr lhs true ()))
             (by farkas (list 1 1)))))
       (case Match
         (s arms)
         ;; hyp 0 = (= e (Match s arms)); hyp ih = subterm-IH. Prove the arms
         ;; bound FIRST (an inline induct over arms, each body reached through
         ;; (Arm pp bb) via the strong IH — proof_size_nonneg's (Case q pp)
         ;; handling); doing it under the (size s) cut would condition the
         ;; list-IH on (le 0 (size s)). The scrutinee s is a direct subterm.
         (have (= (le 0 (size_arms arms)) True)
           (induct arms
             ((case Nil
                (steps
                  ((rewrite (lemma size_arms_nil) lr lhs true ()))
                  (by farkas (list 1))))
              (case Cons
                (a2 rest)
                ;; hyp 0 = (= e (Match s (Cons a2 rest))), hyp 1 = subterm-IH
                ;; 'ih, hyp 2 = list-IH (le 0 (size_arms rest))
                (have (= (le 0 (size_arm a2)) True)
                  (case-on a2 Arm
                    ((case Arm
                       (pp bb)
                       (steps
                         ((rewrite (hyp Arm) lr lhs true ())
                          (rewrite (lemma size_arm_arm) lr lhs true ()))
                         (rewrite-with (hyp ih) lr lhs () ((below)) refl)))))
                  (have (= (le 0 (size_arms rest)) True)
                    (rewrite-with
                      (hyp 2)
                      lr
                      lhs
                      ((inst e e) (inst s s))
                      ()
                      refl)
                    (steps
                      ((rewrite (lemma size_arms_cons) lr lhs true ()))
                      (by farkas (list 1 1 1))))))))
           (have (= (le 0 (size s)) True)
             (rewrite-with (hyp ih) lr lhs () ((below)) refl)
             (steps
               ((rewrite (hyp 0) lr lhs true ())
                (rewrite (lemma size_match) lr lhs true ()))
               (by farkas (list 1 1 1))))))
       (case Let
         (binds body)
         ;; hyp 0 = (= e (Let binds body)); hyp ih = subterm-IH. size_list binds
         ;; by inline induct (like the Ctor case); body is a direct subterm.
         (have (= (le 0 (size_list binds)) True)
           (induct binds
             ((case Nil
                (steps
                  ((rewrite (lemma size_list_nil) lr lhs true ()))
                  (by farkas (list 1))))
              (case Cons
                (a rest)
                (have (= (le 0 (size a)) True)
                  (rewrite-with (hyp ih) lr lhs () ((below)) refl)
                  (have (= (le 0 (size_list rest)) True)
                    (rewrite-with
                      (hyp 2)
                      lr
                      lhs
                      ((inst e e) (inst body body))
                      ()
                      refl)
                    (steps
                      ((rewrite (lemma size_list_cons) lr lhs true ()))
                      (by farkas (list 1 1 1))))))))
           (have (= (le 0 (size body)) True)
             (rewrite-with (hyp ih) lr lhs () ((below)) refl)
             (steps
               ((rewrite (hyp 0) lr lhs true ())
                (rewrite (lemma size_let) lr lhs true ()))
               (by farkas (list 1 1 1))))))
       (case If
         (c t e2)
         ;; hyp 0 = (= e (If c t e2)); hyp 1 = subterm-IH 'ih. Each child is a
         ;; direct subterm of e, so (below) discharges its ordering premise.
         (have (= (le 0 (size c)) True)
           (rewrite-with (hyp ih) lr lhs () ((below)) refl)
           (have (= (le 0 (size t)) True)
             (rewrite-with (hyp ih) lr lhs () ((below)) refl)
             (have (= (le 0 (size e2)) True)
               (rewrite-with (hyp ih) lr lhs () ((below)) refl)
               (steps
                 ((rewrite (hyp 0) lr lhs true ())
                  (rewrite (lemma size_if) lr lhs true ()))
                 (by farkas (list 1 1 1 1)))))))
       (case IntLit
         (n)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case SymLit
         (s)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))))))

(claim size_list_nonneg
  (goal ((ks (List Expr))) () (= (le 0 (size_list ks)) True))
  (induct ks
    ((case Nil
       (steps
         ((rewrite (lemma size_list_nil) lr lhs true ()))
         (by farkas (list 1))))
     (case Cons
       (h t)
       ;; hyp 0 = list-IH (le 0 (size_list t))
       (have (= (le 0 (size h)) True)
         (rewrite-with (lemma size_nonneg) lr lhs () () refl)
         (have (= (le 0 (size_list t)) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps
             ((rewrite (lemma size_list_cons) lr lhs true ()))
             (by farkas (list 1 1 1)))))))))

(claim size_arms_nonneg
  (goal ((arms (List Arm))) () (= (le 0 (size_arms arms)) True))
  (induct arms
    ((case Nil
       (steps
         ((rewrite (lemma size_arms_nil) lr lhs true ()))
         (by farkas (list 1))))
     (case Cons
       (a rest)
       ;; hyp 0 = list-IH (le 0 (size_arms rest))
       (have (= (le 0 (size_arm a)) True)
         (case-on a Arm
           ((case Arm
              (p b)
              (steps
                ((rewrite (hyp Arm) lr lhs true ())
                 (rewrite (lemma size_arm_arm) lr lhs true ()))
                (rewrite-with (lemma size_nonneg) lr lhs () () refl)))))
         (have (= (le 0 (size_arms rest)) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps
             ((rewrite (lemma size_arms_cons) lr lhs true ()))
             (by farkas (list 1 1 1)))))))))
