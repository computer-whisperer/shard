;;; Standard library: generic data types used throughout the kernel.
;;;
;;; No special evaluator support — ordinary user-defined types. All
;;; polymorphism is erased at runtime in narrow; type variables are
;;; annotations the full-language checker will eventually validate.
;;;
;;; Primitives expected from the evaluator (defined in Rust, exposed
;;; as ordinary function symbols here):
;;;   (int_eq Int Int) -> Bool
;;;   (sym_eq Symbol Symbol) -> Bool
;;;   (+ - * / mod tmod ediv : Int Int -> Int)
;;;     pairing is explicit: `/`+`tmod` truncating, `ediv`+`mod`
;;;     Euclidean — the mixed `/`+`mod` is NOT an identity pair
;;;   (lt le : Int Int -> Bool)
;;;   (band bor bxor bshl bshr : Int Int -> Int)
;;;
;;; The primitive comparison ops return values of the user-defined
;;; `Bool` type below — see REVISIT.md (Primitive comparisons return
;;; user Bool).

(type (List T) (Nil) (Cons T (List T)))


(type (Option T) (None) (Some T))

(type Bool (False) (True))

(type (Pair A B) (Pair A B))

;; Nat — the kernel's literal-backed Peano naturals (the one exception to
;; "no special evaluator support" above). This declaration is the REFERENCE
;; SPEC: the reducer packs ground constructions to nonneg Int literals
;; ((S (S Z)) computes to 2 — the unique ground normal form) and matches
;; Z/S patterns against literals by VIEW (0 is Z, n>=1 matches (S (n-1))),
;; so ground Nat values are O(1) machine ints, never unary trees, while a
;; symbolic (S x) stays an ordinary stuck ctor term with ordinary ι. The
;; reducer hooks (reduce.shard nat_pack / match_nat_view) gate on the CORE
;; identity of Z/S — this file is the core crate — so a user type with
;; ctors named Z/S shadows cleanly and is untouched by the views. The
;; primitive's pedigree = behavioral conformance to this inductive: view-
;; matching agrees with ctor matching and packing agrees with the ctor
;; image (probed by examples/nat_prim.shard).
(type Nat (Z) (S Nat))
