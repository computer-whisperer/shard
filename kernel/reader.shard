;;; reader.shard — the s-expression reader, in shard.
;;;
;;; `parse_expr : String -> (List Symbol) -> (Option Expr)` turns source
;;; text (a (List Int) of UTF-8 bytes, as read_file delivers it) into
;;; the kernel's object `Expr`
;;; AST — the same value `src/load.rs::expr_from_str` produces in Rust,
;;; which is how this reader is validated (differential equivalence).
;;;
;;; Two stages:
;;;   read_top   : text  -> (Option SExpr)   pure syntax (paren tree)
;;;   elaborate  : SExpr -> (Option Expr)    ctor-vs-call, sugar, forms
;;;
;;; SCOPE: full proof-file front-end. Expressions: the applicative core +
;;; `if` / `match` / `let` (scope-threaded de Bruijn) / `list` / `quote`
;;; (incl. the `'X` reader macro) / string-literal sugar / the `ty` / `tv`
;;; type-builder sugars. Files: `parse_module` (types/fns/externs) and
;;; `parse_claims` (the `(claim NAME GOAL PROOF)` forms). All validated
;;; byte-for-byte against src/load.rs via `check parse-check` / `module-check`
;;; / `claims-check`. Remaining: assembling these into the checker driver.
;;;
;;; Needs the char↔symbol bridge primitives (src/prim.rs):
;;;   sym_of_chars : (List Int) -> Symbol
;;; Runs under NATIVE eval (it is a tool, not proof-faithful machinery);
;;; its OUTPUT AST is what gets evaluated under the bootstrapped reducer.

;; ---- syntax tree + reader results -----------------------------------------
;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(use (:: kernel term *))
(use (:: kernel module *))

(type SExpr (SInt Int) (SSym Symbol) (SStr (List Int)) (SList (List SExpr)))

;; read_expr's result: one SExpr + the unconsumed input, or an error.
(type RExpr (REOk SExpr (List Int)) (REErr))

;; read_items' result: a sequence of SExprs (a list's contents) + rest.
(type RItems (RIOk (List SExpr) (List Int)) (RIErr))

;; ---- small list/char helpers ----------------------------------------------
(fn rev_i ((xs (List Int)) (acc (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_i t (Cons h acc)))))

(fn sym_mem ((x Symbol) (xs (List Symbol))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (sym_eq x h) True (sym_mem x t)))))

(fn is_ws ((c Int)) Bool
  (if (int_eq c 32) True  ; space
  (if (int_eq c 9) True  ; tab
  (if (int_eq c 10) True  ; newline
  (if (int_eq c 13) True  ; carriage return
  False)))))

;; A delimiter ends an atom: whitespace, parens, quote, comment, or EOF.
(fn is_delim ((c Int)) Bool
  (if (is_ws c) True
  (if (int_eq c 40) True  ; (
  (if (int_eq c 41) True  ; )
  (if (int_eq c 34) True  ; "
  (if (int_eq c 59) True  ; ;
  (if (int_eq c 39) True  ; ' (quote — a delimiter, and a reader macro)
  False)))))))

(fn is_digit ((c Int)) Bool (if (le 48 c) (le c 57) False))  ; '0'..'9'

;; ---- whitespace / comments ------------------------------------------------
;; skip_ws / skip_ws_comment: a MUTUAL STRUCTURAL pair (both recurse on the
;; Cons-tail), so the gate auto-recognizes termination (AdMutual) with no
;; measure clause. Replaces the old skip_ws+skip_line, where skip_ws had a
;; non-structural site (skip_ws (skip_line rest)) — skip_line's output is a
;; computed suffix the gate cannot see shrink. Comment-skipping is folded in:
;; on ';' we enter skip_ws_comment, consume to the newline (inclusive), then
;; resume skip_ws on the tail — byte-identical to the old skip_line behavior.
(fn skip_ws ((cs (List Int))) (List Int)
  (measure (struct cs))
  (match cs
    (Nil Nil)
    ((Cons c rest)
     (if (is_ws c) (skip_ws rest)
     (if (int_eq c 59) (skip_ws_comment rest)  ; ';' comment to EOL
     cs)))))

(fn skip_ws_comment ((cs (List Int))) (List Int)
  (measure (struct cs))
  (match cs
    (Nil Nil)
    ((Cons c rest) (if (int_eq c 10) (skip_ws rest) (skip_ws_comment rest)))))

;; ---- atoms ----------------------------------------------------------------
;; Collect characters up to (not including) the next delimiter. Accumulator
;; style (reversed + rev_i) so the host stack stays flat on long atoms — the
;; reader's list-builders are all written this way; see the term.shard
;; conversion comment for why the (Cons c (recurse …)) shape is a stack bomb.
(fn take_atom_go ((cs (List Int)) (acc (List Int))) (Pair (List Int) (List Int))
  (measure (struct cs))
  (match cs
    (Nil (Pair (rev_i acc Nil) Nil))
    ((Cons c rest)
     (if (is_delim c) (Pair (rev_i acc Nil) cs)
     (take_atom_go rest (Cons c acc))))))

(fn take_atom ((cs (List Int))) (Pair (List Int) (List Int))
  (take_atom_go cs Nil))

(fn digits_val ((cs (List Int)) (acc Int)) Int
  (measure (struct cs))
  (match cs
    (Nil acc)
    ((Cons c rest) (digits_val rest (+ (* acc 10) (- c 48))))))

;; True iff the list is nonempty and every char is a digit.
(fn all_digits_ne ((cs (List Int))) Bool
  (match cs
    (Nil False)
    ((Cons c rest) (if (is_digit c) (all_digits_tail rest) False))))

(fn all_digits_tail ((cs (List Int))) Bool
  (measure (struct cs))  ; empty ok
  (match cs
    (Nil True)
    ((Cons c rest) (if (is_digit c) (all_digits_tail rest) False))))

;; Classify a nonempty atom: an integer (optional leading '-') or a symbol.
(fn classify_atom ((cs (List Int))) SExpr
  (match cs
    (Nil (SSym (sym_of_chars Nil)))  ; unreachable (atom is nonempty)
    ((Cons c rest)
     (if (int_eq c 45)  ; '-'
       (if (all_digits_ne rest) (SInt (- 0 (digits_val rest 0)))
       (SSym (sym_of_chars cs)))
     (if (all_digits_ne cs) (SInt (digits_val cs 0))
     (SSym (sym_of_chars cs)))))))

;; ---- the reader proper ----------------------------------------------------
;; Read exactly one s-expression, returning it and the unconsumed input.
;; Fuel for the input-consuming reader recursion. read_expr ⟷ read_items_go
;; form a mutual SCC over the *unconsumed* input — the recursion is on the
;; tail read_expr returns, not a structural subterm, so this is fuel rather
;; than a structural measure (cf. tc_walk). A give-up on exhaustion yields a
;; parse error (conservative/sound); the budget (1e9) dwarfs any real source,
;; so the give-up is dead code on well-formed input.
(fn read_budget () Int 1000000000)

(fn read_expr ((cs0 (List Int))) RExpr (read_expr_go cs0 (read_budget)))

(fn read_expr_go ((cs0 (List Int)) (fuel Int)) RExpr
  (measure
    fuel
    (by farkas (list 1 0))
    (by farkas (list 1 1))
    (by farkas (list 1 0))
    (by farkas (list 1 1)))
  (if (lt fuel 1) REErr
  (match (skip_ws cs0)
    (Nil REErr)
    ((Cons c rest)
     (if (int_eq c 40)  ; '(' → list
       (match (read_items_go rest Nil (- fuel 1))
         (RIErr REErr)
         ((RIOk items rest2) (REOk (SList items) rest2)))
     (if (int_eq c 41)  ; ')' → unbalanced
       REErr
     (if (int_eq c 34)  ; '"' → string
       (read_string rest Nil)
     (if (int_eq c 39)  ; '\'' → quote reader macro: 'X ≡ (quote X)
       (match (read_expr_go rest (- fuel 1))
         (REErr REErr)
         ((REOk s rest2)
          (REOk (SList (Cons (SSym (quote quote)) (Cons s Nil))) rest2)))
       ;; else: an atom. Re-attach c by classifying from (Cons c rest).
       (match (take_atom (Cons c rest))
         ((Pair atom rest2) (REOk (classify_atom atom) rest2)))))))))))

(fn rev_sexpr ((xs (List SExpr)) (acc (List SExpr))) (List SExpr)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_sexpr t (Cons h acc)))))

;; Read s-expressions until the matching ')'. Accumulator style: the host
;; stack depth is the NESTING depth (via read_expr), never the sibling count.
(fn read_items_go ((cs0 (List Int)) (acc (List SExpr)) (fuel Int)) RItems
  (measure
    fuel
    (by farkas (list 1 0))
    (by farkas (list 1 1))
    (by farkas (list 1 0))
    (by farkas (list 1 1)))
  (if (lt fuel 1) RIErr
  (match (skip_ws cs0)
    (Nil RIErr)  ; unterminated list
    ((Cons c rest)
     (if (int_eq c 41)  ; ')' → done
       (RIOk (rev_sexpr acc Nil) rest)
       (match (read_expr_go (Cons c rest) (- fuel 1))
         (REErr RIErr)
         ((REOk head rest2) (read_items_go rest2 (Cons head acc) (- fuel 1)))))))))

;; Read a string body (the opening '"' already consumed). `acc` holds the
;; decoded characters in reverse.
(fn read_string ((cs (List Int)) (acc (List Int))) RExpr
  (measure (struct cs))
  (match cs
    (Nil REErr)  ; unterminated string
    ((Cons c rest)
     (if (int_eq c 34)  ; closing '"'
       (REOk (SStr (rev_i acc Nil)) rest)
     (if (int_eq c 92)  ; '\' escape
       (match rest
         (Nil REErr)
         ((Cons e rest2) (read_string rest2 (Cons (unescape e) acc))))
       (read_string rest (Cons c acc)))))))

(fn unescape ((c Int)) Int
  (if (int_eq c 110) 10  ; \n
  (if (int_eq c 116) 9  ; \t
  (if (int_eq c 114) 13  ; \r
  c))))  ; \" \\ … → the literal char

;; Read one expression and require the rest to be whitespace/comments only.
(fn read_top ((src (List Int))) (Option SExpr)
  (match (read_expr src)
    (REErr None)
    ((REOk s rest)
     (match (skip_ws rest)
       (Nil (Some s))
       (_ None)))))  ; trailing junk → reject

;; ---- elaboration: SExpr → object Expr -------------------------------------
;; `elaborate` threads `scope : (List Symbol)`, the binder stack with the
;; INNERMOST binder at the FRONT (= BVar 0) — mirroring src/load.rs's
;; LoadCtx so the de Bruijn indices match the Rust loader exactly.

;; "abc" → (Cons 97 (Cons 98 (Cons 99 Nil))) — the String≡(List Int) sugar.
;; Exactly term.shard's accumulator-style conversion.
(fn str_sugar ((cs (List Int))) Expr (intlist_to_expr cs))

;; (list E1 E2 …) → (Cons E1 (Cons E2 … Nil)). Accumulator style: reverse,
;; then fold the object list innermost-first — every call a tail call.
(fn rev_expr_l ((xs (List Expr)) (acc (List Expr))) (List Expr)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_expr_l t (Cons h acc)))))

(fn list_sugar_go ((res (List Expr)) (acc Expr)) Expr
  (measure (struct res))
  (match res
    (Nil acc)
    ((Cons h t)
     (list_sugar_go t (Ctor (qn (quote Cons)) (Cons h (Cons acc Nil)))))))

(fn list_sugar ((es (List Expr))) Expr
  (list_sugar_go (rev_expr_l es Nil) (Ctor (qn (quote Nil)) Nil)))

;; Index of `x` in the scope (0 = front = innermost), or None.
(fn find_idx ((x Symbol) (xs (List Symbol)) (k Int)) (Option Int)
  (measure (struct xs))
  (match xs
    (Nil None)
    ((Cons h t) (if (sym_eq x h) (Some k) (find_idx x t (+ k 1))))))

(fn append_sym ((xs (List Symbol)) (ys (List Symbol))) (List Symbol)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (append_sym t ys)))))

;; ===========================================================================
;; QUALIFIED-PATH FORM  (Stage 2.5)  —  `(:: SEG … NAME)`
;;
;; A reference whose module is named explicitly: the last segment is the entity,
;; the preceding segments are its module PATH, rooted at `self`/`super`/`crate`
;; (relative to the current module) or a crate name (absolute) — mirroring Rust.
;; PARSING produces a QName carrying the RAW path (keywords intact); the resolver
;; (resolve_qpath, below rhead) re-roots it against the current module. A bare
;; name keeps the `core` placeholder and is resolved by env lookup instead — so
;; the two are told apart by whether the parsed module-path is `core`.
;; `::` is built from char 58 (`(quote ::)` is not writable under the bootstrap
;; lexer, cf. dot_sym).
;; ===========================================================================
(fn coloncolon_sym () Symbol (sym_of_chars (Cons 58 (Cons 58 Nil))))
;; the glob marker `*` (char 42) — `(use (:: MOD *))` brings all of MOD's items.
(fn star_sym () Symbol (sym_of_chars (Cons 42 Nil)))

;; every segment SExpr must be a bare symbol
(fn seg_syms ((segs (List SExpr))) (Option (List Symbol))
  (measure (struct segs))
  (match segs
    (Nil (Some Nil))
    ((Cons (SSym s) rest)
     (match (seg_syms rest)
       (None None)
       ((Some r) (Some (Cons s r)))))
    (_ None)))

;; (init, last) — splits the segment names into the module path + entity name.
(fn split_last ((xs (List Symbol))) (Option (Pair (List Symbol) Symbol))
  (measure (struct xs))
  (match xs
    (Nil None)
    ((Cons s Nil) (Some (Pair Nil s)))
    ((Cons s rest)
     (match (split_last rest)
       (None None)
       ((Some (Pair init last)) (Some (Pair (Cons s init) last)))))))

;; A qualified-path head → the RAW (pre-rooting) QName: `(QName path name)` with
;; a NON-empty path (≥2 segments: at least one module/root segment + the name).
(fn qpath_qname ((segs (List SExpr))) (Option QName)
  (match (seg_syms segs)
    (None None)
    ((Some syms)
     (match (split_last syms)
       (None None)
       ((Some (Pair init last))
        (match init
          (Nil None)  ; `(:: x)` — no module segment — rejected
          (_ (Some (QName init last)))))))))

;; --- path re-rooting (used by rhead) ---------------------------------------
(fn first_seg ((p (List Symbol))) (List Symbol)
  (match p
    (Nil Nil)
    ((Cons s _) (Cons s Nil))))

(fn drop_last_sym ((p (List Symbol))) (List Symbol)
  (measure (struct p))
  (match p
    (Nil Nil)
    ((Cons _ Nil) Nil)
    ((Cons h t) (Cons h (drop_last_sym t)))))

(fn drop_last_n ((p (List Symbol)) (n Int)) (List Symbol)
  (measure n (by farkas (list 1 0)) (by farkas (list 1 1)))
  (if (le n 0) p (drop_last_n (drop_last_sym p) (- n 1))))

(fn count_supers ((segs (List Symbol)) (k Int)) Int
  (measure (struct segs))
  (match segs
    (Nil k)
    ((Cons s t) (if (sym_eq s (quote super)) (count_supers t (+ k 1)) k))))

(fn drop_supers ((segs (List Symbol))) (List Symbol)
  (measure (struct segs))
  (match segs
    (Nil Nil)
    ((Cons s t) (if (sym_eq s (quote super)) (drop_supers t) segs))))

;; assoc lookup over a name→module-path table (first match wins).
(fn assoc_sym ((k Symbol) (tbl (List (Pair Symbol (List Symbol)))))
  (Option (List Symbol))
  (measure (struct tbl))
  (match tbl
    (Nil None)
    ((Cons (Pair n p) rest) (if (sym_eq k n) (Some p) (assoc_sym k rest)))))

;; Re-root a raw segment list (the WHOLE list is a module path — no trailing
;; item name) against `curmod` and the use-bound module `aliases` (Stage 2.5b):
;;   self  → curmod                       (then append the rest)
;;   crate → curmod's first segment       (the crate root)
;;   super → curmod's parent, one per super (then append the rest)
;;   a use-bound module alias → the aliased module path (then append the rest)
;;   else  → absolute: the path IS the module path (first segment = crate name)
(fn resolve_full_modpath
  ((segs (List Symbol))
   (curmod (List Symbol))
   (aliases (List (Pair Symbol (List Symbol)))))
  (List Symbol)
  (match segs
    (Nil curmod)  ; `(:: *)` alone → glob the current module
    ((Cons s0 rest)
     (if (sym_eq s0 (quote self)) (append_sym curmod rest)
     (if (sym_eq s0 (quote crate)) (append_sym (first_seg curmod) rest)
     (if (sym_eq s0 (quote super))
       (append_sym
         (drop_last_n curmod (count_supers segs 0))
         (drop_supers segs))
       (match (assoc_sym s0 aliases)
         ((Some base) (append_sym base rest))  ; use-bound module alias
         (None segs))))))))  ; absolute crate-rooted

;; A `(:: MOD … NAME)` head: re-root the MOD path, keep NAME as the local name.
(fn resolve_qpath
  ((rawpath (List Symbol))
   (name Symbol)
   (curmod (List Symbol))
   (aliases (List (Pair Symbol (List Symbol)))))
  QName
  (QName (resolve_full_modpath rawpath curmod aliases) name))

;; Push binder names (in source order) onto the scope: the LAST name ends
;; up at the front, so it becomes BVar 0 (cf. LANGUAGE.md §7).
(fn push_scope ((names (List Symbol)) (scope (List Symbol))) (List Symbol)
  (measure (struct names))
  (match names
    (Nil scope)
    ((Cons n rest) (push_scope rest (Cons n scope)))))

;; ---- patterns ----
;; Returns the kernel Pat plus the variable names it binds, in source
;; (left-to-right) order — the order push_scope expects.
(fn elab_pat ((s SExpr) (ctors (List Symbol))) (Option (Pair Pat (List Symbol)))
  (measure
    (size_sexpr s)
    ;; premises 0/1/2 = (= s (SList items)) / (= items (Cons head rest)) /
    ;; (= head <ctor>); then the if-guards.
    ;; site 1 — (elab_qpat rest Nil ctors), guard ::=True. 4 premises.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ())
       (rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
      (by farkas (list 1 0 0 0 0)))
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
        (by farkas (list 1 0 0 0 0 1))))
    ;; site 2 — (elab_pats rest ctors). guards: ::=False, quote=False,
    ;; (sym_mem h ctors)=True → 6 premises total.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ()))
      (by farkas (list 1 0 0 0 0 0 0)))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl)
    ;; site 3 — (elab_qpat hsegs rest ctors). premise 2 = (= head (SList (Cons
    ;; (SSym hh) hsegs))). 4 premises.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ()))
      (by farkas (list 1 0 0 0 0)))
    (have (= (le 0 (size_sexpr_list hsegs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr_list rest)) True)
        (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
        (by farkas (list 1 0 0 0 0 1 1)))))
  (match s
    ((SInt n) (Some (Pair (PInt n) Nil)))
    ((SStr _) None)  ; strings aren't narrow patterns
    ((SSym name)
     (if (sym_mem name ctors) (Some (Pair (PCtor (qn name) Nil) Nil))  ; bare 0-ary ctor pattern
     (Some (Pair (PVar) (Cons name Nil)))))  ; PVar binds `name` (incl. _)
    ((SList items)
     (match items
       (Nil None)
       ((Cons head rest)
        (match head
          ((SSym h)
           (if (sym_eq h (coloncolon_sym)) (elab_qpat rest Nil ctors)  ; (:: … Ctor)
           (if (sym_eq h (quote quote)) (elab_psym rest)  ; (quote SYM) → PSym
           (if (sym_mem h ctors)
             (match (elab_pats rest ctors)
               (None None)
               ((Some (Pair ps names)) (Some (Pair (PCtor (qn h) ps) names))))
             None))))  ; unknown ctor in pattern → reject
          ;; `((:: … Ctor) p1 …)` — applied qualified-path ctor pattern
          ((SList (Cons (SSym hh) hsegs))
           (if (sym_eq hh (coloncolon_sym)) (elab_qpat hsegs rest ctors) None))
          (_ None)))))))

;; A qualified-path constructor pattern: `segs` the path, `subs` the field
;; sub-patterns. The last segment must name a known constructor.
(fn elab_qpat ((segs (List SExpr)) (subs (List SExpr)) (ctors (List Symbol)))
  (Option (Pair Pat (List Symbol)))
  (measure
    (+ 1 (+ (size_sexpr_list segs) (size_sexpr_list subs)))
    ;; site 1 — (elab_pats subs ctors). subs is a PARAM; both premises (qpath
    ;; result, sym_mem guard) drop (q untyped). decrease needs segs >= 0.
    (have (= (le 0 (size_sexpr_list segs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 1)))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match (qpath_qname segs)
    (None None)
    ((Some q)
     (if (sym_mem (qn_name q) ctors)
       (match (elab_pats subs ctors)
         (None None)
         ((Some (Pair ps names)) (Some (Pair (PCtor q ps) names))))
       None))))

(fn elab_psym ((rest (List SExpr))) (Option (Pair Pat (List Symbol)))
  (match rest
    ((Cons (SSym s) Nil) (Some (Pair (PSym s) Nil)))
    (_ None)))

(fn elab_pats ((ss (List SExpr)) (ctors (List Symbol)))
  (Option (Pair (List Pat) (List Symbol)))
  (measure
    (size_sexpr_list ss)
    ;; site 1 — (elab_pat h ctors). premise 0 = (= ss (Cons h t)). needs t >= 0.
    (have (= (le 0 (size_sexpr_list t)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elab_pats t ctors). premise 0, premise 1 = (= (elab_pat h ctors)
    ;; (Some (Pair p pn))). needs size_sexpr h >= 0.
    (have (= (le 0 (size_sexpr h)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match ss
    (Nil (Some (Pair Nil Nil)))
    ((Cons h t)
     (match (elab_pat h ctors)
       (None None)
       ((Some (Pair p pn))
        (match (elab_pats t ctors)
          (None None)
          ((Some (Pair ps tn)) (Some (Pair (Cons p ps) (append_sym pn tn))))))))))

;; ---- compound expression forms ----
(fn elaborate_list
  ((xs (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option (List Expr))
  (measure
    (size_sexpr_list xs)
    ;; site 1 — (elaborate h). premise 0 = (= xs (Cons h t)). needs t >= 0.
    (have (= (le 0 (size_sexpr_list t)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elaborate_list t). premise 1 = (= (elaborate h ..) (Some e)).
    (have (= (le 0 (size_sexpr h)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match xs
    (Nil (Some Nil))
    ((Cons h t)
     (match (elaborate h ctors scope)
       (None None)
       ((Some e)
        (match (elaborate_list t ctors scope)
          (None None)
          ((Some es) (Some (Cons e es)))))))))

(fn elab_if ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr_list args))
    ;; args = (Cons c (Cons t (Cons e Nil))); premise 0 = that arm. Each site
    ;; recurses on one element; the other two appear positively (need nonneg).
    ;; site 1 — (elaborate c).
    (have (= (le 0 (size_sexpr t)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr e)) True)
        (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
        (steps
          ((rewrite (premise 0) lr lhs true ()) (simp lhs))
          (by farkas (list 1 0 1 1)))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elaborate t). premise 1 = (= (elaborate c ..) (Some ce)).
    (have (= (le 0 (size_sexpr c)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr e)) True)
        (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
        (steps
          ((rewrite (premise 0) lr lhs true ()) (simp lhs))
          (by farkas (list 1 0 0 1 1)))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 3 — (elaborate e). premises 1,2 = (Some ce),(Some te).
    (have (= (le 0 (size_sexpr c)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr t)) True)
        (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
        (steps
          ((rewrite (premise 0) lr lhs true ()) (simp lhs))
          (by farkas (list 1 0 0 0 1 1)))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl))
  (match args
    ((Cons c (Cons t (Cons e Nil)))
     (match (elaborate c ctors scope)
       (None None)
       ((Some ce)
        (match (elaborate t ctors scope)
          (None None)
          ((Some te)
           (match (elaborate e ctors scope)
             (None None)
             ((Some ee) (Some (If ce te ee)))))))))
    (_ None)))

(fn elab_list ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr_list args))
    ;; site 1 — (elaborate_list args), scrutinee position (no premise). args same.
    (by farkas (list 1))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match (elaborate_list args ctors scope)
    (None None)
    ((Some es) (Some (list_sugar es)))))

(fn elab_quote ((args (List SExpr))) (Option Expr)
  (match args
    ((Cons (SSym s) Nil) (Some (SymLit s)))
    (_ None)))

;; type-builder sugars: (ty NAME args…) and (tv NAME) construct Type VALUES
;; (TCon / TVar) — used in claim-body Goal Params. Mirrors load.rs
;; load_ty / load_ty_arg / load_tv. (ty …)'s args-chain is exactly a
;; list_sugar of the elaborated args; a BARE-SYMBOL arg is a 0-ary TCon
;; (so `(ty List Int)` makes Int a `(TCon 'Int Nil)`, not an FVar).
(fn elab_ty_arg ((a SExpr) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr a))
    ;; site 1 — (elaborate a) in the wildcard arm (no premise). a same.
    (by farkas (list 1))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl))
  (match a
    ((SSym sym)
     (Some
       (Ctor
         (qn (quote TCon))
         (Cons (SymLit sym) (Cons (Ctor (qn (quote Nil)) Nil) Nil)))))
    (_ (elaborate a ctors scope))))  ; (tv T), nested (ty …), explicit ctor app

(fn elab_ty_args
  ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option (List Expr))
  (measure
    (+ 1 (size_sexpr_list args))
    ;; site 1 — (elab_ty_arg a). premise 0 = (= args (Cons a rest)). needs
    ;; size_sexpr_list rest >= 0 (the +1 head-fn offset is absorbed by elab_ty_args's +1).
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 1))))
    (have (= (le 0 (size_sexpr a)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 1)))
    ;; site 2 — (elab_ty_args rest). premise 1 = (= (elab_ty_arg a ..) (Some ea)).
    (have (= (le 0 (size_sexpr a)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 1))))
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 1))))
  (match args
    (Nil (Some Nil))
    ((Cons a rest)
     (match (elab_ty_arg a ctors scope)
       (None None)
       ((Some ea)
        (match (elab_ty_args rest ctors scope)
          (None None)
          ((Some erest) (Some (Cons ea erest)))))))))

(fn elab_ty ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr_list args))
    ;; site 1 — (elab_ty_args rest). premise 0 = (= args (Cons (SSym name) rest)).
    (steps
      ((rewrite (premise 0) lr lhs true ()) (simp lhs))
      (by farkas (list 1 0)))
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 1))))
  (match args
    ((Cons (SSym name) rest)
     (match (elab_ty_args rest ctors scope)
       (None None)
       ((Some eargs)
        (Some
          (Ctor
            (qn (quote TCon))
            (Cons (SymLit name) (Cons (list_sugar eargs) Nil)))))))
    (_ None)))  ; (ty) with no name, or non-symbol name

(fn elab_tv ((args (List SExpr))) (Option Expr)
  (match args
    ((Cons (SSym name) Nil)
     (Some (Ctor (qn (quote TVar)) (Cons (SymLit name) Nil))))
    (_ None)))

(fn elab_arm ((s SExpr) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Arm)
  ;; bare numeric measure: the site-0 decrease + nonneg proofs live in the
  ;; sidecar kernel/reader.auto.shard, keyed elab_arm#0#decrease / #0#nonneg.
  ;; FIRST consumer of the auto+sidecar path for totality homework (issue #1).
  (measure (size_sexpr s))
  (match s
    ((SList (Cons patS (Cons bodyS Nil)))
     (match (elab_pat patS ctors)
       (None None)
       ((Some (Pair pat names))
        (match (elaborate bodyS ctors (push_scope names scope))
          (None None)
          ((Some body) (Some (Arm pat body)))))))
    (_ None)))

(fn elab_arms ((ss (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option (List Arm))
  (measure
    (size_sexpr_list ss)
    ;; site 1 — (elab_arm h). premise 0 = (= ss (Cons h t)).
    (have (= (le 0 (size_sexpr_list t)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elab_arms t). premise 1 = (= (elab_arm h ..) (Some a)).
    (have (= (le 0 (size_sexpr h)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match ss
    (Nil (Some Nil))
    ((Cons h t)
     (match (elab_arm h ctors scope)
       (None None)
       ((Some a)
        (match (elab_arms t ctors scope)
          (None None)
          ((Some rest) (Some (Cons a rest)))))))))

(fn elab_match ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr_list args))
    ;; site 1 — (elaborate scrutS). premise 0 = (= args (Cons scrutS arms)).
    (have (= (le 0 (size_sexpr_list arms)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elab_arms arms). premise 1 = (= (elaborate scrutS ..) (Some scrut)).
    (have (= (le 0 (size_sexpr scrutS)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match args
    (Nil None)
    ((Cons scrutS arms)
     (match (elaborate scrutS ctors scope)
       (None None)
       ((Some scrut)
        (match (elab_arms arms ctors scope)
          (None None)
          ((Some arms2) (Some (Match scrut arms2)))))))))

;; let bindings: RHSs elaborated in the OUTER scope (parallel let), names
;; collected in source order.
(fn elab_binds ((ss (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option (Pair (List Expr) (List Symbol)))
  (measure
    (size_sexpr_list ss)
    ;; site 1 — (elaborate rhsS). premises 0,1 = (= ss (Cons b rest)),
    ;; (= b (SList (Cons (SSym name) (Cons rhsS Nil)))). rhsS strict subterm.
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (premise 1) lr lhs true ())
         (simp lhs))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elab_binds rest). premise 2 = (= (elaborate rhsS ..) (Some rhs)).
    ;; expand only ss (leave b); residual = 1 + size_sexpr b, cite b's nonneg.
    (have (= (le 0 (size_sexpr b)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match ss
    (Nil (Some (Pair Nil Nil)))
    ((Cons b rest)
     (match b
       ((SList (Cons (SSym name) (Cons rhsS Nil)))
        (match (elaborate rhsS ctors scope)
          (None None)
          ((Some rhs)
           (match (elab_binds rest ctors scope)
             (None None)
             ((Some (Pair rhss names))
              (Some (Pair (Cons rhs rhss) (Cons name names))))))))
       (_ None)))))

(fn elab_let ((args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (size_sexpr_list args))
    ;; args = (Cons (SList binds) (Cons bodyS Nil)); premise 0 = that arm.
    ;; site 1 — (elab_binds binds). binds is inside the head; bodyS positive.
    (have (= (le 0 (size_sexpr bodyS)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl)
    ;; site 2 — (elaborate bodyS). premise 1 = (= (elab_binds binds ..) (Some (Pair rhss names))).
    (have (= (le 0 (size_sexpr_list binds)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ()) (simp lhs))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl))
  (match args
    ((Cons (SList binds) (Cons bodyS Nil))
     (match (elab_binds binds ctors scope)
       (None None)
       ((Some (Pair rhss names))
        (match (elaborate bodyS ctors (push_scope names scope))
          (None None)
          ((Some body) (Some (Let rhss body)))))))
    (_ None)))

;; The head of a list expression: a special form, or ctor/call application.
;; A qualified-path reference/application: `(:: SEG … NAME)` (segs, no value args)
;; or `((:: SEG … NAME) a1 …)` (valargs the applied arguments). The ctor set
;; (keyed by local name) decides Ctor vs Call, exactly as for a bare head.
(fn elab_qpath
  ((segs (List SExpr))
   (valargs (List SExpr))
   (ctors (List Symbol))
   (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 1 (+ (size_sexpr_list segs) (size_sexpr_list valargs)))
    ;; site 1 — (elaborate_list valargs). valargs a PARAM; both premises (qpath
    ;; result, sym_mem guard) drop (q untyped). decrease needs segs >= 0.
    (have (= (le 0 (size_sexpr_list segs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 1)))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match (qpath_qname segs)
    (None None)
    ((Some q)
     (match (elaborate_list valargs ctors scope)
       (None None)
       ((Some eargs)
        (if (sym_mem (qn_name q) ctors) (Some (Ctor q eargs))
        (Some (Call q eargs))))))))

(fn elaborate_form
  ((h Symbol) (args (List SExpr)) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (+ 2 (size_sexpr_list args))
    ;; All 7 sites are DELEGATIONS — same `args` passed on — so each decrease is
    ;; a constant gap (2 > callee offset); premises are the if-guards on `h`.
    ;; site 1 — (elab_qpath args Nil): guard ::=T (1 premise); msr2 has size_sexpr_list Nil.
    (steps ((simp lhs)) (by farkas (list 1 0)))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps ((simp lhs)) (by farkas (list 1 0 1))))
    ;; site 2 — (elab_if args): 2 premises.
    (by farkas (list 1 0 0))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 1)))
    ;; site 3 — (elab_match args): 3 premises.
    (by farkas (list 1 0 0 0))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 0 1)))
    ;; site 4 — (elab_let args): 4 premises.
    (by farkas (list 1 0 0 0 0))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 0 0 1)))
    ;; site 5 — (elab_list args): 5 premises.
    (by farkas (list 1 0 0 0 0 0))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 0 0 0 1)))
    ;; site 6 — (elab_ty args): 7 premises (through the quote guard).
    (by farkas (list 1 0 0 0 0 0 0 0))
    (have (= (le 0 (size_sexpr_list args)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 0 0 0 0 0 1)))
    ;; site 7 — (elaborate_list args): 8 premises; msr2 = size_sexpr_list args.
    (by farkas (list 1 0 0 0 0 0 0 0 0))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (if (sym_eq h (coloncolon_sym)) (elab_qpath args Nil ctors scope)
  (if (sym_eq h (quote if)) (elab_if args ctors scope)
  (if (sym_eq h (quote match)) (elab_match args ctors scope)
  (if (sym_eq h (quote let)) (elab_let args ctors scope)
  (if (sym_eq h (quote list)) (elab_list args ctors scope)
  (if (sym_eq h (quote quote)) (elab_quote args)
  (if (sym_eq h (quote ty)) (elab_ty args ctors scope)
  (if (sym_eq h (quote tv)) (elab_tv args)
  (match (elaborate_list args ctors scope)
    (None None)
    ((Some eargs)
     (if (sym_mem h ctors) (Some (Ctor (qn h) eargs))
     (Some (Call (qn h) eargs))))))))))))))  ; ctor set decides Ctor vs Call

(fn elaborate ((s SExpr) (ctors (List Symbol)) (scope (List Symbol)))
  (Option Expr)
  (measure
    (size_sexpr s)
    ;; premises 0/1/2 = (= s (SList items)) / (= items (Cons head rest)) /
    ;; (= head <ctor>); site 2 also the if-guard.
    ;; site 1 — (elaborate_form h rest). msr2 = 2 + size_sexpr_list rest.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (simp lhs))
      (by farkas (list 1 0 0 0)))
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 0 0 1)))
    ;; site 2 — (elab_qpath hsegs rest). head = (SList (Cons (SSym hh) hsegs)),
    ;; guard ::=True. msr2 = 1 + size_sexpr_list hsegs + size_sexpr_list rest.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (simp lhs))
      (by farkas (list 1 0 0 0 0)))
    (have (= (le 0 (size_sexpr_list hsegs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr_list rest)) True)
        (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
        (by farkas (list 1 0 0 0 0 1 1)))))
  (match s
    ((SInt n) (Some (IntLit n)))
    ((SStr cs) (Some (str_sugar cs)))
    ((SSym name)
     (match (find_idx name scope 0)
       ((Some i) (Some (BVar i)))  ; local binding → de Bruijn index
       (None
         (if (sym_mem name ctors) (Some (Ctor (qn name) Nil))  ; bare nullary ctor
         (Some (FVar name))))))  ; free variable
    ((SList items)
     (match items
       (Nil None)  ; () is not a valid expression
       ((Cons head rest)
        (match head
          ((SSym h) (elaborate_form h rest ctors scope))
          ;; `((:: SEG … NAME) a1 …)` — applied qualified-path head
          ((SList (Cons (SSym hh) hsegs))
           (if (sym_eq hh (coloncolon_sym)) (elab_qpath hsegs rest ctors scope)
           None))
          (_ None)))))))  ; other non-symbol head → reject

;; ---- expression entry point -----------------------------------------------
(fn parse_expr ((src (List Int)) (ctors (List Symbol))) (Option Expr)
  (match (read_top src)
    (None None)
    ((Some s) (elaborate s ctors Nil))))  ; top-level: empty binder scope

;; ===========================================================================
;; Module parsing: a whole file → kernel Module. Mirrors
;; src/load.rs::module_from_str_with_base — two passes (types first so
;; ctor names are known for bodies), `base_ctors` are the ambient ctors
;; (kernel stdlib) so a file can use Cons/Some/… without redeclaring them.
;; ===========================================================================

;; Read every top-level s-expression in the source. Accumulator style — the
;; host stack must not grow with the number of toplevel forms.
(fn read_all_go ((src (List Int)) (acc (List SExpr)) (fuel Int))
  (Option (List SExpr))
  (measure fuel (by farkas (list 1 0)) (by farkas (list 1 1)))
  (if (lt fuel 1) None
  (match (skip_ws src)
    (Nil (Some (rev_sexpr acc Nil)))
    ((Cons c rest0)
     (match (read_expr (Cons c rest0))
       (REErr None)
       ((REOk s rest) (read_all_go rest (Cons s acc) (- fuel 1))))))))

(fn read_all ((src (List Int))) (Option (List SExpr))
  (read_all_go src Nil (read_budget)))

;; ---- types ----

;; The decimal digits of a non-negative int, as ASCII bytes. Inverse of
;; digits_val; show_nat (term.shard) renders the CANONICAL numeric symbol
;; (no leading zeros), so two mentions of the same width are the same TCon name.

;; ---- AST size over SExpr (issue #1; shared by the SExpr-walker measures) ----
;; size_sexpr / size_sexpr_list are a structural mutual pair (AdMutual — no
;; clause needed). They are the numeric measure driving the (measure …) clauses
;; on qtype/parse_type/parse_types below (a 3-member AdUnresolved SCC: parse_type
;; passes a sublist to qtype which passes it on to parse_types — no single
;; descending structural track). One recursive ctor (SList), so the nonneg proof
;; is one inline list-induction. Developed in examples/sexpr_measure.shard.
(fn size_sexpr ((s SExpr)) Int
  (measure (struct s))
  (match s
    ((SInt _) 1)
    ((SSym _) 1)
    ((SStr _) 1)
    ((SList items) (+ 1 (size_sexpr_list items)))))

(fn size_sexpr_list ((ss (List SExpr))) Int
  (measure (struct ss))
  (match ss
    (Nil 0)
    ((Cons h t) (+ 1 (+ (size_sexpr h) (size_sexpr_list t))))))

;; defining equations (one structural unfold each)
(claim size_sexpr_slist
  (goal ((items (List SExpr))) ()
    (= (size_sexpr (SList items)) (+ 1 (size_sexpr_list items))))
  (steps ((simp lhs)) refl))

(claim size_sexpr_ssym
  (goal ((y Symbol)) () (= (size_sexpr (SSym y)) 1))
  (steps ((simp lhs)) refl))

(claim size_sexpr_list_nil
  (goal () () (= (size_sexpr_list Nil) 0))
  (steps ((simp lhs)) refl))

(claim size_sexpr_list_cons
  (goal ((h SExpr) (t (List SExpr))) ()
    (=
      (size_sexpr_list (Cons h t))
      (+ 1 (+ (size_sexpr h) (size_sexpr_list t)))))
  (steps ((simp lhs)) refl))

;; nonneg pair: size_sexpr_nonneg by subterm-induction (the SList case proves
;; 0 <= size_sexpr_list items inline, each head's bound from the strong IH via
;; (below)); size_sexpr_list_nonneg an ordinary spine induct citing it one-way.
(claim size_sexpr_nonneg
  (goal ((s SExpr)) () (= (le 0 (size_sexpr s)) True))
  (subterm-induct
    s
    (case-on s SExpr
      ((case SInt
         (n)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case SSym
         (y)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case SStr
         (cs)
         (steps ((rewrite (hyp 0) lr lhs true ()) (simp lhs)) refl))
       (case SList
         (items)
         (have (= (le 0 (size_sexpr_list items)) True)
           (induct items
             ((case Nil
                (steps
                  ((rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
                  (by farkas (list 1))))
              (case Cons
                (a rest)
                (have (= (le 0 (size_sexpr a)) True)
                  (rewrite-with (hyp ih) lr lhs () ((below)) refl)
                  (have (= (le 0 (size_sexpr_list rest)) True)
                    (rewrite-with (hyp 2) lr lhs ((inst s s)) () refl)
                    (steps
                      ((rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
                      (by farkas (list 1 1 1))))))))
           (steps
             ((rewrite (hyp 0) lr lhs true ())
              (rewrite (lemma size_sexpr_slist) lr lhs true ()))
             (by farkas (list 1 1)))))))))

(claim size_sexpr_list_nonneg
  (goal ((ks (List SExpr))) () (= (le 0 (size_sexpr_list ks)) True))
  (induct ks
    ((case Nil
       (steps
         ((rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
         (by farkas (list 1))))
     (case Cons
       (h t)
       (have (= (le 0 (size_sexpr h)) True)
         (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
         (have (= (le 0 (size_sexpr_list t)) True)
           (steps ((rewrite (hyp 0) lr lhs true ())) refl)
           (steps
             ((rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
             (by farkas (list 1 1 1)))))))))

;; A qualified-path type: `(:: SEG … NAME)` (0-ary; `segs` is the path, no type
;; args) or applied `((:: SEG … NAME) A1 …)` (`argforms` the type arguments).
(fn qtype ((segs (List SExpr)) (argforms (List SExpr)) (tparams (List Symbol)))
  (Option Type)
  (measure
    (+ 1 (+ (size_sexpr_list segs) (size_sexpr_list argforms)))
    ;; site 1 — (parse_types argforms tparams). argforms is a PARAM; premise 0
    ;; (= (qpath_qname segs) (Some q)) is dropped (q untyped). decrease needs
    ;; size_sexpr_list segs >= 0.
    (have (= (le 0 (size_sexpr_list segs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 1)))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match (qpath_qname segs)
    (None None)
    ((Some q)
     (match (parse_types argforms tparams)
       (None None)
       ((Some args) (Some (TCon q args)))))))

(fn parse_type ((s SExpr) (tparams (List Symbol))) (Option Type)
  (measure
    (size_sexpr s)
    ;; premises (all kept, all reference typed binders): 0 = (= s (SList items)),
    ;; 1 = (= items (Cons head rest)), 2 = (= head <ctor>),
    ;; 3 = if-guard (= (sym_eq … (coloncolon_sym)) <pol>).
    ;; site 1 — (qtype rest Nil tparams), guard True. msr2 = 1 + size_sexpr_list
    ;; rest + size_sexpr_list Nil; expand s to 3 + size_sexpr_list rest.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ())
       (rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
      (by farkas (list 1 0 0 0 0)))
    (have (= (le 0 (size_sexpr_list rest)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (lemma size_sexpr_list_nil) lr lhs true ()))
        (by farkas (list 1 0 0 0 0 1))))
    ;; site 2 — (parse_types rest tparams), guard False. msr2 = size_sexpr_list
    ;; rest; expand s to 3 + size_sexpr_list rest.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ()))
      (by farkas (list 1 0 0 0 0)))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl)
    ;; site 3 — (qtype hsegs rest tparams). premise 2 = (= head (SList (Cons
    ;; (SSym hh) hsegs))). msr2 = 1 + size_sexpr_list hsegs + size_sexpr_list
    ;; rest; expand s to 5 + size_sexpr_list hsegs + size_sexpr_list rest.
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (premise 1) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (premise 2) lr lhs true ())
       (rewrite (lemma size_sexpr_slist) lr lhs true ())
       (rewrite (lemma size_sexpr_list_cons) lr lhs true ())
       (rewrite (lemma size_sexpr_ssym) lr lhs true ()))
      (by farkas (list 1 0 0 0 0)))
    (have (= (le 0 (size_sexpr_list hsegs)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (have (= (le 0 (size_sexpr_list rest)) True)
        (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
        (by farkas (list 1 0 0 0 0 1 1)))))
  (match s
    ((SSym name)
     (if (sym_mem name tparams) (Some (TVar name))  ; a type parameter in scope
     (Some (TCon (qn name) Nil))))  ; 0-ary type constructor
    ;; A numeric LITERAL TYPE — the width index of (Word W S). Encoded as
    ;; a TCon whose name is the canonical decimal symbol: unification and
    ;; substitution treat it like any 0-ary constructor (literals unify
    ;; only with themselves), and tc_ty_wf rejects it anywhere other than
    ;; Word's width slot (no typedef exists for it).
    ((SInt k)
     (if (lt k 0) None (Some (TCon (qn (sym_of_chars (show_nat k))) Nil))))
    ((SList items)
     (match items
       (Nil None)
       ((Cons head rest)
        (match head
          ((SSym hname)  ; (HEAD a1 a2 …) — applied type, or (:: …) standalone
           (if (sym_eq hname (coloncolon_sym)) (qtype rest Nil tparams)
           (match (parse_types rest tparams)
             (None None)
             ((Some args) (Some (TCon (qn hname) args))))))
          ;; `((:: SEG … NAME) A1 …)` — applied qualified-path type
          ((SList (Cons (SSym hh) hsegs))
           (if (sym_eq hh (coloncolon_sym)) (qtype hsegs rest tparams) None))
          (_ None)))))
    (_ None)))  ; SStr isn't a type

(fn parse_types ((ss (List SExpr)) (tparams (List Symbol))) (Option (List Type))
  (measure
    (size_sexpr_list ss)
    ;; site 1 — (parse_type h tparams). premise 0 = (= ss (Cons h t)). decrease
    ;; needs size_sexpr_list t >= 0.
    (have (= (le 0 (size_sexpr_list t)) True)
      (rewrite-with (lemma size_sexpr_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl)
    ;; site 2 — (parse_types t tparams). premise 0 = (= ss (Cons h t)),
    ;; premise 1 = (= (parse_type h tparams) (Some ty)). decrease needs
    ;; size_sexpr h >= 0.
    (have (= (le 0 (size_sexpr h)) True)
      (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_sexpr_list_cons) lr lhs true ()))
        (by farkas (list 1 0 0 1))))
    (steps ((rewrite (lemma size_sexpr_list_nonneg) lr lhs true ())) refl))
  (match ss
    (Nil (Some Nil))
    ((Cons h t)
     (match (parse_type h tparams)
       (None None)
       ((Some ty)
        (match (parse_types t tparams)
          (None None)
          ((Some tys) (Some (Cons ty tys)))))))))

;; A name-or-parameterized head: `NAME` or `(NAME P1 P2 …)`. Shared by
;; `type`, `fn`, and `extern`.
(fn parse_head ((s SExpr)) (Option (Pair Symbol (List Symbol)))
  (match s
    ((SSym name) (Some (Pair name Nil)))
    ((SList (Cons (SSym name) ps))
     (match (sym_names ps)
       (None None)
       ((Some params) (Some (Pair name params)))))
    (_ None)))

(fn sym_names ((ss (List SExpr))) (Option (List Symbol))
  (measure (struct ss))
  (match ss
    (Nil (Some Nil))
    ((Cons (SSym n) t)
     (match (sym_names t)
       (None None)
       ((Some ns) (Some (Cons n ns)))))
    (_ None)))

;; A refined type body: the sole clause `(refine BASE PRED)` — BASE a type, PRED
;; the bare name of the (total Bool) predicate fn. Names are resolved to full
;; QNames later by resolve_refine. None when the body is ordinary ctor clauses.
;; See docs/REFINEMENT.md. (`refine` is reserved as the sole-clause type-body
;; keyword; an ordinary ctor may not be named `refine`.)
(fn parse_refine_body ((ctorForms (List SExpr)) (params (List Symbol)))
  (Option (Pair Type QName))
  (match ctorForms
    ((Cons
       (SList (Cons (SSym h) (Cons baseForm (Cons (SSym predName) Nil))))
       Nil)
     (if (sym_eq h (quote refine))
       (match (parse_type baseForm params)
         (None None)
         ((Some base) (Some (Pair base (qn predName)))))
       None))
    (_ None)))

;; ---- (type …) ----
(fn parse_typedef ((parts (List SExpr))) (Option TypeDef)
  (match parts
    (Nil None)
    ((Cons nameForm ctorForms)
     (match (parse_head nameForm)
       (None None)
       ((Some (Pair name params))
        (match (parse_refine_body ctorForms params)
          ((Some ref) (Some (TypeDef (qn name) params Nil (Some ref))))
          (None
            (match (parse_ctordefs ctorForms params)
              (None None)
              ((Some ctors) (Some (TypeDef (qn name) params ctors None)))))))))))

(fn parse_ctordefs ((ss (List SExpr)) (params (List Symbol)))
  (Option (List CtorDef))
  (measure (struct ss))
  (match ss
    (Nil (Some Nil))
    ((Cons c rest)
     (match (parse_ctordef c params)
       (None None)
       ((Some cd)
        (match (parse_ctordefs rest params)
          (None None)
          ((Some cds) (Some (Cons cd cds)))))))))

(fn parse_ctordef ((s SExpr) (params (List Symbol))) (Option CtorDef)
  (match s
    ((SList (Cons (SSym cname) fieldForms))
     (match (parse_types fieldForms params)
       (None None)
       ((Some ftypes) (Some (CtorDef (qn cname) ftypes)))))
    (_ None)))

;; ---- (fn …) / (extern …) parameter lists ----
(fn parse_params ((s SExpr) (tparams (List Symbol)))
  (Option (Pair (List Symbol) (List Type)))
  (match s
    ((SList items) (parse_param_items items tparams))
    (_ None)))

(fn parse_param_items ((ss (List SExpr)) (tparams (List Symbol)))
  (Option (Pair (List Symbol) (List Type)))
  (measure (struct ss))
  (match ss
    (Nil (Some (Pair Nil Nil)))
    ((Cons item rest)
     (match item
       ((SList (Cons (SSym pname) (Cons typeForm Nil)))
        (match (parse_type typeForm tparams)
          (None None)
          ((Some ty)
           (match (parse_param_items rest tparams)
             (None None)
             ((Some (Pair ns tys)) (Some (Pair (Cons pname ns) (Cons ty tys))))))))
       (_ None)))))

;; ---- (fn …) ----
(fn parse_fndef_core
  ((nameForm SExpr)
   (paramsForm SExpr)
   (retForm SExpr)
   (bodyForm SExpr)
   (ctors (List Symbol)))
  (Option FnDef)
  (match (parse_head nameForm)
    (None None)
    ((Some (Pair name tparams))
     (match (parse_params paramsForm tparams)
       (None None)
       ((Some (Pair pnames ptypes))
        (match (parse_type retForm tparams)
          (None None)
          ((Some ret)
           ;; body sees params as BVars — push names in source order
           ;; (last param = BVar 0), exactly as load_fn_def does.
           (match (elaborate bodyForm ctors (push_scope pnames Nil))
             (None None)
             ((Some body) (Some (FnDef (qn name) ptypes ret body)))))))))))

(fn parse_fndef ((parts (List SExpr)) (ctors (List Symbol))) (Option FnDef)
  (match parts
    ((Cons nameForm (Cons paramsForm (Cons retForm (Cons bodyForm Nil))))
     (parse_fndef_core nameForm paramsForm retForm bodyForm ctors))
    ;; (fn NAME PARAMS RET (measure E PROOF…) BODY) — the admissibility
    ;; clause (issue #1). The FnDef carries the body only; the measure check
    ;; reads the clause back from SOURCE (driver mc_outcome → mc_files), so
    ;; nothing here stores it. Body stays the LAST element.
    ((Cons
       nameForm
       (Cons paramsForm (Cons retForm (Cons clauseForm (Cons bodyForm Nil)))))
     (match (form_head clauseForm)
       (None None)
       ((Some ch)
        (if (sym_eq ch (quote measure))
          (parse_fndef_core nameForm paramsForm retForm bodyForm ctors)
          None))))
    (_ None)))

;; ---- (extern …) ----
(fn parse_externdef ((parts (List SExpr))) (Option ExternDef)
  (match parts
    ((Cons nameForm (Cons paramsForm (Cons retForm Nil)))
     (match (parse_head nameForm)
       (None None)
       ((Some (Pair name tparams))
        (match (parse_params paramsForm tparams)
          (None None)
          ((Some (Pair _ ptypes))
           (match (parse_type retForm tparams)
             (None None)
             ((Some ret) (Some (ExternDef (qn name) ptypes ret)))))))))
    (_ None)))

;; ---- (sig fn …) — a bodyless function SIGNATURE in a module interface --------
;; `(sig fn NAME (params) RET)` declares a public fn's signature in a
;; `mod.req.shard` WITHOUT a body. It loads as an ExternDef, so at proof time it
;; is stuck and reasoned about only through the interface's lemmas — the same
;; opacity `extern` gives. It is NOT an `extern`, though: the impl supplies a
;; real `(fn NAME …)` body (which shadows this when the module is checked or
;; run), whereas an extern has no body anywhere and the runtime dispatches it.
;; The `fn` tag distinguishes this from future sig kinds (e.g. `(sig type …)`).
(fn parse_sigdef ((tail (List SExpr))) (Option ExternDef)
  (match tail
    ((Cons (SSym kind) parts)
     (if (sym_eq kind (quote fn)) (parse_externdef parts) None))
    (_ None)))

;; ---- top-level form helpers ----
(fn form_head ((s SExpr)) (Option Symbol)
  (match s
    ((SList (Cons (SSym h) _)) (Some h))
    (_ None)))

(fn form_tail ((s SExpr)) (List SExpr)
  (match s
    ((SList (Cons _ t)) t)
    (_ Nil)))

;; Forms the module loader ignores (consumed elsewhere or proof-level).
(fn skip_form ((h Symbol)) Bool
  (if (sym_eq h (quote type)) True
  (if (sym_eq h (quote claim)) True
  (if (sym_eq h (quote axiom)) True
  (if (sym_eq h (quote requirement)) True
  (if (sym_eq h (quote fulfills)) True
  (if (sym_eq h (quote bin)) True
  (if (sym_eq h (quote import)) True
  (if (sym_eq h (quote use-module)) True
  (if (sym_eq h (quote use)) True  ; scope directive (Stage 2.5b) — handled by use_scope_of
  (if (sym_eq h (quote app)) True
  (if (sym_eq h (quote cli)) True
  (if (sym_eq h (quote returns)) True  ; refined-return obligation proof (rr_outcome)
  False)))))))))))))

;; Pass 1: collect all (type …) definitions, in source order.
;; `(sig type (Map V))` → an ABSTRACT (opaque) type: a TypeDef with the name and
;; params but NO ctors. The name exports (signatures `(Map Int)` parse), but the
;; ctors stay private — a consumer granted this interface cannot construct or
;; pattern-match the type (its `find_typedef` yields no cases; its ctors are
;; absent from `typedef_ctors`). The impl supplies the FULL `(type …)` with
;; ctors for its own bodies. Mirrors `sig fn` (signature here, definition in the
;; impl). Any non-`(sig type …)` form (incl. `sig fn`) → None.
(fn sig_type_of ((f SExpr)) (Option TypeDef)
  (match f
    ((SList (Cons (SSym h) (Cons (SSym kind) (Cons headForm Nil))))
     (if (sym_eq h (quote sig))
       (if (sym_eq kind (quote type))
         (match (parse_head headForm)
           (None None)
           ((Some (Pair name params))
            (Some (TypeDef (qn name) params Nil None))))
         None)
       None))
    (_ None)))

(fn collect_types ((forms (List SExpr))) (Option (List TypeDef))
  (measure (struct forms))
  (match forms
    (Nil (Some Nil))
    ((Cons f rest)
     (match (form_head f)
       (None None)
       ((Some hname)
        (if (sym_eq hname (quote type))
          (match (parse_typedef (form_tail f))
            (None None)
            ((Some td)
             (match (collect_types rest)
               (None None)
               ((Some tds) (Some (Cons td tds))))))
          (match (sig_type_of f)
            ((Some td)  ; (sig type …) → abstract type
             (match (collect_types rest)
               (None None)
               ((Some tds) (Some (Cons td tds)))))
            (None (collect_types rest)))))))))  ; other forms → not a type here

(fn typedef_ctors ((tds (List TypeDef))) (List Symbol)
  (measure (struct tds))
  (match tds
    (Nil Nil)
    ((Cons (TypeDef _ _ cds _) rest)
     (append_sym (ctordef_names cds) (typedef_ctors rest)))))

;; The TYPE names a module declares — the proof-DSL reader uses these to tell a
;; concrete 0-ary type constructor (in `type_names`) from a goal type variable.
(fn typedef_names ((tds (List TypeDef))) (List Symbol)
  (measure (struct tds))
  (match tds
    (Nil Nil)
    ((Cons (TypeDef n _ _ _) rest) (Cons (qn_name n) (typedef_names rest)))))

(fn ctordef_names ((cds (List CtorDef))) (List Symbol)
  (measure (struct cds))
  (match cds
    (Nil Nil)
    ((Cons (CtorDef n _) rest) (Cons (qn_name n) (ctordef_names rest)))))

;; Pass 2: fns and externs, in source order, using the full ctor set.
(fn collect_fns_externs ((forms (List SExpr)) (ctors (List Symbol)))
  (Option (Pair (List FnDef) (List ExternDef)))
  (measure (struct forms))
  (match forms
    (Nil (Some (Pair Nil Nil)))
    ((Cons f rest)
     (match (form_head f)
       (None None)
       ((Some hname)
        (if (sym_eq hname (quote fn))
          (match (parse_fndef (form_tail f) ctors)
            (None None)
            ((Some fd)
             (match (collect_fns_externs rest ctors)
               (None None)
               ((Some (Pair fns externs)) (Some (Pair (Cons fd fns) externs))))))
        (if (sym_eq hname (quote extern))
          (match (parse_externdef (form_tail f))
            (None None)
            ((Some ed)
             (match (collect_fns_externs rest ctors)
               (None None)
               ((Some (Pair fns externs)) (Some (Pair fns (Cons ed externs)))))))
        (if (sym_eq hname (quote sig))  ; (sig fn …) → bodyless signature
          (match (sig_type_of f)
            ((Some _) (collect_fns_externs rest ctors))  ; (sig type …) → a TYPE (pass 1); skip here
            (None
              (match (parse_sigdef (form_tail f))
                (None None)
                ((Some ed)
                 (match (collect_fns_externs rest ctors)
                   (None None)
                   ((Some (Pair fns externs))
                    (Some (Pair fns (Cons ed externs)))))))))
        (if (skip_form hname) (collect_fns_externs rest ctors)
        None)))))))))  ; unknown form → reject (cf. load.rs)

;; ---- module entry point ---------------------------------------------------
(fn parse_module ((src (List Int)) (base_ctors (List Symbol))) (Option Module)
  (match (read_all src)
    (None None)
    ((Some forms)
     (match (collect_types forms)
       (None None)
       ((Some tds)
        (match
          (collect_fns_externs
            forms
            (append_sym (typedef_ctors tds) base_ctors))
          (None None)
          ((Some (Pair fns externs))
           (Some (Module tds fns externs (build_fn_trie fns) Nil)))))))))

;; ---- whole-program module assembly ----------------------------------------
;; Build M (the module proofs reduce against) by folding `parse_module` over a
;; list of sources in DEPENDENCY ORDER (a file's imports come before it),
;; threading the accumulating ctor set so each file's fn bodies resolve ctors
;; declared in its dependencies, and concatenating the decls onto `acc` (which
;; the caller seeds with the kernel's own types). Mirrors the Rust loader's
;; merge_module + dependency-order base — but parsed entirely by this reader.

(fn app_typedefs ((a (List TypeDef)) (b (List TypeDef))) (List TypeDef)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (app_typedefs t b)))))
(fn app_fndefs ((a (List FnDef)) (b (List FnDef))) (List FnDef)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (app_fndefs t b)))))
(fn app_externdefs ((a (List ExternDef)) (b (List ExternDef))) (List ExternDef)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (app_externdefs t b)))))

(fn merge_modules ((a Module) (b Module)) Module
  (match a
    ((Module at af ax atr _)
     (match b
       ((Module bt bf bx _ _)
        ;; insert b's fns into a's trie (O(|bf|), no full rebuild); af keeps
        ;; priority on a name clash, matching app_fndefs af bf + keep-first.
        (Module
          (app_typedefs at bt)
          (app_fndefs af bf)
          (app_externdefs ax bx)
          (trie_insert_many bf atr)
          (app_env (module_claims a) (module_claims b))))))))

(fn module_typedefs ((m Module)) (List TypeDef)
  (match m
    ((Module tds _ _ _ _) tds)))

(fn module_claims ((m Module)) (List (Pair Symbol (List Symbol)))
  (match m
    ((Module _ _ _ _ cs) cs)))

(fn module_with_claims ((m Module) (cs (List (Pair Symbol (List Symbol)))))
  Module
  (match m
    ((Module tds fns exts trie _) (Module tds fns exts trie cs))))

;; claim/requirement/axiom names of a file's raw forms — Stage 4: claims are
;; module ITEMS, resolvable via use/glob-use exactly like fns and types.
;; (fulfills is NOT an item: its identity is the interface requirement's.)
(fn claim_items_go ((fs (List SExpr)) (mp (List Symbol)))
  (List (Pair Symbol (List Symbol)))
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((SList (Cons (SSym h) (Cons (SSym nm) _)))
        (if
          (if (sym_eq h (quote claim)) True
          (if (sym_eq h (quote requirement)) True
          (sym_eq h (quote axiom))))
          (Cons (Pair nm mp) (claim_items_go rest mp))
          (claim_items_go rest mp)))
       (_ (claim_items_go rest mp))))))

(fn module_externdefs ((m Module)) (List ExternDef)
  (match m
    ((Module _ _ exts _ _) exts)))

(fn build_module ((srcs (List (List Int))) (acc Module) (ctors (List Symbol)))
  (Option Module)
  (measure (struct srcs))
  (match srcs
    (Nil (Some acc))
    ((Cons src rest)
     (match (parse_module src ctors)
       (None None)
       ((Some m)
        (build_module
          rest
          (merge_modules acc m)
          (append_sym (typedef_ctors (module_typedefs m)) ctors)))))))

;; A resolved source: its PATH (for module-path derivation), the `granted` tag
;; (a dependency interface, whose requirements are admitted as axioms), and the
;; source bytes. Replaces the old `(Pair granted src)` so identity survives from
;; the loader to the resolver. Defined HERE (not in loader.shard, which uses it)
;; so the self-hosted reader — which accumulates ctors in dependency order —
;; sees it before parsing loader/driver and reader's own build_module_d.
(type SrcEntry (SrcEntry (List Int) Bool (List Int)))

;; ===========================================================================
;; QUALIFIED-IDENTITY RESOLUTION (Stage 2).
;;
;; `parse_module` tags every identity `core` (via `qn`). This pass rewrites each
;; module's QName heads — definitions AND references — with their real
;; module-path, by RESOLUTION precedence `local > import > core`:
;;   - a name DEFINED in this module  → this module's path
;;   - a name exported by an IMPORT   → that import's path (read off its tag in
;;                                       the accumulated module `acc`)
;;   - anything else (a primitive, a  → `core`
;;     prelude ctor, an unbound name)
;; Resolution is a pure function of (name, locals, imports), independent of term
;; position, so a single uniform tree-walk over a parsed (all-`core`) module is
;; exactly equivalent to resolving at elaboration time. Definitions and local
;; references share one env (locals mapped to this module's path), so they
;; always agree. The Theory/citation namespace is NOT touched here — qualified
;; citations are Stage 4; lemma/claim names still key at `core`.
;; ===========================================================================

;; The resolution CONTEXT threaded through every resolve_* walker: the module
;; being resolved (`curmod`, for self/super/crate re-rooting — Stage 2.5) plus
;; the name→module-path env (locals ++ imports). rhead is the only consumer that
;; inspects either; the walkers just pass it through.
;; curmod, item env (bare-name → module-path), and the use-bound module-alias
;; env (alias → module-path, consumed by resolve_qpath's leading segment).
(type RCtx
  (RCtx
    (List Symbol)
    (List (Pair Symbol (List Symbol)))
    (List (Pair Symbol (List Symbol)))))
(fn rc_mod ((c RCtx)) (List Symbol)
  (match c
    ((RCtx m _ _) m)))
(fn rc_env ((c RCtx)) (List (Pair Symbol (List Symbol)))
  (match c
    ((RCtx _ e _) e)))
(fn rc_aliases ((c RCtx)) (List (Pair Symbol (List Symbol)))
  (match c
    ((RCtx _ _ a) a)))

;; name -> module-path env (assoc list, first match wins → local precedence).
(fn env_lookup ((name Symbol) (tbl (List (Pair Symbol (List Symbol)))))
  (List Symbol)
  (measure (struct tbl))
  (match tbl
    (Nil (qn_core))  ; unresolved → a builtin/prim/prelude name: core
    ((Cons (Pair n p) rest) (if (sym_eq name n) p (env_lookup name rest)))))

;; re-qualify a parsed head. A BARE name carries the `core` placeholder → resolve
;; it by env lookup (local > import > core). A `(:: …)` head carries an explicit
;; raw path → re-root it against the current module (resolve_qpath); env lookup
;; is bypassed, so an explicit path is the unambiguous escape hatch.
(fn rhead ((q QName) (env RCtx)) QName
  (if (sym_path_eq (qn_mod q) (qn_core))
    (qn_at (env_lookup (qn_name q) (rc_env env)) (qn_name q))
    (resolve_qpath (qn_mod q) (qn_name q) (rc_mod env) (rc_aliases env))))

(fn app_env
  ((a (List (Pair Symbol (List Symbol))))
   (b (List (Pair Symbol (List Symbol)))))
  (List (Pair Symbol (List Symbol)))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (app_env t b)))))

;; --- the import env: every name an accumulated module exports → its path -----
(fn fndef_names ((fds (List FnDef))) (List Symbol)
  (measure (struct fds))
  (match fds
    (Nil Nil)
    ((Cons (FnDef n _ _ _) r) (Cons (qn_name n) (fndef_names r)))))

(fn externdef_names ((es (List ExternDef))) (List Symbol)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons (ExternDef n _ _) r) (Cons (qn_name n) (externdef_names r)))))

(fn td_env ((tds (List TypeDef))) (List (Pair Symbol (List Symbol)))
  (measure (struct tds))
  (match tds
    (Nil Nil)
    ((Cons (TypeDef n _ cds _) r)
     (Cons (Pair (qn_name n) (qn_mod n)) (app_env (cd_env cds) (td_env r))))))

(fn cd_env ((cds (List CtorDef))) (List (Pair Symbol (List Symbol)))
  (measure (struct cds))
  (match cds
    (Nil Nil)
    ((Cons (CtorDef n _) r) (Cons (Pair (qn_name n) (qn_mod n)) (cd_env r)))))

(fn fn_env ((fns (List FnDef))) (List (Pair Symbol (List Symbol)))
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons (FnDef n _ _ _) r) (Cons (Pair (qn_name n) (qn_mod n)) (fn_env r)))))

(fn ext_env ((es (List ExternDef))) (List (Pair Symbol (List Symbol)))
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons (ExternDef n _ _) r)
     (Cons (Pair (qn_name n) (qn_mod n)) (ext_env r)))))

(fn module_resolve_env ((m Module)) (List (Pair Symbol (List Symbol)))
  (match m
    ((Module tds fns exts _ cs)
     (app_env (td_env tds) (app_env (fn_env fns) (app_env (ext_env exts) cs))))))

;; Keep only the entries whose module-path is `p` — used to recover ONE file's
;; local env from the merged module (defs at `p`), for strict goal resolution
;; (Stage 2.5c): the merged `m` has every module's defs, so filtering by the
;; file's curmod yields exactly that file's own locals (no re-parse needed).
(fn filter_modpath ((env (List (Pair Symbol (List Symbol)))) (p (List Symbol)))
  (List (Pair Symbol (List Symbol)))
  (measure (struct env))
  (match env
    (Nil Nil)
    ((Cons (Pair n mp) rest)
     (if (sym_path_eq mp p) (Cons (Pair n mp) (filter_modpath rest p))
     (filter_modpath rest p)))))

;; --- the local env: every name THIS module defines → this module's path -----
(fn names_to_env ((ns (List Symbol)) (path (List Symbol)))
  (List (Pair Symbol (List Symbol)))
  (measure (struct ns))
  (match ns
    (Nil Nil)
    ((Cons n r) (Cons (Pair n path) (names_to_env r path)))))

(fn local_env ((m Module) (modpath (List Symbol)))
  (List (Pair Symbol (List Symbol)))
  (match m
    ((Module tds fns exts _ _)
     (names_to_env
       (append_sym
         (typedef_names tds)
         (append_sym
           (typedef_ctors tds)
           (append_sym (fndef_names fns) (externdef_names exts))))
       modpath))))

;; --- the tree-walk rewriters ------------------------------------------------
(fn resolve_type ((env RCtx) (t Type)) Type
  (measure (struct t))
  (match t
    ((TVar _) t)
    ((TCon c args) (TCon (rhead c env) (resolve_type_list env args)))))

(fn resolve_type_list ((env RCtx) (ts (List Type))) (List Type)
  (measure (struct ts))
  (match ts
    (Nil Nil)
    ((Cons h t) (Cons (resolve_type env h) (resolve_type_list env t)))))

(fn resolve_expr ((env RCtx) (e Expr)) Expr
  (measure (struct e))
  (match e
    ((FVar _) e)
    ((BVar _) e)
    ((Ctor c args) (Ctor (rhead c env) (resolve_expr_list env args)))
    ((Call f args) (Call (rhead f env) (resolve_expr_list env args)))
    ((Match s arms) (Match (resolve_expr env s) (resolve_arms_rc env arms)))
    ((Let bs body) (Let (resolve_expr_list env bs) (resolve_expr env body)))
    ((If c th el)
     (If (resolve_expr env c) (resolve_expr env th) (resolve_expr env el)))
    ((IntLit _) e)
    ((SymLit _) e)))

(fn resolve_expr_list ((env RCtx) (es (List Expr))) (List Expr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons h t) (Cons (resolve_expr env h) (resolve_expr_list env t)))))

(fn resolve_arms_rc ((env RCtx) (arms (List Arm))) (List Arm)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p body) r)
     (Cons
       (Arm (resolve_pat env p) (resolve_expr env body))
       (resolve_arms_rc env r)))))

(fn resolve_pat ((env RCtx) (p Pat)) Pat
  (measure (struct p))
  (match p
    ((PVar) p)
    ((PCtor c ps) (PCtor (rhead c env) (resolve_pat_list env ps)))
    ((PInt _) p)
    ((PSym _) p)))

(fn resolve_pat_list ((env RCtx) (ps (List Pat))) (List Pat)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons h t) (Cons (resolve_pat env h) (resolve_pat_list env t)))))

(fn resolve_ctordef ((env RCtx) (cd CtorDef)) CtorDef
  (match cd
    ((CtorDef n fts) (CtorDef (rhead n env) (resolve_type_list env fts)))))

(fn resolve_ctordefs ((env RCtx) (cds (List CtorDef))) (List CtorDef)
  (measure (struct cds))
  (match cds
    (Nil Nil)
    ((Cons h t) (Cons (resolve_ctordef env h) (resolve_ctordefs env t)))))

;; resolve the refinement's base type heads + predicate name via the same env
;; that resolves ctor field types and the typedef name. See docs/REFINEMENT.md.
(fn resolve_refine ((env RCtx) (r (Option (Pair Type QName))))
  (Option (Pair Type QName))
  (match r
    (None None)
    ((Some (Pair base pred))
     (Some (Pair (resolve_type env base) (rhead pred env))))))

(fn resolve_typedef ((env RCtx) (td TypeDef)) TypeDef
  (match td
    ((TypeDef n ps cds r)
     (TypeDef
       (rhead n env)
       ps
       (resolve_ctordefs env cds)
       (resolve_refine env r)))))

(fn resolve_typedefs ((env RCtx) (tds (List TypeDef))) (List TypeDef)
  (measure (struct tds))
  (match tds
    (Nil Nil)
    ((Cons h t) (Cons (resolve_typedef env h) (resolve_typedefs env t)))))

(fn resolve_fndef ((env RCtx) (fd FnDef)) FnDef
  (match fd
    ((FnDef n pts ret body)
     (FnDef
       (rhead n env)
       (resolve_type_list env pts)
       (resolve_type env ret)
       (resolve_expr env body)))))

(fn resolve_fndefs ((env RCtx) (fds (List FnDef))) (List FnDef)
  (measure (struct fds))
  (match fds
    (Nil Nil)
    ((Cons h t) (Cons (resolve_fndef env h) (resolve_fndefs env t)))))

(fn resolve_externdef ((env RCtx) (ed ExternDef)) ExternDef
  (match ed
    ((ExternDef n pts ret)
     (ExternDef
       (rhead n env)
       (resolve_type_list env pts)
       (resolve_type env ret)))))

(fn resolve_externdefs ((env RCtx) (es (List ExternDef))) (List ExternDef)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons h t) (Cons (resolve_externdef env h) (resolve_externdefs env t)))))

;; ---- sig→def rebinding (one function, one qname) ---------------------------
;; A `(sig fn …)` in a module interface and the impl's `(fn NAME …)` body are
;; ONE function: the sig declares it, the def supplies it (the C header/.c
;; discipline). Under qualified identity they would otherwise get two QNames
;; (the interface file's path and the impl file's), splitting the function in
;; two: obligations and consumers reference the sig's qname, the body and the
;; impl's own calls the def's. The rebind: when a file DEFINES a fn whose name
;; its `use` items map to a path holding a loaded sig, AND that path is within
;; the file's own directory module, the local binding is DROPPED — the def's
;; name and every bare reference in the file then resolve THROUGH the use item
;; to the sig's qname. Explicit `use` + same-directory keeps this intentional:
;; a file can never graft a body onto another module's interface (surface
;; discipline), and a private helper never rebinds without a use line.
(fn path_prefix_sym ((a (List Symbol)) (b (List Symbol))) Bool
  (measure (struct a))
  (match a
    (Nil True)
    ((Cons x xs)
     (match b
       (Nil False)
       ((Cons y ys) (if (sym_eq x y) (path_prefix_sym xs ys) False))))))

(fn path_init_sym ((p (List Symbol))) (List Symbol)
  (measure (struct p))
  (match p
    (Nil Nil)
    ((Cons _ Nil) Nil)
    ((Cons h t) (Cons h (path_init_sym t)))))

;; P (the sig's module) is within the dir module of MODPATH (the def's file):
;; P is the directory interface (a prefix — the mod.req case) or a sibling
;; file of the same directory.
(fn supplies_scope_ok ((p (List Symbol)) (modpath (List Symbol))) Bool
  (if (path_prefix_sym p modpath) True
  (sym_path_eq (path_init_sym p) (path_init_sym modpath))))

(fn uitem_path ((n Symbol) (items (List (Pair Symbol (List Symbol)))))
  (Option (List Symbol))
  (measure (struct items))
  (match items
    (Nil None)
    ((Cons (Pair in p) rest) (if (sym_eq n in) (Some p) (uitem_path n rest)))))

(fn sig_at ((n Symbol) (p (List Symbol)) (exts (List ExternDef))) Bool
  (measure (struct exts))
  (match exts
    (Nil False)
    ((Cons (ExternDef q _ _) rest)
     (if (sym_eq (qn_name q) n)
       (if (sym_path_eq (qn_mod q) p) True (sig_at n p rest))
       (sig_at n p rest)))))

;; the fn-def names of this file that SUPPLY a previously-loaded sig.
(fn rebind_names
  ((fnames (List Symbol))
   (uitems (List (Pair Symbol (List Symbol))))
   (sig_exts (List ExternDef))
   (modpath (List Symbol)))
  (List Symbol)
  (measure (struct fnames))
  (match fnames
    (Nil Nil)
    ((Cons n rest)
     (match (uitem_path n uitems)
       (None (rebind_names rest uitems sig_exts modpath))
       ((Some p)
        (if (sig_at n p sig_exts)
          (if (supplies_scope_ok p modpath)
            (Cons n (rebind_names rest uitems sig_exts modpath))
            (rebind_names rest uitems sig_exts modpath))
          (rebind_names rest uitems sig_exts modpath)))))))

;; a SIG TYPE (ctorless typedef — the `(sig type …)` form) named n at path p.
(fn sig_type_at ((n Symbol) (p (List Symbol)) (tds (List TypeDef))) Bool
  (measure (struct tds))
  (match tds
    (Nil False)
    ((Cons (TypeDef q _ cds _) rest)
     (if (sym_eq (qn_name q) n)
       (if (sym_path_eq (qn_mod q) p)
         (match cds
           (Nil True)
           (_ (sig_type_at n p rest)))
         (sig_type_at n p rest))
       (sig_type_at n p rest)))))

;; the TYPE names of this file that SUPPLY a previously-loaded sig type —
;; the type-level mirror of rebind_names: when a use-item maps a local full
;; `(type …)`'s name to a same-dir-module `(sig type …)`, the local binding
;; is dropped so the name (and every annotation in this file) resolves to
;; the INTERFACE's qname. Sig type + full type = ONE TCon identity; without
;; this, an interface obligation (binders at the sig type) can never
;; type-check against rebound defs (params at the local type). The ctors
;; stay locally-qualified (privacy is unchanged — consumers granted the
;; interface still get only the ctorless typedef).
(fn rebind_type_names
  ((tnames (List Symbol))
   (uitems (List (Pair Symbol (List Symbol))))
   (sig_tds (List TypeDef))
   (modpath (List Symbol)))
  (List Symbol)
  (measure (struct tnames))
  (match tnames
    (Nil Nil)
    ((Cons n rest)
     (match (uitem_path n uitems)
       (None (rebind_type_names rest uitems sig_tds modpath))
       ((Some p)
        (if (sig_type_at n p sig_tds)
          (if (supplies_scope_ok p modpath)
            (Cons n (rebind_type_names rest uitems sig_tds modpath))
            (rebind_type_names rest uitems sig_tds modpath))
          (rebind_type_names rest uitems sig_tds modpath)))))))

(fn sym_in_list ((n Symbol) (ns (List Symbol))) Bool
  (measure (struct ns))
  (match ns
    (Nil False)
    ((Cons h t) (if (sym_eq n h) True (sym_in_list n t)))))

(fn env_drop_names ((env (List (Pair Symbol (List Symbol)))) (ns (List Symbol)))
  (List (Pair Symbol (List Symbol)))
  (measure (struct env))
  (match env
    (Nil Nil)
    ((Cons (Pair n p) rest)
     (if (sym_in_list n ns) (env_drop_names rest ns)
     (Cons (Pair n p) (env_drop_names rest ns))))))

;; Qualify a freshly-parsed (all-`core`) module at `modpath`. STRICT bare-name
;; resolution (Stage 2.5c): local defs > the module's `use` items > core (the
;; env_lookup default — prims + the `core` prelude). The Stage-2 flat glob is
;; GONE: a cross-module name must be `use`d or written as a `(:: …)` path. (Fn
;; references still dispatch by local name in the trie, so a missing `use` on a
;; fn is silently tolerated until Stage 3; types/ctors fail loudly here.)
;; `use_aliases` are the use-bound module aliases, consumed by resolve_qpath for
;; `(:: alias …)` references. The fn-trie is rebuilt from the resolved fns.
;; `sig_exts` (the already-loaded externs/sigs) drive the sig→def rebind above;
;; `sig_tds` (the already-loaded typedefs) drive the type-level rebind.
(fn resolve_module
  ((modpath (List Symbol))
   (use_items (List (Pair Symbol (List Symbol))))
   (use_aliases (List (Pair Symbol (List Symbol))))
   (sig_exts (List ExternDef))
   (sig_tds (List TypeDef))
   (m Module))
  Module
  (match m
    ((Module tds fns exts _ _)
     (let
       ((rb
          (append_sym
            (rebind_names (fndef_names fns) use_items sig_exts modpath)
            (rebind_type_names (typedef_names tds) use_items sig_tds modpath))))
       (let
         ((env
            (RCtx
              modpath
              (app_env (env_drop_names (local_env m modpath) rb) use_items)
              use_aliases)))
         (let ((rfns (resolve_fndefs env fns)))
           (Module
             (resolve_typedefs env tds)
             rfns
             (resolve_externdefs env exts)
             (build_fn_trie rfns)
             Nil)))))))  ; claims attached by build_module_d (module_with_claims)

;; ===========================================================================
;; Decl head detectors: classify a top-level form by its head symbol. The
;; bodies are parsed straight to native by the driver (proof_reader); these
;; only pick which decl kind a form is.
;; ===========================================================================

(fn is_claim_form ((f SExpr)) Bool
  (match f
    ((SList (Cons (SSym h) _)) (sym_eq h (quote claim)))
    (_ False)))

(fn is_axiom_form ((f SExpr)) Bool
  (match f
    ((SList (Cons (SSym h) _)) (sym_eq h (quote axiom)))
    (_ False)))

(fn is_requirement_form ((f SExpr)) Bool
  (match f
    ((SList (Cons (SSym h) _)) (sym_eq h (quote requirement)))
    (_ False)))

(fn is_fulfills_form ((f SExpr)) Bool
  (match f
    ((SList (Cons (SSym h) _)) (sym_eq h (quote fulfills)))
    (_ False)))

(fn is_bin_form ((f SExpr)) Bool
  (match f
    ((SList (Cons (SSym h) _)) (sym_eq h (quote bin)))
    (_ False)))

;; ===========================================================================
;; Unified declaration stream: claims and axioms in SOURCE ORDER. The
;; production driver processes a file's forms in order (axioms admitted,
;; claims checked, theory threaded), so it needs them interleaved as written
;; rather than the two separate filtered lists above.
;; ===========================================================================

;; ---- proof-DSL claims ------------------------------------------------------
;; We keep a claim's RAW goal/proof s-expressions and let the driver parse them
;; straight to native Goal/Proof via proof_reader.shard (it needs the module's
;; ctor + type-name sets, which the driver has and this collector does not) —
;; the proof language parsed as its own language, not through the object reader.
(type Claim (Claim Symbol SExpr SExpr))  ; name, goal-sexpr, proof-sexpr

(fn claim_name ((c Claim)) Symbol
  (match c
    ((Claim n g p) n)))
(fn claim_goal ((c Claim)) SExpr
  (match c
    ((Claim n g p) g)))
(fn claim_proof ((c Claim)) SExpr
  (match c
    ((Claim n g p) p)))

;; (claim NAME GOAL PROOF) → Claim, keeping GOAL/PROOF as raw s-exprs.
(fn claim_of_form ((f SExpr)) (Option Claim)
  (match f
    ((SList (Cons _ (Cons (SSym name) (Cons goalS (Cons proofS Nil)))))
     (Some (Claim name goalS proofS)))
    (_ None)))

;; ---- axiom / requirement (goal-only decls) --------------------------------
;; An axiom carries a trust-ledger KIND alongside its goal:
;;   'operational | 'bridging — author-tagged via (axiom NAME (kind K) (goal …))
;;   'untagged                — own axiom with no (kind …) clause yet
;;   'granted                 — a granted interface's requirement (upstream-PROVEN)
;;   'upstream                — a granted interface's axiom (upstream-TRUSTED)
;; The last two are set by collect_decls, never written in surface syntax.
(type Ax (Ax Symbol Symbol SExpr))  ; axiom decl: name, kind, goal-sexpr
(fn ax_name ((a Ax)) Symbol
  (match a
    ((Ax n k g) n)))
(fn ax_kind ((a Ax)) Symbol
  (match a
    ((Ax n k g) k)))
(fn ax_goal ((a Ax)) SExpr
  (match a
    ((Ax n k g) g)))

;; the author-taggable kinds (ledger-internal kinds are not surface syntax).
(fn ax_kind_ok ((k Symbol)) Bool
  (if (sym_eq k (quote operational)) True (sym_eq k (quote bridging))))

;; (axiom NAME GOAL) | (axiom NAME (kind operational|bridging) GOAL) → Ax.
;; An unrecognized kind clause is a MALFORMED decl (hard stream failure).
(fn ax_of_form ((f SExpr)) (Option Ax)
  (match f
    ((SList (Cons _ (Cons (SSym name) (Cons goalS Nil))))
     (Some (Ax name (quote untagged) goalS)))
    ((SList
       (Cons
         _
         (Cons
           (SSym name)
           (Cons (SList (Cons (SSym kw) (Cons (SSym k) Nil))) (Cons goalS Nil)))))
     (if (sym_eq kw (quote kind))
       (if (ax_kind_ok k) (Some (Ax name k goalS)) None)
       None))
    (_ None)))

;; re-kind a granted source's axiom: whatever the upstream author tagged, the
;; CONSUMER inherits it as an upstream trust (the upstream module's TCB).
(fn ax_as_upstream ((a Ax)) Ax
  (match a
    ((Ax n _ g) (Ax n (quote upstream) g))))

(type Req (Req Symbol SExpr))  ; requirement decl: name, goal-sexpr
(fn req_name ((r Req)) Symbol
  (match r
    ((Req n g) n)))
(fn req_goal ((r Req)) SExpr
  (match r
    ((Req n g) g)))

;; (HEAD NAME GOAL) → (Some (Pair NAME GOAL)); shared by axiom + requirement.
(fn goalonly_of_form ((f SExpr)) (Option (Pair Symbol SExpr))
  (match f
    ((SList (Cons _ (Cons (SSym name) (Cons goalS Nil))))
     (Some (Pair name goalS)))
    (_ None)))

;; ---- fulfills (proof-only decl) -------------------------------------------
(type Ful (Ful Symbol SExpr))  ; fulfills decl: name, proof-sexpr
(fn ful_name ((fu Ful)) Symbol
  (match fu
    ((Ful n p) n)))
(fn ful_proof ((fu Ful)) SExpr
  (match fu
    ((Ful n p) p)))

(fn ful_of_form ((f SExpr)) (Option Ful)
  (match f
    ((SList (Cons _ (Cons (SSym name) (Cons proofS Nil))))
     (Some (Ful name proofS)))
    (_ None)))

;; ---- bin (executable-artifact decl) ---------------------------------------
;; (bin NAME (entry E) (externs …) (trusts …) (requires …)) groups a binary's
;; acceptance contract: the entry fn, the permitted I/O boundary, the trusted
;; bolt axioms, and the requirement names it must discharge. The driver reports
;; each required name MET/UNMET against the final theory — so a pending
;; obligation is surfaced (and fails the run), not silently dropped.
(type Bin (Bin Symbol Symbol (List Symbol) (List Symbol) (List Symbol)))
; name, entry, externs, trusts, requires
(fn bin_name ((b Bin)) Symbol
  (match b
    ((Bin n e x t r) n)))
(fn bin_requires ((b Bin)) (List Symbol)
  (match b
    ((Bin n e x t r) r)))

;; bare symbols out of an sexpr arg list (non-symbols skipped).
(fn syms_of_sexprs ((xs (List SExpr))) (List Symbol)
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons (SSym s) rest) (Cons s (syms_of_sexprs rest)))
    ((Cons _ rest) (syms_of_sexprs rest))))

(fn head_sym_or ((d Symbol) (xs (List Symbol))) Symbol
  (match xs
    (Nil d)
    ((Cons h _) h)))

;; the args of the clause (KEY arg …) among a bin's clauses (Nil if absent).
(fn bin_clause ((key Symbol) (clauses (List SExpr))) (List Symbol)
  (measure (struct clauses))
  (match clauses
    (Nil Nil)
    ((Cons (SList (Cons (SSym h) args)) rest)
     (if (sym_eq h key) (syms_of_sexprs args) (bin_clause key rest)))
    ((Cons _ rest) (bin_clause key rest))))

(fn bin_of_form ((f SExpr)) (Option Bin)
  (match f
    ((SList (Cons (SSym h) (Cons (SSym name) clauses)))
     (Some
       (Bin
         name
         (head_sym_or name (bin_clause (quote entry) clauses))
         (bin_clause (quote externs) clauses)
         (bin_clause (quote trusts) clauses)
         (bin_clause (quote requires) clauses))))
    (_ None)))

(type Decl (DClaim Claim) (DAxiom Ax) (DReq Req) (DFul Ful))

;; `granted`: this source is a dependency module's INTERFACE imported by a
;; consumer (a bare-name `(import "mod")` resolved to its mod.req.shard). Its
;; `requirement`s are promises the module already discharges in its OWN check,
;; so for the consumer they are GRANTED — admitted as axioms (citable), not
;; re-imposed as obligations. When `granted` is False (the module's own check,
;; or a plain file) a requirement stays an obligation, fulfilled in-run.
(fn collect_decls ((forms (List SExpr)) (ctors (List Symbol)) (granted Bool))
  (Option (List Decl))
  (measure (struct forms))
  (match forms
    (Nil (Some Nil))
    ((Cons f rest)
     (if (is_claim_form f)
       (match (claim_of_form f)
         (None None)
         ((Some c)
          (match (collect_decls rest ctors granted)
            (None None)
            ((Some ds) (Some (Cons (DClaim c) ds))))))
     (if (is_axiom_form f)
       (match (ax_of_form f)
         (None None)
         ((Some a)
          (match (collect_decls rest ctors granted)
            (None None)
            ((Some ds)
             (if granted (Some (Cons (DAxiom (ax_as_upstream a)) ds))  ; upstream-trusted
             (Some (Cons (DAxiom a) ds)))))))
     (if (is_requirement_form f)
       (match (goalonly_of_form f)
         (None None)
         ((Some (Pair name goalS))
          (match (collect_decls rest ctors granted)
            (None None)
            ((Some ds)
             (if granted
               ;; granted interface → axiom, upstream-PROVEN (kind 'granted)
               (Some (Cons (DAxiom (Ax name (quote granted) goalS)) ds))
               (Some (Cons (DReq (Req name goalS)) ds)))))))
     (if (is_fulfills_form f)
       (match (ful_of_form f)
         (None None)
         ((Some fu)
          (match (collect_decls rest ctors granted)
            (None None)
            ((Some ds) (Some (Cons (DFul fu) ds))))))
       (collect_decls rest ctors granted))))))))

(fn parse_decls ((src (List Int)) (ctors (List Symbol)) (granted Bool))
  (Option (List Decl))
  (match (read_all src)
    (None None)
    ((Some forms) (collect_decls forms ctors granted))))

;; ===========================================================================
;; PARSE-FAILURE DIAGNOSIS (failure path ONLY — costs nothing on success).
;; build_module collapses every reader/decl failure to None; build_module_d
;; re-scans the offending source to say WHERE:
;;   - a lexical line-tracking scan (string- and comment-aware) pinpoints a
;;     stray ')', an unclosed form (with its head, name, start line, and how
;;     many ')' it is missing), or an unterminated string;
;;   - if the source is lexically balanced, a per-form re-parse mirrors the
;;     two collector passes and names the first malformed declaration.
;; The source ordinal (position in the import closure) stands in for the
;; filename until paths are threaded through resolve_closure.
;; ===========================================================================

(fn pd_app ((a (List Int)) (b (List Int))) (List Int)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (pd_app t b)))))

(fn pd_nat ((n Int)) (List Int)
  ;; measure n; recurses on (ediv n 10) (== / on the nonneg line/index domain).
  ;; div-facts names the quotient so farkas closes the descent.
  (measure
    n
    (div-facts n 10 q (by farkas (list 10 9 1 1 0 -10)))
    (div-facts n 10 q (by farkas (list 10 1 -1 0 1 10))))
  (if (lt n 10) (Cons (+ 48 n) Nil)
  (pd_app (pd_nat (ediv n 10)) (Cons (+ 48 (mod n 10)) Nil))))

(type PDiag
  (PDOk)  ; lexically balanced
  (PDStray Int)  ; ')' at top level, at line N
  (PDUnclosed Int (List Int) Int)  ; form at line N (suffix at its '('), missing K ')'
  (PDBadStr Int))  ; unterminated string opened at line N

;; the scan: line-tracking, comment- and string-aware. fline/fsuf remember the
;; current TOP-LEVEL form's start line and the suffix at its '('.
(fn pd_scan
  ((cs (List Int)) (line Int) (depth Int) (fline Int) (fsuf (List Int)))
  PDiag
  (measure (struct cs))
  (match cs
    (Nil (if (int_eq depth 0) PDOk (PDUnclosed fline fsuf depth)))
    ((Cons c rest)
     (if (int_eq c 10) (pd_scan rest (+ line 1) depth fline fsuf)
     (if (int_eq c 59) (pd_scan_comment rest line depth fline fsuf)
     (if (int_eq c 34) (pd_scan_str rest line line depth fline fsuf)
     (if (int_eq c 40)
       (if (int_eq depth 0) (pd_scan rest line 1 line (Cons c rest))
       (pd_scan rest line (+ depth 1) fline fsuf))
     (if (int_eq c 41)
       (if (int_eq depth 0) (PDStray line)
       (pd_scan rest line (- depth 1) fline fsuf))
       (pd_scan rest line depth fline fsuf)))))))))

(fn pd_scan_comment
  ((cs (List Int)) (line Int) (depth Int) (fline Int) (fsuf (List Int)))
  PDiag
  (measure (struct cs))
  (match cs
    (Nil (if (int_eq depth 0) PDOk (PDUnclosed fline fsuf depth)))
    ((Cons c rest)
     (if (int_eq c 10) (pd_scan rest (+ line 1) depth fline fsuf)
     (pd_scan_comment rest line depth fline fsuf)))))

(fn pd_scan_str
  ((cs (List Int))
   (sline Int)
   (line Int)
   (depth Int)
   (fline Int)
   (fsuf (List Int)))
  PDiag
  (measure (struct cs))
  (match cs
    (Nil (PDBadStr sline))
    ((Cons c rest)
     (if (int_eq c 34) (pd_scan rest line depth fline fsuf)
     (if (int_eq c 92)
       (match rest
         (Nil (PDBadStr sline))
         ((Cons e r2) (pd_scan_str r2 sline line depth fline fsuf)))
     (if (int_eq c 10) (pd_scan_str rest sline (+ line 1) depth fline fsuf)
     (pd_scan_str rest sline line depth fline fsuf)))))))

;; "(head name ..." rendered from the suffix captured at a form's '('.
(fn pd_head ((fsuf (List Int))) (List Int)
  (match fsuf
    (Nil "<form>")
    ((Cons c rest)
     (match (take_atom (skip_ws rest))
       ((Pair h r2)
        (match (skip_ws r2)
          (Nil (pd_app "(" (pd_app h " ...)")))
          ((Cons c2 r3)
           (if (int_eq c2 40) (pd_app "(" (pd_app h " ...)"))
           (match (take_atom (Cons c2 r3))
             ((Pair nm _)
              (pd_app "(" (pd_app h (pd_app " " (pd_app nm " ...)"))))))))))))))

;; the types of a file that DO parse — the best-available ctor set for
;; diagnosing fn bodies even when some other declaration is broken.
(fn pd_types_ok ((forms (List SExpr))) (List TypeDef)
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (match (form_head f)
       (None (pd_types_ok rest))
       ((Some h)
        (if (sym_eq h (quote type))
          (match (parse_typedef (form_tail f))
            (None (pd_types_ok rest))
            ((Some td) (Cons td (pd_types_ok rest))))
          (match (sig_type_of f)
            ((Some td) (Cons td (pd_types_ok rest)))
            (None (pd_types_ok rest)))))))))

;; the first form the collectors would reject (mirrors collect_types +
;; collect_fns_externs dispatch, including the unknown-head rejection, AND
;; collect_decls' shape checks for claim/axiom/requirement/fulfills — a
;; malformed decl must be NAMED here, never silently dropped).
(fn pd_bad_decl ((forms (List SExpr)) (ctors (List Symbol))) (Option SExpr)
  (measure (struct forms))
  (match forms
    (Nil None)
    ((Cons f rest)
     (match (form_head f)
       (None (Some f))
       ((Some h)
        (if (sym_eq h (quote type))
          (match (parse_typedef (form_tail f))
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote fn))
          (match (parse_fndef (form_tail f) ctors)
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote extern))
          (match (parse_externdef (form_tail f))
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote sig))
          (match (sig_type_of f)
            ((Some _) (pd_bad_decl rest ctors))
            (None
              (match (parse_sigdef (form_tail f))
                (None (Some f))
                ((Some _) (pd_bad_decl rest ctors)))))
        (if (sym_eq h (quote claim))
          (match (claim_of_form f)
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote axiom))
          (match (ax_of_form f)
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote requirement))
          (match (goalonly_of_form f)
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (sym_eq h (quote fulfills))
          (match (ful_of_form f)
            (None (Some f))
            ((Some _) (pd_bad_decl rest ctors)))
        (if (skip_form h) (pd_bad_decl rest ctors)
        (Some f)))))))))))))))  ; unknown head — the collectors reject it

(fn pd_render_form ((f SExpr)) (List Int)
  (match f
    ((SList (Cons (SSym h) (Cons (SSym nm) _)))
     (pd_app
       "("
       (pd_app (chars_of_sym h) (pd_app " " (pd_app (chars_of_sym nm) " ...)")))))
    ((SList (Cons (SSym h) _)) (pd_app "(" (pd_app (chars_of_sym h) " ...)")))
    (_ "<non-list form>")))

(fn pd_src_tag ((k Int)) (List Int)
  (pd_app " [source " (pd_app (pd_nat k) " of the import closure]")))

(fn parse_diag ((src (List Int)) (base_ctors (List Symbol)) (k Int)) (List Int)
  (match (pd_scan src 1 0 0 Nil)
    ((PDStray line)
     (pd_app "unexpected ')' at line " (pd_app (pd_nat line) (pd_src_tag k))))
    ((PDUnclosed fline fsuf missing)
     (pd_app
       "unclosed form "
       (pd_app
         (pd_head fsuf)
         (pd_app
           " at line "
           (pd_app
             (pd_nat fline)
             (pd_app
               " -- missing "
               (pd_app (pd_nat missing) (pd_app " ')'" (pd_src_tag k)))))))))
    ((PDBadStr line)
     (pd_app
       "unterminated string opened at line "
       (pd_app (pd_nat line) (pd_src_tag k))))
    (PDOk
      (match (read_all src)
        (None (pd_app "unreadable source" (pd_src_tag k)))
        ((Some forms)
         (match
           (pd_bad_decl
             forms
             (append_sym (typedef_ctors (pd_types_ok forms)) base_ctors))
           ((Some f)
            (pd_app
              "malformed declaration "
              (pd_app (pd_render_form f) (pd_src_tag k))))
           (None
             (pd_app "module assembly failed (unknown cause)" (pd_src_tag k)))))))))

;; ===========================================================================
;; USE-DECLARATION SCOPE (Stage 2.5b/c). `use` brings names into THIS module's
;; scope (STRICT resolution: no glob fallback — see resolve_module). Three forms:
;;   (use (:: SEG … NAME))        an ITEM (bare NAME → its module) OR a MODULE
;;                                ALIAS (alias → that module, for `(:: alias …)`)
;;   (use (:: SEG … NAME) as A)   the same, bound under A
;;   (use (:: SEG … *))           GLOB: every item of module SEG… into scope
;; Item-vs-module-alias is decided by resolution: if the path's full tail is a
;; LOADED module identity it's a module alias, else an item. `as` on an item is
;; not yet a rename (needs a name→QName env) — deferred; module `as` works.
;; ===========================================================================

(type UseSpec
  (UseItem QName Symbol)  ; raw (pre-rooting) QName + bound name (NAME or alias)
  (UseGlob (List Symbol)))  ; raw (pre-rooting) module path to glob

;; Is `p` the module-path of some loaded def? (env = name→path of all loaded defs.)
(fn modpath_in_env ((p (List Symbol)) (env (List (Pair Symbol (List Symbol)))))
  Bool
  (measure (struct env))
  (match env
    (Nil False)
    ((Cons (Pair _ mp) r) (if (sym_path_eq p mp) True (modpath_in_env p r)))))

;; Is there a loaded def NAMED n whose module-path is exactly p? Decides the
;; item-vs-module-alias ambiguity in the item's favor: when a module's impl
;; file shares its module's name (foo/foo.shard supplying foo's sig fn foo),
;; the path (:: … foo foo) is BOTH a loaded module identity and an item of
;; the interface — and reading it as an alias silently kills the sig→def
;; rebind. An explicit use names the ITEM whenever one exists; module
;; aliasing is the fallback (and `as`-bound module aliases keep working —
;; an item match there is equally explicit).
(fn item_in_env
  ((n Symbol) (p (List Symbol)) (env (List (Pair Symbol (List Symbol)))))
  Bool
  (measure (struct env))
  (match env
    (Nil False)
    ((Cons (Pair en mp) r)
     (if (sym_eq n en) (if (sym_path_eq p mp) True (item_in_env n p r))
     (item_in_env n p r)))))

;; Classify a `(:: …)` use-path's segments → an item or a glob.
(fn parse_use_path ((segs (List SExpr)) (bound Symbol) (rebound Bool))
  (Option UseSpec)
  (match (seg_syms segs)
    (None None)
    ((Some syms)
     (match (split_last syms)
       (None None)
       ((Some (Pair init last))
        (if (sym_eq last (star_sym)) (if rebound None (Some (UseGlob init)))  ; `* as A` is meaningless
        (match init
          (Nil None)  ; `(:: x)` — no module segment
          (_ (Some (UseItem (QName init last) (if rebound bound last)))))))))))

;; `(use (:: …))` / `(use (:: …) as A)` → a UseSpec. Any other form → None.
(fn parse_use_form ((f SExpr)) (Option UseSpec)
  (match f
    ((SList (Cons (SSym h) tail))
     (if (sym_eq h (quote use))
       (match tail
         ((Cons (SList (Cons (SSym cc) segs)) Nil)
          (if (sym_eq cc (coloncolon_sym)) (parse_use_path segs (quote _) False)
          None))
         ((Cons
            (SList (Cons (SSym cc) segs))
            (Cons (SSym asKw) (Cons (SSym alias) Nil)))
          (if (sym_eq cc (coloncolon_sym))
            (if (sym_eq asKw (quote as)) (parse_use_path segs alias True) None)
            None))
         (_ None))
       None))
    (_ None)))

;; Fold a module's top-level forms into (item-env, alias-env). `curmod` roots
;; relative use-paths; `env` (name→path of all loaded defs) decides module-vs-item
;; and supplies a globbed module's item names. Use-paths do NOT chain through
;; other use-aliases (resolve_* given an empty alias env).
(fn use_scope_of
  ((forms (List SExpr))
   (curmod (List Symbol))
   (env (List (Pair Symbol (List Symbol)))))
  (Pair (List (Pair Symbol (List Symbol))) (List (Pair Symbol (List Symbol))))
  (measure (struct forms))
  (match forms
    (Nil (Pair Nil Nil))
    ((Cons f rest)
     (match (parse_use_form f)
       (None (use_scope_of rest curmod env))
       ((Some (UseGlob segs))
        (let ((globmod (resolve_full_modpath segs curmod Nil)))
          (match (use_scope_of rest curmod env)
            ((Pair items aliases)
             (Pair (app_env (filter_modpath env globmod) items) aliases)))))
       ((Some (UseItem rawq bound))
        (let
          ((resolved (resolve_qpath (qn_mod rawq) (qn_name rawq) curmod Nil)))
          (let
            ((modid
               (append_sym (qn_mod resolved) (Cons (qn_name resolved) Nil))))
            (match (use_scope_of rest curmod env)
              ((Pair items aliases)
               (if (item_in_env (qn_name resolved) (qn_mod resolved) env)
                 (Pair (Cons (Pair bound (qn_mod resolved)) items) aliases)
               (if (modpath_in_env modid env)
                 (Pair items (Cons (Pair bound modid) aliases))
                 (Pair (Cons (Pair bound (qn_mod resolved)) items) aliases))))))))))))

(fn use_forms ((src (List Int))) (List SExpr)
  (match (read_all src)
    (None Nil)
    ((Some forms) forms)))

;; ===========================================================================
;; MODULE-PATH derivation — the loader-assigned, source-unforgeable identity
;; behind every QName module-path (a `(List Symbol)`, mirroring Rust's module
;; tree). A source's path becomes its hierarchical id: strip the file suffix (a
;; `…/mod.req.shard` interface collapses to its module DIRECTORY; a bare
;; `…/x.shard` file keeps its name), split on '/', and canonicalize `.`/`..`
;; so the same file reached by different relative paths gets the SAME id. Used
;; by build_module_d (below) to qualify each definition and reference.
;; ===========================================================================

;; "/mod.req.shard" — appended to a bare module name to reach its interface.
(fn mod_req_suffix () (List Int) "/mod.req.shard")

;; "/mod.req/mod.req.shard" — the DIRECTORY form of a module interface. When a
;; module's req surface outgrows one file, `mod.req.shard` expands Rust-style
;; (foo.rs ⟷ foo/mod.rs) into a `mod.req/` directory whose entry keeps the
;; name; sibling req files (spec vocabulary etc.) live beside it. A bare module
;; import probes this form first and falls back to the flat file (see visit in
;; loader.shard).
(fn mod_req_dir_suffix () (List Int) "/mod.req/mod.req.shard")

(fn strip_prefix ((pre (List Int)) (xs (List Int))) (Option (List Int))
  (measure (struct pre))
  (match pre
    (Nil (Some xs))
    ((Cons p pr)
     (match xs
       (Nil None)
       ((Cons x xr) (if (int_eq p x) (strip_prefix pr xr) None))))))

;; rp is the path REVERSED; drop the interface or .shard suffix, still reversed.
(fn strip_path_suffix ((rp (List Int))) (List Int)
  (match (strip_prefix (rev_i (mod_req_suffix) Nil) rp)
    ((Some d) d)
    (None
      (match (strip_prefix (rev_i ".shard" Nil) rp)
        ((Some f) f)
        (None rp)))))

;; split forward bytes on '/' (47) into segments (cur is the current seg reversed).
(fn path_segs ((xs (List Int)) (cur (List Int))) (List (List Int))
  (measure (struct xs))
  (match xs
    (Nil (Cons (rev_i cur Nil) Nil))
    ((Cons c t)
     (if (int_eq c 47) (Cons (rev_i cur Nil) (path_segs t Nil))
     (path_segs t (Cons c cur))))))

(fn segs_to_syms ((ss (List (List Int)))) (List Symbol)
  (measure (struct ss))
  (match ss
    (Nil Nil)
    ((Cons s rest) (Cons (sym_of_chars s) (segs_to_syms rest)))))

(fn rev_sym ((xs (List Symbol)) (acc (List Symbol))) (List Symbol)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_sym t (Cons h acc)))))

;; the `.` and `..` path segments (built from char 46 — `(quote .)` is not a
;; lexable symbol token).
(fn dot_sym () Symbol (sym_of_chars (Cons 46 Nil)))
(fn dotdot_sym () Symbol (sym_of_chars (Cons 46 (Cons 46 Nil))))

;; canonicalize a segment path: `.` drops, `..` pops the previous segment.
;; acc is newest-first; result is restored to source order.
(fn canon_push ((seg Symbol) (acc (List Symbol))) (List Symbol)
  (if (sym_eq seg (dotdot_sym))
    (match acc
      (Nil acc)
      ((Cons _ t) t))
  (if (sym_eq seg (dot_sym)) acc
  (Cons seg acc))))

(fn canon_go ((ss (List Symbol)) (acc (List Symbol))) (List Symbol)
  (measure (struct ss))
  (match ss
    (Nil (rev_sym acc Nil))
    ((Cons s t) (canon_go t (canon_push s acc)))))

;; Does the path climb ABOVE the invocation root? Module identity
;; (module_path_of) is only meaningful for paths under the repo root:
;; canon_push silently DROPS a `..` that pops past the top, so an escaping
;; path gets a wrong identity — worst case a foreign kernel/stdlib.shard
;; collapsing to core. Walk raw byte segments with a depth counter: empty/`.`
;; keeps it, `..` pops (a pop at depth 0 = escape), anything else pushes.
;; Absolute paths (leading '/') escape by definition. The loader refuses
;; escaping paths in CHECK mode (see visit in loader.shard).
(fn seg_dot ((s (List Int))) Bool
  (match s
    ((Cons c Nil) (int_eq c 46))
    (_ False)))

(fn seg_dotdot ((s (List Int))) Bool
  (match s
    ((Cons a (Cons b Nil)) (if (int_eq a 46) (int_eq b 46) False))
    (_ False)))

(fn segs_escape ((ss (List (List Int))) (depth Int)) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons s rest)
     (match s
       (Nil (segs_escape rest depth))
       (_
         (if (seg_dot s) (segs_escape rest depth)
         (if (seg_dotdot s)
           (if (int_eq depth 0) True (segs_escape rest (- depth 1)))
           (segs_escape rest (+ depth 1)))))))))

(fn path_escapes ((path (List Int))) Bool
  (match path
    (Nil False)
    ((Cons c _) (if (int_eq c 47) True (segs_escape (path_segs path Nil) 0)))))

;; canonicalize PATH BYTES: drop `.` and empty segments, fold `..` against the
;; previous segment. The string-identity companion to module_path_of's
;; symbol-level canon: the loader dedups its closure on canonical bytes, so
;; two relative spellings of one file are ONE visit (a raw-string seen-list
;; would load the file twice and duplicate every decl in it). CHECK mode only
;; — an absolute RUN path would lose its leading '/'. A `..` with nothing to
;; pop is dropped, but the loader refuses escaping paths before canon ever
;; sees one (path_escapes above).
(fn rev_segs ((ss (List (List Int))) (acc (List (List Int)))) (List (List Int))
  (measure (struct ss))
  (match ss
    (Nil acc)
    ((Cons h t) (rev_segs t (Cons h acc)))))

(fn canon_segs ((ss (List (List Int))) (acc (List (List Int))))
  (List (List Int))
  (measure (struct ss))
  (match ss
    (Nil (rev_segs acc Nil))
    ((Cons s rest)
     (match s
       (Nil (canon_segs rest acc))
       (_
         (if (seg_dot s) (canon_segs rest acc)
         (if (seg_dotdot s)
           (match acc
             (Nil (canon_segs rest acc))
             ((Cons _ t) (canon_segs rest t)))
           (canon_segs rest (Cons s acc)))))))))

(fn join_segs ((ss (List (List Int)))) (List Int)
  (measure (struct ss))
  (match ss
    (Nil Nil)
    ((Cons s Nil) s)
    ((Cons s rest) (append_int s (Cons 47 (join_segs rest))))))

(fn canon_path_bytes ((path (List Int))) (List Int)
  (join_segs (canon_segs (path_segs path Nil) Nil)))

;; ---------------------------------------------------------------------------
;; REQUIREMENT SCOPE. A file is REQ-SCOPE iff it is a `mod.req.shard` or lives
;; under a `mod.req/` directory — the module's interface surface, structurally.
;; The loader forbids a req-scope file from importing an implementation file
;; (see visit in loader.shard): the interface may reach only req-scope files,
;; bare module interfaces, and core stdlib. Classified on CANONICAL segments so
;; a `../` detour cannot dodge the gate.
(fn mod_req_dir_sym () Symbol (sym_of_chars "mod.req"))
(fn mod_req_file_sym () Symbol (sym_of_chars "mod.req.shard"))

(fn segs_req_scope ((ss (List Symbol))) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons s Nil) (sym_eq s (mod_req_file_sym)))
    ((Cons s rest) (if (sym_eq s (mod_req_dir_sym)) True (segs_req_scope rest)))))

(fn is_req_path ((path (List Int))) Bool
  (segs_req_scope (canon_go (segs_to_syms (path_segs path Nil)) Nil)))

;; drop `mod.req` segments from a module path: a file under a module's
;; `mod.req/` directory belongs to the MODULE's namespace, exactly as if it
;; sat in the module root. This makes the file→dir interface expansion
;; identity-neutral (qnames, use forms, and the Stage-4 scope rules are
;; unchanged by the move), and keeps sibling req files source-citable —
;; `mod.req` itself is not a lexable symbol, so an uncollapsed path could
;; never appear in a (:: …) form. It also collapses the dir-form entry
;; mod.req/mod.req.shard to the module root after suffix-strip. Corollary:
;; mod.req/foo.shard and foo.shard in the same module would COLLIDE in qname
;; space — don't keep both.
(fn drop_req_dir_segs ((ss (List Symbol))) (List Symbol)
  (measure (struct ss))
  (match ss
    (Nil Nil)
    ((Cons s rest)
     (if (sym_eq s (mod_req_dir_sym)) (drop_req_dir_segs rest)
     (Cons s (drop_req_dir_segs rest))))))

;; kernel/stdlib.shard is the SOURCE of the `core` crate — the builtin prelude
;; types (List/Option/Bool/Pair) and ctors. Like Rust's `core`, its items ARE
;; core, so its module-path collapses to `core` regardless of the relative
;; import used to reach it. (The type checker and reducer hardcode `core` for
;; these builtins; this keeps the module's prelude defs matching them.)
(fn is_core_path ((segs (List Symbol))) Bool
  (match segs
    ((Cons a (Cons b Nil))
     (if (sym_eq a (quote kernel)) (sym_eq b (quote stdlib)) False))
    (_ False)))

(fn module_path_of ((path (List Int))) (List Symbol)
  (let
    ((segs
       (drop_req_dir_segs
         (canon_go
           (segs_to_syms
             (path_segs (rev_i (strip_path_suffix (rev_i path Nil)) Nil) Nil))
           Nil))))
    (if (is_core_path segs) (qn_core) segs)))

;; build_module with diagnosis: same fold, but a failing source is re-scanned
;; for a precise message instead of collapsing to None.
(type BMRes (BMOk Module) (BMFail (List Int)))

(fn build_module_d
  ((srcs (List SrcEntry)) (acc Module) (ctors (List Symbol)) (k Int))
  BMRes
  (measure (struct srcs))
  (match srcs
    (Nil (BMOk acc))
    ((Cons (SrcEntry path _ src) rest)
     (match (parse_module src ctors)
       (None (BMFail (parse_diag src ctors k)))
       ((Some m)
        (let ((mp (module_path_of path)))
          (match (use_scope_of (use_forms src) mp (module_resolve_env acc))
            ((Pair uitems ualiases)
             (let
               ((rm
                  (module_with_claims
                    (resolve_module
                      mp
                      uitems
                      ualiases
                      (module_externdefs acc)
                      (module_typedefs acc)
                      m)
                    (claim_items_go (use_forms src) mp))))
               (build_module_d
                 rest
                 (merge_modules acc rm)
                 (append_sym (typedef_ctors (module_typedefs rm)) ctors)
                 (+ k 1)))))))))))
