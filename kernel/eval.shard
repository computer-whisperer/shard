;;; eval.shard — the `eval` ENTRYPOINT: a direct-style World program. This is
;;; the `main` the Rust narrow interpreter (`eval` bin) runs; everything else
;;; (reading the target file, parsing, reducing) happens here in shard via the
;;; World file-I/O externs. Promoted from the bootstrap scaffolding
;;; `examples/io/eval_app.shard` once the shard runtime was solid.
;;;
;;; The pure pipeline `eval_run` (parse_module → parse_expr → run_expr →
;;; show_expr) reads args[0] = target module file, args[1] = expression.
;;;   eval <module.shard> <expr>

;; The entrypoint declares the closure it needs to run; the `eval` executor
;; resolves these and loads them (deps first, this file last) — no hardcoded
;; file list on the Rust side. eval's true direct deps are reduce (run_expr)
;; and reader (parse_*); the rest are their transitive deps, listed flat here
;; only because the kernel files don't yet declare their own imports (kernel-as-
;; a-module is deferred). When they do, this collapses to reduce + reader.
(import "loader.shard")  ; World + I/O externs + resolve_closure
(import "term.shard")  ; Expr / Pat / Arm + open_many / subst
(import "module.shard")  ; Module / FnDef / Type + lookups
(import "reduce.shard")  ; run_expr — the ground-execution reducer
(import "reader.shard")  ; parse_module / parse_expr
(use (:: kernel loader *))
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel reduce *))
(use (:: kernel reader *))

;; ---- rendering: Expr → surface bytes --------------------------------------
;; (append_int / show_nat / show_int live in term.shard)
(fn show_expr ((e Expr)) (List Int)
  (measure (struct e))
  (match e
    ((IntLit n) (show_int n))
    ((SymLit s) (Cons 39 (chars_of_sym s)))  ; 'sym
    ((FVar s) (chars_of_sym s))
    ((BVar k) (Cons 36 (show_int k)))  ; $k (not expected in NF)
    ((Ctor name args)
     (match args
       (Nil (chars_of_sym (qn_name name)))
       (_
         (Cons
           40
           (append_int
             (chars_of_sym (qn_name name))
             (append_int (show_args args) (Cons 41 Nil)))))))
    ((Call name args)  ; a stuck call, if any
     (Cons
       40
       (append_int
         (chars_of_sym (qn_name name))
         (append_int (show_args args) (Cons 41 Nil)))))
    ((Match _ _) "<match>")
    ((Let _ _) "<let>")
    ((If _ _ _) "<if>")))

(fn show_args ((args (List Expr))) (List Int)
  (measure (struct args))  ; " a1 a2 …"
  (match args
    (Nil Nil)
    ((Cons a rest) (Cons 32 (append_int (show_expr a) (show_args rest))))))

;; (import-closure resolution — drop_to_slash / dir_of / resolve_closure —
;; lives in loader.shard, shared with check.shard.)

;; ---- the eval pipeline ----------------------------------------------------
;; The ambient ctor base: stdlib ctors a user program may use without
;; declaring (parse needs them to tell Ctor from Call). build_module_r then
;; accumulates each file's own ctors as it folds the closure in order.
(fn stdlib_ctors () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

(fn module_all_ctors ((m Module)) (List Symbol)
  (match m
    ((Module tds _ _ _ _) (append_sym (typedef_ctors tds) (stdlib_ctors)))))

;; Default step budget for running an app. run_expr spends one unit per
;; small-step, so this caps an app run at this many reductions. It is a
;; PRAGMATIC bound — lower it to bound execution time when bringing a system up
;; — not a soundness condition: run_expr's totality holds for any budget, and
;; running out returns the partially-reduced (still definitionally-equal) term.
(fn run_budget () Int 1000000000)

(fn eval_run ((sources (List SrcEntry)) (expr_src (List Int))) (List Int)
  (match
    (build_module_r
      sources
      (Module Nil Nil Nil (FnTrie None Nil) Nil)
      (stdlib_ctors))
    (None "error: could not parse module(s)\n")
    ((Some m)
     (match (parse_expr expr_src (module_all_ctors m))
       (None "error: could not parse expression\n")
       ((Some e)
        ;; the CLI expr parses core-tagged — resolve it against everything
        ;; loaded (glob, first-loaded wins), the run-mode scope for an
        ;; anonymous caller; unresolved names stay core (prims/prelude)
        (let ((re (resolve_expr (RCtx (qn_core) (module_resolve_env m) Nil) e)))
          (append_int (show_expr (run_expr m re (run_budget))) (Cons 10 Nil))))))))

;; ===========================================================================
;; THE APP RUNNER — eval.shard actually RUNS a shard app (performs its effects).
;;
;; `run_expr` reduces the app's `(main world0)` to a normal form: an
;; effect-TREE of stuck extern Calls, held as Expr DATA (one meta-level up from
;; eval.shard's own values). This driver is the shard port of eval.rs's run
;; loop + handler: find the frontier extern (the innermost stuck extern Call,
;; all args reduced), DECODE its Expr-encoded args into eval.shard's own values,
;; PERFORM it via eval.shard's OWN externs (which the Rust host dispatches),
;; ENCODE the result back into the tree, re-reduce, and loop. The app exits via
;; its own `exit` extern (a real process exit), so the loop normally terminates
;; there; if `main` returns a World instead, the loop ends with no frontier.
;; ===========================================================================

;; -- marshalling: eval.shard values <-> their kernel-Expr encodings ----------
;; (intlist_to_expr / expr_to_intlist — the (List Int) <-> object-list Expr
;; conversions — live in term.shard, shared with the reducer's chars_of_sym /
;; sym_of_chars prim cases. They are accumulator-style on purpose: these run
;; on whole files at the extern boundary here. A local duplicate of
;; expr_to_intlist used to sit in this file, dead under first-match-wins.)

;; `wq` is the app's OWN World qname (read off its main's signature in
;; run_main): qualified resolution stamps the app's (World …) patterns with
;; the module that binds World there — the app's own typedef for io-style
;; programs, kernel/loader's for tool apps — so every world token handed
;; into the object program must carry that same identity, or the app's
;; matches would go stuck.
(fn encode_world ((wq QName) (w World)) Expr
  (match w
    ((World c) (Ctor wq (Cons (IntLit c) Nil)))))

(fn encode_opt_bytes ((o (Option (List Int)))) Expr
  (match o
    (None (Ctor (qn (quote None)) Nil))
    ((Some bs) (Ctor (qn (quote Some)) (Cons (intlist_to_expr bs) Nil)))))

(fn encode_opt_int ((o (Option Int))) Expr
  (match o
    (None (Ctor (qn (quote None)) Nil))
    ((Some n) (Ctor (qn (quote Some)) (Cons (IntLit n) Nil)))))

(fn encode_arglist ((xs (List (List Int)))) Expr
  (measure (struct xs))
  (match xs
    (Nil (Ctor (qn (quote Nil)) Nil))
    ((Cons h t)
     (Ctor
       (qn (quote Cons))
       (Cons (intlist_to_expr h) (Cons (encode_arglist t) Nil))))))

(fn encode_pair ((a Expr) (b Expr)) Expr
  (Ctor (qn (quote Pair)) (Cons a (Cons b Nil))))

;; -- the extern vocabulary the runner can perform ----------------------------
(fn is_extern ((name Symbol)) Bool
  (if (sym_eq name (quote get_args)) True
  (if (sym_eq name (quote read_file)) True
  (if (sym_eq name (quote read_dir)) True
  (if (sym_eq name (quote write)) True
  (if (sym_eq name (quote write_file)) True
  (if (sym_eq name (quote write_line)) True
  (if (sym_eq name (quote exit)) True
  (if (sym_eq name (quote key_oracle)) True  ; interactive apps' key input
  False)))))))))

;; ===========================================================================
;; THE ENV-MACHINE — `ev` runs a CLOSED, TOTAL shard app by call-by-value
;; reduction against a de Bruijn ENVIRONMENT, performing extern effects INLINE.
;;
;; This is the shard port of eval.rs's `eval_env` (the narrow host's own
;; evaluator), and exists for the same reason eval.rs gives: a SUBSTITUTION
;; reducer (reduce.shard's `step`/`open_many`) deep-copies the body and every
;; captured value on each call, so running the whole self-hosted checker
;; through it is O(n²)+ in time and space. An environment machine looks up a
;; BVar in O(1) and never copies a captured value — and because the host
;; represents shard values with Rc, that sharing is inherited for free.
;;
;; Unlike the old reduce-to-NF + find_frontier + replace_expr loop (which
;; re-reduced the WHOLE program tree once per effect), `ev` threads the real
;; World and performs each extern the instant its args are values, exactly
;; where eval.rs dispatches via its effect handler. So there is no effect-tree,
;; no frontier search, no whole-tree replacement, and no re-reduction.
;;
;; SCOPE: closed, total programs (which is precisely what `run` executes —
;; check.shard, eval apps, …). Every `If` condition reduces to a Bool and every
;; `Match` scrutinee to a constructor; the only irreducible calls are externs,
;; performed here. A genuinely stuck `If`/`Match` (open/symbolic input) would
;; leave an unclosed residual — that path is the symbolic reducer's job
;; (`run_expr`/`step`), not this one. CBV is sound for these apps: the native
;; host ran the same programs CBV, so `ev` reproduces those results.
;; ===========================================================================

;; Two-valued matcher over a VALUE (a fully-reduced Expr). No MStuck: the
;; scrutinee is already a value, so every position is decided. Bindings are
;; collected innermost-first (rightmost PVar = BVar 0), matching match_pat.
(fn match_val ((p Pat) (v Expr) (acc (List Expr))) (Option (List Expr))
  (measure (struct p))
  (match p
    ((PVar) (Some (Cons v acc)))
    ((PInt n)
     (match v
       ((IntLit m) (if (int_eq n m) (Some acc) None))
       (_ None)))
    ((PSym s)
     (match v
       ((SymLit t) (if (sym_eq s t) (Some acc) None))
       (_ None)))
    ((PCtor pc pats)
     (match v
       ((Ctor vc vargs) (if (qname_eq pc vc) (match_vals pats vargs acc) None))
       ((IntLit n) (match_val_nat pc pats n acc))
       (_ None)))))

;; The Nat former's constructor VIEW, two-valued (ev's closed-world matcher —
;; mirrors reduce.shard match_nat_view): a nonneg IntLit IS a ground Nat, so
;; it matches core Z/S structurally (0 is Z, n>=1 is (S (n-1)), recursing for
;; deep patterns). Ill-typed garbage (negatives, arity) just fails to match.
(fn match_val_nat ((pc QName) (pats (List Pat)) (n Int) (acc (List Expr)))
  (Option (List Expr))
  (measure (struct pats))
  (if (core_named pc (quote Z))
    (if (int_eq n 0)
      (match pats
        (Nil (Some acc))
        (_ None))
      None)
  (if (core_named pc (quote S))
    (match pats
      ((Cons p1 Nil) (if (le 1 n) (match_val p1 (IntLit (- n 1)) acc) None))
      (_ None))
    None)))

(fn match_vals ((ps (List Pat)) (vs (List Expr)) (acc (List Expr)))
  (Option (List Expr))
  (measure (struct ps))
  (match ps
    (Nil
      (match vs
        (Nil (Some acc))
        (_ None)))
    ((Cons p pr)
     (match vs
       (Nil None)
       ((Cons v vr)
        (match (match_val p v acc)
          (None None)
          ((Some acc2) (match_vals pr vr acc2))))))))

;; Fire the first arm whose pattern matches value `v`; return its (translated)
;; body + the captured bindings (innermost-first). None ⇒ no arm matched.
(fn fire_earm ((arms (List EArm)) (v Expr)) (Option (Pair EExpr (List Expr)))
  (measure (struct arms))
  (match arms
    (Nil None)
    ((Cons (EArm p body) rest)
     (match (match_val p v Nil)
       ((Some binds) (Some (Pair body binds)))
       (None (fire_earm rest v))))))

;; Environment lookup: BVar k → env[k]. A correct closed evaluation always
;; finds it; the BVar fallback only guards against an impossible miss.
(fn env_get ((env (List Expr)) (k Int)) Expr
  (match (nth_opt env k)
    ((Some v) v)
    (None (BVar k))))

(fn append_exprs ((xs (List Expr)) (ys (List Expr))) (List Expr)
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (append_exprs t ys)))))

;; ===========================================================================
;; LOAD-TIME CALL RESOLUTION — the ev instruction form.
;;
;; Dispatching a Call through the FnTrie costs a fresh qualified-key char
;; list (qn_key_chars ALLOCATES ~|key| cells) plus a per-char trie walk —
;; per CALL. At ev frequency this is the largest single evaluator cost
;; (~15-20% of an interpreted run with its allocation traffic; tools/bench).
;; The trie's answer is a pure function of the module, so run_app resolves
;; every call SITE once at load: fn bodies are translated to EExpr, where a
;; call carries (Option Int) — the winning def's index into FnTab, a Braun
;; tree over the translated bodies (O(log n) int steps, zero allocation).
;; ev_call's PROBE ORDER is preserved exactly (prim → extern → resolved
;; target → stuck for core-pathed heads; target-first otherwise); only the
;; trie consult is replaced by the pre-resolved index. Arity is checked at
;; translation (a site's arg count is static): a mismatch on a resolved
;; head becomes the sentinel index -1 — still "resolved" for probe-order
;; purposes, but braun_get finds nothing there, so the call sticks exactly
;; where the old runtime arity guard stuck it.
;; ===========================================================================

;; PExpr: the PURE instruction form — subtrees the effect analysis (below)
;; proves can never reach an extern. These run on `evp`, which threads no
;; World and returns a bare Expr: the (Pair value World) that ev allocates
;; PER CALL was the largest remaining allocation source after lever 3.
(type PExpr
  (PuVal Expr)  ; value leaf (IntLit/SymLit/FVar) — returned as-is, shared
  (PuBVar Int)
  (PuCtor QName (List PExpr))
  (PuLet (List PExpr) PExpr)
  (PuIf PExpr PExpr PExpr)
  (PuMatch PExpr (List PuArm))
  (PuCall Bool QName (Option Int) (List PExpr)))  ; core-pathed? + head + index

(type PuArm (PuArm Pat PExpr))

;; EExpr: the EFFECTFUL instruction form — a node is EExpr only if some
;; extern is reachable under it; pure subtrees embed as (EPure …) and drop
;; into evp. Value leaves and BVars are always pure, so EExpr has none.
(type EExpr
  (EPure PExpr)
  (ECtor QName (List EExpr))
  (ELet (List EExpr) EExpr)
  (EIf EExpr EExpr EExpr)
  (EMatch EExpr (List EArm))
  (ECall Bool QName (Option Int) (List EExpr)))  ; core-pathed? + head + index

(type EArm (EArm Pat EExpr))

;; A table entry: the translated body in whichever form its fn's effect
;; flag dictates (FtP for pure fns — the invariant that lets evp dispatch
;; without a World; ev-side calls to a pure fn also take the FtP fast path).
(type FtEntry (FtP PExpr) (FtE EExpr))

;; FnTab: a Braun tree over the translated fn bodies, in fns-list order
;; (root = index 0, odd indices in the left subtree, even in the right).
;; braun_cons prepends at index 0 shifting the rest, so folding the
;; REVERSED body list yields index i = fn i.
(type FnTab (FtNil) (FtNode FtEntry FnTab FnTab))

(fn braun_cons ((v FtEntry) (t FnTab)) FnTab
  (measure (struct t))
  (match t
    (FtNil (FtNode v FtNil FtNil))
    ((FtNode w o e) (FtNode v (braun_cons w e) o))))

(fn braun_get ((t FnTab) (i Int)) (Option FtEntry)
  (measure (struct t))
  (match t
    (FtNil None)
    ((FtNode v o e)
     (if (int_eq i 0) (Some v)
     (if (int_eq (mod i 2) 1) (braun_get o (ediv i 2))
     (braun_get e (- (ediv i 2) 1)))))))

;; BTab: a Braun tree of Bools — the per-fn effect flags (bt_get on a miss
;; is False: no fn, no effect).
(type BTab (BtNil) (BtNode Bool BTab BTab))

(fn bt_cons ((v Bool) (t BTab)) BTab
  (measure (struct t))
  (match t
    (BtNil (BtNode v BtNil BtNil))
    ((BtNode w o e) (BtNode v (bt_cons w e) o))))

(fn bt_get ((t BTab) (i Int)) Bool
  (measure (struct t))
  (match t
    (BtNil False)
    ((BtNode v o e)
     (if (int_eq i 0) v
     (if (int_eq (mod i 2) 1) (bt_get o (ediv i 2))
     (bt_get e (- (ediv i 2) 1)))))))

(fn bt_build_rev ((bs (List Bool)) (acc BTab)) BTab
  (measure (struct bs))
  (match bs
    (Nil acc)
    ((Cons b t) (bt_build_rev t (bt_cons b acc)))))

;; The resolution index: the REAL trie shape — same keys, same insert order,
;; same keep-first winners — with each payload's body swapped for its
;; fns-list index (smuggled as an IntLit). trie_insert/trie_lookup are
;; reused verbatim, so a lookup answers with exactly the def the runtime
;; trie would have picked, plus where its translated body lives in FnTab.
(fn ix_fndefs ((fds (List FnDef)) (i Int)) (List FnDef)
  (measure (struct fds))
  (match fds
    (Nil Nil)
    ((Cons fd rest)
     (match fd
       ((FnDef q pts rt _)
        (Cons (FnDef q pts rt (IntLit i)) (ix_fndefs rest (+ i 1))))))))

;; Resolve one call site: the winning def's index, arity-checked statically.
;; None = no def with this name; (Some -1) = a def exists but the site's arg
;; count is wrong (sticks at dispatch, like the old runtime arity guard).
(fn tr_target ((f QName) (args (List Expr)) (ixt FnTrie)) (Option Int)
  (match (trie_lookup f ixt)
    (None None)
    ((Some (FnDef _ ptypes _ ibody))
     (if (arity_ok args ptypes)
       (match ibody
         ((IntLit i) (Some i))
         (_ (Some (- 0 1))))
       (Some (- 0 1))))))

;; ---- effect analysis ---------------------------------------------------------
;; A fn is EFFECTFUL iff its body can reach an extern: a call whose bare
;; name is in the extern vocabulary (conservative — in run mode a core
;; head probes externs after prims, so an extern-named call may perform),
;; or a resolved call to an effectful fn. Computed as the least fixpoint
;; over the resolved call graph: per-fn (direct?, callees) once, then
;; monotone passes until no flag flips (≤ n+1 passes; each pass at least
;; one new True or the loop stops).

;; one body's (direct-extern?, resolved callee indices), accumulator-style.
(fn eff_scan ((e Expr) (ixt FnTrie) (acc (Pair Bool (List Int))))
  (Pair Bool (List Int))
  (measure (struct e))
  (match e
    ((Call f args)
     (let ((acc1 (eff_scan_list args ixt acc)))
       (if (is_extern (qn_name f))
         (match acc1
           ((Pair _ cs) (Pair True cs)))
         (match (tr_target f args ixt)
           ((Some i)
            (if (le 0 i)
              (match acc1
                ((Pair d cs) (Pair d (Cons i cs))))
              acc1))  ; -1 arity sentinel: the call sticks — no effect
           (None acc1)))))  ; unresolved: a prim or a stuck call — no effect
    ((Ctor _ args) (eff_scan_list args ixt acc))
    ((Let bs body) (eff_scan body ixt (eff_scan_list bs ixt acc)))
    ((If c t el) (eff_scan el ixt (eff_scan t ixt (eff_scan c ixt acc))))
    ((Match s arms) (eff_scan_arms arms ixt (eff_scan s ixt acc)))
    (_ acc)))

(fn eff_scan_list ((es (List Expr)) (ixt FnTrie) (acc (Pair Bool (List Int))))
  (Pair Bool (List Int))
  (measure (struct es))
  (match es
    (Nil acc)
    ((Cons h t) (eff_scan_list t ixt (eff_scan h ixt acc)))))

(fn eff_scan_arms ((arms (List Arm)) (ixt FnTrie) (acc (Pair Bool (List Int))))
  (Pair Bool (List Int))
  (measure (struct arms))
  (match arms
    (Nil acc)
    ((Cons (Arm _ b) rest) (eff_scan_arms rest ixt (eff_scan b ixt acc)))))

(fn eff_infos ((fds (List FnDef)) (ixt FnTrie)) (List (Pair Bool (List Int)))
  (measure (struct fds))
  (match fds
    (Nil Nil)
    ((Cons fd rest)
     (match fd
       ((FnDef _ _ _ b)
        (Cons (eff_scan b ixt (Pair False Nil)) (eff_infos rest ixt)))))))

(fn any_eff ((cs (List Int)) (eff BTab)) Bool
  (measure (struct cs))
  (match cs
    (Nil False)
    ((Cons i t) (if (bt_get eff i) True (any_eff t eff)))))

;; one pass: recompute every flag against the previous table.
;; returns (changed?, new flags REVERSED — bt_build_rev's order).
(fn eff_pass
  ((infos (List (Pair Bool (List Int))))
   (eff BTab)
   (i Int)
   (accrev (List Bool))
   (chg Bool))
  (Pair Bool (List Bool))
  (measure (struct infos))
  (match infos
    (Nil (Pair chg accrev))
    ((Cons (Pair d cs) rest)
     (let ((old (bt_get eff i)))
       (let ((new (if old True (if d True (any_eff cs eff)))))
         (eff_pass
           rest
           eff
           (+ i 1)
           (Cons new accrev)
           (if new (if old chg True) chg)))))))  ; monotone: only False→True flips

(fn eff_fix ((infos (List (Pair Bool (List Int)))) (eff BTab) (fuel Int)) BTab
  (measure fuel (by arith (list 1 0)) (by arith (list 1 1)))
  (if (lt fuel 1) eff
  (match (eff_pass infos eff 0 Nil False)
    ((Pair chg flagsrev)
     (if chg (eff_fix infos (bt_build_rev flagsrev BtNil) (- fuel 1)) eff)))))

(fn eff_fuel ((fds (List FnDef)) (n Int)) Int
  (measure (struct fds))
  (match fds
    (Nil (+ n 1))
    ((Cons _ t) (eff_fuel t (+ n 1)))))

(fn build_efftab ((fns (List FnDef)) (ixt FnTrie)) BTab
  (eff_fix (eff_infos fns ixt) BtNil (eff_fuel fns 0)))

;; ---- the body translation: one bottom-up walk --------------------------------
;; Each subtree translates to its OWN form: TrP if no extern is reachable
;; under it, TrE otherwise. A pure child in an effectful parent embeds as
;; (EPure …); the reverse never happens (an effectful child makes its
;; parent effectful). trp_of's fallback arm is unreachable — every use is
;; guarded by all_p / is_p — but keeps the extractor total.

(type TrRes (TrP PExpr) (TrE EExpr))

(fn is_p ((r TrRes)) Bool
  (match r
    ((TrP _) True)
    ((TrE _) False)))

(fn all_p ((rs (List TrRes))) Bool
  (measure (struct rs))
  (match rs
    (Nil True)
    ((Cons h t) (if (is_p h) (all_p t) False))))

(fn tre_of ((r TrRes)) EExpr
  (match r
    ((TrP p) (EPure p))
    ((TrE e) e)))

(fn trp_of ((r TrRes)) PExpr
  (match r
    ((TrP p) p)
    ((TrE _) (PuVal (IntLit 0)))))  ; unreachable (guarded); total

(fn map_trp ((rs (List TrRes))) (List PExpr)
  (measure (struct rs))
  (match rs
    (Nil Nil)
    ((Cons h t) (Cons (trp_of h) (map_trp t)))))

(fn map_tre ((rs (List TrRes))) (List EExpr)
  (measure (struct rs))
  (match rs
    (Nil Nil)
    ((Cons h t) (Cons (tre_of h) (map_tre t)))))

;; is a call with this head pure? Aligned EXACTLY with eff_scan's per-call
;; test — that alignment is the invariant that keeps pure-flagged fns
;; translating to TrP (so FtP entries exist for evp to dispatch into).
(fn call_pure ((f QName) (fb (Option Int)) (eff BTab)) Bool
  (if (is_extern (qn_name f)) False
  (match fb
    ((Some i) (if (le 0 i) (if (bt_get eff i) False True) True))
    (None True))))

(fn tr2_expr ((e Expr) (ixt FnTrie) (eff BTab)) TrRes
  (measure (struct e))
  (match e
    ((IntLit _) (TrP (PuVal e)))
    ((SymLit _) (TrP (PuVal e)))
    ((FVar _) (TrP (PuVal e)))
    ((BVar k) (TrP (PuBVar k)))
    ((Ctor c args)
     (let ((rs (tr2_list args ixt eff)))
       (if (all_p rs) (TrP (PuCtor c (map_trp rs)))
       (TrE (ECtor c (map_tre rs))))))
    ((Let bs body)
     (let ((rb (tr2_list bs ixt eff)))
       (let ((rbody (tr2_expr body ixt eff)))
         (if (if (all_p rb) (is_p rbody) False)
           (TrP (PuLet (map_trp rb) (trp_of rbody)))
           (TrE (ELet (map_tre rb) (tre_of rbody)))))))
    ((If c t el)
     (let ((rc (tr2_expr c ixt eff)))
       (let ((rt (tr2_expr t ixt eff)))
         (let ((re (tr2_expr el ixt eff)))
           (if (if (is_p rc) (if (is_p rt) (is_p re) False) False)
             (TrP (PuIf (trp_of rc) (trp_of rt) (trp_of re)))
             (TrE (EIf (tre_of rc) (tre_of rt) (tre_of re))))))))
    ((Match s arms)
     (let ((rsc (tr2_expr s ixt eff)))
       (let ((ras (tr2_arms arms ixt eff)))
         (if (if (is_p rsc) (arms_all_p ras) False)
           (TrP (PuMatch (trp_of rsc) (map_parm ras)))
           (TrE (EMatch (tre_of rsc) (map_earm ras)))))))
    ((Call f args)
     (let ((core (ev_core_path (qn_mod f))))  ; the head's path is static
       (let ((fb (tr_target f args ixt)))
         (let ((rs (tr2_list args ixt eff)))
           (if (if (call_pure f fb eff) (all_p rs) False)
             (TrP (PuCall core f fb (map_trp rs)))
             (TrE (ECall core f fb (map_tre rs))))))))))

(fn tr2_list ((es (List Expr)) (ixt FnTrie) (eff BTab)) (List TrRes)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons h t) (Cons (tr2_expr h ixt eff) (tr2_list t ixt eff)))))

(fn tr2_arms ((arms (List Arm)) (ixt FnTrie) (eff BTab)) (List (Pair Pat TrRes))
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm p b) rest)
     (Cons (Pair p (tr2_expr b ixt eff)) (tr2_arms rest ixt eff)))))

(fn arms_all_p ((ras (List (Pair Pat TrRes)))) Bool
  (measure (struct ras))
  (match ras
    (Nil True)
    ((Cons (Pair _ r) t) (if (is_p r) (arms_all_p t) False))))

(fn map_parm ((ras (List (Pair Pat TrRes)))) (List PuArm)
  (measure (struct ras))
  (match ras
    (Nil Nil)
    ((Cons (Pair p r) t) (Cons (PuArm p (trp_of r)) (map_parm t)))))

(fn map_earm ((ras (List (Pair Pat TrRes)))) (List EArm)
  (measure (struct ras))
  (match ras
    (Nil Nil)
    ((Cons (Pair p r) t) (Cons (EArm p (tre_of r)) (map_earm t)))))

;; Table entries, REVERSED (the accumulator order braun-building wants).
;; A pure-flagged fn's body is TrP by the call_pure/eff_scan alignment;
;; the FtE fallback there is unreachable belt-and-suspenders.
(fn ft_entries_rev
  ((fds (List FnDef)) (ixt FnTrie) (eff BTab) (i Int) (acc (List FtEntry)))
  (List FtEntry)
  (measure (struct fds))
  (match fds
    (Nil acc)
    ((Cons fd rest)
     (match fd
       ((FnDef _ _ _ b)
        (ft_entries_rev
          rest
          ixt
          eff
          (+ i 1)
          (Cons
            (if (bt_get eff i) (FtE (tre_of (tr2_expr b ixt eff)))
            (match (tr2_expr b ixt eff)
              ((TrP p) (FtP p))
              ((TrE e) (FtE e))))
            acc)))))))

(fn ft_build_rev ((bs (List FtEntry)) (acc FnTab)) FnTab
  (measure (struct bs))
  (match bs
    (Nil acc)
    ((Cons b t) (ft_build_rev t (braun_cons b acc)))))

(fn build_fntab ((fns (List FnDef)) (ixt FnTrie) (eff BTab)) FnTab
  (ft_build_rev (ft_entries_rev fns ixt eff 0 Nil) FtNil))

;; ---- evp: the PURE evaluator --------------------------------------------------
;; Runs PExpr — subtrees the effect analysis proved extern-free — with no
;; World, no app_args, and no result Pair. Same value domain, same env
;; convention, same probe order as ev (minus the extern probe, which the
;; analysis excluded). fire_parm/evp_hit mirror fire_earm/ev_hit.

(fn fire_parm ((arms (List PuArm)) (v Expr)) (Option (Pair PExpr (List Expr)))
  (measure (struct arms))
  (match arms
    (Nil None)
    ((Cons (PuArm p body) rest)
     (match (match_val p v Nil)
       ((Some binds) (Some (Pair body binds)))
       (None (fire_parm rest v))))))

(fn evp ((tab FnTab) (env (List Expr)) (e PExpr)) Expr
  (match e
    ((PuVal v) v)
    ((PuBVar k) (env_get env k))
    ((PuCtor c args)
     (let ((vs (evp_list tab env args)))
       (match (nat_pack c vs)  ; ground Z/S packs to its literal (reduce.shard)
         ((Some v) v)
         (None (Ctor c vs)))))
    ((PuLet bs body)
     (evp tab (append_exprs (evp_list_rev tab env bs Nil) env) body))  ; last RHS = BVar 0
    ((PuIf c t el)
     (let ((cv (evp tab env c)))
       (match cv
         ((Ctor (QName _ (quote True)) Nil) (evp tab env t))
         ((Ctor (QName _ (quote False)) Nil) (evp tab env el))
         (_ (If cv cv cv)))))  ; stuck cond — error-path residual only
    ((PuMatch s arms)
     (let ((sv (evp tab env s)))
       (match (fire_parm arms sv)
         ((Some (Pair body binds)) (evp tab (append_exprs binds env) body))
         (None (Match sv Nil)))))  ; stuck scrut — error-path residual only
    ((PuCall core f fb args)
     (evp_call tab core f fb (evp_list_rev tab env args Nil)))))

(fn evp_list ((tab FnTab) (env (List Expr)) (es (List PExpr))) (List Expr)
  (match es
    (Nil Nil)
    ((Cons h t) (Cons (evp tab env h) (evp_list tab env t)))))

(fn evp_list_rev
  ((tab FnTab) (env (List Expr)) (es (List PExpr)) (acc (List Expr)))
  (List Expr)
  (match es
    (Nil acc)
    ((Cons h t) (evp_list_rev tab env t (Cons (evp tab env h) acc)))))

(fn evp_call
  ((tab FnTab) (core Bool) (f QName) (fb (Option Int)) (vsr (List Expr)))
  Expr
  (if core
    (let ((vs (reverse_exprs vsr)))
      (match (try_step_prim (qn_name f) vs)
        ((Some r) r)
        (None (evp_hit tab f fb vsr))))
    (match fb
      ((Some _) (evp_hit tab f fb vsr))
      (None
        (let ((vs (reverse_exprs vsr)))
          (match (try_step_prim (qn_name f) vs)
            ((Some r) r)
            (None (Call f vs))))))))

;; An FtE hit is unreachable here (an effectful callee would have made the
;; calling site effectful); it sticks, keeping evp_hit total either way.
(fn evp_hit ((tab FnTab) (f QName) (fb (Option Int)) (vsr (List Expr))) Expr
  (match fb
    ((Some i)
     (match (braun_get tab i)
       ((Some (FtP body)) (evp tab vsr body))
       ((Some (FtE _)) (Call f (reverse_exprs vsr)))
       (None (Call f (reverse_exprs vsr)))))
    (None (Call f (reverse_exprs vsr)))))

;; ev: evaluate `e` (whose free BVars index into `env`) to a value, threading
;; the World `w` through inline effects. Returns (value, advanced World).
;; The stuck If/Match residuals can no longer carry their original branches
;; (those are EExpr now) — they are error-path-only values (run_app matches
;; nothing but a Ctor-headed World), so a minimal reconstruction suffices.
(fn ev
  ((tab FnTab)
   (env (List Expr))
   (e EExpr)
   (renv (Pair (List (List Int)) QName))  ; app argv + the app's World qname
   (w World))
  (Pair Expr World)
  (match e
    ((EPure p) (Pair (evp tab env p) w))  ; extern-free: the World is untouched
    ((ECtor c args)
     (match (ev_list tab env args renv w)
       ((Pair vs w1)
        (match (nat_pack c vs)  ; ground Z/S packs to its literal (reduce.shard)
          ((Some v) (Pair v w1))
          (None (Pair (Ctor c vs) w1))))))
    ((ELet bs body)
     (match (ev_list_rev tab env bs Nil renv w)  ; parallel let: RHSs in outer env
       ((Pair vsr w1) (ev tab (append_exprs vsr env) body renv w1))))  ; last RHS = BVar 0
    ((EIf c t el)
     (match (ev tab env c renv w)
       ((Pair cv w1)
        (match cv
          ((Ctor (QName _ (quote True)) Nil) (ev tab env t renv w1))
          ((Ctor (QName _ (quote False)) Nil) (ev tab env el renv w1))
          (_ (Pair (If cv cv cv) w1))))))  ; stuck cond — out of scope (see header)
    ((EMatch s arms)
     (match (ev tab env s renv w)
       ((Pair sv w1)
        (match (fire_earm arms sv)
          ((Some (Pair body binds))
           (ev tab (append_exprs binds env) body renv w1))
          (None (Pair (Match sv Nil) w1))))))  ; stuck scrut — out of scope (see header)
    ((ECall core f fb args)
     (match (ev_list_rev tab env args Nil renv w)
       ((Pair vsr w1) (ev_call tab core f fb vsr renv w1))))))

;; Evaluate a list of args left-to-right, threading the World (so nested
;; effects sequence in source order — the linear World forces it anyway).
(fn ev_list
  ((tab FnTab)
   (env (List Expr))
   (es (List EExpr))
   (renv (Pair (List (List Int)) QName))
   (w World))
  (Pair (List Expr) World)
  (match es
    (Nil (Pair Nil w))
    ((Cons h t)
     (match (ev tab env h renv w)
       ((Pair v w1)
        (match (ev_list tab env t renv w1)
          ((Pair vs w2) (Pair (Cons v vs) w2))))))))

;; ev_list, REVERSED-accumulator form: left-to-right evaluation consing into
;; `acc`, so the result comes out reversed — which is exactly env order for a
;; fn dispatch (BVar 0 = LAST arg) and Let extension order. Tail-recursive:
;; ONE result Pair per list instead of one per element (ev_list's per-level
;; (Pair (Cons …) …) rebuild was measurable churn at call frequency).
(fn ev_list_rev
  ((tab FnTab)
   (env (List Expr))
   (es (List EExpr))
   (acc (List Expr))
   (renv (Pair (List (List Int)) QName))
   (w World))
  (Pair (List Expr) World)
  (match es
    (Nil (Pair acc w))
    ((Cons h t)
     (match (ev tab env h renv w)
       ((Pair v w1) (ev_list_rev tab env t (Cons v acc) renv w1))))))

;; Arity guard: |vs| = |ptypes|, decided in ONE simultaneous walk. Now
;; consulted at TRANSLATION time only (tr_target — a site's arg count is
;; static), no longer per call.
(fn arity_ok ((vs (List Expr)) (ts (List Type))) Bool
  (measure (struct vs))
  (match vs
    (Nil
      (match ts
        (Nil True)
        (_ False)))
    ((Cons _ vr)
     (match ts
       (Nil False)
       ((Cons _ tr) (arity_ok vr tr))))))

;; Dispatch into a pre-resolved user fn: fetch its translated body from the
;; table and enter it on a fresh env of the reversed args. An unresolved head
;; (None) or the arity-mismatch sentinel (-1, which braun_get misses by
;; construction) leaves the call stuck, exactly like the old trie-miss /
;; runtime arity guard.
(fn ev_hit
  ((tab FnTab)
   (f QName)
   (fb (Option Int))
   (vsr (List Expr))  ; REVERSED values — already env order (BVar 0 = LAST param)
   (renv (Pair (List (List Int)) QName))
   (w World))
  (Pair Expr World)
  (match fb
    ((Some i)
     (match (braun_get tab i)
       ((Some (FtP body)) (Pair (evp tab vsr body) w))  ; pure fn: Pair-free descent
       ((Some (FtE body)) (ev tab vsr body renv w))
       (None (Pair (Call f (reverse_exprs vsr)) w))))
    (None (Pair (Call f (reverse_exprs vsr)) w))))

;; Apply a head `f` to already-evaluated value args `vs`:
;;   user fn  → tail-recurse into its body in a fresh env of the reversed args
;;   primitive→ dispatch on the value args (reuses the reducer's prim table)
;;   extern   → perform the effect inline (threads the World)
;;   else     → leave the call stuck (unknown head; not expected for a real app)
;;
;; PROBE ORDER is path-directed: resolution stamps every DEFINED name with its
;; real module path, so a core-pathed head is a primitive / extern / prelude
;; name (or a synthesized entry like `(qn 'main)` / an ad-hoc `eval` expr) —
;; for those, probe the prim table and externs FIRST and the trie only as the
;; fallback, saving a guaranteed-miss char walk + chars_of_sym allocation on
;; every prim call (the single hottest dispatch path in a hosted checker run).
;; Non-core heads probe the trie first, exactly as before. The orders differ
;; only for a core-pathed name that is BOTH a prim/extern AND a user fn name —
;; where prim-first agrees with the proof layer's core-identity semantics.
;; is the head's module-path exactly (core)? Direct structural test — the
;; `(sym_path_eq (qn_mod f) (qn_core))` form allocates a fresh path list and
;; recurses per call, and this runs once per ev_call.
(fn ev_core_path ((p (List Symbol))) Bool
  (match p
    ((Cons c Nil) (sym_eq c (quote core)))
    (_ False)))

(fn ev_call
  ((tab FnTab)
   (core Bool)  ; the head's path is static — decided at translation
   (f QName)
   (fb (Option Int))
   (vsr (List Expr))  ; REVERSED values; prim/extern/stuck paths re-reverse
   (renv (Pair (List (List Int)) QName))
   (w World))
  (Pair Expr World)
  (if core
    (let ((vs (reverse_exprs vsr)))
      (match (try_step_prim (qn_name f) vs)
        ((Some r) (Pair r w))
        (None
          (if (is_extern (qn_name f)) (perform_frontier (Call f vs) renv w)
          (ev_hit tab f fb vsr renv w)))))
    (match fb
      ((Some _) (ev_hit tab f fb vsr renv w))
      (None
        (let ((vs (reverse_exprs vsr)))
          (match (try_step_prim (qn_name f) vs)
            ((Some r) (Pair r w))
            (None
              (if (is_extern (qn_name f)) (perform_frontier (Call f vs) renv w)
              (Pair (Call f vs) w)))))))))

;; -- perform one frontier extern. Threads eval.shard's REAL World; returns the
;; app-facing result (Expr-encoded) paired with the advanced World. `app_args`
;; serves the app's get_args (the real argv slice, computed once at startup).
(fn perform_frontier
  ((call Expr) (renv (Pair (List (List Int)) QName)) (w World))
  (Pair Expr World)
  (match renv
    ((Pair app_args wq)
     (match call
       ((Call name args)
        (if (sym_eq (qn_name name) (quote get_args))
          (perform_get_args wq app_args w)
        (if (sym_eq (qn_name name) (quote read_file))
          (perform_read_file wq args w)
        (if (sym_eq (qn_name name) (quote read_dir))
          (perform_read_dir wq args w)
        (if (sym_eq (qn_name name) (quote write)) (perform_write wq args w)
        (if (sym_eq (qn_name name) (quote write_file))
          (perform_write_file wq args w)
        (if (sym_eq (qn_name name) (quote write_line))
          (perform_write_line wq args w)
        (if (sym_eq (qn_name name) (quote exit)) (perform_exit wq args w)
        (if (sym_eq (qn_name name) (quote key_oracle)) (perform_key_oracle wq w)
        (Pair (Ctor (qn (quote Nil)) Nil) w))))))))))
       (_ (Pair (Ctor (qn (quote Nil)) Nil) w))))))

;; get_args performs no real I/O — it just hands back the stored argv slice and
;; bumps the clock by one (matching the extern's clock axiom).
(fn perform_get_args ((wq QName) (app_args (List (List Int))) (w World))
  (Pair Expr World)
  (match w
    ((World c)
     (Pair
       (encode_pair
         (encode_arglist app_args)
         (Ctor wq (Cons (IntLit (+ c 1)) Nil)))
       (World (+ c 1))))))

;; key_oracle now THREADS the World (clock-locked, input-traced in the contract):
;; the app-facing value is (Pair (Option Int) World), mirroring read_file. The
;; input trace itself is a proof-only observable (no runtime field) — read_key's
;; advanced clock is the only real effect.
(fn perform_key_oracle ((wq QName) (w World)) (Pair Expr World)
  (match (read_key w)
    ((Pair opt w1)
     (Pair (encode_pair (encode_opt_int opt) (encode_world wq w1)) w1))))

(fn perform_read_file ((wq QName) (args (List Expr)) (w World))
  (Pair Expr World)
  (match args
    ((Cons path_e _)
     (match (read_file (expr_to_intlist path_e) w)
       ((Pair opt w1)
        (Pair (encode_pair (encode_opt_bytes opt) (encode_world wq w1)) w1))))
    (_ (Pair (encode_pair (Ctor (qn (quote None)) Nil) (encode_world wq w)) w))))

(fn encode_bool ((b Bool)) Expr
  (if b (Ctor (qn (quote True)) Nil) (Ctor (qn (quote False)) Nil)))

;; read_dir: app-facing (Pair (Option (List (Pair Bool (List Int)))) World).
;; Each entry (Pair is_dir name) encodes to an object (Pair Bool (List Int)).
(fn encode_dirent_list ((es (List (Pair Bool (List Int))))) Expr
  (measure (struct es))
  (match es
    (Nil (Ctor (qn (quote Nil)) Nil))
    ((Cons e t)
     (match e
       ((Pair is_dir name)
        (Ctor
          (qn (quote Cons))
          (Cons
            (encode_pair (encode_bool is_dir) (intlist_to_expr name))
            (Cons (encode_dirent_list t) Nil))))))))

(fn encode_dirents ((o (Option (List (Pair Bool (List Int)))))) Expr
  (match o
    (None (Ctor (qn (quote None)) Nil))
    ((Some es) (Ctor (qn (quote Some)) (Cons (encode_dirent_list es) Nil)))))

(fn perform_read_dir ((wq QName) (args (List Expr)) (w World)) (Pair Expr World)
  (match args
    ((Cons path_e _)
     (match (read_dir (expr_to_intlist path_e) w)
       ((Pair opt w1)
        (Pair (encode_pair (encode_dirents opt) (encode_world wq w1)) w1))))
    (_ (Pair (encode_pair (Ctor (qn (quote None)) Nil) (encode_world wq w)) w))))

;; write_file: app-facing (Pair Bool World) — True = persisted.
(fn perform_write_file ((wq QName) (args (List Expr)) (w World))
  (Pair Expr World)
  (match args
    ((Cons path_e (Cons bytes_e _))
     (match (write_file (expr_to_intlist path_e) (expr_to_intlist bytes_e) w)
       ((Pair ok w1)
        (Pair (encode_pair (encode_bool ok) (encode_world wq w1)) w1))))
    (_ (Pair (encode_pair (encode_bool False) (encode_world wq w)) w))))

(fn perform_write ((wq QName) (args (List Expr)) (w World)) (Pair Expr World)
  (match args
    ((Cons bytes_e _)
     (match (write (expr_to_intlist bytes_e) w)
       ((World c) (Pair (Ctor wq (Cons (IntLit c) Nil)) (World c)))))
    (_ (Pair (encode_world wq w) w))))

(fn perform_write_line ((wq QName) (args (List Expr)) (w World))
  (Pair Expr World)
  (match args
    ((Cons bytes_e _)
     (match (write_line (expr_to_intlist bytes_e) w)
       ((World c) (Pair (Ctor wq (Cons (IntLit c) Nil)) (World c)))))
    (_ (Pair (encode_world wq w) w))))

;; exit performs a real process exit (never returns); the (World c) arm only
;; satisfies the type checker.
(fn perform_exit ((wq QName) (args (List Expr)) (w World)) (Pair Expr World)
  (match args
    ((Cons (IntLit code) _)
     (match (exit code w)
       ((World c) (Pair (encode_world wq (World c)) (World c)))))
    (_
      (match (exit 0 w)
        ((World c) (Pair (encode_world wq (World c)) (World c)))))))

;; -- run an app: evaluate `expr` (its `(main world0)`) with the env-machine,
;; which performs every effect inline and threads the real World. The app exits
;; via its own `exit` extern (a real process exit), so this normally never
;; returns there; if `main` instead yields a World, that final World is the
;; result. `expr`'s only free variables are its `(main …)`'s — none — so the
;; initial env is empty.
;; A run that RETURNS here must have yielded a World (apps normally never
;; return — they exit via their own `exit` extern). Anything else is a stuck
;; residual — e.g. a call to an extern outside `is_extern`'s vocabulary —
;; and used to fall out as a SILENT exit 0: automation read "success" where
;; nothing ran. Fail loudly instead.
(fn run_app
  ((m Module) (expr Expr) (wq QName) (app_args (List (List Int))) (w World))
  World
  (match m
    ((Module _ fns _ _ _)
     (let ((ixt (build_fn_trie (ix_fndefs fns 0))))
       (let ((eff (build_efftab fns ixt)))
         (let ((tab (build_fntab fns ixt eff)))
           (match
             (ev tab Nil (tre_of (tr2_expr expr ixt eff)) (Pair app_args wq) w)
             ((Pair r wf)
              (match r
                ((Ctor c _)
                 (if (sym_eq (qn_name c) (quote World)) wf (run_app_stuck wf)))
                (_ (run_app_stuck wf)))))))))))

(fn run_app_stuck ((w World)) World
  (exit
    4
    (write
      "error: app did not reduce to a World (stuck call — unknown extern?)\n"
      w)))

;; ---- the World wrapper -----------------------------------------------------
;;   eval <module.shard> <expr>      — evaluate an expression against a module
;;   eval run <app.shard> <args…>    — RUN a shard app (perform its effects)
(fn main ((w World)) World
  (match (get_args w)
    ((Pair args w1)
     (match args
       ((Cons a0 rest)
        (if (int_list_eq a0 "run") (run_main rest w1) (eval_main args w1)))
       (_ (exit 2 w1))))))  ; usage

;; the ENTRY FILE's main: the fn named main whose module path is the entry
;; file's modpath — or a PREFIX of it, because a `(sig fn main …)` in the
;; app's own directory interface REBINDS the def to the interface qname
;; (sig→def rebind; shardfmt is the live case). A prefix is exactly what
;; supplies_scope_ok admits, so this cannot pick up a foreign module's main
;; (the old flat build's first-loaded-wins hazard — the reason eval.shard
;; could never be imported into an app's closure).
(fn entry_main ((modpath (List Symbol)) (fds (List FnDef))) (Option FnDef)
  (measure (struct fds))
  (match fds
    (Nil None)
    ((Cons fd rest)
     (match fd
       ((FnDef n _ _ _)
        (if
          (if (sym_eq (qn_name n) (quote main))
            (path_prefix_sym (qn_mod n) modpath)
            False)
          (Some fd)
          (entry_main modpath rest)))))))

;; the app's World identity, read off its (already-resolved) main signature:
;; main : (World) -> World, and the resolver stamped that TCon with whatever
;; module binds World in the entry file — the one identity every world token
;; the run loop hands back must carry. Core fallback keeps this total (a main
;; with a non-TCon param is not runnable anyway — entry dispatch will stick).
(fn world_qname ((fd FnDef)) QName
  (match fd
    ((FnDef _ params _ _)
     (match params
       ((Cons (TCon q _) _) q)
       (_ (qn (quote World)))))))

;; run an app: resolve its import closure, build it (QUALIFIED, glob-fallback
;; — build_module_r), drive its `main` with the remaining argv as the app's
;; own arguments. The entry is the ENTRY FILE's main (its module path is
;; derived from the same path string the resolver saw), not any main in the
;; closure. This is THE standard path for running any shard app —
;; check.shard included.
(fn run_main ((rest (List (List Int))) (w World)) World
  (match rest
    ((Cons app_path app_args)
     (match (resolve_closure app_path True w)  ; True = RUN mode → load module impl bodies
       ((Pair sources w2)
        (match
          (build_module_r
            sources
            (Module Nil Nil Nil (FnTrie None Nil) Nil)
            (stdlib_ctors))
          (None (exit 1 (write "error: could not parse app\n" w2)))
          ((Some m)
           (match (entry_main (module_path_of app_path) (module_fndefs m))
             (None
               (exit 1 (write "error: app entry file defines no main\n" w2)))
             ((Some mainfd)
              (match mainfd
                ((FnDef mq _ _ _)
                 (run_app
                   m
                   (Call
                     mq
                     (Cons
                       (Ctor (world_qname mainfd) (Cons (IntLit 0) Nil))
                       Nil))
                   (world_qname mainfd)
                   app_args
                   w2))))))))))
    (_ (exit 2 w))))  ; usage: need app path

(fn eval_main ((args (List (List Int))) (w World)) World
  (match args
    ((Cons module_path (Cons expr_str _))
     (match (resolve_closure module_path True w)  ; True = RUN mode → load module impl bodies
       ((Pair sources w2) (exit 0 (write (eval_run sources expr_str) w2)))))
    (_ (exit 2 w))))  ; usage: need 2 args
