;;; trace.shard — the proof-spine tracer / failure diagnostics, in shard.
;;;
;;; This is the UNTRUSTED diagnostic layer that explains a FAILED claim: it
;;; renders the goal/premises and walks the non-branching spine of a Proof
;;; (Steps, RewriteWith), replaying each level via the kernel's OWN fns
;;; (apply_step / resolve_eq / apply_rewrite_with_env / dbg_*_subgoal /
;;; check_sequent) and rendering the sequent equation at every depth, so a
;;; deep nested failure is visible instead of just the outer finisher's entry
;;; state. It adds NO trusted code — only orchestration + rendering.
;;;
;;; Originally mirrored the (now-deleted) Rust bin/check.rs diagnostics; it has
;;; since grown past them: have JUSTIFICATIONS and RewriteWith OBLIGATIONS are
;;; checked and the failing sub-proof descended into (they used to be invisible
;;; — the spine traced green while a sub-proof was the failure), Absurd is
;;; replayed, and every failure site dumps the in-scope premises and hyps with
;;; their positional indices (see examples/tracer_demo.shard for the shapes).
;;; Runs under NATIVE eval in the eval module (kernel fns + toolchain), like
;;; the rest of the driver.

;; ---- byte/string helpers --------------------------------------------------
;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "expr_size.shard")  ; size / size_list — the render_* measure
(import "module.shard")
(import "proof.shard")
(import "proof_size.shard")  ; proof_size / case_list_size — the trace SCC measure
(import "checker.shard")
(import "types.shard")
(import "reduce.shard")
(import "lia.shard")
(import "farkas.shard")
(use (:: kernel term *))
(use (:: kernel expr_size *))
(use (:: kernel module *))
(use (:: kernel proof *))
(use (:: kernel proof_size *))
(use (:: kernel checker *))
(use (:: kernel types *))
(use (:: kernel reduce *))
(use (:: kernel lia *))
(use (:: kernel farkas *))

;; (append_int / show_nat / show_int — the shared char helpers — live in
;; term.shard.)
(fn append_lines ((xs (List (List Int))) (ys (List (List Int))))
  (List (List Int))
  (measure (struct xs))
  (match xs
    (Nil ys)
    ((Cons h t) (Cons h (append_lines t ys)))))

;; "  " repeated depth times (the nesting indent).
(fn mk_ind ((depth Int)) (List Int)
  ;; measure: depth, descending by 1; the (lt depth 1)=False guard gives depth>=1.
  (measure depth (by farkas (list 1 0)) (by farkas (list 1 1)))
  (if (lt depth 1) Nil (append_int "  " (mk_ind (- depth 1)))))

;; join lines with '\n' (10) between them (no trailing newline).
(fn join_lines ((ls (List (List Int)))) (List Int)
  (measure (struct ls))
  (match ls
    (Nil Nil)
    ((Cons l rest)
     (match rest
       (Nil l)
       (_ (append_int l (Cons 10 (join_lines rest))))))))

;; prepend the failure-detail's 6-space indent to every line.
(fn indent6 ((ls (List (List Int)))) (List (List Int))
  (measure (struct ls))
  (match ls
    (Nil Nil)
    ((Cons l rest) (Cons (append_int "      " l) (indent6 rest)))))

;; ---- totality measure for the render_* family (issue #1) ------------------
;; render_term / render_app / render_args / render_if are a 4-member MUTUAL SCC
;; that ad_sccs classifies AdUnresolved (render_app passes its list param
;; UNCHANGED to render_args — no single descending structural track), so they
;; carry explicit numeric (measure …) clauses below, citing the AST size
;; helpers `size`/`size_list` now homed in term.shard.

;; ---- term / equation rendering --------------------------------------------
;; Mirrors Rust render_term over the runtime Expr value world.
(fn render_term ((e Expr)) (List Int)
  (measure
    (size e)
    ;; site 1 — Ctor arm: (render_app (qn_name name) args). msr2 = size_list args
    ;; + 1 (render_app's measure), binder args, hyp0 = (= e (Ctor name args)).
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_ctor) lr lhs true ()))
      (by farkas (list 1 0)))
    (have (= (le 0 (size_list args)) True)
      (rewrite-with (lemma size_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 1)))
    ;; site 2 — Call arm: same shape, hyp0 = (= e (Call name args)).
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_call) lr lhs true ()))
      (by farkas (list 1 0)))
    (have (= (le 0 (size_list args)) True)
      (rewrite-with (lemma size_list_nonneg) lr lhs () () refl)
      (by farkas (list 1 0 1)))
    ;; site 3 — If arm: (render_if c t e2). msr2 = 1 + size c + size t + size e2
    ;; (render_if's measure), binders c t e2, hyp0 = (= e (If c t e2)).
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma size_if) lr lhs true ()))
      (by farkas (list 1 0)))
    (have (= (le 0 (size c)) True)
      (rewrite-with (lemma size_nonneg) lr lhs () () refl)
      (have (= (le 0 (size t)) True)
        (rewrite-with (lemma size_nonneg) lr lhs () () refl)
        (have (= (le 0 (size e2)) True)
          (rewrite-with (lemma size_nonneg) lr lhs () () refl)
          (by farkas (list 1 0 1 1 1))))))
  (match e
    ((FVar s) (chars_of_sym s))
    ((BVar k) (Cons 64 (show_int k)))  ; '@' k
    ((IntLit n) (show_int n))
    ((SymLit s) (Cons 39 (chars_of_sym s)))  ; '\'' s
    ((Ctor name args) (render_app (qn_name name) args))
    ((Call name args) (render_app (qn_name name) args))
    ((If c t e2) (render_if c t e2))
    ((Match _ _) "<Match>")
    ((Let _ _) "<Let>")))

;; "(head a b …)" — or bare "head" when no args.
(fn render_app ((name Symbol) (args (List Expr))) (List Int)
  (measure
    (+ (size_list args) 1)
    ;; site 1 — (render_args args). msr2 = size_list args (render_args measure),
    ;; args is render_app's PARAM (the _ arm binds nothing), so NO hyp.
    (by farkas (list 1))
    (steps ((rewrite (lemma size_list_nonneg) lr lhs true ())) refl))
  (match args
    (Nil (chars_of_sym name))
    (_
      (Cons
        40
        (append_int
          (chars_of_sym name)
          (append_int (render_args args) (Cons 41 Nil)))))))

(fn render_args ((args (List Expr))) (List Int)  ; " a b c"
  (measure
    (size_list args)
    ;; site 1 — (render_term a). msr2 = size a, binder a, hyp0 = (= args (Cons a
    ;; rest)). decrease needs size_list rest >= 0.
    (have (= (le 0 (size_list rest)) True)
      (rewrite-with (lemma size_list_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_list_cons) lr lhs true ()))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_nonneg) lr lhs true ())) refl)
    ;; site 2 — (render_args rest). msr2 = size_list rest, binder rest. decrease
    ;; needs size a >= 0.
    (have (= (le 0 (size a)) True)
      (rewrite-with (lemma size_nonneg) lr lhs () () refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma size_list_cons) lr lhs true ()))
        (by farkas (list 1 0 1))))
    (steps ((rewrite (lemma size_list_nonneg) lr lhs true ())) refl))
  (match args
    (Nil Nil)
    ((Cons a rest) (Cons 32 (append_int (render_term a) (render_args rest))))))

(fn render_if ((c Expr) (t Expr) (e Expr)) (List Int)
  (measure
    (+ 1 (+ (size c) (+ (size t) (size e))))
    ;; site 1 — (render_term c). msr2 = size c. decrease needs size t,size e >=0.
    (have (= (le 0 (size t)) True)
      (rewrite-with (lemma size_nonneg) lr lhs () () refl)
      (have (= (le 0 (size e)) True)
        (rewrite-with (lemma size_nonneg) lr lhs () () refl)
        (by farkas (list 1 1 1))))
    (steps ((rewrite (lemma size_nonneg) lr lhs true ())) refl)
    ;; site 2 — (render_term t). decrease needs size c,size e >= 0.
    (have (= (le 0 (size c)) True)
      (rewrite-with (lemma size_nonneg) lr lhs () () refl)
      (have (= (le 0 (size e)) True)
        (rewrite-with (lemma size_nonneg) lr lhs () () refl)
        (by farkas (list 1 1 1))))
    (steps ((rewrite (lemma size_nonneg) lr lhs true ())) refl)
    ;; site 3 — (render_term e). decrease needs size c,size t >= 0.
    (have (= (le 0 (size c)) True)
      (rewrite-with (lemma size_nonneg) lr lhs () () refl)
      (have (= (le 0 (size t)) True)
        (rewrite-with (lemma size_nonneg) lr lhs () () refl)
        (by farkas (list 1 1 1))))
    (steps ((rewrite (lemma size_nonneg) lr lhs true ())) refl))
  (append_int
    "(if "
    (append_int
      (render_term c)
      (append_int
        (Cons 32 Nil)
        (append_int
          (render_term t)
          (append_int (Cons 32 Nil) (append_int (render_term e) (Cons 41 Nil))))))))

;; an Equation as "lhs  =  rhs".
(fn render_eq ((eq Equation)) (List Int)
  (match eq
    ((Equation l r)
     (append_int (render_term l) (append_int "  =  " (render_term r))))))

;; ---- eqref / side / dir / step labels -------------------------------------
(fn render_eqref ((er EqRef)) (List Int)
  (match er
    ((Lemma s) (append_int "lemma " (chars_of_sym (qn_name s))))
    ((Premise k) (append_int "premise " (show_int k)))
    ((Hyp k) (append_int "hyp " (show_int k)))
    ((HypName s) (append_int "hyp " (chars_of_sym s)))
    ((PremiseName s) (append_int "premise " (chars_of_sym s)))))

(fn render_side ((sd Side)) (List Int)
  (match sd
    ((Lhs) "Lhs")
    ((Rhs) "Rhs")
    ((Both) "Both")))

(fn render_dir ((d Dir)) (List Int)
  (match d
    ((Lr) "Lr")
    ((Rl) "Rl")))

(fn step_label ((s Step)) (List Int)
  (match s
    ((Unfold fn sd)
     (append_int
       "Unfold "
       (append_int
         (chars_of_sym (qn_name fn))
         (append_int (Cons 32 Nil) (render_side sd)))))
    ((Simp sd) (append_int "Simp " (render_side sd)))
    ((Reduce sd) (append_int "Reduce " (render_side sd)))
    ((Compute sd) (append_int "Compute " (render_side sd)))
    ((Rewrite er dir sd allocc insts)
     (append_int
       "Rewrite "
       (append_int
         (render_eqref er)
         (append_int
           (Cons 32 Nil)
           (append_int
             (render_dir dir)
             (append_int (Cons 32 Nil) (render_side sd)))))))
    ((Inspect) "Inspect")))

;; ---- failure-site context (the premises + hyps in scope) -------------------
;; Rendered ONLY at failure points (a failed step / rewrite / Refl / Absurd),
;; so the trace NAMES every positional index instead of making the author
;; probe for the stack shape. A ground hyp renders as its equation; an IH
;; (∀-binders and/or premises) is tagged with its shape.
(fn count_params ((ps (List Param))) Int
  (measure (struct ps))
  (match ps
    (Nil 0)
    ((Cons _ t) (+ 1 (count_params t)))))

(fn count_eqs ((es (List Equation))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons _ t) (+ 1 (count_eqs t)))))

;; ---------------------------------------------------------------------------
;; farkas slot table (QoL): a failing (by farkas CERT) renders the full
;; slot layout — the negated-goal constraint (slot 0 = G, whose SIGN picks
;; the refutation direction when the assumed constraint is an equality),
;; each premise's linear reading (or NOT LINEAR), and the supplied cert —
;; so a wrong vector is a table lookup, not a guessing loop.
;; ---------------------------------------------------------------------------

(fn fk_poly_term ((c Int) (a (Option Expr))) (List Int)
  (match a
    (None (show_int c))
    ((Some e) (append_int (show_int c) (append_int "*" (render_term e))))))

(fn fk_poly_run ((p (List (Pair Int (Option Expr)))) (first Bool)) (List Int)
  (measure (struct p))
  (match p
    (Nil (if first "0" ""))
    ((Cons (Pair c a) rest)
     (append_int
       (if first "" " + ")
       (append_int (fk_poly_term c a) (fk_poly_run rest False))))))

(fn fk_poly ((p (List (Pair Int (Option Expr))))) (List Int)
  (fk_poly_run (lia_canonical p) True))

(fn fk_constraint ((eq Equation)) (List Int)
  (match (premise_to_constraint eq)
    (None "NOT LINEAR (multiplier must be 0)")
    ((Some (Pair p needs_nonneg))
     (if needs_nonneg (append_int (fk_poly p) " >= 0   (mult >= 0)")
     (append_int (fk_poly p) " = 0   (mult any sign)")))))

(fn fk_slot_lines ((premises (List Equation)) (k Int) (depth Int))
  (List (List Int))
  (measure (struct premises))
  (match premises
    (Nil Nil)
    ((Cons eq rest)
     (Cons
       (append_int
         (mk_ind depth)
         (append_int
           "["
           (append_int
             (show_int (+ k 1))
             (append_int
               "] premise "
               (append_int
                 (show_int k)
                 (append_int
                   ":  "
                   (append_int
                     (fk_constraint eq)
                     (append_int "   — " (render_eq eq)))))))))
       (fk_slot_lines rest (+ k 1) depth)))))

(fn fk_goal_line ((goal Equation) (depth Int)) (List Int)
  (match (neg_goal_poly goal)
    ((Some (Pair np needs_nonneg))
     (append_int
       (mk_ind depth)
       (append_int
         "[0] G (negated goal):  "
         (append_int
           (fk_poly np)
           (if needs_nonneg " >= 0   (G must be >= 0)"
           " = 0   (G any sign — its SIGN picks the refutation direction)")))))
    (None
      (append_int
        (mk_ind depth)
        "[0] goal reads as a TWO-SIDED equality (int_eq = True, or no core order head) — cert = (list (G M0 …) (G M0 …)); list 1 refutes ¬(L<=R), list 2 refutes ¬(R<=L)"))))

(fn fk_ints ((xs (List Int))) (List Int)
  (measure (struct xs))
  (match xs
    (Nil "")
    ((Cons n rest)
     (append_int
       (show_int n)
       (append_int
         (match rest
           (Nil "")
           (_ " "))
         (fk_ints rest))))))

(fn fk_int_count ((xs (List Int))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ t) (+ 1 (fk_int_count t)))))

(fn fk_cert_line ((cert Cert) (nprem Int) (depth Int)) (List Int)
  (match cert
    ((Cert _ (CList items))
     (match (cd_ints items)
       ((Some ms)
        (append_int
          (mk_ind depth)
          (append_int
            "supplied cert: ("
            (append_int
              (fk_ints ms)
              (append_int
                ")  — "
                (append_int
                  (show_int (fk_int_count ms))
                  (append_int
                    " value(s) for "
                    (append_int (show_int (+ nprem 1)) " slot(s)"))))))))
       (None
         (append_int
           (mk_ind depth)
           "supplied cert: not a flat int list (only the two-sided eq goal takes (list LE GE))"))))
    (_ (append_int (mk_ind depth) "supplied cert: malformed payload"))))

(fn fk_fail_lines ((seq Sequent) (cert Cert) (depth Int)) (List (List Int))
  (match seq
    ((Sequent _ _ premises goal_eq)
     (Cons
       (append_int
         (mk_ind depth)
         "by farkas REJECTED — slot table (cert = (G M0 … Mk), slots in premise order):")
       (Cons
         (append_int (mk_ind depth) (append_int "goal:  " (render_eq goal_eq)))
         (Cons
           (fk_goal_line goal_eq depth)
           (append_lines
             (fk_slot_lines premises 0 depth)
             (Cons (fk_cert_line cert (count_eqs premises) depth) Nil))))))))

(fn render_hyp_goal ((g Goal)) (List Int)
  (match g
    ((Goal Nil Nil eq) (render_eq eq))
    ((Goal ps prems eq)
     (append_int
       "[∀ "
       (append_int
         (show_int (count_params ps))
         (append_int
           ", "
           (append_int
             (show_int (count_eqs prems))
             (append_int " prem]  " (render_eq eq)))))))))

(fn context_premise_lines ((ps (List Equation)) (i Int) (ind (List Int)))
  (List (List Int))
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons p rest)
     (Cons
       (append_int
         ind
         (append_int
           "premise "
           (append_int (show_int i) (append_int ":  " (render_eq p)))))
       (context_premise_lines rest (+ i 1) ind)))))

(fn context_hyp_lines ((hs (List Goal)) (i Int) (ind (List Int)))
  (List (List Int))
  (measure (struct hs))
  (match hs
    (Nil Nil)
    ((Cons h rest)
     (Cons
       (append_int
         ind
         (append_int
           "hyp "
           (append_int (show_int i) (append_int ":  " (render_hyp_goal h)))))
       (context_hyp_lines rest (+ i 1) ind)))))

(fn context_lines_h ((seq Sequent) (depth Int) (header (List Int)))
  (List (List Int))
  (match seq
    ((Sequent params hyps premises eq)
     (match
       (append_lines
         (context_premise_lines premises 0 (mk_ind (+ depth 1)))
         (context_hyp_lines hyps 0 (mk_ind (+ depth 1))))
       (Nil Nil)
       ((Cons l ls) (Cons (append_int (mk_ind depth) header) (Cons l ls)))))))

(fn context_lines ((seq Sequent) (depth Int)) (List (List Int))
  (context_lines_h seq depth "in scope at the failure:"))

;; ---- the tracer ------------------------------------------------------------
(fn seq_eq ((s Sequent)) Equation
  (match s
    ((Sequent params hyps premises eq) eq)))

;; What a replayed RewriteWith yields: the rewritten sequent, the match env
;; (binding the cited equation's pattern vars), and the cited premises opened
;; to the same FVar vocabulary — enough to rebuild every obligation subgoal
;; exactly as check_premise_proofs does.
;; RwTrace carries the REPLAY's own citation state (cited params, the
;; fresh pattern-var names, the openings) so the type-gate diagnosis can
;; reuse it. gen_fresh is unique per call — a gate that re-split the
;; cited params would mint NEW fresh names, find none of them in the
;; replay's match env, and report every captured binder as a dangling
;; pivot (the bogus blanket REJECTED that used to stop every trace at
;; the chain's first lemma rewrite-with).
(type RwTrace
  (RwTrace Sequent Env (List Equation) (List Param) (List Symbol) (List Expr)))

;; Replay one RewriteWith's rewrite to get the resulting sequent PLUS the
;; obligation ingredients, mirroring check_sequent's RewriteWith arm by
;; chaining the same kernel fns. None if any link fails (unresolved lemma,
;; no match, …).
(fn apply_rewrite_step
  ((m Module)
   (th Theory)
   (seq Sequent)
   (er EqRef)
   (dir Dir)
   (sd Side)
   (insts (List Inst)))
  (Option RwTrace)
  (match (resolve_eq er seq th)
    (None None)
    ((Some (Goal cited_params cited_premises cited_eq))
     (match (split_params_by_insts cited_params insts)
       ((Pair openings patvars)
        (let ((opening_fvars (reverse_exprs openings)))
          (let
            ((opened_eq (open_eq_with opening_fvars cited_eq))
             (opened_premises (open_eqs_with opening_fvars cited_premises)))
            (match seq
              ((Sequent params hyps premises goal_eq)
               (match (apply_rewrite_with_env patvars opened_eq dir sd goal_eq)
                 (None None)
                 ((Some (Pair env new_eq))
                  (Some
                    (RwTrace
                      (Sequent params hyps premises new_eq)
                      env
                      opened_premises
                      cited_params
                      patvars
                      openings)))))))))))))

;; ---- type-gate diagnosis (failure path ONLY) --------------------------------
;; The kernel collapses every step failure to None/False; these re-run the
;; checker's own gate fns to NAME the reason — same pattern as the word-fact
;; arm (shared checks, so the diagnosis cannot diverge from the verdict).

;; the first failing site's gate message across a multi-site rewrite.
(fn site_gate_msg
  ((m Module)
   (sparams (List Param))
   (cited_params (List Param))
   (pat_vars (List Symbol))
   (openings (List Expr))
   (envs (List Env)))
  (Option (List Int))
  (measure (struct envs))
  (match envs
    (Nil None)
    ((Cons env rest)
     (match (tc_check_site m sparams cited_params pat_vars openings env)
       ((Some msg) (Some msg))
       (None (site_gate_msg m sparams cited_params pat_vars openings rest))))))

;; why a (Rewrite …) STEP failed — mirrors apply_step's Rewrite arm link by
;; link: unresolved citation / conditional lemma / bad inst name / no match /
;; the citation TYPE GATE (tc_check_sites), whose message is recovered here.
(fn rewrite_fail_reason
  ((m Module)
   (th Theory)
   (seq Sequent)
   (er EqRef)
   (dir Dir)
   (side Side)
   (all Bool)
   (insts (List Inst)))
  (List Int)
  (match (resolve_eq er seq th)
    (None "unresolved citation")
    ((Some (Goal cited_params cited_premises cited_eq))
     (match cited_premises
       ((Cons _ _) "cited goal has premises — use rewrite-with")
       (Nil
         (if (all_insts_named insts cited_params)
           (match (split_params_by_insts cited_params insts)
             ((Pair openings pat_vars)
              (match
                (apply_rewrite
                  pat_vars
                  (open_eq_with (reverse_exprs openings) cited_eq)
                  dir
                  side
                  all
                  (seq_eq seq))
                (None "no match")
                ((Some (Pair envs _))
                 (match
                   (site_gate_msg
                     m
                     (seq_params seq)
                     cited_params
                     pat_vars
                     openings
                     envs)
                   ((Some msg) (append_int "TYPE GATE: " msg))
                   (None "no match"))))))
           "citation: an inst names a binder the cited goal does not have"))))))

;; render a qualified name: "(:: seg … name)".
(fn render_qn_segs ((segs (List Symbol))) (List Int)
  (measure (struct segs))
  (match segs
    (Nil Nil)
    ((Cons x rest)
     (append_int " " (append_int (chars_of_sym x) (render_qn_segs rest))))))

(fn render_qn ((q QName)) (List Int)
  (append_int
    "(::"
    (append_int
      (render_qn_segs (qn_mod q))
      (append_int " " (append_int (chars_of_sym (qn_name q)) ")")))))

;; collect heads in `e` whose NAME matches but whose qname differs — the
;; near-miss set for an unfold/rewrite that found "no match": two same-named
;; fns from different modules display identically as bare names, so without
;; this note the mismatch is invisible.
(fn near_miss_e ((target QName) (e Expr) (acc (List QName))) (List QName)
  (measure (struct e))
  (match e
    ((Call f args)
     (near_miss_list
       target
       args
       (if (sym_eq (qn_name f) (qn_name target))
         (if (qname_eq f target) acc (Cons f acc))
         acc)))
    ((Ctor c args) (near_miss_list target args acc))
    ((If c t el)
     (near_miss_e target el (near_miss_e target t (near_miss_e target c acc))))
    ((Match scrut arms)
     (near_miss_arms target arms (near_miss_e target scrut acc)))
    ((Let binds body)
     (near_miss_e target body (near_miss_list target binds acc)))
    (_ acc)))

(fn near_miss_list ((target QName) (es (List Expr)) (acc (List QName)))
  (List QName)
  (measure (struct es))
  (match es
    (Nil acc)
    ((Cons h rest) (near_miss_list target rest (near_miss_e target h acc)))))

(fn near_miss_arms ((target QName) (arms (List Arm)) (acc (List QName)))
  (List QName)
  (measure (struct arms))
  (match arms
    (Nil acc)
    ((Cons (Arm _ b) rest)
     (near_miss_arms target rest (near_miss_e target b acc)))))

;; Does a Call to `target` occur ANYWHERE in `e` — including the positions
;; unfold cannot reach (Match arm bodies, Let). Consulted only after
;; unfold_one already failed, so a hit means the call sits where unfold
;; cannot fire it (or an arity-mismatched call site).
(fn has_call_e ((target QName) (e Expr)) Bool
  (measure (struct e))
  (match e
    ((Call f args) (if (qname_eq f target) True (has_call_list target args)))
    ((Ctor c args) (has_call_list target args))
    ((If c t el)
     (if (has_call_e target c) True
     (if (has_call_e target t) True
     (has_call_e target el))))
    ((Match scrut arms)
     (if (has_call_e target scrut) True (has_call_arms target arms)))
    ((Let binds body)
     (if (has_call_list target binds) True (has_call_e target body)))
    (_ False)))

(fn has_call_list ((target QName) (es (List Expr))) Bool
  (measure (struct es))
  (match es
    (Nil False)
    ((Cons h t) (if (has_call_e target h) True (has_call_list target t)))))

(fn has_call_arms ((target QName) (arms (List Arm))) Bool
  (measure (struct arms))
  (match arms
    (Nil False)
    ((Cons (Arm _ b) rest)
     (if (has_call_e target b) True (has_call_arms target rest)))))

(fn render_near_misses ((qs (List QName))) (List Int)
  (match qs
    (Nil Nil)
    ((Cons q rest)
     (append_int
       "; NOTE: the goal contains same-named "
       (append_int (render_qn q) " — a DIFFERENT identity")))))

(fn unfold_side_expr ((side Side) (eq Equation)) Expr
  (match eq
    ((Equation l r)
     (match side
       ((Rhs) r)
       (_ l)))))

(fn unfold_fail_reason ((m Module) (seq Sequent) (fname QName) (side Side))
  (List Int)
  (match m
    ((Module _ _ _ trie _)
     (match (trie_lookup fname trie)
       (None
         (append_int
           "target "
           (append_int
             (render_qn fname)
             (append_int
               " is not a defined fn (a sig without a body, or resolution picked another identity)"
               (render_near_misses
                 (near_miss_e fname (unfold_side_expr side (seq_eq seq)) Nil))))))
       ((Some _)
        (if (has_call_e fname (unfold_side_expr side (seq_eq seq)))
          (append_int
            (render_qn fname)
            " IS called on that side, but only where unfold cannot reach (a match ARM body or let — scrutinees are reachable; or an arity-mismatched call site) — rewrite with a have-equation instead")
          (append_int
            "no "
            (append_int
              (render_qn fname)
              (append_int
                " call on that side"
                (render_near_misses
                  (near_miss_e fname (unfold_side_expr side (seq_eq seq)) Nil)))))))))))

(fn step_fail_reason ((m Module) (th Theory) (seq Sequent) (s Step)) (List Int)
  (match s
    ((Rewrite er dir side all insts)
     (rewrite_fail_reason m th seq er dir side all insts))
    ((Unfold fname side) (unfold_fail_reason m seq fname side))
    (_ "no match")))

;; the checker's RewriteWith citation gates, re-run on a SUCCESSFUL replay
;; (apply_rewrite_step doesn't gate): Some msg = check_sequent rejects this
;; rewrite even though the match itself succeeded.
(fn rw_cite_gate
  ((m Module)
   (seq Sequent)
   (insts (List Inst))
   (cited_params (List Param))
   (pat_vars (List Symbol))
   (openings (List Expr))
   (env Env))
  (Option (List Int))
  (if (all_insts_named insts cited_params)
    (match seq
      ((Sequent s_params _ _ _)
       (tc_check_site m s_params cited_params pat_vars openings env)))
    (Some "citation: an inst names a binder the cited goal does not have")))

;; Check each RewriteWith obligation (the cited equation's premises at the
;; match instantiation) and DESCEND into the failing one — passing obligations
;; stay silent (cites are dense; only failures matter). Arity mismatches,
;; which the checker rejects without detail, are named too. Untrusted: only
;; re-runs the trusted check_sequent + renders, like the branch tracers.
(fn trace_obligations
  ((m Module)
   (th Theory)
   (seq Sequent)
   (env Env)
   (cps (List Equation))
   (proofs (List Proof))
   (er EqRef)
   (k Int)
   (depth Int)
   (verbose Bool))
  (List (List Int))
  ;; Match `proofs` (the measure variable) in the OUTER position so the
  ;; recursion's size drop on (proof_list_size proofs) is visible to the gate
  ;; from the scrutinee's own destructuring (mirrors check_premise_proofs).
  ;; `cps` shrinks in lockstep; the truth table is unchanged.
  (measure (proof_list_size proofs))
  (match proofs
    (Nil
      (match cps
        (Nil Nil)
        ((Cons cp _)
         (Cons
           (append_int
             (mk_ind depth)
             (append_int
               "rewrite ("
               (append_int
                 (render_eqref er)
                 (append_int
                   "): missing sub-proof for obligation "
                   (append_int
                     (show_int k)
                     (append_int ":  " (render_eq (subst_eq env cp))))))))
           Nil))))
    ((Cons pf pf_rest)
     (match cps
       (Nil
         (Cons
           (append_int
             (mk_ind depth)
             (append_int
               "rewrite ("
               (append_int
                 (render_eqref er)
                 "): too many obligation sub-proofs")))
           Nil))
       ((Cons cp cp_rest)
        (match seq
          ((Sequent s_params s_hyps s_premises _)
           (let
             ((sub_seq (Sequent s_params s_hyps s_premises (subst_eq env cp))))
             (append_lines
               (if (check_sequent m th sub_seq pf) Nil
               (Cons
                 (append_int
                   (mk_ind depth)
                   (append_int
                     "obligation "
                     (append_int
                       (show_int k)
                       (append_int
                         " of rewrite ("
                         (append_int
                           (render_eqref er)
                           (append_int
                             "):  "
                             (append_int
                               (render_eq (seq_eq sub_seq))
                               "  FAILS  v v v")))))))
                 (trace_proof m th sub_seq pf (+ depth 1) verbose)))
               (trace_obligations
                 m
                 th
                 seq
                 env
                 cp_rest
                 pf_rest
                 er
                 (+ k 1)
                 depth
                 verbose))))))))))

;; Apply Steps one at a time from `cur`, emitting a line per step and stopping
;; at the first that fails to apply. Returns the final sequent (Some if all
;; applied) and the lines, in order.
(fn trace_steps
  ((m Module) (th Theory) (cur Sequent) (steps (List Step)) (i Int) (depth Int))
  (Pair (Option Sequent) (List (List Int)))
  (measure (struct steps))
  (match steps
    (Nil (Pair (Some cur) Nil))
    ((Cons s rest)
     (match (apply_step m th cur s)
       ((Some cur2)
        (let
          ((line
             (append_int
               (mk_ind depth)
               (append_int
                 "step "
                 (append_int
                   (show_int (+ i 1))
                   (append_int
                     " ["
                     (append_int
                       (step_label s)
                       (append_int "]  " (render_eq (seq_eq cur2)))))))))
           (ctx
             (match s
               ((Inspect) (context_lines_h cur2 depth "in scope here:"))
               (_ Nil))))
          (match (trace_steps m th cur2 rest (+ i 1) depth)
            ((Pair fin ls) (Pair fin (Cons line (append_lines ctx ls)))))))
       (None
         (Pair
           None
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "step "
                 (append_int
                   (show_int (+ i 1))
                   (append_int
                     " ["
                     (append_int
                       (step_label s)
                       (append_int
                         "]  FAILED to apply ("
                         (append_int (step_fail_reason m th cur s) ")")))))))
             (context_lines cur depth))))))))

;; Descend the proof spine, rendering the sequent equation at each level.
;; Branching proofs (Induct/Induct2) stop the walk; CaseOn/WfInduct recurse.
(fn trace_proof
  ((m Module) (th Theory) (seq Sequent) (pf Proof) (depth Int) (verbose Bool))
  (List (List Int))
  (measure (proof_size pf))
  (match pf
    ((Admit)
     (Cons
       (append_int (mk_ind depth) "ADMIT: accepted WITHOUT PROOF (unsound)")
       Nil))
    ((Refl)
     (match (seq_eq seq)
       ((Equation l r)
        (if (expr_eq l r)
          (Cons (append_int (mk_ind depth) "Refl: closes (lhs = rhs)") Nil)
          (Cons
            (append_int (mk_ind depth) "Refl: does NOT close — lhs ≠ rhs:")
            (Cons
              (append_int (mk_ind depth) (append_int "  lhs  " (render_term l)))
              (Cons
                (append_int
                  (mk_ind depth)
                  (append_int "  rhs  " (render_term r)))
                (context_lines seq depth))))))))
    ((Steps steps finisher)
     (match (trace_steps m th seq steps 0 depth)
       ((Pair (Some cur) ls)
        (append_lines ls (trace_proof m th cur finisher depth verbose)))
       ((Pair None ls) ls)))
    ((RewriteWith er dir sd insts prems cont)
     (match (apply_rewrite_step m th seq er dir sd insts)
       ((Some (RwTrace seq2 env opened_premises cited_params pat_vars openings))
        ;; the replay matched — but the checker still gates the citation's
        ;; bindings (insts + captures) by type. A gated rewrite must trace
        ;; as the REJECTION it is, not as a successful rewrite.
        (match (rw_cite_gate m seq insts cited_params pat_vars openings env)
          ((Some msg)
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "rewrite ("
                 (append_int
                   (render_eqref er)
                   (append_int ") REJECTED by the TYPE GATE: " msg))))
             (context_lines seq depth)))
          (None
            (Cons
              (append_int
                (mk_ind depth)
                (append_int
                  "after rewrite ("
                  (append_int
                    (render_eqref er)
                    (append_int "):  " (render_eq (seq_eq seq2))))))
              (append_lines
                (trace_obligations
                  m
                  th
                  seq
                  env
                  opened_premises
                  prems
                  er
                  0
                  (+ depth 1)
                  verbose)
                (trace_proof m th seq2 cont (+ depth 1) verbose))))))
       (None
         (Cons
           (append_int
             (mk_ind depth)
             (append_int
               "rewrite ("
               (append_int
                 (render_eqref er)
                 ") did NOT apply (unresolved lemma or no match)")))
           (context_lines seq depth)))))
    ((ByTheory name cert)
     ;; replay the decision procedure (untrusted, like every re-check
     ;; here). A failing farkas renders its slot table; other theories
     ;; at least say REJECTED instead of going silent.
     (if (check_sequent m th seq (ByTheory name cert))
       (Cons
         (append_int
           (mk_ind depth)
           (append_int "by " (append_int (chars_of_sym name) " — ok")))
         Nil)
     (if (sym_eq name (quote farkas)) (fk_fail_lines seq cert depth)
     (Cons
       (append_int
         (mk_ind depth)
         (append_int
           "by "
           (append_int
             (chars_of_sym name)
             " — REJECTED (decision procedure says no)")))
       (context_lines seq depth)))))
    ((WfInduct measure sub)
     ;; do_wf_induct's gate first: a non-Int measure is a REJECTION.
     (match (tc_check_int_expr m (seq_params seq) measure "wf-induct measure")
       ((Some msg)
        (Cons
          (append_int
            (mk_ind depth)
            (append_int "wf-induct — REJECTED by the TYPE GATE: " msg))
          (context_lines seq depth)))
       (None
         (Cons
           (append_int (mk_ind depth) "WfInduct subgoal (IH at Hyp 0):")
           (trace_proof
             m
             th
             (build_wf_subgoal seq measure)
             sub
             (+ depth 1)
             verbose)))))
    ((SubtermInduct var sub)
     ;; do_subterm_induct's gate first: var must be a ∀-param of a datatype.
     (match (subterm_param_type var (seq_params seq))
       (None
         (Cons
           (append_int
             (mk_ind depth)
             "subterm-induct — REJECTED (var is not a goal parameter)")
           (context_lines seq depth)))
       ((Some ty)
        (if (subterm_is_datatype ty m)
          (Cons
            (append_int (mk_ind depth) "SubtermInduct subgoal (IH at Hyp 0):")
            (trace_proof
              m
              th
              (build_subterm_subgoal seq var)
              sub
              (+ depth 1)
              verbose))
          (Cons
            (append_int
              (mk_ind depth)
              "subterm-induct — REJECTED (var type is not an inductive datatype)")
            (context_lines seq depth))))))
    ((Below)
     (if (do_below m seq)
       (Cons
         (append_int
           (mk_ind depth)
           "below — closes (a is a strict structural subterm of x)")
         Nil)
       (Cons
         (append_int
           (mk_ind depth)
           "below — does NOT close (goal not (subterm_below a x)=True, or a is not a strict subterm of x)")
         (context_lines seq depth))))
    ((CaseOn scrut ty cases)
     ;; do_case_on's gates first: an unknown type, or a scrutinee that is
     ;; not a ty value, is a REJECTION (every case-hyp would be absurd) —
     ;; not a per-case rebuild failure.
     (match (lookup_typedef ty m)
       (None
         (Cons
           (append_int
             (mk_ind depth)
             (append_int
               "case-on — REJECTED (unknown type "
               (append_int (chars_of_sym (qn_name ty)) ")")))
           (context_lines seq depth)))
       ((Some (TypeDef _ tparams _ _))
        (match (tc_scrut_targs m (seq_params seq) scrut ty tparams)
          (None
            (Cons
              (append_int
                (mk_ind depth)
                (append_int
                  "case-on — REJECTED by the TYPE GATE (scrutinee is not a "
                  (append_int (chars_of_sym (qn_name ty)) " value)")))
              (context_lines seq depth)))
          ((Some _) (trace_cases m th seq scrut ty cases depth verbose))))))
    ;; Induct setup is INLINED here (rather than a trace_induct forwarder) so the
    ;; only recursive edges are the direct iterator calls below — that keeps every
    ;; SCC edge an honest size drop on (proof_size pf). Mirrors check_sequent's
    ;; Induct arm + the check_induct_exhaustive / check_induct_proofs split.
    ((Induct var cases)
     ;; Pinpointing a failing induction case re-runs check_sequent per case
     ;; (~doubling the claim's cost) — fine when FOCUSED to debug (verbose), too
     ;; expensive for a full run, so non-verbose keeps the cheap one-liner.
     (if verbose
       (match seq
         ((Sequent params _ _ _)
          (match (find_param var params)
            (None
              (Cons
                (append_int
                  (mk_ind depth)
                  "Induct — induction variable not in scope")
                Nil))
            ((Some (Param _ var_type))
             (match (type_head var_type)
               (None
                 (Cons
                   (append_int
                     (mk_ind depth)
                     "Induct — variable has a type-variable type")
                   Nil))
               ((Some (Pair tname targs))
                (match (lookup_typedef tname m)
                  (None
                    (Cons
                      (append_int (mk_ind depth) "Induct — unknown datatype")
                      Nil))
                  ((Some (TypeDef _ tparams ctors _))
                   (append_lines
                     (trace_induct_proofs
                       m
                       th
                       seq
                       var
                       var_type
                       (zip_pairs tparams targs)
                       ctors
                       cases
                       depth
                       verbose)
                     (trace_induct_missing ctors cases depth))))))))))
       (Cons
         (append_int
           (mk_ind depth)
           "Induct — branching proof (focus this claim to trace its cases)")
         Nil)))
    ((Induct2 var cases)
     (Cons
       (append_int
         (mk_ind depth)
         "Induct2 — branching proof; trace stops here")
       Nil))
    ((Absurd er)
     ;; Replay: resolve the cited fact, simp both sides, report. Mirrors
     ;; check_sequent's Absurd arm (ground facts only).
     (match (resolve_eq er seq th)
       (None
         (Cons
           (append_int
             (mk_ind depth)
             (append_int
               "Absurd ("
               (append_int (render_eqref er) ") does not resolve")))
           (context_lines seq depth)))
       ((Some (Goal Nil Nil (Equation l r)))
        (let ((sl (simp_expr m l)) (sr (simp_expr m r)))
          (if (head_clash sl sr)
            (Cons
              (append_int
                (mk_ind depth)
                (append_int
                  "Absurd ("
                  (append_int
                    (render_eqref er)
                    "): closes (head clash after simp)")))
              Nil)
            (Cons
              (append_int
                (mk_ind depth)
                (append_int
                  "Absurd ("
                  (append_int
                    (render_eqref er)
                    ") does NOT close — both sides simp to:")))
              (Cons
                (append_int
                  (mk_ind depth)
                  (append_int "  lhs  " (render_term sl)))
                (Cons
                  (append_int
                    (mk_ind depth)
                    (append_int "  rhs  " (render_term sr)))
                  (context_lines seq depth)))))))
       ((Some g)
        (Cons
          (append_int
            (mk_ind depth)
            (append_int
              "Absurd ("
              (append_int
                (render_eqref er)
                "): cited fact has binders/premises (unsupported)")))
          Nil))))
    ((FinSplit var lo hi cases)
     (if verbose (trace_fin_split m th seq var cases depth verbose)
     (Cons
       (append_int
         (mk_ind depth)
         "FinSplit — branching proof (focus this claim to trace its cases)")
       Nil)))
    ((Have eq pe pr)
     ;; do_have's TYPE GATE first (an ill-typed cut is rejected before its
     ;; justification is even looked at), then check the JUSTIFICATION (same
     ;; context, goal = the cut equation — exactly do_have's first
     ;; obligation). A broken justification is traced in place; only a sound
     ;; cut descends into the continuation.
     (match seq
       ((Sequent params hyps premises goal_eq)
        (match (tc_check_cut m params eq)
          ((Some msg)
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "have "
                 (append_int
                   (render_eq eq)
                   (append_int " — REJECTED by the TYPE GATE: " msg))))
             (context_lines seq depth)))
          (None
            (if (check_sequent m th (Sequent params hyps premises eq) pe)
              (Cons
                (append_int
                  (mk_ind depth)
                  (append_int
                    "have "
                    (append_int
                      (render_eq eq)
                      " — cut; continuing with it as the last premise:")))
                (trace_proof
                  m
                  th
                  (Sequent
                    params
                    hyps
                    (append_eqs premises (Cons eq Nil))
                    goal_eq)
                  pr
                  (+ depth 1)
                  verbose))
              (Cons
                (append_int
                  (mk_ind depth)
                  (append_int
                    "have "
                    (append_int (render_eq eq) "  JUSTIFICATION FAILS  v v v")))
                (trace_proof
                  m
                  th
                  (Sequent params hyps premises eq)
                  pe
                  (+ depth 1)
                  verbose))))))))
    ((RefineFact r ev pr)
     (match seq
       ((Sequent params hyps premises goal_eq)
        (match (refine_fact_checked m params r ev)
          (None
            (Cons
              (append_int
                (mk_ind depth)
                "refine-fact — REJECTED (not a refined type / term not of type R)")
              (context_lines seq depth)))
          ((Some fact)
           (Cons
             (append_int
               (mk_ind depth)
               "refine-fact — appending the invariant:")
             (append_lines
               (trace_fact_lines (Cons fact Nil) depth)
               (trace_proof
                 m
                 th
                 (Sequent
                   params
                   hyps
                   (append_eqs premises (Cons fact Nil))
                   goal_eq)
                 pr
                 (+ depth 1)
                 verbose))))))))
    ((DivFacts n d q pr)
     (match seq
       ((Sequent params hyps premises goal_eq)
        (match (div_facts_checked m params n d q)
          (None
            (Cons
              (append_int
                (mk_ind depth)
                "div-facts — REJECTED (divisor < 1 / quotient name captures / dividend not Int)")
              (context_lines seq depth)))
          ((Some (Pair params2 facts))
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "div-facts — quotient "
                 (append_int (chars_of_sym q) " added; appending facts:")))
             (append_lines
               (trace_fact_lines facts depth)
               (trace_proof
                 m
                 th
                 (Sequent params2 hyps (append_eqs premises facts) goal_eq)
                 pr
                 (+ depth 1)
                 verbose))))))))))

;; one "  + EQ" line per injected fact (word-fact / div-facts tracing).
(fn trace_fact_lines ((eqs (List Equation)) (depth Int)) (List (List Int))
  (measure (struct eqs))
  (match eqs
    (Nil Nil)
    ((Cons eq rest)
     (Cons
       (append_int (mk_ind depth) (append_int "  + " (render_eq eq)))
       (trace_fact_lines rest depth)))))

;; Branch-aware fin-split tracing: rebuild each value's subgoal (subst var:=v,
;; as do_fin_split does) and descend into the failing one. Untrusted: only
;; re-runs the trusted check_sequent + renders.
(fn trace_fin_split
  ((m Module)
   (th Theory)
   (seq Sequent)
   (var Symbol)
   (cases (List FinCase))
   (depth Int)
   (verbose Bool))
  (List (List Int))
  (measure (fincase_list_size cases))
  (match cases
    (Nil Nil)
    ((Cons (FinCase v sub) rest)
     (append_lines
       (let ((subgoal (fin_subgoal seq var v)))
         (if (check_sequent m th subgoal sub)
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "case "
                 (append_int
                   (chars_of_sym var)
                   (append_int " = " (append_int (show_int v) ": ok")))))
             Nil)
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "case "
                 (append_int
                   (chars_of_sym var)
                   (append_int
                     " = "
                     (append_int (show_int v) ":  FAILS  v v v")))))
             (trace_proof m th subgoal sub (+ depth 1) verbose))))
       (trace_fin_split m th seq var rest depth verbose)))))

;; the "case <scrut> = <ctor><tag>" header line (non-recursive; OUT of the SCC).
(fn caseon_line ((scrut Expr) (cname QName) (depth Int) (tag (List Int)))
  (List Int)
  (append_int
    (mk_ind depth)
    (append_int
      "case "
      (append_int
        (render_term scrut)
        (append_int " = " (append_int (chars_of_sym (qn_name cname)) tag))))))

;; CaseOn case tracing. Iterates the CASES (IN the SCC) and descends into each
;; sub-proof; the lone trace_proof edge is on the structurally-matched `pf`, so
;; the recursion is an honest size drop on (case_list_size cases) (mirrors the
;; checker's check_caseon_proofs). The per-case body is inlined in the two ctor
;; arms (was the trace_case / trace_case_full forwarders) precisely so `pf` is a
;; visible structural sub-proof.
(fn trace_cases
  ((m Module)
   (th Theory)
   (seq Sequent)
   (scrut Expr)
   (ty QName)
   (cases (List Case))
   (depth Int)
   (verbose Bool))
  (List (List Int))
  (measure (case_list_size cases))
  (match cases
    (Nil Nil)
    ((Cons (Case cname pf) rest)
     (append_lines
       (match (dbg_caseon_subgoal m seq scrut ty cname Nil)
         (None
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "case "
                 (append_int
                   (chars_of_sym (qn_name cname))
                   ": could not rebuild subgoal")))
             Nil))
         ((Some subgoal)
          (if (check_sequent m th subgoal pf)
            (if verbose
              (Cons
                (caseon_line scrut cname depth ":")
                (trace_proof m th subgoal pf (+ depth 1) verbose))
              (Cons (caseon_line scrut cname depth ": ok") Nil))
            (Cons
              (caseon_line scrut cname depth ":  FAILS  v v v")
              (trace_proof m th subgoal pf (+ depth 1) verbose)))))
       (trace_cases m th seq scrut ty rest depth verbose)))
    ((Cons (CaseB cname names pf) rest)
     (append_lines
       (match (dbg_caseon_subgoal m seq scrut ty cname names)
         (None
           (Cons
             (append_int
               (mk_ind depth)
               (append_int
                 "case "
                 (append_int
                   (chars_of_sym (qn_name cname))
                   ": could not rebuild subgoal")))
             Nil))
         ((Some subgoal)
          (if (check_sequent m th subgoal pf)
            (if verbose
              (Cons
                (caseon_line scrut cname depth ":")
                (trace_proof m th subgoal pf (+ depth 1) verbose))
              (Cons (caseon_line scrut cname depth ": ok") Nil))
            (Cons
              (caseon_line scrut cname depth ":  FAILS  v v v")
              (trace_proof m th subgoal pf (+ depth 1) verbose)))))
       (trace_cases m th seq scrut ty rest depth verbose)))))

;; ---- branch-aware Induct tracing -------------------------------------------
;; Mirrors check_sequent's Induct arm (the setup is inlined into trace_proof) +
;; the checker's check_induct_exhaustive / check_induct_proofs split: the
;; proof-carrying recursion iterates the CASES (so each sub-proof is a visible
;; structural sub-proof ⇒ an honest (case_list_size cases) drop), while coverage
;; / MISSING reporting iterates the CTORS separately (structural, OUT of the
;; SCC). Instead of returning a Bool it check_sequents each case and DESCENDS
;; into a failing one, rendering its per-step trace; passing cases get an "ok".
;; Untrusted: it only re-runs the trusted check_sequent + renders.

;; the "case <ctor><tag>" line for an induction case (no scrutinee term).
(fn caseind_line ((cname QName) (depth Int) (tag (List Int))) (List Int)
  (append_int
    (mk_ind depth)
    (append_int "case " (append_int (chars_of_sym (qn_name cname)) tag))))

;; Iterate the CASES (IN the SCC): per case, look the ctor's field types up by
;; the case's own name (structural on ctors), rebuild its subgoal, check, and
;; descend into the failing one. A spurious case (ctor not in the type) is
;; ignored (its absence is not coverage — that's trace_induct_missing's job).
;; The per-case body is inlined in the two ctor arms so the lone trace_proof
;; edge is on the structurally-matched `pf`.
(fn trace_induct_proofs
  ((m Module)
   (th Theory)
   (seq Sequent)
   (var Symbol)
   (var_type Type)
   (type_env (List (Pair Symbol Type)))
   (ctors (List CtorDef))
   (cases (List Case))
   (depth Int)
   (verbose Bool))
  (List (List Int))
  (measure (case_list_size cases))
  (match cases
    (Nil Nil)
    ((Cons (Case cname pf) rest)
     (append_lines
       (match (find_ctor_fields cname ctors)
         (None Nil)  ; spurious case — coverage reported separately
         ((Some field_types)
          (let
            ((subgoal
               (build_induct_subgoal
                 seq
                 var
                 var_type
                 cname
                 Nil
                 (type_subst_list type_env field_types))))
            (if (check_sequent m th subgoal pf)
              (Cons (caseind_line cname depth ": ok") Nil)
              (Cons
                (caseind_line cname depth ":  FAILS  v v v")
                (trace_proof m th subgoal pf (+ depth 1) verbose))))))
       (trace_induct_proofs m th seq var var_type type_env ctors rest depth
         verbose)))
    ((Cons (CaseB cname names pf) rest)
     (append_lines
       (match (find_ctor_fields cname ctors)
         (None Nil)
         ((Some field_types)
          (let
            ((subgoal
               (build_induct_subgoal
                 seq
                 var
                 var_type
                 cname
                 names
                 (type_subst_list type_env field_types))))
            (if (check_sequent m th subgoal pf)
              (Cons (caseind_line cname depth ": ok") Nil)
              (Cons
                (caseind_line cname depth ":  FAILS  v v v")
                (trace_proof m th subgoal pf (+ depth 1) verbose))))))
       (trace_induct_proofs m th seq var var_type type_env ctors rest depth
         verbose)))))

;; Iterate the CTORS (structural, OUT of the SCC — never descends into a proof):
;; emit a "case <ctor>: MISSING" line for every ctor the author left uncovered.
(fn trace_induct_missing
  ((ctors (List CtorDef)) (cases (List Case)) (depth Int))
  (List (List Int))
  (measure (struct ctors))
  (match ctors
    (Nil Nil)
    ((Cons (CtorDef cname _) rest)
     (match (find_case cname cases)
       (None
         (Cons
           (caseind_line cname depth ": MISSING")
           (trace_induct_missing rest cases depth)))
       ((Some _) (trace_induct_missing rest cases depth))))))

;; ---- top-level entries -----------------------------------------------------
;; The multi-line indented diagnostic for a failed claim: the goal (with
;; premises), then the proof-spine trace. Mirrors build_failure_detail.
(fn failure_detail ((m Module) (th Theory) (seq Sequent) (pf Proof)) (List Int)
  (match seq
    ((Sequent params hyps premises eq)
     (join_lines
       (indent6
         (append_lines
           (append_lines
             (premise_lines premises)
             (Cons (append_int "goal:   " (render_eq eq)) Nil))
           (trace_proof m th seq pf 0 False)))))))

(fn premise_lines ((ps (List Equation))) (List (List Int))
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons p rest)
     (Cons (append_int "given:  " (render_eq p)) (premise_lines rest)))))

;; The full `--trace` block for one claim: the framing header, the goal
;; equation, the verbose per-step trace, and the closing rule. Mirrors the
;; Rust check.rs --trace printout (── trace: NAME ── / goal / lines / ──).
(fn trace_block ((m Module) (th Theory) (seq Sequent) (pf Proof) (name Symbol))
  (List Int)
  (join_lines
    (Cons
      (append_int "── trace: " (append_int (chars_of_sym name) " ──"))
      (Cons
        (append_int "  goal      " (render_eq (seq_eq seq)))
        (append_lines (trace_proof m th seq pf 0 True) (Cons "──" Nil))))))
