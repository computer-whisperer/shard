;; PROOF SIDECAR for kernel/reader.shard — see loader.shard "PROOF SIDECARS".
;; (proof-for NAME PROOF) entries replay deterministically at check time; the
;; checker NEVER searches. These are generated offline by proof-search tooling
;; and re-verified against the obligation the primary file declares (a stale or
;; wrong entry simply fails the gate). Measure-totality obligations are keyed by
;; the per-site synthetic name `<fn>#<site>#decrease|nonneg` (driver mc_site_key);
;; the fn carries a bare `(measure E)` clause whose proofs live here.

;; elab_arm — measure (size_sexpr s), one recursive site (elaborate bodyS).
;; site 0 decrease: premises 0,1 = (= s (SList (Cons patS (Cons bodyS Nil)))),
;; (= (elab_pat patS ctors) (Some (Pair pat names))); bodyS is a strict subterm,
;; patS appears positively, so it needs (le 0 (size_sexpr patS)) as a have.
(proof-for elab_arm#0#decrease
  (have (= (le 0 (size_sexpr patS)) True)
    (rewrite-with (lemma size_sexpr_nonneg) lr lhs () () refl)
    (steps ((rewrite (premise 0) lr lhs true ()) (simp lhs)) (by farkas (list 1 0 0 1)))))
(proof-for elab_arm#0#nonneg
  (steps ((rewrite (lemma size_sexpr_nonneg) lr lhs true ())) refl))
