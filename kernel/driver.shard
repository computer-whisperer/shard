;;; driver.shard — the checker driver, in shard.
;;;
;;; Ties the self-hosted front-end together: parse a file's decls
;;; (reader.shard), parse each goal/proof STRAIGHT to native kernel values
;;; (proof_reader.shard), lift Goal→Sequent, run the kernel's `check_sequent`,
;;; and thread the theory (a passing claim is admitted as `(Proven name goal)`
;;; so later claims can cite it). This is the loop that, in the Rust bootstrap,
;;; lived in `bin/check.rs::process_file`.
;;;
;;; Run via the NATIVE eval::eval (like the Rust checker itself), so
;;; check_sequent stays exactly as fast as native `check` — only the
;;; orchestration moved into shard.
;;;
;;; Named hypotheses `(hyp ih)` are resolved to positional form
;;; (desugar_proof_named, desugar.shard) on the native Proof before checking.
;;;
;;; `check_production` is the entry the DEFAULT `check` routes through: it
;;; takes the whole file list (imports first, then targets), processes each
;;; file's claims+axioms in source order, threads the theory across all of
;;; them, and returns a (List ClaimOutcome) the Rust harness renders as
;;; PASS/FAIL/AXIOM lines.

;; Goal → Sequent: a top-level claim has no in-scope hypotheses (hyps = Nil).
;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(import "proof.shard")
(import "checker.shard")
(import "desugar.shard")
(import "reader.shard")
(import "trace.shard")
(import "proof_reader.shard")               ; native proof-DSL → Goal/Proof

;; The ctor + type-name sets a proof-DSL claim is parsed against. ctors lets
;; `elaborate` tell a value constructor from an FVar in an object snippet;
;; type_names lets the goal reader tell a concrete 0-ary type from a type
;; variable. Int and Symbol are primitive type constructors with no TypeDef, so
;; they're prepended explicitly.
(fn module_ctors ((m Module)) (List Symbol)
  (typedef_ctors (module_typedefs m)))
(fn module_type_names ((m Module)) (List Symbol)
  (Cons (quote Int) (Cons (quote Symbol) (typedef_names (module_typedefs m)))))

(fn lift_sequent ((g Goal)) Sequent
  (match g ((Goal params premises eq) (Sequent params Nil premises eq))))

(fn goal_params ((g Goal)) (List Param) (match g ((Goal ps prems eq) ps)))

;; ===========================================================================
;; Production entry: per-claim outcomes in source order. This is the loop the
;; default `check` routes through (the Rust harness reports each outcome as a
;; PASS/FAIL/AXIOM line). Claims and axioms are processed interleaved as
;; written (parse_decls), threading the theory across the WHOLE file list
;; (imports first, then targets) so every citation — same-file, imported, or
;; axiom — resolves.
;; ===========================================================================

;; Each outcome carries a `trace` field: the `--trace` block for the claim, or
;; empty (Nil) when this claim isn't the trace target. The Rust harness prints
;; the block (if any) before the PASS/FAIL line.
(type ClaimOutcome
  (COPass  Symbol (List Int))                   ; name, trace-block
  (COFail  Symbol (List Int) (List Int))        ; name, diagnostic detail, trace-block
  (COAxiom Symbol))                             ; an axiom admitted without proof

;; theory threaded + PENDING requirements (name→goal, seeded by `requirement`,
;; consumed by `fulfills`) + outcomes accumulated in REVERSE (caller reverses).
;; A pending entry holds the requirement's NATIVE Goal — un-reflected once at
;; seed time (so a malformed goal fails at the contract, not at the distant
;; fulfillment), then reused directly by `fulfills`.
(type PendReq (PendReq Symbol Goal))
(type RunState (RunState Theory (List PendReq) (List ClaimOutcome)))

;; Look up a pending requirement's (already un-reflected) goal by name.
(fn lookup_req ((name Symbol) (pend (List PendReq))) (Option Goal)
  (match pend
    (Nil None)
    ((Cons (PendReq nm g) rest)
      (if (sym_eq nm name) (Some g) (lookup_req name rest)))))

;; Does `--trace target` want this claim traced? ('all matches everything.)
(fn want_trace ((name Symbol) (target Symbol)) Bool
  (if (sym_eq target (quote all)) True (sym_eq name target)))

(fn rev_outcomes ((xs (List ClaimOutcome)) (acc (List ClaimOutcome))) (List ClaimOutcome)
  (match xs
    (Nil acc)
    ((Cons h t) (rev_outcomes t (Cons h acc)))))

;; Process one file's decls in source order, threading the theory and
;; accumulating outcomes. A claim that passes is admitted as (Proven …); an
;; axiom is admitted as (Axiom …); both with the goal closed for citation.
;; the `--trace` block for claim `c` if it's the target, else Nil.
(fn claim_trace ((m Module) (th Theory) (g Goal) (p Proof) (name Symbol) (target Symbol)) (List Int)
  (if (want_trace name target) (trace_block m th (lift_sequent g) p name) Nil))

(fn run_decls ((m Module) (st RunState) (ds (List Decl)) (target Symbol)) RunState
  (match ds
    (Nil st)
    ((Cons d rest)
      (match st
        ((RunState th pend acc)
          (match d
            ;; (axiom NAME (goal …)): parse goal to native, admit without proof.
            ((DAxiom a)
              (match (parse_goal (ax_goal a) (module_ctors m) (module_type_names m))
                (None (run_decls m (RunState th pend (Cons (COFail (ax_name a) "could not parse axiom goal (proof DSL)" Nil) acc)) rest target))
                ((Some g)
                  (run_decls m
                    (RunState (TheoryCons (Axiom (ax_name a) (close_goal_for_storage g)) th)
                              pend
                              (Cons (COAxiom (ax_name a)) acc))
                    rest target))))
            ;; (claim NAME (goal …) PROOF): parse goal and proof STRAIGHT to
            ;; native via proof_reader, then resolve named hyps to positional
            ;; with desugar_proof_named, and check.
            ((DClaim nc)
              (match (parse_goal (claim_goal nc) (module_ctors m) (module_type_names m))
                (None (run_decls m (RunState th pend (Cons (COFail (claim_name nc) "could not parse goal (proof DSL)" Nil) acc)) rest target))
                ((Some g)
                  (match (parse_proof (claim_proof nc) (module_ctors m) (module_type_names m))
                    (None (run_decls m (RunState th pend (Cons (COFail (claim_name nc) "could not parse proof (proof DSL)" Nil) acc)) rest target))
                    ((Some p0)
                      (match (desugar_proof_named m (goal_params g) Nil p0)
                        (p
                      (if (check_sequent m th (lift_sequent g) p)
                          (run_decls m
                            (RunState (TheoryCons (Proven (claim_name nc) (close_goal_for_storage g)) th)
                                      pend
                                      (Cons (COPass (claim_name nc) (claim_trace m th g p (claim_name nc) target)) acc))
                            rest target)
                          (run_decls m
                            (RunState th pend
                                      (Cons (COFail (claim_name nc)
                                                    (failure_detail m th (lift_sequent g) p)
                                                    (claim_trace m th g p (claim_name nc) target)) acc))
                            rest target)))))))))
            ;; (requirement NAME (goal …)): parse the goal to native NOW
            ;; (validating it at the contract), seed it as a pending obligation.
            ((DReq r)
              (match (parse_goal (req_goal r) (module_ctors m) (module_type_names m))
                (None (run_decls m (RunState th pend (Cons (COFail (req_name r) "could not parse requirement goal (proof DSL)" Nil) acc)) rest target))
                ((Some g)
                  (run_decls m (RunState th (Cons (PendReq (req_name r) g) pend) acc) rest target))))
            ;; (fulfills NAME PROOF): look the goal up from the requirement (the
            ;; single source of truth — never restated here), parse the proof to
            ;; native, resolve named hyps (desugar_proof_named), check it.
            ((DFul fu)
              (match (lookup_req (ful_name fu) pend)
                (None (run_decls m (RunState th pend (Cons (COFail (ful_name fu) "no requirement with this name in scope (is the contract imported?)" Nil) acc)) rest target))
                ((Some g)
                  (match (parse_proof (ful_proof fu) (module_ctors m) (module_type_names m))
                    (None (run_decls m (RunState th pend (Cons (COFail (ful_name fu) "could not parse proof (proof DSL)" Nil) acc)) rest target))
                    ((Some p0)
                      (match (desugar_proof_named m (goal_params g) Nil p0)
                        (p
                      (if (check_sequent m th (lift_sequent g) p)
                          (run_decls m
                            (RunState (TheoryCons (Proven (ful_name fu) (close_goal_for_storage g)) th)
                                      pend
                                      (Cons (COPass (ful_name fu) (claim_trace m th g p (ful_name fu) target)) acc))
                            rest target)
                          (run_decls m
                            (RunState th pend
                                      (Cons (COFail (ful_name fu)
                                                    (failure_detail m th (lift_sequent g) p)
                                                    (claim_trace m th g p (ful_name fu) target)) acc))
                            rest target)))))))))))))))

;; Run a whole file list (imports first, then targets), threading theory.
;; An unparseable file is skipped (the Rust harness pre-validates parsing).
;; Each source is tagged `(Pair granted src)`: `granted` marks a dependency
;; module's INTERFACE (its requirements are admitted as axioms, not re-imposed
;; as obligations — see collect_decls, reader.shard).
(fn run_srcs ((m Module) (srcs (List (Pair Bool (List Int)))) (ctors (List Symbol)) (st RunState) (target Symbol)) RunState
  (match srcs
    (Nil st)
    ((Cons (Pair granted src) rest)
      (match (parse_decls src ctors granted)
        (None (run_srcs m rest ctors st target))
        ((Some ds) (run_srcs m rest ctors (run_decls m st ds target) target))))))

;; Production entry point: returns the per-claim/axiom outcomes (source order)
;; for the whole file list, checked against m from the empty theory. `target`
;; is the `--trace` claim name ('all for every claim, or a non-matching
;; sentinel for no tracing).
(fn check_production ((m Module) (srcs (List (Pair Bool (List Int)))) (ctors (List Symbol)) (target Symbol)) (List ClaimOutcome)
  (match (run_srcs m srcs ctors (RunState TheoryEmpty Nil Nil) target)
    ((RunState th pend acc) (rev_outcomes acc Nil))))

;; build_module only reads types/fns/externs (it skips claim/requirement/…), so
;; it neither needs nor sees the granted tag — strip to raw bytes for it.
(fn strip_granted ((srcs (List (Pair Bool (List Int))))) (List (List Int))
  (match srcs
    (Nil Nil)
    ((Cons (Pair _ s) rest) (Cons s (strip_granted rest)))))

;; Production entry that builds M IN SHARD. `build_module` (reader.shard) parses
;; each source's types/fns via the self-hosted reader and merges them onto
;; `seed` (the kernel's types), threading ctors from `base_ctors` (the kernel's
;; ctor names). The full ctor set for claim parsing is then derived from M
;; itself. This is the default `check` entry — M is no longer built by the Rust
;; loader; load.rs only parses the kernel + toolchain into the VM.
(fn check_production_src ((seed Module) (base_ctors (List Symbol)) (srcs (List (Pair Bool (List Int)))) (target Symbol)) (List ClaimOutcome)
  (match (build_module (strip_granted srcs) seed base_ctors)
    (None (Cons (COFail (quote __module__) "could not parse target module(s)" Nil) Nil))
    ((Some m)
      (check_production m srcs (typedef_ctors (module_typedefs m)) target))))
