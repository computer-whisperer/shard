;;; driver.shard — the checker driver, in shard.
;;;
;;; Ties the self-hosted front-end together: parse a file's decls
;;; (reader.shard), parse each goal/proof STRAIGHT to native kernel values
;;; (proof_reader.shard), lift Goal→Sequent, run the kernel's `check_sequent`,
;;; and thread the theory (a passing claim is admitted as `(Proven name goal)`
;;; so later claims can cite it). This is the loop that, in the Rust bootstrap,
;;; lived in `bin/check.rs::process_file`.
;;;
;;; Run via the NATIVE eval::eval (like the Rust checker itself), so
;;; check_sequent stays exactly as fast as native `check` — only the
;;; orchestration moved into shard.
;;;
;;; Named citations `(hyp ih)` / `(premise NAME)` / `(have NAME …)` are
;;; resolved to positional form at the s-expr level (ds_proof, desugar.shard)
;;; before each proof is parsed.
;;;
;;; `check_production` is the entry the DEFAULT `check` routes through: it
;;; takes the whole file list (imports first, then targets), processes each
;;; file's claims+axioms in source order, threads the theory across all of
;;; them, and returns a (List ClaimOutcome) the Rust harness renders as
;;; PASS/FAIL/AXIOM lines.

;; Goal → Sequent: a top-level claim has no in-scope hypotheses (hyps = Nil).
;; imports — the kernel files this module uses (dependency-tracked)
(import "stdlib.shard")
(import "term.shard")
(import "module.shard")
(import "proof.shard")
(import "checker.shard")
(import "desugar.shard")
(import "reader.shard")
(import "trace.shard")
(import "types.shard")  ; object-language type checking (report-only for now)
(import "proof_reader.shard")  ; native proof-DSL → Goal/Proof
(import "admit.shard")  ; definitional-admissibility analysis (issue #1, report-only)
(use (:: kernel term *))
(use (:: kernel module *))
(use (:: kernel proof *))
(use (:: kernel checker *))
(use (:: kernel desugar *))
(use (:: kernel reader *))
(use (:: kernel trace *))
(use (:: kernel types *))
(use (:: kernel proof_reader *))
(use (:: kernel admit *))

;; The ctor + type-name sets a proof-DSL claim is parsed against. ctors lets
;; `elaborate` tell a value constructor from an FVar in an object snippet;
;; type_names lets the goal reader tell a concrete 0-ary type from a type
;; variable. Int and Symbol are primitive type constructors with no TypeDef, so
;; they're prepended explicitly.
(fn module_ctors ((m Module)) (List Symbol) (typedef_ctors (module_typedefs m)))
(fn module_type_names ((m Module)) (List Symbol)
  (Cons (quote Int) (Cons (quote Symbol) (typedef_names (module_typedefs m)))))

(fn lift_sequent ((g Goal)) Sequent
  (match g
    ((Goal params premises eq) (Sequent params Nil premises eq))))

(fn goal_params ((g Goal)) (List Param)
  (match g
    ((Goal ps prems eq) ps)))

;; The goal's own premise count — the named-have desugarer's base index
;; (haves append AFTER the goal premises).
(fn eqs_len ((es (List Equation))) Int
  (measure (struct es))
  (match es
    (Nil 0)
    ((Cons _ t) (+ 1 (eqs_len t)))))

(fn goal_premise_count ((g Goal)) Int
  (match g
    ((Goal ps prems eq) (eqs_len prems))))

;; ===========================================================================
;; QUALIFIED-IDENTITY RESOLUTION for proof-DSL goals/proofs (Stage 2).
;;
;; proof_reader parses goals/proofs with everything tagged `core` (`qn`). The
;; module M they reason about now carries real module-paths (build_module_d's
;; resolver), so a goal's `Nat` / `True` / `int_of_nat` must be re-qualified to
;; MATCH M, or every find_typedef/find_ctor/fn-sig lookup (which compares by
;; qname_eq) fails. We resolve the embedded Expr/Type/Pat references (and the
;; module entities a proof STEP names — the fn it Unfolds, the type it CaseOns,
;; the ctor of each Case) against `module_resolve_env m`, reusing the reader's
;; tree-walkers. EqRef CITATIONS (Lemma names) are deliberately left at `core`:
;; the Theory keys claim names there too, so they still match — qualified
;; citations are Stage 4. (resolve_expr/_type/_pat/rhead live in reader.shard;
;; these proof-structure walkers live here, where proof.shard's types exist.)
;; ===========================================================================

(fn resolve_param ((env RCtx) (p Param)) Param
  (match p
    ((Param n t) (Param n (resolve_type env t)))))

(fn resolve_params ((env RCtx) (ps (List Param))) (List Param)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons h t) (Cons (resolve_param env h) (resolve_params env t)))))

(fn resolve_equation ((env RCtx) (eq Equation)) Equation
  (match eq
    ((Equation a b) (Equation (resolve_expr env a) (resolve_expr env b)))))

(fn resolve_equations ((env RCtx) (eqs (List Equation))) (List Equation)
  (measure (struct eqs))
  (match eqs
    (Nil Nil)
    ((Cons h t) (Cons (resolve_equation env h) (resolve_equations env t)))))

(fn resolve_goal ((env RCtx) (g Goal)) Goal
  (match g
    ((Goal ps prems concl)
     (Goal
       (resolve_params env ps)
       (resolve_equations env prems)
       (resolve_equation env concl)))))

(fn resolve_inst ((env RCtx) (i Inst)) Inst
  (match i
    ((Inst n e) (Inst n (resolve_expr env e)))))

(fn resolve_insts ((env RCtx) (is (List Inst))) (List Inst)
  (measure (struct is))
  (match is
    (Nil Nil)
    ((Cons h t) (Cons (resolve_inst env h) (resolve_insts env t)))))

;; Stage 4: a bare (lemma n) cite resolves through the SAME env discipline as
;; every other name (local > use-items; claims are module items), and the
;; (:: ...) form re-roots like any head. Unresolved stays core -> nothing is
;; admitted at core anymore, so a dangling cite fails its claim LOUDLY.
(fn resolve_eqref ((env RCtx) (er EqRef)) EqRef
  (match er
    ((Lemma q) (Lemma (rhead q env)))
    (_ er)))

(fn resolve_qnames ((env RCtx) (qs (List QName))) (List QName)
  (measure (struct qs))
  (match qs
    (Nil Nil)
    ((Cons h t) (Cons (rhead h env) (resolve_qnames env t)))))

(fn resolve_step ((env RCtx) (st Step)) Step
  (match st
    ((Unfold f side) (Unfold (rhead f env) side))
    ((Reduce side) st)
    ((Simp side stops) (Simp side (resolve_qnames env stops)))
    ((Compute side stops) (Compute side (resolve_qnames env stops)))
    ((Inspect) st)
    ((Rewrite eqref dir side occ insts)
     (Rewrite (resolve_eqref env eqref) dir side occ (resolve_insts env insts)))))

(fn resolve_steps ((env RCtx) (sts (List Step))) (List Step)
  (measure (struct sts))
  (match sts
    (Nil Nil)
    ((Cons h t) (Cons (resolve_step env h) (resolve_steps env t)))))

(fn resolve_proof ((env RCtx) (p Proof)) Proof
  (measure (struct p))
  (match p
    ((Refl) p)
    ((Admit) p)
    ((Steps steps pf) (Steps (resolve_steps env steps) (resolve_proof env pf)))
    ((Induct v cases) (Induct v (resolve_cases env cases)))
    ((CaseOn e ty cases)
     (CaseOn (resolve_expr env e) (rhead ty env) (resolve_cases env cases)))
    ((WfInduct measure pf)
     (WfInduct (resolve_expr env measure) (resolve_proof env pf)))
    ((SubtermInduct v pf) (SubtermInduct v (resolve_proof env pf)))
    ((Below) p)
    ((RewriteWith eqref dir side insts subs pf)
     (RewriteWith
       (resolve_eqref env eqref)
       dir
       side
       (resolve_insts env insts)
       (resolve_proofs env subs)
       (resolve_proof env pf)))
    ((Absurd eqref) (Absurd (resolve_eqref env eqref)))
    ;; ByTheory's Cert payload is theory-PRIVATE narrow data (e.g. farkas's
    ;; (List Int) multipliers), not object terms with module references — it is
    ;; matched as a narrow list by the backends, so resolving it as an Expr
    ;; would corrupt it. Leave it untouched.
    ((ByTheory th cert) p)
    ((FinSplit v lo hi fcs) (FinSplit v lo hi (resolve_fincases env fcs)))
    ((Have eq pf cont)
     (Have
       (resolve_equation env eq)
       (resolve_proof env pf)
       (resolve_proof env cont)))
    ((DivFacts e d q pf)
     (DivFacts (resolve_expr env e) d q (resolve_proof env pf)))
    ((RefineFact r ev pf)
     (RefineFact (rhead r env) (resolve_expr env ev) (resolve_proof env pf)))
    ((Inject er n pf) (Inject (resolve_eqref env er) n (resolve_proof env pf)))))

(fn resolve_proofs ((env RCtx) (ps (List Proof))) (List Proof)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons h t) (Cons (resolve_proof env h) (resolve_proofs env t)))))

(fn resolve_case ((env RCtx) (c Case)) Case
  (measure (struct c))
  (match c
    ((Case ctor names pf) (Case (rhead ctor env) names (resolve_proof env pf)))))

(fn resolve_cases ((env RCtx) (cs (List Case))) (List Case)
  (measure (struct cs))
  (match cs
    (Nil Nil)
    ((Cons h t) (Cons (resolve_case env h) (resolve_cases env t)))))

(fn resolve_fincase ((env RCtx) (fc FinCase)) FinCase
  (measure (struct fc))
  (match fc
    ((FinCase k pf) (FinCase k (resolve_proof env pf)))))

(fn resolve_fincases ((env RCtx) (fcs (List FinCase))) (List FinCase)
  (measure (struct fcs))
  (match fcs
    (Nil Nil)
    ((Cons h t) (Cons (resolve_fincase env h) (resolve_fincases env t)))))

;; parse-then-resolve: parse a goal/proof against M's ctor+type sets, then
;; re-qualify its module references to match M. The single seam every claim,
;; axiom, and requirement flows through.
(fn parse_goal_r ((m Module) (gctx RCtx) (s SExpr)) (Option Goal)
  (match (parse_goal s (module_ctors m) (module_type_names m))
    (None None)
    ((Some g) (Some (resolve_goal gctx g)))))

(fn parse_proof_r ((m Module) (gctx RCtx) (s SExpr)) (Option Proof)
  (match (parse_proof s (module_ctors m) (module_type_names m))
    (None None)
    ((Some p) (Some (resolve_proof gctx p)))))

;; ===========================================================================
;; Production entry: per-claim outcomes in source order. This is the loop the
;; default `check` routes through (the Rust harness reports each outcome as a
;; PASS/FAIL/AXIOM line). Claims and axioms are processed interleaved as
;; written (parse_decls), threading the theory across the WHOLE file list
;; (imports first, then targets) so every citation — same-file, imported, or
;; axiom — resolves.
;; ===========================================================================

;; Each outcome carries a `trace` field: the `--trace` block for the claim, or
;; empty (Nil) when this claim isn't the trace target. The Rust harness prints
;; the block (if any) before the PASS/FAIL line.
(type ClaimOutcome
  (COPass Symbol (List Int))  ; name, trace-block
  (COFail Symbol (List Int) (List Int))  ; name, diagnostic detail, trace-block
  (COAxiom Symbol)  ; an axiom admitted without proof
  (COAdmit Symbol (List Int))  ; (admit) in proof — UNSOUND, exit 3; + trace-block
  (COPending Symbol)  ; a requirement stated but never fulfilled in this closure
  (COBin Symbol Int Int)  ; a bin acceptance summary: name, required, met
  (COLib Symbol Int Int)  ; a lib acceptance summary: name, exports declared, implemented
  ;; COTypeFail: a type error from types.shard — a HARD failure. The decl is
  ;; rejected: an ill-typed axiom is not admitted, an ill-typed requirement is
  ;; not seeded, an ill-typed claim is not proof-checked. (The theory backends
  ;; are only sound for well-typed terms; see types.shard's header.)
  (COTypeFail Symbol (List Int))
  ;; COLedger: a bin's trust-ledger block, pre-rendered. Informative — it
  ;; bumps no counts; the acceptance-failing checks (trusts/externs/unmet)
  ;; stay separate COFail outcomes.
  (COLedger (List Int)))

;; theory threaded + PENDING requirements (name→goal, seeded by `requirement`,
;; consumed by `fulfills`) + outcomes accumulated in REVERSE (caller reverses).
;; A pending entry holds the requirement's NATIVE Goal — un-reflected once at
;; seed time (so a malformed goal fails at the contract, not at the distant
;; fulfillment), then reused directly by `fulfills`.
(type PendReq (PendReq QName Goal))

;; ---------------------------------------------------------------------------
;; Trust ledger — who cites whom. `(Lemma name)` is the ONLY cross-claim
;; citation form in the proof AST (Hyp/Premise are sequent-local and
;; no ByTheory backend reads the theory), so the citation set of an ACCEPTED
;; proof is exactly its syntactic Lemma mentions: every step of an accepted
;; proof ran, so every mention was resolved and used. cites_of_proof walks
;; the same desugared Proof value check_sequent verified.
;;
;; Entry kinds: 'claim | 'fulfills — interior, proven in this run;
;; 'operational | 'bridging | 'untagged — own axioms (this run's TCB);
;; 'granted — a granted interface's requirement (upstream-PROVEN);
;; 'upstream — a granted interface's axiom (upstream-TRUSTED);
;; 'kernel — an axiom AUTHORED in the kernel tree (kernel/facts.shard, the
;;   reviewed core-math set): the trust floor, exempt from (bin trusts)
;;   listing like the arith backend, rendered on its own ledger line.
;;   Driver-assigned (ax_kind_at), never surface syntax.
;; Focus-skipped decls record EMPTY cites — focus runs are unsound and
;; banner-marked anyway; the ledger is only meaningful on acceptance runs.
;; ---------------------------------------------------------------------------
(type LedgerEntry (LedgerEntry Symbol Symbol (List Symbol)))
; name, kind, direct cites

(fn cop_er ((er EqRef)) (List Symbol)
  (match er
    ((Lemma s) (Cons (qn_name s) Nil))  ; ledger keyed by local display name (Stage 4 qualifies)
    (_ Nil)))

(fn cop_step ((s Step)) (List Symbol)
  (match s
    ((Rewrite er _ _ _ _) (cop_er er))
    (_ Nil)))

(fn cop_steps ((ss (List Step))) (List Symbol)
  (measure (struct ss))
  (match ss
    (Nil Nil)
    ((Cons s rest) (sym_concat (cop_step s) (cop_steps rest)))))

(fn cites_of_proof ((p Proof)) (List Symbol)
  (measure (struct p))
  (match p
    ((Refl) Nil)
    ((Admit) Nil)
    ((Steps ss k) (sym_concat (cop_steps ss) (cites_of_proof k)))
    ((Induct _ cs) (cop_cases cs))
    ((CaseOn _ _ cs) (cop_cases cs))
    ((WfInduct _ k) (cites_of_proof k))
    ((SubtermInduct _ k) (cites_of_proof k))
    ((Below) Nil)
    ((RewriteWith er _ _ _ subs k)
     (sym_concat (cop_er er) (sym_concat (cop_proofs subs) (cites_of_proof k))))
    ((Absurd er) (cop_er er))
    ((ByTheory _ _) Nil)
    ((FinSplit _ lo hi fcs)
     (sym_concat (cop_er lo) (sym_concat (cop_er hi) (cop_fincases fcs))))
    ((Have _ pf k) (sym_concat (cites_of_proof pf) (cites_of_proof k)))
    ((DivFacts _ _ _ k) (cites_of_proof k))
    ((RefineFact _ _ k) (cites_of_proof k))
    ((Inject er _ k) (sym_concat (cop_er er) (cites_of_proof k)))))

(fn cop_proofs ((ps (List Proof))) (List Symbol)
  (measure (struct ps))
  (match ps
    (Nil Nil)
    ((Cons p rest) (sym_concat (cites_of_proof p) (cop_proofs rest)))))

(fn cop_cases ((cs (List Case))) (List Symbol)
  (measure (struct cs))
  (match cs
    (Nil Nil)
    ((Cons (Case _ _ p) rest) (sym_concat (cites_of_proof p) (cop_cases rest)))))

(fn cop_fincases ((fcs (List FinCase))) (List Symbol)
  (measure (struct fcs))
  (match fcs
    (Nil Nil)
    ((Cons (FinCase _ p) rest)
     (sym_concat (cites_of_proof p) (cop_fincases rest)))))

;; Does the (desugared) proof contain an (admit) anywhere? Decides ADMIT-vs-
;; PASS reporting: an admitted proof is ACCEPTED by check_sequent but must
;; never render as proven.
(fn proof_has_admit ((p Proof)) Bool
  (measure (struct p))
  (match p
    ((Refl) False)
    ((Admit) True)
    ((Steps _ k) (proof_has_admit k))
    ((Induct _ cs) (pha_cases cs))
    ((CaseOn _ _ cs) (pha_cases cs))
    ((WfInduct _ k) (proof_has_admit k))
    ((SubtermInduct _ k) (proof_has_admit k))
    ((Below) False)
    ((RewriteWith _ _ _ _ subs k)
     (if (pha_proofs subs) True (proof_has_admit k)))
    ((Absurd _) False)
    ((ByTheory _ _) False)
    ((FinSplit _ _ _ fcs) (pha_fincases fcs))
    ((Have _ pe k) (if (proof_has_admit pe) True (proof_has_admit k)))
    ((DivFacts _ _ _ k) (proof_has_admit k))
    ((RefineFact _ _ k) (proof_has_admit k))
    ((Inject _ _ k) (proof_has_admit k))))

(fn pha_proofs ((ps (List Proof))) Bool
  (measure (struct ps))
  (match ps
    (Nil False)
    ((Cons p rest) (if (proof_has_admit p) True (pha_proofs rest)))))

(fn pha_cases ((cs (List Case))) Bool
  (measure (struct cs))
  (match cs
    (Nil False)
    ((Cons (Case _ _ p) rest) (if (proof_has_admit p) True (pha_cases rest)))))

(fn pha_fincases ((fcs (List FinCase))) Bool
  (measure (struct fcs))
  (match fcs
    (Nil False)
    ((Cons (FinCase _ p) rest)
     (if (proof_has_admit p) True (pha_fincases rest)))))

;; Does the proof contain an (inspect) step anywhere? Such a proof gets its
;; trace block rendered REGARDLESS of trace mode (claim_trace), so the
;; tracer's at-the-inspect-point context dump always reaches the author —
;; and a committed (inspect) is loud in every corpus run.
(fn proof_has_inspect ((p Proof)) Bool
  (measure (struct p))
  (match p
    ((Refl) False)
    ((Admit) False)
    ((Steps ss k) (if (steps_have_inspect ss) True (proof_has_inspect k)))
    ((Induct _ cs) (phi_cases cs))
    ((CaseOn _ _ cs) (phi_cases cs))
    ((WfInduct _ k) (proof_has_inspect k))
    ((SubtermInduct _ k) (proof_has_inspect k))
    ((Below) False)
    ((RewriteWith _ _ _ _ subs k)
     (if (phi_proofs subs) True (proof_has_inspect k)))
    ((Absurd _) False)
    ((ByTheory _ _) False)
    ((FinSplit _ _ _ fcs) (phi_fincases fcs))
    ((Have _ pe k) (if (proof_has_inspect pe) True (proof_has_inspect k)))
    ((DivFacts _ _ _ k) (proof_has_inspect k))
    ((RefineFact _ _ k) (proof_has_inspect k))
    ((Inject _ _ k) (proof_has_inspect k))))

(fn steps_have_inspect ((ss (List Step))) Bool
  (measure (struct ss))
  (match ss
    (Nil False)
    ((Cons (Inspect) _) True)
    ((Cons _ rest) (steps_have_inspect rest))))

(fn phi_proofs ((ps (List Proof))) Bool
  (measure (struct ps))
  (match ps
    (Nil False)
    ((Cons p rest) (if (proof_has_inspect p) True (phi_proofs rest)))))

(fn phi_cases ((cs (List Case))) Bool
  (measure (struct cs))
  (match cs
    (Nil False)
    ((Cons (Case _ _ p) rest) (if (proof_has_inspect p) True (phi_cases rest)))))

(fn phi_fincases ((fcs (List FinCase))) Bool
  (measure (struct fcs))
  (match fcs
    (Nil False)
    ((Cons (FinCase _ p) rest)
     (if (proof_has_inspect p) True (phi_fincases rest)))))

;; PASS, unless the accepted proof leans on (admit) — then ADMIT, loudly.
(fn pass_or_admit ((name Symbol) (trace (List Int)) (p Proof)) ClaimOutcome
  (if (proof_has_admit p) (COAdmit name trace) (COPass name trace)))

(type RunState
  (RunState Theory (List PendReq) (List ClaimOutcome) (List LedgerEntry)))

;; Look up a pending requirement's (already un-reflected) goal by name.
;; Stage 4: a fulfills matches a requirement by bare name WITHIN ITS OWN
;; directory module (supplies_scope_ok -- the sig->def rule): the interface
;; declares, the impl supplies, both are ONE qname (the interface's).
(fn lookup_req ((name Symbol) (cur (List Symbol)) (pend (List PendReq)))
  (Option (Pair QName Goal))
  (measure (struct pend))
  (match pend
    (Nil None)
    ((Cons (PendReq q g) rest)
     (if (if (sym_eq (qn_name q) name) (supplies_scope_ok (qn_mod q) cur) False)
       (Some (Pair q g))
       (lookup_req name cur rest)))))

;; Drop the entry lookup_req matched: a requirement with a fulfills decl is
;; no longer PENDING — even when the fulfills FAILS (the FAIL line is the
;; louder report there). What is left at end of run had NO fulfills at all.
(fn remove_req ((name Symbol) (cur (List Symbol)) (pend (List PendReq)))
  (List PendReq)
  (measure (struct pend))
  (match pend
    (Nil Nil)
    ((Cons (PendReq q g) rest)
     (if (if (sym_eq (qn_name q) name) (supplies_scope_ok (qn_mod q) cur) False)
       rest
       (Cons (PendReq q g) (remove_req name cur rest))))))

;; Does `--trace target` want this claim traced? ('all matches everything.)
(fn want_trace ((name Symbol) (target Symbol)) Bool
  (if (sym_eq target (quote all)) True (sym_eq name target)))

(fn rev_outcomes ((xs (List ClaimOutcome)) (acc (List ClaimOutcome)))
  (List ClaimOutcome)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_outcomes t (Cons h acc)))))

;; The whole-module sweep (typedefs, externs/sigs, fn bodies) as outcomes.
(fn type_fail_outcomes ((ws (List (Pair Symbol (List Int)))))
  (List ClaimOutcome)
  (measure (struct ws))
  (match ws
    (Nil Nil)
    ((Cons (Pair name msg) rest)
     (Cons (COTypeFail name msg) (type_fail_outcomes rest)))))

;; Process one file's decls in source order, threading the theory and
;; accumulating outcomes. A claim that passes is admitted as (Proven …); an
;; axiom is admitted as (Axiom …); both with the goal closed for citation.
;; the `--trace` block for claim `c` if it's the target, else Nil.
(fn claim_trace
  ((m Module) (th Theory) (g Goal) (p Proof) (name Symbol) (target Symbol))
  (List Int)
  (if (want_trace name target)
    (trace_block m th (lift_sequent g) p name)
    ;; an (inspect) in the proof forces the trace block — that's how the
    ;; tracer's at-the-inspect-point sequent dump reaches the author.
    (if (proof_has_inspect p) (trace_block m th (lift_sequent g) p name) Nil)))

;; FOCUS MODE (dev aid). When `focus` is a specific claim name (not the
;; `__all__` sentinel), every OTHER claim/fulfills is admitted as `Proven`
;; WITHOUT running check_sequent — its goal is parsed and threaded into the
;; theory (so citations still resolve) but its proof is trusted, and it emits
;; no outcome line. Only the focus claim is really checked (and traced, since
;; check.shard sets target = focus). This turns a heavy whole-file run into
;; "parse everything + check one claim" — seconds instead of minutes — for
;; iterating on a single proof. It is intentionally UNSOUND (it admits the
;; skipped proofs); the real validation runs with focus = __all__.
(fn focus_skip ((focus Symbol) (name Symbol)) Bool
  (if (sym_eq focus (quote __all__)) False (if (sym_eq focus name) False True)))

;; ---------------------------------------------------------------------------
;; `auto` proof indirection. A claim/fulfills whose proof is the bare symbol
;; `auto` — or `(auto …)`, the tail reserved as SOLVER hints, ignored here —
;; takes its real proof from the file's sidecar `<file>.auto.shard`:
;; (proof-for NAME PROOF) forms generated offline by proof-search tooling
;; (read_sidecars, loader.shard). The checker only ever REPLAYS a sidecar
;; proof deterministically; it NEVER searches. A sidecar is untrusted input:
;; the spliced s-expr goes through the same parse / desugar / check_sequent
;; path as an inline proof, so a wrong or stale entry simply fails.
;; ---------------------------------------------------------------------------
(fn is_auto_proof ((s SExpr)) Bool
  (match s
    ((SSym h) (sym_eq h (quote auto)))
    ((SList (Cons (SSym h) _)) (sym_eq h (quote auto)))
    (_ False)))

;; (proof-for NAME PROOF) forms → (name → proof-sexpr); other forms are
;; ignored (a malformed entry surfaces as its claim's missing-entry failure).
(fn autos_of_forms ((forms (List SExpr))) (List (Pair Symbol SExpr))
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (match f
       ((SList (Cons (SSym h) (Cons (SSym name) (Cons proofS Nil))))
        (if (sym_eq h (quote proof-for))
          (Cons (Pair name proofS) (autos_of_forms rest))
          (autos_of_forms rest)))
       (_ (autos_of_forms rest))))))

;; this source's sidecar entries: find its path key, lex the sidecar bytes.
(fn autos_of_src ((pathkey Symbol) (sidecars (List (Pair Symbol (List Int)))))
  (List (Pair Symbol SExpr))
  (measure (struct sidecars))
  (match sidecars
    (Nil Nil)
    ((Cons (Pair k bytes) rest)
     (if (sym_eq k pathkey)
       (match (read_all bytes)
         (None Nil)
         ((Some forms) (autos_of_forms forms)))
       (autos_of_src pathkey rest)))))

(fn auto_lookup ((n Symbol) (autos (List (Pair Symbol SExpr)))) (Option SExpr)
  (measure (struct autos))
  (match autos
    (Nil None)
    ((Cons (Pair k p) rest) (if (sym_eq k n) (Some p) (auto_lookup n rest)))))

(fn auto_missing_msg ((name Symbol)) (List Int)
  (append_int
    "auto proof: no (proof-for "
    (append_int
      (chars_of_sym name)
      " ...) entry in this file's .auto.shard sidecar (generate it with the proof solver)")))

;; Parse a decl's EFFECTIVE proof — inline as written, or spliced from the
;; sidecar for `auto`. Named citations are desugared to positional form at
;; the s-expr level (ds_proof, desugar.shard) against the goal's params and
;; premise count, so the parsed Proof is ready for check_sequent directly.
;; The failure modes carry distinct messages.
(type PrfRes (PrfOk Proof) (PrfErr (List Int)))

(fn parse_proof_auto
  ((m Module)
   (gctx RCtx)
   (name Symbol)
   (raw SExpr)
   (autos (List (Pair Symbol SExpr)))
   (g Goal))
  PrfRes
  (match (if (is_auto_proof raw) (auto_lookup name autos) (Some raw))
    (None (PrfErr (auto_missing_msg name)))
    ((Some prfS)
     (match (ds_proof m (goal_params g) Nil (goal_premise_count g) Nil prfS)
       ((DsErr e) (PrfErr e))
       ((DsOk prfS2)
        (match (parse_proof_r m gctx prfS2)
          (None (PrfErr "could not parse proof (proof DSL)"))
          ((Some p) (PrfOk p))))))))

;; ledger-kind promotion: an axiom AUTHORED in the kernel tree is the trust
;; floor ('kernel) — exempt from (bin trusts) listing (led_own_axioms skips
;; it, like the arith backend), rendered on its own ledger line. Granted
;; sources never reach here with kernel paths in practice, but the promotion
;; is by DECLARING module either way. Never surface syntax (ax_kind_ok).
(fn ax_kind_at ((mp (List Symbol)) (k Symbol)) Symbol
  (match mp
    (Nil k)
    ((Cons h _)
     (if (sym_eq h (quote kernel)) (quote kernel)
     (if (sym_eq h (quote core)) (quote kernel)
     k)))))

;; `gctx` is the file's resolution context (curmod + use-scope, with the glob
;; folded in as the additive base) — used to resolve each goal/proof against the
;; module it was authored in. Constant per file; threaded unchanged.
(fn run_decls
  ((gctx RCtx)
   (autos (List (Pair Symbol SExpr)))  ; the file's sidecar entries (auto splice)
   (m Module)
   (st RunState)
   (ds (List Decl))
   (target Symbol)
   (focus Symbol))
  RunState
  (measure (struct ds))
  (match ds
    (Nil st)
    ((Cons d rest)
     (match st
       ((RunState th pend acc led)
        (match d
          ;; (axiom NAME (goal …)): parse goal to native, admit without proof.
          ((DAxiom a)
           (match (parse_goal_r m gctx (ax_goal a))
             (None
               (run_decls
                 gctx
                 autos
                 m
                 (RunState
                   th
                   pend
                   (Cons
                     (COFail
                       (ax_name a)
                       "could not parse axiom goal (proof DSL)"
                       Nil)
                     acc)
                   led)
                 rest
                 target
                 focus))
             ((Some g)
              (match (tc_check_goal m g)
                ;; ill-typed axiom: REJECTED, not admitted to the theory.
                ((Some msg)
                 (run_decls
                   gctx
                   autos
                   m
                   (RunState
                     th
                     pend
                     (Cons (COTypeFail (ax_name a) msg) acc)
                     led)
                   rest
                   target
                   focus))
                (None
                  (run_decls
                    gctx
                    autos
                    m
                    (RunState
                      (TheoryCons
                        (Axiom
                          (QName (rc_mod gctx) (ax_name a))
                          (close_goal_for_storage g))
                        th)
                      pend
                      (Cons (COAxiom (ax_name a)) acc)
                      ;; leaf entry: kind set by the reader ('granted /
                      ;; 'upstream for granted sources, else the surface tag),
                      ;; promoted to 'kernel for kernel-tree sources.
                      (Cons
                        (LedgerEntry
                          (ax_name a)
                          (ax_kind_at (rc_mod gctx) (ax_kind a))
                          Nil)
                        led))
                    rest
                    target
                    focus))))))
          ;; (claim NAME (goal …) PROOF): desugar named citations at the
          ;; s-expr level, parse goal and proof STRAIGHT to native via
          ;; proof_reader, and check.
          ((DClaim nc)
           (match (parse_goal_r m gctx (claim_goal nc))
             (None
               (run_decls
                 gctx
                 autos
                 m
                 (RunState
                   th
                   pend
                   (Cons
                     (COFail
                       (claim_name nc)
                       "could not parse goal (proof DSL)"
                       Nil)
                     acc)
                   led)
                 rest
                 target
                 focus))
             ((Some g)
              (match (tc_check_goal m g)
                ;; ill-typed claim: REJECTED before any proof checking (even
                ;; in focus mode — an ill-typed goal must not enter the
                ;; theory, where a focus-admitted citation would use it).
                ((Some msg)
                 (run_decls
                   gctx
                   autos
                   m
                   (RunState
                     th
                     pend
                     (Cons (COTypeFail (claim_name nc) msg) acc)
                     led)
                   rest
                   target
                   focus))
                (None
                  (if (focus_skip focus (claim_name nc))
                    ;; not the focus claim — admit its goal, skip the proof.
                    (run_decls
                      gctx
                      autos
                      m
                      (RunState
                        (TheoryCons
                          (Proven
                            (QName (rc_mod gctx) (claim_name nc))
                            (close_goal_for_storage g))
                          th)
                        pend
                        acc
                        (Cons
                          (LedgerEntry (claim_name nc) (quote claim) Nil)
                          led))
                      rest
                      target
                      focus)
                    (match
                      (parse_proof_auto
                        m
                        gctx
                        (claim_name nc)
                        (claim_proof nc)
                        autos
                        g)
                      ((PrfErr emsg)
                       (run_decls
                         gctx
                         autos
                         m
                         (RunState
                           th
                           pend
                           (Cons (COFail (claim_name nc) emsg Nil) acc)
                           led)
                         rest
                         target
                         focus))
                      ((PrfOk p)
                       (if (check_sequent m th (lift_sequent g) p)
                         (run_decls
                           gctx
                           autos
                           m
                           (RunState
                             (TheoryCons
                               (Proven
                                 (QName (rc_mod gctx) (claim_name nc))
                                 (close_goal_for_storage g))
                               th)
                             pend
                             (Cons
                               (pass_or_admit
                                 (claim_name nc)
                                 (claim_trace m th g p (claim_name nc) target)
                                 p)
                               acc)
                             (Cons
                               (LedgerEntry
                                 (claim_name nc)
                                 (quote claim)
                                 (cites_of_proof p))
                               led))
                           rest
                           target
                           focus)
                         (run_decls
                           gctx
                           autos
                           m
                           (RunState
                             th
                             pend
                             (Cons
                               (COFail
                                 (claim_name nc)
                                 (failure_detail m th (lift_sequent g) p)
                                 (claim_trace m th g p (claim_name nc) target))
                               acc)
                             led)
                           rest
                           target
                           focus))))))))))
          ;; (requirement NAME (goal …)): parse the goal to native NOW
          ;; (validating it at the contract), seed it as a pending obligation.
          ((DReq r)
           (match (parse_goal_r m gctx (req_goal r))
             (None
               (run_decls
                 gctx
                 autos
                 m
                 (RunState
                   th
                   pend
                   (Cons
                     (COFail
                       (req_name r)
                       "could not parse requirement goal (proof DSL)"
                       Nil)
                     acc)
                   led)
                 rest
                 target
                 focus))
             ((Some g)
              (match (tc_check_goal m g)
                ;; ill-typed requirement: REJECTED, never seeded — it must
                ;; not be fulfillable. (The later (fulfills) then fails with
                ;; "no requirement in scope".)
                ((Some msg)
                 (run_decls
                   gctx
                   autos
                   m
                   (RunState
                     th
                     pend
                     (Cons (COTypeFail (req_name r) msg) acc)
                     led)
                   rest
                   target
                   focus))
                (None
                  (run_decls
                    gctx
                    autos
                    m
                    (RunState
                      th
                      (Cons (PendReq (QName (rc_mod gctx) (req_name r)) g) pend)
                      acc
                      led)
                    rest
                    target
                    focus))))))
          ;; (fulfills NAME PROOF): look the goal up from the requirement (the
          ;; single source of truth — never restated here), desugar named
          ;; citations at the s-expr level, parse the proof to native, check it.
          ((DFul fu)
           (match (lookup_req (ful_name fu) (rc_mod gctx) pend)
             (None
               (run_decls
                 gctx
                 autos
                 m
                 (RunState
                   th
                   pend
                   (Cons
                     (COFail
                       (ful_name fu)
                       "no requirement with this name in scope (is the contract imported?)"
                       Nil)
                     acc)
                   led)
                 rest
                 target
                 focus))
             ((Some (Pair rq g))
              (if (focus_skip focus (ful_name fu))
                ;; not the focus claim — admit the requirement's goal, skip the proof.
                (run_decls
                  gctx
                  autos
                  m
                  (RunState
                    (TheoryCons (Proven rq (close_goal_for_storage g)) th)
                    (remove_req (ful_name fu) (rc_mod gctx) pend)
                    acc
                    (Cons (LedgerEntry (ful_name fu) (quote fulfills) Nil) led))
                  rest
                  target
                  focus)
                (match
                  (parse_proof_auto m gctx (ful_name fu) (ful_proof fu) autos g)
                  ((PrfErr emsg)
                   (run_decls
                     gctx
                     autos
                     m
                     (RunState
                       th
                       (remove_req (ful_name fu) (rc_mod gctx) pend)
                       (Cons (COFail (ful_name fu) emsg Nil) acc)
                       led)
                     rest
                     target
                     focus))
                  ((PrfOk p)
                   (if (check_sequent m th (lift_sequent g) p)
                     (run_decls
                       gctx
                       autos
                       m
                       (RunState
                         (TheoryCons (Proven rq (close_goal_for_storage g)) th)
                         (remove_req (ful_name fu) (rc_mod gctx) pend)
                         (Cons
                           (pass_or_admit
                             (ful_name fu)
                             (claim_trace m th g p (ful_name fu) target)
                             p)
                           acc)
                         (Cons
                           (LedgerEntry
                             (ful_name fu)
                             (quote fulfills)
                             (cites_of_proof p))
                           led))
                       rest
                       target
                       focus)
                     (run_decls
                       gctx
                       autos
                       m
                       (RunState
                         th
                         (remove_req (ful_name fu) (rc_mod gctx) pend)
                         (Cons
                           (COFail
                             (ful_name fu)
                             (failure_detail m th (lift_sequent g) p)
                             (claim_trace m th g p (ful_name fu) target))
                           acc)
                         led)
                       rest
                       target
                       focus))))))))))))))

;; A file's resolution context (STRICT, Stage 2.5c): real curmod, its OWN
;; locals (the merged module's defs at curmod), and its use-scope — NO glob.
;; Precedence local > use-items > core (env_lookup default). Shared by
;; run_srcs and by library consumers that parse goals/proofs against a file's
;; scope (tools/prove resolves a hinted claim's goal through this).
(fn file_rctx ((m Module) (path (List Int)) (src (List Int))) RCtx
  (let ((curmod (module_path_of path)))
    (match (use_scope_of (use_forms src) curmod (module_resolve_env m))
      ((Pair uitems ualiases)
       (RCtx
         curmod
         (app_env (filter_modpath (module_resolve_env m) curmod) uitems)
         ualiases)))))

;; ---- axiom scope: library trees are THEOREM-ONLY ---------------------------
;; Axioms may be AUTHORED in exactly two places: kernel/ (the reviewed
;; core-math set, kernel/facts.shard) and app/bin trust scopes (I/O bolts,
;; bridging axioms — granted per-artifact, ledger-visible). The library trees
;; (std/, meta/, models/) may never grow the trust surface: an (axiom …)
;; authored in one is refused below, loudly, before admission. Granted
;; sources are exempt — their DAxioms are consumer-side ADMISSIONS of an
;; upstream interface (kinds 'granted/'upstream), not authored axioms.
(fn axscope_banned ((path (List Int))) Bool
  (match (module_path_of path)
    (Nil False)
    ((Cons h _)
     (if (sym_eq h (quote std)) True
     (if (sym_eq h (quote meta)) True
     (sym_eq h (quote models)))))))

(fn first_own_axiom ((ds (List Decl))) (Option Symbol)
  (measure (struct ds))
  (match ds
    (Nil None)
    ((Cons d rest)
     (match d
       ((DAxiom a) (Some (ax_name a)))
       (_ (first_own_axiom rest))))))

;; ---- axiom kind: every authored axiom names its trust kind ------------------
;; An own axiom with no (kind …) clause parses as 'untagged (ax_of_form) and
;; is refused below, before admission — the trust ledger never carries an
;; unclassified entry. Granted sources are exempt for the same reason as the
;; scope gate: their DAxioms are re-kinded 'granted/'upstream consumer-side;
;; the authoring module's own check run is where its tags are enforced.
;; kernel/facts.shard is NOT exempt — its axioms carry surface tags too
;; (ax_kind_at's 'kernel promotion happens at ledger time, after this gate).
(fn first_untagged_axiom ((ds (List Decl))) (Option Symbol)
  (measure (struct ds))
  (match ds
    (Nil None)
    ((Cons d rest)
     (match d
       ((DAxiom a)
        (if (sym_eq (ax_kind a) (quote untagged)) (Some (ax_name a))
        (first_untagged_axiom rest)))
       (_ (first_untagged_axiom rest))))))

;; the one admission veto for a source's decl stream: scope first, then kind.
;; Some = (Pair offending-axiom-name refusal-message) → COFail in run_srcs.
(fn ax_admit_veto ((granted Bool) (path (List Int)) (ds (List Decl)))
  (Option (Pair Symbol (List Int)))
  (if granted None
  (match (if (axscope_banned path) (first_own_axiom ds) None)
    ((Some n)
     (Some
       (Pair
         n
         "axiom authored in a library tree -- std/, meta/, models/ are theorem-only; reviewed prim facts live in kernel/facts.shard, boundary axioms at app/bin trust scopes")))
    (None
      (match (first_untagged_axiom ds)
        ((Some n)
         (Some
           (Pair
             n
             "axiom missing its (kind ...) tag -- every authored axiom names its trust kind: (kind operational) for extern/prim boundary behavior, (kind bridging) for an assumed bridge")))
        (None None))))))

;; Run a whole file list (imports first, then targets), threading theory.
;; A source whose decl stream fails to parse (e.g. a claim missing its proof)
;; is a HARD failure: every decl in that source would otherwise vanish
;; outcome-less — accepted-by-absence. The source is re-scanned by parse_diag
;; (reader.shard) to name the malformed declaration; `k` is the source ordinal
;; for that message. (The Rust harness pre-validates only LEXICAL parsing —
;; decl shape is checked nowhere else.)
;; Each source is tagged `(Pair granted src)`: `granted` marks a dependency
;; module's INTERFACE (its requirements are admitted as axioms, not re-imposed
;; as obligations — see collect_decls, reader.shard).
(fn run_srcs
  ((m Module)
   (srcs (List SrcEntry))
   (ctors (List Symbol))
   (sidecars (List (Pair Symbol (List Int))))  ; path-key → .auto.shard bytes
   (st RunState)
   (target Symbol)
   (focus Symbol)
   (k Int))
  RunState
  (measure (struct srcs))
  (match srcs
    (Nil st)
    ((Cons (SrcEntry path granted src) rest)
     (match (parse_decls src ctors granted)
       (None
         (match st
           ((RunState th pend acc led)
            (run_srcs
              m
              rest
              ctors
              sidecars
              (RunState
                th
                pend
                (Cons
                  (COFail (quote __decls__) (parse_diag src ctors k) Nil)
                  acc)
                led)
              target
              focus
              (+ k 1)))))
       ((Some ds)
        (match (ax_admit_veto granted path ds)
          ((Some (Pair badax vmsg))
           (match st
             ((RunState th pend acc led)
              (run_srcs
                m
                rest
                ctors
                sidecars
                (RunState th pend (Cons (COFail badax vmsg Nil) acc) led)
                target
                focus
                (+ k 1)))))
          (None
            (run_srcs
              m
              rest
              ctors
              sidecars
              (run_decls
                (file_rctx m path src)
                (autos_of_src (sym_of_chars path) sidecars)
                m
                st
                ds
                target
                focus)
              target
              focus
              (+ k 1)))))))))

;; ---------------------------------------------------------------------------
;; solver theory walk — the theory as a real check pass would have it, built
;; INCREMENTALLY: theory_base_st admits the whole closure BEFORE the file
;; keyed `tkey` (sym_of_chars of its path — the driver compares paths as
;; symbols); theory_step then advances the state over decl slices of that
;; file in order. A caller solving N decls threads ONE RunState through its
;; loop — one O(N) walk, not N prefix rebuilds. The walk is run_decls itself
;; with an always-skipping focus, so every goal on the way is admitted
;; exactly as focus mode would admit it and NO proof is checked. This is an
;; offline SOLVER aid (tools/prove): it bounds the citation vocabulary a
;; candidate may use to what a real check pass would resolve at that point.
;; check never calls it — a candidate citing an admitted-but-broken lemma
;; still fails the real pass.
;; ---------------------------------------------------------------------------
(fn decl_named ((d Decl) (name Symbol)) Bool
  (match d
    ((DClaim nc) (sym_eq (claim_name nc) name))
    ((DFul fu) (sym_eq (ful_name fu) name))
    (_ False)))

;; split DS at the decl named NAME: (Pair before from-NAME-on).
;; NAME absent → (Pair ds Nil).
(fn decls_split ((ds (List Decl)) (name Symbol)) (Pair (List Decl) (List Decl))
  (measure (struct ds))
  (match ds
    (Nil (Pair Nil Nil))
    ((Cons d rest)
     (if (decl_named d name) (Pair Nil (Cons d rest))
     (match (decls_split rest name)
       ((Pair before after) (Pair (Cons d before) after)))))))

(fn rs_theory ((st RunState)) Theory
  (match st
    ((RunState th _ _ _) th)))

;; advance ST over decl slice DS of the file whose resolution context is
;; `gctx`, proofs skipped.
(fn theory_step ((gctx RCtx) (m Module) (st RunState) (ds (List Decl))) RunState
  (run_decls gctx Nil m st ds (quote __no_trace__) (quote __theory_walk__)))

(fn theory_base_go
  ((m Module)
   (srcs (List SrcEntry))
   (ctors (List Symbol))
   (tkey Symbol)
   (st RunState))
  RunState
  (measure (struct srcs))
  (match srcs
    (Nil st)
    ((Cons (SrcEntry path granted src) rest)
     (if (sym_eq (sym_of_chars path) tkey) st
     (match (parse_decls src ctors granted)
       (None st)  ; malformed source: stop — the real pass reports it loudly
       ((Some ds)
        (theory_base_go
          m
          rest
          ctors
          tkey
          (theory_step (file_rctx m path src) m st ds))))))))

(fn theory_base_st
  ((m Module) (srcs (List SrcEntry)) (ctors (List Symbol)) (tkey Symbol))
  RunState
  (theory_base_go m srcs ctors tkey (RunState TheoryEmpty Nil Nil Nil)))

;; ---- bin acceptance reporting ---------------------------------------------
;; A `(bin …)` groups requirement names into an artifact's acceptance contract.
;; After the whole closure is checked, each required name is looked up in the
;; final theory: present (a fulfilled requirement / proven claim / admitted
;; axiom) = MET; absent (still a pending obligation) = UNMET. UNMET names become
;; COFail outcomes, so a pending requirement is SURFACED and fails the run —
;; closing the "pending is silent" gap. Bins are scanned from the raw forms
;; (they never enter the decl/theory stream).
;; Stage 4: a bin's requires are about ITS OWN app — the name must be met by
;; an entry admitted within the bin file's directory module (supplies_scope_ok,
;; the same rule fulfills follows). A same-named claim elsewhere in the
;; closure no longer satisfies a require.
(fn req_met_walk ((name Symbol) (binmp (List Symbol)) (th Theory)) Bool
  (measure (struct th))
  (match th
    ((TheoryEmpty) False)
    ((TheoryCons entry rest)
     (match entry
       ((Proven q _)
        (if
          (if (sym_eq (qn_name q) name) (supplies_scope_ok (qn_mod q) binmp)
          False)
          True
          (req_met_walk name binmp rest)))
       ((Axiom q _)
        (if
          (if (sym_eq (qn_name q) name) (supplies_scope_ok (qn_mod q) binmp)
          False)
          True
          (req_met_walk name binmp rest)))))))

(fn req_met ((name Symbol) (binmp (List Symbol)) (th Theory)) Bool
  (req_met_walk name binmp th))

(fn count_met ((names (List Symbol)) (binmp (List Symbol)) (th Theory)) Int
  (measure (struct names))
  (match names
    (Nil 0)
    ((Cons n rest) (+ (if (req_met n binmp th) 1 0) (count_met rest binmp th)))))

(fn len_syms ((names (List Symbol))) Int
  (measure (struct names))
  (match names
    (Nil 0)
    ((Cons _ rest) (+ 1 (len_syms rest)))))

(fn unmet_fails ((names (List Symbol)) (binmp (List Symbol)) (th Theory))
  (List ClaimOutcome)
  (measure (struct names))
  (match names
    (Nil Nil)
    ((Cons n rest)
     (if (req_met n binmp th) (unmet_fails rest binmp th)
     (Cons
       (COFail n "UNMET: listed in a (bin requires) but never fulfilled" Nil)
       (unmet_fails rest binmp th))))))

(fn oc_concat ((a (List ClaimOutcome)) (b (List ClaimOutcome)))
  (List ClaimOutcome)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (oc_concat t b)))))

(fn sym_in ((x Symbol) (xs (List Symbol))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (sym_eq x h) True (sym_in x t)))))

(fn sym_concat ((a (List Symbol)) (b (List Symbol))) (List Symbol)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (sym_concat t b)))))

;; ---- entry: the named fn must exist (with a body); TWO admitted shapes ------
;; The WORLD-LEADING contract (docs/X86.md §44, user-ratified 2026-07-09,
;; generalizing the original (World) -> World I/O contract as its
;; degenerate case): World is the FIRST parameter and the return, and
;; appears NOWHERE else — the entry threads the world through cited
;; effect externs, and any remaining parameters are the values the
;; artifact toolchain's signed glue contract supplies. `World` is the
;; I/O token type; a runnable program defines its own World type (its
;; module-path differs from the kernel's), so this is a module-AGNOSTIC
;; structural check on the type NAME (it gates the entry's calling
;; convention, not a soundness-interpreted symbol). Cf. the Stage-1
;; convention for hardcoded tags.
;; The PURE contract (the native-bin bridge form, docs/X86.md §22,
;; user-ratified 2026-07-08): a value fn with World NOWHERE in its
;; signature — the glue contract owns the process boundary, and the
;; build gates (surface/tie/engine) own the spec ⊑ machine tie.
;; A signature mentioning World in any other position is a hybrid:
;; refused.
(fn is_world ((t Type)) Bool
  (match t
    ((TCon q args)
     (match args
       (Nil (sym_eq (qn_name q) (quote World)))
       (_ False)))
    (_ False)))

(fn params_no_world ((ps (List Type))) Bool
  (measure (struct ps))
  (match ps
    (Nil True)
    ((Cons p rest) (if (is_world p) False (params_no_world rest)))))

(fn entry_ok ((fd FnDef)) Bool
  (match fd
    ((FnDef _ params ret _)
     (if (is_world ret)
       (match params
         ((Cons p rest) (if (is_world p) (params_no_world rest) False))
         (Nil False))
       False))))

;; the pure contract: World nowhere in the signature
(fn entry_pure ((fd FnDef)) Bool
  (match fd
    ((FnDef _ params ret _) (if (is_world ret) False (params_no_world params)))))

(fn entry_check ((entry Symbol) (m Module)) (List ClaimOutcome)
  (match m
    ((Module _ fns _ _ _)
     (match (find_fn_named entry fns)
       (None
         (Cons
           (COFail
             entry
             "entry: no implemented fn of this name (bodyless sig only?)"
             Nil)
           Nil))
       ((Some fd)
        (if (entry_ok fd) Nil
        (if (entry_pure fd) Nil
        (Cons
          (COFail
            entry
            "entry: must be World-leading ((World values ...) -> World) or a pure value fn (any other World-mentioning signature is a hybrid)"
            Nil)
          Nil))))))))

;; ---- trusts: must EQUAL the module's own (axiom) decls (its real TCB) -------
;; Every module-declared axiom must be listed (no hidden trust); every listed
;; name must be one of them (no phantom / proven-listed-as-trusted). The own-
;; axiom set comes from the trust ledger (kinds operational/bridging/untagged),
;; i.e. exactly the own axioms ADMITTED this run; the ledger block additionally
;; reports which of them the bin's requirements transitively cite.
(fn missing_trust ((own (List Symbol)) (trusts (List Symbol)))
  (List ClaimOutcome)
  (measure (struct own))
  (match own
    (Nil Nil)
    ((Cons a rest)
     (if (sym_in a trusts) (missing_trust rest trusts)
     (Cons
       (COFail
         a
         "untrusted: a module (axiom) is not listed in (bin trusts)"
         Nil)
       (missing_trust rest trusts))))))

(fn phantom_trust ((trusts (List Symbol)) (own (List Symbol)))
  (List ClaimOutcome)
  (measure (struct trusts))
  (match trusts
    (Nil Nil)
    ((Cons t rest)
     (if (sym_in t own) (phantom_trust rest own)
     (Cons
       (COFail
         t
         "trusts: not a module-declared axiom (only own (axiom)s are TCB)"
         Nil)
       (phantom_trust rest own))))))

(fn trusts_check ((trusts (List Symbol)) (own (List Symbol)))
  (List ClaimOutcome)
  (oc_concat (missing_trust own trusts) (phantom_trust trusts own)))

;; ---- externs: must EQUAL the module's declared extern surface --------------
;; Real externs come from `(extern …)` forms — NOT the Module's ExternDef list,
;; which also holds every `(sig fn …)` signature (both parse to ExternDef).
(fn missing_extern ((decl (List Symbol)) (listed (List Symbol)))
  (List ClaimOutcome)
  (measure (struct decl))
  (match decl
    (Nil Nil)
    ((Cons e rest)
     (if (sym_in e listed) (missing_extern rest listed)
     (Cons
       (COFail
         e
         "boundary: a declared extern is not listed in (bin externs)"
         Nil)
       (missing_extern rest listed))))))

(fn phantom_extern ((listed (List Symbol)) (decl (List Symbol)))
  (List ClaimOutcome)
  (measure (struct listed))
  (match listed
    (Nil Nil)
    ((Cons e rest)
     (if (sym_in e decl) (phantom_extern rest decl)
     (Cons
       (COFail e "externs: not a declared extern of this module" Nil)
       (phantom_extern rest decl))))))

(fn externs_check ((listed (List Symbol)) (decl (List Symbol)))
  (List ClaimOutcome)
  (oc_concat (missing_extern decl listed) (phantom_extern listed decl)))

;; the module's OWN extern decls = `(extern …)` in its ungranted sources.
(fn extern_decl_name ((f SExpr)) (Option Symbol)
  (match f
    ((SList (Cons (SSym h) (Cons (SSym name) _)))
     (if (sym_eq h (quote extern)) (Some name) None))
    (_ None)))

(fn extern_names_of_forms ((forms (List SExpr))) (List Symbol)
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (match (extern_decl_name f)
       (None (extern_names_of_forms rest))
       ((Some n) (Cons n (extern_names_of_forms rest)))))))

(fn own_externs_of_srcs ((srcs (List SrcEntry))) (List Symbol)
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons (SrcEntry _ granted src) rest)
     (if granted (own_externs_of_srcs rest)
     (match (read_all src)
       (None (own_externs_of_srcs rest))
       ((Some forms)
        (sym_concat (extern_names_of_forms forms) (own_externs_of_srcs rest))))))))

;; ---- the trust ledger: citation closure, call graph, rendered block --------
;; The driver accumulated a LedgerEntry per ADMITTED decl (see RunState).
;; Here each bin closes its `requires` over the citation DAG and its entry fn
;; over the run-mode call graph, and renders the result. The own-axiom set the
;; trusts check consumes is derived from the SAME ledger (kind = operational /
;; bridging / untagged) — the old raw-form text re-scan is gone.

(fn led_lookup ((name Symbol) (led (List LedgerEntry))) (Option LedgerEntry)
  (measure (struct led))
  (match led
    (Nil None)
    ((Cons (LedgerEntry n k cs) rest)
     (if (sym_eq n name) (Some (LedgerEntry n k cs)) (led_lookup name rest)))))

;; ---- termination measure for led_close (data-weighted; issue #1) -----------
;; led_close is a worklist fixpoint: it pops a name and, if unvisited, either
;; marks it (None arm) or marks it AND pushes its citations (Some arm — so work
;; can GROW). It terminates because `visited` saturates toward the ledger's
;; keys. The measure is  led_pending(led, visited) + sym_len(work), where
;; led_pending weights each UNVISITED key by (1 + |its citations|) — that
;; data-dependent weight exactly absorbs the unbounded work-growth at the Some
;; arm (work gains cs, pending drops by 1 + |cs|). The facts cited by the
;; measure live just below led_close; none reaches led_close in the call graph,
;; so stratified citation admits them as same-closure claims.
(fn sym_len ((xs (List Symbol))) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons _ t) (+ 1 (sym_len t)))))

(fn led_pending ((led (List LedgerEntry)) (visited (List Symbol))) Int
  (measure (struct led))
  (match led
    (Nil 0)
    ((Cons (LedgerEntry n _ cs) rest)
     (if (sym_in n visited) (led_pending rest visited)
     (+ (+ 1 (sym_len cs)) (led_pending rest visited))))))

;; the citation list of a lookup result (Nil for a miss). Stating
;; led_pending_drop over this accessor lets its proof reduce directly under the
;; matched ctor — no constructor-injectivity step needed.
(fn le_cites ((e (Option LedgerEntry))) (List Symbol)
  (match e
    (None Nil)
    ((Some (LedgerEntry _ _ cs)) cs)))

(fn led_is_some ((e (Option LedgerEntry))) Bool
  (match e
    (None False)
    ((Some _) True)))

;; transitive closure over the citation DAG: every name reachable from `work`.
;; A name with no ledger entry (an unmet requirement — the run already fails)
;; stays in `visited` as a leaf.
(fn led_close
  ((work (List Symbol)) (visited (List Symbol)) (led (List LedgerEntry)))
  (List Symbol)
  (measure
    (+ (led_pending led visited) (sym_len work))
    ;; site 0: (sym_in n visited)=True, recurse (rest, visited, led)
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma sym_len_cons) lr lhs true ()))
      (by arith (list 1 0 0)))
    (have (= (le 0 (led_pending led visited)) True)
      (rewrite-with
        (lemma led_pending_nonneg)
        lr
        lhs
        ((inst led led) (inst visited visited))
        ()
        refl)
      (have (= (le 0 (sym_len rest)) True)
        (rewrite-with (lemma sym_len_nonneg) lr lhs ((inst xs rest)) () refl)
        (by arith (list 1 0 0 1 1))))
    ;; site 1: None arm, recurse (rest, Cons n visited, led)
    (have
      (= (le (led_pending led (Cons n visited)) (led_pending led visited)) True)
      (rewrite-with
        (lemma led_pending_mono)
        lr
        lhs
        ((inst led led) (inst x n) (inst vis visited))
        ()
        refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma sym_len_cons) lr lhs true ()))
        (by arith (list 1 0 0 0 1))))
    (have (= (le 0 (led_pending led (Cons n visited))) True)
      (rewrite-with
        (lemma led_pending_nonneg)
        lr
        lhs
        ((inst led led) (inst visited (Cons n visited)))
        ()
        refl)
      (have (= (le 0 (sym_len rest)) True)
        (rewrite-with (lemma sym_len_nonneg) lr lhs ((inst xs rest)) () refl)
        (by arith (list 1 0 0 0 1 1))))
    ;; site 2: Some arm, recurse (sym_concat cs rest, Cons n visited, led)
    (have (= (le_cites (led_lookup n led)) cs)
      (steps ((rewrite (premise 2) lr lhs true ()) (simp lhs)) refl)
      (have (= (led_is_some (led_lookup n led)) True)
        (steps ((rewrite (premise 2) lr lhs true ()) (simp lhs)) refl)
        (have
          (=
            (le
              (+ (+ 1 (sym_len cs)) (led_pending led (Cons n visited)))
              (led_pending led visited))
            True)
          (steps
            ((rewrite (premise 3) rl lhs true ()))
            (rewrite-with
              (lemma led_pending_drop)
              lr
              lhs
              ((inst n n) (inst visited visited) (inst led led))
              ((steps ((rewrite (premise 4) lr lhs true ())) refl)
               (steps ((rewrite (premise 1) lr lhs true ())) refl))
              refl))
          (steps
            ((rewrite (premise 0) lr lhs true ())
             (rewrite (lemma sym_len_cons) lr lhs true ())
             (rewrite (lemma sym_len_concat) lr lhs true ()))
            (by arith (list 1 0 0 0 0 0 1))))))
    (have (= (le 0 (led_pending led (Cons n visited))) True)
      (rewrite-with
        (lemma led_pending_nonneg)
        lr
        lhs
        ((inst led led) (inst visited (Cons n visited)))
        ()
        refl)
      (have (= (le 0 (sym_len (sym_concat cs rest))) True)
        (rewrite-with
          (lemma sym_len_nonneg)
          lr
          lhs
          ((inst xs (sym_concat cs rest)))
          ()
          refl)
        (by arith (list 1 0 0 0 1 1)))))
  (match work
    (Nil visited)
    ((Cons n rest)
     (if (sym_in n visited) (led_close rest visited led)
     (match (led_lookup n led)
       (None (led_close rest (Cons n visited) led))
       ((Some (LedgerEntry ln lk cs))
        (led_close (sym_concat cs rest) (Cons n visited) led)))))))

;; ---- totality support for led_close (cited by its measure) -----------------
;; None of these reaches led_close in the call graph, so stratified citation
;; admits them as same-closure facts.
(claim sym_len_nil (goal () () (= (sym_len Nil) 0)) (steps ((simp lhs)) refl))

(claim sym_len_cons
  (goal ((h Symbol) (t (List Symbol))) ()
    (= (sym_len (Cons h t)) (+ 1 (sym_len t))))
  (steps ((simp lhs)) refl))

(claim sym_len_nonneg
  (goal ((xs (List Symbol))) () (= (le 0 (sym_len xs)) True))
  (induct xs
    ((case Nil
       (steps
         ((rewrite (lemma sym_len_nil) lr lhs true ()))
         (by arith (list 1))))
     (case Cons
       (h t)
       (have (= (le 0 (sym_len t)) True)
         (steps ((rewrite (hyp 0) lr lhs true ())) refl)
         (steps
           ((rewrite (lemma sym_len_cons) lr lhs true ()))
           (by arith (list 1 1))))))))

(claim sym_len_concat
  (goal ((a (List Symbol)) (b (List Symbol))) ()
    (= (sym_len (sym_concat a b)) (+ (sym_len a) (sym_len b))))
  (induct a
    ((case Nil
       (steps
         ((simp lhs) (rewrite (lemma sym_len_nil) lr rhs true ()))
         (by arith (list))))
     (case Cons
       (h t)
       (steps
         ((simp lhs)
          (rewrite (hyp 0) lr lhs true ())
          (rewrite (lemma sym_len_cons) lr rhs true ()))
         (by arith (list)))))))

;; 0 <= led_pending led visited.
(claim led_pending_nonneg
  (goal ((led (List LedgerEntry)) (visited (List Symbol))) ()
    (= (le 0 (led_pending led visited)) True))
  (induct led
    ((case Nil (steps ((simp lhs)) refl))
     (case Cons
       (hd rest)
       (case-on hd LedgerEntry
         ((case LedgerEntry
            (m k d)
            (case-on (sym_in m visited) Bool
              ((case True
                 (steps
                   ((rewrite (hyp 1) lr lhs true ())
                    (simp lhs)
                    (rewrite (hyp 0) lr lhs true ())
                    (simp lhs)
                    (rewrite (hyp 2) lr lhs true ()))
                   refl))
               (case False
                 (have (= (le 0 (led_pending rest visited)) True)
                   (steps ((rewrite (hyp 2) lr lhs true ())) refl)
                   (have (= (le 0 (sym_len d)) True)
                     (rewrite-with
                       (lemma sym_len_nonneg)
                       lr
                       lhs
                       ((inst xs d))
                       ()
                       refl)
                     (steps
                       ((rewrite (hyp 1) lr lhs true ())
                        (simp lhs)
                        (rewrite (hyp 0) lr lhs true ())
                        (simp lhs))
                       (by arith (list 1 1 1)))))))))))))))

;; adding x to visited never increases pending.
(claim led_pending_mono
  (goal ((led (List LedgerEntry)) (x Symbol) (vis (List Symbol))) ()
    (= (le (led_pending led (Cons x vis)) (led_pending led vis)) True))
  (induct led
    ((case Nil (steps ((simp lhs)) refl))
     (case Cons
       (hd rest)
       (case-on hd LedgerEntry
         ((case LedgerEntry
            (m k d)
            (have
              (=
                (le (led_pending rest (Cons x vis)) (led_pending rest vis))
                True)
              (steps ((rewrite (hyp 1) lr lhs true ())) refl)
              (have (= (le 0 (sym_len d)) True)
                (rewrite-with
                  (lemma sym_len_nonneg)
                  lr
                  lhs
                  ((inst xs d))
                  ()
                  refl)
                (case-on (sym_eq m x) Bool
                  ((case True
                     (case-on (sym_in m vis) Bool
                       ((case True
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))
                        (case False
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 1)))))))
                   (case False
                     (case-on (sym_in m vis) Bool
                       ((case True
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))
                        (case False
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))))))))))))))))

;; the productive step (n is an unvisited key) drops pending by >= 1 + |cites|.
(claim led_pending_drop
  (goal ((n Symbol) (visited (List Symbol)) (led (List LedgerEntry)))
    ((= (led_is_some (led_lookup n led)) True) (= (sym_in n visited) False))
    (=
      (le
        (+
          (+ 1 (sym_len (le_cites (led_lookup n led))))
          (led_pending led (Cons n visited)))
        (led_pending led visited))
      True))
  (induct led
    ((case Nil (absurd (premise 0)))
     (case Cons
       (hd rest)
       (case-on hd LedgerEntry
         ((case LedgerEntry
            (m k d)
            (case-on (sym_eq m n) Bool
              ((case True
                 (have (= m n) (by arith (list))
                   (have
                     (=
                       (le
                         (led_pending rest (Cons n visited))
                         (led_pending rest visited))
                       True)
                     (rewrite-with
                       (lemma led_pending_mono)
                       lr
                       lhs
                       ((inst led rest) (inst x n) (inst vis visited))
                       ()
                       refl)
                     (steps
                       ((rewrite (hyp 1) lr lhs true ())
                        (simp lhs)
                        (rewrite (hyp 0) lr lhs true ())
                        (simp lhs)
                        (rewrite (premise 2) lr lhs true ())
                        (rewrite (premise 1) lr lhs true ())
                        (simp lhs))
                       (by arith (list 1 0 0 0 1))))))
               (case False
                 (have (= (led_lookup n rest) (led_lookup n (Cons hd rest)))
                   (steps
                     ((rewrite (hyp 1) lr rhs true ())
                      (simp rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (simp rhs))
                     refl)
                   (have (= (led_is_some (led_lookup n rest)) True)
                     (steps
                       ((rewrite (premise 2) lr lhs true ())
                        (rewrite (premise 0) lr lhs true ()))
                       refl)
                     (have
                       (=
                         (le
                           (+
                             (+ 1 (sym_len (le_cites (led_lookup n rest))))
                             (led_pending rest (Cons n visited)))
                           (led_pending rest visited))
                         True)
                       (rewrite-with
                         (hyp 2)
                         lr
                         lhs
                         ((inst n n) (inst visited visited))
                         ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                          (steps ((rewrite (premise 1) lr lhs true ())) refl))
                         refl)
                       (case-on (sym_in m visited) Bool
                         ((case True
                            (steps
                              ((rewrite (hyp 2) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 1) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 0) lr lhs true ())
                               (simp lhs))
                              (by arith (list 1 0 0 0 0 1))))
                          (case False
                            (steps
                              ((rewrite (hyp 2) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 1) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 0) lr lhs true ())
                               (simp lhs))
                              (by arith (list 1 0 0 0 0 1)))))))))))))))))))

;; the names among `names` whose ledger kind is one of `kinds`.
(fn led_filter
  ((names (List Symbol)) (led (List LedgerEntry)) (kinds (List Symbol)))
  (List Symbol)
  (measure (struct names))
  (match names
    (Nil Nil)
    ((Cons n rest)
     (match (led_lookup n led)
       (None (led_filter rest led kinds))
       ((Some (LedgerEntry _ k _))
        (if (sym_in k kinds) (Cons n (led_filter rest led kinds))
        (led_filter rest led kinds)))))))

(fn own_ax_kinds () (List Symbol)
  (list (quote operational) (quote bridging) (quote untagged)))

;; every OWN axiom this run admitted (granted/upstream kinds excluded) —
;; the set (bin trusts) must equal.
(fn led_own_axioms ((led (List LedgerEntry))) (List Symbol)
  (measure (struct led))
  (match led
    (Nil Nil)
    ((Cons (LedgerEntry n k _) rest)
     (if (sym_in k (own_ax_kinds)) (Cons n (led_own_axioms rest))
     (led_own_axioms rest)))))

;; ---- run-mode call-graph closure. Narrow is FIRST-ORDER (no fn values; a
;; callee is always a Call by name), so reachability from the entry fn over
;; the module's bodies is exact, not an approximation. Externs have no body —
;; they are leaves; the reachable extern surface is closure ∩ declared.
(fn calls_of_expr ((e Expr)) (List Symbol)
  (measure (struct e))
  (match e
    ((Call f args) (Cons (qn_name f) (calls_of_list args)))
    ((Ctor _ args) (calls_of_list args))
    ((Match s arms) (sym_concat (calls_of_expr s) (calls_of_arms arms)))
    ((Let bs body) (sym_concat (calls_of_list bs) (calls_of_expr body)))
    ((If c t e2)
     (sym_concat
       (calls_of_expr c)
       (sym_concat (calls_of_expr t) (calls_of_expr e2))))
    (_ Nil)))

(fn calls_of_list ((es (List Expr))) (List Symbol)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons h t) (sym_concat (calls_of_expr h) (calls_of_list t)))))

(fn calls_of_arms ((arms (List Arm))) (List Symbol)
  (measure (struct arms))
  (match arms
    (Nil Nil)
    ((Cons (Arm _ body) rest)
     (sym_concat (calls_of_expr body) (calls_of_arms rest)))))

;; ---- termination measure for call_close (data-weighted; issue #1) ----------
;; call_close is the run-mode twin of led_close: a worklist fixpoint that pops a
;; name and, on an unvisited FN, marks it AND pushes the calls in its body (so
;; work can GROW). The measure is the SAME shape as led_close's,
;;   call_pending(fns, visited) + sym_len(work),
;; with call_pending weighting each UNVISITED fn by (1 + |calls in its body|) —
;; the data weight that absorbs the work-growth at the Some arm (work gains the
;; body's calls, pending drops by 1 + |those calls|). call_close now takes the
;; fn LIST directly (it only ever destructured `fns` out of the Module); that
;; keeps the measure a clean parallel to led_close's bare-list form. The cited
;; facts live just below; none reaches call_close in the call graph, so
;; stratified citation admits them as same-closure claims.
(fn call_pending_fns ((fns (List FnDef)) (visited (List Symbol))) Int
  (measure (struct fns))
  (match fns
    (Nil 0)
    ((Cons (FnDef q _ _ body) rest)
     (if (sym_in (qn_name q) visited) (call_pending_fns rest visited)
     (+ (+ 1 (sym_len (calls_of_expr body))) (call_pending_fns rest visited))))))

;; the call list of a lookup result (Nil for a miss). Stating call_pending_drop
;; over this accessor lets its proof reduce directly under the matched ctor — no
;; constructor-injectivity step needed (cf. le_cites for led_close).
(fn cl_calls ((e (Option FnDef))) (List Symbol)
  (match e
    (None Nil)
    ((Some (FnDef _ _ _ body)) (calls_of_expr body))))

(fn cl_is_some ((e (Option FnDef))) Bool
  (match e
    (None False)
    ((Some _) True)))

(fn call_close ((work (List Symbol)) (visited (List Symbol)) (fns (List FnDef)))
  (List Symbol)
  (measure
    (+ (call_pending_fns fns visited) (sym_len work))
    ;; site 0: (sym_in n visited)=True, recurse (rest, visited, fns)
    (steps
      ((rewrite (premise 0) lr lhs true ())
       (rewrite (lemma sym_len_cons) lr lhs true ()))
      (by arith (list 1 0 0)))
    (have (= (le 0 (call_pending_fns fns visited)) True)
      (rewrite-with
        (lemma call_pending_nonneg)
        lr
        lhs
        ((inst fns fns) (inst visited visited))
        ()
        refl)
      (have (= (le 0 (sym_len rest)) True)
        (rewrite-with (lemma sym_len_nonneg) lr lhs ((inst xs rest)) () refl)
        (by arith (list 1 0 0 1 1))))
    ;; site 1: None arm, recurse (rest, Cons n visited, fns)
    (have
      (=
        (le
          (call_pending_fns fns (Cons n visited))
          (call_pending_fns fns visited))
        True)
      (rewrite-with
        (lemma call_pending_mono)
        lr
        lhs
        ((inst fns fns) (inst x n) (inst vis visited))
        ()
        refl)
      (steps
        ((rewrite (premise 0) lr lhs true ())
         (rewrite (lemma sym_len_cons) lr lhs true ()))
        (by arith (list 1 0 0 0 1))))
    (have (= (le 0 (call_pending_fns fns (Cons n visited))) True)
      (rewrite-with
        (lemma call_pending_nonneg)
        lr
        lhs
        ((inst fns fns) (inst visited (Cons n visited)))
        ()
        refl)
      (have (= (le 0 (sym_len rest)) True)
        (rewrite-with (lemma sym_len_nonneg) lr lhs ((inst xs rest)) () refl)
        (by arith (list 1 0 0 0 1 1))))
    ;; site 2: Some arm, recurse (sym_concat (calls_of_expr body) rest, Cons n visited, fns)
    (have (= (cl_calls (find_fn_named n fns)) (calls_of_expr body))
      (steps ((rewrite (premise 2) lr lhs true ()) (simp lhs)) refl)
      (have (= (cl_is_some (find_fn_named n fns)) True)
        (steps ((rewrite (premise 2) lr lhs true ()) (simp lhs)) refl)
        (have
          (=
            (le
              (+
                (+ 1 (sym_len (calls_of_expr body)))
                (call_pending_fns fns (Cons n visited)))
              (call_pending_fns fns visited))
            True)
          (steps
            ((rewrite (premise 3) rl lhs true ()))
            (rewrite-with
              (lemma call_pending_drop)
              lr
              lhs
              ((inst n n) (inst visited visited) (inst fns fns))
              ((steps ((rewrite (premise 4) lr lhs true ())) refl)
               (steps ((rewrite (premise 1) lr lhs true ())) refl))
              refl))
          (steps
            ((rewrite (premise 0) lr lhs true ())
             (rewrite (lemma sym_len_cons) lr lhs true ())
             (rewrite (lemma sym_len_concat) lr lhs true ()))
            (by arith (list 1 0 0 0 0 0 1))))))
    (have (= (le 0 (call_pending_fns fns (Cons n visited))) True)
      (rewrite-with
        (lemma call_pending_nonneg)
        lr
        lhs
        ((inst fns fns) (inst visited (Cons n visited)))
        ()
        refl)
      (have (= (le 0 (sym_len (sym_concat (calls_of_expr body) rest))) True)
        (rewrite-with
          (lemma sym_len_nonneg)
          lr
          lhs
          ((inst xs (sym_concat (calls_of_expr body) rest)))
          ()
          refl)
        (by arith (list 1 0 0 0 1 1)))))
  (match work
    (Nil visited)
    ((Cons n rest)
     (if (sym_in n visited) (call_close rest visited fns)
     (match (find_fn_named n fns)
       (None (call_close rest (Cons n visited) fns))  ; prim / extern / sig
       ((Some (FnDef fq fp fr body))
        (call_close (sym_concat (calls_of_expr body) rest) (Cons n visited) fns)))))))

;; ---- totality support for call_close (cited by its measure) ----------------
;; Parallel to led_close's lemmas; sym_len + sym_len_{nil,cons,nonneg,concat}
;; are shared (defined above for led_close). None reaches call_close in the
;; call graph, so stratified citation admits them as same-closure facts.

;; 0 <= call_pending_fns fns visited.
(claim call_pending_nonneg
  (goal ((fns (List FnDef)) (visited (List Symbol))) ()
    (= (le 0 (call_pending_fns fns visited)) True))
  (induct fns
    ((case Nil (steps ((simp lhs)) refl))
     (case Cons
       (hd rest)
       (case-on hd FnDef
         ((case FnDef
            (q fp fr fb)
            (case-on (sym_in (qn_name q) visited) Bool
              ((case True
                 (steps
                   ((rewrite (hyp 1) lr lhs true ())
                    (simp lhs)
                    (rewrite (hyp 0) lr lhs true ())
                    (simp lhs)
                    (rewrite (hyp 2) lr lhs true ()))
                   refl))
               (case False
                 (have (= (le 0 (call_pending_fns rest visited)) True)
                   (steps ((rewrite (hyp 2) lr lhs true ())) refl)
                   (have (= (le 0 (sym_len (calls_of_expr fb))) True)
                     (rewrite-with
                       (lemma sym_len_nonneg)
                       lr
                       lhs
                       ((inst xs (calls_of_expr fb)))
                       ()
                       refl)
                     (steps
                       ((rewrite (hyp 1) lr lhs true ())
                        (simp lhs)
                        (rewrite (hyp 0) lr lhs true ())
                        (simp lhs))
                       (by arith (list 1 1 1)))))))))))))))

;; adding x to visited never increases pending.
(claim call_pending_mono
  (goal ((fns (List FnDef)) (x Symbol) (vis (List Symbol))) ()
    (= (le (call_pending_fns fns (Cons x vis)) (call_pending_fns fns vis)) True))
  (induct fns
    ((case Nil (steps ((simp lhs)) refl))
     (case Cons
       (hd rest)
       (case-on hd FnDef
         ((case FnDef
            (q fp fr fb)
            (have
              (=
                (le
                  (call_pending_fns rest (Cons x vis))
                  (call_pending_fns rest vis))
                True)
              (steps ((rewrite (hyp 1) lr lhs true ())) refl)
              (have (= (le 0 (sym_len (calls_of_expr fb))) True)
                (rewrite-with
                  (lemma sym_len_nonneg)
                  lr
                  lhs
                  ((inst xs (calls_of_expr fb)))
                  ()
                  refl)
                (case-on (sym_eq (qn_name q) x) Bool
                  ((case True
                     (case-on (sym_in (qn_name q) vis) Bool
                       ((case True
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))
                        (case False
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 1)))))))
                   (case False
                     (case-on (sym_in (qn_name q) vis) Bool
                       ((case True
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))
                        (case False
                          (steps
                            ((rewrite (hyp 2) lr lhs true ())
                             (simp lhs)
                             (rewrite (hyp 1) lr lhs true ())
                             (rewrite (hyp 0) lr lhs true ())
                             (simp lhs))
                            (by arith (list 1 1 0))))))))))))))))))

;; the productive step (n is an unvisited fn) drops pending by >= 1 + |calls|.
(claim call_pending_drop
  (goal ((n Symbol) (visited (List Symbol)) (fns (List FnDef)))
    ((= (cl_is_some (find_fn_named n fns)) True) (= (sym_in n visited) False))
    (=
      (le
        (+
          (+ 1 (sym_len (cl_calls (find_fn_named n fns))))
          (call_pending_fns fns (Cons n visited)))
        (call_pending_fns fns visited))
      True))
  (induct fns
    ((case Nil (absurd (premise 0)))
     (case Cons
       (hd rest)
       (case-on hd FnDef
         ((case FnDef
            (q fp fr fb)
            (case-on (sym_eq (qn_name q) n) Bool
              ((case True
                 (have (= (qn_name q) n) (by arith (list))
                   (have
                     (=
                       (le
                         (call_pending_fns rest (Cons n visited))
                         (call_pending_fns rest visited))
                       True)
                     (rewrite-with
                       (lemma call_pending_mono)
                       lr
                       lhs
                       ((inst fns rest) (inst x n) (inst vis visited))
                       ()
                       refl)
                     (steps
                       ((rewrite (hyp 1) lr lhs true ())
                        (simp lhs)
                        (rewrite (hyp 0) lr lhs true ())
                        (simp lhs)
                        (rewrite (premise 2) lr lhs true ())
                        (rewrite (premise 1) lr lhs true ())
                        (simp lhs))
                       (by arith (list 1 0 0 0 1))))))
               (case False
                 (have
                   (= (find_fn_named n rest) (find_fn_named n (Cons hd rest)))
                   (steps
                     ((rewrite (hyp 1) lr rhs true ())
                      (simp rhs)
                      (rewrite (hyp 0) lr rhs true ())
                      (simp rhs))
                     refl)
                   (have (= (cl_is_some (find_fn_named n rest)) True)
                     (steps
                       ((rewrite (premise 2) lr lhs true ())
                        (rewrite (premise 0) lr lhs true ()))
                       refl)
                     (have
                       (=
                         (le
                           (+
                             (+ 1 (sym_len (cl_calls (find_fn_named n rest))))
                             (call_pending_fns rest (Cons n visited)))
                           (call_pending_fns rest visited))
                         True)
                       (rewrite-with
                         (hyp 2)
                         lr
                         lhs
                         ((inst n n) (inst visited visited))
                         ((steps ((rewrite (premise 3) lr lhs true ())) refl)
                          (steps ((rewrite (premise 1) lr lhs true ())) refl))
                         refl)
                       (case-on (sym_in (qn_name q) visited) Bool
                         ((case True
                            (steps
                              ((rewrite (hyp 2) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 1) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 0) lr lhs true ())
                               (simp lhs))
                              (by arith (list 1 0 0 0 0 1))))
                          (case False
                            (steps
                              ((rewrite (hyp 2) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 1) lr lhs true ())
                               (simp lhs)
                               (rewrite (hyp 0) lr lhs true ())
                               (simp lhs))
                              (by arith (list 1 0 0 0 0 1)))))))))))))))))))

(fn syms_inter ((xs (List Symbol)) (ys (List Symbol))) (List Symbol)
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons h t) (if (sym_in h ys) (Cons h (syms_inter t ys)) (syms_inter t ys)))))

(fn syms_minus ((xs (List Symbol)) (ys (List Symbol))) (List Symbol)
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons h t) (if (sym_in h ys) (syms_minus t ys) (Cons h (syms_minus t ys))))))

;; ---- ledger rendering -------------------------------------------------------
(fn led_nl () (List Int) (Cons 10 Nil))

;; "name [kind]" — the kind tag, for axiom leaves.
(fn led_ax_item ((n Symbol) (led (List LedgerEntry))) (List Int)
  (match (led_lookup n led)
    (None (chars_of_sym n))
    ((Some (LedgerEntry _ k _))
     (append_int
       (chars_of_sym n)
       (append_int " [" (append_int (chars_of_sym k) "]"))))))

(fn led_ax_items ((ns (List Symbol)) (led (List LedgerEntry))) (List Int)
  (measure (struct ns))
  (match ns
    (Nil "(none)")
    ((Cons n Nil) (led_ax_item n led))
    ((Cons n rest)
     (append_int (led_ax_item n led) (append_int ", " (led_ax_items rest led))))))

(fn led_names ((ns (List Symbol))) (List Int)
  (measure (struct ns))
  (match ns
    (Nil "(none)")
    ((Cons n Nil) (chars_of_sym n))
    ((Cons n rest)
     (append_int (chars_of_sym n) (append_int ", " (led_names rest))))))

(fn led_line ((label (List Int)) (body (List Int))) (List Int)
  (append_int
    "  "
    (append_int label (append_int ": " (append_int body (led_nl))))))

;; a flag line — rendered only when non-empty.
(fn led_line_opt ((label (List Int)) (ns (List Symbol))) (List Int)
  (match ns
    (Nil Nil)
    (_ (led_line label (led_names ns)))))

;; the trust-ledger block for one bin: what this artifact's acceptance
;; transitively rests on. `reach` = citation closure of its requirements;
;; `calls` = run-mode call closure of its entry fn. Informative only — the
;; acceptance-failing checks (trusts/externs/unmet) stay separate.
(fn ledger_block
  ((b Bin) (led (List LedgerEntry)) (own_ext (List Symbol)) (m Module))
  (List Int)
  (match b
    ((Bin name entry externs trusts requires)
     (let ((reach (led_close requires Nil led)))
       (let
         ((calls
            (match m
              ((Module _ fns _ _ _) (call_close (Cons entry Nil) Nil fns)))))
         (append_int
           "LEDGER "
           (append_int
             (chars_of_sym name)
             (append_int
               (led_nl)
               (append_int
                 (led_line
                   "axioms (transitively cited)"
                   (led_ax_items (led_filter reach led (own_ax_kinds)) led))
                 (append_int
                   (led_line
                     "upstream axioms (granted-source, trusted)"
                     (led_names (led_filter reach led (list (quote upstream)))))
                   (append_int
                     (led_line_opt
                       "kernel axioms (reviewed core)"
                       (led_filter reach led (list (quote kernel))))
                     (append_int
                       (led_line
                         "granted (upstream-proven)"
                         (led_names
                           (led_filter reach led (list (quote granted)))))
                       (append_int
                         (led_line
                           "lemmas (proven, interior)"
                           (show_nat
                             (len_syms
                               (led_filter
                                 reach
                                 led
                                 (list (quote claim) (quote fulfills))))))
                         (append_int
                           (led_line
                             "externs (reachable from entry)"
                             (led_names (syms_inter own_ext calls)))
                           (append_int
                             (led_line_opt
                               "externs (declared, unreachable)"
                               (syms_minus own_ext calls))
                             (led_line_opt
                               "own axioms uncited by this bin"
                               (syms_minus (led_own_axioms led) reach)))))))))))))))))

(fn bin_report
  ((b Bin)
   (binmp (List Symbol))
   (th Theory)
   (m Module)
   (led (List LedgerEntry))
   (own_ext (List Symbol)))
  (List ClaimOutcome)
  (match b
    ((Bin name entry externs trusts requires)
     (oc_concat
       (Cons (COBin name (len_syms requires) (count_met requires binmp th)) Nil)
       (oc_concat
         (Cons (COLedger (ledger_block b led own_ext m)) Nil)
         (oc_concat
           (entry_check entry m)
           (oc_concat
             (trusts_check trusts (led_own_axioms led))
             (oc_concat
               (externs_check externs own_ext)
               (unmet_fails requires binmp th)))))))))

(fn bin_reports
  ((bins (List (Pair (List Symbol) Bin)))
   (th Theory)
   (m Module)
   (led (List LedgerEntry))
   (own_ext (List Symbol)))
  (List ClaimOutcome)
  (measure (struct bins))
  (match bins
    (Nil Nil)
    ((Cons (Pair mp b) rest)
     (oc_concat
       (bin_report b mp th m led own_ext)
       (bin_reports rest th m led own_ext)))))

(fn bin_concat
  ((a (List (Pair (List Symbol) Bin))) (b (List (Pair (List Symbol) Bin))))
  (List (Pair (List Symbol) Bin))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (bin_concat t b)))))

(fn bins_with_mp ((mp (List Symbol)) (bs (List Bin)))
  (List (Pair (List Symbol) Bin))
  (measure (struct bs))
  (match bs
    (Nil Nil)
    ((Cons b rest) (Cons (Pair mp b) (bins_with_mp mp rest)))))

(fn bins_of_forms ((forms (List SExpr))) (List Bin)
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (if (is_bin_form f)
       (match (bin_of_form f)
         (None (bins_of_forms rest))
         ((Some b) (Cons b (bins_of_forms rest))))
       (bins_of_forms rest)))))

(fn bins_of_srcs ((srcs (List SrcEntry))) (List (Pair (List Symbol) Bin))
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons (SrcEntry path _ src) rest)
     (match (read_all src)
       (None (bins_of_srcs rest))
       ((Some forms)
        (bin_concat
          (bins_with_mp (module_path_of path) (bins_of_forms forms))
          (bins_of_srcs rest)))))))

;; ---- lib acceptance reporting ----------------------------------------------
;; A `(lib …)` declares a LIBRARY artifact (reader.shard): the module's
;; public functions compiled into a binary and exported BY NAME. Check-side
;; acceptance is DECLARATION well-formedness — every listed export names an
;; implemented fn in the closure (the entry_check posture; a bodyless sig is
;; not an export). Which SIGNATURES may cross a compiled boundary is the
;; lowering emitter's refusal, and the spec ⊑ machine tie is the build
;; gates' job (certs + bytetie + manifest) — neither is re-checked here.
(fn export_impl ((x Symbol) (m Module)) Bool
  (match m
    ((Module _ fns _ _ _)
     (match (find_fn_named x fns)
       (None False)
       ((Some _) True)))))

(fn exports_check ((xs (List Symbol)) (m Module)) (List ClaimOutcome)
  (measure (struct xs))
  (match xs
    (Nil Nil)
    ((Cons x rest)
     (if (export_impl x m) (exports_check rest m)
     (Cons
       (COFail x "lib export: no implemented fn of this name" Nil)
       (exports_check rest m))))))

(fn count_impl ((xs (List Symbol)) (m Module)) Int
  (measure (struct xs))
  (match xs
    (Nil 0)
    ((Cons x rest) (+ (if (export_impl x m) 1 0) (count_impl rest m)))))

;; accepts names must be exports (no phantom exception declarations);
;; the family-vs-cert-surface equality is the artifact toolchain's gate
(fn accepts_check
  ((acc (List (Pair Symbol (List Symbol)))) (exports (List Symbol)))
  (List ClaimOutcome)
  (measure (struct acc))
  (match acc
    (Nil Nil)
    ((Cons (Pair n _) rest)
     (if (sym_in n exports) (accepts_check rest exports)
     (Cons
       (COFail n "lib accepts: not an export of this lib" Nil)
       (accepts_check rest exports))))))

(fn lib_report ((l Lib) (m Module)) (List ClaimOutcome)
  (match l
    ((Lib name exports acc)
     (oc_concat
       (Cons (COLib name (len_syms exports) (count_impl exports m)) Nil)
       (oc_concat (exports_check exports m) (accepts_check acc exports))))))

(fn lib_reports ((ls (List Lib)) (m Module)) (List ClaimOutcome)
  (measure (struct ls))
  (match ls
    (Nil Nil)
    ((Cons l rest) (oc_concat (lib_report l m) (lib_reports rest m)))))

(fn lib_concat ((a (List Lib)) (b (List Lib))) (List Lib)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (lib_concat t b)))))

(fn libs_of_forms ((forms (List SExpr))) (List Lib)
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (if (is_lib_form f)
       (match (lib_of_form f)
         (None (libs_of_forms rest))
         ((Some l) (Cons l (libs_of_forms rest))))
       (libs_of_forms rest)))))

(fn libs_of_srcs ((srcs (List SrcEntry))) (List Lib)
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons (SrcEntry path _ src) rest)
     (match (read_all src)
       (None (libs_of_srcs rest))
       ((Some forms) (lib_concat (libs_of_forms forms) (libs_of_srcs rest)))))))

;; Production entry point: returns the per-claim/axiom outcomes (source order)
;; for the whole file list, checked against m from the empty theory, followed
;; by each bin's acceptance report. `target` is the `--trace` claim name ('all
;; for every claim, or a non-matching sentinel for no tracing).
;; Every requirement still pending at end of run was stated but never
;; fulfilled in this closure — surface each one (the silent-pending hole,
;; closed at check level; the bin form closes it at artifact level).
(fn pending_outcomes ((pend (List PendReq))) (List ClaimOutcome)
  (measure (struct pend))
  (match pend
    (Nil Nil)
    ((Cons (PendReq q _) rest)
     (Cons (COPending (qn_name q)) (pending_outcomes rest)))))

(fn rev_pend ((xs (List PendReq)) (acc (List PendReq))) (List PendReq)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (rev_pend t (Cons h acc)))))

(fn check_production
  ((m Module)
   (srcs (List SrcEntry))
   (ctors (List Symbol))
   (sidecars (List (Pair Symbol (List Int))))
   (target Symbol)
   (focus Symbol))
  (List ClaimOutcome)
  (match
    (run_srcs
      m
      srcs
      ctors
      sidecars
      (RunState TheoryEmpty Nil Nil Nil)
      target
      focus
      1)
    ((RunState th pend acc led)
     (oc_concat
       (rev_outcomes acc Nil)
       (oc_concat
         (pending_outcomes (rev_pend pend Nil))
         (oc_concat
           (bin_reports (bins_of_srcs srcs) th m led (own_externs_of_srcs srcs))
           (oc_concat
             (lib_reports (libs_of_srcs srcs) m)
             (oc_concat
               (mc_outcome m srcs sidecars th focus)
               (rr_outcome m srcs sidecars th focus)))))))))

;; Production entry that builds M IN SHARD. `build_module_d` (reader.shard) parses
;; each source's types/fns via the self-hosted reader and merges them onto
;; `seed` (the kernel's types), threading ctors from `base_ctors` (the kernel's
;; ctor names). The full ctor set for claim parsing is then derived from M
;; itself. This is the default `check` entry — M is no longer built by the Rust
;; loader; load.rs only parses the kernel + toolchain into the VM.
;; the bootstrap ctor prelude every checker-driver consumer seeds with (moved
;; here from check.shard so prove and check share ONE definition). build_module
;; accumulates each closure file's own ctors as it folds, so this only needs
;; the names a first parse can't yet know. The base TYPE DEFS come from the
;; closure itself (the checkee imports the stdlib it needs), so the module
;; seed stays empty.
(fn prelude_ctors () (List Symbol)
  (list
    (quote Cons)
    (quote Nil)
    (quote Some)
    (quote None)
    (quote True)
    (quote False)
    (quote Pair)))

;; ===========================================================================
;; SCOPE REPORT (check.shard's `scope` mode): for a target file, say what the
;; resolver DECIDED — how each use line classified (item / module alias /
;; glob), and which sig→def rebinds fired (with the reason when a candidate
;; did NOT fire) — in the exact closure a normal check builds. The debugging
;; counterpart to silent scope machinery: a misclassified use line or an
;; unfired rebind otherwise surfaces only as a confusing downstream failure
;; (unresolved citation; unfold no-match on a bare name that LOOKS right).
;; ===========================================================================

(fn sr_init ((srcs (List SrcEntry))) (List SrcEntry)
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons _ Nil) Nil)
    ((Cons h t) (Cons h (sr_init t)))))

(fn sr_last ((srcs (List SrcEntry))) (Option SrcEntry)
  (measure (struct srcs))
  (match srcs
    (Nil None)
    ((Cons e Nil) (Some e))
    ((Cons _ t) (sr_last t))))

(fn sr_nl () (List Int) (Cons 10 Nil))

(fn render_modpath ((segs (List Symbol))) (List Int)
  (append_int "(::" (append_int (render_qn_segs segs) ")")))

(fn sr_count ((env (List (Pair Symbol (List Symbol))))) Int
  (measure (struct env))
  (match env
    (Nil 0)
    ((Cons _ t) (+ 1 (sr_count t)))))

(fn sr_or_none ((b (List Int))) (List Int)
  (match b
    (Nil (append_int "  (none)" (sr_nl)))
    (_ b)))

;; one use line's classification, mirroring use_scope_of's decision exactly.
(fn sr_use_line
  ((f SExpr) (curmod (List Symbol)) (env (List (Pair Symbol (List Symbol)))))
  (List Int)
  (match (parse_use_form f)
    (None Nil)
    ((Some (UseGlob segs))
     (let ((globmod (resolve_full_modpath segs curmod Nil)))
       (append_int
         "  GLOB   "
         (append_int
           (render_modpath globmod)
           (append_int
             " *  ->  "
             (append_int
               (show_nat (sr_count (filter_modpath env globmod)))
               (append_int " item(s)" (sr_nl))))))))
    ((Some (UseItem rawq bound))
     (let ((resolved (resolve_qpath (qn_mod rawq) (qn_name rawq) curmod Nil)))
       (let
         ((modid (append_sym (qn_mod resolved) (Cons (qn_name resolved) Nil))))
         (if (item_in_env (qn_name resolved) (qn_mod resolved) env)
           (append_int
             "  ITEM   "
             (append_int
               (chars_of_sym bound)
               (append_int "  ->  " (append_int (render_qn resolved) (sr_nl)))))
         (if (modpath_in_env modid env)
           (append_int
             "  ALIAS  "
             (append_int
               (chars_of_sym bound)
               (append_int
                 "  ->  module "
                 (append_int (render_modpath modid) (sr_nl)))))
           (append_int
             "  ITEM   "
             (append_int
               (chars_of_sym bound)
               (append_int
                 "  ->  "
                 (append_int
                   (render_qn resolved)
                   (append_int
                     "   [WARN: no loaded def at this name+path]"
                     (sr_nl)))))))))))))

(fn sr_use_lines
  ((fs (List SExpr))
   (curmod (List Symbol))
   (env (List (Pair Symbol (List Symbol)))))
  (List Int)
  (measure (struct fs))
  (match fs
    (Nil Nil)
    ((Cons f rest)
     (append_int (sr_use_line f curmod env) (sr_use_lines rest curmod env)))))

;; per-name rebind verdicts. A name with a use item is a CANDIDATE; it fires
;; only when a loaded sig sits at the mapped path AND the path is within this
;; file's own directory module — the unfired cases name the failed condition.
(fn sr_rebind_fns
  ((fnames (List Symbol))
   (uitems (List (Pair Symbol (List Symbol))))
   (exts (List ExternDef))
   (curmod (List Symbol)))
  (List Int)
  (measure (struct fnames))
  (match fnames
    (Nil Nil)
    ((Cons n rest)
     (append_int
       (match (uitem_path n uitems)
         (None Nil)
         ((Some pp)
          (if (sig_at n pp exts)
            (if (supplies_scope_ok pp curmod)
              (append_int
                "  REBIND fn "
                (append_int
                  (chars_of_sym n)
                  (append_int
                    "  ->  supplies sig "
                    (append_int (render_qn (QName pp n)) (sr_nl)))))
              (append_int
                "  NO-REBIND fn "
                (append_int
                  (chars_of_sym n)
                  (append_int
                    "  ->  use maps to "
                    (append_int
                      (render_qn (QName pp n))
                      (append_int
                        " but it is outside this file's directory module"
                        (sr_nl)))))))
            (append_int
              "  NO-REBIND fn "
              (append_int
                (chars_of_sym n)
                (append_int
                  "  ->  use maps to "
                  (append_int
                    (render_qn (QName pp n))
                    (append_int " but no loaded (sig fn) is there" (sr_nl)))))))))
       (sr_rebind_fns rest uitems exts curmod)))))

(fn sr_rebind_types
  ((tnames (List Symbol))
   (uitems (List (Pair Symbol (List Symbol))))
   (tds (List TypeDef))
   (curmod (List Symbol)))
  (List Int)
  (measure (struct tnames))
  (match tnames
    (Nil Nil)
    ((Cons n rest)
     (append_int
       (match (uitem_path n uitems)
         (None Nil)
         ((Some pp)
          (if (sig_type_at n pp tds)
            (if (supplies_scope_ok pp curmod)
              (append_int
                "  REBIND type "
                (append_int
                  (chars_of_sym n)
                  (append_int
                    "  ->  supplies sig type "
                    (append_int (render_qn (QName pp n)) (sr_nl)))))
              (append_int
                "  NO-REBIND type "
                (append_int
                  (chars_of_sym n)
                  (append_int
                    "  ->  use maps to "
                    (append_int
                      (render_qn (QName pp n))
                      (append_int
                        " but it is outside this file's directory module"
                        (sr_nl)))))))
            (append_int
              "  NO-REBIND type "
              (append_int
                (chars_of_sym n)
                (append_int
                  "  ->  use maps to "
                  (append_int
                    (render_qn (QName pp n))
                    (append_int " but no loaded (sig type) is there" (sr_nl)))))))))
       (sr_rebind_types rest uitems tds curmod)))))

(fn scope_report ((srcs (List SrcEntry))) (List Int)
  (match (sr_last srcs)
    (None (append_int "scope: empty closure" (sr_nl)))
    ((Some (SrcEntry path _ src))
     (match
       (build_module_d
         (sr_init srcs)
         (Module Nil Nil Nil (FnTrie None Nil) Nil)
         (prelude_ctors)
         1)
       ((BMFail diag)
        (append_int
          "scope: a dependency failed to load:"
          (append_int (sr_nl) diag)))
       ((BMOk macc)
        (let ((curmod (module_path_of path)))
          (let ((env (module_resolve_env macc)))
            (let ((forms (use_forms src)))
              (match
                (parse_module
                  src
                  (append_sym
                    (typedef_ctors (module_typedefs macc))
                    (prelude_ctors)))
                (None (append_int "scope: target failed to parse" (sr_nl)))
                ((Some pm)
                 (match pm
                   ((Module ptds pfns pexts _ _)
                    (match (use_scope_of forms curmod env)
                      ((Pair uitems _)
                       (append_int
                         "SCOPE  "
                         (append_int
                           path
                           (append_int
                             (sr_nl)
                             (append_int
                               "module: "
                               (append_int
                                 (render_modpath curmod)
                                 (append_int
                                   (sr_nl)
                                   (append_int
                                     (sr_nl)
                                     (append_int
                                       "use lines:"
                                       (append_int
                                         (sr_nl)
                                         (append_int
                                           (sr_or_none
                                             (sr_use_lines forms curmod env))
                                           (append_int
                                             (sr_nl)
                                             (append_int
                                               "rebinds:"
                                               (append_int
                                                 (sr_nl)
                                                 (sr_or_none
                                                   (append_int
                                                     (sr_rebind_fns
                                                       (fndef_names pfns)
                                                       uitems
                                                       (module_externdefs macc)
                                                       curmod)
                                                     (sr_rebind_types
                                                       (typedef_names ptds)
                                                       uitems
                                                       (module_typedefs macc)
                                                       curmod))))))))))))))))))))))))))))))

;; admit mode: build the closure's module (same path as production check)
;; and run the definitional-admissibility analysis over it. Report-only —
;; Phase A of issue #1; nothing is refused. Phase B appends the MEASURED
;; admit mode = the totality CLASSIFICATION report only (nonrec / structural /
;; mutual-resolved / FLAG / unresolved-SCC counts + the per-fn listing). The
;; measure OBLIGATIONS themselves are now checked in the normal `check` pass
;; (mc_outcome), where the run's accumulated theory exists to cite from under
;; the stratified-citation rule — admit mode has no such theory.
(fn admit_report ((srcs (List SrcEntry))) (List Int)
  (match
    (build_module_d
      srcs
      (Module Nil Nil Nil (FnTrie None Nil) Nil)
      (prelude_ctors)
      1)
    ((BMFail diag)
     (append_int
       "admit: a dependency failed to load:"
       (append_int (sr_nl) diag)))
    ((BMOk m)
     (let ((sccs (ad_sccs m)))
       (append_int (admit_scan_s m sccs) (mc_residual_report m sccs srcs))))))

;; ===========================================================================
;; MEASURE CLAUSES (issue #1, Phase B — report-only). A 6-element fn form
;;   (fn NAME PARAMS RET (measure E P…) BODY)
;; declares an Int measure E over the params, plus ONE INLINE PROOF PAIR per
;; recursive call site. Site order = pre-order body walk (a call is recorded
;; before its argument subterms are walked); per site the pair is
;;   decrease:      hyps ⊢ (= (lt E[params:=args] E) True)
;;   nonnegativity: hyps ⊢ (= (le 0 E[params:=args]) True)
;; where hyps are the site's path conditions, outermost first — v1 collects
;; `if` polarities ((= COND True/False)) and CLOSED match arms (no binders,
;; no `_`) as scrutinee equations ((= SCRUT PATTERN)). A site under pattern
;; or let BINDERS is UNSUPPORTED in v1 (reported; its obligations cannot be
;; stated over the params alone until the case-instantiation machinery of
;; Phase B2 lands). Wildcard-only arms walk on without a hyp.
;;
;; The obligation goals are built as goal SEXPRS and run through the SAME
;; pipeline as ordinary claims (parse_goal_r → tc_check_goal → proof parse →
;; desugar → check_sequent) — the only new trusted surface is this
;; generator. Two deliberate restrictions keep the check circularity-free:
;; proofs are checked against M-MINUS-SCC (the fn's whole SCC removed from
;; the module, so the definitions under admission are OPAQUE to their own
;; termination proofs) and the GRANTED theory only (the axioms and
;; requirements of granted sources — exactly what check mode itself
;; assumes; never this run's own claims, which are still unchecked when
;; the admission pass runs). Failure direction is
;; sound: a wrongly-generated obligation can only refuse, never admit.
;; ===========================================================================

;; one extracted clause: name, type params, params form, measure E,
;; inline proofs, body form.
(type MCl (MCl Symbol (List Symbol) SExpr SExpr (List SExpr) SExpr))

(fn mc_of_forms ((forms (List SExpr)) (acc (List MCl))) (List MCl)
  (measure (struct forms))
  (match forms
    (Nil acc)
    ((Cons f rest)
     (match (form_head f)
       (None (mc_of_forms rest acc))
       ((Some h)
        (if (sym_eq h (quote fn))
          (match (form_tail f)
            ((Cons
               nameForm
               (Cons pForm (Cons _ (Cons clauseForm (Cons bodyForm Nil)))))
             (match (form_head clauseForm)
               (None (mc_of_forms rest acc))
               ((Some ch)
                (if (sym_eq ch (quote measure))
                  (match (parse_head nameForm)
                    (None (mc_of_forms rest acc))
                    ((Some (Pair name tparams))
                     (match (form_tail clauseForm)
                       (Nil (mc_of_forms rest acc))  ; (measure) — malformed; parse gate rejects elsewhere
                       ((Cons msr proofs)
                        (mc_of_forms
                          rest
                          (Cons
                            (MCl name tparams pForm msr proofs bodyForm)
                            acc))))))
                  (mc_of_forms rest acc)))))
            (_ (mc_of_forms rest acc)))
          (mc_of_forms rest acc)))))))

;; ---- unannotated-recursive-SCC enumerator (issue #1, the Phase-D flip prereq)
;; mc_outcome verifies the fns that DECLARE a measure clause; it cannot see a
;; recursive SCC that declares NONE. This pass closes that gap for the flip: it
;; walks every SCC (ad_sccs) and, for each RECURSIVE one (ad_scc_verdict is not
;; AdNonRec), reports any member carrying no (measure …) clause. Identity matches
;; the gate exactly — a clause's QName is (QName (module_path_of path) name), the
;; same key mc_check_fn uses for trie_lookup / mc_scc_of. Report-only today (it
;; rides the `admit` diagnostic, leaving the normal check/corpus output byte-
;; unchanged); the enforcement flip turns a non-empty result into a COFail.
;; NOTE: a type-parametric member is exempt at flip time (mc_check_fn SKIPs poly
;; fns — the monomorphic-only v1 limit); the kernel closure has no poly fns so
;; the report needs no exemption today.

;; Resolve a clause's fn to its REAL qname — mirrors mc_check_fn: a same-module
;; fn keys in the modpath trie; a REBOUND opaque sig fn lives at its interface
;; qname (the trie misses) → unique short-name fallback. Without this the
;; residual keys a rebound clause at the file-path qname, never matches the SCC's
;; (rebound) qname, and falsely reports the fn as unannotated. Fail-safe: an
;; unresolvable name keeps the file-path qname (at worst a spurious residual
;; line, never a missed non-terminating fn).
(fn mc_resolve_qn ((tr FnTrie) (fns (List FnDef)) (q QName) (name Symbol)) QName
  (match (trie_lookup q tr)
    ((Some (FnDef rq _ _ _)) rq)
    (None
      (match (mc_uniq_short fns name)
        ((Some (FnDef rq _ _ _)) rq)
        (None q)))))

;; QNames of every measure-clause-bearing fn in one source (rebind-resolved).
(fn mc_clause_qns_of
  ((tr FnTrie)
   (fns (List FnDef))
   (path (List Int))
   (mcls (List MCl))
   (acc (List QName)))
  (List QName)
  (measure (struct mcls))
  (match mcls
    (Nil acc)
    ((Cons (MCl name _ _ _ _ _) rest)
     (mc_clause_qns_of
       tr
       fns
       path
       rest
       (Cons (mc_resolve_qn tr fns (QName (module_path_of path) name) name) acc)))))

;; QNames of every measure-clause-bearing fn across the closure's sources.
(fn mc_clause_qns
  ((tr FnTrie) (fns (List FnDef)) (srcs (List SrcEntry)) (acc (List QName)))
  (List QName)
  (measure (struct srcs))
  (match srcs
    (Nil acc)
    ((Cons (SrcEntry path _ src) rest)
     (match (read_all src)
       (None (mc_clause_qns tr fns rest acc))
       ((Some forms)
        (mc_clause_qns
          tr
          fns
          rest
          (mc_clause_qns_of tr fns path (mc_of_forms forms Nil) acc)))))))

(fn mc_qn_in ((q QName) (qs (List QName))) Bool
  (measure (struct qs))
  (match qs
    (Nil False)
    ((Cons h t) (if (qname_eq q h) True (mc_qn_in q t)))))

;; members of ONE scc carrying no clause (caller has gated on recursive).
(fn mc_scc_missing ((scc (List QName)) (annot (List QName)) (acc (List QName)))
  (List QName)
  (measure (struct scc))
  (match scc
    (Nil acc)
    ((Cons q rest)
     (if (mc_qn_in q annot) (mc_scc_missing rest annot acc)
     (mc_scc_missing rest annot (Cons q acc))))))

(fn mc_unannot_go
  ((tr FnTrie)
   (sccs (List (List QName)))
   (annot (List QName))
   (acc (List QName)))
  (List QName)
  (measure (struct sccs))
  (match sccs
    (Nil acc)
    ((Cons scc rest)
     (match (ad_scc_verdict tr scc)
       ((AdNonRec) (mc_unannot_go tr rest annot acc))
       (_ (mc_unannot_go tr rest annot (mc_scc_missing scc annot acc)))))))

(fn mc_unannot_lines ((qs (List QName))) (List Int)
  (measure (struct qs))
  (match qs
    (Nil Nil)
    ((Cons q rest)
     (append_int
       "UNANNOTATED-REC "
       (append_int
         (qn_key_chars q)
         (append_int (sr_nl) (mc_unannot_lines rest)))))))

;; the residual section: recursive-SCC members declaring no measure clause.
;; Cross-references ad_sccs against the clause-bearing QName set — the half the
;; measure-BLIND admit scan above cannot compute.
(fn mc_residual_report
  ((m Module) (sccs (List (List QName))) (srcs (List SrcEntry)))
  (List Int)
  (match m
    ((Module _ fns _ tr _)
     (let
       ((missing (mc_unannot_go tr sccs (mc_clause_qns tr fns srcs Nil) Nil)))
       (append_int
         (sr_nl)
         (append_int
           "---- recursive SCCs lacking a measure clause ----"
           (append_int
             (sr_nl)
             (match missing
               (Nil "(none — every recursive SCC declares a measure clause)")
               (_ (mc_unannot_lines missing))))))))))

;; ---- the site walker (SOURCE level) ---------------------------------------

;; one recursive call site: index, pattern/let binders in scope at the
;; site, path-condition hyps (OUTERMOST FIRST), args.
;;
;; B2: a site under binders is no longer wholesale-unsupported. At
;; obligation time the substituted measure must be PARAM-PURE (every
;; variable a param, none shadowed by a binder) — else the site is
;; UNSUPPORTED — and binder-mentioning hyps are DROPPED (sound: fewer
;; premises only strengthens the obligation; the drop count is reported
;; on failures so a missing premise is diagnosable). Binder-typed goals
;; (for measures that descend through the data itself, e.g. (len t))
;; arrive with the lemma/theory support they need — Phase C.
;; a recursive (in-SCC) call site: pre-order index, in-scope binders, typed
;; binders, accumulated path-condition hyps, the call's arg forms, and the
;; CALLEE's QName (which SCC member is called — self or a sibling). The callee
;; identity selects whose measure goes on the LHS of the decrease obligation.
(type MSiteS
  (MSiteS
    Int
    (List Symbol)
    (List (Pair Symbol Type))
    (List SExpr)
    (List SExpr)
    QName))

(fn mc_sym_member ((s Symbol) (xs (List Symbol))) Bool
  (measure (struct xs))
  (match xs
    (Nil False)
    ((Cons h t) (if (sym_eq h s) True (mc_sym_member s t)))))

(fn mc_is_lower ((s Symbol)) Bool
  (match (chars_of_sym s)
    (Nil False)
    ((Cons c _) (if (le 97 c) (le c 122) False))))

;; variables of a pattern: lowercase atoms (wildcard `_` binds nothing).
(fn mc_pat_binders ((p SExpr) (acc (List Symbol))) (List Symbol)
  (measure (struct p))
  (match p
    ((SSym s) (if (mc_is_lower s) (Cons s acc) acc))
    ((SList items) (mc_pats_binders items acc))
    (_ acc)))

(fn mc_pats_binders ((ps (List SExpr)) (acc (List Symbol))) (List Symbol)
  (measure (struct ps))
  (match ps
    (Nil acc)
    ((Cons p rest) (mc_pats_binders rest (mc_pat_binders p acc)))))

;; let-bound names from a ((x e) …) bindings form.
(fn mc_let_binders ((binds SExpr) (acc (List Symbol))) (List Symbol)
  (match binds
    ((SList bs) (mc_let_binders_go bs acc))
    (_ acc)))

(fn mc_let_binders_go ((bs (List SExpr)) (acc (List Symbol))) (List Symbol)
  (measure (struct bs))
  (match bs
    (Nil acc)
    ((Cons (SList (Cons (SSym x) _)) rest)
     (mc_let_binders_go rest (Cons x acc)))
    ((Cons _ rest) (mc_let_binders_go rest acc))))

;; param-purity: every VARIABLE (lowercase atom outside head position)
;; is a param and not shadowed by an in-scope binder. (:: …) qualified
;; names and (quote …) literals are pure as wholes; an inner match/let
;; inside an argument shows its binders as unknown atoms and is refused
;; conservatively.
(fn mc_pure_atom ((s Symbol) (pnames (List Symbol)) (bnds (List Symbol))) Bool
  (if (mc_is_lower s) (if (mc_sym_member s bnds) False (mc_sym_member s pnames))
  True))

(fn mc_pure ((e SExpr) (pnames (List Symbol)) (bnds (List Symbol))) Bool
  (measure (struct e))
  (match e
    ((SSym s) (mc_pure_atom s pnames bnds))
    ((SList items)
     (match items
       (Nil True)
       ((Cons h rest)
        (match h
          ((SSym hs)
           (if (sym_eq hs (quote ::)) True
           (if (sym_eq hs (quote quote)) True
           (mc_pure_list rest pnames bnds))))
          ((SList _)
           (if (mc_pure h pnames bnds) (mc_pure_list rest pnames bnds) False))
          (_ (mc_pure_list rest pnames bnds))))))
    (_ True)))

(fn mc_pure_list ((es (List SExpr)) (pnames (List Symbol)) (bnds (List Symbol)))
  Bool
  (measure (struct es))
  (match es
    (Nil True)
    ((Cons e rest)
     (if (mc_pure e pnames bnds) (mc_pure_list rest pnames bnds) False))))

;; split hyps into (kept, dropped-count): binder-dependent hyps go.
(fn mc_keep_hyps
  ((hyps (List SExpr)) (pnames (List Symbol)) (bnds (List Symbol)))
  (Pair (List SExpr) Int)
  (measure (struct hyps))
  (match hyps
    (Nil (Pair Nil 0))
    ((Cons h rest)
     (match (mc_keep_hyps rest pnames bnds)
       ((Pair ks n)
        (if (mc_pure h pnames bnds) (Pair (Cons h ks) n) (Pair ks (+ n 1))))))))

;; pattern scan: 0 = closed (usable as an expression), 1 = wildcards only
;; (no hyp, but no capture either), 2 = binds names.
(fn mc_pat_scan ((p SExpr)) Int
  (measure (struct p))
  (match p
    ((SSym s)
     (match (chars_of_sym s)
       (Nil 0)
       ((Cons c _)
        (if (int_eq c 95) 1  ; '_'
        (if (le 97 c) (if (le c 122) 2 0)
        0)))))
    ((SList items) (mc_pats_scan items))
    (_ 0)))

(fn mc_pats_scan ((ps (List SExpr))) Int
  (measure (struct ps))
  (match ps
    (Nil 0)
    ((Cons p rest)
     (let ((a (mc_pat_scan p)))
       (let ((b (mc_pats_scan rest))) (if (lt a b) b a))))))

;; (= LHS RHS) as a goal-premise sexpr.
(fn mc_eq_s ((l SExpr) (r SExpr)) SExpr
  (SList (Cons (SSym (quote =)) (Cons l (Cons r Nil)))))

(fn mc_hyp ((cond SExpr) (pol Symbol)) SExpr (mc_eq_s cond (SSym pol)))

;; is this call head the measured fn? Bare name, or a (:: … name)
;; qualified head (so a qualified self-call cannot dodge its obligation).
(fn mc_head_is ((f Symbol) (h SExpr)) Bool
  (match h
    ((SSym s) (sym_eq s f))
    ((SList items)
     (match items
       ((Cons (SSym qq) rest)
        (if (sym_eq qq (quote ::)) (mc_last_is f rest) False))
       (_ False)))
    (_ False)))

(fn mc_last_is ((f Symbol) (items (List SExpr))) Bool
  (measure (struct items))
  (match items
    (Nil False)
    ((Cons (SSym s) Nil) (sym_eq s f))
    ((Cons _ rest) (mc_last_is f rest))))

;; ---- binder typing (Phase C case instantiation) -----------------------------
;; A binder-ful arm whose scrutinee TYPE synthesizes lets its binders enter
;; scope TYPED, and the arm equation (= SCRUT PAT) becomes a recorded path
;; condition (PAT read as the ctor expression over its binders). Sites whose
;; measure substitution references those binders then state their obligations
;; over the fn params PLUS the typed binders. Synthesis v1 is deliberately
;; small — a param/binder name or a bare same-module call with a ground
;; return type; anything else leaves the arm untyped (the B2 behavior, which
;; is refusal-only and therefore sound).

(fn mc_app_tbs ((a (List (Pair Symbol Type))) (b (List (Pair Symbol Type))))
  (List (Pair Symbol Type))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (mc_app_tbs t b)))))

(fn mc_app_syms ((a (List Symbol)) (b (List Symbol))) (List Symbol)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (mc_app_syms t b)))))

(fn mc_pat_has_wild ((p SExpr)) Bool
  (measure (struct p))
  (match p
    ((SSym s)
     (match (chars_of_sym s)
       ((Cons c _) (int_eq c 95))
       (Nil False)))
    ((SList items) (mc_pats_have_wild items))
    (_ False)))

(fn mc_pats_have_wild ((ps (List SExpr))) Bool
  (measure (struct ps))
  (match ps
    (Nil False)
    ((Cons p rest) (if (mc_pat_has_wild p) True (mc_pats_have_wild rest)))))

(fn mc_env_ty ((env (List (Pair Symbol Type))) (x Symbol)) (Option Type)
  (measure (struct env))
  (match env
    (Nil None)
    ((Cons (Pair n ty) rest) (if (sym_eq n x) (Some ty) (mc_env_ty rest x)))))

(fn mc_ty_ground ((t Type)) Bool
  (measure (struct t))
  (match t
    ((TVar _) False)
    ((TCon _ args) (mc_tys_ground args))))

(fn mc_tys_ground ((ts (List Type))) Bool
  (measure (struct ts))
  (match ts
    (Nil True)
    ((Cons h t) (if (mc_ty_ground h) (mc_tys_ground t) False))))

;; a fn's return type, if it is GROUND (no type variables) — the only case the
;; binder-typer can use, since an obligation goal must be fully typed.
(fn mc_fd_ground_ret ((fd FnDef)) (Option Type)
  (match fd
    ((FnDef _ _ ret _) (if (mc_ty_ground ret) (Some ret) None))))

;; the fns in `fns` whose SHORT name is `h`. Homonyms across the merged import
;; closure (build_module concatenates every file's fns) show here as more than
;; one entry.
(fn mc_short_matches ((fns (List FnDef)) (h Symbol)) (List FnDef)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons fd rest)
     (match fd
       ((FnDef q _ _ _)
        (if (sym_eq (qn_name q) h) (Cons fd (mc_short_matches rest h))
        (mc_short_matches rest h)))))))

;; the UNIQUE fn of short name `h`, if exactly one exists. Used by mc_synth to
;; resolve an IMPORTED call scrutinee (whose qname is NOT modpath-local, so the
;; trie lookup below misses). Soundness is fail-safe: if `h` is a homonym (≥2
;; matches) or a miss, we return None and the arm stays untyped (the B2 refusal
;; behavior). And a WRONG synthesis can never falsely admit — it would make the
;; obligation goal ill-typed, so the site is rejected, not accepted.
(fn mc_uniq_short ((fns (List FnDef)) (h Symbol)) (Option FnDef)
  (match (mc_short_matches fns h)
    ((Cons fd Nil) (Some fd))
    (_ None)))

(fn mc_synth
  ((m Module) (modpath (List Symbol)) (env (List (Pair Symbol Type))) (e SExpr))
  (Option Type)
  (match e
    ((SSym x) (mc_env_ty env x))
    ((SList items)
     (match items
       ((Cons (SSym h) _)
        (if (mc_is_lower h)
          (match m
            ((Module _ fns _ tr _)
             ;; same-module fns resolve exactly via the modpath-keyed trie; an
             ;; imported call misses there and falls back to a unique short-name
             ;; scan over the merged fns list.
             (match (trie_lookup (QName modpath h) tr)
               ((Some fd) (mc_fd_ground_ret fd))
               (None
                 (match (mc_uniq_short fns h)
                   ((Some fd) (mc_fd_ground_ret fd))
                   (None None))))))
          None))
       (_ None)))
    (_ None)))

(fn mc_td_find ((tds (List TypeDef)) (q QName)) (Option TypeDef)
  (measure (struct tds))
  (match tds
    (Nil None)
    ((Cons td rest)
     (match td
       ((TypeDef tq _ _ _) (if (qname_eq tq q) (Some td) (mc_td_find rest q)))))))

(fn mc_ctor_find ((cds (List CtorDef)) (c Symbol)) (Option CtorDef)
  (measure (struct cds))
  (match cds
    (Nil None)
    ((Cons cd rest)
     (match cd
       ((CtorDef cq _)
        (if (sym_eq (qn_name cq) c) (Some cd) (mc_ctor_find rest c)))))))

(fn mc_tp_zip ((tps (List Symbol)) (targs (List Type)))
  (Option (List (Pair Symbol Type)))
  (measure (struct tps))
  (match tps
    (Nil
      (match targs
        (Nil (Some Nil))
        (_ None)))
    ((Cons p prest)
     (match targs
       (Nil None)
       ((Cons a arest)
        (match (mc_tp_zip prest arest)
          (None None)
          ((Some env) (Some (Cons (Pair p a) env)))))))))

;; pattern binders with their types under scrutinee type TY.
(fn mc_pat_tenv ((m Module) (pat SExpr) (ty Type))
  (Option (List (Pair Symbol Type)))
  (measure (struct pat))
  (match pat
    ((SSym s) (if (mc_is_lower s) (Some (Cons (Pair s ty) Nil)) (Some Nil)))
    ((SInt _) (Some Nil))
    ((SList (Cons (SSym c) ps))
     (if (sym_eq c (quote quote)) (Some Nil)
     (match ty
       ((TVar _) None)
       ((TCon q targs)
        (match (mc_td_find (module_typedefs m) q)
          (None None)
          ((Some td)
           (match td
             ((TypeDef _ tps ctors _)
              (match (mc_ctor_find ctors c)
                (None None)
                ((Some cd)
                 (match cd
                   ((CtorDef _ ftys)
                    (match (mc_tp_zip tps targs)
                      (None None)
                      ((Some tenv)
                       (mc_pats_tenv m ps (type_subst_list tenv ftys))))))))))))))))
    (_ None)))

(fn mc_pats_tenv ((m Module) (ps (List SExpr)) (tys (List Type)))
  (Option (List (Pair Symbol Type)))
  (measure (struct ps))
  (match ps
    (Nil
      (match tys
        (Nil (Some Nil))
        (_ None)))
    ((Cons p prest)
     (match tys
       (Nil None)
       ((Cons ty trest)
        (match (mc_pat_tenv m p ty)
          (None None)
          ((Some a)
           (match (mc_pats_tenv m prest trest)
             (None None)
             ((Some b) (Some (mc_app_tbs a b)))))))))))

;; native Type → source form. Resolved (path-carrying) names render as the
;; literal (:: …) path form, which parse_type reads back to the same QName —
;; round-trip identity by construction, and a bad render can only REFUSE at
;; the goal's parse/type gate.
(fn mc_ty_form ((ty Type)) SExpr
  (measure (struct ty))
  (match ty
    ((TVar s) (SSym s))
    ((TCon q args)
     (let ((head (mc_qn_form q)))
       (match args
         (Nil head)
         (_ (SList (Cons head (mc_ty_forms args)))))))))

(fn mc_ty_forms ((ts (List Type))) (List SExpr)
  (measure (struct ts))
  (match ts
    (Nil Nil)
    ((Cons h t) (Cons (mc_ty_form h) (mc_ty_forms t)))))

(fn mc_qn_form ((q QName)) SExpr
  (match q
    ((QName path name)
     (match path
       (Nil (SSym name))
       (_ (SList (Cons (SSym (quote ::)) (mc_seg_forms path name))))))))

(fn mc_seg_forms ((path (List Symbol)) (name Symbol)) (List SExpr)
  (measure (struct path))
  (match path
    (Nil (Cons (SSym name) Nil))
    ((Cons h t) (Cons (SSym h) (mc_seg_forms t name)))))

;; walker context: the module + file module path (for scrutinee-type
;; synthesis), the measured fn's name, and the param type env.
;; the walk context: module, the fn's module path, the fn's own name, its
;; param type env, and the fn's SCC (the QNames of all mutual-recursion
;; members — used to recognize in-SCC calls, self and sibling alike).
(type MCtx
  (MCtx Module (List Symbol) Symbol (List (Pair Symbol Type)) (List QName)))

(fn mcx_scc ((cx MCtx)) (List QName)
  (match cx
    ((MCtx _ _ _ _ scc) scc)))

;; the SCC member whose short name heads `h`, if any (self or sibling). v1 is
;; same-module: SCC members share one module, so their short names are unique
;; and a short-name match is unambiguous. Cross-module SCCs (import cycles,
;; forbidden today) will need use-scope QName resolution here — see
;; docs/TOTALITY.md §7.
(fn mc_head_member ((h SExpr) (scc (List QName))) (Option QName)
  (measure (struct scc))
  (match scc
    (Nil None)
    ((Cons q rest)
     (if (mc_head_is (qn_name q) h) (Some q) (mc_head_member h rest)))))

(fn mc_walk_list
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (es (List SExpr))
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (size_sexpr_list es))
  (match es
    (Nil st)
    ((Cons e rest)
     (mc_walk_list cx bnds tbs hyps rest (mc_walk cx bnds tbs hyps e st)))))

(fn mc_walk_arms
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (scrut SExpr)
   (arms (List SExpr))
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (size_sexpr_list arms))
  (match arms
    (Nil st)
    ((Cons arm rest)
     (match arm
       ((SList (Cons pat (Cons body Nil)))
        (let ((sc (mc_pat_scan pat)))
          (mc_walk_arms
            cx
            bnds
            tbs
            hyps
            scrut
            rest
            (if (int_eq sc 0)
              (mc_walk cx bnds tbs (Cons (mc_eq_s scrut pat) hyps) body st)
            (if (int_eq sc 1) (mc_walk cx bnds tbs hyps body st)
            (mc_binder_arm cx bnds tbs hyps scrut pat body st))))))
       (_ (mc_walk_arms cx bnds tbs hyps scrut rest st))))))

;; a binder-ful arm: typed when the scrutinee synthesizes, the pattern has
;; no wildcards, and every binder gets a type — else the B2 untyped walk.
(fn mc_binder_arm
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (scrut SExpr)
   (pat SExpr)
   (body SExpr)
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (+ 1 (+ (size_sexpr pat) (size_sexpr body))))
  (let ((bnds2 (mc_pat_binders pat bnds)))
    (if (mc_pat_has_wild pat) (mc_walk cx bnds2 tbs hyps body st)
    (match cx
      ((MCtx m modpath _ penv _)
       (match (mc_synth m modpath (mc_app_tbs tbs penv) scrut)
         (None (mc_walk cx bnds2 tbs hyps body st))
         ((Some sty)
          (match (mc_pat_tenv m pat sty)
            (None (mc_walk cx bnds2 tbs hyps body st))
            ((Some newtbs)
             (mc_walk
               cx
               bnds2
               (mc_app_tbs newtbs tbs)
               (Cons (mc_eq_s scrut pat) hyps)
               body
               st))))))))))

(fn mc_let_rhss
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (binds SExpr)
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (size_sexpr binds))
  (match binds
    ((SList bs) (mc_let_rhss_go cx bnds tbs hyps bs st))
    (_ st)))

(fn mc_let_rhss_go
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (bs (List SExpr))
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (size_sexpr_list bs))
  (match bs
    (Nil st)
    ((Cons b rest)
     (match b
       ;; `nm` (the binding name) is named, not `_`, so the measure gate emits the
       ;; structural premise b=(SList (Cons nm (Cons rhs Nil))) that links rhs to
       ;; bs — a wildcard there would drop it and leave the decrease unprovable.
       ((SList (Cons nm (Cons rhs Nil)))
        (mc_let_rhss_go cx bnds tbs hyps rest (mc_walk cx bnds tbs hyps rhs st)))
       (_ (mc_let_rhss_go cx bnds tbs hyps rest st))))))

(fn mc_walk
  ((cx MCtx)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (e SExpr)
   (st (Pair Int (List MSiteS))))
  (Pair Int (List MSiteS))
  (measure (size_sexpr e))
  (match e
    ((SList items)
     (match items
       ((Cons h rest)
        (match (mc_head_member h (mcx_scc cx))
          ;; an in-SCC call (self or sibling): record (pre-order) WITH the
          ;; callee QName, then walk the args.
          ((Some callee)
           (match st
             ((Pair i acc)
              (mc_walk_list
                cx
                bnds
                tbs
                hyps
                rest
                (Pair (+ i 1) (Cons (MSiteS i bnds tbs hyps rest callee) acc))))))
          (None
            (match h
              ((SSym hs)
               (if (sym_eq hs (quote if))
                 (match rest
                   ((Cons c (Cons t (Cons el Nil)))
                    (mc_walk
                      cx
                      bnds
                      tbs
                      (Cons (mc_hyp c (quote False)) hyps)
                      el
                      (mc_walk
                        cx
                        bnds
                        tbs
                        (Cons (mc_hyp c (quote True)) hyps)
                        t
                        (mc_walk cx bnds tbs hyps c st))))
                   (_ (mc_walk_list cx bnds tbs hyps rest st)))
               (if (sym_eq hs (quote match))
                 (match rest
                   ((Cons scrut arms)
                    (mc_walk_arms
                      cx
                      bnds
                      tbs
                      hyps
                      scrut
                      arms
                      (mc_walk cx bnds tbs hyps scrut st)))
                   (_ st))
               (if (sym_eq hs (quote let))
                 (match rest
                   ((Cons binds bodyrest)
                    (mc_walk_list
                      cx
                      (mc_let_binders binds bnds)
                      tbs
                      hyps
                      bodyrest
                      (mc_let_rhss cx bnds tbs hyps binds st)))
                   (_ st))
                 (mc_walk_list cx bnds tbs hyps rest st)))))
              (_ (mc_walk_list cx bnds tbs hyps items st))))))
       (Nil st)))
    (_ st)))

;; ---- obligation goal construction ------------------------------------------

;; param names from the params form ((x T) (y T2) …).
(fn mc_pnames ((pForm SExpr)) (Option (List Symbol))
  (match pForm
    ((SList ps) (mc_pnames_go ps))
    (_ None)))

(fn mc_pnames_go ((ps (List SExpr))) (Option (List Symbol))
  (measure (struct ps))
  (match ps
    (Nil (Some Nil))
    ((Cons (SList (Cons (SSym x) _)) rest)
     (match (mc_pnames_go rest)
       (None None)
       ((Some xs) (Some (Cons x xs)))))
    (_ None)))

;; capture-naive substitution: every (SSym x) with x in sub is replaced.
;; Sound here because the substituted result must then pass mc_pure —
;; any captured/binder-referencing occurrence makes the site UNSUPPORTED
;; before an obligation is ever stated.
(fn mc_subst ((sub (List (Pair Symbol SExpr))) (e SExpr)) SExpr
  (measure (struct e))
  (match e
    ((SSym s) (mc_subst_lookup sub s e))
    ((SList items) (SList (mc_subst_list sub items)))
    (_ e)))

(fn mc_subst_lookup ((sub (List (Pair Symbol SExpr))) (s Symbol) (orig SExpr))
  SExpr
  (measure (struct sub))
  (match sub
    (Nil orig)
    ((Cons (Pair x v) rest) (if (sym_eq x s) v (mc_subst_lookup rest s orig)))))

(fn mc_subst_list ((sub (List (Pair Symbol SExpr))) (es (List SExpr)))
  (List SExpr)
  (measure (struct es))
  (match es
    (Nil Nil)
    ((Cons e rest) (Cons (mc_subst sub e) (mc_subst_list sub rest)))))

(fn mc_zip ((xs (List Symbol)) (es (List SExpr)))
  (Option (List (Pair Symbol SExpr)))
  (measure (struct xs))
  (match xs
    (Nil
      (match es
        (Nil (Some Nil))
        (_ None)))
    ((Cons x xr)
     (match es
       (Nil None)
       ((Cons e er)
        (match (mc_zip xr er)
          (None None)
          ((Some ps) (Some (Cons (Pair x e) ps)))))))))

;; (goal PARAMS (HYPS…) (= (REL A B) True))
(fn mc_goal_s
  ((pForm SExpr) (hyps (List SExpr)) (rel Symbol) (a SExpr) (b SExpr))
  SExpr
  (SList
    (Cons
      (SSym (quote goal))
      (Cons
        pForm
        (Cons
          (SList (reverse_sx hyps))
          (Cons
            (mc_eq_s
              (SList (Cons (SSym rel) (Cons a (Cons b Nil))))
              (SSym (quote True)))
            Nil))))))

(fn reverse_sx ((xs (List SExpr))) (List SExpr) (reverse_sx_go xs Nil))

(fn reverse_sx_go ((xs (List SExpr)) (acc (List SExpr))) (List SExpr)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (reverse_sx_go t (Cons h acc)))))

;; ---- checking one obligation through the claim pipeline -------------------

;; None = passed; Some reason = failed.
(fn mc_check_one
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (gname Symbol)
   (gs SExpr)
   (ps SExpr)
   (autos (List (Pair Symbol SExpr))))
  (Option (List Int))
  (match (parse_goal_r m gctx gs)
    (None (Some "could not parse the generated obligation goal"))
    ((Some g)
     (match (tc_check_goal m g)
       ((Some msg) (Some msg))
       (None
         (match (parse_proof_auto m gctx gname ps autos g)
           ((PrfErr emsg) (Some emsg))
           ((PrfOk p)
            (if (check_sequent m2 th (lift_sequent g) p) None
            (Some "obligation proof rejected")))))))))

;; M with an SCC made opaque: those fns are dropped from the fn list and
;; the trie is rebuilt, so the definitions under admission are stuck terms
;; to their own termination proofs (the circularity guard).
(fn mc_fns_minus ((fns (List FnDef)) (scc (List QName))) (List FnDef)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons fd rest)
     (match fd
       ((FnDef q _ _ _)
        (if (ad_qn_member q scc) (mc_fns_minus rest scc)
        (Cons fd (mc_fns_minus rest scc))))))))

(fn mc_opaque ((m Module) (scc (List QName))) Module
  (match m
    ((Module tds fns exts _ items)
     (let ((fns2 (mc_fns_minus fns scc)))
       (Module tds fns2 exts (build_fn_trie fns2) items)))))

(fn mc_scc_of ((q QName) (sccs (List (List QName)))) (List QName)
  (measure (struct sccs))
  (match sccs
    (Nil (Cons q Nil))
    ((Cons scc rest) (if (ad_qn_member q scc) scc (mc_scc_of q rest)))))

;; ---- per-fn driver ---------------------------------------------------------

(fn mc_show_i ((i Int)) (List Int) (show_nat i))

(fn mc_line ((key (List Int)) (msg (List Int))) (List Int)
  (append_int
    "MEASURED "
    (append_int key (append_int " " (append_int msg (sr_nl))))))

;; appended to a site's failure when binder-dependent hyps were dropped —
;; the missing premise may be exactly the dropped one.
(fn mc_drop_note ((key (List Int)) (ndrop Int)) (List Int)
  (if (lt 0 ndrop)
    (append_int
      "    note: "
      (append_int
        (mc_show_i ndrop)
        (append_int
          " binder-dependent hyp(s) were dropped from this obligation"
          (sr_nl))))
    Nil))

;; a failed obligation: the MEASURED line plus the indented reason.
(fn mc_fail_line ((key (List Int)) (i Int) (kind (List Int)) (why (List Int)))
  (List Int)
  (append_int
    (mc_line key (append_int "FAIL site " (append_int (mc_show_i i) kind)))
    (append_int "    " (append_int why (sr_nl)))))

;; the synthetic sidecar key for one site's proof: `<fn>#<site>#<kind>`, where
;; kind is "decrease" or "nonneg". `#` is not a reader delimiter (is_delim), so
;; this round-trips as a single symbol in a (proof-for NAME PROOF) sidecar
;; entry — no change to the sidecar format, which is keyed by claim NAME. A bare
;; `(measure E)` clause makes each site's proof the `auto` token; auto_lookup
;; then matches this key against the file's <file>.auto.shard entries.
(fn mc_site_key ((fname Symbol) (i Int) (kind (List Int))) Symbol
  (sym_of_chars
    (append_int
      (chars_of_sym fname)
      (append_int "#" (append_int (mc_show_i i) (append_int "#" kind))))))

;; check one site's decrease + nonnegativity pair. None = both pass. `autos` is
;; the file's sidecar entries: an `auto` proof on a bare measure clause resolves
;; through it by the per-site synthetic key.
(fn mc_site_pair
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (fname Symbol)
   (key (List Int))
   (pForm SExpr)
   (hyps (List SExpr))
   (msr2 SExpr)
   (msr SExpr)
   (i Int)
   (p1 SExpr)
   (p2 SExpr)
   (autos (List (Pair Symbol SExpr))))
  (Option (List Int))
  (match
    (mc_check_one
      m
      m2
      th
      gctx
      (mc_site_key fname i "decrease")
      (mc_goal_s pForm hyps (quote lt) msr2 msr)
      p1
      autos)
    ((Some why) (Some (mc_fail_line key i " decrease:" why)))
    (None
      (match
        (mc_check_one
          m
          m2
          th
          gctx
          (mc_site_key fname i "nonneg")
          (mc_goal_s pForm hyps (quote le) (SInt 0) msr2)
          p2
          autos)
        ((Some why) (Some (mc_fail_line key i " nonneg:" why)))
        (None None)))))

;; the MCl of the named fn among `mcls` (this file's measure clauses).
(fn mc_mcl_find ((name Symbol) (mcls (List MCl))) (Option MCl)
  (measure (struct mcls))
  (match mcls
    (Nil None)
    ((Cons mcl rest)
     (match mcl
       ((MCl n _ _ _ _ _)
        (if (sym_eq n name) (Some mcl) (mc_mcl_find name rest)))))))

;; the CALLEE's (param names, measure expr) for an in-SCC call. A site's
;; decrease obligation is  callee_measure[args] < caller_measure[params]  —
;; the LHS comes from here, so the args must zip against the callee's params
;; and substitute into the callee's measure (self-calls fall out as callee =
;; caller). None = the SCC member has no measure clause (incompletely
;; annotated SCC — see docs/TOTALITY.md §8).
(fn mc_callee_measure ((callee QName) (mcls (List MCl)))
  (Option (Pair (List Symbol) SExpr))
  (match (mc_mcl_find (qn_name callee) mcls)
    (None None)
    ((Some (MCl _ _ cpForm cmsr _ _))
     (match (mc_pnames cpForm)
       (None None)
       ((Some cpnames) (Some (Pair cpnames cmsr)))))))

;; ---- structural measures: (measure (struct ARG)) --------------------------
;; Verify-don't-search (docs/TOTALITY.md §4): the author DECLARES the descending
;; parameter; the gate verifies that every recursive call passes, at the
;; CALLEE's declared position, a strict subterm rooted at THIS member's declared
;; position. No proof, no path conditions — a strict subterm is unconditionally
;; smaller on every branch, and every site must pass, so the structural notion
;; is path-insensitive (unlike the numeric gate's mc_walk, which must collect
;; path conditions). Reuses admit.shard's subterm CLASSIFICATION
;; (ad_fn_sites / ad_cls_at) over the elaborated body; the SEARCH admit uses to
;; *discover* a designation (ad_fix / ad_pick / ad_self_find) stays advisory and
;; out of the trust path.

;; head test for the numeric-vs-structural dispatch in mc_check_fn.
(fn mc_is_struct ((msr SExpr)) Bool
  (match (form_head msr)
    (None False)
    ((Some h) (sym_eq h (quote struct)))))

;; the 0-based index of NAME among the parameter names (source order, first = 0
;; — the same convention ad_env0/ad_cls_at use for the subterm root index).
(fn mc_name_index ((name Symbol) (names (List Symbol)) (i Int)) (Option Int)
  (measure (struct names))
  (match names
    (Nil None)
    ((Cons h t) (if (sym_eq h name) (Some i) (mc_name_index name t (+ i 1))))))

;; the declared descending index from a (struct ARG) clause, or None if msr is
;; not a well-formed struct clause naming a parameter. The head re-check keeps a
;; numeric measure like (size e) from being misread as (struct e).
(fn mc_struct_pos ((msr SExpr) (pnames (List Symbol))) (Option Int)
  (match (form_head msr)
    (None None)
    ((Some h)
     (if (sym_eq h (quote struct))
       (match (form_tail msr)
         ((Cons (SSym arg) Nil) (mc_name_index arg pnames 0))
         (_ None))
       None))))

;; the CALLEE's declared descending index, from its own (struct …) clause.
;; None = the callee carries no struct clause (an incompletely / mixed-annotated
;; SCC) — structural descent across the SCC is then unverifiable and the site
;; must FAIL, never silently pass.
(fn mc_callee_struct_pos ((callee QName) (mcls (List MCl))) (Option Int)
  (match (mc_mcl_find (qn_name callee) mcls)
    (None None)
    ((Some (MCl _ _ cpForm cmsr _ _))
     (match (mc_pnames cpForm)
       (None None)
       ((Some cpnames) (mc_struct_pos cmsr cpnames))))))

(fn mc_struct_fail ((key (List Int)) (callee QName) (why (List Int))) (List Int)
  (mc_line
    key
    (append_int
      "FAIL: call to "
      (append_int (chars_of_sym (qn_name callee)) why))))

;; verify each recursive site: at the callee's declared position the argument
;; must be a strict subterm (AStrict) rooted at THIS member's declared index pi.
(fn mc_struct_sites
  ((key (List Int)) (sites (List MSite)) (pi Int) (mcls (List MCl)) (nok Int))
  (List Int)
  (measure (struct sites))
  (match sites
    (Nil
      (mc_line key (append_int "OK (" (append_int (mc_show_i nok) " site(s))"))))
    ((Cons (MSite _ callee args) rest)
     (match (mc_callee_struct_pos callee mcls)
       (None (mc_struct_fail key callee " has no (struct …) clause"))
       ((Some pj)
        (match (ad_cls_at args pj)
          ((AStrict p)
           (if (int_eq p pi) (mc_struct_sites key rest pi mcls (+ nok 1))
           (mc_struct_fail
             key
             callee
             " — argument is a subterm of a parameter other than the one declared")))
          ((ASame _)
           (mc_struct_fail
             key
             callee
             " — argument is the parameter itself, not a strict subterm"))
          ((AOther)
           (mc_struct_fail
             key
             callee
             " — argument is not a subterm of the declared parameter"))))))))

;; the structural verifier entry: resolve THIS member's declared index, gather
;; its recursive sites (admit's elaborated-Expr walk), verify each.
(fn mc_check_struct
  ((key (List Int))
   (fd FnDef)
   (scc (List QName))
   (pnames (List Symbol))
   (msr SExpr)
   (mcls (List MCl)))
  (List Int)
  (match (mc_struct_pos msr pnames)
    (None
      (mc_line key "FAIL: malformed (struct ARG) — ARG must name a parameter"))
    ((Some pi)
     (let ((sites (ad_fn_sites scc fd)))
       (match sites
         (Nil (mc_line key "OK (no recursive call sites)"))
         (_ (mc_struct_sites key sites pi mcls 0)))))))

;; walk the sites pairing each SUPPORTED site with its proof pair.
;; per-site outcome: SiteHalt stops the whole loop with one line (a setup error
;; — no measure / arity / unsupported / missing proofs — that the old recursive
;; form returned without a continuation); SiteGo carries this site's output, the
;; remaining proofs, and the running nok for the next iteration.
(type MSiteRes (SiteHalt (List Int)) (SiteGo (List Int) (List SExpr) Int))

;; The site loop. STRUCTURAL on `sites`: each iteration consumes one site (the
;; per-site work is the non-recursive mc_one_site) and recurses on the tail. The
;; recursion used to live in the pass-through forwarders mc_site_go/mc_typed_site
;; (they carried the already-shrunk tail and called back with it unchanged — no
;; structural drop on that edge); relocating it here makes every edge a strict
;; subterm step ⇒ a plain (struct sites) measure, no lex offsets.
(fn mc_check_sites
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (fname Symbol)
   (key (List Int))
   (pForm SExpr)
   (pnames (List Symbol))
   (msr SExpr)
   (sites (List MSiteS))
   (proofs (List SExpr))
   (nok Int)
   (mcls (List MCl))
   (autos (List (Pair Symbol SExpr))))
  (List Int)
  (measure (struct sites))
  (match sites
    (Nil
      (match proofs
        (Nil
          (mc_line
            key
            (append_int "OK (" (append_int (mc_show_i nok) " site(s))"))))
        (_ (mc_line key "FAIL: leftover proofs after the last site"))))
    ((Cons site rest)
     (match
       (mc_one_site m m2 th gctx fname key pForm pnames msr site proofs nok mcls
         autos)
       ((SiteHalt line) line)
       ((SiteGo out prest nok2)
        (append_int
          out
          (mc_check_sites m m2 th gctx fname key pForm pnames msr rest prest
            nok2 mcls autos)))))))

;; one site's setup: resolve the callee measure, substitute the call args, then
;; take the pure-measure path (goal over params) or the typed-binder path. The
;; tail (mc_one_site_pair) checks the inline proof pair. Non-recursive — the loop
;; lives in mc_check_sites.
(fn mc_one_site
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (fname Symbol)
   (key (List Int))
   (pForm SExpr)
   (pnames (List Symbol))
   (msr SExpr)
   (site MSiteS)
   (proofs (List SExpr))
   (nok Int)
   (mcls (List MCl))
   (autos (List (Pair Symbol SExpr))))
  MSiteRes
  (match site
    ((MSiteS i bnds tbs hyps args callee)
     (match (mc_callee_measure callee mcls)
       (None
         (SiteHalt
           (mc_line
             key
             (append_int
               "FAIL site "
               (append_int
                 (mc_show_i i)
                 (append_int
                   ": SCC member "
                   (append_int
                     (chars_of_sym (qn_name callee))
                     " has no measure clause")))))))
       ((Some (Pair cpnames cmsr))
        (match (mc_zip cpnames args)
          (None
            (SiteHalt
              (mc_line
                key
                (append_int
                  "FAIL site "
                  (append_int (mc_show_i i) ": arity mismatch at the call")))))
          ((Some sub)
           (let ((msr2 (mc_subst sub cmsr)))
             (if (mc_pure msr2 pnames bnds)
               (match (mc_keep_hyps hyps pnames bnds)
                 ((Pair khyps ndrop)
                  (mc_one_site_pair m m2 th gctx fname key pForm khyps ndrop
                    msr2 msr i proofs nok autos)))
               (mc_one_site_typed m m2 th gctx fname key pForm pnames msr i tbs
                 hyps msr2 proofs nok autos))))))))))

;; the typed-binder path: the measure substitution references pattern
;; binders, so the obligation is stated over the fn params PLUS the typed
;; binders in scope (hyps mentioning an UNTYPED binder still drop, with
;; the note). Binder names must be fresh against the params — a shadowing
;; pattern would alias two distinct values in one goal.
(fn mc_one_site_typed
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (fname Symbol)
   (key (List Int))
   (pForm SExpr)
   (pnames (List Symbol))
   (msr SExpr)
   (i Int)
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (msr2 SExpr)
   (proofs (List SExpr))
   (nok Int)
   (autos (List (Pair Symbol SExpr))))
  MSiteRes
  (let ((tbn (mc_tb_names tbs Nil)))
    (if (mc_tbs_fresh tbn pnames)
      (let ((alln (mc_app_syms tbn pnames)))
        (if (mc_pure msr2 alln Nil)
          (match (mc_ext_pform pForm tbs)
            (None (SiteHalt (mc_line key "SKIP (could not read param names)")))
            ((Some pForm2)
             (match (mc_keep_hyps hyps alln Nil)
               ((Pair khyps ndrop)
                (mc_one_site_pair m m2 th gctx fname key pForm2 khyps ndrop msr2
                  msr i proofs nok autos)))))
          (SiteHalt
            (mc_line
              key
              (append_int
                "UNSUPPORTED site "
                (append_int
                  (mc_show_i i)
                  " (measure argument references pattern/let binders)"))))))
      (SiteHalt
        (mc_line
          key
          (append_int
            "UNSUPPORTED site "
            (append_int (mc_show_i i) " (a pattern binder shadows a parameter)")))))))

;; pair the site's two inline proofs (decrease, nonneg) against pFormX —
;; the fn's params, possibly extended with typed binders — then continue.
;; pair the site's two inline proofs (decrease, nonneg) against pFormX — the
;; fn's params, possibly extended with typed binders. Non-recursive: returns a
;; SiteGo carrying this site's output (a bad-cert message + drop note, or empty)
;; the remaining proofs, and the updated nok; mc_check_sites drives the loop.
;; A missing proof pair halts (the old form returned the line with no recurse).
(fn mc_one_site_pair
  ((m Module)
   (m2 Module)
   (th Theory)
   (gctx RCtx)
   (fname Symbol)
   (key (List Int))
   (pFormX SExpr)
   (khyps (List SExpr))
   (ndrop Int)
   (msr2 SExpr)
   (msr SExpr)
   (i Int)
   (proofs (List SExpr))
   (nok Int)
   (autos (List (Pair Symbol SExpr))))
  MSiteRes
  (match proofs
    (Nil
      (SiteHalt
        (mc_line
          key
          (append_int
            "FAIL site "
            (append_int
              (mc_show_i i)
              ": no proofs left (need decrease + nonneg)")))))
    ((Cons p1 prest1)
     (match prest1
       (Nil
         (SiteHalt
           (mc_line
             key
             (append_int
               "FAIL site "
               (append_int
                 (mc_show_i i)
                 ": only one proof left (need decrease + nonneg)")))))
       ((Cons p2 prest)
        (match
          (mc_site_pair m m2 th gctx fname key pFormX khyps msr2 msr i p1 p2
            autos)
          ;; CONTINUE past a failing site (collect every FAIL, not just the
          ;; first) — invisible when all sites pass (nok = total, output
          ;; byte-identical to before), but surfaces all slot/cert errors in a
          ;; single run during development.
          ((Some bad)
           (SiteGo (append_int bad (mc_drop_note key ndrop)) prest nok))
          (None (SiteGo Nil prest (+ nok 1)))))))))

;; typed-binder goal-param plumbing.
(fn mc_tb_names ((tbs (List (Pair Symbol Type))) (acc (List Symbol)))
  (List Symbol)
  (measure (struct tbs))
  (match tbs
    (Nil acc)
    ((Cons (Pair n _) rest) (mc_tb_names rest (Cons n acc)))))

(fn mc_tbs_fresh ((names (List Symbol)) (pnames (List Symbol))) Bool
  (measure (struct names))
  (match names
    (Nil True)
    ((Cons n rest)
     (if (mc_sym_member n pnames) False
     (if (mc_sym_member n rest) False
     (mc_tbs_fresh rest pnames))))))

;; tbs is innermost-first; the fold reverses, so the appended binder params
;; read outermost-first after the fn's own params.
(fn mc_tb_param_forms ((tbs (List (Pair Symbol Type))) (acc (List SExpr)))
  (List SExpr)
  (measure (struct tbs))
  (match tbs
    (Nil acc)
    ((Cons (Pair n ty) rest)
     (mc_tb_param_forms
       rest
       (Cons (SList (Cons (SSym n) (Cons (mc_ty_form ty) Nil))) acc)))))

(fn mc_app_forms ((a (List SExpr)) (b (List SExpr))) (List SExpr)
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (mc_app_forms t b)))))

(fn mc_ext_pform ((pForm SExpr) (tbs (List (Pair Symbol Type)))) (Option SExpr)
  (match pForm
    ((SList ps) (Some (SList (mc_app_forms ps (mc_tb_param_forms tbs Nil)))))
    (_ None)))

;; param name → type env from the looked-up FnDef (order matches pForm).
(fn mc_fd_penv ((ns (List Symbol)) (fd FnDef)) (List (Pair Symbol Type))
  (match fd
    ((FnDef _ ptys _ _) (mc_penv_zip ns ptys))))

(fn mc_penv_zip ((ns (List Symbol)) (tys (List Type))) (List (Pair Symbol Type))
  (measure (struct ns))
  (match ns
    (Nil Nil)
    ((Cons n nrest)
     (match tys
       (Nil Nil)
       ((Cons ty trest) (Cons (Pair n ty) (mc_penv_zip nrest trest)))))))

;; a bare numeric `(measure E)` clause (no inline proofs) means every recursive
;; site takes its decrease + nonneg proof from the sidecar: synthesize the `auto`
;; token twice per site (decrease, nonneg), in site order. mc_site_pair then
;; resolves each by its per-site synthetic key (mc_site_key). When the author
;; DID write inline proofs, mc_check_fn keeps them verbatim — back-compatible.
(fn mc_auto_proofs ((sites (List MSiteS))) (List SExpr)
  (measure (struct sites))
  (match sites
    (Nil Nil)
    ((Cons _ rest)
     (Cons (SSym (quote auto)) (Cons (SSym (quote auto)) (mc_auto_proofs rest))))))

(fn mc_check_fn
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (gctx RCtx)
   (modpath (List Symbol))
   (mcl MCl)
   (mcls (List MCl))
   (autos (List (Pair Symbol SExpr))))
  (List Int)
  (match mcl
    ((MCl name tparams pForm msr proofs body)
     (match m
       ((Module _ fns _ tr _)
        (let ((q (QName modpath name)))
          ;; Resolve the fn the clause names. A same-module fn keys exactly in
          ;; the modpath trie; a REBOUND opaque sig fn (std/list, std/bytes, …)
          ;; lives at its INTERFACE qname, not the file's module path, so the
          ;; trie misses — fall back to a unique short-name scan (mc_synth's
          ;; rebind idiom). The fd's own qname (rq) is then the gate identity:
          ;; trie/SCC keys + the display line all use rq, never the file path.
          (match
            (match (trie_lookup q tr)
              ((Some fd) (Some fd))
              (None (mc_uniq_short fns name)))
            (None
              (mc_line
                (qn_key_chars q)
                "SKIP (fn not found at the file's module path — rebind?)"))
            ((Some fd)
             (match fd
               ((FnDef rq _ _ _)
                (let ((key (qn_key_chars rq)))
                  (match (mc_pnames pForm)
                    (None (mc_line key "SKIP (could not read param names)"))
                    ((Some pnames)
                     ;; SCC keyed by the fn's REAL qname (rq), so a rebound fn's
                     ;; SCC is found. Needed by the walk (sibling recognition)
                     ;; AND opacity/citation, so compute it first.
                     (let ((scc (mc_scc_of rq sccs)))
                       (if (mc_is_struct msr)
                         ;; Structural descent is a SYNTACTIC strict-subterm
                         ;; check, independent of the element TYPE — so it
                         ;; verifies POLYMORPHIC fns (std/list append/len/…)
                         ;; exactly as monomorphic ones. Only NUMERIC measures
                         ;; (farkas needs typed goals) stay monomorphic-only.
                         (mc_check_struct key fd scc pnames msr mcls)
                         (match tparams
                           ((Cons _ _)
                            (mc_line
                              key
                              "SKIP (type-parametric fn — v1 numeric measures are monomorphic)"))
                           (Nil
                             (match
                               (mc_walk
                                 (MCtx
                                   m
                                   modpath
                                   name
                                   (mc_fd_penv pnames fd)
                                   scc)
                                 Nil
                                 Nil
                                 Nil
                                 body
                                 (Pair 0 Nil))
                               ((Pair _ rsites)
                                (let ((sites (mc_rev_sites rsites Nil)))
                                  (match sites
                                    (Nil
                                      (mc_line
                                        key
                                        "OK (no recursive call sites)"))
                                    (_
                                      (mc_check_sites
                                        m
                                        (mc_opaque m scc)
                                        (mc_theory_for_scc tr scc th)
                                        gctx
                                        name
                                        key
                                        pForm
                                        pnames
                                        msr
                                        sites
                                        (match proofs
                                          (Nil (mc_auto_proofs sites))
                                          (_ proofs))
                                        0
                                        mcls
                                        autos)))))))))))))))))))))))

(fn mc_rev_sites ((xs (List MSiteS)) (acc (List MSiteS))) (List MSiteS)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (mc_rev_sites t (Cons h acc)))))

;; ---- citable theory for measure obligations (STRATIFIED CITATION) ----------
;; A measure obligation proving fn F (its SCC = `scc`) total may cite a fact L
;; iff L's STATEMENT cannot reach any member of `scc` through the call graph —
;; i.e. L does not depend, directly or transitively, on the very fn(s) being
;; shown total. That is the acyclicity rule: an unproven lemma may not prove
;; itself, directly or indirectly.
;;
;; This unifies the two old citation sources. Granted-module requirements live
;; upstream and structurally cannot reach F, so they pass automatically; same-
;; closure claims pass exactly when they are downstream of F. The pool is the
;; run's accumulated theory (granted axioms + this run's PASSED claims — run_decls
;; folds both in as Axiom/Proven), filtered here per F. This supersedes the old
;; granted-only filter AND the blanket same-closure ban: the call-graph test is
;; the precise, order-independent statement of both.

;; the resolvable callee QNames mentioned in a stored goal's statement
;; (premises + conclusion). Prims/externs don't resolve and are excluded.
(fn mc_eq_calls ((tr FnTrie) (eq Equation) (acc (List QName))) (List QName)
  (match eq
    ((Equation l r) (ad_calls_e tr l (ad_calls_e tr r acc)))))

(fn mc_eqs_calls ((tr FnTrie) (eqs (List Equation)) (acc (List QName)))
  (List QName)
  (measure (struct eqs))
  (match eqs
    (Nil acc)
    ((Cons e rest) (mc_eqs_calls tr rest (mc_eq_calls tr e acc)))))

(fn mc_goal_calls ((tr FnTrie) (g Goal) (acc (List QName))) (List QName)
  (match g
    ((Goal _ prems concl) (mc_eqs_calls tr prems (mc_eq_calls tr concl acc)))))

;; True iff some fn transitively reachable from `work` (following fn bodies via
;; the full module trie) is a member of `scc`. `seen` bounds the walk to the
;; finite call graph — each fn is expanded at most once, so the walk halts after
;; at most |work| + (total call-graph edges) steps. That bound is data-weighted
;; over the trie (its honest measure needs the trie<->fns consistency bridge —
;; deferred); for totality (issue #1) we instead fuel the walk. The recursion is
;; non-structural (the expand arm GROWS work with the body's calls). Public
;; wrapper seeds a generous budget; the `_go` core carries (measure fuel).
;; Give-up returns True (conservative: "reaches scc" => the theory entry is NOT
;; citable for this scc => sound, just over-restrictive — a proof could fail to
;; find a lemma and be rejected, never falsely admitted). The budget exceeds any
;; real call graph, so give-up is dead on well-formed input.
(fn mc_reach_budget () Int 1000000000)

(fn mc_reaches
  ((tr FnTrie) (work (List QName)) (seen (List QName)) (scc (List QName)))
  Bool
  (mc_reaches_go tr work seen scc (mc_reach_budget)))

(fn mc_reaches_go
  ((tr FnTrie)
   (work (List QName))
   (seen (List QName))
   (scc (List QName))
   (fuel Int))
  Bool
  (measure
    fuel
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1))
    (by arith (list 1 0))
    (by arith (list 1 1)))
  (if (lt fuel 1) True
  (match work
    (Nil False)
    ((Cons q rest)
     (if (ad_qn_member q scc) True
     (if (ad_qn_member q seen) (mc_reaches_go tr rest seen scc (- fuel 1))
     (match (trie_lookup q tr)
       (None (mc_reaches_go tr rest (Cons q seen) scc (- fuel 1)))
       ((Some (FnDef _ _ _ body))
        (mc_reaches_go
          tr
          (ad_calls_e tr body rest)
          (Cons q seen)
          scc
          (- fuel 1))))))))))

;; a theory entry is citable for `scc` iff its statement can't reach `scc`.
(fn mc_entry_safe ((tr FnTrie) (scc (List QName)) (entry TheoryEntry)) Bool
  (match entry
    ((Proven _ g)
     (if (mc_reaches tr (mc_goal_calls tr g Nil) Nil scc) False True))
    ((Axiom _ g)
     (if (mc_reaches tr (mc_goal_calls tr g Nil) Nil scc) False True))))

;; filter the run's full theory down to what F's SCC may soundly cite.
(fn mc_theory_for_scc ((tr FnTrie) (scc (List QName)) (th Theory)) Theory
  (measure (struct th))
  (match th
    (TheoryEmpty TheoryEmpty)
    ((TheoryCons entry rest)
     (let ((kept (mc_theory_for_scc tr scc rest)))
       (if (mc_entry_safe tr scc entry) (TheoryCons entry kept) kept)))))

;; ---- GENERATOR SUPPORT: emit measure obligations (NOT in the check path) ----
;; tools/prove uses these to DISCOVER what a bare `(measure E)` clause must
;; prove, so the offline solver can search each obligation and persist the cert
;; keyed by mc_site_key. The derivation MIRRORS mc_check_fn / mc_check_sites /
;; mc_one_site / mc_one_site_typed exactly — same mc_walk sites, same callee-measure substitution,
;; same mc_keep_hyps / typed-binder handling, same mc_goal_s — so a generated
;; proof is searched against the IDENTICAL obligation the gate later checks. The
;; checker never calls these, and a derivation mismatch could only make the gate
;; REJECT the cert (never falsely accept it), so this stays out of the TCB.
;; Each supported site yields two entries: <fn>#<i>#decrease and #nonneg.
;; Unsupported / no-measure / arity-mismatch sites emit nothing (the gate
;; reports them; there is no cert to generate).

;; the two goal obligations for one site, consed onto `tail`.
(fn mc_ob_emit
  ((name Symbol)
   (i Int)
   (pFormX SExpr)
   (khyps (List SExpr))
   (msr2 SExpr)
   (msr SExpr)
   (tail (List (Pair Symbol SExpr))))
  (List (Pair Symbol SExpr))
  (Cons
    (Pair
      (mc_site_key name i "decrease")
      (mc_goal_s pFormX khyps (quote lt) msr2 msr))
    (Cons
      (Pair
        (mc_site_key name i "nonneg")
        (mc_goal_s pFormX khyps (quote le) (SInt 0) msr2))
      tail)))

;; one site: derive (pFormX, khyps, msr2) the same two ways mc_check_sites does
;; (simple param-pure path / typed-binder path), then emit; or pass `tail`
;; through unchanged when the site is unsupported.
(fn mc_ob_site_join
  ((name Symbol)
   (pForm SExpr)
   (pnames (List Symbol))
   (msr SExpr)
   (i Int)
   (bnds (List Symbol))
   (tbs (List (Pair Symbol Type)))
   (hyps (List SExpr))
   (args (List SExpr))
   (callee QName)
   (mcls (List MCl))
   (tail (List (Pair Symbol SExpr))))
  (List (Pair Symbol SExpr))
  (match (mc_callee_measure callee mcls)
    (None tail)
    ((Some (Pair cpnames cmsr))
     (match (mc_zip cpnames args)
       (None tail)
       ((Some sub)
        (let ((msr2 (mc_subst sub cmsr)))
          (if (mc_pure msr2 pnames bnds)
            (match (mc_keep_hyps hyps pnames bnds)
              ((Pair khyps _) (mc_ob_emit name i pForm khyps msr2 msr tail)))
            (let ((tbn (mc_tb_names tbs Nil)))
              (if (mc_tbs_fresh tbn pnames)
                (let ((alln (mc_app_syms tbn pnames)))
                  (if (mc_pure msr2 alln Nil)
                    (match (mc_ext_pform pForm tbs)
                      (None tail)
                      ((Some pForm2)
                       (match (mc_keep_hyps hyps alln Nil)
                         ((Pair khyps _)
                          (mc_ob_emit name i pForm2 khyps msr2 msr tail)))))
                    tail))
                tail)))))))))

(fn mc_ob_sites
  ((name Symbol)
   (pForm SExpr)
   (pnames (List Symbol))
   (msr SExpr)
   (sites (List MSiteS))
   (mcls (List MCl)))
  (List (Pair Symbol SExpr))
  (measure (struct sites))
  (match sites
    (Nil Nil)
    ((Cons (MSiteS i bnds tbs hyps args callee) rest)
     (mc_ob_site_join
       name
       pForm
       pnames
       msr
       i
       bnds
       tbs
       hyps
       args
       callee
       mcls
       (mc_ob_sites name pForm pnames msr rest mcls)))))

;; the obligations for one clause; Nil for struct / type-parametric / not-found
;; / unreadable clauses (nothing to generate).
(fn mc_obligations_for
  ((m Module)
   (sccs (List (List QName)))
   (modpath (List Symbol))
   (mcl MCl)
   (mcls (List MCl)))
  (List (Pair Symbol SExpr))
  (match mcl
    ((MCl name tparams pForm msr proofs body)
     (match tparams
       ((Cons _ _) Nil)
       (Nil
         (if (mc_is_struct msr) Nil
         (match m
           ((Module _ _ _ tr _)
            (match (trie_lookup (QName modpath name) tr)
              (None Nil)
              ((Some fd)
               (match (mc_pnames pForm)
                 (None Nil)
                 ((Some pnames)
                  (let ((scc (mc_scc_of (QName modpath name) sccs)))
                    (match
                      (mc_walk
                        (MCtx m modpath name (mc_fd_penv pnames fd) scc)
                        Nil
                        Nil
                        Nil
                        body
                        (Pair 0 Nil))
                      ((Pair _ rsites)
                       (mc_ob_sites
                         name
                         pForm
                         pnames
                         msr
                         (mc_rev_sites rsites Nil)
                         mcls))))))))))))))))

;; a clause whose proofs must be GENERATED: numeric (non-struct) and bare (no
;; inline proofs). Inline-proof clauses are left alone (the gate uses their
;; proofs, never the sidecar), and struct clauses carry no numeric proofs.
(fn mc_is_bare_numeric ((mcl MCl)) Bool
  (match mcl
    ((MCl _ _ _ msr proofs _)
     (match proofs
       (Nil (if (mc_is_struct msr) False True))
       (_ False)))))

(fn mc_pair_app ((a (List (Pair Symbol SExpr))) (b (List (Pair Symbol SExpr))))
  (List (Pair Symbol SExpr))
  (measure (struct a))
  (match a
    (Nil b)
    ((Cons h t) (Cons h (mc_pair_app t b)))))

(fn mc_file_obligations
  ((m Module)
   (sccs (List (List QName)))
   (modpath (List Symbol))
   (todo (List MCl))
   (all (List MCl)))
  (List (Pair Symbol SExpr))
  (measure (struct todo))
  (match todo
    (Nil Nil)
    ((Cons mcl rest)
     (mc_pair_app
       (if (mc_is_bare_numeric mcl) (mc_obligations_for m sccs modpath mcl all)
       Nil)
       (mc_file_obligations m sccs modpath rest all)))))

;; generator entry: every (site-key, goal) obligation a file's BARE numeric
;; measure clauses must prove, given the file's already-built module `m`, its
;; source forms, and its module path. tools/prove turns each into an AutoDecl
;; and searches it; the cert is keyed by mc_site_key so the gate replays it.
(fn mc_obligations_of_forms
  ((m Module) (forms (List SExpr)) (modpath (List Symbol)))
  (List (Pair Symbol SExpr))
  (let ((all (mc_rev_mcls (mc_of_forms forms Nil) Nil)))
    (mc_file_obligations m (ad_sccs m) modpath all all)))

;; ---- the section entry ------------------------------------------------------

;; `todo` is the iteration cursor; `all` is the file's full clause list, passed
;; unchanged to every fn as its SCC sibling table (a member's measure obligation
;; needs its siblings' measures — see mc_callee_measure).
(fn mc_mcls
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (gctx RCtx)
   (modpath (List Symbol))
   (todo (List MCl))
   (all (List MCl))
   (autos (List (Pair Symbol SExpr))))
  (List Int)
  (measure (struct todo))
  (match todo
    (Nil Nil)
    ((Cons mcl rest)
     (append_int
       (mc_check_fn m sccs th gctx modpath mcl all autos)
       (mc_mcls m sccs th gctx modpath rest all autos)))))

(fn mc_files
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (srcs (List SrcEntry))
   (sidecars (List (Pair Symbol (List Int)))))
  (List Int)
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons (SrcEntry path granted src) rest)
     (match (read_all src)
       (None (mc_files m sccs th rest sidecars))
       ((Some forms)
        (let ((mcls (mc_of_forms forms Nil)))
          (match mcls
            (Nil (mc_files m sccs th rest sidecars))
            (_
              (let ((allmcls (mc_rev_mcls mcls Nil)))
                (append_int
                  (mc_mcls
                    m
                    sccs
                    th
                    (file_rctx m path src)
                    (module_path_of path)
                    allmcls
                    allmcls
                    (autos_of_src (sym_of_chars path) sidecars))
                  (mc_files m sccs th rest sidecars)))))))))))

(fn mc_rev_mcls ((xs (List MCl)) (acc (List MCl))) (List MCl)
  (measure (struct xs))
  (match xs
    (Nil acc)
    ((Cons h t) (mc_rev_mcls t (Cons h acc)))))

;; ---- failure detection for the enforcement flip (issue #1, Phase D) ---------
;; needle is a contiguous prefix of hay.
(fn mc_prefix ((needle (List Int)) (hay (List Int))) Bool
  (measure (struct needle))
  (match needle
    (Nil True)
    ((Cons n nt)
     (match hay
       (Nil False)
       ((Cons h ht) (if (int_eq n h) (mc_prefix nt ht) False))))))

;; needle occurs as a contiguous substring of hay.
(fn mc_has_sub ((hay (List Int)) (needle (List Int))) Bool
  (measure (struct hay))
  (if (mc_prefix needle hay) True
  (match hay
    (Nil False)
    ((Cons _ ht) (mc_has_sub ht needle)))))

;; True iff some MEASURED line in the rendered block reports a FAIL verdict.
;; Every failure line is "MEASURED <key> FAIL…"; keys are space-free QName
;; renderings, so the token " FAIL" appears ONLY as a verdict word (never inside
;; a key), making this an exact discriminator against OK / SKIP lines.
(fn mc_any_fail ((lines (List Int))) Bool (mc_has_sub lines " FAIL"))

;; ---- proof-ADMISSION accounting (issue #1, Phase D) ------------------------
;; The totality gate refuses non-terminating fns that are ADMITTED TO THE PROOF
;; SYSTEM — used as a component of a proof — not every recursive fn that merely
;; exists in a loaded file. A fn is admitted when a proof REACHES it through the
;; call graph: an `unfold`/`reduce`/`compute` step uses its defining equation, so
;; its non-totality would be unsound. A closure with no proofs admits nothing —
;; the interpreter (ev) and the offline solver (prove) are programs, not proof
;; components, and stay un-gated though genuinely partial.
;;
;; The seed is every fn NAMED ANYWHERE in a proof-bearing form (claim / fulfills
;; / requirement / returns / axiom) — goal AND proof body, so a fn pulled into
;; reduction by a `have` / `case-on` / `unfold` operand (not just the goal's
;; fns) is caught. Symbols naming no fn drop out (mc_uniq_short). This is an
;; OVER-approximation by construction: a spurious seed only over-restricts (asks
;; a measure of a fn no proof truly reduced) — it can never admit a non-total fn.
;; The advisory admit report (mc_residual_report) is unchanged: it still lists
;; ALL unannotated recursive SCCs; only the ENFORCED gate is admission-scoped.

;; every SSym appearing anywhere in an SExpr.
(fn mc_form_syms ((s SExpr) (acc (List Symbol))) (List Symbol)
  (measure (struct s))
  (match s
    ((SSym x) (Cons x acc))
    ((SList items) (mc_form_syms_list items acc))
    (_ acc)))

(fn mc_form_syms_list ((items (List SExpr)) (acc (List Symbol))) (List Symbol)
  (measure (struct items))
  (match items
    (Nil acc)
    ((Cons it rest) (mc_form_syms_list rest (mc_form_syms it acc)))))

;; symbols → fn QNames (a symbol naming no fn drops out), accumulated.
(fn mc_syms_to_fns ((fns (List FnDef)) (syms (List Symbol)) (acc (List QName)))
  (List QName)
  (measure (struct syms))
  (match syms
    (Nil acc)
    ((Cons s rest)
     (match (mc_uniq_short fns s)
       ((Some (FnDef rq _ _ _)) (mc_syms_to_fns fns rest (Cons rq acc)))
       (None (mc_syms_to_fns fns rest acc))))))

;; a proof-bearing top-level form: its named fns seed the admission walk.
(fn mc_is_proof_form ((h Symbol)) Bool
  (if (sym_eq h (quote claim)) True
  (if (sym_eq h (quote fulfills)) True
  (if (sym_eq h (quote requirement)) True
  (if (sym_eq h (quote returns)) True
  (if (sym_eq h (quote axiom)) True
  False))))))

(fn mc_seed_of_forms ((forms (List SExpr)) (acc (List Symbol))) (List Symbol)
  (measure (struct forms))
  (match forms
    (Nil acc)
    ((Cons f rest)
     (match (form_head f)
       (None (mc_seed_of_forms rest acc))
       ((Some h)
        (if (mc_is_proof_form h) (mc_seed_of_forms rest (mc_form_syms f acc))
        (mc_seed_of_forms rest acc)))))))

;; the closure's proof-admission seed: fn QNames named in any proof form.
(fn mc_proof_seed ((fns (List FnDef)) (srcs (List SrcEntry)) (acc (List QName)))
  (List QName)
  (measure (struct srcs))
  (match srcs
    (Nil acc)
    ((Cons (SrcEntry _ _ src) rest)
     (match (read_all src)
       (None (mc_proof_seed fns rest acc))
       ((Some forms)
        (mc_proof_seed
          fns
          rest
          (mc_syms_to_fns fns (mc_seed_of_forms forms Nil) acc)))))))

;; keep only the unannotated members a proof actually reaches (admitted). For a
;; mutual SCC, reaching one member reaches the rest through the cycle, so each
;; member is tested against the seed independently with no loss.
(fn mc_filter_admitted
  ((tr FnTrie) (seed (List QName)) (qs (List QName)) (acc (List QName)))
  (List QName)
  (measure (struct qs))
  (match qs
    (Nil acc)
    ((Cons q rest)
     (if (mc_reaches tr seed Nil (Cons q Nil))
       (mc_filter_admitted tr seed rest (Cons q acc))
       (mc_filter_admitted tr seed rest acc)))))

;; one hard COFail per recursive-SCC member that declares no (measure …) clause.
(fn mc_residual_cofails ((qs (List QName))) (List ClaimOutcome)
  (measure (struct qs))
  (match qs
    (Nil Nil)
    ((Cons q rest)
     (Cons
       (COFail
         (sym_of_chars (qn_key_chars q))
         "non-terminating: recursive SCC declares no (measure …) clause"
         Nil)
       (mc_residual_cofails rest)))))

;; MEASURE OBLIGATIONS in the normal check pass (issue #1, Phase D — ENFORCED).
;; Emits the informative COLedger block as before, but the totality gate is now
;; a HARD gate: a closure FAILS the run when either
;;   (a) a recursive SCC that is ADMITTED TO THE PROOF SYSTEM declares no
;;       (measure …) clause — mc_unannot_go ∩ mc_filter_admitted, or
;;   (b) a declared clause is not verified              — a FAIL in the block.
;; "Admitted" = reached by a proof through the call graph (see mc_proof_seed);
;; a recursive fn no proof reduces (the interpreter, the offline solver) is a
;; program, not a proof component, and does not move the gate. Each (a) is one
;; COFail naming the unannotated fn; (b) is one COFail pointing at the block. A
;; measure-free / fully-verified closure is byte-unchanged (no COFail, same
;; COLedger), so only genuinely non-terminating proof components move.
;; `th` is the run's accumulated theory (granted axioms + this run's passed
;; claims); mc_check_fn filters it per fn under the stratified-citation rule.
;; Skipped under focus mode (totality is a whole-closure property, and focus
;; admits unproven claims that must not seed measure citations).
(fn mc_outcome
  ((m Module)
   (srcs (List SrcEntry))
   (sidecars (List (Pair Symbol (List Int))))
   (th Theory)
   (focus Symbol))
  (List ClaimOutcome)
  (if (sym_eq focus (quote __all__))
    (match m
      ((Module _ fns _ tr _)
       (let ((sccs (ad_sccs m)))
         (let ((lines (mc_files m sccs th srcs sidecars)))
           (let
             ((missing
                (mc_filter_admitted
                  tr
                  (mc_proof_seed fns srcs Nil)
                  (mc_unannot_go tr sccs (mc_clause_qns tr fns srcs Nil) Nil)
                  Nil)))
             (oc_concat
               (match lines
                 (Nil Nil)
                 (_
                   (Cons
                     (COLedger
                       (append_int
                         "---- measure obligations ----"
                         (append_int (sr_nl) lines)))
                     Nil)))
               (oc_concat
                 (mc_residual_cofails missing)
                 (if (mc_any_fail lines)
                   (Cons
                     (COFail
                       (quote __totality__)
                       "a declared (measure …) obligation was not verified — see the measure obligations block above"
                       Nil)
                     Nil)
                   Nil))))))))
    Nil))

;; ===========================================================================
;; REFINED-RETURN OBLIGATIONS (refinement types, slice 2 — ENFORCED).
;; A fn `(fn f PARAMS R BODY)` whose return type R = (refine BASE PRED) is
;; admitted with an ordinary BASE-typed body (tc_fn_body_ret relaxes the
;; body↔return unification in types.shard). That relaxation is ONLY sound if
;; every such fn discharges
;;     ∀PARAMS, (= (PRED (refine_val (f PARAMS))) True)
;; — the proof that f's result really lands in R. The proof is supplied by a
;; SEPARATE top-level form `(returns f PROOF)` (not a fn clause, so a recursive
;; refined-return fn keeps its (measure …) clause unchanged). This gate emits a
;; HARD COFail when the obligation is missing or its proof is rejected; it is
;; silent on success, so a closure with no refined-return fn is byte-unchanged.
;;
;; SOUNDNESS — why EVERY fn in the closure is checked (not just the targets):
;; refine-fact (slice 1) will inject (= (PRED (refine_val E)) True) for ANY E
;; whose inferred head is R, in ANY file. So an UNCHECKED refined-return fn g in
;; an imported file would let a consumer assume g's invariant for free. The gate
;; therefore walks all srcs, exactly as mc_files does for measure obligations.
;; The obligation is consumed but never re-published into the theory (its name is
;; the synthetic `f#returns`), so it can cite freely without circularity.
;; The proof is checked against the FULL module m (m2 = m) so it can unfold f.
;; See docs/REFINEMENT.md.
;; ===========================================================================

;; the declared return type of fn q, if q names a fn in m.
(fn rr_fn_ret ((m Module) (q QName)) (Option Type)
  (match m
    ((Module _ _ _ trie _)
     (match (trie_lookup q trie)
       (None None)
       ((Some fd)
        (match fd
          ((FnDef _ _ ret _) (Some ret))))))))

;; the predicate QName of fn q's return type, if that return is refined; else
;; None (not a fn, or an ordinary return).
(fn rr_pred_of ((m Module) (q QName)) (Option QName)
  (match (rr_fn_ret m q)
    (None None)
    ((Some ret)
     (match (type_head ret)
       (None None)
       ((Some (Pair rname _))
        (match (typedef_refine rname m)
          (None None)
          ((Some (Pair _ pred)) (Some pred))))))))

;; collect the file's (returns NAME PROOF) forms into a name→proof table.
(fn rr_returns ((forms (List SExpr)) (acc (List (Pair Symbol SExpr))))
  (List (Pair Symbol SExpr))
  (measure (struct forms))
  (match forms
    (Nil acc)
    ((Cons f rest)
     (match (form_head f)
       (None (rr_returns rest acc))
       ((Some h)
        (if (sym_eq h (quote returns))
          (match (form_tail f)
            ((Cons (SSym name) (Cons proofS Nil))
             (rr_returns rest (Cons (Pair name proofS) acc)))
            (_ (rr_returns rest acc)))  ; malformed → no proof; fn COFails below
          (rr_returns rest acc)))))))

(fn rr_proof_for ((name Symbol) (rs (List (Pair Symbol SExpr)))) (Option SExpr)
  (measure (struct rs))
  (match rs
    (Nil None)
    ((Cons (Pair n p) rest)
     (if (sym_eq n name) (Some p) (rr_proof_for name rest)))))

;; the call args of the obligation: one (SSym pname) per param binder of pForm.
(fn rr_arg_syms ((binders (List SExpr))) (List SExpr)
  (measure (struct binders))
  (match binders
    (Nil Nil)
    ((Cons b rest)
     (match b
       ((SList (Cons headS _)) (Cons headS (rr_arg_syms rest)))
       (_ (rr_arg_syms rest))))))

(fn rr_args ((pForm SExpr)) (List SExpr)
  (match pForm
    ((SList binders) (rr_arg_syms binders))
    (_ Nil)))

;; the obligation goal sexpr: (goal PARAMS () (= (PRED (refine_val (f args))) True)).
;; PRED and f are written as exact (:: …) qnames so resolution cannot pick a
;; homonym (an unsound predicate substitution).
;; the obligation goal: (goal PARAMS () (= (PRED (self args)) True)). No
;; refine_val: this goal is checked against a module where `self`'s SCC is
;; DE-REFINED (return R → BASE; see rr_check), so (self args) : BASE and PRED
;; applies directly. The de-refinement is what makes refine-fact unable to fire
;; on `self` or a mutually-recursive sibling — closing the circularity by which
;; a refined-return obligation could otherwise prove ITSELF.
(fn rr_goal_s ((pForm SExpr) (pred QName) (self QName) (args (List SExpr)))
  SExpr
  (SList
    (Cons
      (SSym (quote goal))
      (Cons
        pForm
        (Cons
          (SList Nil)
          (Cons
            (mc_eq_s
              (SList
                (Cons
                  (mc_qn_form pred)
                  (Cons (SList (Cons (mc_qn_form self) args)) Nil)))
              (SSym (quote True)))
            Nil))))))

;; the synthetic claim name for f's obligation: `f#returns` (# is not a reader
;; delimiter, so this is one symbol — and it never collides with a real claim).
(fn rr_gname ((name Symbol)) Symbol
  (sym_of_chars (append_int (chars_of_sym name) "#returns")))

(fn rr_missing_msg ((name Symbol)) (List Int)
  (append_int
    "refined return: fn "
    (append_int
      (chars_of_sym name)
      " has a refined return type but no (returns …) proof — its refinement invariant is unproven")))

(fn rr_fail_msg ((name Symbol) (why (List Int))) (List Int)
  (append_int
    "refined return: fn "
    (append_int (chars_of_sym name) (append_int ": " why))))

;; ---- SCC de-refinement: the circularity guard --------------------------------
;; When checking f's refined-return obligation, every fn in f's recursive SCC has
;; its return type R lowered to BASE (tc_fn_body_ret does the R→BASE map). The fn
;; BODIES are untouched, so the proof can still unfold them; only the declared
;; return type changes, so a call (g args) to an SCC member types as BASE and
;; refine-fact — which keys off the head being a refined type — cannot grant its
;; invariant. This is the analogue of the measure gate's mc_opaque (which removes
;; the SCC) for an obligation whose goal must still MENTION the fn.
(fn rr_deref_fns ((m Module) (scc (List QName)) (fns (List FnDef))) (List FnDef)
  (measure (struct fns))
  (match fns
    (Nil Nil)
    ((Cons (FnDef q pts ret body) rest)
     (Cons
       (if (ad_qn_member q scc) (FnDef q pts (tc_fn_body_ret m ret) body)
       (FnDef q pts ret body))
       (rr_deref_fns m scc rest)))))

(fn rr_deref ((m Module) (scc (List QName))) Module
  (match m
    ((Module tds fns exts _ items)
     (let ((fns2 (rr_deref_fns m scc fns)))
       (Module tds fns2 exts (build_fn_trie fns2) items)))))

;; check one refined-return fn `name` (params pForm, predicate pred, in module
;; path `modpath`). Nil on success; one COFail on missing/failing proof. The
;; obligation is checked against m DE-REFINED over name's SCC (`sccs` = the run's
;; precomputed SCCs), so the proof cannot assume name's own refinement nor a
;; mutually-recursive sibling's — it must establish the invariant honestly.
(fn rr_check
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (gctx RCtx)
   (modpath (List Symbol))
   (name Symbol)
   (pForm SExpr)
   (pred QName)
   (rmap (List (Pair Symbol SExpr)))
   (autos (List (Pair Symbol SExpr))))
  (List ClaimOutcome)
  (match (rr_proof_for name rmap)
    (None (Cons (COFail name (rr_missing_msg name) Nil) Nil))
    ((Some proofS)
     (let ((m2 (rr_deref m (mc_scc_of (qn_at modpath name) sccs))))
       (match
         (mc_check_one
           m2
           m2
           th
           gctx
           (rr_gname name)
           (rr_goal_s pForm pred (qn_at modpath name) (rr_args pForm))
           proofS
           autos)
         (None Nil)
         ((Some why) (Cons (COFail name (rr_fail_msg name why) Nil) Nil)))))))

;; one form: if it is a fn with a refined return, check its obligation.
(fn rr_of_form
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (gctx RCtx)
   (modpath (List Symbol))
   (f SExpr)
   (rmap (List (Pair Symbol SExpr)))
   (autos (List (Pair Symbol SExpr))))
  (List ClaimOutcome)
  (match (form_head f)
    (None Nil)
    ((Some h)
     (if (sym_eq h (quote fn))
       (match (form_tail f)
         ((Cons nameForm (Cons pForm _))
          (match (parse_head nameForm)
            (None Nil)
            ((Some (Pair name _))
             (match (rr_pred_of m (qn_at modpath name))
               (None Nil)
               ((Some pred)
                (rr_check m sccs th gctx modpath name pForm pred rmap autos))))))
         (_ Nil))
       Nil))))

(fn rr_of_forms
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (gctx RCtx)
   (modpath (List Symbol))
   (forms (List SExpr))
   (rmap (List (Pair Symbol SExpr)))
   (autos (List (Pair Symbol SExpr))))
  (List ClaimOutcome)
  (measure (struct forms))
  (match forms
    (Nil Nil)
    ((Cons f rest)
     (oc_concat
       (rr_of_form m sccs th gctx modpath f rmap autos)
       (rr_of_forms m sccs th gctx modpath rest rmap autos)))))

(fn rr_files
  ((m Module)
   (sccs (List (List QName)))
   (th Theory)
   (srcs (List SrcEntry))
   (sidecars (List (Pair Symbol (List Int)))))
  (List ClaimOutcome)
  (measure (struct srcs))
  (match srcs
    (Nil Nil)
    ((Cons (SrcEntry path _ src) rest)
     (match (read_all src)
       (None (rr_files m sccs th rest sidecars))
       ((Some forms)
        (oc_concat
          (rr_of_forms
            m
            sccs
            th
            (file_rctx m path src)
            (module_path_of path)
            forms
            (rr_returns forms Nil)
            (autos_of_src (sym_of_chars path) sidecars))
          (rr_files m sccs th rest sidecars)))))))

;; the section entry: HARD COFails for unproven refined returns, closure-wide.
;; Skipped under focus mode (focus admits unproven claims that must not seed the
;; obligation's citable theory, and the property is whole-closure). The SCC set
;; is computed ONCE here and threaded down for the per-fn de-refinement.
(fn rr_outcome
  ((m Module)
   (srcs (List SrcEntry))
   (sidecars (List (Pair Symbol (List Int))))
   (th Theory)
   (focus Symbol))
  (List ClaimOutcome)
  (if (sym_eq focus (quote __all__)) (rr_files m (ad_sccs m) th srcs sidecars)
  Nil))

(fn check_production_src
  ((seed Module)
   (base_ctors (List Symbol))
   (srcs (List SrcEntry))
   (sidecars (List (Pair Symbol (List Int))))  ; from read_sidecars (loader)
   (target Symbol)
   (focus Symbol))
  (List ClaimOutcome)
  (match (build_module_d srcs seed base_ctors 1)
    ((BMFail diag) (Cons (COFail (quote __module__) diag Nil) Nil))
    ((BMOk m)
     ;; the type sweep over the assembled module (typedefs, externs/sigs, fn
     ;; bodies) runs first; its findings are HARD COTypeFail outcomes.
     (oc_concat
       (type_fail_outcomes (type_report m))
       (check_production
         m
         srcs
         (typedef_ctors (module_typedefs m))
         sidecars
         target
         focus)))))
